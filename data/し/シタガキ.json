    "definitions": [
      {
        "index": 1,
        "gloss": "draft",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また下書きなどをしてその上を綺麗に塗りつぶす月並なやり方の通弊を脱し得る所以であるまいか。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が目下書きまくっている種類の作品を書きつくした時、私は何を書くべきか、私には今はっきりとは判らない。",
              "citation": {
                "source": "私の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、仕方がなく、如上の下書きのある雑記帳をひろげ、冷汗を絞りつゝ訳文の筆を走らせた。",
              "citation": {
                "source": "消息抄（近頃書いた或る私の手紙から。）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本番の原稿を書くあてもないまま、日記にはかなり詳しく取材メモを整理した下書きを残しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の例と違って故人の名は現わさずに、死んだ愛人を阿弥陀仏にお託しするという意味を、愛のこもった文章で下書きをして源氏は見せた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから押絵の下絵は、お母様が錦絵を二十枚ばかり持っておいでになるのと、お弟子から借りてお写しになった沢山の下書きの中から生れて来るのでしたが、優しいのや厳めしいのが見ているうちに出来てくるその面白さ……。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が新聞に出そうと思った広告の下書きであった。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年五月発病当時も母は例の旅日記の下書きを整理中であったが、遂にそれを自身の手で完結する事が出来ず長逝したのであった。",
              "citation": {
                "source": "葭の影にそえて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄は姉の法名、佳室妙豊大姉というのを彫りつける下書きを文人的凝り性から、何百枚も書き直しては丹念に書いていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、作品の筋書、または未完成な下書きでもいい、作家はそれを工場クラブなどの一般集会で読んで、みんなの意見や忠告をきけ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この八月中に下書きだけでも出来上らせて仕舞わなければならないと思って居るのに一向に筆が進まない。",
              "citation": {
                "source": "曇天",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仏への願文を文章博士に作らせる下書きをした硯のついでに、薫は、あげまきに長き契りを結びこめ同じところに縒りも合はなん　と書いて大姫君に見せた。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことも、こと細かに、下書きをした上で、その日の日記帳に書き止められ、しかも彼女の批判がつけられてあるのが、浜子の仕方だった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は離れの一室に籠っているが笑われたくないとか、山田家で立かえるとしても、悠暢に遊ばせている金ではないとか、披露の式は都下の新聞紙にも掲載されるだろうから、その費用の領収証は取り揃えてお目にかけるというような下書きは、美妙が書いて渡した。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その次の日の午後二時頃、ひろ子が二階でニュースの下書きをしていると、誰かが一段、一段と重そうに階子をのぼって来る跫音がした。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悌二の方は、いかにも永くかかって下書きしたのをまた次の晩電燈の下で永い時間かけて清書したらしく、消しの一つもない手紙に、ありどおりのいきさつと自分の心持とを披瀝していた。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンブラントのスケツチは、雪舟の墨繪にも比較すべきものであるが、その下書きである所にまた一種の興味がある。",
              "citation": {
                "source": "今の寫生文",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "習作集と謂へば、家隆の「壬二集」、定家の「拾遺愚草」及び員外も同じく、下書き歌までも録した物であるらしい。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき友達の画家が、談たまたま手紙一般より恋文のことに至り、御婦人に宛てる手紙だけは原稿用紙は使わない、レター・ペーパーを用いる、原稿用紙は下書きにすぎないから、と言う。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき友達の画家が、談たまたま手紙一般より恋文のことに至り、御婦人に宛てる手紙だけは原稿用紙は使はない、レター・ペーパーを用ひる、原稿用紙は下書きにすぎないから、と言ふ。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見、書家の書体であり、版下書きの書体である。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは坊間ざらに見る、僅かに数銭を投げうてば、たちどころに揮毫するところの版下書きの書ではないか。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大著成るに及んで、最後の大切な表紙の題書を坊間の版下書きの書をもって満足するとはなにごとである。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、『名器鑑』のような大著の上になんとしても考えもなく低級な版下書きの書を用いしや。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉の※後、邦子さんは亡き姉の遺稿を整理する傍ら、一葉がまだ中島歌子の萩の舍塾で歌の手ほどきを受けてゐた時分の、詠草や手紙の下書き、日記や小遣帳、大音寺前時代の仕入帳などを丹念に整理して、桐の箱に收めて藏つておいた。",
              "citation": {
                "source": "緑雨と一葉",
                "author": "伊庭心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、見ず知らずの愛讀者から貰つた手紙もあり、自分の手紙の下書きなどは本物のやうに、美しい例の千蔭流で走り書きされてあつた。",
              "citation": {
                "source": "緑雨と一葉",
                "author": "伊庭心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾州藩の方へ差し出す嘆願趣意書の下書きとも言うべきものである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治五年の二月に、彼は早くも筑摩県庁あて嘆願書の下書きを用意したが、いかに言っても郡県の政治は始まったばかりの時で、種々な事情から差し出すことを果たさなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年始めて西洋の土地を踏んだ晩ゲノアの宿屋で夜ふけに窓の下でマンドリンをひきながら歌う者があった、その歌の調子がいかにも感傷的と言うのか卑俗と言うのか妙な感じがしましたがきょうのもやはり同じ感じがしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前、ゴーリキイはこの労働者に対する射撃を防ごうとして他の同志とともにウイッテと会い、熱心に談判したがきき入れられなかった。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
