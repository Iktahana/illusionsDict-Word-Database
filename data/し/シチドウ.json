    "definitions": [
      {
        "index": 1,
        "gloss": "the seven districts of ancient Japan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
