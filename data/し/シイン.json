  {
    "uuid": "3045c2be-a7fa-5edc-924c-390e71cebf42",
    "entry": "私印",
    "reading": {
      "primary": "しいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
