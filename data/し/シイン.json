[
  {
    "uuid": "ce7d615f-a2de-5775-9bd8-784ddaae41c9",
    "entry": "子音",
    "reading": {
      "primary": "しいん",
      "alternatives": [
        "しおん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
