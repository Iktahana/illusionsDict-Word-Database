      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "consonant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勿論子音の排列分布もかなり大切ではあるが、日本語の特質の上からどうしても子音の役割は母音ほど重大とは考えられない。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや日本語となると子音の役目はよほど軽くなると云っても差しつかえはない。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこういう声を出さずに口だけ動かす読み方では子音を発するに必要な細かい調節はよほど省略されている。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは如何なる点に存するか明白に自覚し得ないが、やはり子音母音の反復律動に一種の独自の方式があるためと思われる。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は子音の重なるのは不得意だから st がｓになることは可能である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを haradati の子音と比べると同一である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが子音転換すれば「タマ」になる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれらは子音転換によれば前述のｋｈｒの群になるのである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、「え」に相当する当時の音は「愛」の類と「延」の類と二つにわかれているが、そのうち、「愛」の類は母音のｅあり、「延」の類はこれに子音の加わった「イェ」（ye、ｙは音声記号では〔j〕）であって、五十音図によれば、「愛」はア行の「え」にあたり「延」はヤ行の「え」に当る。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　以上、「あ」「い」「う」「お」にあたる音および「え」にあたる音の一つは母音から成立つものであるが、その他の音は子音の次に母音が合して出来たものと認められる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、初の子音について考えると、カ行、タ行、ナ行、マ行、ヤ行、ラ行、ワ行の仮名にあたる諸音は、それらの仮名の現代の発音と同じく、それぞれｋ　ｔ　ｎ　ｍ　ｙ　ｒ　ｗのような子音で初まる音であったろうと思われる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、タ行の仮名の中、「ち」「つ」にあたるものは、現代の東京・京都等の発音とは異なり、「ち」は現代のようなチ（chi、chはチャチョなどの子音で、分解すれば、タの最初の子音ｔとシの最初の子音shとの合したもの。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮名ではティ）であり、また「つ」は現代語のようなツ（tsu、tsはタ行の子音ｔと、サソなどの子音ｓとの合したもの）でなくしてtu（独逸語などの発音。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サ行の仮名にあたる音の子音は、決定に困難である。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代語においてはサスセソの子音はｓであり、シだけはsh（シャシュ等の子音と同じもの。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハ行の子音は、現代ではｈであるが、方言によってはＦであって「は」「ひ」「へ」をファフィフェと発音するところがある。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "音変化として見れば、ｐからＦに変ずるのが普通であって、その逆は考え難いから、ハ行の子音はｐ→Ｆと変化したものと思われるが、奈良朝においては、どうであったかというに、平安朝から室町時代までは、Ｆであったと認むべき根拠があるから、その直前の奈良朝においても多分Ｆ音であったろうと思われる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に濁音の仮名に相当する諸音については、ガ行の仮名にあたる諸音の子音は多分現代の東京・京都等の「がん」「ぎん」「ごく」「げんき」「ぐん」などの「が」「ぎ」「ぐ」「げ」「ご」の子音と同じｇ音（音声記号では〔〕）は、当時はなかったのではあるまいかと思われる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ行の仮名にあたる諸音の子音は、サ行にあたる諸音と同じ子音の有声音であろうが、当時の発音は、その清音と同様に未だ決定し難い。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダ行の仮名にあたる諸音は、現今のダの子音と同じｄであった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "バ行の仮名にあたる諸音の子音は、現代と同じくｂであった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、子音の次に母音がついて成立つ諸音における母音について見るに、奈良朝時代の諸音のうち、その一音が後世の一つの仮名にあたるものにおいては、ア段の仮名に相当する諸音は、現代の仮名の発音と同じくａの母音で終り、イ段ウ段エ段オ段の仮名にあたる諸音も同様にそれぞれｉｕｅｏの母音で終ったものと考えられる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金は欲しいんだらう。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやお父さん、あれで負けたことはやつぱり口惜しいんですよ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはいつか私に、おれは淋しいんだ、孤獨なんだよ、親も兄弟も無い、この孤獨の淋しさが、お前、わからんかね、なんておつしやつてたぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあれで、何か色氣があるらしいんだね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだのかい」「死んだらしい」「どうしたんだい」「やけに呷ったらしいんだ」「フーム」「………………」「で、水葬はいつかい」「一運に一度訊いて見よう」「酒が、わるかったんだね」「ウム、どうもはっきり分らねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寂しいんだよ」「では、どうして差上げたらよろしいのでございましょう」「どんな端っこでもいい、おまえの家へ泊めとくれよ」　翁の声は小さかったが強訴の響は籠っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鷺はおいしいんですか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとぴたっと鳥の群は通らなくなりそれと同時にぴしゃぁんといふ潰れたやうな音が川下の方で起ってそれからしばらくしいんとしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
