        "examples": {
          "standard": [
            {
              "text": "クリスマスシーズンには、街角で人々が社会鍋に募金をする姿が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "困っている人々のために、彼女は積極的に社会鍋に寄付をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このイベントの収益は、すべて社会鍋に寄付され、支援を必要とする人々に届けられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "餅も自家で消費する分の三倍も四倍もついて、社会鍋や小学校に寄付したり、善哉をつくって大盤振舞いをしたりする。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
