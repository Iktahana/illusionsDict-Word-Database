        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっと廻すと札幌のＩＫ、名古屋のＣＫ、新潟のＱＫ、熊本のＧＫ、静岡のＰＫ、仙台のＨＫなどという具合に、二十七ヶ所の違った放送が目盛盤のひねり様一つで出てくる。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当方十一歳――ＪＡＣＫベンスン。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味で、リンピイ・リンプと彼の仕事は、僕の上に、じつに歓迎すべきＬＵＣＫの微笑だったと言ってよかろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＵＣＫは日本語では「オ○ンコ」であり、ＮＯＷは「いまただちに」だ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャニス・ジョプリンにとってＦＵＣＫとは、「自分が持っているものでいちばん大切なのは、フィーリングなのよ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（カントリー・ジョ・マクドナルド）10　ＥＬＶＩＳ　ＩＳ　ＢＡＣＫ　提供はミシン会社のシンガーだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "永年の友、小松五郎義兼ではない、ＢＬＡＣＫ＆ＷＨＩＴＥよ、さらば、である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポークチャップの馬鹿でかい奴を食ってるところへ、ＪＯＣＫから迎へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒にゐた藤山が、伴奏を引受けて呉れ、ＪＯＣＫへ行き、六時二十五分から三十分、「歌・歌・歌」ってのを座談的に、うんとくだけてやってみた、藤山もよく伴奏を入れて呉れ、之は又面白い一分野が拓けさうである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳山も渡辺も二三回宛出て大サービスだ、漫談も三十分以上やる、トリに「朗かな演芸会」、昼間はこれをＣＫ管内中継した（300）。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
