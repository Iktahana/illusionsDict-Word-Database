[
  {
    "uuid": "8cc7f3be-3c65-503e-a4fe-88af50fe76e9",
    "entry": "時化",
    "reading": {
      "primary": "しけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
