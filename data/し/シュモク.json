[
  {
    "uuid": "8580e8c3-e5f2-520a-a748-4ef5fb73ee5b",
    "entry": "種目",
    "reading": {
      "primary": "しゅもく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
