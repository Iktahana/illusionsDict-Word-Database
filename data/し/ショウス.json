[
  {
    "uuid": "21e21b12-92cc-576e-bb84-d76083096817",
    "entry": "称す",
    "reading": {
      "primary": "しょうす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-サ変-す",
        "動詞-他動詞"
      ],
      "ctype": null,
