  {
    "uuid": "e02187d7-1b44-54d8-b651-e53755d4a232",
    "entry": "私田",
    "reading": {
      "primary": "しでん",
      "alternatives": [
        "わたくしだ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "privately owned rice field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「私田舎へ帰つてよ。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに困ったって、私田舎こそ厭ですよ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で独立ができさえすれば、私田舎へなぞ行くのは、気が進まないんです。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "近々御隠居ともならば、私田を御次男御三男にも御分譲。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床の中で口説かれるなんて、そんなこと、私田代さんに惨めな思いさせたり惨めな田代さん見たくないから、許しちゃうかも知れないのよ。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん国造県主等の私田を耕す農民は、その私民であって、同じ農民でもオオミタカラとは呼ばれなかったであろう。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なおより以上に働くことを欲するものは、口分田以外に公田あるいは貴族の私田を小作することができ、また実際小作した。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると脱税や使役をのがれるために戸籍をごまかしたり、逃亡をやり、税のかゝらぬ寺領や貴族領へのがれたり、または私田を寄進したりする。",
              "citation": {
                "source": "現代の詐術",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の親類に当る地主たちは、一家ケンゾク各々私田を開墾し、肥タゴかついで勇敢にやっているという時節柄だが、彼だけは一｜段歩の私田も残さず、それというのが、彼はひところ何々会社取締役というようなことを三つばかり兼ねていたようなこともあるから、実業界でなんとかなろうと見込んでいたせいもあった。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく、行われた大化の革新も、でたらめ制度に堕し、個人が私田や私兵を持つことは禁ずという根本の国政を、てめえたちの栄達を分け取りするために、めちゃくちゃにしてしまやがった」　と、眦をさいて痛罵し、なお、濁み酒をあおっていいつづけた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣、関白からして、土地国有を無視し、諸国に私田を蓄めこんで、私に租税をしぼり取ってるのだ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "良持は、生前から、何事につけ、藤氏の門に、臣礼を執り、彼の擁する東国の私田の事務でも勤めたがっていた男だからであった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大炊寮の廩院では、財務官たちが、青くなって、全国の庄家（荘園役所）にたいし、私田、公田の徴税と輸送とを、督促するのに、眼のいろを変えていた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも、あちこちの荘園やお家の私田まで、豊田の将門へ、奪われている。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やす　　そんなら、国に戻ろごたなしでん、泣やあとつとけえ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "でんでんむしむしでんでんむしむし、角ひけよ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは江戸から持ち越して明治時代には相当客足をひいたものだが、案外はやく消えたのが浅草名物の「なめしでんがく」。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもでんぼ隠しの記念であって、その婆さんはでんぼで且つ跛であったからという人もあるが、所によっては大師様自身が生れつき跛で、それでこの晩村々をまわってあるかれるのに、雪が降るとその足跡が隠れてちょうどよいと喜ばれるといい、「でえしでんぼの跡隠し」という諺もあるそうです（小谷口碑集）。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
