  {
    "uuid": "639608a3-ee84-5457-bcea-12d7a6425423",
    "entry": "資源",
    "reading": {
      "primary": "しげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
