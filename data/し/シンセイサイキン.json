        "examples": {
          "standard": [
            {
              "text": "真正細菌は地球上のあらゆる環境に生息しており、生態系で重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この微生物は、一般的な細菌とは異なる真正細菌に分類される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真正細菌のゲノム解析は、生命の起源を理解する上で不可欠な情報を提供する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "真正細菌に密接に関連するものと結局みなされるようになると思われる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "リケッチアは普通に使う染色法への反応の違いとか生きている細胞を含まない人工培地で発育しないとか生きている動物とか組織培養で細胞の中でしか増殖しないとかで真正細菌と違っている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正細菌と密接に関連していたことは疑いが無い。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
