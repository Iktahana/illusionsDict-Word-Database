          "standard": [],
          "literary": [
            {
              "text": "神經衰弱症のごときは多くは氣の死定もしくは氣の失調より生ずるもので、同一のことに長時日の間吾が氣を死定せしめて使用したり、氣の調節を、あるひは心理上、或は生理上より缺くやうにしたりすると起るのであるが、之を氣の作用より説けば、或は萎む氣、或は亢る氣、或は散る氣、或は凝る氣等の爲さしむることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱症などの多くは気の死定や気の失調から生じるもので、同じことに長期間我が気を死定させたり、気の調節が心理上や生理上によって欠くようになると起るのであるが、これを気の作用から説けば、萎む気や昂る気や散る気や凝る気等がそうさせるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそ全く失調時代です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の秋からは、妻にも明らかに栄養失調の徴候が現われ始めた。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓死する人間も見たであろうし、その人たち自身、栄養失調で這って帰って来たかも知れない。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって家計失調は日本において全般的な状態で、この事情は業種別勤労者賃銀表と見くらべると深刻な日本の全人民層の生活難を語っている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誕生このかた不断の栄養失調のうちに辛うじて息づいて来た旧日本文学の精神は、全く非人間的な擅断と営利主義とによって導かれた自身の崩壊さえも、その事実の重大さにおいて自覚し得なかった。",
              "citation": {
                "source": "新日本文学の端緒",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇買いをしないために営養失調から死んだ判事の問題が新聞に報じられているし「葦折れぬ」という一冊の本は、闇買いをわるいこととして絶対にそれをしないで病死した一人の若い女教師の手記である。",
              "citation": {
                "source": "再版について（『私たちの建設』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスチャンということをこの頃強調する片山首相夫人は、営養失調で死んだ判事の事件に対して新聞記者のインタービューに答え「そこは奥様が少しなんとかね」と語っている。",
              "citation": {
                "source": "再版について（『私たちの建設』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな栄養失調だとうわさしています。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、そのころ、誰かが黒板に、山本先生の栄養失調って落書していたからです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかれも出たんだし、栄養失調もあるのだから、当分寝ててもらうのさ」　とおっしゃいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「榮養失調だな、爺は……」「ふざけちやいけないよ。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野の風の涼しき夜とならん登場したり文三と月と　この春（二十一年）栄養失調でなくなつた江南文三君である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、螺旋菌の脊髄中に入りしためにして、運動に失調起り下腹部に激烈なる疼痛現われて、幹枝の幻想も苦痛に伴う悲哀の表現に充ち、華鬘萎み羽衣穢れ――とかいう、天人衰焉の様を唱うようになれり。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の愛する娘も、だいぶ栄養失調の恐れが濃厚になってきた。",
              "citation": {
                "source": "或る日の対話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑務所側の説明に依れば、三木は警視庁以来、疥癬にかかり、また栄養失調を来し、九月半ばに急性腎臓炎となり、症状が進んで、病舎にあること二日にして急逝したとのことである。",
              "citation": {
                "source": "三木清を憶う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は栄養失調の気味であったが、教室で見る大学生はみんなマルマルとして血色がよく、年中タバコをすっていた。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し女には守らさねばならぬが、男には寛假されると云ふやうな矛盾のあるものなら、それは人間生活を破綻失調させる舊式道徳であつて、私達の信頼することの出來ないものだと思ひます。",
              "citation": {
                "source": "貞操は道徳以上に尊貴である",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、薬をのんで健康の失調をなおすなどということは昔流行した不自然な、そして損なやり方です。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから近世においては、食物でもって健康の失調をなおすのです。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康の失調はなおるし、口にもすてきにおいしいし、両得ではありませんか」　タクマ少年のいうことは、なるほど道理にかなっている。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに腹が減った」「私に出された料理が、お客さんのよりもみすぼらしいということは、お客さんの方が私よりも健康の失調がひどいのです。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二十年前の人間は、悪病と栄養失調と非衛生とおどろくべき無知無能のために、このような衰弱したからだを持っている。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全軍栄養失調で、太平洋の孤島へ進出した日本軍と同じこと、冬があるだけ苦痛が一つ多かつた。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れるとすぐに栄養失調にならない新劇運動が生れてくる。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の寝姿は見えないけれど、私などこの頃あまりのめないために、酒精失調とでもいう病気にかかり、眼を開いたまま眠るか、どうか。",
              "citation": {
                "source": "飛沙魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、当時は食糧難で、栄養失調の気味もあり、不覚にも流しの上へヘタヘタとくずれて、しばしノビテしまったのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
