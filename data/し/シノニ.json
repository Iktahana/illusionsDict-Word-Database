    "definitions": [
      {
        "index": 1,
        "gloss": "rolling a two and four (with two dice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
