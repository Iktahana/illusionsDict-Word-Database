        "examples": {
          "standard": [
            {
              "text": "スキーの初心者は、まず斜滑降をマスターして斜面を横切る練習をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゲレンデの急斜面を、鮮やかな斜滑降で滑り降りていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "斜滑降をしながら、次にターンするタイミングを計る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "天狗平を右下に見て高廻りし、弥陀ヶ原に斜滑降で下ります。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下りはスキーが下手なので、輪カンジキで下る予定にしていたが、割合藪も少なく、愉快な斜滑降ができた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
