        "examples": {
          "standard": [
            {
              "text": "配線の接続部には、感電防止のために必ずシースを取り付けること。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い家電製品のコードのシースが劣化して、中の銅線が見えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "作業中は、むき出しの電線にシースを被せておくのが安全だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
