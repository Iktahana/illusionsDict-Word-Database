    "definitions": [
      {
        "index": 1,
        "gloss": "flight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、彼はこの後、たびたび出奔癖がついた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　盗癖のために村にいられなくなって、どこかへ出奔して、十数年来頼りがない茂吉という、じいさんの弟があった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の巌殿へ引返して、山越で出奔する分の事です。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から殆ど三十年以前に、彼は角川家を出奔して、お杉と共に諸国を流浪して歩いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千恵造の出奔を切っ掛けとして、児子家は以後多事多端であった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな一少女の出奔を知己の間に言いふらすことが、彼の自尊心をどんなに満足させたか。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな一少女の出奔を知己の間に言ひふらすことが、彼の自尊心をどんなに滿足させたか。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸にそれは劇毒で、政宗の毒味番が毒に中って苦悶即死したから事｜露われて、政宗は無事であったが、其為に政宗は手ずから小次郎季氏を斬り、小次郎の傅の小原縫殿助を誅し、同じく誅されそこなった傅の粟野藤八郎は逃げ、目上の人即ち政宗の母は其実家たる最上義光の山形へ出奔ったという事がある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは夏のみじか夜の明けるを待ちかねて、養家のうなぎ屋を無断で出奔した。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出奔した前太子は晋の力を借りて衛の西部に潜入し虎視眈々と衛侯の位を窺う。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之も矢張衛から出奔した戯陽速が此の言葉を伝え聞いて、斯う酬いた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国を出奔する時後に残して来た男の児である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子・衛侯は即刻出奔、父・太子が代って立つ。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或夜、荘公は渾良夫に向って、先の衛侯｜輒が出奔に際し累代の国の宝器をすっかり持去ったことを語り、如何にして取戻すべきかを計った。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之も矢張衞から出奔した戲陽速が此の言葉を傳へ聞いて、斯う酬いた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "國を出奔する時後に殘して來た男の兒である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子・衞侯は即刻出奔、父・太子が代つて立つ。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或夜、莊公は渾良夫に向つて、先の衞侯｜輒が出奔に際し累代の國の寶器をすつかり持去つたことを語り、如何にして取戻すべきかを計つた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚ノートに依つて見ると弟は東京を慕ひ、聞いて居た俺を慕つて飛騨から出奔して来たことが分明つた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや召使の婢が金子を掠めて出奔せしに、お艶は争で遁すべきとて、直ちに足留の法といえるを修したりき、それかあらぬか件の婢は、脱走せし翌日より遽に足の疾起りて、一寸の歩行もなり難く、間近の家に潜みけるを直ちに引戻せしことを目撃したりき。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とぞして今一度東上し、この胸の苦痛を語りて徐ろに身の振り方を定めんものと今度漸く出奔の期を得たるなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一先づ手に手をとつて出奔するといふのがそれである。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば貧乏を嫌う妻が金持ちの老人の許に出奔したのを怒って、その残された夫が富を欲して非常な勤勉家となるような、また例えば家庭の波乱に苦しむ人が或る芸術や或る事業に熱心になり、常人の及びつかない精励をするような、このような事例は世に稀でないが、これ等の中には真に張る気を生じるものもある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "せがれの武助は放蕩者、同藩中の森山郡兵衛と共謀して、自分のおやじが鍵預かりをしている金蔵へ忍び込み、五百両の金をぬすみ出して出奔した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年程前迄は活動写真に凝つて身を過つてゐる妻の弟が助手だつたが、不定な給料に関して不平を抱いて出奔してからは、そのまた弟の受験生であるＮが代つてゐたが、私の仕事がすゝむに伴れてＮだけでは手不足だつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は、叔父の家さへ出奔しようと思ふことさへあつたが、徒に幻想だけが放浪的になるばかりで、三村といふ看護婦と通じて居るといふことゝは全々別に、たゞ無暗と臆病な消極的な理性に怯されるばかりだつた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが出奔した時には三人の子供を抱えてどうしようと思ったもんやが……。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その揚げ句に不義理な借金をこさえ情婦を連れて出奔したのじゃ。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰元お多根の家出出奔も、主人の難儀はわが難儀と、悲しさあまって心中だてに忠義の出奔というやつよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
