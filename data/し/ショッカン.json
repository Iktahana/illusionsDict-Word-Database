    "definitions": [
      {
        "index": 1,
        "gloss": "food texture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "野菜の至味を想う頃、筆者の食感を揺するものに、初秋の鮎がいる。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食感を想えば、我が肉虜ひとりでに肥えるを覚えるのである。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "美食感覚へのこのすこしばかりの実証。",
              "citation": {
                "source": "海にふぐ山にわらび",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
