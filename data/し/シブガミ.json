    "definitions": [
      {
        "index": 1,
        "gloss": "paper treated with astringent persimmon juice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間も渋紙で物を包んで水の浸入に備えたり、渋面をして他人との交渉を避けたりする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャディが三人、一人はスマートで一人はほがらかな顔をしているがいずれも襟頸の皮膚が渋紙色に見事に染めあげられている。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まだこの時も、渋紙の暖簾が懸った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた手拭で頬冠りをして、大人のような藍の細かい縞物の筒袖単衣の裙短なのの汚れかえっているのを着て、細い手脚の渋紙色なのを貧相にムキ出して、見すぼらしく蹲んでいるのであった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところ元気のいい子で、顔も背中も渋紙のような色をして、そして当時｜流行っていた卑猥な流行唄を歌いながら丸裸の跣足で浜を走り廻っていた。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "垢染みて、貧乏｜皺のおびただしくたたまれた、渋紙のような頬げたに、平手で押し拭われたらしい涙のあとが濡れたままで残っている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "膠もない、活気もない、艶も光もない渋紙色した彼の顔面に相当する彼の声は、常に雑音で低調で、平板である。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上には汚れ除けの渋紙が敷き詰めてある、屏風や長押の額、床の置ものにまで塵除けの布ぶくろが冠せてある。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから幹に立たせて置いて、やがて例の桐油合羽を開いて、私の天窓からすっぽりと目ばかり出るほど、まるで渋紙の小児の小包。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も裸体が渋紙に包まれていたんじゃ、氏素性あろうとは思わぬはず。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は仕方なしに、床と同じように渋紙を張った壁にもたれて、しゃがんだ。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又左衛門は平生眼が悪くて勤めに不自由をするところから女のお岩に婿養子をして隠居したいと思っていると、そのお岩は疱瘡に罹って顔は皮が剥けて渋紙を張ったようになり、右の眼に星が出来、髪も縮れて醜い女となった。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の皮が剥けて渋紙色をした眼の悪い髪の毛の縮れた醜い女の形相は夜叉のようになった。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋紙した顔に黒痘痕、塵を飛ばしたようで、尖がった目の光、髪はげ、眉薄く、頬骨の張った、その顔容を見ないでも、夜露ばかり雨のないのに、その高足駄の音で分る、本田｜摂理と申す、この宮の社司で……草履か高足駄の他は、下駄を穿かないお神官。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時五十二になる権兵衛の面長なきりっとした顔は、南の国の強い陽の光と潮風のために渋紙色に焦げて、胡麻塩になった髪も擦り切れて寡くなり、打裂羽織に義経袴、それで大小をさしていなかったら、土地の漁師と見さかいのつかないような容貌になっていた。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「釜礁がどうしたのか」「此の二三日、彼の釜礁は、竜王が大事にしておるから、とても破れない、また破っておいても、翌日になると、元のとおりになっておるとか、いろいろの事を云っております」「そうか、そんな事を云っておるか」　これも陽の光と潮風に焦げて渋紙色になった総之丞の顔には嘲笑が浮んだ。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "印絆纏を着た男が、渋紙の大きな日覆を巻いている最中であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋紙のような顔に、胡麻塩鬚が中伸びに伸びている。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書館に納めることが功徳になるか、どうかすこぶる疑問だな、などと思いながら、彼は、渋紙を探して小包を作りにかかった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、渋紙色の顔をして朝晩に何かをたくらんでゐるやうな、すこしも人に腹の奥底を見せない老人の顔が眼前に浮んで来た。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わりに大きく長い枯れ枝の片を並べたのが大多数であるが、中にはほとんど目立つほどの枝切れはつけないで、渋紙のような肌をしているのもあった。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その舟には顔の渋紙色をした六十に近い老人と三十位の巌丈な男が艪を漕ぎ、十八九に見える女が炊事をやっていた。",
              "citation": {
                "source": "参宮がえり",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高は長方形の渋紙に包んだ量ばった物を抱いていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめよ、汝、手ぶらで往っちゃ、これ持ってくのよ、お婆さんに持って往かして」　それは抱きかかえている渋紙包を持って往けと云うのであった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい」「そうじゃないの」「へい」　平吉はまたとぼけるように云って渋紙包を受けとった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平吉は窓の傍に渋紙包を持って立っていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胡蓙を敷いておくれよ」　お高は渋紙包に手を持って来た。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここへ」「そうよ」　平吉は渋紙包をわたして胡蓙を探した。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
