    "definitions": [
      {
        "index": 1,
        "gloss": "frosty night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山霧深うして記号標の芒の中に淋しげなる、霜夜の頃やいかに淋しからん。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍結した霜夜の街を駆け行く人力車の車輪の音――またゴム輪のはまっていなかった車輪が凍てた夜の土と砂利を噛む音は昭和の今日ではもうめったに聞くことの出来ないものになってしまった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍てた霜夜の土で想い出すことがもう一つある。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして過ぎ去った青春の夢は今｜幾何の温まりを霜夜の石の床にかすであろうか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動くは逢見たき欲よりなり、騒ぐは下に恋しければなり」　女は暫時※惚として、そのすゝけたる天井を見上げしが、蘭燈の火かげ薄き光を遠く投げて、おぼろなる胸にてりかへすやうなるもうら淋しく、四隣に物おと絶えたるに霜夜の犬の長吠えすごく、寸隙もる風おともなく、身に迫りくる寒さもすさまじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふの霜夜の空に冴え冴え、松の梢を光らして、かなしむものの一念に、懺悔の姿をあらはしぬ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで対照されていいと思うものは冬の霜夜の辻占売りの声であった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を浮かべて、ゆるやかに流るるこの沼川を、漕ぎ上る舟、知らずいずれの時か心地よき追分の節おもしろくこの舟より響きわたりて霜夜の前ぶれをか為しつる。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次に見つけたらあれを買って来るのだと思いついた時には、自分をのせた電車はもう水道橋を越えて霜夜の北の空に向かって走っていた。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖爐の瓦斯は颯々と霜夜に冴えて、一層殷紅に、且つ鮮麗なるものであつた。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬二頭が、鼻あらしを霜夜にふつふつと吹いて曳く囃子屋台を真中に、磽※たる石ころ路を、坂なりに、大師｜道のいろはの辻のあたりから、次第さがりに人なだれを打って来た。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「按摩あ……鍼ツ」と忽ち噛みつきさうに、霜夜の横寺の通りで喚く。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男を見た時に、『霜夜鐘』の芝居に出る六浦正三郎というのはこんな人だろうと思った。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を持たない秋が深うなつた霜夜の寝床が見つからない　そうろうとして歩きつづけていた私は、私相応の諦観は持っていたけれど、時としてこういう嘆息を洩らさずにはいられなかった。",
              "citation": {
                "source": "寝床〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "むざんや口角より血をしたたらし、合掌し、瞑目し、むざんや天上に縊れたるものの、光る松が枝に靈魂はかけられ、霜夜の空に、凍れる、凍れる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この霜夜に、出しがらの生温い渋茶一杯｜汲んだきりで、お夜食ともお飯とも言い出さぬ。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜夜に芬と香が立って、薄い煙が濛と立つ。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ハオ、イヤア、ハオ、イヤア、）霜夜を且つちる錦葉の音かと、虚空に響いた鼓の掛声。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百千網巷巷に空車行く音もなくあはれ、今、都大路に、大真夏光動かぬ寂寞よ、霜夜の如く、百万の心を圧せり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、なんとなく、霜夜の街頭のカンテラの灯を聯想する。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫と天井から一幅落ちたが、四辺が暗くて、その何にも分らぬ……両方の棚に、ひしひしと並べた明｜晃々たる器械のありとも見えず、寂となって隠れた処は、雪に埋もれた関らしく、霜夜の刑場とも思われる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮る樹立の楯もあらず、霜夜に凍てたもののごとく、山路へぬっくと立留まった、その一団の霧の中に、カラカラと鐸が鳴ったが、「ほう――」　と梟のような声を発した。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖炉の瓦斯は颯々と霜夜に冴えて、一層｜殷紅に、且つ鮮麗なるものであつた。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恁る霜夜に、掻乱す水は、氷の上を稲妻が走るかと疑はれる。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の性質は霜夜の幽霊のように沈んで寂しいのかも知れないのに、行為は極めて蓮葉で、真夏のごときは「おお暑い。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男を見た時に、「霜夜鐘」の芝居に出る六浦正三郎というのはこんな人だろうと思った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にわたしなども霜夜の枕にひびく餅の音を聴きながら、やがて来る春のたのしみを夢みたもので――有明は晦日に近し餅の音――こうした俳句のおもむきは到るところに残っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水練をしらないらしい彼が、この霜夜に赤裸で大池へ飛び込んだのであるから、その運命は判り切っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明くる年の六月、「霜夜鐘十字辻筮」が新富座の二番目狂言として上演された。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの「霜夜鐘」の正本も金さんが又貸しをしてくれたもので、わたしはこの時に初めて芝居の正本というものを読んだのであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
