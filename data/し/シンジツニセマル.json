    "definitions": [
      {
        "index": 1,
        "gloss": "to close in on the truth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
