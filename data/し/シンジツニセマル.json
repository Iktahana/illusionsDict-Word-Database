        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "探偵は、様々な証拠から事件の真実に迫る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史家は、残された資料を丹念に調べて真実に迫る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのドキュメンタリー番組は、事件の真実に迫る内容で大きな反響を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの会見の冒頭で、のっけから「Congratulations !!」の真実に迫る質問が飛んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに乃公は二度目の夢の中での殺人に、かなり真実に迫るものを感じたから。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四四　渾名　あらゆる東京の中学生が教師につける渾名ほど刻薄に真実に迫るものはない。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "思索の為に世を捨てても尚、一向に真実に迫ることができておらぬと彼は言い、我が無知なることに、生命と神の御前で赤子のようにあることに満足している、と言ったのだ。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
