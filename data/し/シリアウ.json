    "definitions": [
      {
        "index": 1,
        "gloss": "to get to know each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
