      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "にっこりと笑った三要は払子を打って法戦終結を告げ、勝負は強いて言わずに、次の言葉を発しました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この討論は到底相撲にならないで終結したらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲大戦が終結して平和がやってきた。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理的な終結はあっても、空想の満足がなかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この果てなく見える旅路が偶然にもわれわれの現代に終結して、これでいよいよ彼岸に到達したのだと信じうるだけの根拠を見いだすのは私には困難である。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと言って、いつまでもなんらかこの種の方法をとらなければ、独断と独断との間の討論の終結する見込みは立たないように思われるのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようなら」と言って、それっきりで事件が終結した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが最終の第四楽章に入ると、再びもとの静かさに帰る、そうして「花の座」が現われ、最後に、ゆるやかなあげ句で、ちょうど春の夕暮れのような心持ちで全編が終結するのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は出資者たる戸畑を相手として進行して居た訴訟を示談によつて終結させたいと思つて戸畑側と熱心なる交渉を重ねた結果、戸畑は五万円迄の資金を白川が確実なりとし戸畑の腑にも落ちる方法によつて支出する。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとどのつまり出刃打ちが殺したになって、予審は終結した。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくともこの点では、もはや議論は終結した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて長谷場純孝氏の提議にて討論終結の動議成立し、杉田議長採決を宣したるに出席總數三百四十五票中決議案を可とする者　百六十八票否とする者　　　　　百七十七票にて戰は僅々九票の差にて政府黨の勝利に歸し申候。",
              "citation": {
                "source": "雲間寸觀",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十八年八月を以て戰爭が終結すると共に、社會主義者の氣勢は漸く鈍つた。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、勿論しかし、それが夫婦のものの、身の終結になるかも分りません。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、ひたすら外交手段による戦争終結を渇望していたのだ。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の一身に絡まる怪奇な因縁は、中々ソレ位の事で終結にはなりませんでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ニコラス廃帝が、その皇后や、皇太子や、内親王たちと一緒に過激派軍の手で銃殺された……ロマノフ王家の血統はとうとう、こうして凄惨な終結を告げた……という報道があったことを逸早く耳にしているにはいたのですが、その時は、よもやソンナ事があろう筈はないと確信していました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればヨブ記はここを以て終結とすべきではないかと思われる。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭勒の利かぬような者は難いかな今の世に免れん事をと歎息し、智馬をして空しく無識の販馬商の鞍下に羸死せしめぬよう冀望を述べてこの章を終結する。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵な大事業は計劃せられ、実行せられ、終結せられて十分余りある。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "南朝五十七年も其前後の準備や終結を除いた正味は二十五年ぐらいなものであろう。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　『八犬伝』および失明後終結『八犬伝』は文化十一年、馬琴四十八歳の春｜肇輯五冊を発行し、連年あるいは隔年に一輯五冊または六、七冊ずつ発梓し、天保十二年七十五歳を以て終結す。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしただ最初の起筆と最後の終結との年次をのみいうならばこれより以上の歳月を閲したものもあるが、二十八年間絶えず稿を続けて全く休息した事がない『八犬伝』の如きはない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく二十八年間同じ精力を持続し、少しもタルミなく日程を追って最初の立案を（多少の変更あるいは寄道はあったかも知れぬが）設計通りに完成終結したというは余り聞かない――というよりは古今に例のない芸術的労作であろう。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来『八犬伝』は百七十一回の八犬｜具足を以て終結と見るが当然である。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "『牡丹燈籠』は『書生気質』の終結した時より較やおくれて南伝馬町の稗史出版社（今の吉川弘文館の横町）から若林※蔵氏の速記したのを出版したので、講談速記物の一番初めのものである。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つてこの結合関係は安定的でも永続的でもなく、政治闘争の終結とゝもに武装を解くのである。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
