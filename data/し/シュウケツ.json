[
  {
    "uuid": "cdb79b79-cae9-5cd8-8d6f-6551955f9c6a",
    "entry": "終結",
    "reading": {
      "primary": "しゅうけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
