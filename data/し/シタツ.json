    "definitions": [
      {
        "index": 1,
        "gloss": "gate of the imperial palace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
