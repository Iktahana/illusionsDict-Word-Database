    "definitions": [
      {
        "index": 1,
        "gloss": "fleshy fruit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
