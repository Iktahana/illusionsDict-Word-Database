    "definitions": [
      {
        "index": 1,
        "gloss": "(security) guard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "樹園宮沢賢治髪白き山田博士が書いだき帰り往くころかはたれはしづに這ひ来てふくよかに木の芽ほごるゝ鳥飛びて気圧を高み守衛長〔以下未完〕ぎごちなき独乙冠詞を青々となげく窓あり",
              "citation": {
                "source": "樹園",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、知り合いの医員は一人も居らず、たった一人、頭の禿に見覚えのある守衛がいた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "又珍らしいことに荻原守衛も来会した。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃声は守衛が威嚇的に射ったものだろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "守衛がまた威嚇的に発砲したのであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "面会に来て、父親の銀造が青い着物を着ているのを見るのが辛く、チマ子は工面して闇市で洋服を買い、守衛にたのんで差入れたのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "チマ子は靴も差入れようとしたのだが、拘置所では靴をはくことは許されず、持って行った靴は守衛への賄賂になったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかないと守衛をよぶぞ。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夜の心配に堪えられなくなった守衛長（若い瑞典人）は、遂に、乱暴極まる措置を思いついた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冥府の構造から、オシリス神の審判の順序から、神々の性行から、オシリス宮の七つの広間、二十一の塔の間やその守衛者の名前迄｜悉く誦んじている。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "城門の口には見るからに恐ろしい守衛がたくさんいた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の鬼使は前に立って往って、かの帖を一人の守衛の前にさしだした。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "守衛は一眼見て頷いた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門口にいた守衛のような角のある体の青い夜叉が、どこからくるともなしに刀を持って出てきて、男の方に近寄るなり、いきなりその刀を男の腹に突込んで切り裂いた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の門をくぐって、守衛に、彼から来た葉書を示し、事務所へはいると、そこに十人ばかりの女の子が、ひっそり事務を執っています。",
              "citation": {
                "source": "東京だより",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠行の香薬とは、支那で線香を焼いて人事不省たらしめて盗みを行う者あるごとく、特異の香を放ち、守衛を不覚にして宮中に入ったのであろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて禁界を標示せる樹木を引き抜いて守衛二人を殺し、巨鬼に囚われた一素女を救い、また多くの犬と勇士を率いて一船に打ち乗り、虹の神の赤帯を求めて島々を尋ね、毎夜海底の妖怪鬼魅と闘う。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから当時ロンドンで総領事だった荒川巳次君宅へ寄食したが、子供の守りをするがうるさいとかで逃げ出し、前途何たる目的もなしに一日大英博物館をうろつく内、余り異風な故守衛が何国の産かと問うと日本と答う。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、東国から大番（京都守衛の役）のために上京する武士達が、日高い頃に、かいづに泊った。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下を往来する守衛の靴の音が、此の上なく非音楽的なリズムをつくって、乾燥した音波を鼓膜に送って来る。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "職工の一人も問題にしないばかりか、巡査上りの守衛から、工場長さえ取り合いもしない。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時は一度に人が随分要らなくなったので、とう／＼ストライキになって、職工たちが夜中に工場へ押しかけて行って、守衛をブン殴ぐって、そのコンヴェイヤーのベルトを滅茶苦茶にしてしまったことがありました。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、後でそれが守衛であることが分った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんなことがあるだろうと、予め屋上の所々に立ち番をしていた守衛は、「こら、こら！",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方のなくなった守衛は、屋上からの狭い出口を厳めて、そこから一人ずつ通して首実験をしようとしたが、そんなことをしていたら一時間経っても仕事が出来ない。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなれば、守衛には最早どうにも手がつかなかった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "入場者の〆切は四時半で、五時には、かれこれ園内には人影が見えなくなり、それから、一時間ほどの間は、守衛や掃除人夫らしい人がまだ往来しているが、六時半頃になると、人間の声も、人間に関係のある物音も園内ではほとんど聞こえなくなる。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "守衛に見つかったら、面倒ですからね」男は言葉の調子をがらりとかえて、妙に丁寧になった。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもって一目散に守衛のもとへかけつけたら……私はつい卑劣極まる考えを起こしたが、すぐにあわててその考えを打ち消した。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手帳がにせ物だとわかればあの男は僕がこの中にいることを知ってきっと夜の明けんうちに逃げ出すか、ここの守衛を起こすかして、手配りをするにきまっていますよ」「では僕も一しょにつれて逃げて下さい。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
