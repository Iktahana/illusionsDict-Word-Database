[
  {
    "uuid": "e2e02ec9-6e0c-50c2-9d5c-373ef7675ecf",
    "entry": "史筆",
    "reading": {
      "primary": "しひつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "historical writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一体馬琴は史筆｜椽大を以て称されているが、やはり大まかな荒っぽい軍記物よりは情緒細やかな人情物に長じておる。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "矧や渡辺氏の史筆の如きものがあつて、遺憾なく辯駁してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "史筆の選択取舎せざること能はざるは勿論である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "率直にいふと、私は彼の史才や史筆に就いて、飽足らなく感ずる點が尠くない。",
              "citation": {
                "source": "司馬遷の生年に關する一新説",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へて見ると、明治二十年、先生が一時世上の交渉を絶つて、閑窓の下に「開国始末」の著作に没頭された時、攘夷論の犠牲となつて桜田門外の雪と消えた井伊大老の為に、雪寃の史筆を揮つて居られた時は、維新以来久しく窒息状態に潜伏して居た攘夷的感情が、機運一転して擡頭の時節接近した時であつたらしい。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊かに高きその史筆明治の篇を結びませ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにこれを伝えた史筆の上にも、確かに忌むところがあって隠した形跡が窺われるのである。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が皇胤であることを隠さんとした史筆の陰に、そんな事があっても一向差し支えはないではなかろうか。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、学者は多いが、史筆の人材は、極めて、稀であること。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "江口や神崎の君たちに、史筆があれほどまでに及んでいたということは、異例な女性待遇といってよい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの郡長が巡回に来て、大雨で一晩泊つて行つた時、手に取つてひつくら返しひつくら返し見て褒めて行つた事がありました哩。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆んなひつからげて、笞でぴしぴしひつぱたいてくれるといいんだ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半みな花をもて飾りしひつぎをばとりまきあめふる夜半をすごしぬ。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎて行く日を惜みつつ春を待つ餅花に出しひつこめし顔｜綺麗一月十七日　大崎会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくしたらなつけてたよ　ツシヤこのいしとかねとやに　てたしひつかは　とのす世はちよわれ又よかるたらなつけ　是も簡単な構成ながらも、第三行のシヒツカハが解しがたく、またトノス世もはっきりしないから、何を詠じているのか見当もつかぬが、ともかくもツシヤの石と金属とに縁があったらしいことが考えられる。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には同じ『草紙』の十五巻の六に、たくしたらなつけてだよツシヤコの石とかねとやにてだしひつかば（う）とのす世はちよわれ　このツシヤコは磁石のことだろうという説も有るが、全体にこの一篇は意味が取りにくい。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
