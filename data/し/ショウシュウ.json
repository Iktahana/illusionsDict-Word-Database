          "literary": [
            {
              "text": "学ぶ者はこの時において、学ぶところの書物の文と礼学の容儀とを誦習し、日にその不足のところを知り、月にその優れたところを忘れない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに、最古の古典たる「古事記」が、稗田阿礼なる女性の誦習にもとづくらしいことをも、私たちは知っている。",
              "citation": {
                "source": "女性史研究の立場から",
                "author": "高群逸枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
