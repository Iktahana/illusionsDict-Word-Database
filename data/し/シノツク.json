[
  {
    "uuid": "d1871d37-cf54-58fc-883e-5c048f4a396b",
    "entry": "篠突く",
    "reading": {
      "primary": "しのつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
