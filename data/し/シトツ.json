        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぼくたちは、中国兵の捕虜に自分たちの墓穴を掘らせてから、面白半分、震える初年兵の刺突の目標とした。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく思ひめぐらして彼れは夜露にしとつた肩をたゝきながら、船橋の方を見返った。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、ことしとつた綿の花の中から種子を一粒づつ拾ひ出してゐた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とひくく私に言つて聞かせながら、ペリカンの樣樣の姿態をおそろしく亂暴な線でさつさと寫しとつてゐた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は釣に行くと申しとつたさうですが、一人が角縁の眼鏡を掛けてゐたといふ點は島の者の證言と全く符合してをります。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次も白い食鹽を爪の先で少しとつて口へ入た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜になつてから「爺、今朝のお飯冷たく成つたつけべ俺ら忘れて喚ばりに行つたのがよ、さうしたら爺は疾に居ねえのがんだもの、そんでも先刻はがや／＼一｜杯居るやうだつけがあつちぢや甘え物あつて爺等とつ返しとつたんべなあ」とおつぎが少し甘えたやうにいつたことを彼は有繋に憎いと思つては聞かなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、城中記録の片々に依つて私は、様々な、馬鹿々々しい城主の奇行を無数に発見して、私は丹念に私のノートに写しとつてゐるのであつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早月さん※」　葉子はややしばしとつおいつ躊躇していたが、とうとう決心して、何かあわてくさって、鍵をがちがちやりながら戸をあけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見て三浦君がひどく心配し、では私が清書しませうと云つて、大半彼が代つて寫しとつて呉れたのであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時か寒石老人と説文の話か何かしとつた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "劍持はしたり顏になつて、『僕はな、以前から高橋を注意人物にしとつたんぢや。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――誰か僕の批評をしとつた者は無いか？",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二学期が始まる四五日前に彼は、忠実な学生を訪れて、厭がるのも関はずその日録を奪つて五十日間の「天気」を写しとつたのである。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ら、ついうとうとしとつたもんぢやけに。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何も餘計な手はかけんと、温とうにしてぢつとしとつて自然とをさまるのを待つとるのが一番ぢや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々短氣を出しとつたら、村には住めんよつて。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手傳ひに行つた山田のおつ母が、衣裳を見てぶつたまげて、蟲干しに何日かかるべつて心配しとつたが、おれもトラツクに荷物を積みながら、これが皆米の俵の化けたのかと思ふと、何だか妙な氣がしたよ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "議席で顏を合しとつたのはほんの僅かの期間のことぢや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣岡が作りたい云ふその田圃をつい去年の秋まで作らしとつた男やが。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに廣岡か畑浦かと云ふことになりや、前に一度その田圃を作らしとつた畑浦の方にやつぱし歩があるけんなあ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしもどうもうつかりしとつて知りませんかつたが、つまりですな、豫算の收入の部が大半寄附金といふことになつて居りますやろ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、関係しとつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そやけど、拙僧がお辞儀しとつた事、誰にも言ひなはんなや。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが五月に這入つてから頭の工合が相変らず善くないといふ位で毎日諸氏のかはるがはるの介抱に多少の苦しみは紛らしとつたが、五月七日といふ日に朝からの苦痛で頭が悪いのかどうだか知らぬが、とにかく今までに例のない事と思ふた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私が春のインバネスを羽織つてゐたことを修一から別れた妻が聞いたら、「おや／＼、そないなお洒落をしとつたの、イヨウ／＼」と、嘸かし笑ふであらう。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "長げえあひだ信用しとつた酒場の亭主も、やがてのことに信用しなくなつてのう。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちぢや、あれを親身の息子のやうにしとつたでねえか！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな漁位しとつても何にもならん。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きれば恥多しとつくづくあの日は思ったね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
