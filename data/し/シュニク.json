[
  {
    "uuid": "3ed4b80a-6554-5ecb-a524-09258c8dc5b6",
    "entry": "朱肉",
    "reading": {
      "primary": "しゅにく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thick red ink (used for signature seals)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "でもござりませんければ、朱肉を真四角、べたりでもござりません。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも打出しもので、中はつぎのないくりぬきを、表の金質に好配して、黄金また銀の薄金を覆輪に取って、しっくりと張るのだが、朱肉入、驕った印章入、宝玉の手奩にも、また巻煙草入にも、使う人の勝手で異議はない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い丸い月が出て居る有様を朱肉で丸印が捺してあるものとして、一行の雁字と共に一幅を成して居るかのやうにしやれて見たのであらう。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "杭州にて　杭州では西冷印社という印肉屋に朱肉を見に行ったりした。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し茶色がかった朱肉などもあった。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黒い、大きな判こが、朱肉になってくると、商業の具合がちがってくるな。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが朱肉の、奇麗な印判になると、自然古い商業の、法則と反したものが流れてきて、古い取引が倒れたり、新らしいやりかたが破産したりしたものと見える。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいきた」　一人が、受取ると、益満が、矢立を開いて、朱肉を印へついて、手紙を、裏返すと「うむ」　と、云った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "書類や筆墨や朱肉やなどの――あの役所にだけある特別な臭気が、つンと鼻をついた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険と書いた道路の建札と同じぐらゐ大きな書体で、親展と朱肉で捺してあるのである。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "山木はうなずき、ベルを鳴らして朱肉の盒を取り寄せ、ひと通り証書に目を通して、ふところより実印取り出でつつ保証人なるわが名の下に捺しぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日まで書き残して出来ずにおった雌龍の右の手が見事に書き上がって、然も落款まで据わって、まだまだ生々と致して印の朱肉も乾かず龍の画も隈取の墨が手につくように濡れて居りますのは、正しく今書いたのに違いありません」　――なんとこのスリルは鮮やかではないか。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも殺されたばかりの重信がのこりの絵を仕上げにかえってきているところいかにも芸道の士の幽魂らしく、さらにその落款の「朱肉も乾かず」というへんな生々とした実感さ。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙には「先日の雪の絵はなかなか良いが、あの判を貴方の所の朱肉で押されてはちょっと困る。",
              "citation": {
                "source": "南画を描く話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロー石の印は朱肉をつけておせば写りがよいけれど、スタンプインキをつけておしたのではからだめである。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに米兵らは朱肉をつかふことを知らないので、ロー石のスタンプにインクをつけてゴム印同様に習慣的にポンと叩きつけるのである。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱肉色の生雲丹のあとで、苦蓬をいれたジェリィの鳥肉が出てくる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンドイッチが、白と朱肉色の切り口を見せて坐っています。",
              "citation": {
                "source": "キャラコさん",
                "author": "月光曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は朱肉のいいのがなくなりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの小さい商品棚に、紫水晶、象牙、めのう、水牛などの印材朱肉入れの類が並んでいるのに気づかなければ、ちょっと見、何屋だか分らない構えだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒イ墨、又ハ黒イ肉ノ場合モアルガ、朱墨ヤ朱肉ノ場合モアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱肉の色は、上の印と、下のと少し違っているのう。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
