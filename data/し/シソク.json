[
  {
    "uuid": "290162b7-5fca-512c-908d-7226f7950fc4",
    "entry": "子息",
    "reading": {
      "primary": "しそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
