      "alternatives": [
        "しょうぜつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(in Japan) 4th note of the ancient chromatic scale (approx. F)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "平調―壱越（または神仙）―盤渉―黄鐘―双調（または勝絶）―平調この音階にあって宮音たる平調と、徴音たる盤渉とは、主要なる契機として常に整然たる関係を保持している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの関係は、勝絶より黄鐘を経て盤渉に至るときの黄鐘にも、平調より双調を経て黄鐘に至るときの双調にも現われる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "優勝絶対です」「それは優勝絶対にきまっとる。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人そろえば、優勝絶対だから」「じゃ、当ってみます。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
