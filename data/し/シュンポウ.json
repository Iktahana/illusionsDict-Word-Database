        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "峻峰皆將軍、磊嚴盡く貔貅たり。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "北は天塩北見界の峻峰群起して我れと高さを競わんとす。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あふげば西の山々の奧に南アルプスの峻峰は、折から夕日を浴びて眞白に雪を輝かしてゐる。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "峻峰奇峰の間に焼け崩れたようなぼろぼろの古代の城壁が見える。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘厳なものは岩の峻峰と空と太陽と城砦である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプスの峻峰を飛行機で飛び越えてベニスへ出る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "入れ代り立ち代り現れる、峻峰奇峰の無端の変貌。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それになほ、彼は、窓掛けを開いて連山の奧に、夕映の空の中に、赤味を帶んで紫に染めだされた颯爽たる峻峰を指して、あれがユング・フラウであると教へてくれた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夕食の後、一人で、窓に對し、暮ゆく空に獨り餘光を輝かしてゐるこの美しい峻峰をぢつと眺めやつてゐた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "山谿を彫み、峻峰を削り、きはめて徐々に、全くの沈默と思はるゝこれ等の氷雪が、不斷の動きを、目に見えぬ下降をつゞけてゐる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白な峻峰が、鋭い角度を空中に描いて、近づくも恐ろしいばかりに屹立つてゐる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紅葉時　今まで海に面していた眸子を転ずると、峠へ出るまでは見えなかった普賢の峻峰が、突如として道の行手を遮って、目の前に表われる。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大きな盆景を隔てて眉山の秀麗な峻峰と相対し、眉山の裾をひく不知火の海には九十九島が絵のように浮んでいる。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがアルプスのような峻峰ではない。",
              "citation": {
                "source": "ドナウ源流行",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに峻峰が見え出して来て、その裾に雲がかたまり薄く藍の色に見えている。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うには既に峻峰が迫っており、左手には寂しい人家を画いている。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "足尾山は、中宮祠湖畔の二荒山や、奥日光の峻峰を掩い隠しているけれど、わが上新田から一里半ばかり南方の玉村町近くへ行くと赤城と足尾連山の峡から奥白根の高い雪嶺が、遙かに銀白色の光を放っているのを眺め得よう。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四阿山は、上信国境の峻峰であるけれど、遠く榛名の西の肩に隠れて姿を出さない。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "古生層の緑色斑岩を主塊となす峻峰白根三山が、太平洋へ向かって長い裾を延ばした、その襟のあたりに水源を持つ興津川の水は玉のように洒麗である。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて遥か彼方、煙霧めいた層雲の上に、高い真白な峻峰が二つ並んで、その姿を現わしてくる。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキンレイの峻峰。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の多くはそれら峻峰を取囲んだ高低様々の山々である。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう風にして教育して居る中に低い山もようやく高い山となり、またその中に一峻峰を見出すことが出来るようになる。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丘の如き相貌を呈したものが他日の峻峰とならぬと誰が断言出来よう。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの城に上って見ると、周囲は皆ことごとく高山峻峰だ、山ばかり屏風のように立てこんでいたろう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐の連山や秩父の峻峰も、みなこの晴れの日を審議するもののように御岳のまわりをめぐっていた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　＊　　　　　＊　四国｜阿波の国第一の峻峰、つるぎ山の頂から一羽の角鷹が、バタバタバタと翼を鳴らして斜めに飛び、やがて、模糊とした霞の底へ沈んで行った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
