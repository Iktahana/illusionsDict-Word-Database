    "definitions": [
      {
        "index": 1,
        "gloss": "kindheartedness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうした前川の親切気を妨げる手もないので、新子はだまっていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と親切気に云はずには居られなかつた。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はどれほどの親切気で言い聞かしたのか知れないが、次郎左衛門は心からその親切を感謝した。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず与次郎が持って来てくれる――とまではむろん彼を信用していないのだが、まあどうかくめんしてみようくらいの親切気はあるだろうと考えている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父の甚五郎はなかなか親切気のある男で、わたくしなぞも何かに付けて世話になったことがありましたが、甚五郎は三年前に死にまして、今は伜が二代目の甚五郎を継いでいる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はメイ子の親切気と、そして現在の下宿の四畳半とを思つて、困つた顔で、その箱を取りあげ、鉄砲のやうに担いで外に出た。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言はれるのが何よりも得意で、精々悲しさうな顔をしようとしてゐるが、内村氏には他人の苦労まで背負はうといふ親切気が無いので、顔がリンコルンよりも、リンコルンの写真版に肖てゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって僕は、親類に本当に親切気があるなら、こんどなどは盛んな干渉のあることと思っていた。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、人前では虚偽を装って、平常｜擲りつける妻の腕を、親切気に保ってやる男もないではありませんでしょう。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の交渉の間、家主がプロフェッショナルでなく、丁寧に、又、親切気を持って居て呉れると云うことが、如何程我々をよろこばせたか判らない。",
              "citation": {
                "source": "又、家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう一生を棒に振りゃあがった」「よせばいいのに親切気を出して、病人の介抱なんかしたからよ」「ここまで来りゃあ大丈夫だ」年上の傀儡師は芒を投げた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といきなり当人に云ったと云う医者の態度があまり親切気がない様で切角主婦がああ云って居るのにそんな事を云っていやな思いをさせずともと、娘はすっかりいやな気持になって、　医者なんてまるで冷血動物だ。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持で気前のいい地主だろうか、それとも奉職ちゅうにたんまりと財産を拵えたような、親切気のある人間ではなかろうか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが、そのとりなしは決して親切気から出たものではなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ親切気を見せさへすれば、すぐにころりと落ちてしまふ。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永の母の保証するところでは、田口という老人は見かけに寄らない親切気のある人だそうだから、あるいは旅行から帰って来た上で、また改めて会ってくれないとも限らない。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、ほんとに心配そうな、私のことを思う親切気を眼色に浮べてのことだ。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいきなり、金を引出そうとしてる云々と、而も親切気を以てなので、私は答える言葉がなかった。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　しかし田舎にはこういったような、風体様子こそガサツではあるが、心が綺麗で親切気のある、長兵衛があることはあるものと思った。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣子や美代子には、親切気などないけれども、ヤス子は頼まれゝば、人のためにも計ろうとする気持があった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉や舌を買ってもその通り商人に親切気のある者が滅多にありませんから一々よく検査しないと高い代価を払って悪い品物ばかり押付けられます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な親切気など、起こすものではないと私は思った。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しもともと他巳吉は他人のことに自ら進んで一肌ぬぐといふやうな勇み肌の親切気は、まつたく持合せがなかつたのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大筒で退治してくれというようなことは、思いつきの、お座なりの希望で、とにかく、この近海へ、異様な怪物が現われたから充分の御注意あってしかるべし、ということを、親切気を以て報告に来てくれたことは疑いないのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "臍が茶を沸かすことといえば、臍が茶を沸かすことに違いないが、それだけまた相当に親切気を見せ、いたわるのだから、今のところ、あの女の手一つに、主膳の家庭味というものが握られて、甚だしい酒乱にも至らず、甚だしい放埒もない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはんやその誤を正さん親切気においてをや。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば開業十数年で学位を持っている人が応召すると見習士官で、はるかに年齢も下で、経験はほとんど皆無でも、軍医学校を出た者が中尉だったりして、「くさってしまう」場合が多かったのだろうが、それにしても、兵隊の命を粗末にするとしか考えられぬことや、いかにも親切気が足りぬと思われることが度々あった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一われわれに一任しようものならそれこそ大変、僕らは僕らのおめでたさと親切気とでもって、あたかも蠅がこの画に対してしたと同じことを、この世界に対してしでかすだろうよ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウチのカカアなんぞ、一度親切気を起したばかりに、ひどく腹を立てましたよ」「そうかい。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなやつにも、こんな親切気があるのかねえ」　と、口の中で言って、とろんとした眼、自暴に髪の根を掻いている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
