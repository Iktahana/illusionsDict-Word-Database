    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Emperor's cup",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向うから来かかった老婆がすれちがった時、二人は急に立止って、老婆の方から、「ホー、しばらくだったね、もう少しはいいかえ」と聞く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少しはいぢけてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の具合は少しはいいですか？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飴を塗った胡桃の串刺しはいかが？",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたといふの、　あゝ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられやうとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいつも自分の体の事は自分で致すのですから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "古樽の吹き直しはいやだ、材料が悪い。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたといふの、あゝ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられやうとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小半刻も経ってから彼女は怖々のぞいて見ると、白いまぼろしはいつか消えていて、どこかで一番鶏の鳴く声がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたというの、　ああ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられようとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此物何ぞ数ふるに足らんと劉伯温の云ひしはいかが。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれらの顔のクローズアップのむしろ頻繁な繰り返しはいよいよその暗い印象を強めるのであった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀の糞を鼻のあたまに浴びるなど、わしはいやなのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはいまでも、あのときわたしがうしかいのちょうちんにともしてやった火が、つぎからつぎへうつされて、どこかにともっているのではないか、とおもいます。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはいままで、いくつのものの命をとったかわからない、そしてその私がこんどいたちにとられようとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしはいまなら誰のためにでも命をやる。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母は　すこしはいゝか。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはいままでいくつのものの命をとつたかわからない、そしてその私がこんどいたちにとられようとしたときはあんなに一生懸命にげた。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう唯心論者もまだ少しはいるのである。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうせ何んでも自分でやらないじゃならない学校だからかまわないといえばかまわないことだが……今日は少しはいいの」　澄んで底力のある声が、清逸の眼にだんだん明瞭な姿を取ってゆく園の方から静かに響いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕はおどろいていたわりながら、「葦さん、ぼくは大変な事をしたねえ、いたいだろう」　と申しますと葦は悲しそうに、「それはすこしはいたうございます」　と答えます。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、わたくしはいつかの小さなみだしをつけながら、しずかにあの年のイーハトーヴォの五月から十月までを書きつけましょう。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしはいきなり野原へ走りだしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいろいろ話しかけて見ましたが、ロザーロはどうしてもかなしそうで一言か二言しか返事しませんので、わたくしはどうしてももっと立ち入ってファゼーロと二人のことに立ち入ることができませんでした。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいろいろやって見ましたがどうしてもいけなかったのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしはいきなり立ってデストゥパーゴに別れを告げました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　洋傘直しはいきなり高く叫びます。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御参詣の方にな、お触らせ申しはいたさんのじゃが、御信心かに見受けまするで、差支えませぬ。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
