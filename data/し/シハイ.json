[
  {
    "uuid": "357343e5-7c2e-5a8f-a3a3-e06ec87471c7",
    "entry": "支配",
    "reading": {
      "primary": "しはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
