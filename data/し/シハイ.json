      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rule",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新楽天主義（それは未来を支配する）の輝やかしい黎明の光がうかがはれる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもさうした純潔の詩人の生涯こそ、かの音楽家のそれと等しく、人生の最も神聖なる住宅、即ち道徳及びその他の感情生活の世界を支配する最高至美の権威でなければならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて此処では、「多勢に無勢」なる法則だけが支配し、芸術は何時も窘められるが、而も生活側が芸術を窘めようとすることこそ人類が芸術的要求を有する所以のものであり、芸術的要求の生活側に於ける変態的現象であると云へる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "価値意識の乏しい所は困雑が支配することとなる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "数々の解釈が多少とも夫々の偶然性に支配されるといふだけのことだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論人間は全的には何も支配することは出来ないことは彼も知つてゐるのだが、けれども彼が生きるとして、時間的なものに不満であるのは自然の勢ひだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の方が小説家より、とかく気分に支配され勝ちであるとか、気がよすぎるとか、小説よりも詩の本は少いとか、飜訳も小説のに比べれば不完全なものが多いなぞといふ様様な、随分尤もな理由があるのでもあらうが、詩人は切角刻苦しなければなるまい。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花やかにしゃちこばった気分がドイツ大学生特にいわゆるコアー学生の常住坐臥を支配しているように思われるのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は維新前いわゆる御鯨方の支配の下に行われた捕鯨の壮観と、大漁後のバッカスの饗宴とを度々目撃し体験していたので、出発前にその話を飽きるほど聞かされていた。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この深谷の幾千本針の針葉樹よりも、はた幾｜万斛の水よりも、一寸の魚が、谷の感情を支配していないとは言えなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、君が、現在の世の中に対して持つてゐる、支配階級へのじゆそ、君と同じやうに踏みくだかれてゐる者への愛情や涙、この不合理から自分自身を解放する為の組織、さういふものを、死を決して、遺言として残す積りでかゝれば、必ず人を打ち、動かすものが書けると思ふ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともまた現在で未来を支配する事が出来るものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくすると、急に家中がしんとして、大風の後のやうな靜穩が此の山腹全體を支配するやうに感ぜられた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気温や日照を人為的に支配することは現在の科学の力では望むことが出来ない。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、無理な注文かもしれないがもし出来ることなら、こうした機関はむしろ文部省の管轄からも独立させて、全く特殊な恒久的国家機関とし、非科学的なあるいは科学に無理解な御役人達の政治の支配下から解放して健全な発達を計るのが国家百年の大計のために甚だ望ましいことではないかという気もする。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体諸機関の活動を支配する脳神経の作用は別として、人間の五体殊に手足のごときものを力学的に見ればただ複雑な槓杆の組み合せだと云うことも出来る。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然に冥通の人間の上に、自然が支配する時間の爪の掻き立て方は人間から緩急調節できた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空間といえども自然の支配下のものであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子夫妻が父の祖神の翁に顔を合すとき、大体話は山の生産の模様、山民の生活の状況、それ等を統ねて行く岳神としての支配の有様、そのようなものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、恋愛の一分野たる精神意慾、ロマンチツクな詩的感激は必ず肉体慾にのみ支配されてあるべきものであらうか、否、その見解もまた当つたものではない、結局は霊肉一致、それをくりかへして云ふならば、最もロマンチツクなしかも最も現実に即した人生行路の途上に於ける詩篇なのであります。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人的または社会的体験に基づいた冷やかな知見が可能性としての「いき」を支配している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、灰色と茶色と青色の一切のニュアンスが「いき」な建築を支配している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "旋律の規範としての音階は、わが国には都節音階と田舎節音階との二種あるが、前者は技巧的音楽のほとんど全部を支配する律旋法として主要のものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室において行う簡単なる実験においてはこれら条件を人為的に支配し制限し得る便あり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うから来かかった老婆がすれちがった時、二人は急に立止って、老婆の方から、「ホー、しばらくだったね、もう少しはいいかえ」と聞く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少しはいぢけてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の具合は少しはいいですか？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飴を塗った胡桃の串刺しはいかが？",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたといふの、　あゝ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられやうとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいつも自分の体の事は自分で致すのですから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
