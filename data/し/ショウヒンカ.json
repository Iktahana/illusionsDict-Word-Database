[
  {
    "uuid": "20f7baf6-1982-50c0-a2ed-e7292cdedd5b",
    "entry": "商品化",
    "reading": {
      "primary": "しょうひんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
