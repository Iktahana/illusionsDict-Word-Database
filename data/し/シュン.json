      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "season (for fruit, seafood, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大隅君が渡支して五年目、すなわち今年の四月中旬、突然、彼から次のような電報が来た。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年の年月を過し、遂に石垣島を陥し入れたのは、つい旬日前のことであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋の薄ら冷たさも身に泌みなれた九月下旬の或日の夕方、いよ／＼それを取はづさうとして手をかけた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おれはその幾千由旬の海を自由に漕ぎ、その清いそらを絶え絶え息して黒雲を卷きながら翔けれるのだ。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の一月下旬、北米合衆国で数日続いて広区域にわたって著しい凍雨と雨氷があった。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長塚へ梅の歌を詠めと云うてやったら三月上旬に出京して実際を見てから作ると云うてきた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途はギリシアからブリンデイシ、ヴェニスを経て一八七三年五月初旬にロンドンに着いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月下旬に沓掛へ行ったときは時鳥が盛んに啼いたが、八月中旬に再び行ったときはもう時鳥を聴くことが出来なかった。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しもつき上旬のある朝、探偵は玻璃の衣裳をきて、街の十字巷路を曲つた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯んな事は僕達より、旬報さん、あんた方の方がよく御存じです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年の目出度き春を迎えるに際しましてキネマ旬報誌に折入って懇願致したい事があります。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中貞雄には、旬報さんよ、ダマッて活動写真だけを撮らせて置いて下さい。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走の下旬の話である。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傳染病室から普通の病室へ擔架で移されたのは、六月の中旬頃の事だつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時しか七月も中旬に近くなつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、六｜月の下旬にまたＴ市の居住地に歸營した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで十月中旬來引きつづいての朝毎の喘息發作も一おう納るのだらうと思ふと、恐らく人によつては非常な苦惱に違ひないところの九度二分の發熱も自分には何物でもなく、一種の肉體的福音なのだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が東京を去って、この七月でまる四年になるが、その間に、街路や建物が変化したであろうと想像される以上に人間が特に文学の上で変っていることが数すくない雑誌や、旬刊新聞を見ても眼につく。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　九月中旬になって東京の街路を飾るプラタヌスの並み木が何か思い出しでもしたように新しい芽を出している。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月初旬であったかと思う。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすきの木菟は旬はずれで、この頃はその尖ったくちばしを見せなかったが、名物の風車は春風がそよそよと渡って、これも名物の巻藁にさしてある笹の枝に、麦藁の花魁があかい袂を軽くなびかせて、紙細工の蝶の翅がひらひらと白くもつれ合っているのも、のどかな春らしい影を作っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "罷違うて旧道を皆｜歩行いても怪しゅうはあるまい、こういう時候じゃ、狼の旬でもなく、魑魅魍魎の汐さきでもない、ままよ、と思うて、見送ると早や深切な百姓の姿も見えぬ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は過ぎても、初夏の日の長い、五月｜中旬、午頃の郵便局は閑なもの。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五｜月の上旬……とは言ふが、まだ梅雨には入らない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして九月上旬にもう一度行ったときに、温泉前の渓流の向こう側の林間軌道を歩いていたらそこの道ばたにこの花がたくさん咲き乱れているのを発見した。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月初旬三度目に行ったときには宿の池にやっと二三羽の鶺鴒が見られた。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年六月、キネマ旬報）　　　　　六　バンジャ　映画「バンジャ」を見た。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　とんぼ　八月初旬のある日の夕方｜信州星野温泉のうしろの丘に散点する別荘地を散歩していた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は冬で鰈のしゅんだ。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
