[
  {
    "uuid": "dc300a13-fe46-5924-8282-89c60c9e1746",
    "entry": "旬",
    "reading": {
      "primary": "しゅん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
