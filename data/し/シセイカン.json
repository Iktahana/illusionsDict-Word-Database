        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍需参与官やら、海軍司政官までが当選しているし大日本婦人会の理事で当選している婦人もある。",
              "citation": {
                "source": "春遠し",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田信長がごっそり金と物資を運び去り、豊臣秀吉は市の三方にある濠を埋め、会合衆（佐貝の倉庫業者で共和自治体の司政官）らを強制的に大阪へ移住させた。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            }
          ]
        }
