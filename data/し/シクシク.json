[
  {
    "uuid": "6f38caca-078d-51d4-9914-69204c745db6",
    "entry": "しくしく",
    "reading": {
      "primary": "しくしく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "weeping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悲しむときは、鳴沢に小石が滑り落ちる音が止めどもなくしくしくと聞えて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は、いきなり両手を顔にあてゝしくしく泣いてしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたのか冬子が泣きながらはいって来て、着物をきかえ床へはいってもまだしくしく泣いていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」キッコは両手を目にあててまたしくしく泣きました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコはそこでやっぱりしくしく泣いていました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は、いきなり両手を顔にあててしくしく泣いてしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると楢夫がしばらく口をゆがめて変な顔をしてゐましたがたうとうどうしたわけかしくしく泣きはじめました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとだんだん泣きやんでつひにはたゞしくしく泣きじゃくるだけになりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ明日が手術という夜は、皆寐静まってから、しくしく蚊のように泣いているのを、手水に起きた娘が見つけてあまり不便さに抱いて寝てやった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんふくろふのお母さんはしくしくしくしく泣いてゐました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は、いきなり兩手を顏にあててしくしく泣いてしまひました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとうひるすぎの一時から、かま猫はしくしく泣きはじめました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんふくろうのお母さんはしくしくしくしく泣いていました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」象は細ういきれいな声で、しくしくしくしく泣き出した。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに思うと弱虫だった僕は淋しく悲しくなって来て、しくしくと泣き出してしまいました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と仰りながら僕を長椅子に坐らせて、その時また勉強の鐘がなったので、机の上の書物を取り上げて、僕の方を見ていられましたが、二階の窓まで高く這い上った葡萄蔓から、一房の西洋葡萄をもぎって、しくしくと泣きつづけていた僕の膝の上にそれをおいて静かに部屋を出て行きなさいました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にはいってから泣きやんでいた妹たちも、ぼくがしくしく泣きだすといっしょになって大きな声を出しはじめた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぶったってぼくはあとでかわいがってやったよ」「私だってかわいがってよ」　妹が山の中でしくしく泣きだした。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕はほとほとなんとお返事をしていいのかわからないでうつぶいたままでこれもしくしく泣きだしました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂にしくしく泣き出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "with a prolonged dull pain",
        "register": "standard",
        "nuance": null,
