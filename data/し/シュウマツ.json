    "definitions": [
      {
        "index": 1,
        "gloss": "end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太初の女王か終末の女王？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島の青年団によって喚び起された自分の今日の地震気分は、この静岡市役所前の青年団の歓声によって終末を告げた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州大戦の終末に近いある年のたぶん五月初めごろであったかと思う。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして静かにこの一編の終末がフェードアウトするのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この終末の取り扱い方にどこかフランス芸術に共通な気のきいた呼吸を見ることができるような気がする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "終末の幕切れに教授の死を弔う学生の「アーメン」にいたっては、蛇足にサボをはかせたようなものではないかと思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、果して嘘らしいか真実らしいかは、終末まで読んで見れば自然に判る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎も終末には黙って了った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "駐在所でも終末には持余して、彼等が悪事を働かない限は、其ままに捨てて置くらしい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兎に角、人間終末には枯淡な東洋趣味がいゝよ。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし春吉君だけは、事がまだ終末にいたっていない。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮時から讀み出したのだが、幽かにインキの匂ひの殘つてゐる手觸りの粗い紙の間に、使い馴れた象牙の紙切を入れる毎に面白みが増して、すぐに返事を出さねばならぬ手紙の來てゐた事も忘れ、先程女中の代へて行つた珈琲のすつかり冷え切つたにも心付かずに、つい一息に終末まで讀んでしまつた。",
              "citation": {
                "source": "新しい歌の味ひ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を見ても少し長い記事になると、もう五六行讀んだ許りで、終末まで讀み通すのがもどかしくなつて、大字の標題だけを急がしく漁つた。",
              "citation": {
                "source": "不穩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今一つその終末に、主人公が屍体に爪と頭を打ち込むところで、何となく「余計な真似」というような感じがしました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲の終末のクライマクスを現わす最高音でも同様で、ヤタラに高音を連続し、又は突然急調の変化を用いて観衆を刺戟するのは弱い方法であると同時に、そんな無茶な事は肉声では出来難い。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに思春期には終末幻想が亢進し、あんまり死ぬのが怖いので自殺まで考えたほどだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶化して通つたといつてもいゝので、其でもどうにか終末試驗に及第もするし心に苦痛といふことは感じないでしまつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "終末に関する大説教である、二十一章七節より三十六節まで。",
              "citation": {
                "source": "聖書の読方",
                "author": "来世を背景として読むべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十一講　ヨブの終末第四十二章七節以下の研究◯ヤコブ書第五章十一節に曰く「汝らかつてヨブの忍びを聞けり、主いかに彼に行し給いしかその終末を見よ、すなわち主は慈悲深くかつ矜恤ある者なり」と、まことにその通りである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯ヨブの「終末」を記すヨブ記の結末を語る前に既往を回顧するに、ヨブの異常の災禍に逢えるを三友は罪悪の結果と見、この罪を告白し懺悔せば禍は自ら去るべしと做して、経験と神学と常識とを以てヨブを責める。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　小説の危機　すべてのものには起源があると同様に終末がある。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして到頭｜終末まで読手で通した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今にして隣室の男の女中をからかか續けた心理や、世の終末をこの地に定めた青年たちの心理がだんだん眞近に響いてゐるのを感じて來た。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、何時になつたら済むといふのだ、念のため教へて欲しいと友達がいふと、フイシユは革表紙の擦り切れた新約全書を机の上から引張り出して、「有難いのは、この本だよ、ちやんと今度の戦争の終末期まで出てゐるから、大したもんさ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "決戦戦争では戦争目的達成まで殲滅戦略を徹底するのであるが、各種の事情で殲滅戦略の徹底をなし難く、攻勢の終末点に達する時戦争は持久戦争となる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンは新しき殲滅戦略により敵を圧倒したが結局ここに攻勢の終末点に達した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンはドノー川に沿うてウインに迫り、逃ぐる敵を追ってメーレンに侵入したが、攻勢の終末点に達ししかも普国の態度疑わしく、形勢楽観を許さぬ状況となったが、ナポレオンは巧みに墺、露の連合軍を誘致して十二月二日アウステルリッツの会戦となり戦争の目的を達成した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
