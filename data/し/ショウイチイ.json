    "definitions": [
      {
        "index": 1,
        "gloss": "first rank in the hierarchy of the government",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "播磨名所巡覧図会には「正一位小刑部大明神は姫路城内の本丸に鎮座、祭神二座、深秘の神とす。",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此野菜畑の突當りが、一重の木槿垣によつて、新山堂の正一位樣と背中合せになつて居る。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夜な／＼正一位樣の御使なる白狐が來て寢る處とかいふ事で、かの鰯の頭も信心柄の殊勝な連中が、時に豆腐の油揚や干鯡、乃至は強飯の類の心籠めた供物を入れ置くところである。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此野菜畑の突当りが、一重の木槿垣によつて、新山堂の正一位様と背中合せになつて居る。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夜な／＼正一位様の御使なる白狐が来て寝る処とかいふ事で、かの鰯の頭も信心柄の殊勝な連中が、時に豆腐の油揚や干鯡、乃至は強飯の類の心籠めた供物を入れ置くところである。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事によらず一代の名人巨匠となると女子供にはちょっと了解致し難い人間のぬしとなり切ってしまい、狐でいえば金毛九尾となって、狐の中の超正一位のぬしとなる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡者乙　　元老院議長……正一位……。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡者乙　　正一位大勲位公爵。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お札の表には正一位稲荷大明神と書いてあって、そのお札で撫でると、お医者さんでも癒らない病気が癒るとされてあるものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "続紀『天平神護元年、名草郡大領紀直国栖』と云ふは、紀伊国神名帳『名草郡正一位紀氏栗栖大神』と相因む所あらん、云々。",
              "citation": {
                "source": "国栖の名義",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　御稲荷様は皆正一位大明神なり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内の専門学校皆大学と改まり生徒は角帽金ボタン教師は誰しも博士とならば其名の空聞に帰せん事恰も御稲荷様の正一位に於けるが如くなるべし。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "御稲荷様に油揚を上げるは正一位なるが為ならず御利益のあるかなきかに基くなり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたもひどい人やな、卑しくも、もったいなくも、正一位関白太政大臣羽柴筑前守秀吉公を籠伏せの刑に仰せつけるとはいったいどうしたのですかい！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「正一位、女に化けて朧月」と作ったが、狂句めいて、自分ながらおかしくなった。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正一位女に化けて朧月」の下には「御曹子女に化けて朧月」とある。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一品（親王）八十町より四品四十町、正一位八十町より従五位八町まで。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）田令には位田正一位八十町より従五位八町までを規定し、別に禄令において正一位三百戸より従三位百戸までの食封を規定している。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに慶雲二年に至って、「冠位已に高うして食封何ぞ薄き」という理由の下に、正一位六百戸より従四位八十戸に増額された。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正一位位田八十町に対して食封は六百戸であるが、しかし従四位は位田二十町に対して食封八十戸である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち正一位においては一町すなわち七戸半、従四位においては一町すなわち四戸、太政大臣においては一町すなわち七十五戸である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神使のざうりとりさきにはせきたりて跋扈かり、大｜声にて正一位｜三社宮使者と大呼。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一条院の御時正暦四年五月廿一日　菅神に正一位左□臣を贈らる。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれば此　御神の御位は正一位大政□臣としるべし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後に正一位大夫人をもらった。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三代の才女が太陽の子を育てているとき、正一位三千代大夫人はこれもせッせと太陽の娘を育てていた。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太政大臣正一位大禅定入道浄海、謹んで申し奉る。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
