[
  {
    "uuid": "6ce68aa3-712e-58ad-a3af-d8cd75fe0918",
    "entry": "出仕",
    "reading": {
      "primary": "しゅっし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
