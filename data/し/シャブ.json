  {
    "uuid": "6c3aa6d1-75d7-54e8-87cf-e3c0c281437a",
    "entry": "しゃぶ",
    "reading": {
      "primary": "しゃぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shabu-shabu",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "純な子供の心はこの時に完全に大自然の懐に抱かれてその乳房をしゃぶるのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥や鼠や猫の死骸が、道ばたや縁の下にころがっていると、またたく間に蛆が繁殖して腐肉の最後の一｜片まできれいにしゃぶりつくして白骨と羽毛のみを残す。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小殿原はためしにしゃぶってみたことがあり、勝栗もかじってみたことがあるが榧の実ばかりは五十年間ただ眺めて来ただけである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山に並べた栗のいがばかりしゃぶらせるような教科書は明らかに汽車弁当に劣ること数等であろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の中隊が、橇でなく徒歩でやって来ていたならば、彼も、今頃、どこで自分の骨を見も知らぬ犬にしゃぶられているか分らないのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸じゅうの黄蘗を一度にしゃぶらせられた訳ではあるめえし、口の利かれねえ筈はねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き血を吸いに来たのか、骨をしゃぶりに来たのかと、お蝶はもう半分死んだもののようになって、一心に衾の袖にしがみ付いていると、やがてその衣摺れの音は次の間へ消えて行ったらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の、犬にしゃぶられた遺骸を見ようとつまさきで立ちあがっている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜索隊が行くまで、毛のむく／＼した野犬どもが集って、舌なめずりをしながら、しゃぶっていたそうだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ばかりの死骸は森の中の暗い処、おまけに意地の汚い下司な動物が骨までしゃぶろうと何百という数でのしかかっていた日には、酢をぶちまけても分る気遣はあるまい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてさて迷惑な、こりゃ目の前で黄色蛇の旨煮か、腹籠の猿の蒸焼か、災難が軽うても、赤蛙の干物を大口にしゃぶるであろうと、そっと見ていると、片手に椀を持ちながら掴出したのは老沢庵。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子馬が生まれて三日ぐらいだという場面で、母馬の乳をしゃぶりながらかんしゃくを起して親の足をぽんぽんける、そのやんちゃぶりや、また、けられても平気ですましている母の態度や、実に涙が出るほどかわいくおもしろい真実味があふれている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを買ってもらってしゃぶったものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥やねずみや猫の死骸が道ばたや縁の下にころがっているとまたたく間にうじが繁殖して腐肉の最後の一片まできれいにしゃぶり尽くして白骨と羽毛のみを残す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい時、きょうだいで寄ってたかって、おちちだといってしゃぶった疣だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　いやみ、つらみや、怨み、腹立ち、怒ったりの、泣きついたりの、口惜しがったり、武しゃぶりついたり、胸倉を取ったりの、それが何になるものぞ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄豪傑の汗なら好んでもしゃぶるが、こんな懦弱い奴の汗を舐めるのは御免である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩等は握飯を失ったので仕方なく、コーンビーフの缶詰を切り、握飯の中の梅干だけはまさか汗漬にもなるまいと、塩からい冷肉をパク付き、梅干をしゃぶっている心細さ！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狂女め、と振払う、むしゃぶりつくを突飛ばす。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その虹の散るのを待って、やがて食おう、突こう、嘗みょう、しゃぶろうと、毎夜、毎夜、この間、……咽喉、嘴を、カチカチと噛鳴らいておるのでないかい。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが却って葛飾を一層怒らせることになって、挙句の果に葛飾は、ヒステリイを起してまるで頑是ない子供のようにむしゃぶりつく美代子を振りもぎって戸外へ飛び出して行った。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代子は僕にむしゃぶりついた時に偶然――まさか計画的にではないでしょう――僕のネクタイを※りとったので、いい加減な出鱈目を思いついたのです。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん下の坊ちゃんが、わしのしゃぶってた骨をけとばしたもんだから、それで、その足にかみついてやったんだ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は母者人の乳房にもみずからすすんでしゃぶりつくようなことはなく、母者人のふところの中にいて口をたいぎそうにあけたまま乳房の口への接触をいつまででも待っていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は彼の幅のひろい胸にむしゃぶりついたのである。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行こうというあてもなく、駅のほうに歩いて行って、駅の前の露店で飴を買い、坊やにしゃぶらせて、それから、ふと思いついて吉祥寺までの切符を買って電車に乗り、吊皮にぶらさがって何気なく電車の天井にぶらさがっているポスターを見ますと、夫の名が出ていました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリイムをなめたって、キャラメルをしゃぶったって、活動写真を見たって、ほんの一時、気持がまぎれるだけのものじゃありませんか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の長老が、憎い仇の大腿骨を右手に、骨に付いた肉を旨そうにしゃぶった。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃぶり終ってから骨を遠くへ抛ると、水音がし、骨は湖に沈んで行った。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっときゃ土がすってしまうが」と、年とった百姓がわらすべをおりにひたしては、しゃぶりながらいいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
