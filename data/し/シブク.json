    "definitions": [
      {
        "index": 1,
        "gloss": "to splash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし木枯らし吹く夕暮れなどに遠くから風に送られて来るラッパの声は妙に哀愁をおびて聞こえるものである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の外はあらし吹く。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし吹くとなおたまらなくなってしまう。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "長く、かすけく、また遠く今はたつゞく一ひゞき呼ぶか閻浮の魂の聲かの永劫の深みより、「われも浮世のあらし吹く波間にうきし一葉舟入江の春は遠くして舟路半ばに沈みぬ」と。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が家の子ぞ折からにつゞく倉庫の向河岸古き映画の忘られし歌の一ふし繰返しくりかへし吹くハーモニカ。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲では無く、たんじゅんな二小節を、ただ息の続く限り、くり返しくり返し吹くだけ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し吹く程だといいのにと思っています。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の尻をしぶく鞭の音が凍る嵐にもつれて響いてきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "副業雨降りしぶくひるすぎを、　　青きさゝげの籠とりて、巨利を獲るてふ副業の、　　　銀毛兎に餌すなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菅がさきに眼を覺まし、その細ながい眼をしぶくあけてヴエランダへ出た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れて快く眠る子供の顔を見比べながら雨戸にしぶく雨の音を聞いているうちにいつのまにか説明のできない涙が流れた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨がしぶく、横さまにしぶく。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "片眼だけをしぶくあけて、出て來た。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮にせきもあへぬ女の吐息あはれその愁如し、しぶく噴水そことなう節ゆるうゆらゆるなべに、いつしかとほのめきぬ月の光も。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そがもとに噴水のむせび濡れ濡れて薄闇に入る……空気は重し……なほ赤し……黄に……また緑……いつしかに蒸汽の鈍き船腹のごとくに光りかぎろひし瘋癲院も暮れゆけば、ただ冷えしぶく茴香酒、鋭き玻璃のすすりなき。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――霧しぶく苑の奥、夕日の光、水盤の黄なるさざめき、なべて、いまものあまき嗟嘆の色。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、空に苦熱のうなり、見あぐれば、名しらぬ大樹千万の羽音に糜け、鈴状に熟るる火の粒潤やかに甘き乳しぶく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のひかり、雲のうつろひ、栄えしぶく麝香の真珠、――絶えず、わが夢かしたたる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらがなし、田螺ころころ、夜の昴宿しぶく泡だち。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "額髪の女童も交りて、ほつほつと、ひとりひとりに、軽き提げ重きはかつぎて、あなかなし五浦少女、草いきれ暑き小径を、潮しぶく東の磯の潮見堂、その母家まで、山越え野越え。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」踏躙る気勢がすると、袖の縺、衣紋の乱れ、波に揺るゝかと震ふにつれて、霰の如く火花に肖て、から／＼と飛ぶは、可傷、引敷かれ居る棘を落ちて、血汐のしぶく荊の実。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はしぶくように降って来た。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりからお十三夜の豆名月は、秋空｜碧々として澄み渡った中天にさえまさり、宵風そよぐみぎわのあたり月光しぶく弁天の森、池面に銀波金波きらめき散って、座頭の妻の泣く名月の夜は、今がちょうど人の出盛りでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷吉は頭が疲れて來ると、門の外に茫んやり立ち盡して、薄寒くしぶく、果てもない大洋を見た。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸にはしぶく雨滴が滝となって流れ、やがて破れ、突風は私のベッドにまず一撃をあたえて、花瓶も金魚鉢も吹き飛ばした。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何ぐずぐずしぶくってるのさ、きょうぐらいはけるじゃないか！",
              "citation": {
                "source": "自然描写における社会性について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かにはあわてて拾って食べてみますと、それはしぶくって口がまがりそうでした。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かにが、「こんどもやっぱりしぶくってだめだ。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は窓から、野一面白い花でうごめいている鉄道草の上に、雨のしぶくのを見ていたが、私はいつか知らない土地で、何時｜霽れるとも知れぬ長雨にあって、やはりこうして降る雨をみつめていた、子供の時の気持ちを思い出した。",
              "citation": {
                "source": "雨の回想",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に窓へ雨がしぶくと、水平線さえかすかに煙って見える。",
              "citation": {
                "source": "妙な話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
