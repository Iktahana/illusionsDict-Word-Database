[
  {
    "uuid": "6e8dafcc-a46d-5bd1-ba02-fd9fd9e4fd8c",
    "entry": "診療",
    "reading": {
      "primary": "しんりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "diagnosis and treatment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっともこれを忘れているおかげで今日を楽しむことができるのだという人があるかもしれないのであるが、それは個人めいめいの哲学に任せるとして、少なくも一国の為政の枢機に参与する人々だけは、この健忘症に対する診療を常々怠らないようにしてもらいたいと思う次第である。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏子の夫は歯科医で、大阪の戎橋附近の小さなビルの一室を診療所に借りて、毎日蘆屋から通っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の家は歯医者らしく、二階の部屋で白い診療衣を着た医者が黙々と立ち働いているのが見えました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野屋旅館に滞在し、久保博士の診療を受ける。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月、福岡に戻って久保博士の診療を受ける。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間経ったある朝、豹一が出社して間もなく、白い縮のシャツの上へ薬剤師や医者の着る白い診療服のようなものを羽織った男が、自転車を押してはいって来て、柱時計を見上げ、「あ、五分遅刻したぞ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者か――全科診療の開業医と見た。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えておいでの方もおられようが、こちらの結婚と、続く開業診療の開始後は、かつてあったホームズと私との深く親しい関係にもいくぶんか変化が生じた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに、あの四月二十四日の宵、うちの診療室に立ち入る友人の姿を目にしていささか驚いたのである。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い扉に紙を貼って、昨日の日づけで、診療の都合により面会を謝絶いたし候――医局、とぴたりと貼ってある。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花房の父の診療所は大千住にあったが、小金井きみ子という女が「千住の家」というものを書いて、委しくこの家の事を叙述しているから、loco citato としてここには贅せない。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ビルヂング街にある博士の診療所へ、此方の仕事の合間を見計らつては通つてゐる。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日僕が診療所の控室で順番の来るのを待合せてゐた時、隣りの応接部屋で、友達らしい老紳士と博士が雑談に耽つてゐる様子であつたが二人の会話のうちから次のやうな絶れ絶れの言葉を聞きとつたこともあつた。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、両親は、八九郎をつれ、遙々Ｔ市をたずねて、鬼頭博士の診療を請うことにしたのである。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "難澁してゐる病人があるといふことが耳に入れば、頼まれなくてもこつちから出かけて行つて診療したし、施療の範圍も今迄よりももつと擴張した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は黙って患者を診療して居ればよい、余計な世話を焼くな、と、こういうのです。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を診療してくれた友人は頻りに転地療養をすすめましたが私は頑としてきかず、妻も私の心に同情して、私たちは再び人工心臓の研究に取りかかりました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは患者に対して、非常に親切でして、重病患者などは、その家に寝とまりして診療に従事するという風でしたから、またたくまに四、五年の月日を送ってしまいました。",
              "citation": {
                "source": "ジェンナー伝",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の学校、診療所、産院等五ヵ年計画では大した予算で増設されている。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同炊事や托児所や診療施設など。",
              "citation": {
                "source": "新しき大地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カール・コルヴィッツというドクトルはつつましい生活をする勤労者のためにノルデンにあった月賦診療所に働くことを、科学者としての使命と考えていた人で、真に労働者の医者であろうとした人であった。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケーテの天性にそなわっていた思いやり、洞察、誠意は、良人カールの月賦診療所をめぐって展開される赤裸々な社会生活の絵図と、おびただしい肉体と精神とに負わされている階級社会の重荷とを、苦しみにゆがんでいる顔の一つ一つの皺に目撃することとなったのであった。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツェークーブは「学者の家」のほかに附属の病院、診療所、「休みの家」、クラブなどをもっている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きのう何故診療部へ行かなかったのさ。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の方の衛生準備はどうしても遅れていて、今度五ヵ年計画で診療所を非常に殖やすということで、医者を地方に派遣する新しい規定とか、いろいろなそういうものを制定している。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し有料診療を受けなけりゃならない場合は半額だ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "集団農場、工場は診療所をもっている。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、勤労婦人の現実の生活を身軽に、幸福にする各区の無料病院、託児所、診療所、母子健康相談所、共同食堂の経営などは、みんな市ソヴェトの保健部の仕事と関係があります。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の性質上婦人が多いので、ここの衛生委員は特別に歯科の診療所を工場内に設けた。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが働きながら歯医者へ通うことは時間の都合で不便だから、とうとうわたし達は工場へ歯科診療所をこしらえることにしたんです。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
