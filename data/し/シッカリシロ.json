        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いったい」と蛸の肩を突衝いて、よろけるのをまたぐいと引き寄せて「君の眼はどだい節穴だよ」「そうかい」「ちと確りしろ。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、確りしろ」　と世話役は叫んで、倒れたまゝ愈起きまじとする重右衛門を殆ど五人掛りにて辛くも抱上げ、猶ぐづ／＼に埋窟を云ひ懸くるにも頓着せずに、Ｘの字にその大広間をよろめきながら、遂に戸外へと伴れ出した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……確りしろシッカリ……あの青年が君にソックリなのは当り前の事なんだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お梅は恟りして、　梅「家の良人が何うか為ましたから誰方か来て下さいよう、總助さん／＼」　總「何うした／＼、きまりだ、吐血だ、だから酒を飲んじゃア宜かねえと云うのだ、何う云うものだこれ喜助｜確りしろ、喜助／＼」　喜「ウーン」　それなりに相成りました。",
              "citation": {
                "source": "政談月の鏡",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だろうと思って、ヒョイと見ると、ブル、ブル、ブル」「確りしろ、なんて間抜けな声を出すんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "確りしろ、みんなお前の臆病がさせたことだ」　小田島老人はまるで相手にしません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、確りしろ」「親分、あつしは、あつしはもういけない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火の呪ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でも親分を助けさへすれば本望だ」「何をつまらねエ、確りしろ、馬鹿野郎ツ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火の呪ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、確りしろ」「親分、あっしは、もういけない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でも親分を助けさえすれば本望だ」「何をつまらねエ、確りしろ、馬鹿野郎ッ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「確りしろ、これ、お前は厩番の綾吉に相違は無いか」　高蔵人は、差し寄って抱き起こしました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第三夜　お化け若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、義理や誤魔化しで泣くのではなく、聲をあげて泣く姿は、譬へやうもなく醜怪で、八五郎などは、「確りしろ、大の男が何んといふザマだ」　などと、間違つたやうな顏をして、二つ三つどやし付けた程でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒矢",
                "note": "青空文庫"
              }
            },
            {
              "text": "「確りしろ、八、もう大丈夫だ」　平次はその縄を切りほどいて、赤ん坊を抱くように起してやりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だらうと思つて、ヒヨイと見ると、ブル、ブル、ブル」「確りしろ、何て間拔けな聲を出すんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "確りしろ、皆んなお前の臆病がさせたことだ」　小田島老人はまるで相手にしません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "確りしろ、八」　さう言ふ平次も、漸くホツとした樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美保子、美保子、確りしろ、どうしたのだ、これは」　傷いたらしい体を抱き上げて、春樹は少し取乱して居ります。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美保子、確りしろ、傷は浅いぞ」　兄に抱き上げられた美保子の瑠璃色のエヴニングの胸は、緋牡丹を叩き付けたように血に染んで居りますが、幸に傷は浅かったらしく、暫くすると漸く物を言える程度に人心地付きました。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は怠けた、怪しからんことである、ドゥイング・ナッシング・イズ・ドゥイング・アイルだ確りしろ。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると男は、息も絶え絶えに、「も、もう削れねえだ、もう、些っと、押しても、それで……ああ、危ねえ――」「おい、確りしろ、誰がやったんだ」「…………」「おい！",
              "citation": {
                "source": "天狗岩の殺人魔",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだ、オイ、しっかりしろよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしろ」　無念の石松、叫ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると刑事は一枚の調査を私に手渡ししながら、「――おい、しっかりしろ、あの娘はとんでもない阿魔だぞ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また庭に引出して水をやあびせられむかと、泣叫びてふりもぎるに、おさえたる手をゆるべず、「しっかりしろ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洪水だ、しっかりしろ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむと唸くに力を得て「やい、しっかりしろ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしろ、生命と亭主は二ツなしだ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松、しっかりしろよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　境も歯の根をくいしめて、「しっかりしろ、可恐しくはない、可恐しくはない。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝が臆病だから、そんな夢を見たのだ、しっかりしろ」　平太郎は僕をしかりつけて置いて己の室へ帰って寝たが、もう眼が覚めて睡られなかった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
