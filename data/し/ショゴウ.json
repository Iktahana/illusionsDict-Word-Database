    "definitions": [
      {
        "index": 1,
        "gloss": "first number (e.g. issue of a magazine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初号活字の名刺でも作りますか。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初号は十五日に出す事、主筆が当分総編輯をやる事、其他巨細議決して、三面の受持は野口君と予と、モ一人外交専門の西村君と決つた。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥夫三年の間にちびちび溜めて来たというものの、もとより小資本で、発行部数も僅か三百、初号から三号までは、無料で配り、四号目には、もう印刷屋への払いが出来なかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二段抜の初号｜標題で畜生道におちた兄妹としたものであった。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の一日に初号を出す。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、皆は初号の原稿に忙しい。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "同人に加えない俺には、少しも必要のない初号の締切期日などを報じて、俺を苛だたしてやろうというあいつの悪意が、歴然と見え透いている。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜｜牛込山吹町の惨劇」、「被害者は妙齢の美人、犯人の目星つく」という初号活字を交えた四段抜き三行の標題で次のようなことが記されてあった。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という初号活字の号外さえ発行したところもある。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行田文学」の初号ができて持ってきたので、昨夜から文学の話が盛んにでた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が子供の時分に初号から十年あまりも購読してゐたといふ或る新聞社から発行されてゐた子供科学とお伽噺を主にしてゐた雑誌で、何でも彼は当時大変得意になつて大人の自分の処へまでそんな雑誌を月々贈つて寄したことがある。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒラガナノ活字ガイカニ醜イカトイウコトハ初号クライノ活字ヲ見タラダレニモワカルダロウ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）が創刊され、初号の巻頭に小杉天外氏が書くことになつてゐて、二号の分を私に書くやうにと言つて来たのが、大阪から附箋になつて廻つて来た。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝の新聞紙は、一斉に特初号活字、全段ぬきという途方もない大きな見出しで、「希代の科学者｜鏖殺犯人｜遂に捕縛せられる。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝へ聞く、ル・メルキウル・ド・フランスが初号を市に出せし時も、元より文壇不遇の士の黄白に裕なる筈なければ、やむ無く一株六十｜法の債券を同人に募りしかど、その唯一の大株主たるジユウル・ルナアルが持株すら僅々四株に過ぎざりしとぞ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の記事かいな」　吾輩が差出した新聞の綴込を抱えた山羊髯は、紙面を鼻の先に押付けて、初号活字の標題を探り読んだ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トント外国の漫画に出てまいります屁っぽこドクトルそのままで……読みさしの新聞の裏面に「花嫁殺し迷宮に入る」という標題が、初号三段抜きで掲げてありますところを特に大うつしにして御覧に入れておきます。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君等が生れない前の初号三段抜きだから、今で云ったら号外ものだろう。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは初号活字三段抜きの大標題で、次のような記事が殆んど社会面の全面を蔽うばかりに掲載されていた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その全面広告の中央には五寸四方ぐらいの呉羽嬢の丸髷姿の写真が、薄い小さな唇の片隅から白い歯をすこしばかり洩らした、妖美な笑いを凝固させており、その周囲に一寸角から初号、一号活字ぐらいの赤や黒の大活字が重なり合って踊りまわっていた。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、はっきりと見えるのは「生活、正月号」と云う初号活字である。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その初号に載った「鼻」を、夏目先生に、手紙で褒めて頂いた。",
              "citation": {
                "source": "羅生門の後に",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの特報は大きな注目を受けなければならないのに、多くの人の目は多くというより、その悉くが鎌子夫人事件の見出しの、初号活字に魅惑されてしまった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして、これへ来られましたな」「これごらんなさい」そう云って彼の差出したのは、初号活字の大きい見出しのついた東京××新聞の号外だった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
