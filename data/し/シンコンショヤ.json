        "examples": {
          "standard": [
            {
              "text": "新婚初夜は、二人の思い出に残る特別な夜となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊張と期待に胸を膨らませて、新婚初夜を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新婚初夜を祝うために、友人がシャンパンを贈ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば新婚初夜に於ける権右衛門の態度だ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一人前にアロハなんか着やがってるくせに新婚初夜に木石じゃないか。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚初夜の行事に、処女を犯すという表現は、カストリ雑誌以外ではチト無理でしょう。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
