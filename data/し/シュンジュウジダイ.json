    "definitions": [
      {
        "index": 1,
        "gloss": "Spring and Autumn period (of Chinese history; approx. 770-403 BCE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "源為朝（平安末期の武将、剛弓の使い手）や養由基（中国、春秋時代の楚の武将。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また三国の時の孔明（諸葛孔明）は、管仲（中国春秋時代、斉の政治家）、楽毅（中国戦国時代の燕国の武将）などの人々を自分の心の目標としていた。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "老子（中国春秋時代の哲学者）が関所を出ようとするに先だって関尹喜（関所の役人）が望んで之を知った気は紫気である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "子路は孔先生（孔子：中国・春秋時代の思想家、儒学の祖。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、秦（中国、春秋時代の一国）を滅ぼし、楚（中国、春秋時代の一国）を滅ぼした韓信（中国、漢の将軍）は真に好将軍である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（子曰く）　子は男子の通称であり、ここでは孔子（中国・春秋時代の思想家、儒教の祖、孔丘字は仲尼。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから、老子（中国春秋時代の哲学者）が、「大道は極めて平らかなのに、なぜか人々は径を好む。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子は中国の春秋時代の人で、その時代の制度の中で自己を修め社会を正すことに努められたので、そのため現在の私たちから見て肯定できない面も多々あります。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルフォールの印度百科全書三版四七八頁）　支那には春秋時代呉王闔閭の女藤王がすてきな疳癪持ちで、王が食ひ殘した魚をくれたと怒つて自殺した。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "由來秦國は春秋時代よりして、稍や列國と異なる色彩を有し、武力を以て著はる。",
              "citation": {
                "source": "韓非子解題",
                "author": "小柳司気太",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が春秋時代となつて、周の王室が衰微すると、楚・呉・越等南蠻の國君が王號を僭し初め、降つて戰國時代となると、中國の諸侯達も亦之に倣ひ、最後に陪臣より諸侯となつた韓・魏・趙の三晉の君すら王と稱して、王號の價値は甚だ低落して來た。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い年月の間には、攻爭併呑の結果、是等の諸侯は次第にその數を減じ、春秋時代には百六七十國、戰國時代には十國内外となり、最後に秦の一統となつた。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "列國平和會議（弭兵會）なども支那が開祖で、已に二千四五百年前の春秋時代に實行されて居る。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "降つて春秋時代になると、有名な齊の桓公、晉の文公、何れも人肉を食して居る。",
              "citation": {
                "source": "支那人の食人肉風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に春秋時代から、この禮制に違背する者があつた。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋時代の宋の樂子明（溷）が、服中に子を生んだ爲め、喪※而生子とて、その同姓の者から罵倒されて居る（『左傳』定公九年）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋時代に起つた親殺し事件の處分を、『禮記』に左の如く記してある。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに紹介した春秋時代の直躬は、父の罪を訐いた爲め、死刑に處せられて居る（『韓非子』五蠹篇、『呂氏春秋』當務篇參看）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は春秋時代に決めた親殺しの處分法であります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らばこれらの思想智識は春秋時代に於いて孔子時代以前に存せしは明也。",
              "citation": {
                "source": "『尚書』の高等批評",
                "author": "特に堯舜禹に就いて",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど禹貢の九州が荊州即ち楚の地を含めるに見、一方この地方の知られたるは春秋時代なるに見ば、兎に角周時代まで泝らせ得べきには非ざる也。",
              "citation": {
                "source": "『尚書』の高等批評",
                "author": "特に堯舜禹に就いて",
                "note": "青空文庫"
              }
            },
            {
              "text": "先秦の文化が伝説にいう周の文化として完成せられ、その末期の春秋時代に至って反省せられ、次いで戦国の時代の混乱と破壊とによって次の新しい文化に所を譲ったことは、ちょうどギリシアがローマに変わったことと同じ意味に解せられねばならない。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋時代に支那へ鞦韆が渡らなかつたと云ふ反證はないけれど、其後久しく文献の徴すべきものがないことを考へると、さまでに古るい起こりでなささうに思はれる。",
              "citation": {
                "source": "鞦韆考",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋時代の名臣であつた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、当時は春秋時代の末期で、道義が地に落ち政治の大本がみだれていたので、孔子は時にその方面のことが強調したかつたのであろうと思われる。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その戦争はさらに乾坤一｜擲な次の大戦争を大坂方とのあいだに孕んではいるが、しかしそれはもう長い戦争の終局的なもので、その一戦で長い長い日本の春秋時代も、ほんとの平和に回るだろうと、一般の人心は観ているのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
