        "examples": {
          "standard": [
            {
              "text": "最終回まで勝敗の分からない、まさにシーソーゲームだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "選挙戦は、最後までどちらが勝つか分からないシーソーゲームの様相を呈した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テニスの試合は、互いにポイントを取り合うシーソーゲームとなり、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "力の均等したる二つのチームのシーソーゲームにおける肉薄と追撃は、まさしくこの二つの判断の力学的構造を、外的現象の上に具象化するものである。",
              "citation": {
                "source": "スポーツの美的要素",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ううちに半馬身ほど抜かれ、さらにずっと抜かれるかと見るまに、反対に半馬身先に立つ――と思うと……まるでシーソーゲーム。",
              "citation": {
                "source": "競馬",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーソーゲームのように押しつ押されつ、一学期も終ったある日、用事で本校へ出むいていった男先生はみょうなことをきいてかえった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
