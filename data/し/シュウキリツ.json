        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そは幾何學的の周期律を示さない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども旋律的な周期律を示して居る。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも一つの「自由なる周期律」を有するリズムである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて韻律は拍子（拍節の周期律）を意味した。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既知の元素との対応を付けられなかっただけではなく、周期律表の中で将来の発見に備えて空席になっている場所に当てはめることにも失敗した。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋に理論的な研究（化学元素の周期律の研究など）の他に、木材から照明ガスの製法、古くなった絵の色を元に戻す方法など、種々の実用的研究を行った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
