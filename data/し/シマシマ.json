        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このために画面の高さの五倍くらい離れないと、縞々が目について見られない。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オンエアされる詩、それは縞々のズボンを履いた美神たちのように聞こえる。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配者となるのは縞々のズボンを履いた人々だろう。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい話ながら動物崇拝など大抵こんな事で、金色の鼠王なども当時の中央アジア人に取っては、わが国王こそ毘沙門の正統で、現にその使物が生身でわれわれの供物を納受しましますという信念を堅め、中央アジアの文化を高むるに大いに力あった事と惟う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば女人の御身として、かかる濁世末代に、法華經を供養しましませば、梵王も天眼を以て御覽じ、帝釋は掌を合せてをがませたまひ、地神は御足をいただきて喜び、釋迦佛は靈山より御手をのべて、御頂をなでさせ給ふらん、南無妙法蓮華經南無妙法蓮華經。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……がしかし殿にはどう遊ばしましますので？",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……堅磐常磐に斎ひまつりて、いかし御世に栄えしめまつり、康治元年より始めて、天地日月と共に、照し明らしましまさむことに、本末傾かず、いかしほこの中執り持ちて、仕へ奉る中臣｜祭主正四位上神祇大副大中臣清親寿詞をたゝへ、こと定めまつらくと申す。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「着々事が運んで行く」　宮家は悦喜しましました。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひとは　がらものの　うわぎを　すそで　まくりあげ、　しましまの　スカートのうえに　おおきな　エプロンを　かけていました。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち　２ひきは　にげきりましたが、　いちばん　ちいさいのは　ジャクソンさんに　つかまってしましました。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "往昔、孔子は「怪力乱神を語らず」といわれたるに、予がごとき浅学の者、天地間の大怪たる幽霊、鬼神を論ずるは、孔子もしましまさば、一声の下に呵責し去るはもちろんなりといえども、時勢変遷の今日にありては、またやむをえざるなり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
