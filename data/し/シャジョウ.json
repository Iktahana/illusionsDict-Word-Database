[
  {
    "uuid": "71083346-db96-5a40-b457-134a269f8d2d",
    "entry": "射場",
    "reading": {
      "primary": "しゃじょう",
      "alternatives": [
        "いば"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "archery range",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "騎射場一切の準備は整うて、騎士は悉く指定の地に就く。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出でゝ右一町餘りにして大騎射場に達する。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大殿蟲麿が關東隨一の騎射場と誇つて居るところ、之れに東葛飾一郡にして、名馬を養ふ武夫二百人を越ゆると云ふが、特に得意禁じ難き點である。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "栴檀の木稲荷の絵馬売の老婆に託して、源之丞が射場通いの途中、密と手渡して貰ったのであった。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガッチリ弓を棚に掛け、袴両袖をポンポンと払うと、静かに葉之助は射場を離れ、端然と殿の前へ手を支えた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼等は、鍬を捨て文選箱を投げて注射場へ集まつて行く。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして注射するのはただ永年の惰性であつたり、また全然注射場へ現はれないのもある。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はまた弓射場にもなっているので、月に幾日か弓袋を持った人が出入して、的に中る矢の音が聞えます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラブというからなにをしているのかと思ったら、療養所の外気室のようなヴェランダのついたコテージの中へ、酒場だの、グリルだの、モンテ・カルロ式の鳩射場などをこしらえて、戦争中、毎日パァティをして遊んでいたというんですから」　ママがまたいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お願いだから、やってちょうだいね」　キャラコさんは、日曜ごとに長六閣下と戸山ヶ原の射場へ出かけて行って、射※のカンヴァスに閣下と並んで腹ばいになって、いっしょうけんめいに点数を争う。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月はじめのある日、この原にオランダ人献上の大臼砲を据えようというので、御鉄砲御用衆といわれる躑躅の間｜詰のお歴々が、朝がけから、露もしとどな夏草を踏みしだき、間竿を持った組下を追いまわして、射場の地取りをしていた。",
              "citation": {
                "source": "ひどい煙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝あけから、床几に縛りつけて、射場の地取りを見せておいたが、貴様には、この謎がとけなかったそうな」「とても、そこまでのことは……しかしながら、玉の出ぬ大筒は射てぬはず。",
              "citation": {
                "source": "ひどい煙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　カロンの臼砲の領収発射は、六月二十一日、勝手ヶ原の射場で行われた。",
              "citation": {
                "source": "ひどい煙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "御鉄砲方、大筒役、火薬奉行の組下、与力、同心、属役は、日の出前に射場に集合した。",
              "citation": {
                "source": "ひどい煙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三弾は小臼砲から射ちだされたが、充弾が空中で炸裂し、稲妻のような青白い彩光が射場の上に閃きわたった。",
              "citation": {
                "source": "ひどい煙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "五二　破魔射場という地名　この地名は奥州から中国にわたって無数にあるが、まずその中から破魔射場の文字を宛てた者のみを挙げてみる。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほかに浜射場とある例もあり、また別に浜弓場または浜矢場と言うのもある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもゆずりあって射場にのぼり、勝負がすむと射場を下って仲よく酒をのむ。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同ピストル射場の外に出て、息を殺していると、刑事は竿の先を押入の天井まで上げて、狙を定め、怪物の腕を目がけて非常な勢で叩きつけた。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
