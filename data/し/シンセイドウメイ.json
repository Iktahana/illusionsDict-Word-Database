    "definitions": [
      {
        "index": 1,
        "gloss": "Holy Alliance (of Russia, Austria and Prussia in 1815)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
