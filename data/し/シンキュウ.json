[
  {
    "uuid": "fc7915ea-8365-5eeb-a557-fa5649c96cff",
    "entry": "新旧",
    "reading": {
      "primary": "しんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
