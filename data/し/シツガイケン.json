        "examples": {
          "standard": [
            {
              "text": "「バスケットボールのジャンプ動作を繰り返したことで、膝蓋腱を痛めてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「膝蓋腱は、太ももの筋肉の力を脛の骨に伝える重要な組織だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「膝の皿のすぐ下にある膝蓋腱を押すと、鈍い痛みを感じる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "膝蓋腱反射は両側とも同程度に減弱している。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
