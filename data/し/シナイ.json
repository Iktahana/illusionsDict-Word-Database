  {
    "uuid": "6caa77b2-88e5-5bee-b6f6-00063a2592c5",
    "entry": "竹刀",
    "reading": {
      "primary": "しない",
      "alternatives": [
        "ちくとう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bamboo sword (for kendo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おまけに竹刀でバシバシと、すこたんを遠慮なしに打ん殴りやがったっけ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹刀が長持ちに幾杯とかあったというような事を亮の祖母から聞いた事がある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃剣でも竹刀の打ち込まれる電光石火の迅速な運動に、この同じ手首が肝心な役目を務めるであろうということも想像されるであろう。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で竹刀を使つてゐるのだと、立處に引込まれて、同伴が犬に怯えたかはりに、眞庭念流の腕前を顯はさうといふ處である。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は江戸ももう末で、世の中がだんだんに騒がしくなって来たものですから、町人でも竹刀などを振りまわす者も出来て、浅井さんにお弟子入りをしている若い衆が十人ぐらいはありました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はすぐに組中の子供を呼びあつめて、めいめい木刀や竹刀を持ち出して、およそ十五六人が鬨を作って追って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに点呼当日長髪のまま点呼場へ出頭した者は、バリカンで頭の半分だけ刈り取られて、おまけに異様な姿になった頭のままグランドを二十周走らされ、それが終ると竹刀で血が出るくらいたたかれるらしいという噂は、私を呆然とさせた。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士はうやまひあつし竹刀とりお前にとうと聲｜徹り撃つ激しくうちあふ竹刀眼には入れこの畏こさに面も小手もわかず營庭にて三聯隊の兵全部凹形に整列し、隊歌を合唱す。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士はうやまひあつし竹刀とりお前にとうと声｜徹り撃つ激しくうちあふ竹刀眼には入れこの畏こさに面も小手もわかず営庭にて三聯隊の兵全部凹形に整列し、隊歌を合唱す。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道の時間なども大抵は病気と称して見学し、真面目に面をつけて竹刀を振廻している私達の方を、例の細い眼で嘲笑を浮べながら見ているのだったが、ある日の四時間目、剣道の時間が終って、まだ面も脱らない私のそばへ来て、自分が昨日三越のギャラリイで熱帯の魚を見て来た話をした。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃劍の竹刀の撃合ふやうな音と、威勢のいい掛聲とが入り交つて、如何にも爽やかな感じである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃剣の竹刀の撃合うような音と、威勢のいい掛声とが入り交って、如何にも爽やかな感じである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに竹刀離れがして来たぞ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "面小手で竹刀を引担いでお前、稽古着に、小倉の襠高か何かで、朴の木歯を引摺って、ここの内へ通っちゃ、引けると仲之町を縦横十文字に鳴して歩いた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はたうとう憤慨のバネに撥ぢかれて、あの日に天狗党の末孫から贈られた竹刀に取り縋りながらうねうねと立ちあがつた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹刀の音もなく、ひとりの懸声ばかりが澄み徹つて響いてゐた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴々の武士が竹刀の持ちようも知らず、弓の引きようも知らず、それでも立派にお役を勤めて家繁昌する世の中に、なんの役にも立たない鎧や刀は、五月の節句の飾り具足や菖蒲刀も同様だ。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その指先にはりっぱな竹刀だこが、少なくも剣道の一手二手は使いうることを物語る証左の竹刀だこが、歴然としてあったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、鋭く目を射たものは、疑問の藩士の両手の指と手のひらに見える竹刀だこでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹刀だこの当たっているほど武道熱心な者が、見るとおり両刀は腰にしたままで、鯉口さえ切るひまもなくあっさりやられているところを見ると、この下手人はじつに容易ならぬ腕ききにちがいなかったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの決まったところ、さっとつぶてをかわしたところ、きりっと体が締まったところ、おいたはおよしなさいませとおちついたところ、やっとう剣法、竹刀のけいこでたたきあげたにしても、まず切り紙以上、免許ちけえ腕まえだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論その間に、俺は二三度調べに出て、竹刀で殴ぐられたり、靴のまゝで蹴られたり、締めこみをされたりして、三日も横になったきりでいたこともある。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「××、××――え、××――え※」　それは竹刀、平手、鐵棒、細引でなぐられるよりひどく堪えた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　遠くで劍術をやつてゐるやうな竹刀の音（たしかに竹刀の音だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を後に縛ったまゝ刑事部屋の天井に吊し上げられ、下からその拷問係が竹刀で殴ぐりつけた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云った、彼女も二度ほど警察で、ズロースまで脱ぎとられて真ッ裸にされ、竹刀の先きでコヅキ廻わされたことがあったのだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、これは、僕の無理だ、　　　　こんなに、野道を歩いてゐながら　　　　野道に、食物、ありはしない。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌もつれようともつれまいと花に嘘などつけはしないんだ。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へやつて来た此の鉄色がかつた栗色の肌の牧野信一は、部屋に這入るなり進みもしないで坐つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕、邪魔はしないからねえ、邪魔はしないからねえ」と、みんなの者に云つたのがその時の挨拶であつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
