[
  {
    "uuid": "65ecf07d-088f-58bd-9715-a6318e685f84",
    "entry": "市内",
    "reading": {
      "primary": "しない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in the city",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はズツと離れた郊外にゐたし、彼の友人や知人はみんな市内やまた他の方面の郊外にゐたので、彼は電車賃がないとなれば、誰かが遊びに来るのを待つてゐて、遊びに来た者から借りるか、それとも本を売るかしなければならないのだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は口惜しい儘に、毎日市内をホツツキ歩いた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪具箱へスケッチ板を一枚入れて、其れと座蒲團代りの古い布切れとを風呂敷で包み隱したのを抱へて市内電車で巣鴨迄行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道では、今でもまだ人間と動植物が生存競争をやっていて、勝負がまだ付いていないという事は札幌市内の外郭を廻っても分る。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛西という名が、旧東京人の父には、市内という観念をいかにしても受付けさせなかった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼女の癇高い水銀色の声が市内の電線を引ちぎってしまう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日ほど前に家の半町ほど先に起つた女中殺しのためだが、住み馴れて既に二十六年、東京市内にもこんな閑靜な好ましい屋敷町はさうあるまいと思つてゐたほどの町内も、あの騷ぎですつかり臺無しにされた感じ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に這入るとこれがいっそう多くなる。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが東京市内に限らず全国的であることを思うといっそう著しいことと思われて来るのである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "便衣隊と前後して、共産党員が市内にもぐりこんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内の小学校を出た子供は、先生が六カ月も前から、肝煎って受験準備を整えている上に、試験場でもあわてずに落ちついて知って居るだけを書いて出すが、田舎から出て来た者は、そういう点で二三割損をする。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行一も水道や瓦斯のない不便さに身重の妻を痛ましく思っていた矢先で、市内に家を捜し始めた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近に東京帝国大学地震学科学生某氏は市内二か所の街上における自動車の往復数に関する統計についても、やはりかなりの程度まで同様な物理的方則が適用される事を示した。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――市内に友人ないのか。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市内の地理と警察網に精通している新聞記者の私であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある事件で朝刊の市内版を遅らしたために、三時近くなったので、主筆の自宅に押しかけて泊めて貰うつもりでタタキ起したがなかなか起きない。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具箱へスケッチ板を一枚入れて、それと座ぶとん代わりの古い布切れとを風呂敷で包み隠したのをかかえて市内電車で巣鴨まで行った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、大多数の東京市内電車の乗客は、長い休止の後に来る最初の満員電車に先を争って乗らなければ気が済まないように見える。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち「第一に、東京市内電車の乗客の大多数は――たとえ無意識とはいえ――自ら求めて満員電車を選んで乗っている。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市民を驚かせるような強震が二日に一度三日に一度ずつ襲って来るとしたらどうであろうか、市内の家屋構造は一変してしまい、地震研究所の官制は廃止になるであろう。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌で教師をしていた頃も、よく学校を休んで市内の旅館に泊りこんで筆を取ったものです。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーン市内の青年男女の有志者が、芝生の上で終日、四つん這いになって暮しているのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この謠をですね、醉つて私は唄ひながら、あの坂を降りて東京市内から自宅の方へ歸つたものですよ。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝か、晝ごろ出れば大がい夕方醉つて私は市内から歸るのでしたよ。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にも取らないで、口のなかに低声におよみなすったのが、市内衛生会委員、教育談話会幹事、生命保険会社社員、一六会会長、美術奨励会理事、大野喜太郎。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか、市内は一音信金五錢で、局待の分ともで、私は十錢より預つて出なかつた。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "假に場所を東京市内に選んで、神田とすれば、又其處に特有の天然があります。",
              "citation": {
                "source": "小説に用ふる天然",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおかくの通りの旱魃、市内はもとより近郷隣国、ただ炎の中に悶えまする時、希有の大魚の躍りましたは、甘露、法雨やがて、禽獣草木に到るまでも、雨に蘇生りまする前表かとも存じまする。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、これは、僕の無理だ、　　　　こんなに、野道を歩いてゐながら　　　　野道に、食物、ありはしない。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
