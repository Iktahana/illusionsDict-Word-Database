    "definitions": [
      {
        "index": 1,
        "gloss": "season (period in which regulated games are played)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし日本も東京辺では四月末から五月初めへかけて色々な花が一と通り咲いてしまって次の季節の花のシーズンに移るまでの間にちょっとした中休みの期間があるような気がする。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったら自分も一つやってみようかなどとこのようなたわいもない夢のような事を思うのもやはり美術シーズンの空気に酔わされた影響かもしれない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国でも毎年四五月ごろは山火事のシーズンである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またＡとＢとは同じ野球チームの選手だが、春のシーズンには二人とも同じ打撃率だったものが、秋のシーズンになってＡは安打数が増え、Ｂは相変らず凡打、三振を続けている。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は毎夜露き出しの夜会服の背中を寒がりながら、シーズンの演劇を見て廻つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の横の金網の目から、春のシーズンの名残りらしく野球の球が白く往き来しているのが透けて見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳月がたつと、一代の想出も次第に薄れて行ったが、しかし折れた針の先のように嫉妬の想いだけは不思議に寺田の胸をチクチクと刺し、毎年春と秋競馬のシーズンが来ると、傷口がうずくようだった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新協なんか、もうせんから、シーズンになれば欠かさないのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろ／＼君のシーズンが来るな。",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夕暮にちかい時分に岡の裏側にある競馬場へ行つて見ると、「シーズン」が近づいたといふので日毎に練習馬の数が増えてゐる。",
              "citation": {
                "source": "娘とドリアン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、船長は猟のシーズンが来ても、例の事務所に姿を見せなかったので、これに代る者を物色せねばならないことになった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多年の間、このシーズンにここへ来る船のうちで、どの船であろうとも、わが北極星号のごとく多くの鯨油の金をもたらしたものはなく、諸君も皆その多額の分配にあずかってきたことを、心にきざんでおいてもらわなければならない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "海のシーズンであたりが賑やかであればあるほど、徒然の毎日を送つていらつしやる百合子さんはお淋しいことゝお察しいたして居ります。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　翌年のシーズンに久保は、「美奈子夫人の肖像」と題する作品を発表した。",
              "citation": {
                "source": "階段",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーズンはずれのさびしい葉山の街には、もう灯がともっていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裡に秋が来て、冬物を着るシーズンとなっても、大島の揃は、中々出来る様子は見えなかった。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ・バーズ、〈（トゥ・エヴリシング・ゼア・イズ・ア・シーズン・）ターン！",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこうした嫌厭の情を胸に抱きながら、そのシーズンは終わった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーズンが終わると、私たちは別れた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは今、自分の病室で静かにあの当時のことを回想していると、一八八四年のあのシーズンのことどもが異様に明暗入り乱れて、渾沌たる悪夢のように見えてくる。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、懊悩と嫌悪の念を持って、わたしは去年のシーズンのことや、ウェッシントン夫人のことを思い出した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、今の雇いぬしは誰なんでしょうね」　キッティは前のシーズンにウェッシントン夫人とちょっと逢ったことがあって、蒼ざめている彼女については常に好奇心を持っていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために、彼は過去六シーズンのあいだに築き上げた上手な話し手としての名声を台なしにしてしまった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのシーズンには、イーグル・ハウスはいつもより客が少なかつた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　竹下は、シーズンの制作に、海辺の風景を選んで、麗かな日だと午前から百合子やローラやそして八重達を誘つて、馬車で海辺へ通つてゐた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月中旬からロンドンも急に夏らしくなって、日曜日の新聞を見ると、ピカデリー・サーカスにゆらめく青いパラソルの影、チャーリング・クロスに光る白い麦藁帽の色、ロンドンももう夏のシーズンに入ったと云うような記事がみえました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月中旬から倫敦も急に夏らしくなって、日曜日の新聞を見ると、ピカデリー・サアカスにゆらめく青いパラソルの影、チャーリング・クロスに光る白い麦藁帽の色、ロンドンももう夏のシーズンに入ったと云うような記事がみえました。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
