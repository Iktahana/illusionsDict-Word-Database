  {
    "uuid": "bcd04181-2710-50cb-9cc9-43f9f738b8ab",
    "entry": "松竹梅",
    "reading": {
      "primary": "しょうちくばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
