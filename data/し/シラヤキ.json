          "literary": [
            {
              "text": "そして屋形船で雪見酒をやり乍ら、木場あたりの川岸へつけて、障子の蔭から鯨骨と象牙の一尺ばかりの小竿を出し、炬燵にあたりながら、タナゴを釣つて白焼きにし、三杯酢につけて酒の肴にした。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白焼きの橙酢、から揚げ、ふらい、椀種、味噌田楽。",
              "citation": {
                "source": "榛名湖の公魚釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味が少ないから白焼きの橙酢、カラ揚げ、椀種、味噌田楽向きにこしらえてもおいしい。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣った山女魚を白焼きにして、まだ温かいうち生醤油で食べれば、舌先に溶ける。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供相手の面白焼きが地面に筵を敷いて支度をしている。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
