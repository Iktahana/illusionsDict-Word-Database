    "definitions": [
      {
        "index": 1,
        "gloss": "Shinto shrine precincts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
