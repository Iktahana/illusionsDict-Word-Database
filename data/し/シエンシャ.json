          "literary": [
            {
              "text": "Ｊ・Ｃ・Ｒ・リックライダーという支援者を得て育った灯火は、アラン・ケイに引き継がれ、もう一方でリックライダーはネットワークの種をまきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "特定の団体や個人に生活を支えてもらえば、表現には支援者へのおもねりが交じる可能性が出てくる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプラッターな直接描写、明示的な支援者や隣人の存在、中間話法による視点の多元化など、小説技法的にも見所の多い作品です。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
