        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "田植えの前に、丁寧に代かきをして土を平らにならす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "代かきの作業は、稲の生育に非常に重要な工程だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "トラクターを使って効率よく代かきを行い、田んぼを準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "代かきの真似をする。",
              "citation": {
                "source": "田遊び祭りの概念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の代かき次に牛が出る。",
              "citation": {
                "source": "田遊び祭りの概念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には、実際に耕作の助けをしたので、行事にも、代かきに出る事になつてゐる。",
              "citation": {
                "source": "田遊び祭りの概念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "代かきは言うまでもなく、植付け直前の整地作業である。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年頃の男達になると、女の気質も知りぬいてをり、手練手管も見ぬいてをり、なべて「女的」なものにむしろ憎しみをもつのだが、彼等の執着はもはや肉慾のみであるから、憎しみによつて執着は変らず、むしろかきたてられる場合の方が多いのだ。",
              "citation": {
                "source": "続戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
