[
  {
    "uuid": "f3322082-280e-5dd3-aa05-fe75fc080dd0",
    "entry": "詩吟",
    "reading": {
      "primary": "しぎん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
