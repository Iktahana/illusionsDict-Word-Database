        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれどここでも、コンピューターは新幹線か飛行機くらいの役にはたつ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊里を出て、妻のヨーコと京都駅のプラットホームに立ち、下りの新幹線を待った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシは新幹線に乗り、東京へ向かった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新幹線で大阪まで下り、大阪と徳島のあいだは東亜国内航空のＹＳ―11で飛んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新幹線はあまり好かない。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日後に東京を発つ」「木曜日か」「午後一時三分発の新幹線。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新幹線のプラットフォームに上がると、定刻より二十分ほど早かった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服の女性たちふたりは、新幹線の発車を待たずに帰っていった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新幹線は発車した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新幹線に乗って」「どこまでですか」「ついて来て。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "取材の仕事はやや遅れぎみに進行してますから、明日にでも出発したっていいのです」「平日の午前十時頃の、東京駅発の新幹線を選んで、そのなかで落ち合えばいいわ」「日時と列車を僕が選んでみます。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野は日を選び、新幹線の列車もきめて、コンパルサに電話をした。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "走る新幹線の外は晴天の真夏日だった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れていってください」　三津子が降りると言った停車駅でふたりは新幹線を降りた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都へ向かう彼はここから新幹線の停まる駅までいき、そこで新幹線に乗り換える。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定していた取材をすべて済ませ、矢野は新幹線で東京へ帰った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葬式はお父さんの実家でお父さんのお兄さんがすべておこなって、私とお母さんは新幹線でいって喪服を着てお葬式に出て、帰って来ただけ」「ほんとにびっくりしたよ。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "航空券、特急や新幹線の切符、実家にいる妹との打ち合わせなど、すべての手はずを母親は整えた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新幹線の改札を入り、エスカレーターでプラットフォームへ上がり、そこでひかり号を待った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お昼は新幹線のなかで食べた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも新幹線に乗ると、つまんなくなるんだよね。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
