        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国民皆農私説私は「国民総耕作」と言つたことがある。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はもう、すこしぶきみにかんじました、しかしせつかく、こゝまで盥をかついで来て水にはいりもせず帰つては、あまり意気地のないはなしではありませんか。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしせつないわ、と、女が言つた。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が少しせつないようだと言っていたが、やはりいつものように火鉢の前で襤褸とじくりなどをしていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その女の感情がありあり分るようで、少しせつない気がした。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しせつない悲しさが、なんの意味とも分からずに突然こみあげてしまふのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、然しせつない愛情だけがあまり生々しく生きすぎてゐる。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしせつかくのお尋ねだから卑見をでたらめに申し述べる。",
              "citation": {
                "source": "探偵小説小論",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
