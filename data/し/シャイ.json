    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、こゝはランカシャイヤだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近頃エールシャイアのある地に航空隊の練習場を設けかかった。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十九日『東京朝日新聞』）　　　　　　　　　四十一　　　　　　一種の迷信　英国デボンシャイアのある町に百二十年来営業を続けている牛肉屋があるが、開店の昔から今日まで店に屋号というものがない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ここはランカシャイヤだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外来ヨークシャイヤでも又黒いバアクシャイヤでも豚は決して自分が魯鈍だとか、怠惰だとかは考えない。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランドンのヨークシャイヤも又活版刷りに出来ているその死亡証書を見た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死亡承諾書、私｜儀永々｜御恩顧の次第に有之候儘、御都合により、何時にても死亡｜仕るべく候年月日フランドン畜舎内、ヨークシャイヤ、フランドン農学校長｜殿　とこれだけのことだがね、」校長はもう云い出したので、一瀉千里にまくしかけた。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではお供いたしましょう、」ピシッと鞭がせなかに来る、全くこいつはたまらない、ヨークシャイヤは仕方なくのそのそ畜舎を出たけれど胸は悲しさでいっぱいで、歩けば裂けるようだった。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな工合にヨークシャイヤは一日思いに沈みながら三日を夢のように送る。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨークシャイヤの一生の間のいろいろな恐ろしい記憶が、まるきり廻り燈籠のように、明るくなったり暗くなったり、頭の中を過ぎて行く。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、むすこが、エングランド、ロンドンにいて、おやじがスコットランド、カルクシャイヤにいた。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとこうだろう、するとカルクシャイヤのおやじめ、あわてくさっておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「勿論、僕は、ひどく何て云うか、ガール・シャイとでも云うんですかね、他の女はみんな怖かったんです。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩銀座×丁目二十四番地、印度人シャイロック・スパダ氏経営に依るカフェー・クロコダイルで世にも恐しい且つ奇怪なギャング事件が勃発致しました。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "襲撃致しましたのは過般銀座銀行を襲撃して満都を驚かしました国粋団の一味で、カフェー・クロコダイルの入口に立っておりました印度人シャイロック・スパダ氏を射殺し、尚も奥へ乱入しようと致しましたが、急を聞いて馳付けた警官のために三人ほど捕縛されてしまいました。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し強情我慢の名を惜しむ二人はここでヘタバッてなるものかと歯を噛みしめて、互いに先陣を争って行くうちに、やっと人家近い処へ来たので二人とも通りかかった小川で尻を洗い、宿屋に着くには着いたが、あまりの息苦しさに、ボーオとなって腰をかけながら肩で呼吸をしているところへ宿屋の女中が、「イラッシャイマセ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャイニング、ブライト、イン、ア、キャビン。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "イン、ザ、ウィンドウ、イッツ、シャイニング、フォア、ミイ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アイルシャイアーの株はどのくらいですか？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいらハンプシャイアのベドウスさんとこへつっ走ろうかと思うんだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時私は、フォーデングブリッジと云うのはハンプシャイアにあることを思い出した。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、このベドウス氏と云う、例の船乗りが、おそらくはユスルのであろうが、訪ねて行くと云っていた人も、またハンプシャイアに住んでいると云ってたらしいことを思い出した。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンフォード大学の大学院でＣＡＤ（コンピューターを使って設計をやろうという、怠け者のアイデアだ）を博士論文のテーマにしようとしていたアンディ・ベクトルシャイムは、研究に使う適当な機械がこの世に存在しないことにはたと気づいて、サンのワークステーションの原型となるマシンを自作する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オンダモダイタモエンブチハウノモオマエノコジャモノ、キナガニサッシャイ、イカニモショッショ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "取出でていうほどの奇はないが、二葉亭の一生を貫徹した潔癖、俗にいう気難かし屋の気象と天才｜肌の「シャイ」、俗にいう羞恥み屋の面影が児供の時から仄見えておる。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして品物を並べたり動かしたりしているのが、最も適切に「イラッシャイ」や「イカガ様」を表現している事は見易い道理である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベニスの商人、史上有名な貯蓄の才は、あながちシャイロックのみではあるまい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
