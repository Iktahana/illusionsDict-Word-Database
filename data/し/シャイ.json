  {
    "uuid": "5d159b03-5715-52bd-b163-9b85c5ef27f5",
    "entry": "社医",
    "reading": {
      "primary": "しゃい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "company doctor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ははん」へんにはしゃいでいた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田さんもそれは保証していらっしゃいました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は、大隅君がも少し無邪気にはしゃいでくれてもいいと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人でどこへでもいらっしゃいと言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、まだ、そこにいらっしゃいますの。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿をおっしゃい。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばか、そんなにしないだって、ご馳走あげるわよ」　柚木の額の汗を掌でしゅっと払い捨ててやり「こっちにあるから、いらっしゃいよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと待ってらっしゃい」　そういって主人は障子を開けて中へ入った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとボーイは「何でもむかし東海道でよくお目にかかった作楽井の息子と言えばお判りでしょうと仰っしゃいますが」　主人は部屋へ通すように命じて私に言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももうすぐあとからいらっしゃいます。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒の制服を着て雑嚢をさげ、ひどくはしゃいで笑っている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ジンタ音楽と「いらっしゃいいらっしゃい」とが同時にオーヴァラップして聞こえていても、われわれはきれいに二つを別々に聞き分けることができるが、二つの少し込み合った映像の重合したものはただ混沌たる夢のようなものにしか見えない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんもよくそうおっしゃいました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の一人がつかつかと傍へ寄り、　「失礼だが、若しやお前さん武井の安五郎さんの身内で神沢の小五郎さんとは仰しゃいませんか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ御免なせえ」　「いらっしゃいまし」　とお静。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」　「御免なすって……石松つあんのお宅はこちらで御座いますか」　「あの……兄さん今一寸留守なんですけど」　「へえ儂は駿河の清水港の次郎長の身内、大瀬半五郎と申します」　「お父っつあん、お父っつあん」　とお静、奥へ呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なーんだ、父っつあん、自分がやくざのくせに今迄俺がやくざになりてえと云うと目の色かえて叱るのは可笑しいや」石松は嬉しいから、多少はしゃいで言う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「もうお前の耳に這入ってるだろうが、実は先刻石松が旅から帰って来たンだ」　「そ、そうですってね」　「帰って来た事は確かに帰って来たンだが、直ぐ又その足で旅に出たんだ」　「嘘おっしゃい」　「嘘じゃねえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静、出て、　「いらっしゃい」　お静、茶なぞ汲みながら、石松と気付かない。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」Ｓ＝奥座敷　石松と七五郎。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店で客を呼んでいたお絹が三次を見て「休んでいらっしゃいまし」と愛想笑い。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が「何と仰しゃいます？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "易者が、Ｔ「根気よく探さッしゃい」　「よしッ」と左膳見料払って出掛けます。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではあなたは、この世界にまだどこか人の手の触れない新しい土地があるように思っていらっしゃいますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あなたマルリンク家とお心易くしていらっしゃいますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そんな時にお感じになった事は間違いこはないと思っていらっしゃいますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは今日お互に顔を合せてどう致すと思召していらっしゃいましたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして無理にわたくしを引き摩って、先へ先へと駈けていらっしゃいましたでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あなたは画家でいらっしゃいます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
