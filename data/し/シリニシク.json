        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殊においねは旧主人をかさにきて、とかくに亭主を尻に敷く形があるので、権七はいよいよ気がさして来た。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小芳め、さぞかし尻に敷くことでござんしょうな、とね。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は男を軽じて尻に敷くか、そうでなければ反対に男から撲られなければ満足しない。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは旦那と御一所か、さなくば朝を早く出て、退庁前には帰るのが、尻に敷くには似合はない、お定まりの寸法だに。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしわたくしがあなたの立場なら、夫を尻に敷くまでは何も言わないけど。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
