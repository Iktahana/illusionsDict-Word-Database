[
  {
    "uuid": "663aa508-f0dd-5a4f-82be-309c96516cbf",
    "entry": "食費",
    "reading": {
      "primary": "しょくひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
