          "standard": [
            {
              "text": "日本語の「ふ」の音は、唇歯音ではなく両唇摩擦音に近い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "言語学の授業で、様々な発音記号とともに唇歯音について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "唇歯音の発音は、上下の唇と歯をうまく使う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ウヂはウチ即ち「……の中の」のうちで、ヂの発音は「氏ウヂ、蛆ウジ」の鼻音がかつたものでなく、明瞭に強く英語の t-h（唇歯音）を発音すると思へば真に近いだらう。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            }
          ]
