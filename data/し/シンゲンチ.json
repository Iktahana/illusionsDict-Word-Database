    "definitions": [
      {
        "index": 1,
        "gloss": "epicenter (of an earthquake)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
