[
  {
    "uuid": "e0a9638f-5043-5072-9c54-90afcba504e5",
    "entry": "親善",
    "reading": {
      "primary": "しんぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "friendship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これではお互いの親善とか好意が無駄になります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に、日支親善外交に、一大汚跡を、踏み残す事になる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉人と貧困の親善なる何ぞそれ斯くの如きや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア彼もしわれらに親善ならんには彼の成功はなかりしならん、彼の成功は、全く自分の主義を棄て、意気を失いしより得たる賜ものなりけり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親善を厚うするとか、相互の利害を議するとか、連絡を圖るとか、趣旨は頗る立派であつたけれど、月例會は要するに、飮んで、食つて、騷ぐ會なので、主筆の所謂人の惡い奴許りだから、隨分と方々に圓滑な皮肉が交換されて、其度にさも面白相な笑聲が起る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親善を厚うするとか、相互の利害を議するとか、連絡を図るとか、趣意は頗る立派であつたけれど、月例会は要するに、飲んで、食つて、騒ぐ会なので、主筆の所謂人の悪い奴許りだから、随分と方々に円滑な皮肉が交換されて、其度にさも面白相な笑声が起る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃満洲では鄭家屯事件も無事に片付いたので、督軍張作霖が頻と「日支親善」といふ事を言ひ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「さうだ、日支親善を忘れちやいけない……」と直ぐ何かの名義を拵へて宴会をする。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラテン・アメリカの諸国は人種的にも経済的にも概して合衆国よりも欧州大陸と親善の気持を持っているにも拘らず、第一次欧州大戦以後は急速に米州連合体の成立に向いつつある事は即ち歴史の必然性である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時事變講演會の催しがあつて君もしば／＼引き出される毎に、君はこの鳩を伴なつて行つて、鳩同志の親善を大衆に説いたとある。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは小さなものの名殘、短かくはあるがおのづからな親善と愛との形見である。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ペンクラブは、「ペン」による国際親善運動を目的とし、国際ペンクラブへ正式加入して日本支部設立を計画している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は家族、また姻戚との親善な関係といふ形式に於ける、多少とも満足な家庭生活である。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも抽斎と親善であった比良野｜貞固は、抽斎のこの議を唱うるを聞いて、馳せ来って論難した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古館教授にして、五十石町に私塾を開いていた工藤他山は、元秀と親善であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には当時四郎左衛門と親善であつた人さへある。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上｜蘭台の門に井上｜金峨を出し、金峨の門に此篁と偕に金峨の門に出で、蘭軒と親善に、又蘭軒の師友たる茶山と傾蓋｜故きが如くであつた人もある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」蘭軒に至つては、既に鏑木雲潭と親善であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は抽斎と親善であつた枳園は、未だ贄を執らざる時、既に蘭軒の家に出入して筆生の務に服したものと看るべきであらうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年備後に来て、茶山と親善であつたことは、後者の癸未以後の詩に徴して知られる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして思へば、瑞英と親善にして其子に命名する杉本は、此句を著けざることを得なかつたのであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "真さんは渋江抽斎と其長子六堂｜恒善との教をも受けてゐたので、優善とは親善であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "菖軒孫の浅田栗園と親善であつたことは、孫の履歴に徴して知ることが出来る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒と霞亭との親善であつたことは上に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅茶山とは親善であつたと云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会的に親善を図るのは人間のみである。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日米親善も日仏協商も、日英同盟も気にかける必要はない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五目並べなんていったのは昔の話で、今では高木名人考案の縦横十五線の新連珠盤が出来て、段位も段差のハンディキャップも確立するし、国技として外国に紹介するには最もいゝ競技で、国際親善の為に大いに発展させるべきものだといいましてね、その連盟とかに金を出せというんです。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩國の親善を圖る爲には、兩國人が互にその相手の氣質を理會して置く事が、一番必要と思ふ。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
