    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dip-dyeing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
