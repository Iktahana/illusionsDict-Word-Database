        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バァーンとシンバルを叩いたような感じである。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンバルみたいに、八分できざむバスドラなんか、はじめて聴いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トップばっかし」　そういって、服部はもうひとつのストゥールの中心をスネア、端をトップ・シンバルに見立てて、叩きはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラディックのスネアに、ジルジャンのシンバル！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "電熱器と鍋まであるんだぜ」「電熱器は、ほかで手に入るけどさ……ま、いっぱいいて、にぎやかなほうがいいな」　服部は階段の手すりをシンバルがわりにして、右手で八分音符を叩く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの映画んなかでさ、テレビの人が、リンゴのシンバルを勝手に叩くでしょう」「おう、そういや、そんなシーンがあったな」「藤井は、もっとひどいことしたんだもの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえら、売店でコーラ仕入れて、一本に十円のせて売れば、シンバルをもう一枚、買えたんじゃねえのか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二小節目の頭のシンバルに合わせて、寮から見た校舎の全景に校章が重ねられる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ころがってひざを立てたまま、慶一は右足で一、三拍を叩き、高志は右ひざをシンバル、左ひざをスネアにして、二、四拍を叩き、その音はしだいに大きくなり、フェイドアウトのギター・リフを、「パラララン」と口ずさんだころには、右足で柱を蹴っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進曲蒿雀が鳴いて水がしたたり風が艶をぬり、雲が翳りを掃くのはわれわれのさびしい精神を空中へ、より高みへおくるあたらしい行進曲でなくて何かその笛やシンバルを愛さずしてどうして野原を歩き廻れようか。",
              "citation": {
                "source": "季節の馬車",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてクリストフは、昏迷のうちにもがきながら、無意味な文句を口にして、想像の管弦楽を、トロンボーン、トランペット、シンバル、チンパニー、バスーン、コントラバス……などを指揮し演奏し、熱狂的にひき吹き打ちたたいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "両肱を胴に寄せて爪先きで拍子をとり、明るい電灯を映すサイド・ドラムを思いきり連打して最後にひとつシンバルをたたいた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて亜理沙が暗闇の中で緑色に光るスティックを振り回しながらハイハットシンバルとスネアドラムを交互に叩き、しばらくすると赤いスポットライトが亜理沙を包み込んだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーケストラのシンバルの交互に促すような調子。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは昔（とアリウスは言っている）、一匹の象が各々の脚に一つずつシンバルをつけ、もう一つをその鼻先につけてうち振ると、他のすべての象がその音につれて、楽器の導くがままに、ちゃんと調子にあわせて、或いは飛び或いは伏し、円形を造って舞ったのを見たことがある。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
