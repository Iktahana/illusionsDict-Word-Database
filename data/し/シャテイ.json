[
  {
    "uuid": "b6ad42a3-77be-5449-8eca-dabb3fc94abb",
    "entry": "舎弟",
    "reading": {
      "primary": "しゃてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
