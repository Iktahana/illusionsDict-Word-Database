[
  {
    "uuid": "0e4cc4e6-aed4-5afa-9210-b418d764d5a5",
    "entry": "修築",
    "reading": {
      "primary": "しゅうちく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "repair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こはいはゆる三角洲に人為の修築を加へたるものにして、これがために川おのづから分岐して海に入るの勢を生ず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下修築最中で旧道は行通遮断と来た。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王、徳州の城の、修築｜已に完く、防備も亦厳にして破り難く、滄州の城の潰えるゝ」］こと久しくして破り易きを思い、之を下して庸の勢を殺がんと欲す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は西教寺も願行寺も修築せられ、願行寺の生垣は一変して堅固な石塀となった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸大名に対しては、私に婚姻するを禁じ、築城や無届の修築を禁止するなど、十三箇条の武家諸法度を厳に励行させた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の戸長菊地氏之を慨き、縣廳に上申して、こゝに鹽釜港の修築起れり。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の修築と境内の秋芝刈りを願おうと存じたのでな。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しより（首里に）おわる（在す）てだこが（王が）もゝうらおそい（百浦添御本殿を）げらいて（修築して）たまばしり（玉の戸）たまやりど（玉の戸）みもん（美しいかな）ぐすく（城に）おわる（在す）てだこが（王が）　〔十三―一〇〕　ももうらおそいは三十一年毎に建てなおす例になっていたが（？",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黄白い魚臭が冬晴れの日光に波紋して、修築中の郵便局の屋根へ、鎖で縛った瓦の束がするすると捲き上って行った。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "河身ヲ修築シテ其天然ノ旧ニ復スル其二ナリ。",
              "citation": {
                "source": "直訴状",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し唯一の堤防修築を怠らざれバ前途洋々として頗る多望なるものあり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して昨三十七年十二月廿日栃木県会ハ夜半密かに秘密会議を開き、陽に土木治水費中堤防修築費と称し陰に谷中村買収の意味を含まして曖昧なる土木費を議決したり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔孝武帝より約百年後の孝成帝時代に、黄河の氾濫を防止すべく、※防修築の議が起つた時、按經義。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "河身を修築して其の天然の旧に復する其二なり。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十七年末の栃木県会に於て、知事は政府の命令に従て堤防修築費の偽名の下に三十六万円の谷中村破壊追加予算案を県会最後の日に提出した。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、道路の修築が始まった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、淳和天皇の頃、美濃の国守の藤原高房という人があって、安八郡のさる池の堤がこわれて水がたまらず灌漑の用を果しておらぬのを見て、修築を企てた。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが住民は隣接の赤麻沼に面する堤防缺潰箇所を自費で修築しました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名南麓の箕輪町でも、疎開学童を受け入れることになったので、校舎の修築、炊事場の新設、井戸を新しく掘るなど、いろいろ準備に忙しい。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「りうきう國てたがすゑあんじおそひすへまさる王にせかなし」と長々しい尚寧王の神號から始まつて、王が英祖王の陵を修築せしめ、其の曾祖父の遺骸を此處に移し、將來王自らの奧津城にもせんとし、此の碑を建つる旨を莊重な琉球文で記してある。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、淳和天皇の頃、美濃の国守の藤原高房といふ人があつて、安八郡のさる池の堤がこはれて水がたまらず潅漑の用を果してをらぬのを見て、修築を企てた。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて明和四年に秋元家が、六万石でここに移封したさいには、城郭の荒廃すこぶるはなはだしくなっていた様子であるが、秋元氏これを修築し、外濠内に三千石の田地を開いてこれを込高としておったとのことである。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校集会所で、最上時代以後秋元家修築前の状を現わした数軸の地図を拝見した。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "城塞修築等の土木工事にも彼らは使役せられた。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三、江戸聞書き（下）　江戸城修築も本腰にこれにかゝつたのは文禄元年（西一五九二年）の三月からだといふことである。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後この門が修築せられたにもしろ、以前とさほど形を変えたわけではない。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、道路を修築することを命じておいたのに、殆んど実行されてゐない。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "明代の貢院は太平賊の兵燹に滅びて、今存するは同治三年の修築に係かるものと云ふ。",
              "citation": {
                "source": "貢院の春",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
