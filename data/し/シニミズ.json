    "definitions": [
      {
        "index": 1,
        "gloss": "water given to a dying person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
