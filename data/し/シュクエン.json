[
  {
    "uuid": "0be61fcd-f08e-5857-a53b-c0ec9bc78a28",
    "entry": "宿縁",
    "reading": {
      "primary": "しゅくえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
