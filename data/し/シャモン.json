[
  {
    "uuid": "7538e468-4a45-536f-913a-6b68eef0c638",
    "entry": "沙門",
    "reading": {
      "primary": "しゃもん",
      "alternatives": [
        "さもん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shramana (wandering monk)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔毘沙門の堂は古びて〕毘沙門の堂は古びて、　　　　梨白く花咲きちれば、胸疾みてつかさをやめし、　　堂守の眼やさしき。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　いや爰でこそ、呑気らしい事をいふものゝ、磊々たる巉巌の尖頂へ攀ぢて、大菩薩の小さな祠の、たゞ掌に乗るばかり……といつた処で、人間のではない、毘沙門天の掌に据ゑ給ふ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武将だから毘沙門とか、八幡とかへ願えばまだしも宜いものを、愛宕山大権現へ願った。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "毘沙門かなんかの縁日にはＩ商店の格子戸の前に夜店が並んだ。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は下駄の上に泥の乗るのも忘れて、冗談口をたゝきながら毘沙門の裏通りへと折れ曲つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、毘沙門樣の祭禮だな。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "淵沢小十郎はすがめの赭黒いごりごりしたおやじで胴は小さな臼ぐらいはあったし掌は北島の毘沙門さんの病気をなおすための手形ぐらい大きく厚かった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠きその昔は知らず、いまの男は、牛込南榎町を東状に走つて、矢來中の丸より、通寺町、肴町、毘沙門前を走つて、南に神樂坂上を走りおりて、その下にありける露地の家へ飛込んで……打倒れけるかはりに、二階へ駈上つたものである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永瀬はこの土地で呼ぶばかりでなく、時には神楽坂へもつれて行き、毘沙門横丁の行きつけの家で、山手の異った雰囲気のなかに、彼女を置いてみたり、ある時は向島の一号である年増の家へも連れて行き、彼女を馴染ませてみようともした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "道衍の人となりの古怪なる、実に一｜沙門を以て目す可からずと雖も、而も文を好み道の為にするの情も、亦偽なりとなす可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又観世音菩薩、毘沙門天王にも夢に会ったとある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に子供の腰揚げが深く、辨財天、毘沙門天、布袋、福祿壽の腰から下が青縞の地にかくれて、裾と足とだけが見えるのは興が深い。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙門の一行門前なる群集に近づく。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙門等は下手の方、程よき所に立ち並ぶ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽声、沙門、伊留満等の祈祷唱讃の声、諸人の驚き叫ぶ声、紛々囂々ととだえとだえにひびらぐ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（演説の調にて）法相｜真如といふと雖も之れ仏陀乃至伝教等沙門の頭を写したる幻の塔、夢の伽藍、どうせ人の頭より出たるほどのもの故、学んで悟られぬ筈はおりない。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙門等、長順、白萩のみのこる。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて沙門の一行、列をなして上手の方に退く。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（沙門等｜悉く上手より去。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川下のは長門といってそこに毘沙門堂があってタガメが住んでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とき／″＼彼女は岸船のあかを掻い出している途中、ふと釣がしてみたくなって客の預り竿を持出し、長門の毘沙門堂の下へ船をつけて鮒を釣ってみたりしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くの字に曲って来て、お秀の貸船屋の前の淵に突当った水は、その反動でタガメの住む対岸の毘沙門堂の洲を作り、またこちらの岸にうち当てゝ象の鼻の瀞となっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ過ぎり街にゆく者、――婆羅門の苦行の沙門、あるはまた生皮漁る旃陀羅が鈍き刃の色、たまたまに火の布巻ける奴隷ども石油の鑵を地に投げて鋭に泣けど、この旱何時かは止まむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一所不住の沙門ぢやで、山松風も聴いて行かうぞ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に日輪を背負うた薬師の木像を真中にして、左に小さな毘沙門の木像が立ち、右には問題の不動の木像についた後光の板と剣があって木像は見えなかった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
