    "definitions": [
      {
        "index": 1,
        "gloss": "professional education",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちゃんとした職業教育は女にも必要であると思う。",
              "citation": {
                "source": "ものわかりよさ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア職業教育とでも言はうか。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に類して獨逸の教育法も、職業教育とか實業教育とかを主とするのである。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業教育を狹くやると、さう云ふ弊に陷つて來る。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならと云つて、僕は决して職業教育をするなと云ふのではない、職業を求むる爲に教育をすれば又た宜いこともある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の國民にして今日の如き進歩をなしたのは、主として此の職業教育が盛んになつた結果であることは僕が斷言して憚らぬ。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業教育に就いては、茲に又た最も著しき一例がある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云ふ意味に取るときには、職業教育も餘程注意しなければならぬ。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其説の要點は、今日我日本に於いて、專ら職業教育を唱へるけれども、之には注意しなければならぬことがある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに一方に於て職業を輕蔑する觀念が大いに除かれ無ければ、どれほど職業教育に力めた所で効能が薄からう。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア職業教育とでも言おうか。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに類して独逸の教育法も、職業教育とか実業教育とかを主とするのである。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業教育を狭くやると、そういう弊に陥って来る。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならといって、僕は決して職業教育をするなというのではない、職業を求むるために教育をすればまた宜いこともある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国民にして今日の如き進歩をなしたのは、主としてこの職業教育が盛んになった結果であることは僕が断言して憚らぬ。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業教育に就いては、ここにまた最も著しき一例がある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味に取るときには、職業教育もよほど注意しなければならぬ。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その説の要点は、今日我日本に於いて、専ら職業教育を唱えるけれども、これには注意しなければならぬことがある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに一方に於て職業を軽蔑する観念が大いに除かれなければ、どれほど職業教育に力めたところで効能が薄かろう。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "既成の劇場乃至映画会社は、其内部機構の曖昧さよりも、寧ろその生産によつて示される品位の低さによつて、如何なる方法でも、現在以上良質な材を誘引することは絶対に不可能であり、進歩的研究的と称する小劇団さへも、その理論的背景はともかく、実質に於て、責任ある職業教育のプランは樹て得ない事情にある。",
              "citation": {
                "source": "官立演劇映画学校の提唱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省専門学校令に準拠するとはいへ、実はこれは、大学の課程に相当するもので、その点職業教育の実を直ちに挙げることは困難だと思ふが、少くとも、演劇映画方面に進まうとする人々のために、相当深い精神的準備を与へ得るプランである。",
              "citation": {
                "source": "明治大学文芸科に演劇映画科を新設する件",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おなじ中等学校でも、普通の中学校、女学校と、職業教育を主とする中等学校との間柄には著しい差異があり、後者は、不思議にも、「小学校型」の色合を多分に帯びてゐるのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日は徴兵猶豫の必要はないが、職業教育だけで最高學府でもあるまい。",
              "citation": {
                "source": "綜合大學を迎へて",
                "author": "會津八一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、学校へなんかはひりたがらないうちに、実地の職業教育を受けさせようと思ふんだ。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここではどういう教育を受けるかというと、これも一言でいえば、それは職業教育である。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業と教養との比率は、大学によって違うらしいが、職業教育を重視する大学が多いようである。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち純粋な職業教育である。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には、職業教育振興何々会というようなものがあるが、アメリカには、そういうものはまずない。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学教育が、すなわち職業教育であるからである。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業教育というと、日本では、何か非常に卑近で実用的なことだけを教える、というふうに考えられ易い。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
