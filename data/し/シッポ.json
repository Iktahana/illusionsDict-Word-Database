    "definitions": [
      {
        "index": 1,
        "gloss": "tail (of an animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の脊中へ赤い紙片を貼付け、尻尾に摺粉木を一本縛り付けて野良へ出しておく。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴉が下りて来て牛の脊中の赤い紙を牛肉と思ってつつくと、牛は蠅でも追う気でぴしゃりと尻尾ではたく、すると摺粉木の一撃で鴉が脆くも撲殺されるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻尾なんかブラ下げて歩きゃしねえからな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オリュンポスが馬を一匹くれるはずであったが、馬の代りに尻尾を一本くれた。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尻尾の端には最後の息をしている馬がぶら下がっていた」というので馬鹿気ているが、何処かしら古代日本人のユーモアとウィットを想わせるものがあると思う。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の前の鍵盤のようなものの一つを指で押すと槓杆の仕掛けで一疋の猫の尻尾をぐいと押す。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚紙か何かの筒の横腹から四つ足を出したものが猫の胴になりその一端に薄っぺらな短い尻尾が付いている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時尻尾は下に垂れているが、糸を切って落すと同時にバネ仕掛けで尻尾がくるりと百八十度廻転する、そのはずみで胴体も宙返りをして四つ足で立つというのである。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻尾の短いほとんどないような猫はどうするだろう。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も鼠の尻尾も一種の鱗片で蔽われているし、その他身体の一部に多少の鱗片あるものはあるが、狐の先祖が鱗片を着けていたという説は新しい。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "函館から札幌までは赤※の尻尾の部分に過ぎないが、これだけ行ったので北海道の本当の大きさがいくらか正しく頭の中で現実化されたように思う。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから前脚を一本ずつずっと前へ伸ばして頭を低く仰向いて大きな欠伸をして、尻尾をＳの字に曲げてから全身を前脚の方へ移動しのめらせてそうして後脚を後方へのばした。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "素裸で村の川や溝へ這入っては、鮒鰌をすくったり、蛙を呑んでいる蛇などを見つけては、尻尾を手づかみにして叩き殺す位なことは、平凡ないたずらの方であった。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　三四四頁には尻尾のある人間の事が出ている。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の尻尾くらいの大きさだが毛が生えていないとある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬喩的には今でも大概の人間がみんな尻尾をぶら下げて歩いている。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大掃除の午後の路地の交互点、こわれたおもちゃに葱大根の尻尾、空瓶空ボールの交響楽、マルクス、ムッソリニの赤ん坊の夢を買わないか。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯛の頭に孔雀の尻尾。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月一日『東京朝日新聞』）　　　　　　　　　三十二　　　　　　有益な鼠　北米に産する地鼠の一種に尻尾の短いのがある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫まつくろけの猫が二疋、なやましいよるの家根のうへで、ぴんとたてた尻尾のさきから、糸のやうなみかづきがかすんでゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはどこへ行くのか知らない、おほきな、いきもののやうな月が、ぼんやりと行手に浮んでゐる、さうして背後のさびしい往来では、犬のほそながい尻尾の先が地べたの上をひきずつて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が東洋の女の尻尾と男性の舞踊会に用いるルーブル紙幣の仮面、といって彼女が銀色のコオセットに太平洋をぶらさげてはいないのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夜間の遊覧飛行イルミネェーションで作られたファンタジツクな科学の尻尾、――妻にたいする愛を結びつけて、……。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は、切断された蜥蜴の尻尾のように穴の中ではねまわった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除の仕方が悪いと、長い箒を尻尾に結びつけられて、それをぞろ／＼引きずって、これも各班をまわらせる。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが不思議なことには死んだボーヤの小さい時とほとんどそっくりでただ尻尾が長くてその尻尾に雉毛の紋様があるだけの相違である。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しおくれて、それまでは藤棚から干からびた何かの小動物の尻尾のように垂れていた花房が急に伸び開き簇生した莟が破れてあでやかな紫の雲を棚引かせる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっぽがまるで箒のやうだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそのころのやさ男が粉をふりかけた鬘のしっぽをリボンで結んで、細身のステッキを小脇にかかえ込んで胸をそらして澄ましている木版絵などもある。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
