    "definitions": [
      {
        "index": 1,
        "gloss": "shooting range",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "されば菓子屋、植木屋、吹屋、射的場の前には、今一客を止めず。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍の射的場のひびきも随分騒がしかった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "千恵造夫婦は京城にいる賀来子の伯父を頼って朝鮮に渡り、今は京城の色町で、「赤玉」という小さな撞球場兼射的場をひらいてさゝやかな暮しをしている、内地とちがい気候が不順で困る、などとあり、この手紙のことは権右衛門の耳にいれぬ様にと念を押してあった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　療養所のすじむかいに小さい射的場があって、その店の奥で娘さんが顔を赤くして笑っている。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽かに射的場のほうを意識して、僕は紫陽花を眺めたりしてポオズをつけていたのかも知れない。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕はまさか、ツネちゃんに恋いこがれて、ツネちゃんの射的場へ行こうかどうしようかと、門のところで思い迷っていたというわけでは決してない。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、僕は前からツネちゃんをきらいじゃなかったし、それにどうもあの色男との噂が気になっていたのも事実だったから、全くツネちゃんの射的場を度外視して、門のところに立っていたと言ってもやっぱり嘘になるかも知れないね。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく僕は、ツネちゃんに声をかけられて、それから、のこのこツネちゃんの射的場に行ったのだ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その射的場で、一ばんむずかしいのは、この雀撃ちという事になっている。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡市天神町水鏡天満宮二百五十年御神祭につき、表舞台（今の城内練兵場、旧射的場附近御下屋敷所在）で三日とも翁附の大能を拝命した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分らはこれを天文台と名づけていたが、実は昔の射的場の玉よけの跡であったので時々砂の中から長い鉛玉を掘り出す事があった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと見ると前に射的場があります。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "三回分の料金が四十五銭、それを敷島六個の代金一円八銭から差し引いて六十三銭の金を受け取ると私は夢中で射的場を飛びだしました」「私の精神状態はこれだけのことでがらりと一変しました。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしいような、悲しいような、半ば夢中の精神状態で、私はづかづかと二人の乞食のそばへ走りよって、射的場で貰ってきた金を残らず、この親子づれの乞食にくれてやりました。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は、射的場近くの野へ出て、｜Ｍ大尉の射撃演習を手伝いました。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は毎日他の士官等と一緒に、家のすぐ前の練兵場の射的場で、ピストルの稽古をした。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その日清戦争から帰って来てからは、一里ばかりある大宝寺という、ほんとうの実弾射撃をやる射的場へ連れて行った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "射的場と兵営のお濠との間には障害物があった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが飽きると、というよりもむしろ、もう夕方近くなって兵隊がみな隊に帰ると、僕はよく射的場の弾丸をほりに行った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銀杏の木は前に言った射的場ともとの僕の家の間にあった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも言った大宝寺の射的場のバッタ狩り。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、一風呂浴びて一本傾けて、そしてぶら／＼歩く、こゝにも温泉情調はある、カフヱーと自称するもの二軒、百貨店と自称するもの一軒、食堂二三軒、そこかしこに三味線の音がする、……いやまて、ビリヤード二軒、射的場も一軒ある。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その僅かに二三尺から、四五尺の高さに残っているコンクリートや煉瓦塀の断続の間に白と、黒と、灰色の斑紋になった袋の山みたような物が、射的場の堤防ぐらいの高さに盛り上っていた。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学時代を過した郷里の、海岸の松林のなかに、昔、射的場があって、聯隊の兵士たちが時折実弾射撃をやった。",
              "citation": {
                "source": "書かれざる作品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その射的場の附近の砂の中に、流れ弾が埋ってることがあって、それを掘りだすのが少年の楽しみだった。",
              "citation": {
                "source": "書かれざる作品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "射的場の砂中から拾い出された一個の銃弾が主人公なのである。",
              "citation": {
                "source": "書かれざる作品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、射的場で、兎を撃ったことも、十仙出して本物のインディアンと腕角力をしたことも、マジック・タアオンの鏡の部屋で――。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
