          "standard": [
            {
              "text": "公園の芝生には、たくさんの白詰草が咲いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは白詰草で花冠を作って遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "四つ葉の白詰草を見つけると幸せになれると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すべてしろつめくさのいちめんに咲いた野原のまん中の心持、円舞終る。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輸入された白花の｜しろつめくさは、我国のよりも花が大きく、茎も長く、そして実によい香がする。",
              "citation": {
