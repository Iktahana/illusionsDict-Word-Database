[
  {
    "uuid": "e59b6038-fd70-525a-8de4-f400aad1d746",
    "entry": "死活問題",
    "reading": {
      "primary": "しかつもんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
