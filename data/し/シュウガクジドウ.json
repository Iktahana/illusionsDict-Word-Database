        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『二十人来るにしても、三十八名に二十……残部十四名の不就学児童があるぢやありませんか？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "就学児童はどの位増大するか？",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、日本では百三十万の未就学児童があります。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ゆく人々がみんな行きずりに、お早うといふ、学校生徒は只今々々といふ（今日は日曜だが、午後は只今帰りましたといふ）、これも山国らしい嬉しい情景の一つである（その癖、行乞の時は御免が割合に多い、未就学児童が、御免々々といふのは何としても嬉しくない）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がかつて或る県の漁村の小学校を視察に行った時に、女児の就学児童の極めて少いのに不審を起して、村の学齢簿を調査してみたところが、実際その村には女の児が少かった。",
              "citation": {
                "source": "特殊部落の人口増殖",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
