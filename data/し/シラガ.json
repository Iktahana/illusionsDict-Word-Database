    "definitions": [
      {
        "index": 1,
        "gloss": "white hair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔いざ渡せかし　おいぼれめ〕宮沢賢治「いざ渡せかし　おいぼれめいつもこゝにて日を暮らす」すぱとたばこを吸ひやめて何を云ふともこの飯の煮たたぬうちに　立つべしや芋の子頭白髪しておきなは榾を加へたり",
              "citation": {
                "source": "〔いざ渡せかし　おいぼれめ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気味わるく物凄い顔をした、雲助のような男たちに脅やかされたり、黒塚の一軒家のような家に泊って、白髪の恐ろしい老婆に睨まれたりした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪交りの荒い頭髪は何時も三四分位に刈揃へられ、さうした顔面の上に「ワ」の字型に懸つてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道の並木の松さすがに昔の名残を止むれども道脇の茶店いたずらにあれて鳥毛挟箱の行列見るに由なく、僅かに馬士歌の哀れを止むるのみなるも改まる御代に余命つなぎ得し白髪の媼が囲炉裏のそばに水洟すゝりながら孫｜玄孫への語り草なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生と若先生と二人で患家を引受けていたが、老先生の方はでっぷりした上品な白髪のお茶人で、父の茶の湯の友達であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃のわが家を想い出してみると、暗いランプに照らされた煤けた台所で寒竹の皮を剥いている寒そうな母の姿や、茶の間で糸車を廻わしている白髪の祖母の袖無羽織の姿が浮び、そうして井戸端から高らかに響いて来る身に沁むような蟋蟀の声を聞く想いがするのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪んだ眼にまさに没せんとする日が落ちて、頬冠りした手拭の破れから出た一束の白髪が凩に逆立って見える。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い方はもう頭に白髪が十分まじつて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筧の水は、物語る白髪の嫗にさも肖てる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり鏡というものを見る機会のない私は、ある朝偶然｜縁側の日向に誰かがほうり出してあった手鏡を弄んでいるうちに、私の額の辺に銀色に光る数本の白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその代りにいつの間にか白髪が生えていた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後に気を付けて見ると同年輩の友人の中の誰彼の額やこめかみにも、三尺以上｜距れていてもよく見えるほどの白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ自分等よりはずっと若い人で自分より多くの白髪の所有者もあった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも白髪と視力聴力の衰兆とこれだけの実証はどうする事も出来ない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪の上品な老婦人で耳もかなり遠いらしく腰も曲っている。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し見え出したつむじの白髪が弾ねて光る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ男の頭へ沢山に散りかかって居る花片の間からところどころ延びた散髪に交って立つ太い銀色の白髪が午後の春陽に光って見えるのでありました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈愛深ければこそ、白髪をかかえて吾児を旅に手離して寂しさを守って居るのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "をばさんは余り躊躇せずに記憶の一部を喚び醒さうとするやうに、平手で白髪の束髪の上を撫でて、大胆にはつきりと言つて退けた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで尊敬を忘れずに心易立てをも敢てする老僕の態度で、スタニスラウスの白髪頭の上へ首を屈めて云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しびっこで恐ろしく背の高いやせこけた老翁であったが、破れ手ぬぐいで頬かぶりをした下からうすぎたない白髪がはみ出していたようである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、地震前には漆のように黒かった髪の毛が、急に胡麻塩になって、しかもその白髪であるべき部分は薄汚い茶褐色を帯びている事であった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪の多い、頬骨の高いおまきは、伏目にそれをじっと眺めながら、ときどきそっと眼を拭いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地落上白髪かざして高清は、　　　　　ブロージットと云へるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから東には敏感な空の白髪が波立つ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」海蛇は白髪を振って恭々しく申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも直ぐに買って帰って、孫が喜ぶ顔を見たさに、思案に余って、店端に腰を掛けて、時雨に白髪を濡らしていると、其処の亭主が、それでは婆さんこうしなよ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だナ、と鈍い声をして、土間の左側の茶の間から首を出したのは、六十か七十か知れぬ白髪の油気のない、火を付けたら心よく燃えそうに乱れ立ったモヤモヤ頭な婆さんで、皺だらけの黄色い顔の婆さんだった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の前に、大きな肘掛椅子に埋もれた、一人の白髪の老人が現われる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば幕が落ちる途中でちょっと一時何かに引っかかったが、すぐに自然にはずれて首尾よく落ちる、その時の幕の形や運動の模様だとか、また式辞を朗読する老紳士の白髪の一束が風に逆立つ光景とか、そういう零細な事象までがことごとくこくめいに記録されるのである。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
