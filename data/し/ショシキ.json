    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prescribed form (of writing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "色々記入する書式の中の宗教という項に神道と書いたら、それはどういう宗教だと聞かれて困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして反射神経でありあわせなラブレターの書式など、実にうまくなりましたこと。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリのガール・デュ・ノールでは誰だか知らない人が書式へいい加減のことを書いてくれてそれで万事が滞りなくすんだのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、新感覚派運動もついに志賀直哉の文学の楷書式フォルムの前に屈服し、そしてまた「紋章」の茶会のあの饒慢な描写となったのである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに書式をざっとこしらえておきましたから、よろしければ署名だけでも。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず、風景を描くための言語を作り、景色に関するデータはこの言語の書式に合わせて書いておきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「書式や体裁にこだわらず、内容を伝える」ことを優先するＢＢＡに対して、青空文庫は「底本の保存」を重視した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "注にいわく、ここに言えるあの畑とは隣り持ちの畑だと、つまり自分の畑さえ害せずば隣人はどんなに困っても構わぬという書式だ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単な書式のようなものだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを付け込んで、今後は生徒を可愛がってやれと言い聞かせます」　しかし冥府から渡される差紙などというものの書式を誰も知らなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、今度は、ひとつこれを見て下さい」　東屋氏は、書式張った商業書類らしい紙片を数枚取り出しながら、「これは、この戸棚の書類金庫から一寸拝借したものです。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単な書式のやうなものだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜訪ねて来て書式を聞いて行つたのだから、展けて見なくても解職願な事は解つてゐる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』「その書式を教へたのは誰だ？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜訪ねて來て書式を聞いた行つたのだから、展けて見なくても解職願な事は解つてゐる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『その書式を教へたのは誰だ？",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――書式やなんぞは役場でわかりますよ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　読者に奇異の感を与えるそのような冒頭の文句ではじまる、長文の上申書の終りは、かつての転向上申書の書式を思わせ、共産党への罵倒と「いかなる罰も天命であって人智のなすべからざるところと。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう書式があるということはそのときまで知らなかった。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと書式の違いなどはそちらの方で直してくれるでしょうから。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "書式のことなら何から何まで心得ていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "規定された書式とか、文体とかいうものはどこにもない……という一言を添えておけば十分であると思う。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、あらゆる科学智識を、百科全書式に応用して、法律上の諸問題を解決するっていうんだから、手ッ取早く云えば所謂、名探偵の助手みたいなもんだよ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早書式や熟語を可なり知つて居る筈である。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく来た集団農場書記が、入って左側の室でしきりに書式を埋めている。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はる子さんは新米の社員が書式を間違えた原稿をよこしたって、ちゃんと直して打ってやるぐらいだったんだもの、まさか知らん顔しやしないわ」　有楽町で別れるとき柳はミサ子に、「じゃいいわね、あのこと忘れないでいて下さいね」と念を押した。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上、公式令、詔書式）（二）八月甲子朔、受禅即位。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しながら、其一番初めのものに近い形と考へられてゐるのは、詔書式に見えた朝拝の詔詞よりない。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、書式だけを（離婚届）書かせる。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
