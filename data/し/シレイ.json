    "definitions": [
      {
        "index": 1,
        "gloss": "command",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がマ司令に密告するわけじゃあるまいし。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "始末書ヲ書ク　上海ニテ司令官乗船、事務長ガ頼ム　司令官、兵ヲ事務長ノ室ヘ呼ブ（夜）　始末書ヲ破ル、兵感激ス。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令官、兵ニ破ッタ始末書ヲ渡シ、海ヘ捨テロト云フ　兵室ヲ出ル、消灯ラッパ聞コエル　兵戻ッテ来ル　司令官「遅レタ罪ダ」ト兵ヲ叱ル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の司令官早く来い。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人を指導した陳独秀が、いまでは南京総司令の策略によって彼の首が無産者の弗箱に変わるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "長楽路の蛇酒屋から掠奪した蛇酒に昂奮した赤い布の一連も、中央司令部の銭大鈞の軍隊が出動して忽ち潰滅されてしまった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜の旅団司令部か何かに使っていたのを占領したものだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く泥棒のような仕業に、自分達だけをこき使う司令官を「馬鹿野郎！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛兵司令は、大隊長が鞭で殴りに来やしないか、そのひどい見幕を見て、こんなことを心配した位いだった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「軍司令官はどこまでも戦争をするつもりなんだろうか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅団司令部と、大隊本部の間は、急設電話によって連絡された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令部の阪西大尉は、土嚢塁の出来上った成績を点検した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンミニストは日を逐うて、戦いの用意を整えている……」この悲痛な手紙を突きつけられた、裏切者、蒋介石の軍司令部の一行だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　司令部の前に来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　けれども、歩哨には、直魯連合軍司令もヘッタクレもあったもんじゃなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令官は、満洲が脅かされることを知っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、パルチザンの正体と居所を突きとめることに苦しんでいる司令部員は、密偵の予想通り、この針小棒大な報告を喜んだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長は、そのパルチザンの巣窟を、掃除することを司令官から命じられていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不明瞭な点を残さず、悉くそれを赤ときめて、一掃してしまえば功績も一層｜水際立って司令部に認められる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうして司令官は、こんなことをやらせるんです！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長は、司令部へ騎馬伝令を発して、ユフカに於けるパルチザンを残さず殲滅せしめたと報告した。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ユフカは、たしかに司令官閣下の命令通り、パルチザンばかりの巣窟でありました――そう云います。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "閣下とは司令官のことだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐一顧軍刀の鞘を拂つて、屹と屹立つ司令塔上、一｜令忽ち高く、本艦々上戰鬪喇叭鳴る、士官の肩章閃めく、水兵其配置に就く、此時、既に早し、既に遲し、海賊船から打出す彈丸は雨か、霰か。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦長松島海軍大佐の號令はいよ／＼澄渡つて司令塔に高く、舵樓には神變不可思議の手腕あり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田の畔にしれいのごとき草花面白きは何と云うものにや。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまけて遊んだっておもしれいもんでねい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「省作さんにおごらねけりゃなんねい事があるたアこりゃおもしれい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとよさアが省作さアに惚れてる」「さアいよいよおもしれい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
