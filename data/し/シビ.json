[
  {
    "uuid": "7ba5e6ae-e6f8-5c3d-b24a-86b300adb0a3",
    "entry": "鴟尾",
    "reading": {
      "primary": "しび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ornamental ridge-end tile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昼間見ると、その鴉が何羽となく輪を描いて、高い鴟尾のまわりを啼きながら、飛びまわっている。",
              "citation": {
                "source": "羅生門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝間見ると、その鴉が何羽となく輪を描いて高い鴟尾のまはりを啼きながら、飛びまはつてゐる。",
              "citation": {
                "source": "羅生門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂ル名古屋城ノ金鴟尾ナリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに鴟尾の一つが後醍醐時代の模作として幾分｜拙いために、両端から中央へ力を集めようとする企画がかなりの破綻を見せているなどは、この堂の調和の有機的なことを思わせるに十分である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく寸のつまっている大棟も、この夜は気にならず、むしろその両端の鴟尾の、ほのかに、実にほのかに、淡い金色を放っているのが、拝みたいほどありがたく感じられた。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左上に鴟尾のある屋根の少し見えてゐるのが正門です。",
              "citation": {
                "source": "北京「可園」のスケッチ",
                "author": "小林古徑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく寸のつまつてゐる大棟も、この夜は気にならず、むしろその両端の鴟尾の、ほのかに、実にほのかに、淡い金色を放つてゐるのが、拝みたいほど有難く感じられた。",
              "citation": {
                "source": "月夜の東大寺南大門",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋根のそりをはつきりと現はしてゐるのは、大棟の鴟尾のところから四隅の軒先へ流れ下る降り棟の線であるが、その線の緩やかにはね上つてゐる先端へ、正面の軒の左右にのびた線の端の方もまた緩やかにはね上つて一緒になる。",
              "citation": {
                "source": "西の京の思ひ出",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかははねがすっかりしびれてしまいました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の爪草の花、青白いともしびを點じ微かな悦びをくゆらしそれから月光を吸ふつめくさの原。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永らく坐りつづけていたあとで足がしびれて歩けなくなる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、しびれた足の爪先をいくら揉んでもたたいてもなかなか直らない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、夜中に眼が覚めてみると、片腕から手さきがしびれて泣きたいような歯がゆいような心持がすることがある。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもその、しびれた手さきや手首を揉んでも掻いてもなかなか直らない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの場合にはそのしびれた脚や腕の根元に近いところに着物のひだで圧迫された痕跡が赤く印銘されているのでそこを引っかき摩擦すればしびれはすぐに消散するのである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身がしびれ、強直して動けなくなったが、それが「電気のせい」だと思われた。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕詞の「あしびきの」は「あしびき」と読みますが、これも「あしひきの」であって「ひ」というのは皆清音の仮名で書いてある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕はしびれて重かった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の芯から慄えてきて、着剣している銃を持った手がしびれて力が抜けてしまう。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しびっこで恐ろしく背の高いやせこけた老翁であったが、破れ手ぬぐいで頬かぶりをした下からうすぎたない白髪がはみ出していたようである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎の眼は、何かを、しびれを切らして待ちもうけているもののように、いら／＼していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　製氷所の機械場では、黄ろいホコリをかむった蟇のような靴を、マメだらけの足にひっかけて兵士達が、しびれをきらして、自分達の番を待ち、待っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しびれを切らした武松は、坑口まで様子をさぐりに出て来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小さなセララバアドは少しびっくりしたようでしたがすぐ落ちついて答えました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴を抱くようにして急いで脱って、少しびっこを引きながら、そのまっ暗なちらばった家にはね上って行きました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何だか指がしびれたようでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎の腕はしびれてわからなくなってただびくびくうごきました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今度はとんだ災難で定めしびっくりなさったでしょう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲立つの神の御歌を解きて、その時立ちし雲は天地のみたまの顕はせりし吉瑞にて、いともくしびなる雲なりけむなど橘の守部が云へるは、当れりや否や、知らず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "くしびなる雲とは如何なる雲ぞや、問はまほし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
