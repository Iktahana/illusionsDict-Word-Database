    "definitions": [
      {
        "index": 1,
        "gloss": "to become numb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "聴いてゐてさへも身の痺れるやうな寂しい遣瀬ない声、その声が今夜も向うの竹林を透してきこえる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最う其だけで痺れるばかり。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝までに身体が凍え痺れる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧に似たる細雨は隙間もなく瀟々と降頻って、濡れたる手足は麻痺れるように感じた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "痺れるだけ痺れさせて置く氣だ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は指が痺れるほど冷たくて、とてもいい気持よ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念だが、貴様に向ふと手足も痺れる、腰も立たん。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あゝ、私は五躰が痺れる。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがそれを唇に宛てるとき、たった二つのこの唇の小さな押花から女の真ごころが身体中に痺れるほども染み亘る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伊右衛門殿」「うむ、今帰ったが、さっきの薬を飲んだか」「はい、彼のお薬を服むと、其のまま熱が出て顔が痛うて」「そうか、顔が」「痺れるようでござりました」　お岩はそう云いながら蚊帳の裾をめくって出て来た。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ために、咽喉が涸き、手足の痺れるような感じが頻りにする。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、あの痺れるような歓喜！",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹に近く来るとその人全身｜痺れるほど怖ろしくなり銃を放ち能わず一生にかつてこんな恐い目に遭った事なしと（一八九四年十二月『フォークロール』二九六頁）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とずっと出すと、びったり額を伏せて、しっかりと膝を掴んだが、苦痛を堪える恐い力が入って、痺れるばかり。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "懷で眠つた與吉を騷がすまいとしては足の痺れるので幾度か身體をもぢ／＼動かした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は痺れるやうな足を引摺つてとぼとぼと歩いて行つた。",
              "citation": {
                "source": "旋風",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今日、またポストの中にあの封筒を発見した時は、どういうものか、妾は頭の中が痺れるような気がした。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は痺れるような足を伸して、窓際に行った。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て、下腹部の底が少し宛痺れる様に痛み出した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て、下腹の底が少しづゝ痺れる樣に痛み出した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、私は藍色の皮膚をもち、鬼のような顔をした赤ん坊を想像して、全身の神経が痺れるように感じました。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い明神坂を登る時分には、背で眠った弟の重みで、手が痺れるようであった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の身体が、斯も痺れる者とは今まで思い寄らなんだ、声の出ぬのは勿論の事、瞼までも痺れて仕舞い目を開き度くとも開く力さえなく、強いて開こうとしても瞼が直ぐに弛く垂れて眼を蔽うて了い、唯｜辛くに糸ほど細く開いた間から外の明りを見るに過ぎぬ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "張りつめた寒さと痺れるような睡たさとで、私は坐ったまま居睡りをし始めた。",
              "citation": {
                "source": "わが父",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤羽主任は脳髄の痺れるのを感じた。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少青年時代に愛讀して手離さなかつた日本外史の、その章を咄嗟に思ひ出して、不意に感動に襲はれて、頭の中がジーンと痺れるのを覺えた。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さと疲れとで顔の皮は板のように硬ばり、脚は棒のように堅くなり、かつ痺れる。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜もそろそろ咲きかけてるのに、厭ね、私たち‥‥」　なか子は五六年前、観桜会とかで足が痺れる程、一日立ちづめで働いた料理屋の生活を思ひ出してゐた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その振動が手の指先に響いてびりびりとしびれるように感じられた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分からあれを見るとぞうっと総毛立って寒けを催すと同時に両方の耳の下からあごへかけた部分の皮膚がしびれるように感ずるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
