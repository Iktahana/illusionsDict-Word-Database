    },
    "definitions": [
      {
        "index": 1,
        "gloss": "enclosing wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう家は大抵周囲に植木が植込んであって、それが有力な障壁の役をしたものらしい。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山東は満蒙の障壁として、又、重大なる価値を有するものである。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは雨夜の仮の宿で、毛布一枚の障壁を隔てて男女の主人公が舌戦を交える場面、もう一つは結婚式の祭壇に近づきながら肝心の花嫁の父親が花嫁に眼前の結婚解消をすすめる場面である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の歴史のある時期に地球上のある地点に発生した文化の産物は時間の経過とともに人為的のあらゆる障壁を無視して四方に拡散するのは当然である。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてとうとう身親しくその地をおとずれる日が来たのであったが、その時からまたさらに二十年を隔てた今の自分には、この油絵のスイスと、現実に体験したスイスとの間の差別の障壁はおおかた取り払われてしまって、かえって二十年前の現実が四十年前の幻像の中に溶け込むようにも思われるのである。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や」はその上にあるものと下に来るものとを対立させるための障壁である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "句を読むものが舌頭に千転する間にこの障壁が消えて二つのものが一つになりいわゆる陪音が鳴り響く。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃になっては、昭和五年に世界各国は金禁止に伴って関税障壁を競い出した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すもものかきねのはずれから一人の洋傘直しが荷物をしょって、この月光をちりばめた緑の障壁に沿ってやって来ます。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもせっかく入れた師匠に意地がなく、銀子の顔色をさえ見るというふうなので、世間への障壁にはなっても、銀子自身の守りにはならなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "着衣喫飯の主人公たる我は何物ぞと考え考えて煎じ詰めてくると、仕舞には、自分と世界との障壁がなくなって天地が一枚で出来た様な虚霊皎潔な心持になる。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤理学士の奥州産業総説に曰く、「撃てば則ち草に匿れ、追へば即ち山に入つた蝦夷族の版図たりし奥州、山岳重畳して到るところ天然の障壁をなし、以て交通を阻害してゐる奥州、風波高く海運不便なる日本海と、北上山脈にさへぎられて発達しない鋸歯状の岬湾の多い太平洋とに包まれた奥州。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の反対側の窓を開けると相模川の河口の南湖の松林を越して、大山連山の障壁の空に、あっと息を詰めるほど白く見事に富士の整った姿がかかっていた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも述べた通り万一これが、ほかの大衆的な芸術で、封建の障壁が取払われている現代であったならば、芸術界に於ける翁の威望はどの範囲にまで及んでいたであろうか。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "通産省と文部省の作ったコンピュータ教育開発センター（ＣＥＣ）のお墨付きを得てＢＴＲＯＮが教育用コンピューターに指定されながら、「それは一種の非関税障壁じゃないの」とのアメリカのクレームを前後して指定取消となったときには、開いた口がふさがらずに医者に駆け込む始末となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが米国通商代表部が教育用パソコンへのＢＴＲＯＮ採用は、アメリカ企業の市場参入を阻む排他的な貿易障壁となると言いだし、通産省の腰が呆れるほどあっけなく崩れて採用は取り消しとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時忽然として心が急に開け朗かになって、門や窓が開け障壁が消え去ったようになって、それからは異常なくらいに優れて、悟りの速い人になったというではないか。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽井沢のように気流の流れる落ちる地や、神奈川、静岡海岸のように北に高山の障壁があり南は大洋に臨んでいる為に気温の平和を得ている地も、地気清爽とか平和とか言えるだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにつまらない事務用の通信でも、交通｜遮断の孤島か、障壁で高く囲まれた美しい牢獄に閉じこもっていたような二人に取っては予想以上の気散じだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬吉には、おくみの存在が現在の暗いじめ／＼とした世界と、明るい晴々とした自由な世界とを、遮ぎつて居る障壁のやうに、思はれる日が多くなつた。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今ではもう人に対して殆ど何の障壁も持てなかった。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "地はその周囲を一列の高い障壁で取り囲まれ、そして地とこの壁との中間のくぼみに何人も越えることのできない大洋がある、壁の向こう側には神々のために当てられた領域がある。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、其の醜い、其の固陋な障壁を破ろうとして、何時から血の汗を掻きながら戈を振って来ただろう。",
              "citation": {
                "source": "無題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戈を振いながら、彼等の右手は、恐ろしい執念を以て、壊れ落ちる障壁の破片を、しっかりと、命に掛けて掴んで居る。",
              "citation": {
                "source": "無題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの熱心な問い合わせはあったが、コイル部が最後まで障壁となって、記事のカメラには完成にこぎ着けられる人がほとんどいなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "障壁となっていたこだわりが解けると、松本の手は素早く動いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "指のなじみが新規の参入障壁となるこの分野に切り込んでいくには、何らかの新しい特長が必要となると思われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といへば、批評的精神は、あらゆる固定せる障壁を突破して、常住不斷に前進するのを其の本性としなければならぬからである。",
              "citation": {
                "source": "生みの力",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも繰り返し言つた通り、批評的精神の本性は、一切の障壁を突破して、常住不斷に前進するに在る。",
              "citation": {
                "source": "生みの力",
                "author": "片上伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
