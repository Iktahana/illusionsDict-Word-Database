[
  {
    "uuid": "208087ac-7b0a-59f3-b382-cfc58be8296c",
    "entry": "障壁",
    "reading": {
      "primary": "しょうへき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
