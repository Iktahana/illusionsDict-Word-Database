        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浦人島人乗せて城下に往来すること、前に変わらず、港開けて車道でき人通り繁くなりて昔に比ぶればここも浮世の仲間入りせしを彼はうれしともはた悲しとも思わぬ様なりし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すゞが帰ると、間もなく、青島で彼女を貰い受けるため骨折った中津が、足繁く出入りするようになった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔水霜繁く霧たちて〕水霜繁く霧たちて、　　すすきは濡ぢ幾そたび、馬はこむらをふるはしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆は繁く丈よりも高き汀に、船はとんとつきあたりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも花繁く間遠からではをかしからじ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅みどりの葉の色茎の色、日の光に透くやうに見えたるに、小き花のいと繁くも簇がりて紅う咲きたる、もてあそびものめきたれど憎からず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯がともったその低い家並で挾まれた町筋を、仕事をなし終えたと思しい人々がかなり繁く往来していた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客足も夏に向くと段々繁くなつて来る。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "官立大学で経済を学んでいたために、父亡き後の母は、この遠縁に当って足繁く自家へ出入する青年を、何かと相談相手にして、いわば私との恋仲も黙許よりも、寧ろ奨励する形で、結婚にまで熟するのは容易な道行でありました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきは雨脚が繁くって、まるで、薄墨で刷いたよう、堤防だの、石垣だの、蛇籠だの、中洲に草の生えた処だのが、点々、あちらこちらに黒ずんでいて、それで湿っぽくって、暗かったから見えなかったが、少し晴れて来たから、ものの濡れたのが皆見える。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……知つてゐるのは、秋また冬のはじめだが、二度三度、私の通つた數よりも、さつとむら雨の數多く、雲は人よりも繁く往來した。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく視めたが、牡鷄がパツと翼を拂いて、雨脚がやゝ繁く成つたから、歩行き出すと、蘆の根を次第高に、葉がくれに、平屋のすぐ小座敷らしい丸窓がある。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、雨漏にも旅馴れた僧は、押黙って小止を待とうと思ったが、ますます雫は繁くなって、掻巻の裾あたりは、びしょびしょ、刎上って繁吹が立ちそう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい女のその声に、この折から、背後のみ見返られて、雲のひだ染みに蔽いかかる、桟敷裏とも思う町を、影法師のごとくようやく人脚の繁くなるのに気を取られていた、松崎は、また目を舞台に引附けられた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして都會の狹い露路裏に、稻荷の鳥居をくぐる藝者等は、彼等の弗箱である客や旦那等が、もつと足繁く通ふやうに乞うてるのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はあかあかと照り出して、河の上は漸く船の往来も繁くなった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世々の物知り人、また今の世に学問する人なども、みな住みかは里遠く静かなる山林を住みよく好ましくするさまにのみいふなるを、われは、いかなるにか、さはおぼえず、ただ人繁く賑はしき処の好ましくて、さる世放れたる処などは、さびしくて、心もしをるるやうにぞおぼゆる。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に棋の品甚だ繁くして、奕の旨一ならず。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳場は遠し、あとは雪がやや繁くなった。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの雑誌の性質上、サロンの出いりも繁く、席上、太宰さんの噂など出ますけれど、そのような時には、春田、夏田になってしまって熱狂の身ぶりよろしく、筆にするに忍びぬ下劣の形容詞を一分間二十発くらいの割合いで猛射撃。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、八戒と語ることが繁くなるにつれ、最近妙なことに気がついてきた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩堂とお医者様の玄関及び郷校のオルガンある室との間を最も繁く往来したりければ、薬の香り、楽声の余韻なども沁みこみてありと知るべし。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "足繁くなると、ほとんど毎日のように、明神の森へ通ったが、思う壺の巣が見出せない。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も刈萱の蓑いつしかに露繁く、芭蕉に灌ぐ夜半の雨、やがて晴れて雲白く、芙蓉に晝の蛬鳴く時、散るとしもあらず柳の葉、斜に簾を驚かせば、夏痩せに尚ほ美しきが、轉寢の夢より覺めて、裳を曳く濡縁に、瑠璃の空か、二三輪、朝顏の小く淡く、其の色白き人の脇明を覗きて、帶に新涼の藍を描く。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきは雨脚が繁くつて、宛然、薄墨で刷いたやう、堤防だの、石垣だの、蛇籠だの、中洲に草の生へた処だのが、点々、彼方此方に黒ずんで居て、それで湿つぽくツて、暗かつたから見えなかつたが、少し晴れて来たからものゝ濡れたのが皆見える。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔洪積の台のはてなる〕宮沢賢治洪積の台のはてなる一ひらの赤き粘土地桐の群白くひかれど枝しげくたけ低ければ鍛冶町の米屋五助は今日も来て灰を与へぬ。",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくするうち東の空白み渡りて茜の一抹と共に星の光まばらになり、軒下に車の音しげくなり、時計を見れば既に五時半なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きんに生きず死になんに、　　得こそ死なれぬわが影を、うら濁る水はてしなく、　　　　さゝやきしげく洗ふなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔遠く琥珀のいろなして〕遠く琥珀のいろなして、　　春べと見えしこの原は、枯草をひたして雪げ水、　　さゞめきしげく奔るなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
