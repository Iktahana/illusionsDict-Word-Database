[
  {
    "uuid": "aa61d3fa-aa8a-5703-9400-d4f499f2c6cb",
    "entry": "し放題",
    "reading": {
      "primary": "しほうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
