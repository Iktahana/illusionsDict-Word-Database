    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to contribute",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――否、発明発見も人類の幸福に資するものだくらゐは知つてるよと云ふ人もあらう。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人鵜照君の年賀状観の変遷史をここに御紹介して読者の御参考あるいはお笑い草に資するのである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには問題のつり橋のどの鋼索のどのへんが第一に切れて、それから、どういう順序で他の部分が破壊したかという事故の物的経過を災害の現場について詳しく調べ、その結果を参考して次の設計の改善に資するのが何よりもいちばんたいせつなことではないかと思われるのである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを講誦せしめ、また諸国へ普及せしめられたということは、やはり仏教をして国民生活の現実全体に資するところあらしめようとした日本仏教の精神からであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地中のあらゆる汚穢を悉く自己に資する摂取として地上陽下に燦たる香彩を開く、その逞しき生命力。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話頭詩に転ずるや、彼曰く、我は如何なる人の作たるを問はず、一特長ある詩ならば日夕愛誦に資するに躊躇せずと。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高利貸に投資するつもりか」私は皮肉った。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時としては変わった教育法であったが、これが後年の歴史家司馬遷に資するところのすこぶる大であったことは、いうまでもない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それ以上に、人間的完成に資する所の多い途は無かったか？",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は南アフリカのある投資事業に、投資することは、思い止まってしまったのだね」　私はサッと驚かされてしまった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうとなれば、正義に資するためここで本人の供述を採ることこそわたくしどもの務め。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして著作権法はもう一方で、著作物の「公正な利用」に配慮することも、大目的達成に資すると想定している。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "では先駆者達のコンセプトとは全く無関係だったこの運動は、ひとりひとりの人間を自由にするコンピューターを作りだす上で資するところがなかったのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその法王庁や、各国大公使の特殊的社交場であって、最も公平なる世界ニュースの集積地たる以上は、公使を置いて以って我国現在及び将来の国威発展に資する必要がある。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰊漁業などという堅実味のない、経営主の信用状態もあやふやなものに融資するほどに、銀行の金は遊んではいなかった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その作品を提出することによって、癩者の幸福に資する点があるとか、あるいは社会問題としての癩に貢献する確乎たる自信がないかぎり、これは芸術家――ことに映画のような娯楽的性格を持つ芸術に携わるもの――の触れてはならない題材ではないだろうか。",
              "citation": {
                "source": "映画と癩の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ適当の書の研究に資するなきを憾むのみ。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類が今日まで夥しい努力と犠牲によって押しすすめて来た文化の蓄積を最も豊富、活溌に人間性の開花に資するようにうけとり活用して、そのような動的形態の中に脈々と燃える人間精神の不撓な前進の美を感得することは、何故これらの批評家にとってこれ程まで感情的に承認しにくいことなのであろう？",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから吾々は科学的認識を用いて改めて生産にも資するということになる。",
              "citation": {
                "source": "技術と科学との概念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省の教育政策思想政策としては、例の大仕掛けの国民精神総動員（之は文部省単独の仕事ではなく内政全般に渡る責任によるものだが）を別としても、国体明徴のために文理大や若干の帝大に国体学講座を新設するとか、又引き続き国体明徴に資する研究にも、補助費の支給を世話するとか、勿論多忙を極めている。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし欧米の方法は慎重に取捨してこれをおのれに資することを期すべきである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつじょ、警察の名で新聞広告を出して、チャアリイ・ロスの発見、ならびに誘拐者の捕縛に資する重要材料の提出者には、告知と同時に二万五千ドルを与えるというので、これはじつに、真正面から誘拐者を相手どった、思いきった挑戦だった。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強ともあれば博物館にも出掛けて行って、支那絵の古画、絵巻物、ときどきは仏画などをも参考に資するべく、わざわざ奈良の博物館へ弁当持参で参ったものです。",
              "citation": {
                "source": "作画について",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆考拠に資するには物足らぬ作である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "姑く録して後考に資する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにもかかわらず、最も資本に豊富な世界一の富国たる英国において、それらの仕事が皆放棄されたままになっているのは、それら貧乏人の要求に応ずべき事業に放資するよりも、海外未開地の新事業に放資する方がもうけが多いからである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "費用は五十万の漁民から一戸当り毎年二十銭ずつ、各道の官庁から切ってもらって、半官半民的に漁民の指導保護、福利増進に資すると同時に北は露領沿海州から、西は大連沖、支那海まで進出して宜しいという鼻息を、総督から内々で吹き込まれた……というと実に素晴らしい、堂々たる事業に相違ない。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに幽囚中の読書ほど身に資するものが無いと言ひ得よう。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            },
            {
              "text": "書きたいことはないけれど、あの人が嫌ではないしするから書かうといつて書く手紙に、受取つた人が感動する筈はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
