    "definitions": [
      {
        "index": 1,
        "gloss": "to die",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芥川君の死去の報に接した時、自分はむしろ彼の前に、舌を噛んで慚死する恥を感じた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は私は、もう悶死するのかとも思つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は夭死するのだなと思った事はあったが、死が恐ろしくてそう思ったのではない。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "辨天樣の池畔などで、ぐつたり寢そべつて甲羅を干してゐるのは、あれは、いしがめとでもいふのであらうか、繪本には時々、浦島さんが、あの石龜の脊に乘つて小手をかざし、はるか龍宮を眺めてゐる繪があるやうだが、あんな龜は、海へ這入つたとたんに鹹水にむせて頓死するだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の晴れた夜には地面は盛んに温熱を放散して冷却し、雪などに比べては遥かに低い温度に下がって土は凍って作物の芽も凍死する事があるが、雪で蓋をするとこの過度の冷却を遮られ却って凍死を免れるのである。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個中隊すべての者が雪の中で凍死する、そんなことがあるものだろうか？",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならばまだまだ安全であるが、排泄物をなくするために食物を全廃すれば餓死するより外はない。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜉蝣のごときはあしたに生れ、夕に死する、ただ一日の命なのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度の大震大火、男女多く死するの前には、「おれは河原の枯芒、おなしおまへも枯芒、どうせ二人が此世では花の咲かないかれすゝき」といふ謡が行はれて、童幼これを唱へ、特に江東には多く唱はれ、或は其曲を口笛などに吹く者もあつた。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、妻子を食わせるために犠牲になって枯死する人間の多いことだけは事実である。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今度襲われる地方がどの地方でそれが何月何日ごろに当たるであろうということを的確に予知することは今の地震学では到底不可能であるので、そのおかげで台湾島民は烈震が来れば必ずつぶれて、つぶれれば圧死する確率のきわめて大きいような泥土の家に安住していたわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "置いていっても、飢え死するようなことはないだろうね。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢え死することはないだろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれはあした戦死するのだ。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青仮面が出て来て、溺死する時のやうな格好で一生懸命跳ね廻ります。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が百円持って銀行に預けに行く途中で、掏児に取られた体にして届け出よう、そう為ようと考がえた、すると嫌疑が自分にかかり、自分は拘引される、お政と助は拘引中に病死するなど又々浅ましい方に空想が移つる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑死する者は世間に滅多にありや仕ないから、食って生きてるだけなら誰だってするよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田　　芸術のために殉死するのさ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も食べるものの無くなった今、蒟蒻は貴重な糧食であるばかりでなく、私はどうせ餓死するなら蒟蒻ばかり食べて死のうと、こんないこじな気持ちを募らせていました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも恋人はそのために狂死する。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……誰もお媼さんの御馬前に討死する約束は豫て無いらしい。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれで當分餓死する氣遣はない。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處寛政三年波あれの時、家流れ人死するもの少からず、此の後高波の變はかり難く、溺死の難なしといふべからず、これによりて西入船町を限り、東吉祥寺前に至るまで、凡そ長さ二百八十間餘の處、家居取沸ひ、空地となし置くものなり。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その髪千筋一筋ずつ、獣が食えば野の草から、鳥が啄めば峰の花から、同じお稲の、同じ姿｜容となって、一人ずつ世に生れて、また同一年、同一月日に、親兄弟、家眷親属、己が身勝手な利慾のために、恋をせかれ、情を破られ、縁を断られて、同一思いで、狂死するわいの。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも餓死する覚悟があれば、日々好日であり事々好事である、何のおそれるところもなく、何のかなしいものもない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "又タスマニヤ人は其妻死する時は、其子までも共に埋めて平然たる姿なりと。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠洲の或る土人の如きは、其妻の死するや、之を山野に運び、其脂をとりて釣魚の餌となすと云う。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書きたいことはないけれど、あの人が嫌ではないしするから書かうといつて書く手紙に、受取つた人が感動する筈はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんなことが考へられもするが、考へられてもそれはどうにもならないことだしするから、私は身を棄ててお前に尽さうと思ふよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
