  {
    "uuid": "876eb7ad-6466-511c-babc-64c5af80d21f",
    "entry": "死する",
    "reading": {
      "primary": "しする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
