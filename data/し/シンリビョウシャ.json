    "definitions": [
      {
        "index": 1,
        "gloss": "psychological description",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんな大人のお伽話みたいな心理描写ばっかりである。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の心理描写は平凡な心理描写に過ぎなかった。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから将来の心理描写こそは真実な心理そのものの解析、綜合でなければならぬ。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宙外の心理描写も、空想の分子が余り多すぎたので、硯友社の人達の作品と比べて稍々真面目な処があるにも拘らず、余り高い名声を得るに至らなかつた。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』――心理描写――ロシヤ文学、とてもあの細かい彫刻のやうな筆致は真似が出来ないと思はれてゐた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何方かと言ふと、この心理描写が下手だ。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国では、ゴンクウルだの、ドストイエフスキーだの、トルストイだの、モウパツサンだの非常に心理描写の旨い人もあるが、日本ではさう多くない。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目さんのものは他には別に感心もしないが、又その程度があまりに普遍的で平凡であるが、それでも心理描写には骨を折つた人だ。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、『弓子』に試みた心理描写が非常に難かしくて困つた。",
              "citation": {
                "source": "心理の縦断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなアクションの少ないものは、もっと心理描写をしなければだめだ。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作者の、機械的、乃至は幾何学的とでも云い度い程で確な心理描写の中に夫れのあるのは面白い。",
              "citation": {
                "source": "他界の味其他",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、ろくに「いろは」も書けない様なものがこんな事を云うのもあんまり生意気の様ではあるが、やっぱりあの頃に二葉亭四迷が「浮草」ほどの心理描写をしたものが世に出て居たとすれば、紅葉山人の終りの方の作には或る面白い変化があれば、あられたろうと思う。",
              "citation": {
                "source": "紅葉山人と一葉女史",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気、殊に、恐ろしい「コレラ」と云うものに対しての恐怖、先生が病気の弟子を思う心、　あれは立派な心理描写である。",
              "citation": {
                "source": "紅葉山人と一葉女史",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、そういう意味での心理描写や、諷刺を幽鬼の街と村との内の世界に求めることは徒労である。",
              "citation": {
                "source": "観念性と抒情性",
                "author": "――伊藤整氏『街と村』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年後の明治二十年に、二葉亭四迷の小説「浮雲」があらわれ、日本文学ではじめての個性描写、心理描写が試みられたのであった。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝口氏が益々奥ゆきとリズムとをもって心理描写を行うようになり、ロマンティシズムを語る素材が拡大され、男らしい生きてとして重さ、明察を加えて行ったらば、まことに見ものであると思う。",
              "citation": {
                "source": "「愛怨峡」における映画的表現の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その凄惨な光景や心理描写が、きわめて巧妙にきわめて力強く、描き出されてあったことの記憶が思い浮べられるに過ぎない。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るのは心理描写位なものだ。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命当時、「装甲列車」を書いたフセワロード・イワーノフは、ロイド眼鏡こそ昔のままだが、気力のない、階級性欠落状態で昔の思い出や個人的な心理描写をはじめた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リベディンスキーが、「射撃」の作者に対して、心理描写も、プロレタリア・リアリズムにとって欠くことの出来ない一つの要素だと云った時は、間違っていなかった。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リベディンスキーは、彼の持論である心理描写において、全く個人主義的な立場での心理穿鑿に陥ったばかりではない。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カターエフの誤謬は階級的闘争を大衆的に表現せず、個人の心理描写で説明しようとしたところにある。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯友社の文学はその頃でも「洋装をした元禄小説」と評されていたのだが、そういう戯文的小説のなかへ、二葉亭四迷はロシア文学の影響もあって非常に進歩した心理描写の小説「浮雲」を、当時は珍しい口語文で書いたのであった。",
              "citation": {
                "source": "生活者としての成長",
                "author": "――二葉亭四迷の悲劇にもふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "広津柳浪は既に「残菊」などで心理描写だけの小説を試みているけれども、一葉は、お力の心の浮沈を辿ったその執拗さで源七の心理を追究しようとは試みていない。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（或は心理描写の影を帯びてゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふ手法に煩はされないとすれば、「小春治兵衛」は心理描写の上には決して写実主義を離れてゐない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人物も心理描写の上には存外｜屡写実主義的である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして前者の新らしい心理描写――行為の説明のための心理解剖ではない――の文学が、性格を軽視すると共に、後者の結局は権力をめざす階級闘争――真の社会革命のための闘争ではない――の文学も、性格を軽視する。",
              "citation": {
                "source": "性格批判の問題",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「音もなく咲いて音もなく凋む一輪の花の命を、或る限られた時間に観察することが出来るとしたら、それは恐らく、彼の戯曲を観ることになるであらう」といふ批評は、蓋し、繊細な暗示に富む心理描写の清澄な詩的表現を云ひ尽してゐるやうに思はれる。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
