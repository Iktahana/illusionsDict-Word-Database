        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ホホホホホホ」女は全速力の船の、スクルーシャフトが回転してるようだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がべルトやシャフトや電球のフィラメントやセルロイドの切り屑に見えてよいものだろうか。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄骨の梁を渡っているシャフトの滑車の各機械を結びつけている幾条ものベルトが、色々な角度に空間を切りながら、ヒタ、ヒタ、ヒタ、タ、タ、タ……と、きまった調子でたるみながら廻転していた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この労働者の首ッ根にベルトがかゝれば、彼等は旋盤がシャフトを削り、ボール盤が穴を穿ち、セーパーやステキ盤が鉄を平面にけずり、ミーリングが歯車を仕上げると同じそのまゝの力を出す。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "大乗盤の側の空所に、註文の歯車やシャフトや鋲付する煙筒や鉄板が積まさっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャフトにベルトをかけると、突然生物になったように、機械は歯車と歯車を噛み合わせ、シリンダアーで風を切った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステキ盤でシャフトに軌道をほっていた仲間が、口を掌で囲んで、後から悪戯した。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "うべなるかな、熊本博士は、窓を支える滑車のシャフトにも油をさしておいたから、こう楽に上るのだ。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、そう、だけどあれでもアルゲマイネ・ゲゼルシャフトの錚々たる社員だわ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻るシャフトの下から、油のにじんだ手袋が延び出て来ると、参木の靴の間でばたばたした。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はアルゲマイネ・エレクトリチテート・ゲゼルシャフトの支店詰のヘルマン・フィルゼルというものです。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われらの敵、アルゲマイネ・エレクトリチテート・ゲゼルシャフトの隆盛のために。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Gt はゲゼルシャフト、ドイツ語で会社という意味だ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィッセンシャフトリヘ・ビブリオテク 6-8.17.73.　ベルタ・フォン・ズットネル著、ディ・ワッヘン・ニイデル。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評は動力の枢軸（シャフト）を必要とするのである。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を連結し、交錯交流させ、推し動かし、分解させ再構成させるシャフトである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に彼はデモーニッシュなものはあらゆるライデンシャフトに伴ふのがつねであると述べた。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして我々はそれが個人的としては「ライデンシャフト」に、社会的としては「パトス」に伴ふといふ風に区別することもできやう。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といはれた句に於けるライデンシャフトから區別しなければならぬ。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の解釋によれば、ライデンシャフトは個人的身體に結合し、パトスは社會的身體に結合する。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史に於ける如何なる大いなるものもライデンシャフトなしには、然しまたパトスなしには爲し遂げられなかつたのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲマインシャフト的な具體的な社會においては抽象的な情熱であるところの名譽心は一つの大きな徳であることができた。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲゼルシャフト的な抽象的な社會においてはこのやうな名譽心は根柢のないものにされ、虚榮心と名譽心との區別も見分け難いものになつてゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも機械の運転を休止して、予備のシャフトを入れ換える事だ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャフトのアトからブクブクブクと来るんだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャフトの素晴らしさが。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も吾輩が乗ったからシャフトが折れたのかも知れないがね、ハッハッ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ一本しか無い予備シャフトを無駄にしたらそれこそホントウに運の尽きだからな。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯ヶ浜の鋳製所も、久光が調所にねだってくれたので、出来たのだしのう――」　斉彬は、笑いながら「船を作ろうとして、シリンドルと、シャフトを鋳造したいと申したら、久光が、由羅の臍繰から、捲上げて来てくれた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "榴弾も出来たし、シャフトも出来たし、紅硝子もできたし、ただ一冊の、オランダの本だけからでも、異国に負けぬものが造れた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
