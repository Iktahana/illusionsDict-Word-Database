[
  {
    "uuid": "f2eae29b-c092-5c8f-8787-d9223f553963",
    "entry": "蝦蛄",
    "reading": {
      "primary": "しゃこ",
      "alternatives": [
        "シャコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mantis shrimp (any marine crustacean of order Stomatopoda, esp. the species Oratosquilla oratoria)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……それが可厭なら蝦蛄の天麩羅。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗へ妻、蝦蛄のひと籠、吹く風は緑に煙り、「時」はよし、照り移るなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのよろし蟹よ蝦蛄よ、それよこれよ、そをめせ、かくめせとあはれ、中つつき、殻ほじりあはれ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その和子はかくなる歳を、老いづくを、蟹や蝦蛄さもこそあらめど、身の老の、その海老腰の、おのれ知らずて。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前のその蝦蛄の乾もののようになった、両手の指を、交る交る這って舐めろと言え。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ばっかりなら、蝦蛄だって大好きなんだ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾の南方を、町から当面の出島をかけて、蝦蛄の這う様にずらり足杭を見せた桟橋が見ものだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に蟹や蝦や蝦蛄なんかが入っていたらさぞ旨かろうな」。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "灣の南方を、町から當面の出島をかけて、蝦蛄の這ふ樣にずらり足杭を見せた棧橋が見ものだ。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「引っ舁げ」「人質か」「おふくろとあれば、取りに来ずにはいられまい」　それを聞くと、ばばは、骨ばった体を反らして、蝦蛄のように暴れた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしゃこの二、三日、寿命を縮める思いをしながらアンタの行方を探いておったがなア」「アハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　そこまで言われてですね、事実、わしゃこの通り髪はまったくすばらしいほどの赤い色合いをしておりますので、このことで競うなら今まであったどんなやつにだって負ける気すらせんのですわ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野は細面手の色黒い顔に、こしゃこしゃした笑いようをしながら、くたびれたような安心したようなふうで、大儀そうに片手に毛布と鞄との一括を持ち、片手にはいいかげん大きいふろしき包みを二つ提げてる。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のごとく、こしゃこしゃした笑顔で、不順序に思う事をいう。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄は足手まといですから、親分わしゃここでお暇をいただきますと、あっさり出ちゃどうだい。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "海が遠浅なので、私はよく潮の退いた跡へおり立って、蝦や、しゃこや、がざみや、しおまねぎや、鰈や、いろんな貝などを捕った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、行く先ゃさっきの職人からきいた化け物屋敷のように思われますが、あっしゃこう見えても善人なんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、だんな、あっしゃこれでも、だんなのためにゃ命までもと打ち込んでいるつもりなんですが、まさか急にだんなは、あっしにみずくさくなったわけじゃござんすまいね」「やぶからぼうに、おかしなことをからまってくるが、いったいどうしたのかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、だんな、それであっしゃこう思うんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、だんな、性得あっしゃこの秋っていうやつが気に食わねえんでね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生得あっしゃこういうものがはだに合わねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃべりだしゃこれでずいぶんとたのもしいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしゃこななでっかいやつを……。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かァさん、かさん――やくらか、やくや――ほうちさ、やくやくう――おんこしゃこ――もこしゃこ――」　何処で教わるともなく、鞠子はこんなことを覚えて来て、眠る前に家中踊って歩いた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしゃこんど初めてこんなところへ来たんですから。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん達は何も知らないだろうけれど、あたしゃこれで、あの家は隅から隅まで見て来たんだよ。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "松年先生の画風というのは四条派のしっかりしたたちで、筆などもしゃこっとした質のもので狸の毛を用いたのをよくお使いになっていられた。",
              "citation": {
                "source": "三人の師",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "結綿、割唐子、めおと髷、唐人髷、蝶々、文金高島田、島田崩し、投島田、奴島田、天神ふくら雀、おたらい、銀杏返し、長船、おばこ、兵庫、勝山丸髷、三つ輪、芸妓結、茶筌、達磨返し、しゃこ、切髪、芸子髷、かつら下、久米三髷、新橋形丸髷。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "達磨返し、しゃこ結び、世帯おぼこ、三ツ葉蝶、新蝶大形鹿子、新蝶流形、新蝶平形、じれった結び、三ツ髷、束ね鴨脚、櫛巻、鹿子、娘島田、町方丸髷、賠蝶流形、賠蝶丸形、竹の節。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなら、わたしゃこう言ってやりますだよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
