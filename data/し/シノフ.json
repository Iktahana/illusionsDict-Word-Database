        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、なつかしむようにいって、マタンの亜麻色のかみが、ぼうしのふちからのぞいているのをちらっと見て、「あなたのおかあさんは、亜麻色のかみをしていましょう。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、わたしのふきならす笛の音色はあなた方、土の上の者には聞こえはせぬ。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ふたりは、ひゅうひゅう、ひどいあらしのふくなかへとびだした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイルばりの大きなだんろのそばには、ししのふたのついた、青磁のかめが、おいてありました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのふところには売り忘れたアラン・ポーの「ユリイカ」が一冊しのんでゐるだけだつた。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――腕を伸して抱きあげたが、鳥は眼を閉ぢて、驚く様子もなく、わたしのふところに移つた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎は、わたしのふところから首を出して、空を見あげてゐた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「不足かい」「だって、兵糧をつめないことには、いくらあっしだって、いくさはできませんよ」「それだから、金葉へでもちょっくら寄って、中ぐしのふた重ねばかりも食べようかといってるんだよ」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "――腕を伸して抱きあげたが、鳥は眼を閉ぢて、驚く樣子もなく、わたしのふところに移つた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくともわたしのふれた範囲では、「勤労者文学」の規定について、ふみこんだ討議がされないままに、『勤労者文学』が創刊された。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのみがく桃色のうつくしい足のゆびは、息のあるやうにうごいて、わたしのふるへる手は涙をながしてゐる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのふたつの手はくさりとともにさらさらと鳴つてゐる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫とくらべてハ私などハ、うんがつよくなにほど死ぬるバへでゝもしなれず、じぶんでしのふと思ふても又いきねバならん事ニなり、今にてハ日本第一の人物勝憐太郎殿という人にでしになり、日々｜兼而思付所をせいといたしおり申候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年三月二十日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなことが暫く続いておりますうちに、わたくしのふとした粗相から、ますます面倒なことになって参りました。",
              "citation": {
                "source": "花子の陳述",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのふくが赤かつたら、わたしのおびが青かつたら、わたしは　もうすこしおとなしいのに。",
              "citation": {
                "source": "〈あかい、やさしい　はなもやうが〉",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉が落ちつくして、こがらしのふき始める秋まで待つ事はたえ切れなかったのです。",
              "citation": {
                "source": "真夏の夢",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒー沸しのふたも、まだおとなしくしている。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの少しのふくらみであり、寝床にはいってさわってみると飛び上るほど痛かった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、銀の屋根の建物の下で、大きい黄金の寝台の上で、わたしのふところで寝られます。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、こがらしのふく、季節となりました。",
              "citation": {
                "source": "水七景",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて明治六年キリシタン禁制の高札は撤去せられ、あっぱれ信仰を守り通した浦上のキリシタンはふたたび懐かしのふるさとへ送り返されたのであります。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "張り板がその過去に、どんなひどいめにあわされてきたかと疑ったことに、すこしのふしぎもなかったからです。",
              "citation": {
                "source": "春さきの古物店",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、わたしのふるさとの景色だこと。",
              "citation": {
                "source": "海からきた使い",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま、わたしのふんだほご紙に、とのさまのお名まえがかいてあっただけのことです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま泰軒の言ったとおり、江戸の大空に明鏡をかけたように、大小の事々物々、大岡様の眼をのがれるということはないのですから、この、巷に隠棲する作阿弥を、かねてからそれとにらんでいたとしても、すこしのふしぎもないので。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ東兵衛が、わしと半分ずつ持って具足屋へおろした資本だな、それだけは、わしのふところから出して、急場をしのがねはならぬことになったのだ」「でも、それはお出しにならなければならなかったことはございますまい。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは、幾分か片方で切りつめて余った energy をこちらの方に向ける、どちらかといえば押しのふとい方なのです。",
              "citation": {
                "source": "無題",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいのめうしは、ちっぽけだ、めうしのふくらはぎはちっぽけだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "はづなは入り用であったから、もうあとそれでわたしのふところには二十スーしか残らないと思いながら、六十スー出した。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
