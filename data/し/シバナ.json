    "definitions": [
      {
        "index": 1,
        "gloss": "Triglochin maritima var. asiatica (variety of seaside arrowgrass)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
