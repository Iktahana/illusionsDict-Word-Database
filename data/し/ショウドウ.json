      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "advocacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かえって唯名論の唱道する個別的特殊の一種なる民族的特殊性である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この同じピタゴラスがまた楽音の協和と整数の比との関係の発見者であり、宇宙の調和の唱道者であったことはよく知られているようであるが、この同じピタゴラスが豆のために命を失ったという話がディオゲネス・ライルチオスの『哲学者列伝』の中に伝えられている。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はとにかく今日では我邦ですらも科学というものの功利的価値は、理解されたというよりむしろ無理解に世間で唱道されている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又其特殊な趣味が容易に多数に肯われない所を、決然身を挺して唱道する所が、評家会心の点らしい。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人の思はく如何は別問題として、彼の唱道した超人主義の哲学が、此際｜独乙に取つて、何れ程役に立つてゐるかも遠方に生れた自分には殆んど見当が付かない。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪辺の町医村医は口だけは聞き覚えた東洞が唱道の「万病一毒」といふモツトーを喋舌るが、実技は在来の世間医だつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に各種の發明者、若くは新説の唱道者、眞理の發見者等は、皆此の努力に因つて其の一代の事業を築き上げて居ると云はねばならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから写生の唱道は啓蒙運動として見る時に価値があるが、真の芸術の絶対境はその写生から出てもつと高い、もつと深い、もつと幽かな、真の象徴に入つて初めてその神機が生き気品が動く。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "平民的道徳の率先者も、社会改良の先覚者も、政治的自由の唱道者も、誰か斯民に生命を教ふる者ならざらんや、誰れか斯民に明日あるを知らしむる者にあらざらんや。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は政論家として若くは経世家として、是問題を唱道する者にあらず、尤も濃厚なる、尤も着実なる宗旨家として、善く世の道理力と人の正心とを対手として、以て吾人の天職を尽さんとするにあり。",
              "citation": {
                "source": "「平和」発行之辞",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "又類例を以て云へば、天香西田氏詰の唱道する所が、種々の點に於てこれに近似してゐる。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこゝで忌憚なく所信を發表すれば校長無用論を唱道する。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に各種の発明者もしくは新説の唱道者、真理の発見者等は、皆この努力に因ってその一代の事業を築き上げていると言わなければならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "タゴオルの唱道されるのは、一面は（全面とは言はない）矢張さういふところから来てゐるのであらう。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから僕は大いにハガキ文學を唱道してるんだ。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "模倣、卑しき模倣、之れ国民の、尤も悲しむべき徴候なり、我は英国文学を唱道すと宣言し、我は独逸文学を唱道すと宣言し、我は仏国文学を唱道すと宣言す、その外に又た、我は英国思想を守ると曰ひ、我は米国思想を伝ふと曰ひ、我は何、我は何と、各々便利の思想に拠つて、国民を率ゐんとす。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学派の後またストア学派なる者があって、同一の主義を唱道した。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは今日もしばしば唱道されて、しかも絶滅し得ない一種の弊害であるらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "典型的な文展に対して、大阪が同情し、後援すべき画風がありとすれば、それは独創を尚び、研究の自由を唱道し、兼ねてまた反抗的精神に富むでゐる美術院一派でなくてはならぬといふのが、会の主人側の意見であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義唱道の当時も、欧羅巴の自然流の作品については、余り多く親むでは居なかつたやうだが、渉猟した書物から獲た智識を、統一し摂取して自分のものにするには独得の技倆を有つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大男＊＊６・26東京日日（夕）　体育がさかんに唱道せられるやうになつてこのかた、青年学生の体格がよほどよくなつたのは、あらそへない事実だが、それでも昔の人と今の人とをくらべてみると、やはり昔の方が大きかつたらしく思はれる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でも大衆に対して述べようという場合となると、国家の利害に対する責任上、数百年来の昔から伝わり、そして公認の宗教と合体し、従って神聖にして犯し難いものになっている在来の観念を唱道しなければならなかった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペリクレス（Perikles）の師であったアナキサゴラス（Anaxagoras）は紀元前約五〇〇年に小アジアで生れ、ペルシア戦争後アテンに移った人であるが、彼は以上の考えを宇宙全体に適用し、すなわち、宇宙の永遠不滅を唱道した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの書中にエピキュリアン派（Epicur）の人生哲学と、エムペドクレス及びデモクリトスの宇宙観自然観を賛美し唱道している、その中に物質の磁性に関する記事解説もある。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョルダノ・ブルノもまたこの説を熱心に唱道した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "トそう思うほど、お顔が見たくッて、堪らないから、どうしましょうどうしましょう、どうかしておくれな。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄よさらわれて行った兄よあなたの後へはすぐ続く者がある筈だあなたをこぼれ種子に捨て置く筈がどうしてありましょうどうかお心丈夫にわたしたちも今にこのしかえしはして見せる奴等を迎え討つ！",
              "citation": {
                "source": "さらわれた兄よ",
                "author": "――残された妹の歌――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで国粋主義のしょうどうは日本においても近時いちじるしく盛んであるのは、あたかもドイツに似ているともいわれるであろう。",
              "citation": {
                "source": "日本文化と科学的思想",
                "author": "石原純",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
