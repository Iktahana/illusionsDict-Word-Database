[
  {
    "uuid": "b4efe964-be77-5942-8075-611fd2c270d7",
    "entry": "唱道",
    "reading": {
      "primary": "しょうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
