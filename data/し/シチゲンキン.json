        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（足音近づくと共に、七弦琴の音聞こゆ）女子　（耳を澄まし）七弦琴の音がする。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の幼い頃、この室へ来ぬ前に、弟と一緒に弾いた七弦琴の音がする。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一層高く七弦琴鳴る。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に七弦琴を持つ）少年　（女子を眺め）お姉様！",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私この七弦琴に合わせて弾くことが出来るのよ。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までお姉様のいらっしゃった岩の上には、お姉様がしじゅう弾いていらっしゃった七弦琴が置いてあったばかり。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ね、この七弦琴が。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と自分の持ちたる七弦琴を差し出す）そこで私は、岩の上に立ち上がって海の方を眺めたのよ。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉様の弾いていらっしゃった七弦琴を弾いてね。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私、ただ七弦琴に合わせて、節だけ鳴らしていたんですの。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と云いつつ床上に落ちたる七弦琴を取り上げてヨハナーンに渡し）さあ。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年　（七弦琴を受け取り）お姉様！",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と七弦琴を構える）女子　（絶えず、扉の外の物音に気をくばり）このお歌は。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
