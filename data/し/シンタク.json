    "definitions": [
      {
        "index": 1,
        "gloss": "trust",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "信託会社の分譲地の柱が立っている。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしに代つて今は信託會社が地主で、昔のわしとこの小作の衆は會社を旦那にしとるわけだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大部分の貸主は勸業銀行と信託會社だ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中は、わしと同じ地主だが、同時にまたわしが借りとる信託會社や地方銀行の株主でもあるんだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る信託会社と、専門家の間ではネゲティブな意味で名を知られているその電気会社とが共同で計画して開いた住宅地が××町であった。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その親方は手広く商売をし、信託会社にも関係があった。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかた建つだけの家が建ち、信託会社も請負師も住宅地から手を引いた。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……去年来たときから見るとその辺の樹も太くなったようですね」「同じ信託地の内でも、あっち側は低いし、時代のついた木なんぞ一本もありませんから、さて建てるとなると、庭が大変です」　女は都会人らしく気味悪そうに空地の入り口に袂を掻き合わせて佇んでいた。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尾は龍子の金を信託された責任を負い、そして、龍子は、その委託金の融通権限をもっていた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣太郎は、信託會社の不動産課に勤めてゐて、月のうち、二週間位はあつちこつち地方を廻つて歩いてゐる。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋の或る信託會社に勤めてゐて、時々詩や小説なんかを書いてゐた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月の末になると、某信託会社から使者が来て、規定どおり五百円の金をおいてゆくのだった。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入院費や手術費とは別に、多額の金が、その信託会社から支払われたそうである。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう見た三井信託の男がやって来たが、あれはものになる土地にあらず。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本信託の森川氏が、娘やその友達のために建てたもので、毎年、一月のはじめごろになると一行が、料理番の婆やと女中をひとりつれてやってくる。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枝は、その金の管理を、夫の親友で、関東信託に勤めてゐる瀬戸といふ男に頼み、その高については、母の下枝子にさへ内証にしてゐたのである。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも國政は、國民の嚴肅な信託によるものであつて、その權威は國民に由來し、その權力は國民の代表者がこれを行使し、その福利は國民がこれを享受する。",
              "citation": {
                "source": "新憲法の解説",
                "author": "日本國憲法",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十章　最高法規第九十七　　この憲法が日本國民に保障する基本的人權は、人類の多年にわたる自由獲得の努力の成果であつて、これらの權利は、過去幾多の試錬に堪へ、現在及び將來の國民に對し、侵すことのできない永久の權利として信託されたものである。",
              "citation": {
                "source": "新憲法の解説",
                "author": "日本國憲法",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十章　最高法規第九十七條　この憲法が日本國民に保障する基本的人權は、人類の多年にわたる自由獲得の努力の成果であつて、これらの權利は、過去幾多の試錬に堪へ、現在及び將來の國民に對し、侵すことのできない永久の權利として信託されたものである。",
              "citation": {
                "source": "日本國憲法",
                "author": "日本国",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊丸　小さな信託會社で、工場や商會などの經理方面の依託事業などもしていますけど――御橋　じや……だから、勤めているんでしよう？",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お立派な観音様、これはね、先代様がシャム国へ御派遣になった時、有名なワット・サーケーという寺院の御住職様から御拝領になったものですよ、あんまり大きいので平常は菱井信託の地下二階の宝物庫にお預けになっていたのを特にこの度お取り寄せになったんです」　と同族の侯爵夫人が云った。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのべらぼうに大きな寝観音の背中にはうんと土産物をかくしているそうだ、信託へ持ち込まないうちに盗ってやれ、鼻をあかしてやろうじゃないか、一泡ふくぜ』と憎い口をきいているのです。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々悩んだ揚句、ふと思いついたのは信託の地下二階に保管を頼んである寝観音でした。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい荷物の出し入れは毎度の事なので信託の人々にも怪しまれず、始末が出来ました。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年目の祥月命日、即ちこの遺書を認める前日私は信託へまいり、寝観音を開いて見ました。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでせめてもの心やりに懇意な人形師に頼み、公高の似顔をつくらせ、それを時折眺めに信託にまいり、僅かに慰めていたのです。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は四五年前からある信託会社の地下室の保護金庫を借りて居りました。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信託会社では私共は信用されて居りますし、長い間の得意ですから、決して疑うような事はありません。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一ヶ月ほどして内地から来た新聞に、『某信託会社の保護金庫内よりミイラ現わる』という大標題で、勝田家の借りていた大金庫内のトランクからミイラが出たということが出ていました。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
