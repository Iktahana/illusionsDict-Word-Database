        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新大橋の下｜直に○中洲ありて川の西部に横たはり、儼として一島をなし、酒楼の類のこゝに家するもの少からず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒楼の下の岸には画舫もある、舫中の人などは胡麻半粒ほどであるが、やはり様子が分明に見える。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までいた宴会の趣旨の船の新造卸しから連想するためか、水の上の人々が酒楼に上ったときの話が多かった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕は翔る、葉煙草と※オロン薫ゆる和蘭の酒楼のまへを。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は友と湯島の酒楼に会し、韻を分つて詩を賦した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「瀬戸橋畔｜東屋酒楼にて飲す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "老入歓場感易増、煙花猶記昔遊曾、酒楼旧日紅粧女、已似禅家退院僧。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "白石氏は長崎の人で上海第一の日本酒楼六三亭の主人であるが、居留邦民中の任侠家として名高い。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもや貞之進にそんな思惑があろうとは、同宿の悪太郎輩も心附かなんだが、秋元の女房は近来貞之進の帰宿が遅く、預りの金をことごとく請戻したことから、羽織帯小袖の注文｜石鹸香水の吟味が内々行われることを考え合せ、密かに目を注けてあやしんで居たものゝ、それでも単身柳橋の酒楼に馳向うとは夢にも思わなかった。",
              "citation": {
                "source": "油地獄",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "――街の剃頭店主人、何小二なる者は、日清戦争に出征して、屡々勲功を顕したる勇士なれど、凱旋後とかく素行｜修らず、酒と女とに身を持崩していたが、去る――日、某酒楼にて飲み仲間の誰彼と口論し、遂に掴み合いの喧嘩となりたる末、頸部に重傷を負い即刻絶命したり。",
              "citation": {
                "source": "首が落ちた話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たのは如何なる因縁か、何時も小有天と云う酒楼だった。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "談判の際大抵豪商とは直接にしないで、番頭を相手に交渉するのであるから、その事なき平素から留守居は時々番頭に贈物をしたり、また酒楼へ連れて行ったりして、機嫌を取るに汲々としていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "水本先生は酒を飲むから酒楼に行くことも度々で、酔って帰ることも多かったが、また塾生を同行することもあった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒楼に上がれば、一合三、四勺入りの徳利を二合入りと称して、一本七十銭から八十銭と勘定書についてくる。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "木母寺の植半は旅宿をかねたる酒楼にてその頃は芸者を連れし泊込みの客多かりしが二、三年を出でずして或会社のこれを買ひ取りて倶楽部とやらになせしより木母寺の境内再び紅裙のひらめくを見ず、梅若冢の柳を見ても黄昏一片麋蕪雨と柏如亭が名吟を思ふべき人もなくなりたり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "言問のほとりにも中の植半とて名高き酒楼ありしが大正のはじめには待合風の料理屋となり女夫風呂とか名付けし鏡張りの浴室評判なりしが入浴中に情死を遂げしものありて忽客足絶えほどなく家も取壊しになりしと聞けり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その酒楼の二階座敷の手摺には、鎗ぶすまを造って下からずらりと突き出した数十本の抜き身の鎗がある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その規定によると、滞在中は洛の中外を随意に徘徊することは許される、諸商い物を買い求めたり小屋物等を見物したりすることも許される、しかし茶屋酒楼等へひそかに越すことは許されない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口屋の女主お直というは吉原の芸妓であったが、酒楼川口屋を開いて後天保七年に隅田堤に楓樹を植えて秋もなお春日桜花の時節の如くに遊客を誘おうと試みた。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "是ニ於テヤ酒楼ノ情況宛然妓院ニ似タルモノアリ。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑是ノ酒肆ハ浅草雷門外ナル一酒楼ノ分店ニシテ震災ノ後始テ茲ニ青※ヲ掲ゲタルモノ。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒楼に上りても夜少しく深けかかると見れば欄干に近き座を離れて我のみ一人｜葭戸のかげに露持つ風を避けんとす。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "盃盤の選択は酒楼にあつては直に主人が風懐の如何を窺はしめ一家にあつては主婦が心掛の如何を推知せしむ。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重多年｜教坊にあり都下の酒楼旗亭にして知らざるものなし。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "因にしるす南岳が四谷の旧居は荒木町｜絃歌の地と接し今岡田とかよべる酒楼の立てるところなり。",
              "citation": {
                "source": "礫川記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途湖山唖※の二子と酒楼笹川に飲む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "また湯島の酒楼松琴楼は松金屋のことで、広重の錦絵「江戸高名会席｜尽」に不忍池を見渡す楼上の図が描かれている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜枕山湖山らの月を賞した棹月楼は橋場の酒楼柳屋のことである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝五時から晩の八時頃まで、長い割竹の先にしゅろうのささらをつけて、ヒョコリヒョコリ歩いていたお爺さんが死んだ。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
