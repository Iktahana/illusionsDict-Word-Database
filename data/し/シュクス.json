[
  {
    "uuid": "2388ca1e-3fcd-57db-8355-3d05d2f8d820",
    "entry": "祝す",
    "reading": {
      "primary": "しゅくす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to congratulate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出征を祝す、の征旗も、旗を取り込んで、てつぺんに葉を少し残した旗竿だけが、淋しく軒先きに立つてゐる。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ポーラとの結婚を祝する座員ばかりの水入らずの宴会の席で、ポーラがふざけて雌鶏のまねをして寄り添うので上きげんの教授もつり込まれて柄にない隠し芸のコケコーコーを鳴いてのける。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又李白の子を祝する句に曰く、揚杯祝願無他語、謹勿頑愚似汝爺矣。",
              "citation": {
                "source": "聞きたるまゝ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、としよりの爲には此の暖な日和を祝する。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "散策子はむくと起きて、ひそかにその幸福を祝するのであった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「万歳※」「秋山男爵の成功を祝す。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……窈窕たるかな風采、花嫁を祝するにはこの言が可い。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを祝する意味に於いて、だ、（一升瓶とさかなを両手にぶらさげ部屋にはいり、部屋の上手の襖をあけ）おうい、おうい。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "老生の初陣を慶祝するが如き風情に有之候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他なし、社会のために祝するなり。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ道学先生のために、祝すべき事ではない。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「長田秀雄君の入営を祝す」と大書したびらに黒わくを附けたのを高村君が持つて来て壁にかけた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街を走る吹聽人はいふも更なり、今咲き出づる「アネモオネ」の花、高く聳ゆる松の末より空飛ぶ雲にいたるまで、皆我を祝する如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロオザが杯を擧げて、我健康を祝せんとする時、友は急に遮りて、否々、凡そ婦人たるものは、決してアントニオが健康を祝すべからず、そは此男終身｜娶らずと誓ひぬればなりといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "牽牛織女のおめでたを、下界で慶祝するお祭りであろうと思っていたのだが、それが後になって、女の子が、お習字やお針が上手になるようにお祈りする夜なので、あの竹のお飾りも、そのお願いのためのお供えであるという事を聞かされて、変な気がした。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主仰天して彼を捉え打っていわく、汝死人に遇わば愍んで今後かかる事なかれと言うべきに多く祝するは何事ぞと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大いに祝すべしぢやないか？",
              "citation": {
                "source": "アカシヤの花",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同時に入露以前から二、三の露国革命党員とも交際して渠らの苦辛や心事に相応の理解を持っていても、双手を挙げて渠らの革命の成功を祝するにはまた余りに多く渠らの陰謀史や虐殺史を知り過ぎていた。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、先生の喜壽を祝すると共に、二三の思出を記すに過ぎない。",
              "citation": {
                "source": "井上先生",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「閣下、警備飛行団長から、祝電がまいりました」「ほう、祝電が」「飛行島の竣工と、無事なる試運転を祝す――というのであります」「無事なる試運転か。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁な変様をする位なら、寧ろ依然『眠れる都会』であつて呉れた方が、自分並びに『美しい追憶の都』のために祝すべきであるのだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の一代の盛典を祝するために、僕は今、僕の心からなる記念品として、「恋愛曲線」なるものを送ろうとして居る。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝すべきか、弔すべきか！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮羊君来庵、観そこなつた五人の斥候兵の話などを聞く、娘さんの出生を祝する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心の平静をとりもどした、私は日に日に刻々燈みつつある、と自信し自祝する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旗さえ見たらこの群集の意味も大概分るだろうと思って一番近いのを注意して読むと木村六之助君の凱旋を祝す連雀町有志者とあった。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "総選挙の結果は一見無産派の前途を祝するように見られる。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの雪影がやつて來て、廢刊の辭をみなに書いて呉れと云ふから、呑牛と僕とで『廢刊を祝す』と書いてやつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒はたしかに私を世間的には蹉跌せしめたが、人間的には疑ひもなく生かしてくれた、私は今やうやく酒の繋縛から解脱しつゝある、私の最後の本格が出現しつゝあるのである、呪ふべき酒ではあつたが、同時に祝すべき酒でもあつたのだ、生死の外に涅槃なく、煩悩の外に菩提はない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「書後」の筆を投ずるに臨んで敬んで君の健康を祝する。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
