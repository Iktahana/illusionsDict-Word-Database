        "examples": {
          "standard": [
            {
              "text": "組合を設立するために、メンバーから一口1万円の出資金を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倒産時には出資金が戻ってこないリスクがあることを、事前に説明された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出資金を元手に最新の設備を導入し、生産効率を劇的に向上させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『それもそのはず、これは極秘で、なにぶん出資金はひそかに集められ、表にはできないほど良いものだからで。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "インチキ会社を設立し、何百万ドルも手にしたあげく、株価に無頓着なために、出資金を横領したことになった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
