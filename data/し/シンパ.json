[
  {
    "uuid": "88e9087f-a3ae-5327-8cf6-3b25f6f6f579",
    "entry": "シンパ",
    "reading": {
      "primary": "シンパ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(Communist, union, etc.) sympathizer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文字通りの意味でのシンパシーまたミットライドとはこんなのを言うのかもしれない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いシンパとして獄中にある河上肇博士の告白にうたれた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミナサン」ト　モルモツトハ、シンパイサウニ　シテ　ヰル　ミンナノ　カホヲ　ミマハシテ　イヒマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカアサンタヌキハ　シンパイシテ、キノ　カゲヲ　カクレテ　サムラヒノ　アトヲ　ツイテ　イクノデス。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロイ　テフテフハ　シンパイサウニ、「コレカラ　ドコヘ　イクノ」ト　フウセンニ　キキマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいこの作品には、この少年工に対するシンパシーが少しも現われていない。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には同志ばかりか単なる「シンパ」さえいた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏に入って、主としてインテリ層の間に全国的に多数のシンパ嫌疑者を出したが、本会員中にも二、三の検束者が出た。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに上州の山の中の小屋で私を思い出して下さって、あの深い孤独と、澄んだ叡智とに輝いた便りを下さった時、また湖の畔の旅館からの静かな心をこめた手紙、また母上を東京に送って行かれて帰られた時の手紙など、感動と非常に親しいいきいきしたシンパシーとをもって拝見したのでした。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビユツフオンの飼つてゐたシンパンジイ種の猿は、主人の好いた或る女が来る度に厭がつて、主人の杖を持ち出して威したさうだ。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "猩々やシンパンジイの猟をしたドユ・シヤイユウは人を避けて穴居してゐるこの猿共の性質の面白いことを報告してゐる。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は平気で、なんの不思議な業でもない積りで、一疋のシンパンジイが木の枝に隠れて寝てゐるのを殺したことを話した。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に人間の子が母親の乳を含んでゐる時、シンパンジイが来てその母親を殺したと思へ。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してシンパンジイは老年になつて意地が悪くなる事もあるが、大抵気が優しくて、子供を愛してゐる。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "提督がまだ艦長でゐた時、恐ろしく敏捷な、小さいシンパンジイを連れてゐた。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時ディスクジョッキーとしてロックのレコードを回し、急進的な政治グループのシンパとなり、超越瞑想に入れ込んだケイパーは、社会が急速に熱を冷まし、彼自身超越瞑想のトレーナーの職を失った一九七三年、コンサルタント会社にプログラマーの職を得た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "在学中から運動に飛こんで、乏しい自分なぞまでシンパにして大に勇猛果敢に活動した闘士がこの栗原とはどうしても思へなかつた。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は、その頃、すでに、共産党のシンパサイザァだったらしいのですから、ぼくや母の杞憂は、てんで茶化していたようでしたが、さすがに、一人の弟の晴衣とて心配してくれたとみえます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のハヤリ言葉を借用すれば、「シンパ」と言ふ所だらう。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門学校の英語の教師で、地位こそ低いが、相当世間の注意も惹いてる評論家だし、一時はプロレタリア運動にもシンパの地位に立っていたし、其後、文化史の研究に精進してる、そのあなたがですよ。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間共存のシンパシィと、先人の遺産ならびに同時代者の寄与とに対する敬意と感謝の心とをもって書物は読まるべきである。",
              "citation": {
                "source": "学生と読書",
                "author": "――いかに書を読むべきか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの、今西巻子は、共産党員でもシンパでもありません。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まだシンパというところだったが、三月下旬京見物に托して大阪へ出て、伏見挙兵計画の背後に参画してからは、もう単なるシンパではなかった。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、此方で働く気でも、さうでなくても失業地獄の当世に、子持の上に、シンパ嫌疑で首と云ふケチの付いた男だもの、片つぱしから、相手にもなつてくれない。",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは新聞が世間のその日その日の常識を反映したものであると共に、新聞が世間をそういう風に教育しているということでもあるが、おかげでシンパも減ったろうが、マルクス主義の野次馬も減ったのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都帝大の講師の就任が望めなくなって法政大学の教授となったが、シンパ事件で之も一時やめねばならぬようになった時、その後任のような意味で私が法政の講師になった。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ三木のシンパ事件が起きた。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
