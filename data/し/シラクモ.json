    },
    "definitions": [
      {
        "index": 1,
        "gloss": "white clouds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔甘藍の球は弾けて〕宮沢賢治甘藍の球は弾けて青ぞらに白雲の房呑屋より二人の馬丁よろめきてあらはれ出づる",
              "citation": {
                "source": "〔甘藍の球は弾けて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看痾宮沢賢治七月はさやに来れど故しらに人はなほ疾み日過ぎ来し白雲の野はさびしくも掃き浄めらる",
              "citation": {
                "source": "看痾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜解け道を踏んで白雲を見ればそれでよい。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い青空に、濃い白雲がギラギラ光つて、おもひばかりが一杯で、私には、なにが何やら分らない。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大海に島もあらなくに海原のたゆとう波に立てる白雲」という万葉の歌に現われた「大海」の水はまた爾来千年の歳月を通してこの芭蕉翁の「荒海」とつながっているとも言われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまはうすい白雲にはひり、黒い鳥が高く高く環をつくってゐます。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　硫黄猛しき現場監督の、　　　　こたびも姿あらずてふ、元山あたり白雲の、　　　　澱みて朝となりにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国土青き草山雑木山、　　　　　　はた松森と岩の鐘、ありともわかぬ襞ごとに、　　白雲よどみかゞやきぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの楊の中の白雲でくわくこうが啼いた。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早池峰の西どなりの群青の山の稜が一つ澱んだ白雲に浮き出した。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お日さまの、　お通りみちを　はき浄め、　ひかりをちらせ　あまの白雲。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この壁柱は星座に聳え、白雲に跨がり、藍水に浸つて、露と雫を鏤め、下草の葎おのづから、花、禽、鳥、虫を浮彫したる氈を敷く。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "望雲楼　東坡が望雲楼の詩に、陰晴朝暮幾回新、已向虚空付此身、出本無心帰亦好、白雲還似望雲人、といへる、さすがにをかしからぬにはあらねど、なほ下の心のあるやうにて、白雲点頭すべきや否や覚束無し。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲中の夢　上にあげたる如き白雲の中に眠りても人の夢は猶塵境に迷ひて、おろかなる事のみ見るものなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白雲の中に寐ても山をいでゝ塵のちまたに通ふ夢かな」とは我がある時の実際をよみたる吟なりき。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなとこ雲　東の方に築地をつきたる如く立つ白雲を、かなとこ雲といふよしなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東に白雲の築地の如く見えたるは眼にしたれど、猶かなとこ雲の風情といふを知らず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそれに答えず縁側の柱に凭れたまま、嵐も名残と吹き散る白雲の空をぼんやり眺めていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上には青空か白雲、時には飛行機が通る。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏光を生じるニコルのプリズムを通して白壁か白雲の面を見ると、妙なぼんやりした一抹の斑点が見える。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまはうすい白雲にはいり、黒い鳥が高く高く環をつくっています。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は清く澄んで、大空を横ぎる白雲の断片を鮮かに映している。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈なる哉この石、天の雨降んとするや、白雲油然として孔々より湧出で溪を越え峯を摩する其｜趣は、恰度窓に倚つて遙かに自然の大景を眺むると少も異らないのである。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト山地なべて吹雪のたえまより、　　はたしらくものきれまより、コバルト山地山肌の、　　　　ひらめき酸えてまた青き。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらくも頭の児一人目に着きぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にこれしらくもにはね打かはし飛ぶかりのかずさへ見ゆる秋の夜の月あな面白の景色やなど眺めくらす。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（a）自分の倅がせむしであるから・しらくも頭であるから・といって、それをわが子と白状しない父を、私はかつて見たことがございません。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらくも頭で洟垂れの畸形児みたいに手脚ばかりヒョロ長かった嬰児の時から知っている武蔵である。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その彼の姿を見ると、町の洟たらしや、しらくも頭や、悪童たちが、『やあい、ぼんやり飴屋』『唖か』『唄を忘れたのか』『胸の人形が欠伸しているぞ』　と、ぞろぞろ尾いて来て、揶揄った。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洟たれの子、しらくも頭の子、ひかん病みの子、乳の出ぬ乳に泣く子と吠える女房などの住む茅ら屋から、この布令を知ると飛び出して、「春の跫音が聞えるぞ」　と、裏藪の竹を伐った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
