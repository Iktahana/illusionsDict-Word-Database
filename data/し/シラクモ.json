[
  {
    "uuid": "1ea842e8-36a2-5d7b-aca2-36b93748b444",
    "entry": "白雲",
    "reading": {
      "primary": "しらくも",
      "alternatives": [
        "はくうん"
      ],
      "is_heteronym": false
    },
    "grammar": {
