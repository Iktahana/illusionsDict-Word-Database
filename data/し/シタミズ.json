    "definitions": [
      {
        "index": 1,
        "gloss": "water flowing underneath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河豚汁の宿赤々と灯しけり　と、冬の街路に炉辺の燈灯を恋うる蕪村は、裏街を流れる下水を見て易水に根深流るる寒さかな　と、沁々として人生のうら寒いノスタルジアを思うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院で手術した患者の血や、解剖学教室で屍体解剖をした学生の手洗水が、下水を通して不忍池に流れ込み、そこの蓮根を肥やすのだと云うゴシップは、あれは嘘らしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣へ見にやる、菓子屋へ見にやる、下水溝の橋の下まで見たが、まさかに池とは思わないので、最後に池を見たらば……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "窒扶斯菌の寿命　北米シカゴ市ではミシガン湖から用水を取っているので市中の下水を湖水に流し込む訳に行かぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで下水｜溝渠はすべてこれをミスシッピイ河に放流してしまうようになっている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその下流なるセントルイ市で窒扶斯が蔓延し、これはシカゴの病菌が下水とともに河を下って来るためだろうというところからやかましくなり、その結果、窒扶斯菌が水中で幾日間生きているものかという問題を研究せねばならぬ事になった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで色々試験をしてみた結果だというのを聞いてみるに、普通下水溝渠のごとき汚水中では精々四日間くらいしか生きていぬが、水が清浄なほど永く生きているそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）橋下水深く流れ濶くして、遠く海上を望む風景おのづから浩大にして、大河の河口たるに負かざるの趣致あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁公は堀を埋める組、親父は下水用の土管を埋めるための深いみぞを掘る組。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の下水に落ちている犬を子供が助けてやった事実でも、自転車が衝突して両方であやまっていた実例でも適当に描かれれば有意義である。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら豊富なその力（飽くまで生き抜く力）が私たちの上に備わっていても、ただのままでは、地下何百尺の地下水のようなものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械によって井戸を掘り、はじめて地下水は私たちの役に立ちます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政の頃本所南割下水に住んで、祿高千｜石を領した大御番役、服部式部の邸へ、同じ本所林町家主惣兵衞店、傳平の請人で、中間に住込んだ、上州瓜井戸うまれの千助と云ふ、年二十二三の兄で、色の生白いのがあつた。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よこしぶき　さても、其の後、江戸で元二が身を置いた處は、本所南割下水に住んで祿千石を領した大御番役服部式部邸で、傳手を求めて同じ本所林町、家主惣兵衞店、傳平と云ふもの請人で齊く仲間に住込んで居たのであつた。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下水からは下水の水が溢れてゐる、芥箱には芥が充滿になつている。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸橋陸橋を渡つて行かう黒くうづまく下水のやうにもつれる軌道の高架をふんではるかな落日の部落へ出よう。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の上に雀も少くなり、下水の埃も少くなった。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いて、屈んで、板へ敷く半纏の裙を掻取り、膝に挟んだ下交の褄を内端に、障子腰から肩を乗出すようにして、つい目の前の、下水の溜りに目を着けた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンネルの冷い地下水を、頬に、首筋に、滴々と受けながら、おれの知つたことぢやない、とわざと大股に歩いてみた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつましき尿の香の滲み入るほとり、腐れたる酒類の澱み濁りてそこここの下水よりなやみしみたり、白粉と湯垢とのほめく闇にも青き芽の春の草かすかににほふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向方の紫山巒※闇黒の裡、僅に其所在を認む可く、其下水田を隔てゝ寒村あり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生のあらゆる事象の底にはこの目に見えぬ暗い流れが走り、それが生の行手を、前後左右を劃っていて、街の下を流れる下水の如くに、時々ほんのちょっとした隙から微かな虚しい響を聞かせるように三造には思われた。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下水の親方の隅田川に並んでいるのは糞船ばっかりだろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の事であったか、その時の事であったか、父の弟の五百枝と、末弟の林｜駒生と三人が、家の外に集まって下水の掃除をしていた姿を思い出す。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下水のそばにきたない木戸があって、それに葡萄らしいものがからんでいる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊枝は顔を赤らめて、下水を越え、田圃の畦を川べりの方へやって行った。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には負傷した人食虎を追跡して、下水溝にまで這い下りたと云う逸話が、今でも印度で話題になっているほどなんだよ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そのローリストン・ガーデンズには空き家がふたつあって、何でも大家が下水を修理しなかったもんで、片方に住んでた借り主が腸チフスで死んじまった、っていうんですよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたみずからがみずからに向って、身をもってする理解 Beurteilung は、哲学もがその一部であるところの最も広い存在の問、あるいは学に従属しなければならない。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムンクの寂寥からはじめて、表現派より、シュープレマティズム、シュール・リアリズムにいたるまで、彼らはもはや確固としたみずからの観点を失ったのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
