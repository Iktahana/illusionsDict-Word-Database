  {
    "uuid": "4c717840-d066-5174-87b5-a8260e7184b6",
    "entry": "清楽",
    "reading": {
      "primary": "しんがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Qing-era Chinese music (popularized in Japan during the early 19th century)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清楽なんぞやる奴は国賊だとなった。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "地だんだ踏んでもいま一度今年の春を呼び返し、君とともに味わったかの清楽と、花やかなしかし見識のある歓楽が味わいたい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原の清楽亭という寄席では、次郎時代の玉川勝太郎君と二人会も演った。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会では当時の帝大生たちが流行の清楽合奏などしたが、主宰者の思案もまだ二十歳代の学生だった。",
              "citation": {
                "source": "カフェー",
                "author": "勝本清一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "康有為の建てた大同学校に於てする清楽の哀歌がほそぼそとカーテンから洩れている。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓにいろいろ話すが、しんがくさっていてあっちからもこっちからも云われるという工合にしか理解しない。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が陰ってきても、頭のしんがくらくらしていた。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
