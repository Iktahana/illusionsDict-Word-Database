  {
    "uuid": "5327e51d-8ac7-59a0-956d-de01992ee09b",
    "entry": "新楽",
    "reading": {
      "primary": "しんがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "new music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新楽天主義（それは未来を支配する）の輝やかしい黎明の光がうかがはれる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、日本の新楽劇振興案。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其伝統は僧心越、杉浦琴川、幸田｜親益、宿谷空々、新楽閑叟、杉本樗園である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを読んだ時に、実朝は、誰をめどにして書かれたものとは見当もつきませんでしたが、此狂女は、博士の新楽劇や、振事を出し物にすることを許されて、舞台の上で度々成功した、音羽屋と言ふ女形がある、と聞いて居ましたから、恐らく此人にあてはめて居られるものと信じて居ました。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新楽、石家荘、井※といふやうな地名が眼にうつる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "保定の南、新楽の町はづれに鉄橋があるが、それと並んで急造の橋がかかつてゐる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やつぱり汽車は出るんでせうね」　昼間、私は、鉄道に関係のある将校から、明日新楽行の軍用列車に乗せて貰ふ許しを得てゐるからである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、新楽までは、平時なら三時間といふのだが、今日はどれくらゐかゝるか？",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜は新楽かな、定県かな」　堀内氏はひとり言のやうに呟いた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新楽まで　守備兵の一人が、切りに大声で車の上へ話しかけてゐる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、新楽はぢきでせう？",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこが新楽ですよ」　灯の見えない部落には、しかし、何かが動いてゐる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は、もう前へは出られませんね」　新楽の南端に沙河といふ河があつて、その鉄橋がまだ修復できないのである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新楽の駅に着くと、堀内氏は、荷物を一旦構内の片隅に纏めておろし、部下の一人を見張に残して、早速宿舎の探険に出掛けて行つた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀内氏は、すたすた、裏道伝ひに新楽の城門を目指して歩いて行くのである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやあ、なんべんも来てますから……」　城門をはひると、すぐに「新楽県治安維持会」といふ標札の出てゐる建物があつた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして新しく唐新楽（羯鼓楽）が起こり、高麗楽と共に左右楽部として雅楽なるものを形成した。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時からニューグランドで、ビクターの新楽長辻順治の披露茶会あり、中山晋平・辻・岡等のスピーチつまらず、お茶とサンドウィッチ腹でしょうがなく、会が済んでから、ニューグランドで、スープとローストビーフを食って座へ、雪にもめげず満員である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓにいろいろ話すが、しんがくさっていてあっちからもこっちからも云われるという工合にしか理解しない。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が陰ってきても、頭のしんがくらくらしていた。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
