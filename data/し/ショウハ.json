[
  {
    "uuid": "e3171b1c-7629-555a-a855-2c4608a6f481",
    "entry": "翔破",
    "reading": {
      "primary": "しょうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "completing a flight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして爆音勇ましくアタマ飛行場を離陸すると、無限の時空を一気に翔破しつつ、諸君の眼下に横たわる雄大、荘厳を極めた万有進化の大長流を六億年ほど逆航するのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし八十歳の老人が、ヒマラヤに登り、銀髪の老夫人がグリーンランドを翔破出来るのもまた科学の力である。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく万里を翔破します。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのぶんしょうは、ずいぶん下手だべ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑り落ちるんだから落ちましょうは大できだ。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "お忘れでしょうは、ご挨拶だった。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼントルメン大いに飲みましょうは、たいていの亜米利加人に通じる訳のものではないが、そこがバーのバーたるところで、ゼントルメン大いに飲みましょうとやるや否や、士官連がわあっと云って主人公を胴上にしたそうである。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんしょうは若実、若芽（キノメ）でなくては価値がない。",
              "citation": {
                "source": "山椒",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官　せっしょうは、こっちだ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいごんじの　おしょうは　てんかに　かくれない　がくもんの　ふかい　おしょうじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かそうさまの　さしょうは、どんな　りっぱな　てらの　じゅうしょくにも　なれる　高い　ねうちの　あるものです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくしょうは冬期によく捕れる蟹で、握りめしのようなむっくりした形をしてい、茶色で、全体が毛だらけであり、毛蟹とも呼ばれていたが、それは殆んど冒涜的にまで元井エンジに似ていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅりのすけどのにおかせられても、しょうはいは弓矢とる身の常、なにごともまわりあわせとおぼしめされてきょうまでのいしゅを水にながされ、このしろをあけわたして高野山のふもとへたちのいてくださらぬか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいしょうは、うすい金属かビニールで、できているのかもしれない。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうだよ、ロボットの衣しょうはこまかくおりたたんで、このかばんの中にいれてある。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
