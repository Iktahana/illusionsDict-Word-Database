    "definitions": [
      {
        "index": 1,
        "gloss": "phosphorescent light",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
