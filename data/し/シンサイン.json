[
  {
    "uuid": "0776441c-551c-5432-89e4-0dc62942dcc9",
    "entry": "審査員",
    "reading": {
      "primary": "しんさいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
