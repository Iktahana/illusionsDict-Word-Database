    "definitions": [
      {
        "index": 1,
        "gloss": "such and such",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例えば地殻の一部分にしかじかの圧力なり歪力なりが集積したために起ったものであるという判断である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、しかじかであるからと、爺に聞いた伝説を、先祖の遺言のように厳に言って聞かせると、村のものは哄と笑う。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久住の屋敷は番町のしかじかというところだということで、総てがいちいち符合していますから、お筆の身許に嘘はないようです。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかじかと認められぬ。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親心に上下がねえならねえで、しかじかかくかく、せがれがこれこれこうでごぜえますゆえ、依怙のご沙汰はごかんべんくだせえましと、何が何してどう依怙の沙汰だか、どうせ死ぬからにはもっと詳しくけえて直訴すりゃいいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかじかかくかくで、途方もねえことが起き上がったんだから、早くおしたくなさいましよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も申し上げたとおり、しかじかかくかくで、とてもどえれえことになったんだから、早いことお出ましくださいましよ」「騒々しいな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでしかじかかくかくといったって、何もまだ聞かねえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえたちふたりがそばにいりゃ暑くてしようがねえからとおっしゃいましたんで、辰の野郎と河岸へ降りてめえりましたら、しかじかかくかくで小町の屋形がぶくぶくとやりましたんでね、さっそく舟をつけて調べましたら、屋形の底に刀かなんかでくりぬいた穴があるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかじかかくかく、こいつとてもひとりの力じゃ手に負えねえとお思いなすったとみえてね、まずなにはともかくと、あっしのところへ飛んでおいでなすったんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "今そこまでいったら、つじ役人どもがうろうろしているんで、うまいことかまをかけて探ったら、しかじかかくかくであば敬の行くえを捜しているところだというんですよ」「捜すとはまたどうしたんだい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "はよう、犬と人形をお持ち帰りになって、しかじかかくかくと申しあげ、クロの忠義をたてておやりなせえまし――伝あにい、早く手配しな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、今すぐ南町ご番所へ自訴にいって、しかじかかくかくでござりますと正直に申し立てろ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかじか斯々でごぜえますからと早く言えばいいものを、お殿様程の分った御前を、怕いの恐ろしいのと思い違えて逃げ帰ったのがこんな騒ぎのもととなったんでごぜえます」「不埓者めがッ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早う飛んで帰って腰本治右にしかじかかくかくとあることないこと搗きまぜて申し伝えい。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊り合わせたその宿の若い内儀が夕方近くから俄かに行方知れずになったとやらで、それがよくよく人相など聞いて見ますると、崖ぶちから身を投げたあの女にそっくりそのままで厶りましたのでな、それならばしかじか斯々じゃと言う出家の話から騒ぎが大きくなってすぐに人が飛ぶ、谷底から死骸が運ばれて来る。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかじかかくかくであったと、そなたから正直にお打ちあけなさらば、かえって夫婦仲がむつまじゅうなりましょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜の二更、大雨の最中に、しかじかの処を廻って居りますと、忽ちに一つの怪物が北の方角から参りました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "久住の屋敷は番町のしかじかというところだということで、総てがいちいち符号していますから、お筆の身許に嘘はないようです。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、一金五萬兩也、右借用候事しかじかといふやうな一本建の數値だけがあつてそのうちの數字が虫に喰はれてゐるのでは、探しやうがないが、もしそれが加減乘除の運算書であれば、その一部が虫に喰はれてゐても、前後の關係から推理によつて正確に判別することができる。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、一金五万円也、右借用候事しかじかというような一本建の数値だけがあってそのうちの数字が虫に喰われているのでは、探しようがないが、もしそれが加減乗除の運算書であれば、その一部が虫に喰われていても、前後の関係から推理によって正確に判別することができる。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この期会にめぐまされ候こと、まことに嬉ばしき限りにて』しかじかといった調子で、終りに彼女は母にむかって、訪問をお許し願いたいと申出ていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのさまざまの声々の底には、女というものはしかじか、女の幸福はしかじか、という定型へのものわかりよさ、困難をさけようとするときのおのずからなるものわかりよさが、作用しているのである。",
              "citation": {
                "source": "ものわかりよさ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、理論家にとっては一篇の作品を細心に吟味することで、プロレタリア文学として次の発展段階へ、しかじかにありたい、という要望をひき出すことが可能である。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝記というものも、こういう歴史そのものの本質に立つ以上、ある人の身の上にただこれこれしかじかの事件が起った、よくそれに耐え、それを凌いだ、云々という訓話的記述であってはつまらない。",
              "citation": {
                "source": "なぜ、それはそうであったか",
                "author": "――歴史・伝記について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あいつはいろんなことを探りに、故意とこっそりやって来たんだとか、作者はしかじかの人間で、これこれの外套を着ており、アグラフェーナ・イワーノヴナのところへ立寄ったとか、あいつは食いしんぼうだなどと、あられもないことまで言いだす。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分は何もかも会得しており、一切は明白であると思いこんでしまって、『つまり、事の起こりはしかじかであった、しかも、その張本人はこれこれの人種と解すべきである！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
