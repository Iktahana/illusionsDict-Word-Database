[
  {
    "uuid": "f343291a-4b15-52ca-a738-acdc4ce31807",
    "entry": "信用",
    "reading": {
      "primary": "しんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "confidence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は彼を信用したわけではないが、といつて彼を悪い奴だといふのではない。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用しないのに何もかも彼の云ひなりに返事をしたといふのも変なものだが、尤もあんなに三田村が感激してゐる時には……どうも困る。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（此処らをもつと厳密な言葉で書くに書けないこともないが、私は読者の頭を信用したいし、徒らに侃々にもなりたくない）。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその支那人を信用し切つた母の「お前よく言つて呉れたね、そんな時はこれからでも一寸わたしまで言つてお呉れよ」といふ声が聞えた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは、私もおとなしくしてゐるから、故郷の家でも、少しづつ私を信用して來た樣子で、うれしくてなりません。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、賣藥の效能書を、實に信用する愚かな性質を持つて居ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもね、爬蟲類だからね、蛇の親類なんだからね、信用のないのも無理がねえよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今東光を、藤森成吉を、片岡鉄兵を、中条百合子を、信用しようとも、しもしなかつた私たちである。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも何かの錯覚であるかどうか信用の出来る資料がないから不明である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどこまでも信用の出来る案内者はあり得べからざるものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ公然と表立ってそれを指摘し攻撃する人がないとしても、それを審査し及第させた学者達は学界の環視の中に学者としての信用を失墜してしまわねばならないし、その学者の属する学団全体の信用をも害しない訳には行かない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについては世界中の信用のある学者の最大多数が裏書をしている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ユダヤ人はその職業上の環境や民族の過去のために、人から信用されるという経験に乏しい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族的反感からは信用したくない人でも、論理の前には屈伏しなければならない事を知っているから。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の会話の断片を基にしたジャーナリストの評論や、またそれの下手な受売りにどれだけの信用が措けるかは疑問である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木田久老の『信濃漫録』の中にも龍麿の説を信用しないようなことを書いております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また旧い記録例えば記紀のごときものの記事にあるような語源説が信用出来ないという事は既に学者の明白に認めているところである。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者の側からも信頼されると同時に政府側の有力者、また貴族の間に信用が厚かったからである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその前に一枚のルーブリの形をした信用状が彼のかくしに這入っていたのであったと記憶する。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはそこまでに学者の腕前に対する信用が高められないためかもしれない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ一マイルの手紙　米国のある水兵が電信用の紐紙に細々と書いた手紙をその友に送った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "財界｜平衡則に反した信用のインフレーションは英蘭銀行の利下げとともにその崩落の道をたどった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄の云うことは何事でも信用する藤二だった。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中の実在と眼前の実在とが矛盾するのを発見する瞬間に自分の頭に対する信用が一度に消滅するのである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥瞰図式の粗雑なものはあったが、図がはなはだしく歪められているので正確な距離や方角の見当がつかないし、またどのくらい信用出来るかも不明である。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみよの兄という人が下町のある大店に勤めていて、その兄の方から月々の仕送りを受けているのだと母のおちかは吹聴していたが、その兄らしい人が曾て出入りをしたこともないので、近所ではそれを信用しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあへずその椿を掘り倒してみたが、その結果はいたづらに賣卜者の信用を墜すにすぎなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋのをぢさんは半七を信用して萬事を頼むと云つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりものじゃ、ゆうて、おまえを、しんようしていても、そうそう、おとこさんのなまえがちごうては、わしもくるしいけに、さっち五円おくってくれとあったが、ばばさがしんで、そうれんもだされんのを、しってであろう。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの兄弟は、ワタシをしんようしてないみたいです。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
