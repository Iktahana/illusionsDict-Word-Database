  {
    "uuid": "47448cbb-90e8-54e2-9029-49820cda6cf4",
    "entry": "社命",
    "reading": {
      "primary": "しゃめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
