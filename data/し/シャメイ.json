          "literary": [
            {
              "text": "列車は第三十三列車名古屋行、普通車で東京駅を出たのが午前十一時三十五分だった。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車名、発車時刻、そして到着時刻などを、優子は手帳に写した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
