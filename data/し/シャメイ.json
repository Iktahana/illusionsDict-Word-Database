    },
    "definitions": [
      {
        "index": 1,
        "gloss": "company name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まず試みに各社名宝のスターの「横顔の音」でも聞かせたらどうであろう。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表者となったボブ・スタインは、妻だったアリーン・スタインとボイジャー・プレスを作った人物で、ここから引き継いだ社名は、ＮＡＳＡの惑星探査機から取ったそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、同社名誉会長の井深大クンから挙手がありました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社名のＳＵＮは、Stanford University Network から取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし袖印だけは届け出での社名を用いることになっていて、わたしもカーキー服の左の腕に東京通信社と紅く縫った帛を巻いていました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "社名は兄キの意見通り保文社とかかえる方がよかろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二四年、ＣＴＲは社名をＩＢＭ（インターナショナル・ビジネス・マシンズ）に変更した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西が稲盛と出会う直前、のちにエプソンと社名を変更する信州精器は、ＨＣ―20と名付けた超小型のパーソナルコンピューターを発表していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二（昭和五十七）年の暮れぎりぎりまでマイクロソフトで作業を続けた山下は、十二月三十一日にシアトル空港発の飛行機に乗り、成田に降り立った翌年の一月一日付けで、社名をアスキーに変更したばかりの西の会社に入った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社名のロータスは仏の座る蓮華座から、１―２―３という製品名は、第一ステップの表計算で処理したデータを第二ステップでグラフ化し、第三ステップにデータベースの機能を用意するとの意味を込めて付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権の表示には、マイクロソフトと日本電気の両社名を併記する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の名前のどちらを先にして社名とするかは、コインを投げて決めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "囲碁の「当たり」から社名を取った同社の創設者ノーラン・ブッシュネルは、スティーブン・ジョブズの生まれる一一年前、一九四三年にユタ州に生まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新会社の社名として、西はアスキーマイクロソフトを予定しているという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社名はマイクロソフトに引っかけて、日本マイクロハードを名乗った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｗｉｎｄｏｗｓの搭載をあきらめざるをえなくなった中で、表計算のマルチプランとともにあらたに開発して標準添付されることになった日本語ワードプロセッサーは、アスキーの陰に隠れた真の開発者、ジャストシステムの社名からＪＳ―ＷＯＲＤと名付けられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし八ビットのホビイマシンだけは、新日本電気から社名を変更していた日本電気ホームエレクトロニクスに担当させる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷の追分で降りて、ブリキの塀をくねくね曲ると、緑のペンキの脱落した、おそろしく頭でっかちな三階建の下宿屋の軒に、螢程の小さい字で社名が出ていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷の追分で降りて、ブリキの塀をくねくね曲ると、緑のペンキの脱落た、おそろしく頭でっかちな三階建の下宿屋の軒に、蛍程な社名が出ていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又竜動に居るとき、或る社中の人が社名を以て議院に建言したと云うて、その草稿を日本使節に送て来た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その工場で出来る時計は頗る精巧な物で、いわゆる舶来品に劣らぬものであるが、その製造品には社名が記し付けてない。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝部は二階の広い部屋で、その出口の横に新聞記者控室があり、壁に各社名を書き込んだ札が並んでゐる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに延喜式に社名を石城とある以上、この遺蹟が後世のものでない事は明らかである。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭神は倉稲魂神となっているが、之は式内社の伊波神社に詣ずる人が多くなるに連れて、祭神もいつしか倉稲魂神となり、イチハノ神は忘られ、唯社名に存するのみとなったものではあるまいか。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や第一号を発するに臨み、先づ吾儕社名の義を取る所の自由の説を述べて以て端を啓くといふ。",
              "citation": {
                "source": "『東洋自由新聞』第一号社説",
                "author": "中江兆民",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに妾といわれるのが嫌で、月々届けられる「夕陽新聞」の社名の入ったハトロン紙の封筒の表には「酒月秘書殿」と書いて貰うことにしてあるというが、そんな細かい詮策はこの際大して必要はあるまい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのあと、その広告のちかくに掲げられた告知……小松島保安部、小松島巡査派出所、及び、関西汽船株式会社名による乗客への注意書は、もッと、太だ、われ／＼をよろこばした。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってみると、金は来ていないで、社名での親展書が伸子あてに着いていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
