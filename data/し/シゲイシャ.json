    "definitions": [
      {
        "index": 1,
        "gloss": "court ladies' residence (in the inner Heian Palace)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
