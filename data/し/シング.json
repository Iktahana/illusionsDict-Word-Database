    "definitions": [
      {
        "index": 1,
        "gloss": "bedding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は寝具だけは身分不相応のものを作っていて、羽根蒲団など、自分で鳥屋から羽根を買って来て器用に拵えていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台にも、寝具にも、その附近すべてに、支那人の変な匂いがしみこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中央の一つだけがまだ寝具をたたんだままで、アトは四人の人間が皆、頭から布団を引冠ってスースーと眠っている様子である。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は寝具だけは身分不相応のものを作っていて、羽根｜蒲団など、自分で鳥屋から羽根を買って来て器用に拵えていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小汚い寝具とぼろ着物が二三枚片隅によせかけてあつて、其外になんにもない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠だか、蜘蛛だか、奴は、それなり、その角の片側の寝具部屋へ、ごそりとも言わず消えたげにござりますがな。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、火鉢の火や茶道具を運んで来た小女中が、寝惚け眼で寝具を二つ並べて敷いて去ったあと、葛岡は、自分の分の布団をぐいと片側に寄せ、わたくしの分の布団との間に畳の空地を慥えました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋で一室に臥るときは、二人のバンドを繋ぎ合して寝具の間の距てにした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔はほとんど寝具で覆われ、眠り込んでいるように見えた。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の入ったのには寝具などはなにもなかった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "また寝台や寝具はお探りになったでしょうね。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台はただ一個あるだけで、その寝具は取りのけられ、床の中央に投げだされていた。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄の小さな金庫が寝具（寝台ではなく）の下に発見された。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰を受けるようなことをしたと悟って、自分のやった凶行を隠そうと思ったらしく、ひどくそわそわして部屋じゅうをとびまわり、そのたびに家具をひっくり返したりこわしたりし、また寝台から寝具をひきずり落したりした。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから瞬一つせずに、頭をソロソロと左右に傾けて、白いずくめの寝具と、解かし流されたまま、枕の左右に乱れかかっている自分の髪毛を見た。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は自分で雨戸をくり、自分で寝具を片づけ、ぼんやり障子の蔭に坐して庭を眺めていた。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙にさえて落ち付き払ったひとみを静かに働かして、部屋の中を静かに見回していたが、やがて夢遊病者のように立ち上がって、戸棚の中から倉地の寝具を引き出して来て、それを部屋のまん中に敷いた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小谷さんは夜が明け放れると、また電灯のスイッチをパチンと閉め、私の寝具をきちんと正し、便器を清め、床を拭き、やがてくまなく調うた床で私に食事させ、さらにあと片づけするまで一刻も小止みなく、見る眼にも感に堪えるほどこまめに働いた。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この朝は幾分遅れて出勤したのであつたが、例に依つてＡ子の部屋を視守つてゐたが（寝台の様子で見ると、一刻前に起き出て、取り散らかつたまゝの様子だつたから、直ぐに現はれるであらう――何時も彼女は自分で寝具を取り片づけるのが常である故。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は弥勒に出かけて、人夫を頼んで、書籍寝具などを運んで来た。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳間に寝具が三つ、二人は何れへ寝たものかと立つてゐると、源助は中央の床へ潜り込んで了つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚だけ残して雨戸も閉め、散乱つた物を丁寧に片寄せて、寝具も布き、蚊帳も吊つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰一人として寝具をもっているものはなかった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮浪者が一夜をあかしたベンチが、彼の寝具の古新聞とともに私を待っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ヵ月の間に病院の料理場と洗濯場とは改良され、本国からの積送品を整理するための政府の倉庫ができ、病兵の寝具類は煮沸器で消毒されるようになった。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけていると、寝具や、床の上までもその不快な血痕が、点々として附着しているのを発見した。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々の庵室に寝泊りするにしろ、それに必要な寝具、机、食事などは、小松屋が一手で賄った。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスチナ・ロゼチの『しんぐ・さんぐ』を讀んで、こんなのを作つてみたらと思つて試みたものです。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
