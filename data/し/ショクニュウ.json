      {
        "index": 1,
        "gloss": "eating into (esp. insects and larvae eating into fruit, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
