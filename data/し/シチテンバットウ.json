[
  {
    "uuid": "8b5dc9b9-3e81-55e4-98bf-158664475e84",
    "entry": "七転八倒",
    "reading": {
      "primary": "しちてんばっとう",
      "alternatives": [
        "しってんばっとう"
      ],
