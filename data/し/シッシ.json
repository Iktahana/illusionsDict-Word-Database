    },
    "definitions": [
      {
        "index": 1,
        "gloss": "jealousy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何ぞや、曰く、世界の驚嘆と嫉視の焦点に於ける外交時期の一｜転舵なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸侯の敬遠と御用学者の嫉視と政治家連の排斥とが、孔子を待ち受けていたもののすべてである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羨望、嫉視、自己の前途への不安、酸つぱい葡萄式の哀しい矜恃、要するに之等の凡てを一緒にした漠然たる胸騷ぎ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、自分も、世間が――喝采し、憎悪し、嫉視し、阿諛する世間が、欲しいのだろうか。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四、役人は、互に嫉視反目するな。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長、秀吉、家康　戦国の群雄が素懐とした上洛の理想は、尾張に崛起した織田信長によつて遂げられたが、かうして、一躍新武家時代の寵児となつた信長は、上洛の栄誉を獲ると同時に、天下諸大名の嫉視の的となつたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから封建の世だけに、藩と藩との間の対立嫉視もある。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺から、日本は世界史の舞台に登場したわけで、ロンドン及びワシントンの軍縮会議などは、日本の涯りなき発展に対する欧米列強の嫉視的工作であると云つてもいゝと思ふ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（劇場の徒の多く相嫉視するを諷するにや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな趣きの無い原っぱに、日本全国から、ぞろぞろ人が押し寄せ、汗だくで押し合いへし合い、一寸の土地を争って一喜一憂し、互に嫉視、反目して、雌は雄を呼び、雄は、ただ半狂乱で歩きまわる。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女同志の批判は決して甘くないばかりか、場合によつては嫉視的なトゲをさへ加へてゐることがあるので、結局女なるが故にといふ甘い点をつけるものは、男許りであるといふことに到達する。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性は屡※練絹の外衣の下に襤褸の肉衣を着る）、本能の如き嬌態、女性間の嫉視反目（姑と嫁、妻と小姑の関係はいうまでもあるまい。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日、世界列強が日本を嫉視している時代となっては、正しくその真相を捉え根底ある計画の下に国防の大方針を確立せねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この決心処置は迅速果敢しかも適切敏捷に行なわれナポレオンを嫉視ないし軽視していた諸将を心より敬服せしめるに至った。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は此篇を藐視する消極の言ではなくて、此篇を嫉視する積極の言である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし若し考証の煩を厭ふならば、其人はこれを藐視して已むべきで、これを嫉視するに至るべきでは無い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "云はゞ常に相嫉視して居るのであります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこういう場所を占有したなら、周囲から集る羨望嫉視の鎮る時機がないのである。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず隙間を狙う兇器の群れや、嫉視中傷の起す焔は何を謀むか知れたものでもない。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして平和主義的な文明諸国から嫉視された通り、その武力の過度な膨脹は果して世界の危険を馴致してこの度の大戦争となりました。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両階級が対立して存在する限り、いずれかの一方が代って支配者の地位に就くことを要求し、特権を占有する者と第二次的人格者として隷属する者との嫉視争闘の断える機会は永久に来ないでしょう。",
              "citation": {
                "source": "階級闘争の彼方へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三の小娘があるときは朝早くから、またある期間は夜ばかり、毎日石造りの陰鬱な大きな部屋に通って、慣れない交換台に向かって、加入者の罵声を浴び、仲間からは粗末な服装を嘲笑され、両親から譲られた唯一のものである美貌を嫉視されて、白眼と冷眼のうちに自己を開拓していった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "交換局では同性ばかりの集まりからくる嫉視・反目・排擠、徹底した意地悪さ、それに冷たい監督、それが全部だった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉視、迫害、批難攻撃は二人の身辺を取りまいた。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を著くる所独早くして時運は未だ到らず、常に保守姑息の徒の多数を頼みて嫉視妨害するあり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしなぞは、まだ足下にも及ばぬ」　長崎屋の表情に、あらわに嫉視のようなものがうかぶのを、雪之丞は見のがさなかった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしはあの頃の少年の、毛程もまじり気のないあどけなさを思い出すと、その真珠を泥で汚し、清水に濁りを注ぎ込んだそこ許のことを憎まずにはいられないのだ」　と、片里をジロリと嫉視しました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そんな調子です」「それから奇抜なのは、そういう恋愛を得た時、この男のインスピレーションは高められて、しっしと、引受けた店頭建築の意匠を捗らせて見事な仕事をするのですが、出来上った店頭装飾建築には、一々そのときの恋人の名前をつけるんです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあやあ、しっしっ、吹くやら、払いますやら、静として赤蜻蛉が動かねえとなると、はい、時代違いで、何の気もねえ若い徒も、さてこの働きに掛ってみれば、記念碑糸塚の因縁さ、よく聞いて知ってるもんだで。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっしっし、やっしっし、それ筏は着くぞ。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
