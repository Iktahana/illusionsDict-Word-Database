      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "small country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小国の学者になるものではないという気がしたのはあの時であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしのやうな小国の王の杯は受けぬと言ふのか、恩知らず奴ツ」彼はこう叫ぶやいなや、その大杯を丈の高い蘭人の額にハツシとぶつけた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際外交上では極地の果に等しい小国にいながら、目を世界の形勢に放って、いつも豊富な意見を蓄えていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂によるとちかごろ彼女は欧羅巴の小国のプランセスの位置を狙つてゐるさうだ。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小国民の教育をなさっている人が、これでは、いけないと思いました。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）◎予を北門に世話してくれたのは、同社の硬派記者｜小国露堂といふ予と同県の人、今は釧路新聞の編輯長をしてゐる。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其新聞には野口雨情君も行くのだと小国君が言ふ。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく命なりと云うにしても、「一小国に限定されない・一時代に限られない・天下万代の木鐸」としての使命に目覚めかけて来た・かなり積極的な命なりである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、尋常科三四年頃、小国民とか、少年園とかいう雑誌があった。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、家康は、自分は小国で小勢を使い習っているから、大勢は使えないし、心を知らぬ人を下知するのも気苦労だから、自勢だけで沢山だと云った。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に取るに足りないような小国でありますが、しかしこの国について多くの面白い話があります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、単に経済上より観察を下しまして、この小国のけっして侮るべからざる国であることがわかります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "大国の軍、国王の失せたもう事に驚きて戦う事なくして小国に順いぬ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてかの舅氏国の王失せにければ、大国、小国、臣下等この王を忍びて迎え取りて、二箇国の王としてあり、細かには『六波羅蜜経』にぞ申しためると。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家が今あるがままの状態で、民衆の生活を整理して行くためには、家族が小国家の状態で強国に維持されることを極めて便利とする。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んとかなるまいかと言ふ身の振り方の相談であつたが、私の新聞社にも席がないし、北門新聞社に校正係が欲しいと聞いたから、幸ひに君と同県人の佐々木鉄窓氏と小国露堂氏がゐる、私が紹介をするから、この二人に頼むのが一番近道であることを話した。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "北門新聞の校正　啄木は佐々木氏か小国氏か二人を訪ねて北門新聞社へ行つた。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三日程経つと小国氏から、啄木の家族三人が突然札幌へ来て小使部屋に同居してゐるが、新聞社だから女や子供がゐては狭くて困る、東十六条に家を借りて夕方越すから今夜自分も行くが一緒に来て呉れと言ふ電話があつた。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに小国氏は五合位はいつた酒瓶を下げてやつて来た、私は啄木の越し祝ひの心で豚肉を三十銭ばかり買つて持つて行つた。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "籔の中の細い道をあつちへ曲りこつちへ曲り小国氏の案内で漸く啄木の所へ着いた。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人はどうして恁うせせこましい、万事に抜目のない様な、悧巧さうな、小国民らしい顔をしてるだらうと、トンダ不平を起して再び目を窓外に転じた。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六節　第二次欧州大戦　第二次欧州大戦では、ドイツのいわゆる電撃作戦がポーランド、ノールウェ―のような弱小国に対し迅速に決戦戦争を強行し得たことは、もちろん異とするに足りません。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次欧州大戦で新興ナチス・ドイツはポーランド、オランダ、ユーゴー、ギリシャ等の弱小国家のみならず、フランスに対しても極めて強力に決戦戦争を強制した。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる時、如何なる所に於ても、両交戦国の戦争力に甚だしい懸隔があるときは持久戦争とはならないのは、もちろんであり、第二次欧州大戦に於けるドイツと弱小国家との間の如き、これである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来二十数年、第二次欧州大戦に於ける戦車の数と質の大進歩は、空軍の威力と相俟って、ドイツ軍が弱小国及びフランスに果敢な決戦戦争を強制し得た原因の一つである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次欧州大戦でドイツのいわゆる電撃作戦が、ポーランドやノルウェーの弱小国に対して迅速に決戦戦争を強行し得た事はもちろん驚くに足らない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがため武力の進歩が群小国家を整理して大国家への発展となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
