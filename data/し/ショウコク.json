[
  {
    "uuid": "0e73af05-cb9d-5b6e-9238-9067cb2b1bf3",
    "entry": "小国",
    "reading": {
      "primary": "しょうこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
