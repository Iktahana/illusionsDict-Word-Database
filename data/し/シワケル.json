          "literary": [
            {
              "text": "藪をおしわける音がして、現われたのはイスラエルのお町で、もう一度呼んだが答えがなかった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷えちまうじゃないかね……」　与平はさからう水を押しわけるようにして、左右に大きく躯をゆすぶりながら、水ぎわに歩いて来た。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原ッぱを登ったり沈んだり、おしわける萱の葉に首をさされたり、棟梁の身内が近よっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々に分類して居る様々の性格の型を、一人でしわける能力のあることを言ふらしいのです。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠などからふり顧ると、必、うしろの枯れ芝山に、ひなたと陰とをくつきり照しわける、早春の日があたつて居た。",
              "citation": {
                "source": "山のことぶれ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりキューとひきつめていていやなので、殆ど元のとおりですが、左の方をすこしわけるようにしてかきつけることにしたのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども先方はまっすぐに近よって来、突然、霧を押しわけるようにして、源太の眼の前にあらわれ、その大きな舳先を源太の機械船の横腹へ突っかけた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
