    },
    "definitions": [
      {
        "index": 1,
        "gloss": "autumn sunlight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋陽が森の中へさし込んでいる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子に秋陽がさしている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の雨の名殘りの水潦が路の處々に行く人の姿々を映して居るが、空は手掌程の雲もなく美しく晴れ渡つて、透明な空氣を岩山の上の秋陽がホカ／＼と温めて居た。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の雨の名残の潦が路の処々に行く人の姿々を映して居るが、空は手掌程の雲もなく美しく晴れ渡つて、透明な空気を岩山の上の秋陽がホカ／＼と温めて居た。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、私達のは、ちょっと午後行って、鳩を撃つ位いのものですから、沙漠の強烈な秋陽に照らされて来るばかりです。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美しい山吹が秋陽に半顔を照らしながらシクシク泣いているのであるから、ちょっと形容出来がたいほど可愛らしく見えるのであった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い秋陽がしらしらと敷物の上を照らしている。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の秋陽のあおりを受けて、この部屋はほのかに明るくて、そうして静かで浄らかであり、その中で烏鷺をたたかわせる、石の音ばかりがしばらくつづいた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして町全体がパツとオレンヂ色の秋陽を浴びて浮び上つたやうに輝いてゐるのです。",
              "citation": {
                "source": "文化村を襲つた子供",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰の辺りに幾とせ消え残る万年雪が、まだらに白く秋陽に輝いていた。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに秋陽にカンカン照らされ、さらにベラベラ喋舌ったため、その酔いが加速度に進行し、ひどいものになっている彼でもあった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋陽が赤々と木立に射し渡り鳥が鳴いている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名分せえ立ちゃア、いま死んでもいいのだが、それがどうした――」　橋の下から見あげて、そう問いかえす左膳の片眼は、秋陽を受けて異様に燃えかがやいている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "微風に梳かれる秋陽は、播州の山々と、畑、小さい町とそこの樹木を金色にとかし、荷馬車は、かたり、ことりと一筋の国道の上を、目的地に向って、動いてゆく。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の気持や、今自分達二人が、透明に秋陽のさす庭で、薔薇を剪る剪らぬと云い縺れている心持。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなにか辛かったことだろう」　正造は額に皺をよせて、秋陽の下の群集をながめやった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "お米の方では、思いがけないよい機を、どうかして遁すまいと、九条安治川の渡舟小屋の側に立って、秋陽に縒れる川波をまぶしそうにしてたたずんでいた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
