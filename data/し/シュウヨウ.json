  {
    "uuid": "5dadb4d2-be3d-5eec-bd89-62e99d7538d1",
    "entry": "秋陽",
    "reading": {
      "primary": "しゅうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
