    "definitions": [
      {
        "index": 1,
        "gloss": "early winter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眩しくなった眼を室内へ移して鴨居を見ると、ここにも初冬の「森の絵」の額が薄ら寒く懸っている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は東から西へと引いたように取れると一天は石灰洞のような大口を開けて、見る見るうちに次第にひろがり、碧い初冬の冴え返った空が、冷たい鯖色をした湖水のようになって、金光ちらりと黒砂に燃え落ちる、黒砂の一線、天に向って走るところ、頂上火口の赭禿げた土は、火を翳したように眩ゆくなる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の山と幾分か軽く視て、雪中の登山服装というほどの準備もしていなかったため、幾重の衣も徹されて、腹から股にかけ、薊で撫で廻されるような疼痛を感じ初めた、唇はピリッとして、亀裂するかと惑われ、その寒さにわなわなと骨髄から震動した。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節は初冬に入っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の風が吹いて満山の木が鳴った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉へ移る少し前、初冬の風のうす寒い日に、僕等二人は連れだつて活動寫眞を見に行つた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬といっても彼らの活動は空に織るようである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初冬の時雨はもう霰となって軒をはしった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに初冬の朝なるかな。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜学校を出た時真暗らだと思われていた空は実際は初冬らしくこうこうと冴えわたって、無数の星が一面に光っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃の初冬と変らぬうすら冷い白々しい景色であった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の午後であった。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工　（枠張のまま、絹地の画を、やけに紐からげにして、薄汚れたる背広の背に負い、初冬、枯野の夕日影にて、あかあかと且つ寂しき顔。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真綿のように処々白い雲を刷いたおっとりとした青空で、やや斜な陽が、どことなく立渡る初冬の霧に包まれて、ほんのりと輝いて、光は弱いが、まともに照らされては、のぼせるほどの暖かさ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外の広場の一廓、総湯の前には、火の見の階子が、高く初冬の空を抽いて、そこに、うら枯れつつも、大樹の柳の、しっとりと静に枝垂れたのは、「火事なんかありません。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前十時、初冬の日は愈よ暖かく麗かになって、白い霜の消えて行く地面からは、遠近に軽い煙を噴いていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の雨上りの朝には、屡く此樣な光景を見るものだと思ツただけである。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "外では初冬の風が町の雑音を吹き靡けている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは初冬ながら、もはや早春が訪れでもしたような爽かさであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴の裏と大地の堅さとの間に、さりさり砂ほこりが感じられる初冬の町を歩るいて鼈四郎は自宅へ帰りかかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根は初冬に入り肥えかかっていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬に入って間もないあたたかい日で、照るともなく照る底明るい光線のためかも知れない、この一劃だけ都会の麻痺が除かれていて、しかもその冴え方は生々しくはなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいい塩梅に船もそう混まないで、引潮の岸の河底が干潟になり、それに映って日暮れ近い穏かな初冬の陽が静かに褪めかけている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもやがて杜絶えて、一筋の往還がまつたく蕭々たる初冬の象徴の様に茫漠とした田甫なかに来しかたはるかに、行く手果てなく続くのでありました。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋だか初冬の夕だかに斯んな田圃から町の方へ、黄ろい大きな前歯をむき出したお婆さんが一人白髪頭をふりさばいて黙つて歩いて行く――こんなことが凄いやうに描いてありはしませんでした？",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋より初冬にかけては、金朱のいろの錦の蓑をかけ連ねたやうに美しくなつた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとから、注意されないうちは、晩秋、初冬、厳寒、平気な顔して夏の白いシャツを黙って着ている。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日は釣瓶落しだ、お前さん、もうやがて初冬とは言い条、別して山家だ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「初冬から年末……ははは、いやに仲人染みたぜ……そち以来だそうだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊遣の煙古井戸のあたりを籠むる、友の家の縁端に罷來て、地切の強煙草を吹かす植木屋は、年久しく此の森に住めりとて、初冬にもなれば、汽車の音の轟く絶間、凩の吹きやむトタン、時雨來るをり／＼ごとに、狐狸の今も鳴くとぞいふなる。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
