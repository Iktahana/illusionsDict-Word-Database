        "examples": {
          "standard": [
            {
              "text": "私たちは、カフェでコーヒーを飲みながら、ゆっくりと喋り合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "卒業後、久しぶりに再会した二人は、昔話に花を咲かせ、夜が明けるまで喋り合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親友と長電話で、お互いの悩みを打ち明け、喋り合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "座談会のみならず、座談すること、友達と喋り合うこと、それすら、私は好まない。",
              "citation": {
                "source": "私は誰？",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少年たちは、がやがやと、そんなことをしゃべりあうのでした。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
