        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "箱のそとには黄色い琥珀の粒の眼をつけた縞馬の置物が、水粒が透けて汗をかいたやうな硝子板に鼻を擦りつけてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金魚、縞馬、花、稲妻――まるで幻想詩派の文人たちの悦びさうなシーンだね」　落ちついて水を持つて来た姪のせん子に、聞かせるといふほどの意志もなく桂子はいつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞馬は相変らず硝子箱の外側に口を触れて、琥珀の眼を円らにしてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三岸節子の装幀で、瀟洒な白と金の地に、黒い縞馬の描かれた本も見た。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子は前に同棲していた異国人から、縞馬と呼ばれていたという。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははン、それはどうも……」「じゃあ、気をつけてお出でなせえ、さようなら」　縞馬の刑事は、向こうへすたすたといってしまった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばらばらとこっちへ駆けてくるところを、貫一が透かしてみると、何のこと、さっき名乗った縞馬の刑事野郎であった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞馬みたいな刑事が煙草の火を借りに来て、この辺は物騒だから要慎するように注意して去った。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢徳寺から弥勒菩薩の金像を背負って出で来た貫一の行手に、またもや縞馬姿の刑事が立ち塞ったのには、さすがの貫一もぞっとした。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもや縞馬姿の刑事が、森蔭を出て、煙草の火を借りに来たのには愕くよりも呆れてしまった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像を背負って出て来た貫一を、やはり前四夜と同じように遠方から見咎めて駆付けて来る縞馬姿の刑事！",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は猫背に黒眼鏡の、有名な探偵袋猫々であったし、もう一人は縞馬服の例の刑事であったから。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "横筋にすると、なるほど縞馬のやうで見た目は綺麗だが、どうももちが悪い。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも昔は、阿弗利加の沙漠で、縞馬の腹を引裂いてゐたんだ。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞馬つてやつだな」　少年の眼は次の貨車に、次の貨車にとあはたゞしく移つてゆきました。",
              "citation": {
                "source": "動物列車",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞馬、これはほかのすべての縞馬の透し絵の標本だ。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、塔の窓の格子を通して射し込んでゐる朝日がジジの身體に當つてゐたので、ジジは眠つてゐる一匹のしなやかな縞馬のやうに見えた。",
              "citation": {
                "source": "羽ばたき",
                "author": "Ein Marchen",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　縞馬は突然、はね起きた。",
              "citation": {
                "source": "羽ばたき",
                "author": "Ein Marchen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライオンが縞馬を倒したあとには、必ずハイエナがわけ前にあずかるものだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の体は縞馬のようだといったら、ナオミは可笑しがって笑った。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その隣り」　今度は彼女の言葉に続いて、おそらく縞馬だろう、左から二番めのクラッカーが、見事に砕けた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりかえし　サンタさんは　シマウマで　さんぽに　でかけるので、　ババールは　それに　じてんしゃで　ごいっしょしまして。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャツもズボンも同じ染めだから、この美人はまっかなシマウマのように見えた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
