[
  {
    "uuid": "ee0a3f08-edef-5583-8fc5-208ab498292c",
    "entry": "生じる",
    "reading": {
      "primary": "しょうじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
