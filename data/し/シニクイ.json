[
  {
    "uuid": "e3052242-2682-5f96-880e-db9557c5c207",
    "entry": "し難い",
    "reading": {
      "primary": "しにくい",
      "alternatives": [
        "しがたい"
      ],
      "is_heteronym": true
    },
    "grammar": {
