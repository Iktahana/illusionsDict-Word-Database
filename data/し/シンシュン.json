        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汽車の時間が迫ったので、みんな店先で草鞋をはいたところへやっと出来て来たので、上り口に腰かけたまま慌ただしい新春を迎えたのであったが、これも考えてみるとやはり官能的の出来事であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は新春の屠蘇機嫌からいささか脱線したような気味ではあるが、昨年中頻発した天災を想うにつけても、改まる年の初めの今日の日に向後百年の将来のため災害防禦に関する一学究の痴人の夢のような無理な望みを腹一杯に述べてみるのも無用ではないであろうと思った次第である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新春の読ものだからといって、暢気らしい。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の縁先に福寿草のあの黄金色の花が開いているのを見ると、私達はなんとなく新春の気分に浸って来ます。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新春の祝賀には新しい女夫が打揃うて殿の館に參殿しようといふ次第だ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした若い女たちは新春の喜びに満ち足らったふうであった。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は心が惹かれて、新春の第一夜をここに泊まることは紫夫人を腹だたせることになるかもしれぬと思いながら、そのまま寝てしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらぬ下僕なども主人に従って六条院へ来る時には、服装も身の取りなしをも晴れがましく思うのであったから、まして年若な高官たちは妙齢の姫君が新たに加わった六条院の参座には夢中になるほど容姿を気にして来て、平年と違った光景が現出された新春であった。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "△久しく鈍つてゐた筆を馳つて新春号には諸君の意に添ふべき程のものを出さなければならないと切に思つてゐます。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速お引き受けは致したが、何しろ押し詰まってのことでその年はどうにもならず、明けて明治二十一年、新春早々から取り掛かりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日や……小春日や……伝六女にしてみてえ、とはどうでござんす……」　行くほどに、急ぐほどに、町はやぶいり、日はぽかぽかびより、――湯島のあたり突く羽子の音がのどかにさえて、江戸はまたなき新春でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか新春の日も昼をすぎて、行きついたその四ツ谷ご門あたりは飄々、颯々とめでためでたの正月風が、あわただしげに行きかわす中間小者折り助たちのすそを巻いて、御慶の声をのせながら吹き通りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか烈風吹きすさぶ新春です何卒御自愛下さい。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十五年新春増刊号）",
              "citation": {
                "source": "ヂュパンとカリング",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十四年新春増刊号）",
              "citation": {
                "source": "歴史的探偵小説の興味",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「サンデー毎日」新春特別号、昭和四年一月）",
              "citation": {
                "source": "被尾行者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これならなるほど人もするはずだと、自宅が見えなくなったころのびのびと新春の気持ちになった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、Ｎさん久しぶりに来庵、明けてからの第二の来庵者である（第一の訪問者は九日の暮羊君であつた）、焚火をかこんで閑談しばらく、それから連れ立つて近郊を散歩、おとなしく別れた（昨年の新春会合はよくなかつたが）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖戦第三年、興亜新春、万歳万々歳。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "中華人民共和国の輝やかしい一九五〇年の新春を慶賀いたします。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月も六日といえば、選挙闘争に本腰がはいって、その日の紙面もトップに田中候補が信州上田で藤村の「破戒に学ぼう」と闘っているニュースをのせ、四日には「新春いろどる新入党」と作家・芸能人の入党記事はなやかだった。",
              "citation": {
                "source": "事実にたって",
                "author": "――一月六日アカハタ「火ばな」の投書について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの新春から故グレエ子爵の『二十五年回想記』と『フアロドン雑講』を読んでゐるが、この大戦中の英名外相がその政治的活躍の背景として様々な楽しみ乃至趣味を有つてゐたのに驚く。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新春の御祝儀万々歳御目出度、兼々御揃被遊御機嫌様宜しく入らせられ大寿至極恐悦奉申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」文の首に「新春の御祝儀」と云ふより見れば、「十三日」は正月十三日である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "62新春＊　雲はチューリップの面に涙、さあ、早く盃に酒をついでのまぬか。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "120はなびらに新春の風はたのしく、草原の花の乙女の顔もたのしく、過ぎ去ったことを思うのはたのしくない。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "122新春にはチューリップの盃上げて、チューリップの乙女の酒に酔え。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "62　新春――イランには古くから一種の太陽暦が行われ、春分の日、すなわち春の彼岸が一年のはじめとなっている。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "出獄後半年たつと、昭和十三年になり、私は久振りに自分の家庭で新春を迎える喜びを有ち得たが、丁度その時、正月七日の朝のことである、青楓氏が自分のうちで書初めをしないかと誘いに来られた。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の遊びをされるのでもなく、常の新春に変わったことばかりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "まぼろし",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
