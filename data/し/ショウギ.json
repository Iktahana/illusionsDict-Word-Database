  {
    "uuid": "a65fd483-5c1d-5a43-8a7e-3b8812343e79",
    "entry": "勝義",
    "reading": {
      "primary": "しょうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
