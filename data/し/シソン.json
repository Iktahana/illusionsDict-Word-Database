[
  {
    "uuid": "7ba19fec-907e-54e2-a762-1270a095803d",
    "entry": "子孫",
    "reading": {
      "primary": "しそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "descendant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なにせ相手は槍の名人の子孫である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍の名人の子孫に対して私は極度に用心し、かじかんでしまったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の日本人は子孫のことを多少でも考えない人は少なかったようである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故意に、また漂流の結果自由意志に反してこの国土に入り込んで住みついた我々の祖先は、年々に見舞って来る颱風の体験知識を大切な遺産として子々孫々に伝え、子孫は更にこの遺産を増殖し蓄積した。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで吾々もこうして子孫に伝えるのだと云ったとある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から一万二、三千年の子孫の世には北極はとんでもない天の河のはずれを向いて、七夕の星が春見えるような事になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店の先祖がどういう訳だか店の名を付けなかったが、商売は非常に繁昌し子孫代々名無しの牛屋で通っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の諸国にあるこの種の部落的タブーは、おそらく風俗習慣を異にした外国の移住民や帰化人やを、先祖の氏神にもつ者の子孫であろう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何代か前からきっと立派な血が流れて来ていて、それが子孫に現われて来るんですね」「これは家内とも相談ですが」と貝原は再び儀式的の掛け合いのように念を押して、「小初先生。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、なんらかの方法でこの保存ができたとして、そうして数十世紀後のわれらの子孫が今のわれわれの幽霊の行列をながめるであろうということは、おもしろくもおかしくもまたおそろしくも悲しくもあり、また頼もしくも心細くもあるであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自分がそれらのビーイングの正統の子孫であると考えてみた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "態に似合わず悠然と落着済まして、聊か権高に見える処は、土地の士族の子孫らしい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼が生物の母体から子孫に伝わると考えた遺伝の元子のようなものが近代の生物学者の考える遺伝素といかによく似たものであるか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在でもニエルス・ボーアやド・ブローリーのごときは明らかにその子孫である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして当時の学界へのパッスを所有していた他のルクレチウスの子孫ヘルムホルツによって始めて明るみに出るようになった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "災難を予知したり、あるいはいつ災難が来てもいいように防備のできているような種類の人間だけが災難を生き残り、そういう「ノア」の子孫だけが繁殖すれば知恵の動物としての人間の品質はいやでもだんだん高まって行く一方であろう。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによると、この「嫌忌の遺伝」は、正当の意味での遺伝として生殖細胞のクロモソームを通して子孫に伝わるのでなくして、むしろ「教育の効果」として伝わるのかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロクソンには日本人の子孫が三千人もいたので、シロオテにとって何かと便利であった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃人間は私を大変に重宝がって、わざわざ木を腐らして私共の畑を作ってくれますから、私共はだんだん大きな立派な子孫が殖えて行くばかりです。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さん、私共のつとめは、第一に傘をひろげて種子を撒き散らして子孫を殖やすこと、その次は人間に食べられることですが、人間は何故だか私共がまだ傘を開かないうちを喜んで持って行ってしまいます。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風だと今に私共は種子を撒く事が出来ず、子孫を根絶やしにされねばなりません。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッシリアのものはわずかに極東日本にその遠い子孫を残すに過ぎないと思われていたが、同じようなものが東トルキスタンで発見されたそうである（紀元一世紀ごろのもの）。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時代に、もし地震学が現在の程度ぐらいまで進んでいたとしたらその子孫たる現在のわれわれは地震に対してもう少し安全であったであろう。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民自身も今のようなスピード時代では到底百年後の子孫の安否まで考える暇がなさそうである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この驚くべき技巧がもっともっと自由に応用され、観客が次第にそれに慣らされて、そうしてそれに固有な効果を十二分に感受することのできる日が来るとしたら、その日から人間の子孫にとっては全く新しい世界が生まれるであろう。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この性欲の根本使命は、種の保存、子孫繁栄にあるようですから、これを今さら取り立てて説明研究する必要はありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家庭を作って心身の拠りどころとし、ひいては子孫をもうけ家系を絶やさぬようにするのが世間のしきたりだからそういう声が起って来るのだと。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚するに際して持参金目当てとか、家門のため、子孫繁栄のため、生活能率増進のため、放蕩防止のために結婚しようとするのは浅はかな考えであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は子孫へ向って自分が生き継がれて行くとか、ある人は事業を以て自分の後身としたり、または人を愛したことや世話したことを以て人々の記憶の中に自分のことを残して置こうとします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平等の体から言えば、人々、同じ人間であり、同じく本能を持ち、同じく生命を養い生活を享受し子孫を遺そうとしております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
