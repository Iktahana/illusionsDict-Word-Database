        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「鼻が詰って口で息をするものだから、小児科のお医者さんに診せたのだよ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちは小児科医の話を聞いて、なるほどおまえの腕白もみなそのアデノイドがさせるわざだと決めてしまった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃った事は、婦人科、小児科、歯科もある。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児科の医者、特許弁理士、もう一つ内科呼吸器科の医者、派出婦会、姓名判断の占師、遠慮深くうしろの方から細い首を出して長唄の師匠の標柱が藍色の杵の紋をつけている。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜六時から九時まで三時間の勤務で月給六十円だから、待遇は悪くはなかつたが、その代り内科、小児科、皮膚科、産婦人科の四つも持たされ、経験のない楢雄では誤診のないのが不思議なくらゐだつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしちゃ、（私は小児科はいかんよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家は津田という小児科の医者、その隣りが舟大工、その隣りが空屋であったが、近頃其所へ越して来た母娘の人があった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "遊芸には縁のなかったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小児科医となつて相当に成功した。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そつと契月氏にお知らせする、子供の加減が悪い折には、小児科医に診て貰つた方が一番安心である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "托児所はキット一人の小児科医と数人の姆母さんと炊事掃除がかりとで構成されている。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新開地のことで、近くには小児科の医者も無かった。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は途中でミルクを買いしなこの友達にも逢って、小児科医の心あたりを聞いて見る積りであった。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆川という医学士が大学の方に居ますが、この人は小児科専門ですから」　こう主人は気の毒がって言ってくれた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "途次小児科医の家の前を通る度に、学士は車を停めて、更に注射を加えて行こうかと考えて、到頭それも試みずに本郷へ着いた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の末に、学士の勧めに随って、私はお房を大学の小児科へ入院させることにした。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児科のことで、隣の広い室には多勢子供の患者が居た。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児科の入口も堅く閉っていた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野小児科医院、そこに多賀治君が待つてゐて下さつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　庸三は小児科の先生に嗤われたが、子供をあまりいろいろな場所へ連れ行くのはどうかと、人に警告されたこともあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四　ふとした感冒から、かなり手重い肺炎を惹き起した静子が、同じ区内のある小児科の病院へ入れられてから、お増はほとんど毎日そこに詰めきっていなければならなかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく小児科も産婆も用のないとこなんだろう。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病院へ通う博士の厚意で、小児科の病室の明いたところが嫂に貸し与えられてあった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "無料で健康相談にのって貰え、事情によっては小児科病院へも入れるように計らって呉れる。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかお詫びの手紙を出そうと念じながらも、ひとりぎめの間のわるさの為に、出しそびれて、何かのきっかけをと思い、あなたの『晩年』とかいうのが出たら、そのときのことにしようと最近心にきめていましたところ、今日、本屋であなたの一文を拝見して、無しょうにかなしくなり、話しかけたくなりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をつぶって顔を抱えて……段々心がしずかになって来ると一緒にやたらむしょうにかんしゃくを起したあとの淋しさがたまらないほど迫って来る。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
