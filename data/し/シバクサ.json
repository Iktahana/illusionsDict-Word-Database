        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "線路のへりになったみぢかい芝草の中に、月長石ででも刻まれたやうな、すばらしい紫のりんだうの花が咲いてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路のへりになったみじかい芝草の中に、月長石ででも刻まれたような、すばらしい紫のりんどうの花が咲いていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉十は芝草の上に、せなかの荷物をどっかりおろして、栃と粟とのだんごを出して喰べはじめました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路のへりになつたみじかい芝草の中に、月長石ででも刻まれたやうな、すばらしい紫のりんだうの花が咲いてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の日は既に高く上つて、樹々の蔭を小さく濃く美しい芝草の上に印してゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉十は芝草の上に、せなかの荷物をどつかりおろして、栃と粟とのだんごを出して喰べはじめました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾からびた褐色のヒースと、うす黒く焦げた芝草が、白い砂洲のあいだに見えるだけでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生は飯を食はうとして、枯れた芝草の倉庫の影に、音樂の忍び居り、蟋蟀のやうに鳴くのを聽いた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になり月がのぼって、池の面が白くかぎろいはじめるころ、若者は恋人をともなって、芝草の上の露をふみながらふたたび泉のほとりにやってきた。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その玄関の燈を背に、芝草と、植込の小松の中の敷石を、三人が道なりに少し畝って伝って、石造の門にかかげた、石ぼやの門燈に、影を黒く、段を降りて砂道へ出た。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は二人の男達が近づいても、其処にぼんやり停って足下の芝草を見て居た。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝草の上に坐って大きな楽な呼吸が五ツ六ツしたかった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な芝草がよじれて引っちぎられて、飛び立つ羽虫のように飛んだ。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は芝草の上に膝を斜めに折り屈げて、器械細工のように坐った。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれ、やれ、みな疲労れたろう」　鹿を初め獲物の兎や雉などは、庭前の黄色くなりかけた芝草の上に置かれた。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　森の入口の柔らかい芝草の上に私が匍い上った時には、もうすっかり日が暮れて、大空が星だらけになっておりました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからすこし森の奥の方へ進み入りますと、芝草が無くなって、枯れ葉と、枯れ枝ばかりの平地になりました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い綿雲が邪魔扱いにされて、低い空をグングン流れて行く、一番いたぶられた月見草や芝草が、綺麗に露で化粧をして、あまやかな土から、徐々に頭をもたげかけている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の下は青毛氈を敷いたように芝草が生えていた。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝草のような草の間を流れている水の澄みきった流れが前を横ぎっていて、それには一枚石が橋のように架っていた。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手には芝草が生えてその上に植ゑた薔薇の花が月の光にほの白く見えてゐた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰をおろすに恰好な形を持つた場所に芝草が茂り、腰をおろして海に向つた頭の上には老松が程よく枝をひろげて居る。",
              "citation": {
                "source": "鴉と正覺坊",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の芝草の上に身を横へて、長い間それに読み耽つて、後にはそれを顔の上に伏せて、ぐつすり眠り込んで了つたりした。",
              "citation": {
                "source": "路傍の小草",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兎に角、一度、その断崖の犯罪現場へ行って見よう」二　殆ど一面に美しい天鵞絨の様な芝草に覆われ、処々に背の低い灌木の群を横えたその丘は、恰度木の枝に梟が止った様な形をして、海に面した断崖沿いに一段と嶮しく突出していた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程彼の言う通り、殆ど崖の縁近く凡そ六坪位いの地面が、其処許りは芝草に覆われないで、潮風に湿気を帯んだ黒っぽい砂地を現わしていた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て暫くして、靴跡が交錯しながら砂地から芝草の中へ消えているあたり迄来ると、再び二人の立会人を招いて、地上を指差しながら言った。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方大月は、考え込みながらぶらぶらと歩き続けていたが、ふと立止ると、屈み込んで、何か小さなものを芝草の間の土の中から拾い上げた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、僕は、君があの証人と何か話合っている間に、あの芝草の中から、こ奴を、このレコードの缺片を、拾い上げたんさ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
