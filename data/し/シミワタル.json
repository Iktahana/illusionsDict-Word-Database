    "definitions": [
      {
        "index": 1,
        "gloss": "to penetrate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今度は腹まで染み渡るやうな心持が、何とも云へない程好かつた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくにはよく解らないながら、川北氏の一言一句はネルチンスキイの肺腑に染み渡るとみえ、彼はいかにも恐縮した様子で、「I'm sorry.」を繰返しては頷いていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかこう節々に、結構な3660ワルプルギスの夜の楽が染み渡るようだ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に飲む酒は、いつも以上に染み渡る……しかし、そこへお前さんが、現れた。",
              "citation": {
                "source": "三重塔にて",
                "author": "福永信",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分はこの音が嗜きなので、林の奥に座して、ちょこなんとしていると、この音がここでもかしこでもする、ちょうど何かがささやくようである、そして自然の幽寂がひとしお心にしみわたる！",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてまた音と、運動と、触覚――体じゅうにしみわたるぴりぴり疼く感覚。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日はしだいに低く、水の色はだんだん納戸色になり、空気は身にしみわたるようにこい深い影を帯びてきた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五臓六腑にしみわたる朝酒のほろ酔機嫌で！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝酒はほんたうにうまい、一滴一杯が五臓六腑にしみわたるやうである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴きたてるこほろぎ、その声が身にしみわたる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――二月十六日　行程三里、島原町、坂本屋（投込五〇・中）さつそく緑平老からの来信をうけとる、その温情が身心にしみわたる、彼の心がそのまゝ私の心にぶつつかつたやうに感動する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝酒は身心にしみわたる、酔うて別れる、誠二さんはすでに出勤、書置を残して、そして周東美人を連れて！",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなにわずかな扉の隙間からでも夜風は忍びこんで、君の傷口にしみわたるだろう。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年もたたぬうちに、いかさま賽のつかいかたも覚えれば、そそり節の調子も出せ、朝酒の、腸にしみわたるような味も覚えた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまくて、つめたくて、腸にしみわたる。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴクンゴクンと喉を通って腸までしみわたる。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十七日◯昨夜から、軍神杉本五郎中佐の遺稿「大義」を読みつつあり、段々と心にしみわたる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から抱きしめている梅玉堂の体温がしみわたる。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "美の真価は、そのとき、男の目にしみわたるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋸をひいていても、空腹がしみわたるばかり、かえって、あの日以来、空腹が身にしみて仕様がない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに幼くとも、低能でも、その切なさは万人の身にしみわたる悲しさで、変りのあるものではない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "心なき身にも哀れはしられけり、鴫立沢の秋の夕暮れという大磯の歌を、よく助六師匠が西行法師をやるときにそう言っていたが、ほんとに今度のようなことにあって、こんな一人旅を続けているとつくづく秋の寂しさが身にしみわたる。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声がおれの胸ぞこへしみわたるやうだつた。",
              "citation": {
                "source": "春泥",
                "author": "『白鳳』第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮の空にしみわたる吹奏楽を競技場の方角に聞いたやうに思つたのである。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにも吹き倒されるかと思うばかりに、ミリミリと家じゅうがきしみわたる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はらの底に、しみわたるようなひびきが、船体につたわった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝のさきからしみわたる水の心地よさ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに寧楽びとが念に耐へて　汝は千年を経ぬるかなわれなづさへて柔き苔の微光に　かすかなる息吹を窺ひぬいのちなきものかはいのちなきものかはひまなくぞ雨はふりけり秋のくれ啼く鹿の声のしみわたるかな――昭和十七年秋――新薬師寺高畑の道　新薬師寺を訪れた人は、途中の高畑の道に一度は必ず心ひかれるにちがいない。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙女の恵みの露はしんしんとして指の先までもしみわたる。",
              "citation": {
                "source": "胆石",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の話す声はあらゆる神経にしみわたるようで、痺れるような、うっとりするような、快い安堵のなかに節子を浸した。",
              "citation": {
                "source": "おばな沢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
