        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がおッ母さんの素人下宿を出たのは全く木村に勧められたからです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも表向ではなく、例の素人下宿。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど素人下宿のような宿で、部屋も三つしかなかったし、内湯も無くて、すぐ隣りの大きい旅館にお湯をもらいに行くか、雨降ってるときには傘をさし、夜なら提燈かはだか蝋燭もって、したの谷川まで降りていって川原の小さい野天風呂にひたらなければならなかった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突は向う隣の素人下宿屋の台所の屋根に倒れ落ちて、その屋根をめりこましていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば一種の素人下宿のような家で、主婦は五十をすこし越えたらしい上品な人でした。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "房枝の死体をいちばん先に見つけたのは、その素人下宿の女主人だった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、本郷林町の素人下宿にいる洋画家の友人が、夏の間その海岸にいたことを思いだして、それとなしに女の噂でも聞いてみようと思って、浅草の問屋へ往っての帰りに夕飯を途ですまし、団子坂下から電車をおりてその下宿へ往った。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人下宿の二階の一室になった室の中には、洋燈の石油の泡のような匂いがあって、それがノートのページを繰るたびにそそりと動くのであった。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はそこで素人下宿をやっていて、マリーはその手助けをしていた。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "デ・ドゥローム街というのは短くて、せまいが、にぎやかな通りで、河岸からそう遠くなく、ロジェエ夫人の素人下宿からできるだけまっすぐに行って二マイルばかりの距離のところにあった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寄宿舍を出て素人下宿に居た時だ。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿といつても此家は普通の下宿ではない、ただ二階の二間を友人と共に借切つて賄をつけて貰つてるといふ所謂素人下宿の一つである。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは間もなく、小さいお二人を置いて出てこられて、或私立の女学校へ手工を教へに行つてゐられたが、後には二人をつれてお出でになつて、女生徒を預る素人下宿を開いたり、いろ／＼に迷はれた後に、たうと今のカッフェーをお出しになつたのであつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚このほかに、金のある未亡人に特に多く行われている方法で、震災後急に殖えたのは素人下宿である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいいが、今では、この素人下宿の女主人が商売人なのか、又は下宿人が商売人なのかわからぬ程度まで、お互に進化しているらしい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり素人下宿に泊って非道い眼に会った学生、又はうっかり腰弁さんを下宿さして散々な眼に会った未亡人なぞがいくらもある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが銀座だと教へられたばかり、美くしい『夜』の横顔を遠くから見たままで、私は暗い烏森の芸妓屋つづきの路次をぬけて、汚ないある街の某と云ふ素人下宿に辿りついた。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友人は、己の秘に行った自恂の行為を、いっしょに宿にいた友人が、下宿の者や、附近の者にふれ歩いたと思いだして、それから皆の顔に嘲笑が見えだし、その友人と大喧嘩をした結句、素人下宿へ往ったが、どうも素振が怪しいので、私と、も一人、その当時医科大学へ往ってた友人と二人で、見に往った。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はＳに会ったとき、朝の戸籍調べのことを話したら、全市を挙げて虱つぶしに素人下宿の調査をしているらしいから気を付けないといけないと云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、マハン・サンノム老人の経営する素人下宿に住居しているのだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "公然の營業は罷めて、牛込は神樂坂裏の、或る閑靜な所に移つて素人下宿をやるといふ事になつて、五十人近い止宿人の中、願はれて、又願つて、一緒に移つたのが八人あつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い洋風擬ひの建物の、素人下宿を営んでゐる林といふ寡婦の家に室借りをしてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "公然の営業は罷めて、牛込は神楽坂裏の、或る閑静な所に移つて素人下宿をやるといふ事になつて、五十人近い止宿人の中、願はれて、又願つて、一緒に移つたのが八人あつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は米町裏のトある寺の前の素人下宿に宿つて居るけれど、モウ二月越下宿料を一文も入れてないので、五分と顔を見てさへ居れば、直ぐそれを云ひ出す宿の主婦の面が厭で、起きて朝飯を食ふと飛び出した儘、昼飯は無論食はず、社から退けても宿へ帰らずに、夕飯にあり付きさうな家を訪ね廻る。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い洋風擬ひの建物の、素人下宿を營んでゐる林といふ寡婦の家に室借りをしてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今頃、素人下宿なんてあるものか。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親の内職に出さした素人下宿も間数が少く、まだ整ってもいなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
