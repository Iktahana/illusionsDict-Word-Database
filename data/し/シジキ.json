        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤い旗が出て上下に振れば十点、黒い円形の弾痕指示器が出て左右に振れば零点なのです。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョイと出たのは黒い指示器。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、あわれ、黒い指示器が。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれにも第三回の発射には黒い指示器が左右に振られたのであります。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "賑やかなのは一時で、然しじきもとの独り住みの静けさに戻る。",
              "citation": {
                "source": "蓮花図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしじきに慣れた。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしじきまたある家へ養子にやられた。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグレガーおじさんは　いしじきの　ゆかに　ふくろを　なげおろしました。",
              "citation": {
                "source": "ばにばにきょうだいのはなし",
                "author": "THE TALE OF THE FLOPSY BUNNIES",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ととのった　すてきな　だいどころに、　いしじきの　ゆか、　きの　はり　――　まきばで　みる　だいどころと　まったくおなじで。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
