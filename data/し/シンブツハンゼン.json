    "definitions": [
      {
        "index": 1,
        "gloss": "separation of Buddhism and Shintoism (government policy during the beginning of the Meiji period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
