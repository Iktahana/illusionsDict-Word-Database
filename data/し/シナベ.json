[
  {
    "uuid": "ec23bbfc-da93-50c0-87b5-84e63ad65d59",
    "entry": "品部",
    "reading": {
      "primary": "しなべ",
      "alternatives": [
        "ともべ"
      ],
      "is_heteronym": false
    },
    "grammar": {
