[
  {
    "uuid": "a2d6cb2d-9a2d-50a5-ae9a-8ae768e8533a",
    "entry": "屍蝋",
    "reading": {
      "primary": "しろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "adipocere (waxy substance formed by the decomposition of corpses subjected to moisture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああいま春の夜の灯かげにちかくうれしくも屍蝋のからだを嗅ぎてもてあそぶやさしいくちびるに油をぬりつけ　すべすべとした白い肢體をもてあそぶ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝やける手おくつきの砂よりけちえんの手くびは光るかがやく白きらうまちずむの屍蝋の手指くされどもらうらんと光り哀しむ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Omega の瞳死んでみたまへ、屍蝋の光る指先から、お前の靈がよろよろとして昇發する。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいま春の夜の灯かげにちかくうれしくも屍蝋のからだを嗅ぎて弄ぶ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んで見給へ、屍蝋の光る指先から、お前の至純な靈が發散する。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫斯科の十字路で硝子箱入の屍蝋と化している筈の親友であった。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犠牲者が、所々に完全な屍蝋となっている。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジメネス教授がみた女の姿は、たぶんエミリア・ヴィダリ嬢だろうし、また沼地から現われた化石｜屍蝋をみて、水棲人｜覗くと早合点したのだろう。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "確か上川島（広東省珠江の河口附近）で死んだシャヴィエル上人は、美しい屍蝋になっていたのでした。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「院長が、坐魚礁の上に失楽園の建物を建設してから、今月で恰度満三年になりますが、その間完全屍蝋の研究が秘密に行われておりました。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これが完全屍蝋の研究以外に、失楽園で過された生活の全部だったのです」　宝相華と花喰鳥の図模様で飾られた表紙を開くと、法水の眼は忽ち冒頭の一章に吸い付けられて行った。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、院長の死を発見する直前に、屍蝋室の窓下で、番匠鹿子が卒倒しているのを見付けたのでした。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、三十幾つか取り出されて、現在は屍蝋室の硝子盤の中に貯蔵されているのですがなかには膜が、相当強靭なものもあるのですよ」「なるほど」　と法水も頷いたが、「全く腹腔内の異物が、こんな所に散乱しているなんて、実に薄気味悪い話です。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜一時ごろ、あのひどい濃霧の中を、私は屍蝋室の窓下へ参りました。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、弾殻は飛去来器に伴って、再び手許に戻って来るのですが、その時の火花が、幾つかの硝子窓を通って、屍蝋室の硝子盤に映じたのです」　その瞬間杏丸に向けて、何やら含んでいそうな視線が、一斉に注がれた。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀盆や鉄板を開けるのは何んでもありません、穴の中を見ると、屍蝋と火薬がありますから、火薬だけを外へ移して、今日の正午に、両方から関係者一同に入ってもらう段取にしただけの事です。",
              "citation": {
                "source": "古銭の謎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しろうるり」などという声が耳の中で響き、すまないことだが先生の顔がそのしろうるりに似て来るような気がしたりするのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へゝゝゝ、おもしろうござります。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもモンブランの氷河を見に行った日は天気がよくておもしろうございました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世のドイツを見るような気がしておもしろうございました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の室々にはいろいろな遺物など並べてありますが、私にはゲーテの実験に使った物理器械や標本などがおもしろうございました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜僕は梅田先生の処から借りてきてから読みはじめたけれどおもしろうて止められない。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこだと聞かっしゃるな、どこでもええじゃござんせんか、徳のつれてゆく所におもしろうない所はない」と徳二郎は微笑を帯びて言った。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンが手下の騎兵を使う時でも、斯うまでの早業はむずかしろう。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一昨日、みぃぞれ降ったれば　すゞらんの実ぃ、みんな赤ぐなて、　雪の支度のしろうさぎぁ、　きいらりきいらど歯ぁみがぐ。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲と乙とは渠に向かいて慇懃に一揖して、「おかげでおもしろうございました」「どうも旦那ありがとう存じました」　弁者は得々として、「おまえさんがたも間があったら、公判を行ってごらんなさい」「こりゃ芝居よりおもしろいでございましょう」　乗客は忙々下車して、思い思いに別れぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは日頃の彼女にしてみれば非常に珍しいことで、しかもその青年はちっとも美青年でもなんでもなくて、むしろうち見たところひどく不器用な感じしかない男なのですが、そんな点がいっそ却って彼女の心をひいたのかも知れません。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんとにおもしろうございますわ！",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は高飛車に人をこなし付ける手を覚え、軽蔑して鼻であしろう手を覚えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、そんなことで筆頭などゝ認められても、格別嬉しくもないが、そも／＼私が寫眞を初めたのは、十一二の時分のことで、年｜號にすれば、明治三十五六年、流行｜物どころかしろうとに寫眞など寫せるものではないといふやうな考へのある時｜代だつた。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
