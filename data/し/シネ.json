        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死んだ宮沢は、自分が死ねば全集が出ると、果して予測してゐたであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　海賊ナポリを見てから死ね！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポリを見てから死ね！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しく君を望み見て百たび胸を焦すより死なば死ねかし感情のかくも苦しき日の暮れを鐵路の道に迷ひ來て破れむまでに嘆くかな破れむまでに嘆くかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、君といふ肉体は、一つの遺言も残さないで死ねば、それつ切りだ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ねばどうなるのか私はそれを知らない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「役者が、舞台で死ねたら　本望……」　勇ましや、恋人の言葉！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夢も感激も喪つてゐながら、而も人間は容易に死ねやしない。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は死ねばそれッきりだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順の城はほろぶともほろびずとても何事か君知るべきやあきびとの家のおきてになかりけり君死にたまふことなかれ××××××は戦ひに××××からは出でまさねかたみに人の血を流し獣の道に死ねよとは死ぬるを人のほまれとは　勝手に数行を引いたのであるが、××は筆者がした。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分が死ねば自分の過去も死ぬと同時に全世界の若葉も紅葉も、もう自分には帰って来ない。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死ねば一番いいのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも社会の進歩にマイナスの働きをなしている奴等は全部、死ねばいいのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は惡魔の傲慢さもて、われよみがへるとも園は死ね、と願つたのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にたくても死ねないようにして差し上げるって申しましたこと……おわかりになりまして？",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして死ねばよかった」　と思いつつ……。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうするとなんだナ、やはり死ぬ気で来たことは来たが昼間は死ねないで夜やったのだナ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前がたは分らないかもしれないが、男には、一生に一度、自分の力がどれほどあるものだか、それを出しきらなければ死ねないような気持が起るものだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死ねと云つても死ぬものか」と腹の中で反抗しながら、母が剥してたゝんで置いた張物を風呂敷に包むと、直ぐ店を出た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ねと云つたつて、人、誰が死ぬものか」さうお末は道々も思ひながら姉の家に着いた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが今年死ねばおまえと私の会えるのは今年限り。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥ぢて死ね」　部屋に歸つてからしつかりと考へる積りでゐながら、急性な彼れの本心は瞬時も彼れに餘裕を與へて置かなかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "潰れて死ね、富士も自分も、他のもののために潰されて死ぬのではない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、二人は一緒に死ねなかった。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に人間が死ねば、もう後は何も残らず、一切空滅に消え失せてしまうのでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ねばこんな苦艱がない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛びおりてしまへばすぐに死ねるんだと思つても、いざとなると一寸思切が出来ないでゐるうちに、汽車はどん／＼進行して行きます。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "）晃　死ね、死ね、死ね、民のために汝死ね。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等利根川の岸邊に立てば、さらさらと洋紙は水にすべり落ち、いろあかき魚のひとむれ、しねりつつ友が手に泳ぐを見たり。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしねえ」と、その傍にゐた会社員風の男が睡さうに云つた、「音羽屋のを見てからは見られませんよ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
