    "definitions": [
      {
        "index": 1,
        "gloss": "step in a Japanese entranceway",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
