  {
    "uuid": "2b865e1e-2333-54d2-ad8a-26da08ec8ee9",
    "entry": "出校",
    "reading": {
      "primary": "しゅっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going to or leaving school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出校の途次、一洵さん立ち寄る、母へお経をよんでくれる、ありがたう、望まれて近詠少々かいてあげる、いづれ何かの埋草になるのだらう。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は思ふ仔細があるから、例刻より早ャ目に出校して山嵐を待ち受けた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "所へ両隣りの机への所有主も出校したんで、赤シヤツは早々自分の席へ帰つて行つた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は思う仔細があるから、例刻より早ヤ目に出校して山嵐を待ち受けた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ両隣りの机の所有主も出校したんで、赤シャツは早々自分の席へ帰って行った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時四十分出校ということになっていた。",
              "citation": {
                "source": "若き日の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
