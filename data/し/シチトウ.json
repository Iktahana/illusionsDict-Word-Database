    "definitions": [
      {
        "index": 1,
        "gloss": "seven islands (e.g. of Izu)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "碧水金砂、晝の趣とは違つて、靈山ヶ崎の突端と小坪の濱でおしまはした遠淺は、暗黒の色を帶び、伊豆の七島も見ゆるといふ蒼海原は、さゝ濁に濁つて、果なくおつかぶさつたやうに堆い水面は、おなじ色に空に連つて居る。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧水金砂、昼の趣とは違って、霊山ヶ｜崎の突端と小坪の浜でおしまわした遠浅は、暗黒の色を帯び、伊豆の七島も見ゆるという蒼海原は、ささ濁に濁って、果なくおっかぶさったように堆い水面は、おなじ色に空に連って居る。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆七島のうち二三の島がその潮流のうへにくつきりと浮んで見えた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "江の浦は遠州灘駿河灣伊豆七島あたりへ出かくる鰹船の餌料を求めに寄るところで、小松の茂つた崎の蔭の深みには幾箇所となく大きな自然の生簀が作られ、其處に無數の鰯が飼はれて居る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "駿河灣一帶の風光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく頃日『皇大神宮参詣順路図会』を繙くと、二見浦の東｜神前の東北海中に七島あり阿波良岐島という、また毛无島とてまるで巌で草木なき島あり、合せて八島｜相聯なる、『内宮年中行事記』に、六月十五日｜贄海神事の時舟子の唄う歌の中に「阿波良岐や、島は七島と申せども、毛无かてては八島なりけり」と載す。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『続々群書類従』一に収めた、『内宮氏経日次記』には「阿婆羅気や、島は七島と申せども、毛無からには八島なりエイヤ／＼」に作る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし内宮神事の唄の意は、阿婆良気は七島よりなるといえど側なる毛無島を合算すると八島となるというらしく毛無と阿婆良気は別だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正八年三月の『飛騨史壇』、故三嶋正英の『伊豆七島風土細覧』に新島の乱塔場に新しく鶏を放ち飼った土俗を載せある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は未だ中々止まないが、序にすぐ並びの七島八島の池をも見ようと、猶北方へ歩を移した。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政七年林氏の門人籍に列し、昌平黌に講説し、十年｜榊原遠江守政令に聘せられ、天保三年故あつて林氏の籍を除かれ、弘化四年榊原氏の臣となり、嘉永三年伊豆七島全圖を著して幕府の譴責を受け、榊原氏の藩邸に幽せられ、四年｜謫せられて越後國高田に往き、戊辰の年には尚高田｜幸橋町に居つた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒潮を越えて式根の島にあり近づき難し幽明の線　十二年頃の事だらうと思ふが近江さん達と伊豆七島の幾つかを廻られたことがある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しあの中から強ひて、更に古い新島の姿を求めようならば、はちまきの裾を垂らした下緒と称する、伊豆七島のものいみ生活に通じたはちまきの固定した形である。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の為政者や、記録家の知らぬ間に、幾度か、七島の海中の波を凌いで来た、下級宗教家の業蹟が、茲に見えるのである。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて三宅島は伊豆七島の中でありまして、最も罪人の沢山まいる処であります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯今午後七時三十分、米国空軍の主力は、伊豆七島の南端、三宅島の上空を通過いたして居ります旨、同島の防空監視哨から報告がございました。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　伊豆七島の上空にあり、北上中なり、と。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、島の人で学校時代に僕より二三年先輩で、一二回会ったくらいで顔もうろ覚えになっている檜垣をたよってきたんだが、そして着くなりそのまま檜垣の家に厄介になっていたが、檜垣の家は伊豆七島｜屈指の海産物問屋で、父親がその方をやっていた。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京湾の南へ二百キロ、伊豆七島の八丈島には、海軍の八丈島航空隊、その南方、更に六百キロの小笠原諸島の父島に、大村航空隊がある」「ははア、随分海軍の航空隊って、太平洋の真中の方にあるんだなア。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちようど中世紀の歐洲人が、擧つて淨土西印度の空想をあめりかに實現した樣に、此は七島・奄美・沖繩諸島を探り得たのだ。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "石廊岬の突端で、姿を没した鰡群は駿河湾の真ん中へ出てしまうのか、それとも伊豆七島の方の太平洋へ旅するのか、仲木や松崎の方へは姿を見せないという。",
              "citation": {
                "source": "蜻蛉返り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上代から中世まで、各時代のミヤコ言葉が残っているのはすでに奈良朝時代からクゲの流人が七島へ送られた記録がハッキリしているのだから、うなずける。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丈のススキは伊豆の七島で牛の飼い葉として作っているものであるが、内地の南海岸ではそれが野生している。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは伊豆七島の三宅島などに行くと幾らでも得られます。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サクユリは、伊豆七島における八丈島の南にある小島青ヶ島の原産で、日本のユリ中、最も巨大なものである。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京付近では房州〔千葉県の南部〕、相州〔神奈川県〕、豆州〔伊豆半島と伊豆七島〕へ行けば得られる。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆七島へ差しおくる囚人が七人。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一〇段　離島の迷信　一（伊豆七島）　つぎは伊豆七島の迷信談に移る。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
