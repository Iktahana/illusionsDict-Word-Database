    "definitions": [
      {
        "index": 1,
        "gloss": "Minister of Justice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
