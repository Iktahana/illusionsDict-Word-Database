    "definitions": [
      {
        "index": 1,
        "gloss": "new breed of humans (used to refer to the younger generation, who have different ideals and sensibilities)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新人類の加入　一九七七（昭和五十二）年四月、後藤富雄がアメリカに出発する直前に入社し、マイコン販売部に配属された新人は、ある種の新人類だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺和也はこの新人類に、評価用キットとして生まれたＴＫ―80をコンピューターとして育て上げる作業を命じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "課題はすでに、土岐自身も所属する新人類のユーザーたちによって示されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人類は同時に、人間の持っている可能性をより幅広く開花させうるはずである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "調和のとれた争わない新人類たちによる社会、山岸のモットーである「われ、ひとと共に繁栄せん」という精神を体現した社会にいたる道が、見えるような気がしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした新人類に生まれ変わっていくことで、新しい世界へ一歩近づけるのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部　第三章　恐るべき新人類たちの夢想力一九八二　アルトの子供への挑戦　西和彦は、巨大で聡明で老獪な幼児だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキー関係者の証言を集めた書籍にはほかに、『アスキー　新人類企業の誕生』（那野比古著、文藝春秋、一九八八年）がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康、裕福、美貌、斬新な感覚の持ち主の新人類であり、若葉であった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミリアムがトリガーセンを見つめ、どきどきしながら興味深く思った印象は、人間性を学ぶ学生が新人類に対して抱く感情のようだった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
