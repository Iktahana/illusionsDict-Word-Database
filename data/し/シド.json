        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、眼鏡の視度を調節する輪を、無暗にクリクリと動かした。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何程視度を調節しても無駄だつた、それでも彼は熱心にそんなものを弄んだ。",
              "citation": {
                "source": "鏡地獄",
