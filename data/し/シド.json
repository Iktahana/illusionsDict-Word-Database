    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indication",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし人体に感ずる暑さは必ずしも寒暖計の示度ばかりでは分らぬ。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暑い」ということと寒暖計の示度の高いということとも、互いに関係はあるが同意義ではない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒暖計の示度によらないで冷温を言う場合にはその人によってまるでちがった判定を下す事になる。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともいわゆる、ルーティン的な仕事であって、予定の方法で、予定の機械の指示する示度を機械的に読み取って時々手帳に記入し、それ以外の現象はどんな事があっても目をふさいで見ないことにする流儀の研究ではなんの早わざもいらない、これには何も人間でなくてもロボットもしくは自記装置を使えばすむことである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはたとえば、摂氏零下二七三度から数えた温度の対数を取って、これを温度の示度とすればそれだけでもよいのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここかしこに、違った種数の松の樹が附近の樹々よりも正味四五十フィートも高く聳えているので、その中のどれがフリント船長のさした「高い木」であるかということは、その場所へ行って、羅針儀の示度で定めるより他はないのであった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田博士の言に依ると、低気圧の中心示度は七百十粍を下っているらしかった。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどうもＡには呑込めぬ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどつちかと言へばむしろ泣菫の方が好きであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを当の松岡は（これは譬噺で、事実談ではありません）レニンに呆れられているという事にも気づかず、「なんだ、レニンってのは、噂ほどにも無い男だ、我輩の眼光におされてしどろもどろではないか、意気地が無い！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も少しどぎまぎして、わるかったかな？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "困りましたね」「言いすぎかも知れないけれど、君の言葉はひどくしどろもどろの感じです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――中傷さ」「それじゃ言うが、そのしどろもどろは僕の特質だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぐい稀な特質だ」「しどろもどろの看板」「懐疑説の破綻と来るね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメルトは赭ら顔で眼をしょぼしょぼさせた何となく田舎爺のような感じのする、しかしどこかなかなか喰えないような気のする先生であったが、しかしやはり一とかどのえらい学者のように思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな言ひかたを體得して、弱いしどろもどろの人を切りまくつて快しとしてゐる人が、日本にも、ずゐぶんたくさん在る。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな愚かな藝無しどもが、もろもろの藝術の神であるとは、どうしても私には考へられないのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうも、あの爪の生えたぶざいくな手で水を掻き、海底深くもぐつて行くのは、不自然のやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、さかなども、少しどけ、若旦那が乙姫さまに逢ひに行くのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としどろもどろのごまかし方をして、「ところで、おれにその藥を少しゆづつてくれないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しどけなき、なれが頸は虹にしてちからなき、嬰児ごとき腕して絃うたあはせはやきふし、なれの踊れば、海原はなみだぐましき金にして夕陽をたたへ沖つ瀬は、いよとほく、かしこしづかにうるほへる空になん、汝の息絶ゆるとわれはながめぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうちには鈴を振るような音がよく聞こえたが、しかしどうかするとその音がまるで反対の方向から聞こえるように思われた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうも此の東京の街頭に畫架を据ゑて、往來の人を無視してゆつくり落着いて、目を細くしたり首をひねつたりする勇氣は――やつて見たら存外あるかも知れないが、考へて見ただけではどうもなささうに思はれる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "落雷はすなわち強い電気の火花だから理論上蚊帳は落雷の時の防衛になる事になりそうである、しかしどのくらいの程度まで有効かという事や、麻、木綿、絹等の比較などは専門の学者の研究を待たねば分らぬ。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしどちらか一方だけでも出来ればいくぶんか楽であろうと思われるが、この中で横揺れの方だけはよほど少なくする方法が色々発明されている。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどこへ置いたところでその幸のないものは、育った方が却って面白からぬことになるような育ち上りをしてしまうかも知れない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもジョバンニは手を大きく振ってどしどし学校の門を出て来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いきなり、カムパネルラが、思ひ切ったといふやうに、少しどもりながら、急きこんで云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ではわたくしどもは失礼いたします。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、あたしどんなとこへいくのかしら。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
