    "definitions": [
      {
        "index": 1,
        "gloss": "to wish (to do)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてヒステリーは現実よりも表現を名称を吟味したがるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縁談などの時には、たいてい自分の地位やら財産やらをほのめかしたがるものらしいが、小坂のお父さんは、そんな事は一言もおっしゃらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、同じクラスの者は大学を出てからも、仲の良いくせにつまらないところで張合って喧嘩をしたがる傾向がある。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下はフロべエルの嘆きであるが、「私はいつも眼のまへのものを拒否したがる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、人というものは懶けもので、小楽をしたがる性分である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず老爺のヴァイオリン弾きはしきりに辞去したがる。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "用もないのにむやみに外来語を使いたがる稚気と、僅ばかりの外国語の知識をやたらにふりまわしたがる衒気とが民衆にないとは決していえない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "○鉢巻をしたがる兵隊。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは文藝作品の――特に世界的な名篇傑作の撮影などと云へば、監督には勿論仕映えのある仕事だらうし、俳優達も進んで出演したがると云ふやうなこともあるからに違ひない。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を言わないで物を言うよりも多くを相手に伝えるこの西洋流のしぐさは、なんでもこくめいに言葉で言い現わしたがるドイツ人には珍しいと思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は天然の美しい舞臺裝置を見つけると、なぜか芝居をしたがるのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば硬直したがる僕の神經に對しても、また、おそらくはおなじやうな諸君の神經に對しても、いささか毒消しの意義あれかし、と取りかかつた一齣であつたが、どうやら、これは甘すぎた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬骨折って鷹に取らるるか……腕も知恵もないザマで立身出世ばっかりしたがる上役の下に付いとっちゃあ堪らんのう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の方が土間の椅子に足を伸ばして葉巻を吹かしたがるようなありさまで、話がアベコベでさ。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人、ことに知識階級の人々の中にはとかく同胞人の業績に対してその短所のみを郭大し外国人のものに対してはその長所のみを強調したがるような傾向をもつものがないとは言われない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一には、時のパースペクティヴとでもいうのか、近いほうの事がらの印象が遠い以前のそれを掩散したがる傾向がある。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概は自分はちゃんと殻を冠ったまま、相手だけの殻を破らせて、自分の勝手な愛のなかへ相手を取込めようとしたがるものなのです。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に姿を隱したがるのは、此の、私ばかりには限らぬ樣子。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この内にも、狐狸とか他の動物の仕業もあろうが、昔から言伝えの、例の逢魔が時の、九時から十一時、それに丑満つというような嫌な時刻がある、この時刻になると、何だか、人間が居る世界へ、例の別世界の連中が、時々顔を出したがる。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い男なんてやつは、すぐ女に同情したがるんでね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまに、男の方て、筆蹟をみたらいっぺんにその人がわかりますのねえ」　私はむかむかッとして来た、筆蹟くらいで、人間の値打ちがわかってたまるものか、近頃の女はなぜこんな風に、なにかと言えば教養だとか、筆蹟だとか、知性だとか、月並みな符号を使って人を批評したがるのかと、うんざりした。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとを、どんなひとをも、蔑視したがる傾向が在る。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次女は、一家中で最もたかぶり、少しの功も無いのに、それでも祖父は、何かというと此の次女に勲章を贈呈したがるのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつそり人のやうすを見ようとするものは、自分の姿をかくしたがるものであります。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は元来が安価な人間であるから、大抵の人のものを見ると、すぐ感心したがる癖があるが、此「土」に於ても全くそうであった。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に結構が大きい割に、年代が前後数年にわたる割に、周囲に平たく発達したがる話が、筋をくっきりと描いて深くなりつつ前へ進んで行かない。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
