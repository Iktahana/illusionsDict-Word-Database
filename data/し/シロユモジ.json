          "standard": [
            {
              "text": "江戸時代の風俗を描いた小説には、白湯文字の悲哀が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "資料によると、当時の吉原には白湯文字と呼ばれる女性たちがいたようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は白湯文字として生計を立てながら、ひそかに家族を支えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "緋衣、紅裙、青衣、白衣、緇衣、黄巾、青踏、赤前垂れ、白湯文字等、服粧で職業や階級を呼ぶ事多く、明治十年前後和歌山に奧縞ちう淫賣女が多かつた。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            }
          ]
        }
