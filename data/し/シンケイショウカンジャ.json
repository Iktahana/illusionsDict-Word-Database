        "examples": {
          "standard": [
            {
              "text": "彼は重度の神経症患者で、人との交流を極度に避ける傾向がありました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神経症患者への対応には、専門的な知識と深い理解が求められます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その病院は、神経症患者のための専門病棟を設けています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ある神経症患者の告白！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "正常な心と病的な心の働きについて今日では50年前よりはるかに多くの事を知っているし過去には絶望的で手に負えなかったような多くの神経症患者を環境に適応させることが可能である。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に慢性病患者で多くは神経症患者である。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
