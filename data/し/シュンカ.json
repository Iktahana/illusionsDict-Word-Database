[
  {
    "uuid": "65a0bbed-2174-52a9-aa5f-c0772cc58715",
    "entry": "春歌",
    "reading": {
      "primary": "しゅんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bawdy song",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　中尉がこうひとりごとをいうと、そのしゅんかん、夜番はまたもとの夜番になりました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、もうなん年にも、このしゅんかんのような気持をわたしは知らなかった。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一しゅんかん、次郎はふりむきざまにポケットのピストルをとりだして、ごうぜん一発うちはなした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一しゅんかん、探照灯の反射鏡のように見えた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったとたんに、ぴかりと電光が暗闇を一しゅんかんま昼のように照らした。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲劇は、次のしゅんかんにやってきた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしゅんかん、機は、ものすごい音をたてた。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、トム吉が、はっと思ったしゅんかんに、糸は指からはなれて、曲玉は、波の中に落ちて呑み込まれてしまいました。",
              "citation": {
                "source": "トム吉と宝石",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師が台所にとびこんだしゅんかん、戸はあけられ、かすかな人のけはいが外へむかってかけだしたようだった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」このしゅんかん、足がすべって、ぼちゃん！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、そのしゅんかん母親はふり向いた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいって来るしゅんかん、かれはわたしに目をすえて、それはいやな目つきでにらめた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはイタリア人ではないな」「ええ、わたしはフランス人です」　ガロフォリが部屋にはいって来たしゅんかん、二人の子どもがてんでんにかれの両わきに席をしめた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜといってこのしゅんかんドアがあいて、ヴィタリス親方がはいって来たからである。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいのりを唱えよう、こぞうさん」　このしゅんかん、七、八人のランプを持った坑夫がわたしたちの方角へかけて来て、はしご段に上がろうと骨を折っていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいじょうぶ、まに合うよ」　このしゅんかん、大きなコンプルーが声を立ててすすり泣きを始めた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはいつも人をびっくりさせることが好きだったから」　いよいよそのしゅんかんが来た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは」　このしゅんかん、女中のようなふうをした女が出て来た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では来て、お父さんにキッスをおし」　わたしはまえからこのしゅんかんのことをゆめのように考えては、きっともうそのときは幸福に胸がいっぱいになりながら、父親のうでにとびついてゆくだろうと想像していた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはこのしゅんかんをどんなに望んでいたろう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらがそっとドアを閉めたしゅんかんに、マチアがねどこの中で動いたこと、まくらの上であお向けになったことをわたしは見たように思った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがこの広い世界に独りぼっちであったじぶん、かえってわたしはこのしゅんかんほどに不幸だとは感じなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "カピがわたしを見つけたしゅんかん、かれはひもをぐいと引っ張った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよだいじなしゅんかんが来た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれはわたしがかの女の所に来て、いつも歌い慣れたナポリ小唄を歌うのを聞いて、はげしい感動を起こしたしゅんかんに、かの女がその声を回復したことがわかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍持の槍はサッと引かれて、ねらいさだめた駿河太郎のわきの下へ――と思ったしゅんかん、「待てというに」　二つの礫がどこからともなくとんで、ふたりの槍持の顔をうつと、白衣の心外道人は、竹矢来をメリメリとやぶって、仕置場の中へおどりこんだのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花と土砂と、うずをまいておそいかかると見るや、役人も小者も、囚人の泉田筑後までも一しゅんかきけすように見えなくなったのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、つぎのしゅんかん、もっとびっくりしました。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのしゅんかんに、うしろのほうで、ものすごいさけび声とどうじに、爪でガリガリひっかく音、つづいてズシーンと、からだが落ちる音が聞こえました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ニールスは、ふたりの子どもを見たしゅんかん、じぶんがどこにいるかを、すっかり忘れてしまったのでした。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
