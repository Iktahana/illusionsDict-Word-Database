          "literary": [
            {
              "text": "ただ水に入りさえすれば死ねるものと心得て入ってみたが、さてここが死にどころというのが見当らなかった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "報国の赤心をつらぬく時機に、その効果をあらわす大切な道具になると存じますので、心中ひそかに、死にどころをえた心地がいたします。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "好漢まだ三十三歳、早くもここを死にどころと見極めて、軍人訓のうちにも見えるいはゆる「生死觀」の眞諦に徹して、血と粉雪にまみれ入つた彼のすがたが眼に見えるやうである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度の大任こそ、男の死にどころ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
