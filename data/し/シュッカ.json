      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outbreak of fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隣のＴＭ教授が来て市中所々出火だという。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには水道が止まった上に、出火の箇所が多数に一時に発生して消防機関が間に合わなかったのは事実である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、此寺の門前に一軒、婆さんと十四五の娘の親子二人暮しの駄菓子屋があった、その娘が境内の物置に入るのを誰かがちらりと見た、間もなく、その物置から、出火したので、早速馳付けたけれども、それだけはとうとう焼けた。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十二月三十一日、浅草区馬道八丁目より出火して、中村座も村山座も類焼す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○二月三日、日本橋区橘町より出火し、久松座は新築後半年にして類焼す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五年（壬午）　一八八二○一月二十三日の夕刻、猿若座の興行中に出火して全焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一月二十三日、猿若座より出火して全焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月六日、千歳座より出火して全焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月二十三日、本郷の春木町より出火、春木座も類焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一月二十二日、浅草西鳥越町より出火して、鳥越座も類焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月二十八日、神田和泉町より出火して、市村座も類焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月二十三日、本郷区春木町一丁目より出火して、春木座類焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月六日、神田三崎町の改良座より出火、全焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十月五日、本所の寿座より出火して全焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは地震のあった月の二十九日で、本郷追分から出火して、谷中まで焼き、一方は小石川の水戸邸から出火して、上野湯島天神、聖堂筋違橋、向柳原、浅草茅町、南は神田から伝馬町、小舟町掘留、小網町、それから本所へ飛火して、回向院の辺、深川。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の冬不慮に出火ありて、かの家城も類火にあい、難儀の中の小屋掛けへ、道春見舞に来たられ、（中略）まずはおのおの怪我もせず立ち退かるること珍重なり、して財宝は残りしか。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し警視庁の命令によって、釜前は石造または煉瓦作りとなったので、出火の憂いは頗る減少した。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代には湯屋から出火した例が甚だ多く、大風の日には臨時休業の札をかけたそうであるが幸いにそんな事はなくなった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御見舞御礼△此度の本社出火のことは既に諸君も御存知のことでせうが、その節は多くの方々から早速お見舞をいたゞきまして厚く御礼申しあげます。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは出火の時、当選者の原稿の一部が紛失しました。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事があったら半鐘の音ぐらい聞えそうなもんだったが、出火の報鐘さえ聞かなかった。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、宵のうちからひゅうひゅうとからッ風が吹き荒れて、今晩あたり出火したら、と大びくびくのところへ、場所もあろうに鳶頭金助の家の前で、お隣が大火事だア、とばかり大声でどなったものでしたから、なんじょうあわてないでいられましょう！",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜具の上に草木の散りぼふが見えて、日うららかなるに出火あり。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六年の一月二十二日午後三時三十分に浅草の西鳥越町から出火して、鳥越座も類焼した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの三箇所の出火は、どうもこれもＳ国のスパイがやった仕事ですよう」「ナニ、Ｓ国のスパイ」　スパイは、だにのようにしつこく、この直江津の町に食いついているのだった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人が死んでから一月たたぬうちに、ある夜お蝶さんの家から出火して、お蝶さんも、赤子も、白も、みんな焼け死んでしまいました。",
              "citation": {
                "source": "狂女と犬",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦闘していた「民報」の最後に打撃を加えた出火事件の真相に対して、官憲はどんな調査をしただろう。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紛れもなく出火らしい。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
