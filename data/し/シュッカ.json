[
  {
    "uuid": "f058fb98-bdcc-504d-8f28-9e213af5bef2",
    "entry": "出火",
    "reading": {
      "primary": "しゅっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
