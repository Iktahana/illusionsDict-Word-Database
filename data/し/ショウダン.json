[
  {
    "uuid": "0e631c38-a924-5329-9b3c-f619495e201f",
    "entry": "商談",
    "reading": {
      "primary": "しょうだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "business discussion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "反｜蒋介石派の激化と、東支鉄にからんだ露支間の葛藤、南京政府の幣制の改革にたいする商人の思惑は、対支商談におけるワシントン政府の経済政策が、帝国主義戦争の一つの徴として、ワシントン当局者のからくりによって時局が平穏のうちに解決されると、南京政府は中央銀行を設け、上海造幣｜厰を開いた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "北浜界隈も、支那財界の大混乱のために、対支商談は不況のどん底に陥ってしまった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "商談が大切だと、辛抱して調子を合わせていたものの。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この風呂敷の問屋は、芸者に関係者はなかったが、商談などの座敷に呼ばれ、お神が出入りの芝居者から押しつけられる大量の切符を、よく捌いてくれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから宿の者に、お酒を言いつけて、やあ、この部屋は汚いなあ、君はよくこんな部屋で生活が出来るね、まあ我慢しよう、ここでその大将とお酒を飲みながら、ゆっくり話合ってみようじゃないか、商談には饗応がつきものだ。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先生と大将との間に頗る珍妙な商談がはじまった。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「商談、お待ち合わせにお利用下さい」　という女文字の貼紙の下で、あたかも誰かを待ち合わせているかの如き顔をしているのだが、むろん誰を待ち合わせているのでもない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し日歩は十銭がぎりぎりだ、というような商談だけがしるされてありました。",
              "citation": {
                "source": "旅役者の妻より",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉大夫ニもくハ敷御申｜被成候得バ、此拙蔵ハ何でも出来ることだけハ御｜定約仕候間、御国の御為にも、よ程相成、私の国ニもつがふよろしく商談相立可申候と存候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月二十八日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "洒落と、戯談と、哄笑とで、商談をすすめて行く。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "商談は、またこの次の機会ということに願います」　そういって、博士は、重力打消器が入っているトランクを軽々と肩にのせて、歩きだした。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縁談などゝいうものはマトモすぎるからヤヽコシクて、これがあなた、当世のヤミ商談なら、公定千円の紙、ヤミに流して二千五百円、これを百レン買って二十五万円、これを一万何千部かの本にして一冊七十円、七カケで売ってザッと七十万、諸がゝりをひいて、二十万はもうかる。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに於て商談は中止に及んで、もつぱら飲みませう。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "首くゝりも最上先生の商談のうちでせうから、すでに拙者はとめないです。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、奥の茶の間で会社の饗応がある、ブローカーの商談がある、一組小は一万円から大は三万五万ぐらゐ遠慮なくチョウダイする。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウヰスキー一ビン四千円で飲ませるから闇会社の十人ちかい商談になると忽ち五万円ぐらゐになる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治は政策が主要なもので風格など問題ではないのだけれども、日本では政治といふと人心シューラン術のやうなもので、敵と妥協し、商談して、まとめあげる手腕などが政治だと思ひ、政策、政策の実行、その信念、それを二の次にしてゐる。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」長造は、言おうか言うまいかと、鳥渡考えたのち「こう世間が不景気で萎びちゃっちゃあ、何もかもお終いだナ」「また、いい日が廻ってきますよ、あなた」お妻は、夫の商談がうまく行かなかったらしいのを察して、慰め顔に云った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方からの買出し人が来ると、商談を纏め、大きい木の箱に詰めて、秋葉原駅、汐留駅、飯田町駅、浅草駅などへそれぞれ送って貨車に積み、広く日本全国へ発送するのだった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは順序として、まず五千円の商談をして来よう」「ちょっと待った」と私は老人を呼び止めた。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二世のセラダがウチへくるようになったのは法本が彼をウチへよんで何かの商談をやったからです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当日はこの商談の席に加わるために、日野もよばれてウチで待機していました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうわけで、法本がせっかく一席もうけた商談は全然役立たずです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場は冗談でまぎらして、いずれ宝石商の鑑定をうけた上でというような商談だけでその日は話を打ちきりました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "父との商談ですからそれぐらいは覚悟の上で、父の鼻をあかしてやるためならそれぐらいの金はだしてあげようと私や妹の主人たちも大へん乗気なのです。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　九月初めの或日、圭介は丸の内の勤め先に商談のために長与と云う遠縁にあたる者の訪問を受けた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "種々の商談の末、二人の会話が次第に個人的な話柄の上に落ちて行った時だった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は羽生のもとへ引返して、「御多用中相済まぬが、ひとつ商談に乗っていただきたい。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに単なる商談だよ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなんでしょうだんな。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
