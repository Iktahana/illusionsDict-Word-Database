          "literary": [
            {
              "text": "アッシリア語で風車をつくるもいい。",
              "citation": {
                "source": "私の果樹園",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代のシリア語專門の大家の説によると、キルヘルスを始め、十七世紀頃の歐洲の學者に、エストランゲロ體のシリア文を完全に譯し得た人は、殆どなかつたであらうといふ（31）。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "エジプト攻略の後で、ギリシア語の著作はしばしばシリア語を介してアラビア語に翻訳された。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア語からシリア語へ、シリア語からアラビア語へ、アラビア語からヘブライ語へ、およびヘブライまたはアラビア語からラテン語への翻訳において、ギリシアの古い著作者の形態および思想にしばしば混乱が無いわけではなく、しばしば誤りが生まれ、ガレノスの解剖学は伝達にさいしてひどい目にあっていた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の情報の源になる数多くの碑文と書類は廃墟となった幾つかのアッシリアの市で見つかりアッシリア語で書かれている。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの本の多くは他のセム系言語であるシリア語にすでに訳されていたのでアラビア語への翻訳は早かった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
