      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "worry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――さう心配したもんぢやないよ、今に子供でも出来れば――あ、子供は出来ないのか。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ朝、海デ泳グカラ、皆、夜ノ心配ヲ忘レマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か心配でもあるのかと夫人が聞いたら、あまり楽しくて嬉しいので、いつまでこの家に住み、いつまでこんな幸福が続くかと思い、それがまた心配になって来たと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼の言葉通りに、現実の心配が迫って来た。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、心配なさらなくても、いいのよ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店のをばさんが、だいいちに心配しはじめた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども心配そうに、口ごもりながら、「行ってもすぐ帰って来るのでは意味がない、それから、どんな事があっても阿片だけは吸わないように。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさぞ、御心配だったでしょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の事も子供の事も、ちっとも心配していない様子で、ただ、お庭の植木の事ばっかり言って寄こします。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは心配ないだろう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ相手のお嬢さんは、ひどく若くて綺麗だそうだから、実は心配していたのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の健康状態やら、また、将来の暮しに就いて、いろいろ御心配して下さってありがとうございます。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も心配して何だとか彼だとか言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまた祖母と祖母との争ひなどが起つたり、母がそれにキン／＼しだすと不可ないといふ心配もあつたし、それに私の喋舌り出すと止められない、つまらないことにでも力を入れたりする質が却々そこを退かうともした私を許さなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今迄はお父さんとお祖母さんだけだつたのが此の頃ではあんたまでお母さんの心配を多くする。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度お父さんがあそこの養子さんにお嫁さんの心配をするんでそのことに就いて一寸……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は人の前に出る毎に、この反対衝動の発作が恐ろしく、それの心配と制止観念とで、休む間もなく心を疲らし、気を張りきって居らねばならぬ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京に入りて息子とかの宿に行くまでの途中いさゝか覚束なく思わるゝは他人のいらぬ心配かは知らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二、三歳の頃ひどくからだが弱くて両親に心配をかけた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "力やエネルギーの概念がどうなったところで、建築や土木工事の設計書に変更を要するような心配はない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今電車の窓から日曜の街の人通りをのどかに見下ろしている刻下の心持はただ自分が一通りの義務を果してしまった、この間中からの仕事が一段落をつげたと云うだけの単純な満足が心の底に動いているので、過去の憂苦も行末の心配も吉野紙を距てた絵ぐらいに思われて、ただ何となく寛ろいだ心持になっている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雨の中を頭からぬれひたって銀座通りを歩いていてもだれもとがめる人もなければ、よけいな心配をする人もない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃自分は愛読していた書物などの影響から、人間は別になんにもしなくても、平和に綺麗に一生を過せばそれでよいと云ったような考えが漠然と出来ていたので、病気で試験を休もうが、落第しようが、そんな事は一向心配しなかった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人からの借金や何か、病氣全快してから少しづつ返すやうに心掛けて、なにも、くよくよ心配する必要なし。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの之までの業蹟に就いては親戚の者共、いづれも心配してゐた樣である。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお見舞ひも何も言はれぬくせに、こちらから御禮を述べ、「心配無用だよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ事が、いつか必ず起るのではないかと、前から心配してゐたのでした。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の健康状態やら、また、將來の暮しに就いて、いろいろ御心配して下さつてありがたうございます。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが晃平一人はウンと踏ん張った、　心配するなッ、犢鼻褌を焚いたッても、お前方を殺すことじゃあねえぞ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなさん」と　もるもっとは、しんぱいそうに　して　いる　みんなの　かおを　みまわして　いいました。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
