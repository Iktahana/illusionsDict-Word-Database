[
  {
    "uuid": "bec33d9e-5752-5764-a2ce-99a2b49793f7",
    "entry": "心配",
    "reading": {
      "primary": "しんぱい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
