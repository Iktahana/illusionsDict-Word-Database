  {
    "uuid": "b431fb7b-90a6-5fe0-a867-8ae2a2c8354a",
    "entry": "諸他",
    "reading": {
      "primary": "しょた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
