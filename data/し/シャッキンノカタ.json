          "literary": [
            {
              "text": "彼の下宿の借金のカタに彼の最も貴重な財産たる一つのミカン箱をおいてきた。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "継母サナエは元旗本の娘であるが、借金のカタに二十いくつも齢のちがう全作のところへお嫁入りした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "全作がサナエの美しいのに目をつけて借金のカタにお嫁にもらったと思うのは筋ちがいのようだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガーエフ　そう、だがこの庭も、借金のカタに売られてしまう。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "高輪に壮大なる邸宅があってそれは借金のカタになっているが、妹が結婚する迄はその家をもって行くという処世術を守る家風です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
