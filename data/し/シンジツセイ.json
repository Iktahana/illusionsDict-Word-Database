[
  {
    "uuid": "ceb74f28-1ec3-50a5-8ddc-37f9d051c397",
    "entry": "真実性",
    "reading": {
      "primary": "しんじつせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
