[
  {
    "uuid": "5e83c973-b40c-50d5-bd8c-d681060c3a0f",
    "entry": "支局",
    "reading": {
      "primary": "しきょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
