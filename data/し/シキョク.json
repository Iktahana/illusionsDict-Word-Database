      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "branch office",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝日支局の大山為嗣さんに迎えられて、大宮まで自動車を走らせた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうものは全国にただ一つあって、各地には適当に支局を分配して、中央を通じて相連絡すればよい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、私は故郷の、やや有名な新聞社の東京支局から招待状をもらっていたのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、朝から両手に桜｜麦酒をかかえ込んで遊びに来た九州は福岡の読売新聞の支局長だというＹ君に、「どうだね、これは貰っときたいが。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "横田というのは、東京の××新聞の社員で、去年からこの静岡の支局詰めを命ぜられた青年記者である。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「倉沢君は町へ遊びに出たといって、日の暮れがたに私の支局へたずねて来てくれたので、××軒という洋食屋へ行って、一緒にゆう飯を食ったのですが、その時に倉沢君は西瓜を注文して……。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは社用で九州へ出張する途中、この広島の支局に打合せをする事があって下車したのである。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "支局では大手町の旅館へ案内してくれたが、その本店には多数の軍人が泊り合せていたので、さらに停車場前の支店へ送り込まれた。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "来合わせたタキシーを拾って神奈川県庁前の東都日報支局に横付けて、中学時代の同窓であった同支局主任の宇東三五郎をタタキ起して、程近い鶏肉屋の二階に上った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐに行こうで……チョット待て、支局から電話をかけて置こう」　話はダンダンと急テンポになって来た。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の新聞社の支局へも挨拶しないまま、今から直ぐに出発したいという我ままな願いも、そんなに八釜しく仰言らずに承知して下さいました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｒ市長は、当時同市の支局に派遣されてゐた新聞記者である私の義弟の従兄であつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前代未聞のこの怪事件を最初に発見し、そしてその現場に一番乗りをした上に、全世界の報道網に対し輝かしき第一報を打つことに成功したデンマーク新報のアイスランド支局員ハリ・ドレゴの命名によるものであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前十時半長田君大庭君（大阪毎日）神戸支局の某君に見送られて神戸丸に乗込む。",
              "citation": {
                "source": "旅日記",
                "author": "東海道線",
                "note": "青空文庫"
              }
            },
            {
              "text": "長田君、大庭君、日向君の代理として其半身の種子さん支局詰の某君等船まで見送られる。",
              "citation": {
                "source": "旅日記",
                "author": "東海道線",
                "note": "青空文庫"
              }
            },
            {
              "text": "下諏訪の桔梗屋で、本社の山中氏と私達父子は、支局の中島氏と、ヒユッテの持主で篤実の山の研究者であり、「山郷風物誌」などの興味ふかい著述をもつてゐる長尾宏也氏といふ霧ヶ峰スキイ場の開拓者として知られてゐる青年が、わざわざ山の案内役におりて来たのに、紹介されたりして、急に心強くなつた。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ・ナップ支局からメッセージが来た。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西支局のＷも女房や子供と前後して上京した。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ港へくると、早速九州の新聞社の支局の記者がきて、「大杉他二名」に対する感想を話してもらいたいといった。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク・タイムズ東京支局長リンゼー・パロット氏、ＡＰ東京支局長ラッセル・ブラインズ氏に対して日本人として鈴木文史朗氏が出席している、肩書はリーダーズ・ダイジェスト日本版編集長とある。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、天聲はあわてた樣子をして、「さうせツかちにしなくてもよからう」と云つて、パスのことを旭川へ度々云つてやつて貰ふのだが、旭川の支局長がなか／＼ずぼらで、今囘に限らず、いつも滅多に返して來ないこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し約束したパスはまだ旭川の支社から返つて來ないので、兎に角、社からそのつもりで預つてゐる二十圓だけを渡すから、その金と紹介状とを以つて、同社の支局並びに天聲の友人等を渡つてゐて呉れろ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして義雄が帶廣に於いて、メール社支局の記者や、旭川新聞並びに釧路新聞の出張員等と一緒に料理屋へ行つた時、その藝者が義雄を誰れか當てて見よとその地の記者等に云はれ、島田さん（氷峰のこと）か、さなくば物集さん（北劍のこと）かと答へた事實を語つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭川でも、メール支局の主任は既に陸軍演習の地に向つた留守で、却つて、反對の新聞社に紹介して貰つて、アルコール釀造場を見たこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私達は加藤さんと午前に住吉町の朝日新聞の支局に局長の大井二郎さんを訪ねた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年も此地にゐて郭松齢事件に機敏な報道をして手腕を本社に認められたが、今度は支局長として二箇月前に東京から派遣されたのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日の支局を辞して、附近のレストオランで昼食を済ませてゐると、長濱哲三郎さんが自動車を以て迎へに来られた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
