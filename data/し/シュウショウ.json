[
  {
    "uuid": "f7be6682-2991-52d7-9144-35f063e33328",
    "entry": "周章",
    "reading": {
      "primary": "しゅうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "confusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「大学を出たのに職がない」といふと、尠くも近親は周章てるが、「腕はあるのに職がない」なぞと云はうものなら、「威張つてやがらァ」ではないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「予想」が現今大概の人の場合に稀薄なのであるし、これは多分「人間像」を見失ふ、つまり「おのづと感じられる面白味」といふものの離散であらうし、それは意志だけの如き意志、謂はば周章狼狽の結果でもあらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の照る砂地に落ちてゐた硝子を、歩み来た旅人は周章てて見付けた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丁度向側の家が持主の代が変りそうだという評判を聞いて、その家は保存的価値のある建築であったので、美術大臣が周章てて今度の持主に手紙で政府の保護を申出でた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現われて来る眼に見えぬ敵を想像して周章てはてた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵「ナニ」と強い男に向わんとするのを、　半次、　周章てて止めた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところへ誰かが出て来ると、さあ周章て鉄砲を隠す、本を繰る、生憎開けたところと読んで居るところと違って居るのが見あらわされると大叱言を頂戴した。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのできるはずのことがなかなか容易にできないのは多くの場合に群集が周章狼狽するためであって、その周章狼狽は畢竟火災の伝播に関する科学的知識の欠乏から来るのであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると木樵はだんだんぐるっと円くまはって歩いてゐましたがいよいよひどく周章てだしてまるではあはあはあはあしながら何べんも同じ所をまはり出しました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると木樵はだんだんぐるっと円くまわって歩いていましたがいよいよひどく周章てだしてまるではあはあはあはあしながら何べんも同じ所をまわり出しました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」給仕、（周章てゝ来る）「はいはい、相済みません。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫博士、周章してかけまはる。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の眼は、秘密が露見した時に人がする眼であり、まあそんなことを云つて呉れてはと、周章ててゐる私を見た時に、弟の眼はタジ／＼とした。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりかへしのつかない思ひに、ただただ周章てふためいてゐた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休の様子には少しも周章えた様子は見えません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごとごとと溝板を踏み乍ら、勝手の方から濡れ手を拭き拭き駈けて来た下女のおすめが周章ててランプの心を馴れた手付きで捻じ細めた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀田、周章ててお辞儀をする。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それと見て、つかつかと、小刻みながら影が映す、衣の色香を一目見ると、じたじたとなって胴震いに立窘むや否や、狼狽加減もよっぽどな、一度駆出したのを、面喰って逆戻りで、寄って来る清葉の前を、真角に切って飛んで遁げた、赤熊の周章てた形は、見る見る日本橋の袂へ小さくなって、夜中に走る鼬に似ていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐッすり寐込んででもいようもんなら、盗賊が遁込んだようじゃから、なぞというて、叩き起して周章てさせる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "米は鍵屋あって以来の上客を得た上に、当の敵の蔵屋の分二名まで取込んだ得意想うべく、わざと後を圧えて、周章てて胡乱々々する蔵屋の女に、上下四人をこれ見よがし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「周章てるない、」といって滝太郎は衝と戻って、やにわにお雪の手を取った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると白い服を着た給仕が周章てて走り寄りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と立ちかけると、濱島は周章て押止め『ま、ま、お待ちなさい、お待ちなさい、今から旅亭へ皈つたとて何になります。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は周章てゝ起上つたが、怒氣滿面、けれど自己が醜態に怒る事も出來ず、ビール樽のやうな腹に手を當てゝ、物凄い眼に水夫共を睨み付けると、此時私の傍には鬚の長い、頭の禿た、如何にも古風らしい一個の英國人が立つて居つたが、此活劇を見るより、ぶるぶると身慄して『あゝ、あゝ、縁起でもない、南無阿彌陀佛！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "火夫、船丁等の周章狼狽は言ふ迄もない、其内に乘客もく二三｜船員の聲も聽える。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と一聲吾等は周章狼狽て鐵檻の車の中へ逃込んだが、危機一髮、最後に逃込んだ武村兵曹はまだ其半身が車外にあるのに、殆んど同時に飛付いて來た雄獅子のために、ズボンは滅茶苦茶に引裂かれ、片足の靴は無殘に噛取られて、命から／″＼車中に轉び込んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛獸羣は不意に驚いて、周章狼狽て逃げ失せる。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "周章狼狽戸外に飛出して見ると、今迄は北斗七星の爛々と輝いて居つた空は、一面に墨を流せる如く、限りなき海洋の表面は怒濤澎湃、水煙天に漲つて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
