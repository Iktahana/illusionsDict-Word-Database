    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Syrah (wine grape variety)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからドレスデンやらエナへ行って後、ワイマールに二時間ばかりとどまって、ゲーテとシラーの家を見ました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラーの家はいっそう質素と言うよりはむしろ貧しいくらいでした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテの家には制服を着けた立派な番人が数人いましたが、シラーのほうには猫背の女がただ一人番していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラー町の突き当たりの角は大きな当世ふうのカッフェーで、ガラス窓の中から二十世紀の男女が、通りかかった毛色の変わった私を珍しそうに見物していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手には小さなシラーの詩集を持って。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中になってシラーの詩に読み耽っていた園は、思いもよらぬ不安に襲われて詩集から眼を放して機械を見つめた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに詩人シラーのいいしがごとく、天然には永久の希望あり、壊敗はこれをただ人のあいだにおいてのみ見るのであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て理性とか法則とかいっている者の根本には意志の統一作用が働いている、シラーなどが論じているように、公理 axiom というような者でも元来実用上より発達した者であって、その発生の方法においては単なる我々の希望と異なっておらぬ（Sturt, Personal Idealism, p. 92）。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツでは、大層盛大なワグナア祭典が行われていたり、ゲーテやシラーについて政府としての評価が語られたりしているようだ。",
              "citation": {
                "source": "明日の実力の為に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもシラーは歴史家たるの天分を有しなかつた。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラーは上に記した有名な書簡の中で、ゲーテの精神を思弁的精神に対する直観的精神として規定し、思弁的精神が統一から出発するに反して、直観的精神は多様から出立すると述べてゐる。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とシラーは述べてゐる。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラーは右に引用した書簡の中でゲーテに云つた、「あなたは単純な組織から一歩一歩より多く複雑な組織へ昇られる、かくて最後に凡てのうち最も複雑な組織即ち人間に至り、これを発生的に全体の自然の建築物の諸材料から築き上げられる。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七九八年六月三十日付のシラーへの書簡の中で、ゲーテは、上から下へ降る自然哲学と、下から上へ昇る自然研究家とについて述べ、そして「私は少くともその中間に立つ直観のうちにおいてのみ私の安心を見出す。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテは彼とシラーとの際会をかかるものと考へた。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かやうにして私のシラーとの知り合ひには全く或るデモーニッシュなものが支配してゐた。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにそれが丁度、私がイタリア旅行を終へそしてシラーが哲学的思弁に倦き始めた時代であつたといふことは、重要なことであり、二人にとつて最も大きな効果のあることであつた。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスのシラーのいはゆるヒューマニズムなどもこの傾向に屬してゐる。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人シラーのいうごとく人生の目的として花を選ぶ者とその実を選ぶ者とは別種の者に数えるが至当であろう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が三十六のころ、ドイツ見物に数週間ベルリンに費やしたことがあったが、その際ある文士に会って、四方山の文談を聞いたときに、話がゲーテとシラーに移って、両氏の性格および文才と、後世に及ぼせる偉業を論じた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく僕の精神発達のいまだ幼稚なるを証するのではあるまいかと、自ら疑うことが多いと告白したところが、かの文士は、それは君は心配するにおよばない、ドイツ人のうちにも、今日なおシラーを推して、思想においてははるかにゲーテに優るものなりと称嘆する者はけっして少なくない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『理論と実行との矛盾は、シラーやシヨーペンハワーと同様にゲーテにもある。",
              "citation": {
                "source": "双葉山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀の全部の美学の罪は、それが芸術家の作品に結び付かないで、彼等の言葉を分析したことにある』といふので、彼等といふのは、シラー以下の諸先進のことを指してゐる。",
              "citation": {
                "source": "双葉山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれだけ忙しい人生の合ひま／＼にゲーテだのシラーだの時にはゴッホの絵本などゝいふどこから種本を見つけてくるのやら飜訳といふ仕事をやり、私が小説の本をだしたよりもたくさん飜訳の本をだしてゐるのである。",
              "citation": {
                "source": "足のない男と首のない男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはカッシラーの指摘した実体概念的思惟方法である。",
              "citation": {
                "source": "レンズとフィルム",
                "author": "――それも一つの性格である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシュールが、彼の言語哲学の構造を、将棋の運用構造に適応してみせていることは、後のカッシラーの『象徴的形式』の考えかたに道を開いている。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはカッシラーにまで一貫する方法である。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
