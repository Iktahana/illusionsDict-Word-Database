        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "峠が上り下りして、森らしくなる、杜鵑がしきりに啼く、湯治の客が、運んだ飜ぼれ種子からであろうが、栂の大木の下に、菜の花が、いじけながらも、黄色に二株ばかり咲いていた、時は七月末、二千｜米突の峠、針葉樹林の蔭で！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルオガセの垂れる針葉樹の間からも、同じように起る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この深谷の幾千本針の針葉樹よりも、はた幾｜万斛の水よりも、一寸の魚が、谷の感情を支配していないとは言えなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を伸し合う針葉樹は、格子縞を、虚空に組み合せている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた針葉樹林を駈け下りる、水の音がするすると、樹の間を分けて上って来るようだ、水！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって空に星はあったが、電光が白い柱を、谷の中に投げては、夜営の人々をおどろかした、夜半には、秋雨が音なく注いだ、川縁に転がっている流材を焚火にして、寒さを凌いだ、針葉樹の切崖で囲んだ、瓶のように窄い谷底からは、天も谷川ほどの細さで流れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み心地のよい針葉樹の、暗い路を登るほどに、いつしか栂の純林となって、この鈍林を放れ切るまで、松葉つなぎの腐蝕土はつやを消したような光線で、うす暗くぼかされている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外には鼠色の平なる屋根、高き春の空、静に揺ぐ針葉樹の頂を臨む。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば信州へんでもある東西に走る渓流の南岸の斜面には北海道へんで見られるような闊葉樹林がこんもり茂っているのに、対岸の日表の斜面には南国らしい針葉樹交じりの粗林が見られることもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外はまっくろな腐植土の畑で向ふには暗い色の針葉樹がぞろりとならんでゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は黒い針葉樹の列をくぐって外に出た。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不注意なわれわれ素人には花のない見知らぬ樹木はだいたい針葉樹と扁葉樹との二色ぐらいか、せいぜいで十種二十種にしか区別ができないのに、花が咲いて見るとそこに何か新しい別物が生まれたかのように感じるものらしい。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またうち湿った闊葉樹、針葉樹の林を、森を、また花いろの遠い煙霞を。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈高き針葉樹の園を限りたるさまは、北伊太利の柳と相似たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く杉檜等の針葉樹であるが、間々この山獨特の珍しい草木もあるとのことである。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この峠は上下七里の間、一軒の人家をも見ず、唯だ間斷なくうち續いた針葉樹林の間を歩いてゆくのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "松栢、その他の針葉樹、その内に巻き込まるゝときは、摧け折れ、断片となりて浮び出づ。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の度に杉は針葉樹の特色を現して樹脂多い葉がばり／＼と凄じく鳴つて燒けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "栂や樅などの針葉樹林であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くは針葉樹の林であるが、中に雑木も混り、とりどりに紅葉してゐた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、渓ばたを離れて路はやゝ嶮しく、前後左右の見通しのきかない様な針葉樹林の中に入つてしまつた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "樅、栂、などすべて針葉樹の巨大なものがはてしなく並び立つて茂つてゐるのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "樅、栂、などすべて針葉樹の巨大なものがはてしなく並び立って茂っているのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、後方の、針葉樹の林に登った太陽が、濃い霧を透し始めると、左の丘には、やはり砲軍の姿がほのかに見えていた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の屋敷は鬱蒼たる針葉樹林に取り巻れて、大昔の面影をその儘伝へたピラミツド型の斜面を持つた草葺屋根を二棟に分つた館を中心にして、池を囲らせてゐる。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "針葉樹と闊葉樹が混り合つてゐるので、色も斑らな美しさであつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏口へ來て向うを望むと、曇つた空の下に低く蹲る山の木々は、針葉樹と濶葉樹が半々で、濶葉樹は白つぽい葉の裏を見せながら絶えず小さくざわざわと搖めいてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の窪みから峯へと層々と疊まるやうに繁つてゐる針葉樹の集りは、集合體全體が大きく搖ぎつつ、ぢつと見てゐると下の方からもくもくと盛り上つてでも行くやうに見えた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の踏む所は一面に針葉樹の葉で掩はれてゐて、すべつて歩きにくかつた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上流と下流とからうへへそり返つて黄、赤、べに等のいろづき葉が、松その他の針葉樹の青葉と入りまじつて、横へ四つに重なつた山山の絶頂まで一面につらなり渡つてる。",
              "citation": {
                "source": "鹽原日記",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
