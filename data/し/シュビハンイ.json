    "definitions": [
      {
        "index": 1,
        "gloss": "area of the field one is supposed to (or able to) defend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
