[
  {
    "uuid": "2376cca9-c234-5ecd-8c79-d55b17da8807",
    "entry": "仕舞う",
    "reading": {
      "primary": "しまう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to finish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "万事が手軽くこだわりなく行き過ぎて仕舞う。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして湊の代りに相手の客にその盃をつき返して黙って行って仕舞う。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊がはいって来ると、つんと済して立って行って仕舞うこともある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がいま呼んで、もし「はい」といってその女性が眼の前に出て来たなら自分はびっくりして気絶して仕舞うに違いないとは思う。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はだかの肌をするする撫でられるようなころ合いの酸味に、飯と、玉子のあまみがほろほろに交ったあじわいが丁度舌一ぱいに乗った具合――それをひとつ喰べて仕舞うと体を母に拠りつけたいほど、おいしさと、親しさが、ぬくめた香湯のように子供の身うちに湧いた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙鳶は他の子供が二枚も三枚も破り棄てて仕舞う間に自分は一枚の紙鳶を満足に※げて遊んで居た程でした。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、糸目の着加減を両かしぎというのにして、右へでも左へでも何方へでも遣りたいと思う方へ紙鳶が傾くように仕た上、近傍に紙鳶が揚って居ると其奴に引からめて敵の紙鳶を分捕って仕舞うので、左様甘く往くことばかりは無かったが、実に愉快で堪えられないほどの事におもって居たのです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから左様いう人が旅行をするのは何の事は無い、「御茶壺」になって仕舞うようなものですテ。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは是非共漁の総ての関係からして、左様いうように仕なければ漁場が荒れて仕舞うので、年のいかないものや、働きの弱い年寄などは蹈切って他所へ出ることが出来ないから、自分の方の漁場だけで働いて居るが、腕骨の強い奴は何時でも他所へ出漁する。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、今日ですっかり片付けて仕舞うんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白金色の痛みは身体中に拡大し、眠りの幕は放射状の爆破で、一気にどこかへ吹き飛ばされて仕舞う。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが蓑吉は一わたり玩具をいじり廻して仕舞うと鼻声になり「何か呉れない。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何だかおずおずとして仕舞うのであった。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚栄の風で食物の味は吹き曝されて仕舞う。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は客に料理場の秘密を内通して仕舞う。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、他に目ぼしい乗客もないので、結局、先の一行に注意を向け勝ちになって仕舞うのであった。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にあれ等はみな無くなって仕舞うのです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女　――禁ぜられた呪いを犯すときには、お祖父さまの代から燃え続いて居るこの炉の火が消えて仕舞うのです。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔の牙に噛み攻められ、殆ど自己の信任を失して仕舞うほどの心を引立てて、面を焦さんばかりの罪にまともに向き合って、その中より生命の浄化の秘密を探り出す般若の行道、これこそもっともお前に相応したものである。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蘭の玉の緒を、いつあの白痴が曳いて行ったか、自分が婿を貰い、世の常の女の定道に入るとすれば、この世の中の何処かの隅であの白痴が潰え崩れて仕舞うような傷ましさを、お蘭の心がしきりに感じるのをどうしようもなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは自分の一生も案外小ぢんまりした平凡に規定されて仕舞う寂寞の感じはあったが、しかし、また何かそうなって見ての上のことでなければ判らない不明な珍らしい未来の想像が、現在の自分の心情を牽きつけた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の一生を小さい陥※に嵌め込んで仕舞う危険と、何か不明の牽引力の為めに、危険と判り切ったものへ好んで身を挺して行く絶体絶命の気持ちとが、生れて始めての極度の緊張感を彼から抽き出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の露店は皆仕舞うたんじゃ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたはもう家へ追いかえして仕舞うから、そう思え。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃がして仕舞うといけないから、直ぐに追っかけてお出でなさいよ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は浦和の小地主の娘として生まれ、少女時代を東京で堅い屋敷奉公に過ごし、その屋敷が時代の英傑後藤新平の家であり、目端の利くところから、主人に可愛がられ、十八までそこの奥向きの小間使として働き、やがて馬喰町のある仕舞うた家に片着いたのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は裕福な仕舞うた家のようで、意気な格子戸の門に黒板塀という構えであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "と聞くから、二日くらいでこんなになってしまうのだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども人は、ひとたびこの小説を企てたその日から、みるみる痩せおとろえ、はては発狂するか自殺するか、もしくは唖者になってしまうのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで雑誌の最後的プランをきめてしまうのだとか言っていましたが、――どうでしょう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
