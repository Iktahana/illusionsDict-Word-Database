    "definitions": [
      {
        "index": 1,
        "gloss": "New Economic Policy (Soviet Union, 1922-1928)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
