[
  {
    "uuid": "c23fa5b2-96a0-5fcd-bbbc-33b6f6d15674",
    "entry": "使用料",
    "reading": {
      "primary": "しようりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
