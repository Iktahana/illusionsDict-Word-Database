        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一行はいま私が講演した会場の寺院の山門を出て、町の名所となっている大河に臨み城跡の山へ向うところである。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏休みは標本採集の書きいれ時なので、毎日捕虫網を肩にして旧城跡の公園に出かけたものである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家の近所にお城跡がありまして峻の散歩にはちょうど良いと思います」姉が彼の母のもとへ寄来した手紙にこんなことが書いてあった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄と姉とその娘と四人ではじめてこの城跡へ登った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない夜で涼みかたがた見物に来る町の人びとで城跡は賑わっていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "峻はこの間、やはりこの城跡のなかにある社の桜の木で法師蝉が鳴くのを、一尺ほどの間近で見た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――峻はこの城跡へ登るたび、幾度となくその入江を見るのが癖になっていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか英国人の宣教師の細君が旧城跡の公園でテントを張って幾日も写生していた事があった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ岩櫃山というて正平年間｜吾妻太郎行盛の城跡、巨巌重畳、断崖｜聳立、山中に古戦場あり、今日に及んでなお白骨の横わるものありという。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに少憩して付近の勝を探ぐり、はるかに左方｜春日山の城跡を仰おいで、曠世の英傑上杉｜輝虎の雄図を偲び、夕陽斜めに北海の怒濤を照すの夕闇に、潮鳴りの物凄き響きをききつつ、直江津の町へ入った。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "見さつせえ、いまに太陽様が出さつせえても、濠端かけて城跡には、お前様と私等が他には、人間らしい影もねえだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い村道の向こう側は一面の青田で向こうには徳川以前の小さい城跡の丘が見える。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの通りの口碑を持つ古城跡が諸国に多くある。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は蜜柑問屋から借りて来たフオード自動車を駆つて町の城跡へ進んでゐた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、城跡通ひを一先づ打ち切つて、当分村の書斎に引き籠つてゐる！",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の森、学校の屋根、火の見櫓、役場、銀行、城跡――私はそれらの眺めを、ぼんやりと見渡して、「おゝ、あれは遊廓だ！",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどのくらゐの間、二人してその城跡の山の上の枯草原で密議を凝らしましたか、二人とも非常な昂奮を抱いて山を降りる頃は、日はもうとつぷりと暮れてをりました。",
              "citation": {
                "source": "金比羅參り",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の大きくなった士族町からは昔の城跡が近かった。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸に私は誰にも逢はずに、逢へば必ずなつかしさうに向うから寄つて来て、その時はぢかには話さぬにしても、あとでいろいろと噂の種にはせずには置かないであらう村の人達にも逢はずに、丘の松の林の中の路をずつとＹの城跡の方まで出て行くことが出来た。",
              "citation": {
                "source": "あさぢ沼",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "行っても、行っても、お菊の思うような小諸の古い城跡へは出なかった。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "……市役所・国泰寺・大阪銀行・広島城跡を見物して、バスは産業奨励館の側に停った。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い勉強部屋にくると、城跡の石垣と青い堀が、明暗を混じえてガラス張りの向うにあった。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……市役所・国秦寺・大阪銀行・広島城跡を見物して、バスは産業奨励館の側に停まつた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い勉強部屋にくると、城跡の石垣と青い堀が、明暗を混じへてガラス張りの向うにあつた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "田代の古城跡から武器が出たとか。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨中に眺めたときの姿は、矢羽根を連ねたような黒褐色の壮大さで、自分の国の崩れた城跡とは凡そ反対な、一見翼を拡げた見事な鳶を聯想させた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし屋敷跡もあり、父母の墓もあるし、旧主の城跡もあるとすれば、播州の人と云う、正確な証拠の出ぬ以上、美作の人とすべきである。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "四畳半式も結局、上流に如法寺山を控へ、臥竜淵を添へ、下流に城跡の小丘、高山の屏風をめぐらして、大きくＳ字形に曲流する大洲の肱川観が、この長流の中心、その枢要の地であるといふことになる。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔猥れて嘲笑めるはた寒き〕猥れて嘲笑めるはた寒き、　　　凶つのまみをはらはんとかへさまた経るしろあとの、　　天は遷ろふ火の鱗。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずむしろあとから「硫黄」をうまくはめ込んだものらしいと思われるふしもある。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
