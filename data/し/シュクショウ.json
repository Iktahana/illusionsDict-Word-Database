[
  {
    "uuid": "1eb653f8-72f2-53c7-923c-e6d079dec3c9",
    "entry": "縮小",
    "reading": {
      "primary": "しゅくしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
