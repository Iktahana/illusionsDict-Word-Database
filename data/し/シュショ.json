    },
    "definitions": [
      {
        "index": 1,
        "gloss": "writing in red",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "篋の内に朱書あり、之を読むに、応文は鬼門より出で、余は水関御溝よりして行き、薄暮にして神楽観の西房に会せよ、とあり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "篋中の朱書、道士の霊夢、王鉞の言、呉亮の死と、道衍の請と、溥洽の黙と、嗚呼、数たると数たらざると、道衍｜蓋し知ることあらん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内わきの、左手の庵室、障子を閉して、……たゞ、假に差置いたやうな庵ながら構は縁が高い、端近に三寶を二つ置いて、一つには横綴の帳一册、一つには奉納の米袋、ぱら／＼と少しこぼれて、おひねりといふのが捧げてある、眞中に硯箱が出て、朱書が添へてある。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内わきの、左手の庵室、障子を閉して、……ただ、仮に差置いたような庵ながら構は縁が高い、端近に三宝を二つ置いて、一つには横綴の帳一冊、一つには奉納の米袋、ぱらぱらと少しこぼれて、おひねりというのが捧げてある、真中に硯箱が出て、朱書が添えてある。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "章の番号や、本の終わりと始まりを示す、伝統的に朱書きされてきた部分も、印刷時には空きのまま残されました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文の手写に専念する工房がある中で、イニシャルや朱書きに特化したところが生まれ、文様や装飾画にはまた、別の工房が専門にあたるといった分業化が進んでいきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政二年、出羽の代官からかようの鼠に関し差し出した届けの朱書に、その鼠、色赤く、常鼠より小さく、腹白く、尾短しとある由（『郷土研究』二巻、白井博士「野鼠と竹実」）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰不華元帥はその当時｜西台の御史であったので、その事件の記録に朱書きをして、「鬼贓」としるした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「渠が旅行に出る度毎に女を拵らへて來ないことはない」とある側らに、誰れかのいたづらで、「而して歡迎會の歸りに女郎買ひをした」といふ朱書きがある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄外評は初｜頁より二十七頁に至るまで、享和元年より後二年にして家を嗣いだ阿部侯｜椶軒正精の朱書である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」士整の下に「名融思、号鳳嶺、観画吏、善詩画」と註し、又観画吏の傍に唐画目利と朱書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "※斎詩集には客崎詩稿の次に、森｜枳園の手迹と覚しき文字で文化四年丁卯以後と朱書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵜川は茶山に書を寄せたことが、原本の氏旁に朱書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "月日の下の括弧内数行は原本に朱書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻は百｜零三｜頁の半紙本で、頁数は森｜枳園の朱書する所である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨書は榛軒、朱書は柏軒である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "革袋は黒の漆塗で、その水戸家から受けたものには、眞志の二字が朱書してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（朱書、磨滅）月　日―――――――――認おわりて枕辺におしやる頃、門守る犬の声には夜ふかふおぼへ、鳥のこゑのこゝかしこにきこゆるは寅の針は卯をさすにちかゝらんか。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月十日　長崎奉行あて差出の草案",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い小さい西洋封筒に「速達」と朱書きしてあった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　昔から花火屋のある処は暗いものの例となっている位で、店の真中に一本の燈心を灯し、これを繞って飾られている火薬に、朱書された花火という字が茫然と浮出している情景は、子供心に忘れられない記憶の一つで、暗いものの標語に花火屋の行燈というが、全くその通りである。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹当へ、大きく「御用」と、朱書した馬に乗った侍が、雪の泥濘を蹴って走ってきた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "古鈔本中｜元暦校本に朱書で或ウネメノとあるに従って訓んだが、なおオホヤメノ（神）タオヤメノ（文）の訓もあるから、旧訓或は考の訓によって味うことも出来る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧臘某日の事とか、千々岩が勤むる参謀本部に千々岩にあてて一通のはがきを寄せたる者あり、折節千々岩は不在なりしを同僚の某何心なく見るに、高利貸の名高き何某の貸し金督促状にして、しかのみならずその金額要件は特に朱書してありしという。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外朱書〕仲ハ中ニ改可シ十月九日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔一行アキノ欄外朱書〕麻布移居五月廿三日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔朱書〕小品文砂糖を寄稿す七月十八日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は台石に三遊連と朱書されてゐるところを見ると、往昔全盛を誇つた三遊派の同僚花形たちはこの明治開化一代の人気者のために金円を投じ合つて墓表を建立したものかも知れない。",
              "citation": {
                "source": "巣鴨菊",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「組合へ、顔出しゅしょうかと思うとったが。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
