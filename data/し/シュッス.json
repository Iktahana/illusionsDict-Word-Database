        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十二年十二月五日、京都にて卒す。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷氏の史に、建文帝、生れて十年にして懿文卒すとあるは、蓋し脱字にして、父君に別れ、儲位に立ちたまえる時は、正しく十六歳におわしける。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年｜楊応能卒し、葉希賢次いで卒す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "衍｜頓首して謝し、尋で卒すと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太子欠位の中に霊公が卒する。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十二年一月十八日卒す。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同二十五年八月十日卒す。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治九年三月二十日卒す。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄公｜卒するの時、武田家の軍機は我等四人内密に行うべきを遺言された。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば姓氏を重んずる支那でも、〈田常斉の国中の女子｜長七尺以上なるを選み後宮と為す、後宮百を以て数え、而して賓客舎人の後宮に出入する者を禁ぜざらしむ、常卒するに及び七十余男あり〉。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "会ふに及ばずして卒す。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "後三年を隔てゝ天保元年定信卒す、襄乃ち文を作りて之を祭れり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに加うるに、在位二十八年にして四年以前譲位せし我父｜微爾列謨第一世王も、遠行して悲哀に沈めり（ウイルレム第一世は安永元年｜壬辰に生れ、文化十二年｜乙亥に王位に封ぜられ、天保十一年｜庚子今王に位を譲り、同十四年｜癸卯に卒す。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "父卒するに及んで、叔齊、伯夷に讓る。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "伯夷列傳第一",
                "note": "青空文庫"
              }
            },
            {
              "text": "至るに及んで西伯卒す。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "伯夷列傳第一",
                "note": "青空文庫"
              }
            },
            {
              "text": "応永二十四年為尹薨去の年、正徹三十七、同二十七年今川了俊卒する年、正徹四十歳。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
