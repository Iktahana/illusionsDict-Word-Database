    "definitions": [
      {
        "index": 1,
        "gloss": "ceremonial dress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
