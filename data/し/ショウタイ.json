            },
            {
              "text": "食堂までくると、ふたりの団員が、しょうたいもなく眠っていることがわかりました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
