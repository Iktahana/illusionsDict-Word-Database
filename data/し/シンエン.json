        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "心炎狂舞　越前守は、はたと、耳をすました。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠らんとすればするほど心炎はカッカと冴えてくるばかり。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
