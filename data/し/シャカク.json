[
  {
    "uuid": "874b3873-43d7-5022-8bd5-e3352e9fb1a0",
    "entry": "射角",
    "reading": {
      "primary": "しゃかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "angle of fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "反射角と入射角と等しいという意味の言葉もある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃ち出した砲弾が大気の条件によってどんな影響を受け、初速や発射角度などに応じてどのような軌跡を描いてどこに着弾するかを示す弾道数表作りを高速化する目的で、一九四三年に開発が始まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は屍体に喰い込んだ弾丸の入射角を正確に測ろうなどとは毛頭考えたことがなかった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の速度をベクトルで書くと、こうなります、弾丸の速度はこうです……」と笹木光吉は、三角｜定規を組合わしたような線を、紙の上に引いてみせて、「これが弾丸の入射角です。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
