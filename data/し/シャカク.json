  {
    "uuid": "74f28e14-c2f1-5153-bcbb-b27df944f0db",
    "entry": "社格",
    "reading": {
      "primary": "しゃかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shrine ranking (abolished in 1946)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一の宮だが現社格は近代まで県社ぐらいの低いものだったらしく、祭神が今もハッキリとしない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の任地なる飛騨高山地方は当時筑摩県の管下にあったが、水無神社は県社ともちがい、国幣小社の社格のある関係からも、一切は本省の指令を待たねばならなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は郷社の社格であるので、郡視学たる西原君は郡長に代り奉幣使として当神社祭典の際に参向した。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "社格からいふと鎮守さんは郷社、こちらは村社であつて境内も狭いが、私たちがたゞ御宮といひ神さんといふときは必ずこの方のことであつた。",
              "citation": {
                "source": "祭のさまざま",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しからずして極位に達して停止に帰し、いたずらに稲荷の正一位に名残を留めて弊害をさえ生じたが、これに伴のうて設けられた官知の特典と、社格の階段制とは、僅か形を替えて久しく記憶せられ、且つ明治の新政において復活した。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
