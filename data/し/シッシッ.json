        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やあやあ、しっしっ、吹くやら、払いますやら、静として赤蜻蛉が動かねえとなると、はい、時代違いで、何の気もねえ若い徒も、さてこの働きに掛ってみれば、記念碑糸塚の因縁さ、よく聞いて知ってるもんだで。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに干物を攫われた印判屋の台所の上で、なにかごとごとという音がきこえたので、おおかた猫か鼠だろうと思った女房は、台所へ出てしっしっと追ったが、屋根のうえの物音はまだ止まなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルチック司令官｜寝呆豆腐とござあい」「ワッハッハ」「しっしっ聞えるぞ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茂登は、何かのはずみで往来へ出ている眼の真赤な兎を、つかまえどころがわからなくて、しっしっと下駄を鳴らして囲いの中へ追い込んだ。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、げんまんして」　小指をさしつけ、順助が黙ってさし出す小指に桃子は自分の小指を絡めて、子供たちが約束げんまん、しっしっしっと振る時のように真面目に力を入れて一つ二つ三つと自分で上下に振った。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『しっしっ、プリムロウズ！",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ御茶を一つ」と立ち上がりながら、しっしっと二声で鶏を追い下げる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふん、なら、しっしっ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言っては、くるごとに嫌いな犬をしっしっと門のそばで、半ばコワがりながら叱っていた。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は容赦なく追い立て、野蛮人のようにしっしっというのだった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親のあの耐えがたいしっしっという追い立ての声さえなかったら、どんなによかったろう！",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうほとんど向きを変え終ったというのに、いつでもこのしっしっという声に気を取られて、おろおろしてしまい、またもや少しばかりもとの方向へもどってしまうのだ。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてグレゴールは、ドアを閉めて、自分にこんな光景とさわぎとを見せないようにしようとだれも思いつかないことに腹を立てて、大きな音を出してしっしっというのだった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しっしっ、」彼らは叫びました、「いっちまえ、この能無しのクソ鳥め、首を絞められなかったのがめっけもんだと思えこの騒音野郎！",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠追ふや椿生けたる枕上　　　　田福　夜鼠が出て来て枕もとをごそつかすので、寝ていながらしっしっとそれを追うた、その枕もとには椿が生けてあるのだ、というのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっしっ、などと追ったぐらいでは動かない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しっしっ、寝なきゃ、また悪くなりますよ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
