        "examples": {
          "standard": [
            {
              "text": "専門家は、過度な格差こそが犯罪率を押し上げる諸悪の根源であると指摘している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "組織内の風通しの悪さが諸悪の根源となって、不祥事が相次いで発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「不規則な生活こそが君の体調不良の諸悪の根源だよ、早く寝なさい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "即ち諸悪の根源である。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようするに諸悪の根源は、アメリカにおいて独特の進展をみせた資本主義なのだから、その枠の内部でほころびをつくろってみてもなにごともはじまらない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
