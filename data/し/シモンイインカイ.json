          "standard": [
            {
              "text": "政府はデジタル通貨の導入に向け、民間の有識者による諮問委員会を設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "諮問委員会の議事録が公開され、そこでの活発な議論の内容が明らかになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はその卓越した知識を買われ、環境省の諮問委員会のメンバーに選出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "第二次大戦後、ＮＡＳＡの前身の航空宇宙諮問委員会（ＮＡＣＡ）エイムズ研究所で風洞の研究に携わったエンゲルバートはやがて、人類の多くを進歩させるような意義のあるはでな仕事につきたいと、若者らしい野心を抱くようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの無條件降伏を前提とし、ドイツを三分し米、英、ソで占領する案が、欧州諮問委員会で決定した旨、ストックホルム電は伝う。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
