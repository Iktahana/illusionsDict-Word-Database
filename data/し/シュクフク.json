    "definitions": [
      {
        "index": 1,
        "gloss": "celebration (of a joyous occasion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汝等祝福されてあるべきなり、其の他はすべて分解しければ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは僕にとって、嘆くべきことか祝福すべきことか解らない。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、かれらが人間から軽侮される生活そのものが、実は人間にとって意外な祝福をもたらす所以になるのである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は手をその方へ掲げて、彼等を祝福した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの大家プランクはこの論文を見て驚いてこの無名の青年に手紙を寄せ、その非凡な着想の成効を祝福した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の説だというのに拠れば、社会の祝福が単に制度をどうしてみたところでそれで永久的に得られるものではない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋では「老」といふ言葉に無限の祝福が含まれて居り、イデアが指示されてゐるからである。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私より少しでも年若く、私より更に新らしく生れて来た二つの相似た霊魂の為めに祝福し、更に甚深な肉親の交歓に酔ふ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ君の魂に祝福あれ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我々の懐かしい祖父の尊霊が此席の上に、祝福を降しつゝ飛翔してお出になると云ふことは、わたしの疑はない所である。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから附け合せの蒸米を取つたが、その様子は先代の主人にも、先先代の主人にも、フイレエ肉を差し上げたことのある、この老人の顫えてゐる手から、祝福を受けるのかと思はれるやうであつた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がその薔薇の花で飾られて、異樣に祝福されてゐるのを。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズ・バンド、マルセル・シュオブに似たセロ弾き、グロテスクな洋服師思い出すボンベイの過去、いまではロシアで苦心｜惨憺アンナ・ニコロを祝福して、私は最期迄知ってしまう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のパートナアが酒果の祝福を私に与えてから私が日本人である故貴方は油断のならぬ国民である、今後彼女西欧の人種は日本人によって不幸になるであろうことなど臆測を交えて語り出すのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下の御健康と御国の未来を祝福して！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「選りに選つて奴が落ちるなんてよつぽど運が惡いや‥‥」と、一人はまたそれが自分でなかつた事を祝福するやうに云つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "方位によつて従来行動の吉凶祝福を申しまするのも、二千年も前の慰繚子といふ兵法家が既に嘲笑つて居りまして、方角の好否で戦の勝敗が定まつて堪るものかと申して居ります位です。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の木立ちも行きかう電車もすべての常住的なものがひどく美しく明るく愉快なもののように思われ、歩いている人間がみんな頼もしく見え、要するにこの世の中全体がすべて祝福と希望に満ち輝いているように思われた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか彼らが人間から軽侮される生活そのものが実は人間にとって意外な祝福をもたらすゆえんになるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを祝福する内意もあり、わづかではございますが、奉仕させていただきたく存じます。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを祝福する内意もあり、わずかではございますが、奉仕させていただきたく存じます。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか僕の友のために、杯をあげてくれたまえ、彼の将来を祝福して！",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の言葉で言えば貴様は運命に祝福されて居る方、貴様の言葉で言えば僕は不幸な結果を身に受けて居る男です。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……安心しろ貴様たちを祝福してやるんだ、俺は死を賭して貴様たちに加勢してやる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れだって粗忽な真似はし無えで、兄弟とか相棒とか云って、皮のひんむける位えにゃ手でも握って、祝福の一つ二つはやってやる所だったんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして戸部とともちゃんとの未来を祝福しようじゃないか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは彼等の為に祝福してやらねばならぬ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "△　△　△△華やかな春にあこがれていられる石花菜君の若々しい感情を祝福する。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
