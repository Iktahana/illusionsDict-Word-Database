          "literary": [
            {
              "text": "「これはたんなる脂肪腫だ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「するとその脂肪腫も、何かそれと関係あるのかい？",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「脂肪腫というのは、遺伝するものかな」「なぜ？",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その脂肪腫というのは、体に害をなす輩じゃないんだね」「そう。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エーベルス・パピルスは傷（咬傷、火傷、虫刺傷）、異物、壊疽、膿の蓄積、膿疱、悪臭を放つ膿瘍、新生物（脂肪腫、頸の膿瘍、腺の腫大、乳腺の腫脹）、体躯および四肢の外部の病気（膿疱、打撲傷、水ぶくれ、硬化、など）、および痔、などを取り扱っている。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
