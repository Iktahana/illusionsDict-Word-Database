[
  {
    "uuid": "bd81d841-1e67-520d-8bb9-a03ecde64da0",
    "entry": "親密",
    "reading": {
      "primary": "しんみつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
