      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "intimacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぜ私は、こんな男から逃げ出さずに、かえって親密になっていったのか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "師と子規と親密になったのは知り合ってから四年もたって後であったが懇意になるとずいぶん子供らしく議論なんかして時々｜喧嘩などもする。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "審査員というものには通例話の纏まりやすい二、三人というところが選ばれ、その親密な合議で事を決するようになっているものらしい。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶井君と三好君との交際は、側で見てさへ羨ましいほど親密で、しかも涙ぐましいほどに純情だつた。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして牧水氏との友情は、さまで親密とは言へないながら、お互に深い敬愛と好情とを感じ合つて、割合に長く續いてゐた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兄の要求した通りに、我々は親密に和合して、今日彼の第八週年忌の祭を施行するのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでずっと昔から知り合っている中のように、極親密に話したのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お富は朋輩の中でもお秀とは能く気の合て親密しい方であるからで。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、姿を見せないで大きな結果だけを残して行った「盗賊」と、形は見えないがわが家の生活に大きな変化をもたらした「げじげじ」とが幼時の記憶の中で親密に握手をしている。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一中根の叔父が銀行の頭取、そのほかに判事さんもいた、郡長さんもいた、狭い土地であるからかねてこれらの人々の交際は親密であるだけ、今人々の談話を聞くと随分粗暴であった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教では、この大きな天地も、私たち小さな人間のいのちも、その根もとで一つに親密に繋がり融け合って、分け距てがないことを教えております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は、このＴ老学士には、中学校の師弟以上の親密な指導を受けていた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ私に向ひ『貴君、今本艦水兵と貴君の同伴者なる武村兵曹との談話によると、貴君等は、我が最も親密なる海軍大佐櫻木重雄君と縁故の人の樣に思はれるが、果して左樣ですか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "年少のぼくに彼女がそんな身の上話をきかせてくれた、と言うよりむしろ、ぼくが巧くそうさせたと言うことの満足と、そういう話をしたということがお互いの親密の度を増したという喜びのためなのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に轡川がぼくを嫉妬したということは、之まで何の関係も無かった二人が少くとも轡川の想像の中では、たとえ仮定的にしろある種の関係をもっていることになるので、無意識の裡にぼくらの親密の度を増して行くことに役立ったのだろう。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がスフィンクスであったにしても、私共はともかくその位の親密な体裁にはいきおいならざるを得なかった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あんまり有名な方じゃありませんから多分御存知ないでしょうけれど――イヤ、でも僕は坊城君とは非常に親密な間柄なんだから、清水って名前位は坊城君からお聞き及びになっていらっしゃるかも知れませんねえ。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの主人でも、抱えとお客とあまり親密になることは禁物なんだわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいっそう親密にもなれよう。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究生は上級生まで集めて十人ほどでかなり親密だった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな天才生活時代の前生涯と、今のプライヴェート生活のような親密な性情と両面持っている……」　かの女とむす子がプライヴェートな会話に落ちこんでいると見たらしく、アルトゥールは非常に軽快なアクセントで、他の連中に講演口調で喋っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は、このＴ老学士には、中学校の師弟以上の親密な指導を受けてゐた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どういふ原因が其処にあつたものか、ともかく女同志の親密な気持ちには時々はかり知れない神秘的なものが介在してゐるかと思へば極々つまらない迷信にも一大権威となつて働きかけられる場合もないではないぢやありませんか。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か親密な話を切り出す機会を捉えようとじれているらしい。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ私は、こんな男から逃げ出さずに、かへつて親密になつていつたのか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りと雖も相互に於ける身分の貴賤、貧富の隔壁を超越仕り真に朋友としての交誼を親密ならしめ、しかも起居の礼を失わず談話の節を紊さず、質素を旨とし驕奢を排し、飲食もまた度に適して主客共に清雅の和楽を尽すものは、じつに茶道に如くはなかるべしと被存候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く観じ来れば、後に到って、この藤野先生と周さんと私と三人が結んだあの親密な同盟も、何の事は無い、日本語不自由組の同気相求めた結果のものに過ぎなかったのではないか、と情け無い気持にもなるが、しかし、それは、あまりにもふざけた冗談の推論かも知れない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の樣な交通の便利の時に、東京から遠くない所にさう云ふ者を求めると云ふ事は第一無理であるが、然し舞臺と見物とは非常に親密である。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は人より先きに起き、飯櫃の蓋の簾から炊き立ての御飯の親密な匂いをさせ、丸盆を取って母や嘉六に給仕もいたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
