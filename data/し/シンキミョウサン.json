        "examples": {
          "standard": [
            {
              "text": "敵の動きを読み切った彼の采配は、まさに神機妙算としか言いようがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの将軍の戦術は、常に神機妙算で敵を翻弄した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の事業成功の裏には、誰もが驚く神機妙算があったに違いない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "敵に計ありと覚れば、うかと長追いはして来ないだろう」　諸将は、それこそ帝の神機妙算なりとたたえた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
