[
  {
    "uuid": "b3d45d9f-5321-53bf-bb8c-04d20765449f",
    "entry": "審査",
    "reading": {
      "primary": "しんさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
