[
  {
    "uuid": "cc36ee6b-7d44-5134-930f-71db61378a4e",
    "entry": "下側",
    "reading": {
      "primary": "したがわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
