    "definitions": [
      {
        "index": 1,
        "gloss": "trial product",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その試作品をなんどか見せてもらって感服した。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この第九室は、博士が試作品を入れておかれる部屋なんです。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アネットは試作品ですから、特別の符号でないと通じないのでございますよ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アネットは作り上げられてから、もう何週間もこの部屋で試作品の世話をして働いていたのです。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエディターを含むソフトウエアは、マスクＲＯＭに焼かれ、試作品に組み込まれて評価された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、たくさん作った生きている金属の試作品の中で『骸骨の四』がまっ先に、生きている金属となったのだ、そこでこれを金属Ｑと名づけた」「なるほど」「いま、きみが見たのは、金属Ｑだけではなくその金属のまわりを、人工細胞十四号が包んでいるものだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと昔は、科学力において、世界の第十何位かにあった日本は、新体制をとってから、めきめきと科学力を増強し、二十五年後には、右にのべた原子弾破壊機の第一試作品をつくり上げることに成功し、それからこっちへ五年、とうとう、世界に魁けて、強力なるその機械を十万台から整備するようになったのである。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、それが多量にないため、試作品ということにして、ストックされていたのです。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、試作品だからね。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、試作品です。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「試作品をべらぼうな値で押しつけられちゃあ、こっちがたまりませんね。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、試作品はいつも最優秀品ときまっていますよ。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、その種の試作品だったかもしれない。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学に於ける日本主義は国学的・農本的・東洋主義的・精神主義的・又ナチス的・等々の試作品を産んだが、この一年間の傾向は、そうした露骨な体系を特に表面に出さぬようになったと共に極めて間接な表現をさえ取るに至ったが（風土論の如き）、文化理論其の他に次第にその傾向が浸潤し始めている。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "博物館へ行ったときに、一〇年かかって作った試作品をご覧に入れましょう。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の試作品や重要な書類などを、大阪や京都やの支社とか本社などに、直接汽車にゆられて運んで行く。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――」カタリナはそう云って、三角｜棚の下の段から、第一回の試作品である舞妓の人形を出して来た。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さいしょの試作品として、つくったのが、今、世間をさわがせている透明怪人第一号だ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時幾種かの試作品を示され、私の意見を求められた。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいるのは、その人の試作品なの。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
