    "definitions": [
      {
        "index": 1,
        "gloss": "copying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "デュパンはそれを念入りに調べて紙入れにしまい、それから写字台の引出しの錠をあけ、そこから一通の手紙を出して、総監にやった。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "『書物の出現』を書いたアンリ＝ジャン・マルタンは、「買い手が印刷術という新しい方法に胡散臭さを感じていた」であるとか「写字生たちに気づかれてその神経を逆なで」しないため、といった諸説を否定してこう結論づけています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "写字をしたり口授を筆記したりして私の仕事の手伝いをしていた。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬吉は、最初はノートの写字や、筆耕などをやつて来たが、夫は二人を養ふのに十分な職業ではなかつた。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマとギリシアの国家の隆盛期には奴隷の数が人民の大多数を占めていたのであるが、彼らの中の少数な学識ある奴僕たとえば写字生のようなもの以外のものは精神文化の進歩を享受することを許されていなかった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭様で、写字をして、だいぶ原稿が儲かる訳になるのだがね。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃伊沢では病源候論を写してゐたので、山陽は写字の手伝をした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にはこの写字という仕事の中に、千変万化の、楽しい一種の世界が見えていたのである。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある長官は親切な人で、彼の永年の精励に報いんがためにありきたりの写字よりは何かもう少し意義のある仕事をさせるようにと命じた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつちへ行つてくれ」「僕は、一昨日まで、写字と翻訳をやつてゐたんです。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "写字は一行一｜文、翻訳は一行二｜文です。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外一頁五銭程にしか当たらぬ写字を夜の更けるまでやった。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく写字の錯誤ではなからうか。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在は麺麭のためにする写字である。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "足のとれた写字机、石版画、セーブル焼の置時計、手風琴、金｜鍍金の枝燭台、古甕……鎧扉の隙まからさしこむ光線のほそい縞の中で、埃をかぶった古物が雑然とその片鱗を浮きあがらせている。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾窓のなかには、脚のとれた写字机や、石版画の西洋の風景や、セエブル焼きの置時計、壊れた手風琴、金｜鍍金の枝燭台、さまざまな壺や甕、赤く錆びた三稜剣。",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "写字机と置戸棚の間にあった三稜剣が壁の隅のほうへ寄り、前列にならんでいたジャヴァの土壺がすこしばかりうしろへひきさげられ、そのかわり、今までは横側しか見えなかった油絵が、正面に向きかえられている。",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "『但し、本書に収録された通信は、全部がイムペレエタアから出発し、そしてレクタアがその写字生をつとめたものである。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャヴァノン村から来た人です」とわたしは写字机に向かっていたきたならしいばあさんに向かって言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大学を出たばかりの文学青年で、写字と翻訳の下｜請負で細々と暮していた時ですが、窓の外に立った美声の少女の、雨に濡れた蒼白い顔が、十何年後の今でも忘れることが出来ません。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "食魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある写字台によって、大きな帳簿になにか書いていた一人の若い娘――鉢巻リボンと大きすぎる足とを持った栗色の髪のかわいい少女が、彼のほうへやって来て、何御用ですか、と愛想よく問うた。",
              "citation": {
                "source": "神の剣",
                "author": "GLADIUS DEI",
                "note": "青空文庫"
              }
            },
            {
              "text": "書く術を知らないという非難が、それらの写字生どもによって幾度となく彼に発せられた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "尨大な外来経典の写字、校正、装幀、勘出人、などの各課にわかれて、長期な筆耕仕事に一生をつぶしてゆく。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん彼らの写字仕事なるものも、年度年度の途切れやら、しばしば後続きのしない場合などあって、その職場保持は何よりも彼らの念頭におかれていたものらしい。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "写字者が一頁を、薄い透明な紙に書き、この紙を表面を下に版木にはりつけるから、透いて見える字はひっくり返しになる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれにしても烏組の奴らめ、市中へ入り込む早々にして、こんな放れ業をするなんて、随分腕がたっしゃじゃアないか！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
