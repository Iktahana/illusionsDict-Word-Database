  {
    "uuid": "503a354e-9a87-53a2-b92d-6a1d609205a8",
    "entry": "社寺",
    "reading": {
      "primary": "しゃじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shrines and temples",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お揃ひで社寺へお詣りなさる事も度々ございましたし、またお花見や、お月見、また船遊びなどには、いつも御台所さまをお誘ひになり、殊にも和歌会や絵合せの折には、御台所さまは、それこそ、なくてかなはぬお方で、将軍家に京風の粋をお教へ申し上げるお優しい御指南役のやうにさへ見受けられました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十七になるこの老女は、わたくしが無断家出したのを矢張り心配して、近くの社寺へ祈祷を頼みに行ったりしていたそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗徒勢は城下の民家社寺を焼き払って陣を布いた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "文永弘安の両役に於ける莫大なる戦費は勿論、その前後に於ける辺海警備の費用、諸社寺に於ける祈祷に対する恩賞などで、鎌倉幕府の財政は、漸く窮乏を告ぐるに至つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは公園や社寺の池に麩を投げた時に集つて来る鯉の趣に似てゐるがその多さは比べものにならなかつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "這ひのぼりてゆけば、その極まる處、社寺に見るが如き手洗鉢の形を成し、穴の幅三寸ばかり、水之に滿つ、巖中より滴り出づるにや、手を入るれば、水、肱に及ぶ。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬研堀と、仲橋広小路の市は、社寺の境内でなく、往来に立ったのだから、その地割がその筋でやかましく、いろいろ干渉されますので、土地の世話役は旨く極め合いを附けるのが骨が折れたものです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "歳の市のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "御領内に鎮座まします御社でござるゆえ、御身のものと申さば御身のものじゃが、社寺仏閣の公事争い訴訟事は寺社奉行様御支配じゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは公園や社寺の池に麩を投げたときに集まってくる鯉の趣に似ているが、その多さは比べものにならなかった。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（12）『遠野古事記』という写本の第三巻、社寺縁起の巻にでもある話だろう。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "れっきとした大家の古文章古記録に載らず石塊か古墳かがなくてはならず、社寺、堂宇等の縁起書に拠らねばならぬ調査法のみが学問ではなくなった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "松山で多いのは――医院、社寺、おでんや三月二十日　曇、春らしく、晴。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、一切の地主、皇室及び社寺の所有土地の無償没収、農民への交付。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後古社寺保存会の用件で、私は幾度奈良京都に出張したか知れませんが、この初旅の時が一番正直に見て来ております。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "奈良見物に行ったことのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "明珍恒男君は深川｜森下の生まれ、初めは私の弟子で、後美術学校入学、卒業後、古社寺保存会の新納忠之介氏の助手として奈良に行き、古彫刻修繕の方を専らやっている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "古社寺保存会の用向きで紀州熊野に行きそのまま帰らず、今日は消息も絶えている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "このため、一八九七（明治三〇）年には古社寺保存法が制定された。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術的国宝を社寺とひきはなすことも緊急である。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃奈良に工藤精華という八十幾歳かのお爺さんで写真を写す一風変った人があって、まだ御維新で充分に整理のついていない社寺の仏像や絵巻などをうんと撮影していた。",
              "citation": {
                "source": "土田さんの芸術",
                "author": "土田麦僊追悼",
                "note": "青空文庫"
              }
            },
            {
              "text": "全国の石高を幕府、諸大名、御料、皇族並公卿、社寺に配当したのを見るに、左の通である。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある相当立派な西洋建築の研究家がわが国の大社寺の実に完備していることを認め、これを称揚したのは全くほんの最近のことである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "北陸道は西本願寺の信徒多き土地なれば、使僧等は常に先発して社寺奉行及び各宗の寺院を集め、王政維新の御趣旨、幕府の罪状等を演達し太政官の大号令を諭示して、更に之を諸民に伝へしむべし。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も文化の進展と共に、算木卜占術を傳習して算所となり、更に社寺豪族に隷屬する下賤の奴僕となつて散所と呼ばれたのであらう。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行団体の色彩をもち、社寺をはなれて、信仰行事の色彩なしの芸能となります。",
              "citation": {
                "source": "無頼の徒の芸術",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "社寺に保護せられた奴隷の村に伝承せられて来た、主としては農業関係のまじなひとも言ふべき形の演劇が、社寺以外に行はれる様になり、村を基礎とした座の組織が、次第に専門化し、職業化して行つた。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "社寺の芸奴なる神人童子の群れを基礎とした組合――座――から発足して居る。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅は内務省の社寺局へ出て四十円の月給を貰っている。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれにしても烏組の奴らめ、市中へ入り込む早々にして、こんな放れ業をするなんて、随分腕がたっしゃじゃアないか！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
