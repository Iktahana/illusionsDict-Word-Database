          "literary": [
            {
              "text": "私はロータスの出張店へ入つて行つた。",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハルミさん一昨年の夏とかに、避暑かたがた軽井沢へ美容院の出張店を出していたのよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の身内にあたるという出張店をあずかっている若い男が、お今のことでちょいちょい浅井を訪ねて来てから、浅井もおのずからその話に肩を入れないわけに行かなかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十九　仮にお今を迎えるための室の家が、出張店の人たちによって、じきに山の手の方に取り決められた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎から代りに出て来た室の親類の人たちや、出張店の店員などが、それに連なって居並んだ。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店の中に銀座にある出張店が一軒あつて、なりの高い緑色のあんどんのやうなスカートをはいた女の子がいて、お茶をはこんで來たが笑つた顏を見せたことがなかつた。",
              "citation": {
                "source": "巷の子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは徳山の何かの店が出張店を出すためその弟家族をよびよせた由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は座員一同鎌倉の海で慰労会といふ日、駅からすぐ海岸へ、日本茶館の出張店で休む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
