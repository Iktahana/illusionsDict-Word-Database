    "definitions": [
      {
        "index": 1,
        "gloss": "quotation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その演説の要旨の中から、少しばかり抄録してみる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（附記）　以上はほとんどすべて Robert John Strutt すなわち現在のレーリー卿の著書“John william Strutt, Third Baron Rayleigh”から抄録したものである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は近着の Geographical Review. Oct., 1932. 所載の記事から抄録したものである。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他旧作に於ても、削除すべきは割愛し、抄録の分も更に改訂を敢てした。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時代の銭湯と今日のいわゆる浴場とは多少の相違があるので、何かの参考までにその一部をここに抄録することにした。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この早稲田本を早大に移る以前に抄録解説したのが饗庭篁村氏の『馬琴日記抄』であって、天保二年の分を全冊転印されたのが和田万吉氏の『馬琴日記』（原本焼失）である。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "饗庭氏の抄録本もしくは和田氏の校訂本によって馬琴の日記を読んだものは、誰でもその記載の事項が細大洩らさず綿密に認められたのを驚嘆せずにはいられない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩愛誦家の中にはママ諳んずるものもあるが、小説愛好者、殊に馬琴随喜者中に知るものが少ないゆえ抄録して以てこの余談を結ぶ。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "寅二郎は、着替えの衣類二枚と、小折本孝経、和蘭文典前後訳鍵二｜冊、唐詩選掌故二｜冊、抄録数冊とを小さい振分の荷物にした。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今その書中、緊要の章句を少しく抄録せんに、云く、一切の書を見るには先づ題號を解するを簡要とす次には其の書の部類を分別すべし是れ目録學の綱領を摘出したる者なり。",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "手帳は富士川游さんが嶺松寺の墓誌銘に就いて抄録したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本医学史には此抄録が用ゐてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　書牘はこれより無仏斎が二著の抄録に入る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百十三　狩谷※斎の西遊にして、此年辛巳以前に係るものは、これを三村氏の抄録中に索むるに、下の如くである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はスミスの思想についても、これをここに詳しく語るの余裕を有せぬが、わが賢明なる読者は、以上掲げし一二の抄録によって、その個人主義のほぼいかなるものなるかを推知せらるるであろう。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋のランプの下で書いた日記の抄録に止めます。",
              "citation": {
                "source": "日光小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先年『斯文』といふ雜誌の孔子追遠號に、孔子の人格に關する私見を披瀝して置いたから、之を抄録して茲にその大要を紹介する。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『成吉思汗實録』が出版されて間もなく先生を訪うた時、先生は尨然たる草稿を示されて、『成吉思汗實録』著述の際、蒙古に關する漢洋の史料を渉獵した間に、種々從來氣附かなんだ事柄を發見して、一寸抄録したのが是だけある。",
              "citation": {
                "source": "那珂先生を憶ふ",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ゴンクウル兄弟が書いた同夫人の伝記などは西洋流美人の見方に就てのよい一例となるだらうと思はれるから、左に抄録してみよう。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿等にして若し、予が煩悶の跡を見んと欲せば、請ふ、以下に抄録せんとする予が日記を一瞥せよ。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「余が言文一致の由来」は、改造社版「現代日本文学全集第十巻」「二葉亭四迷集」から抄録したもので、同集の年譜によると、この談話は――二葉亭のした談話の筆記で、明治三十九年五月の雑誌「文章世界」に載せられたものである。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日読んだ書物の中から備忘のため抄録して、そのままに捨てて置いた紙片である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　二ヵ月｜後甲野さんはこの一節を抄録して倫敦の宗近君に送った。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此本を獲て幾分損失を恢復した樣な氣がしたものの、此書は門人に示す爲めの抄録のごとく思はれ、概要を瞰ふことは出來るが、内容の上にも修辭の上にも著しい差異があつて、同一人の著述としては甚だ見劣りがするのである。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、偶然この作の発表された直後に書いた感想が手許にみつかつたから、それを抄録すると、「……この『もやもやした考へ』は、いかに努力をしてみても追ひ払ふことはできない。",
              "citation": {
                "source": "「風俗時評」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広告文をここへ抄録してみよう。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一　法然が常によく云いつけていた言葉のうちから幾つかを抄録して見る。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分け方を見ると、大分鄭樵の議論の影響を受けたことが分り、幾分これに據つたであらうが、極めて簡單に、しかも多くは自ら筆を執らず、他人の書を抄録し、それによつて自然に歴史が大體分るやうにしてあるところは、後來の王應麟などの學風をすでに開いてゐるやうである。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に巡回文庫は、未だ本邦に例なきが故に、今、当事者の調査したる米国巡回文庫中の一節を抄録して、本誌に収めて読者の参考に供す　一、米国において図書館令を発布したるは、ニユーヨーク州をもって始めとす。",
              "citation": {
                "source": "米国巡回文庫起源及び発達",
                "author": "佐野友三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に之を抄録して読者の一※に供しよう。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
