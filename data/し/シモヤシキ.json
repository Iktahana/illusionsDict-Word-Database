[
  {
    "uuid": "ae408439-e7f8-5a61-b241-32b165b4d911",
    "entry": "下屋敷",
    "reading": {
      "primary": "しもやしき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
