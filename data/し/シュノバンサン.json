        "examples": {
          "standard": [
            {
              "text": "教会では、イエスの受難を記念して主の晩餐の礼拝が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "主の晩餐において、パンはキリストの体を、ぶどう酒は血を象徴する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "聖餐式とも呼ばれる主の晩餐は、キリスト教の最も重要な儀式の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "開場式のお歴々の群集も畢竟一種の囚徒で、工場主の晩餐会の卓上に列なる紳士淑女も、刑務所の食卓に並ぶルンペンらも同じくギャングであり囚人の群れであるように思われてくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし信者たちは熱心に聖餐を受けることを望み、復活祭の週の木曜日即ち主の晩餐の日には三十余人の信者が聖餐を受けた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
