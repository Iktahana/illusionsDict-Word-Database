        "examples": {
          "standard": [
            {
              "text": "シーラカンスは「生きる化石」と呼ばれ、太古の姿を今に伝える貴重な魚だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深海でシーラカンスが発見されたというニュースは、多くの科学者を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水族館の特別展で、シーラカンスのレプリカが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "以前に、『イグアノドンの唄』という大人のための童話を書いたことがあるが、その中の主人公の一人、すなわち南アフリカ喜望峰の一角に突如として出現した一億年前の化石魚シーラカンスなども、もちろんその一つである。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
