    "definitions": [
      {
        "index": 1,
        "gloss": "before meals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕食前の数分間には子供部屋をおとずれている彼を見かけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事のあとでりんごか何か食っていたようであったが、とにかく三人のムードが、食前とはすっかり一変して、なんとなく気重く落ち着いた、眠ったいような雰囲気がその食卓の上にただよっているように感ぜられた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、食前の日光浴をしにヴエランダへ出た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は上り框に腰かけて、何の恥らう様子も無く、悪びれた態度もなく、大声をあげて食前の誦文を唱え、それから悠々と箸を執った。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の烏　御同然に夜食前よ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜が明けて朝食前。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "食前、食間は勿論である。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬でも朝食前に一汗かかぬと気持ちが悪かったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達も、休み中なるべく早起きの習慣をつけたいと思っていますから……」準之助氏は、新子をうながすように、小径を先に立って歩きながら、「じゃ、朝食前に、小太郎に読み方と算術を教えて下さい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、私達は食前の運動に来たと云うだけだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間のあいだはずっと妙に落ち着かない様子で、しきりに窓から外をのぞいて、いつも夕食前になさっていた短い散歩もおやめに。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの夕食前の摩擦の時にも、助手さんたちは固パンに向って英語を色々たずねて、「ねえ、教えてよ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼の有名な悪食家であることを知つてゐる、だから食後の不浄の歌をきくことを好まない、そしていま朝の鴉の、食前の空腹の歌を嬉しく思はれる。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝も、また食前に、我を待たずして行き、食後もまた行く。",
              "citation": {
                "source": "親馬鹿の旅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "數日前支那旅行の歸りがけにわざ／＼其處まで訪ねて來て呉れた地崎喜太郎君が上海からの土産物の極上ウヰスキイを二三杯食前に飮んだのがきいて、まだ膳も下げぬ室内に仰臥してうと／＼と眠りかけてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大阪に行かんか」　と父から相談をかけられたのはその朝食前の、応接間での出来事でした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして何喰わぬ顔で朝食前の散歩に出かけました。",
              "citation": {
                "source": "卵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "食前の祈祷10・17（夕）　仏教信者は食事をする時、先づ飯を一｜箸とつて仏に供へる事を忘れない。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人役は勿体ぶつた顔つきをして、「恐れ入りますが、食前のお祈祷を貴方にお願ひしたいものですな。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈々皆が箸を執らうとすると、老つた市村氏の父は食前の祈祷を始めた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食前の感謝も、極く簡単にやった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度々々の食前の祈祷すら廃している。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると夫婦は一階ずつ梯子段を踏む音をさせて降りて来て、入念に食前の感謝をささげた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捨吉、貴様はまだ昼食前だろう、まあ飯でもやれ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑然紛然とした空気の中で、伊勢崎屋へ来て就く奥のチャブ台の前で、十年一日のような信仰に生きて来た真勢さんがそれとなく捧げる食前の祈祷に、人知れず安息日を守っているということは、更に捨吉を驚かした。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昼食前に樹明君が来て、山口へ出張するから同伴しようといふ、一も二もなく出かける。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、何のために西比利亜を通過するか、宗教は―― if any 何を信ずるか、たべ物はなにが好きか、朝は大体何時に起きるか、習慣としてお茶をのむか飲まないか、もし喫めば食前か食後か等々すべての個人的告白を強要される。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、食前にあれだけの蛮勇をふるうんだから、自然運動にもなって近代人にはことに適しているだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
