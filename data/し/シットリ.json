    "definitions": [
      {
        "index": 1,
        "gloss": "damp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし池畔からホテルへのドライヴウェーは、亭々たる喬木の林を切開いて近頃出来上がったばかりだそうであるが、樹々も路面もしっとり雨を含んで見るからに冷涼の気が肌に迫る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがそぼふる秋雨ににじんで、更にしっとりとした情趣を帯びていた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路は清潔に掃除されて、鋪石がしっとりと露に濡れていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "至るところに日影が深く、町全体が青樹の蔭のようにしっとりしていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原や、斜丘にころびながら進んで行く兵士達の軍服は、外皮を通して、その露に、襦袢の袖までが、しっとりとぬれた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お柳は男の背に手をのせて、弱いものいいながら遠慮気なく、「あら、しっとりしてるわ、夜露が酷いんだよ。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっとりと腕に重い、この魚のようにはつらつとした肉体の圧迫に、私は酔心地どころではなかった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶四郎は無造作に傍の石に腰かけてしばらく莨を喫っていたが、やがて、しっとりとした声で言った。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌も皆三にむかっていると、あれほど気嵩で散漫だと思う自分がしっとり落付き、こまかく心が行届いて、無我と思えるほど自分には何にも無くなり、ひたすら皆三の身の囲りの面倒を見てやり度くなるのであった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて四阿の向うに来ると、二人さっと両方に分れて、同一さまに深く、お太鼓の帯の腰を扱帯も広く屈むる中を、静に衝と抜けて、早や、しとやかに前なる椅子に衣摺のしっとりする音。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……銀貨入を握った手が、しっとり汗になりました。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……上衣無しで、座敷着の上へ黒縮緬の紋着の羽織を着て、胸へ片袖、温容に褄を取る、襲ねた裳しっとりと重そうに、不断さえ、分けて今夜は、何となく、柳を杖に支かせたい、すんなりと春の夜風に送られて、向うから来る姿。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長襦袢の浅葱の褄、しっとりと幽に媚めく）それへ、唯今それへ参りまする。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、砂がついて、あれ、こんなに、」と可怨しそうに、袖についた埃を払おうとしたが、ふと気を着けると、袂は冷々と湿りを持って、塗れた砂も落尽くさず、またその漆黒な髪もしっとりと濡れている。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "垢抜して色の浅黒いのが、絞の浴衣の、糊の落ちた、しっとりと露に湿ったのを懊悩げに纏って、衣紋も緩げ、左の手を二の腕の見ゆるまで蓮葉に捲ったのを膝に置いて、それもこの売物の広告か、手に持ったのは銀の斜子打の女煙管である。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蔭から、しなやかな裳が、土手の翠を左右へ残して、線もなしに、よろけ縞のお召縮緬で、嬌態よく仕切ったが、油のようにとろりとした、雨のあとの路との間、あるかなしに、細い褄先が柔かくしっとりと、内端に掻込んだ足袋で留まって、其処から襦袢の友染が、豊かに膝まで捌かれた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙のあとの森も屋根も、市街はしっとりと露を打って、みはらしの樹の間の人影は、毛氈とともに仄暗い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言わるるごとにひやひやと身体に冷たき汗しっとり、斬刻まるるよりつらからめ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔には桃の露を帯び、眉に柳の雫をかけて、しっとりと汗ばんだが、その時ずッと座を開けて、再び燈を蔽うて住った、夫人を見つつ恍惚と、目を円らかに瞻った、胸にぶらりと手帳の括に、鉛筆の色の紫を、太白の糸で結んで、時計のように掛けたのは、総六の娘お鶴。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪におされて、羅は、その、あの蹴出しにしっとり離れて、取乱したようですが、ああした品の可い人ですから、須磨の浦、明石の浜に、緋の袴で居るようでした。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の手にも涼しいほど、しっとり花が濡れましたよ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "褄を高々と掲げて、膝で挟んだあたりから、紅がしっとり垂れて、白い足くびを絡ったが、どうやら濡しょびれた不気味さに、そうして引上げたものらしい。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五株、六株、七株、すらすらと立ち長く靡いて、しっとりと、見附を繞って向合う湯宿が、皆この葉越に窺われる。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、戸前が松原で、抽でた古木もないが、ほどよく、暗くなく、あからさまならず、しっとりと、松葉を敷いて、松毬まじりに掻き分けた路も、根を畝って、奥が深い。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しっとりとした、いい容子ね、目許に恐ろしく情のある、口許の優しい、少し寂しい。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外の広場の一廓、総湯の前には、火の見の階子が、高く初冬の空を抽いて、そこに、うら枯れつつも、大樹の柳の、しっとりと静に枝垂れたのは、「火事なんかありません。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸浪は西洋風に手を動かす癖が眼立ちましたが、千代はおちついてしっとりと好く演じていました。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっとりと落着きながら、ほのぼのと明るい感じの住居だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しきり人出の減った海は何処か空の一隅の薄曇りの影さえ濃やかな波の一つ一つの陰に畳んでしっとりと穏かだった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
