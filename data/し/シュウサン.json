  {
    "uuid": "a813bad4-42b9-507f-abaf-3afbf2533697",
    "entry": "聚散",
    "reading": {
      "primary": "しゅうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "collection and distribution",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しなやかに細い多くの線をなして麗はしく輝やかしく落下る美しさは、恰も纖く裂いた絖を風に晒して聚散させたを觀るやうな感じである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の離合聚散の測り難きこと、また今更に驚かれぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く古書の聚散遷移の迹を識つてゐる人の教を乞ひたい。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此詩は茶山と波響との交を知る好資料であつて、啻に甲子舟遊の発端を見るべきのみでなく、寛政より文政に至る間の二三聞人の聚散の蹤がこれに由つて明められる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "離合｜聚散、共に自由にならない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで段々書物の聚散して來た由來を書いたゞけで、何の評もありませぬ。",
              "citation": {
                "source": "支那の書目に就いて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂、天に帰すとは、消散の意なり」と）程子曰、聚為精気、散為遊魂、聚則為物、散則為変、観聚散則鬼神之情状著矣、万物之終始不越聚散而已、鬼神者造化之功也。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "聚散をみるときは、すなわち鬼神の情状｜著わる。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物の終始、聚散を越えざるのみ。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、貝原益軒の『自娯集』（巻七）に曰く、「天道流行、発育乎万物、陰陽之運、乃天之道也、二気聚散無窮、聚則生、散則死、二気之霊在人身者、謂之魂魄、人身所受、二気与魂魄、猶陰陽与鬼神、非有二也、蓋魂魄者、其主而霊者而已矣、故二気消散、則魂魄亦随而亡矣、然則身死後、魂魄豈復可留滞于天地之間乎。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "安んぞ知らん、彼等は何も縛束せらるる程の義務もなければ、恩愛もなしとて、都合次第に聚散離合、所謂相手代れど主は不替との俗諺に墜り、此間、人に被欺、人に被売、数年の後、始めて、其謀略の非なるを悟るべし。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
