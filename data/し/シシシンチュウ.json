        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "谷山家の獅子身中の虫となって、私を半狂人になるまで苦しめ抜く計画を、冷静にめぐらしていたケダモノが、その新聞記者だったのです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶吉に肱鉄砲を食ッて、鳶頭に懐中の駒下駄を焼かれた上、人の妓を食おうとする、獅子身中の虫だとあって、内の姉御に御勘気を蒙ったのを、平蜘蛛で詑を入れて、以来きっと心得まするで、何卒相変りませず、今夜も来ている。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄吉　大かた獅子身中の蟲とでも云はれたのでござりませう。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ神聖なる真言の教えを冒涜する、獅子身中の虫といわざるを得ないのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先生は、自分は教育界｜獅子身中の虫だと言つて居られるの。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先生は、自分は教育界の獅子身中の蟲だと言つて居られるの。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「獅子身中の虫とはおのれが事……」　これは彼が弟を折檻する時の言葉であった。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際戦争反対をとなえるような者は獅子身中の虫だと、やっつける。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云う奴のあるのは塾の為めには獅子身中の虫と云うものだ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は官軍に内通している獅子身中の虫と見られ、ある夜のごときは数十人の兵にその身辺を取りまかれ鉄砲の筒口を一斉に向けられ硝煙に包まれたことさえあった。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕臣の中過激な者は、その安房守の遣り口を、手ぬるいと攻撃するばかりでなく、徳川を売って官軍に従く獅子身中の虫だと云って、暗殺しようとさえ企てた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子身中の虫をさえ、観破することさえお出来なさらない。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「獅子身中の虫とは、机博士、おまえのことだ、おまえは盗人のようにわたしの部屋へしのびこんだ。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちこそ、実に徳川にとっては獅子身中の虫だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも尋常の盗人ではない、お館を破滅に導こうとする、獅子身中の虫のような盗人なのだ！",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの紅梅派という獅子身中の毒虫へ宣戦布告をすべきときだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くより品川に到着しておりましたが、獅子身中の虫ともいいつべき、当道場内の一派の策動にさまたげられ、今日まで延引いたし、ただいまやっとまいりましたるところ、先生におかせられては、すでに幽明さかいを異にし……」　柳生源三郎！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んどそれは獅子身中の毒虫の行為だ。",
              "citation": {
                "source": "俳優への手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根の甚伍左獅子身中の虫だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず真剣になって心掛けているんだな」「野郎は帝大出でいながら帝大出の僕を馘ったんだから、獅子身中の虫だ。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、正三郎」「これが御家の獅子身中の蟲で御座います。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、正三郎」「これが御家の獅子身中の虫でございます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "訴訟を起して、お家の獅子身中の蟲を退治する積りだった父上の御心持はよく解るが、主君の亡びた今になって見れば、それは藪蛇であった。",
              "citation": {
                "source": "十字架観音",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根の甚伍左、獅子身中の虫だ、奸賊、斬らんか、仙太っ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは謀叛人だ、徳川にとって獅子身中の虫なのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり二人は獅子身中の虫になった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私は獅子身中の虫ということをいうた。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが獅子身中の虫というのである。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奴は日本にとって獅子身中の虫だ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子身中の虫が、逆に国民党に噛みついてきよった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
