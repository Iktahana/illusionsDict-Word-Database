          "standard": [
            {
              "text": "夜の林道で、街灯に誘われるように白灯蛾が舞っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "白灯蛾の幼虫は、特定の植物の葉を食べることで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昆虫図鑑で白灯蛾の美しい模様に見入ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "始発駅で、さけのつみこみを終って、戸をしめるすきにはいりこんだものだろうが、なにしろひとりで汽車へ乗りこんだくまもめずらしいというので、駅員たちがだいじに飼っていたが、二年あまりで死んでしまった。",
              "citation": {
                "source": "くまと車掌",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪にいたためか、あるいは町の上流家庭の視野を狭すぎると思ったせいか、むしろひとりですっかり引っ込んで暮していた。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            }
          ]
