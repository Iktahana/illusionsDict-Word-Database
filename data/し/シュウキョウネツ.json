          "literary": [
            {
              "text": "経済の圧迫した時に宗教熱が起るのは、凡ての国民の歴史だ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ等は真剣な仕事の宗教熱烈な祈願の宗教、純真な尊敬の宗教を唱道する。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝らの宗教熱心は俳優的扮装だ、所作だ。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教熱心はよいけれども、パリサイ人の固陋はいけない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
