    "definitions": [
      {
        "index": 1,
        "gloss": "officers and soldiers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
