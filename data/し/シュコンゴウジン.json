    "definitions": [
      {
        "index": 1,
        "gloss": "Vajradhara (vajra-wielding gods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
