  {
    "uuid": "491f2a4f-043a-5e1e-a142-ee6d132bb416",
    "entry": "神名",
    "reading": {
      "primary": "しんめい",
      "alternatives": [
        "じんみょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "name of a god",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "英米に最も盛んなゴッデム（神汝を罪す）又、デム何某（罰當りの何某）などは嚴戒の神名を呼ぶ上に、詛を兼ねた者故、極めて聞苦しい。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "……第一何と申すか、神名がおありなさらないのでありましてな、唯至って古い、一面の額に、稲荷明神――これは誰が見ても名書であります。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "野槌は最初神の名で、諾冉二尊が日神より前に生むところ、『古事記』に、野神名｜鹿屋野比売、またの名｜野椎の神という。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど同時に出来た『延喜式神名帳』、加賀に野蛟神社二所あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書の著者｜段成式かつて試みて六、七に至りしがそれ已外は乱れて弁ぜず、郭いわくようやく炬を益せばすなわち別つべしとありて、九影の神名を書いた物あったが虫に食われて紙面全からず皆まで分らぬと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江國の竹生島は今「チクブシマ」と發音するが、延喜式の神名帳によれば都久夫須麻神社とある。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに一方に於て、古事記には、綏靖天皇の兄神八井耳命は阿蘇君の祖なりとあり、又舊事紀の國造本紀には、崇神天皇の御代に、神八井耳命の孫の速瓶玉命を阿蘇の國造に定め賜ふとあつて、神八井耳命の子は健磐龍命と云ひ、延喜式の神名帳に祭られて居る神であるといはれてゐる。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち天照大神遙宮と延暦儀式帳、延喜式神名帳等にいへる者なり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷川士清の和訓栞「くぬぎ」の條に云く、神名式伊勢國度會郡に棒原神社見ゆ、こは棒字字書の義に違ひたれば欅原にて訓もぬをすに誤りたる也社地今田邊郷淺管村に在り萬葉集に　度會の大河のへの若歴木われ久ならば妹戀ひんかもとあり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名帳考證にも棒は欅字の誤也、久奴木の略語奴木原也、長谷街道也とあり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴氏の考に魚見社は神名祕書に機殿、儀式帳云、魚見社三前、月讀命、豐玉彦命、豐玉姫と見えたり、延喜式神名帳にも多氣郡魚見神社見えたり、麻積と關係ありげにも見ゆ。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "久奴須奴といへる神名も、古代の習として地名を取りたるべければ、之を華奴蘇奴に當てんと思ふなり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭姫命世記にも御櫛落し賜ひて、櫛田社、定賜ふことあり、儀式帳にも櫛田根椋の神御田奉ること見え、神名帳には多氣郡櫛田神社、櫛田槻本神社、大櫛神社等あり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛※玉命、櫛明玉命、天明玉命、天太玉命、豐玉彦命又倉稻魂命、宇都志國玉神など、玉、魂の語を有せる神名甚だ多し。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "間智は宇麻志麻遲命の麻遲に同じく、荒木田守良が鹿龜雜誌富岡氏藏本に麻遲の名の古書に見えたるを擧げて、宇麻志麻遲命の外に神名帳の遠江國佐野郡｜己等能麻知神社、近江國高島郡麻知神社、及び中臣壽詞に麻知弱韮由都篁生出とあるを引き、其の釋義は明かならずといへり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の長は阿波國那賀郡なるべきが上に、此國には又美馬郡といふもあり、神名帳には此國名方郡に御間都比古神社ありて、栗田氏は即ち觀松彦色止命を祀るとせり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名帳に出雲國出雲郡阿須伎神社同社神伊佐我神社あり、又同郡に伊佐波神社、伊佐賀神社あり、栗田氏の神祇志料に皆出雲國造の祖、天夷鳥命の子伊佐我命を祀るとせり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊佐我命に縁ある者としては、神名帳に出雲國出雲郡に都我利神社あり、栗田氏の志料に武夷鳥命即ち天夷鳥命の孫、津狡命を祀るとせり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "載斯烏越　　載を戴の訛とせば、武内に近しといふ説あれど、今は字を改めずして解釋を試みんに神名帳に出雲國飯石郡須佐神社あり、今須佐郷に在り、又大原郡佐世神社あり、今佐世郷に在り倶に須佐能袁命を祀ると栗田氏の志料に見えたり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "延喜式神名帳によれば、本郡に比都佐神社あり、又此地方に鳥坂長峰あるによるなり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『苑には、領す神名こそあれ、畏こし、あな天の『あくがれ』女。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾万の拍手はひびき、神名は流された。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿の父上は……」　ターミナは、大切な守りの神名でも告げるように、恭しく、スーラーブの耳に囁いた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡禮や參詣人が二三人も來て、神名帳や神符を頂きに社務所へ來たけれど、門が閉まつてゐるので、暫く扉を叩いては、ブツ／＼言ひながら立ち去つた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名式阿波國に、波爾移麻比彌神社とも見えたり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐後風土記日田郡ノ條ニ「昔者纒向日代宮御宇大足彦天皇、征伐球磨贈於凱旋之時、發筑後國生葉行宮、幸於此郡、有神名曰津媛、化而爲人、參迎辨申國消息、因斯曰久津媛之郡、今謂日田郡者訛也」上ノ津媛ノ上ニ、久字落チタルカ、生葉ハ、景行紀ニ的邑トアリ、今ノ生葉郡ナリ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名帳に、賀茂別雷神社、亦若雷とあるのは、有力な証拠である。",
              "citation": {
                "source": "わかしとおゆと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、此神名、世に和計伊加豆知と唱へなれたるにあはせて、かの分穿屋甍而升於天とあるにより、或は、鳴神となりて、雲を別けて、天にのぼりませる由などより、別雷の義なり、といはむは、古意ならず。",
              "citation": {
                "source": "わかしとおゆと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、神名が似てゐるのは、神の性質が近似してゐるのだし、それと同時に名前が一寸違つてゐても性格の上に細かな相違のあることを示してゐるのだ。",
              "citation": {
                "source": "真間・蘆屋の昔がたり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
