[
  {
    "uuid": "90611cc9-f671-512e-8c99-312db7bb098c",
    "entry": "識見",
    "reading": {
      "primary": "しきけん",
      "alternatives": [
        "しっけん"
      ],
      "is_heteronym": false
    },
    "grammar": {
