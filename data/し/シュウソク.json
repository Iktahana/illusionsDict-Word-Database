    "definitions": [
      {
        "index": 1,
        "gloss": "conclusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが超絶的なブランド力を備えるＩＢＭのマシンの誕生は、ベーシックの混乱を収束させるチャンスをマイクロソフトに与えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結末の収束と責任と暗い予感が虫のやうに食ひこんでゐた。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "収束するところなく共に動いていた健三はしまいに飽きた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら我々の結論は今や――その放縦さにも拘らず――私の声明をここまで読んでこられた方には説明するまでもない性格のものへと完全に収束していたからである。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで喧嘩はいつも収束する。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "騒動も収束し、団長もいつもの仕事に戻ったので、嗅ぎ回った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの別個の捜査路線が臨界点で収束するかも知れない。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
