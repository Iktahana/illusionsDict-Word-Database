          "literary": [
            {
              "text": "脳炎の急な発症で、一時心神喪失になっていたからだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく、一九二八年に這入ってからだが――一月五日――今度は Floria Macfadden という七歳の少女が、程近いカアランド Carland 町へ通ずる淋しい裏道で、コロロフォルムを嗅がされて××されたと覚しく、心神喪失の状態で路傍に遺棄されていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や心神喪失状態、支離滅裂なことを口走っている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
