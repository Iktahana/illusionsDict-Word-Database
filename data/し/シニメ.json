    "definitions": [
      {
        "index": 1,
        "gloss": "moment of death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蝶子は柳吉の傍に附き切りで、母親の死に目に会えなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に目に会ふことも許されない寿枝と楢雄は香櫨園の家でソハソハしながら、不安な気持のまま何か殺気立つてゐた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に目にお会いになれないかも。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、お絹の死に目に会わなかったことが残り惜しくも思われた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に目に会えなかったのも自分の罪ではない、今夜行かないのも自分の薄情からではないと、彼はいろいろの理屈をかんがえて努めて自分を弁護しようと試みた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は自分の混亂した忿激と愁傷とをまぶたの落ち窪んだ目に漲らせ、而も自分は亡兒の魂に從つて既に地獄か墓の底までも檢閲して來たやうなつよい暗い光を顏ぢうに現はして、「あなたのおかげで、わたしも兒どもの死に目に逢へなかつたぢやアありませんか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは長い暗い路を歩きながら、また人の死に目に遇ふのかとおもつた。",
              "citation": {
                "source": "星のわななき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "チブスで動きのとれなかったぎんは、とうとう親の死に目にも会えなかった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとはちがって、きつつきは、おかあさんの死んだ知らせが来ても、鏡に向かって紅をつけたり、おしろいをぬったり、おしゃれに夢中になっていて、とうとう親の死に目に合わなかったものですから、神さまがおおこりになって、「お前は木の中の虫でも食べているがいい。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親が待つて居る、瀕死の妹が待つて居る、死に目に遇つてやれ、空気が清い、青い海が手を広げて居る、新鮮な魚がある、静かに英気を養ひ潜勢力を貯へて来い、身体が大切だ！",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日に限つて遊びに出て居て死に目に遇へなかつたことを悔いた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は定雄の二十五歳のときに京城で脳溢血のために斃れたので、定雄は父の死に目にも逢っていなかった。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "悴が死にかかっていますので、早よ街へ行かんと死に目に逢えまい思いましてな。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男はその時帰つたぎり、兄の死に目にも会はずにしまつた。",
              "citation": {
                "source": "庭",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、保一くんは悲しくも未亡人の死に目に遭ったのでした。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時、公暁を勤めて居た先代尾上菊五郎は、実弟坂東家橘の、思ひがけない死に目に逢はねばならなかつた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの葡萄蔓にも紛はうず髪をさつさつと空に吹き乱いて、寄せては返す荒波に乳のあたりまで洗はせながら、太杖も折れよとつき固めて、必死に目ざす岸へと急いだ。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は死に目にも会えなかったのです。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を捨てた子は、母の死に目にも会いません。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "必死に目をつぶろうとしたが、どうしたことか瞬き一つ不可能だった。",
              "citation": {
                "source": "幽霊",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となっては言いますが、おまえのお母さんがあの小さな坊やのむごたらしいみじめな死に目に会うまで生きていなかったことを神さまに感謝します！",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、半蔵は伊之助の死に目にもあわずじまいだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、わたしは母の死に目にも会わずじまいでした。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、志道軒ムラクモというその道の専門家がいるから、この人物は親父の死に目やムシ歯の痛む最中でも唄って唄えない仁ではなかろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が死んだ時には仕事の都合で帰省することが出来なかつて、其の死に目に逢はなかつた。",
              "citation": {
                "source": "落葉降る下にて",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬えば夢を見る人が、夢の感じの溢れたために、眼の覚めるのと同じように、この生活の夢の感じの力で、己は死に目覚めるのか。",
              "citation": {
                "source": "痴人と死と",
                "author": "ホフマンスタアル　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今日、もう死に目にも近づいて、ミサに行きそこなう。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに気力が衰え、色香が褪せ、死に目にもう遠くない彼女を見ると、孫娘の不始末ぐらい、ほかのことと同じようにどうでもよさそうなものを、と、人は驚くのである。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東京に居たですから死に目には得逢はなかつたのです、残念ですよ。",
              "citation": {
                "source": "千里の駒後日譚拾遺",
                "author": "楢崎龍、川田雪山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大めかしにめかし込んだ姿で、宰相の側に腰をかけてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
