[
  {
    "uuid": "f9910dc2-0ac3-55fb-8276-db6f36289900",
    "entry": "集合",
    "reading": {
      "primary": "しゅうごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
