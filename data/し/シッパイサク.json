    "definitions": [
      {
        "index": 1,
        "gloss": "failure (i.e. an unsuccessful work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
