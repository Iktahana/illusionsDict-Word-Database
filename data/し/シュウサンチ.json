    "definitions": [
      {
        "index": 1,
        "gloss": "distribution center (centre)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "………かの女たちは、ハンド・バッグさえあれば、たとえ露天の夜だってたえ忍ぶことができる、浪速へなりと、上海だって、街のエロチシズムの集散地へなりと、こころのままに行くことができる。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方の産物の集散地で人口も一万以上あるやうだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処から稲※村まで二里、此処に無集配の郵便局があって、附近の物産の集散地になって居る。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "物貨の集散地にしても、一国の首府にしても、世界最古の人間活動地だとしても、なお疑問は残る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "村は物資の主要な集散地として位置している。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "穀類、木材の集散地。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　次いで開原駅では、近年欧洲の市場にまでも輸出せられるに至つた満洲大豆の大きな集散地の一つである事を聞いた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道の開通は此地を枢要な貨物の集散地として、ますます未来の殷賑を期待せしめてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備隊専属の○○船で揚子江を横ぎり、その船でまた大熊部隊長の一行を運んで来るのであるが、途中、十二※といふ有名な塩の集散地で、同時に、地区隊の一部が守備してゐる地点に立寄り、更に、そこから北は天津まで通じてゐるといふ大運河を遡つて楊州に還り着く予定である。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを物資の集散地というのかね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに物資だけではなく人間の集散地でもある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、物と人の単なる集散地には独創だの計画だのというものは、あんまり現れることがないのだろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと他の問屋に頼みたい、そのことはもう四、五年も前から、下海道辺の問屋でも今渡（水陸荷物の集散地）の問屋仲間でも、荷主まで一緒になって、みんな申し合わせをしたことよなし。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪は海灣に面して、淀川は舟楫の便あり、四通八達、物資の集散地として、屈強な地の利、水の利がある。",
              "citation": {
                "source": "大阪といふところ",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当地第一の物産たるコーヒーの集散地なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀中頃に、フランドルのブルウジュは、ヨオロッパの北方と南方との間の貿易の大集散地であった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "今考えるとあの大沽というところは、兵隊の集散地だったらしい。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹と木材の集散地で、河見家でも広い木山を持っているため、庄屋のほかに藩の山方の差配を命ぜられてい、屋敷のまわりには樵たちの長屋があった。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小出は昔から生糸や絹布の集散地で、江戸から買付けに来たり、こっちから荷を送ったり、定期的に江戸と連絡のある商人が幾人かいた。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下関が集散地になっているだけで、河豚は瀬戸内海はもちろん、玄海灘でも、どこの海でもとれる。",
              "citation": {
                "source": "ゲテ魚好き",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
