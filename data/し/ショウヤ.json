    "definitions": [
      {
        "index": 1,
        "gloss": "village headman (esp. in the Kansai region)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詳しいことは忘れたが、何でも庄屋になる人と猟師（加八という名になっている）になる人の外に、狸や猪や熊や色々の動物になる人を籤引きできめる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋になった人が「カアチ／＼鉄砲打て」と命ずると、「カアチ（加八）」になった子が「何を打ちましょう」と聞く。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋殿が例えば「狸」と仰せられると加八は一同の顔色を注意深く観察して誰が「狸」であるかを観破するために云わば読心術の練習のようなことをする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまく当れば当てられたのが代って「加八」になり当てた「加八」が庄屋になる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主が、Ｔ「昨日　山向うの庄屋の家に　白羽の矢が」Ｓ＝庄屋の家　屋根に白羽の矢が、突きささって居る下で大勢の百姓がわいわい言って居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「嫁入前の庄屋の　娘が可哀そうに　人身御供に」Ｓ＝元の茶店　亭主が話す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝庄屋の家の表――夕方　屋根の白羽の矢。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝内部　娘の室から驚いて庄屋が出て来た。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝庄屋の表　葛籠が人々の手によって山へ送られる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄屋や母親や親類縁者が、泣きの涙で供をする。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝庄屋の家の内部　祝いの酒宴である。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "感心して聞く庄屋や其他村人。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝元の庄屋の家　語り終る武蔵。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いた庄屋が、Ｔ「巳年の男で　御座いますか」　左様、と武蔵がうなずいて、さて、　Ｔ「聞けば近々　御婚礼との事で　御座るが」　ハッハイと庄屋、心配そうに、Ｔ「相手の男が　巳年でないと」　悪う御座いますかと訊く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、Ｔ「天狗の祟りが　怖ろしう御座るぞ」　ハテ困った、と庄屋。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　数日の後――Ｓ＝村はずれの街道　庄屋や六助お絹の若夫婦や、　其他村人達に送られて、　武蔵と団九郎が旅立ちであります。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は『松葉屋』や『庄屋』がその同類として引き込みに手を廻して来るのを、きっぱりとはねつけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『松葉屋』も、『網元』も、『庄屋』も、証拠不十分で不起訴になった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『庄屋』は、門の用材に伐った松が、竹三郎の所持林の境界線をはずれて、『庄屋』自身の山にあったものだと云い出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄屋は、その樹を戻せと云い出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「庄屋の旦那が、貧乏人が子供を市の学校へやるんをどえらい嫌うとるんじゃせにやっても内所にしとかにゃならんぜ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄屋の旦那に銭を出して貰うんじゃなし、俺が、銭を出して、俺の子供を学校へやるのに、誰に気兼ねすることがあるかい。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、それぞれ試験がすんで帰ってくる坊っちゃん達を迎えに行っている庄屋の下婢や、醤油屋の奥さんや、呉服屋の若旦那やの眼につかぬように、停車場の外に立って息子を待っていた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、汽車が着くと、庄屋や、醤油屋や、呉服屋などの坊っちゃん達が降りて来た。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と庄屋の下婢は、いつもぽかんと口を開けている、少し馬鹿な庄屋の息子に、叮嚀にお辞儀をして、信玄袋を受け取った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥か、獣か、それともやっぱり土蜘蛛の類かと、訪ねると、……その頃六十ばかりだった織次の祖母さんが、「あれはの、二股坂の庄屋殿じゃ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角｜無代価で乗ってもらおうと思っているのに、二人共乗れないとは困ったな」「おれも乗りたいけれども、これじゃ仕方がない」「もうよしましょうや。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　新吉はちょっと左肩をよじって不平の表情をしてみたが名優サッシャ・ギトリーの早口なオペレットの台詞を真似て、――マダムの言いつけとあらば、なんのいなやを申しましょうや。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しばし、お名あがり家ととのうたるのちは、御兄上様御姉上様、何条もってあしざまに申しましょうや。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がちょうの　たんじょうび新美南吉　ある　おひゃくしょうやの　うらにわに　あひるや、がちょうや、もるもっとや、うさぎや、いたちなどが　すんで　おりました。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
