        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ひきがしどいね」　とＭがいいました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」“Chon-aiko! chon-aiko! ……”「華魁、ちよいと、御覧なさいな、久し振で裏門が開いたと思つたら、大変ですわねえ、あれ、あんなに水が、随分しどい音だこと、堤をもう越したんですとさ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しどいわ、あなたは」と、ぶつ真似をして、「はい、これでもうちへ帰ったら、お嬢さんで通せますよ」「お嬢さん芸者万歳」と、僕は猪口をあげる真似をした。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しどい、わ」吉弥は真ッかになって、恨めしそうにそれを拾った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、ほら、少しどいてくだせえ」　爺はそう言って、車の梶棒で人々を掻き除けるようにした。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、売ったのはしどいな。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路へはいりながら、しどい場処ですといって番地と表札をさがしたが、西川鉄五郎の家はどうしても知れないので空家のような家で聞くと、細い細い声で返事をした。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い、しどい、刺戟のある臭気を、香を焚き、鼻の穴へ香水をつけた綿を挿て私が世話をすると、その時だけ意識が分明して、他の者には近よらせなかった。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "生意気な、白目の大将が好きなンだろう」「しどいわねえ、ええいいわよ！",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といったが、古い日のことを思出したのであろう、お前の踊の師匠だった、おとねさんは、しどいよ、と言った。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体｜無頓着なのに、橘屋ときたら、そのころはしどい借金だったのですからね。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さんへって宛名で、随分しどいこと書いてよこしたのですって。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様にお土産なんぞ持っていらッしたよ」　「ほんとにしどいね。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様にお土産なんぞ持っていらッしたよ」「ほんとにしどいね。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "衝立のそばまでゆくと、肉親の人らしい女の背中が少しどいて、そこから白いガーゼで胸から蔽つた三谷氏が見え、顏だけがあふのきにこつちを迎へてゐた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "（前略）「華魁、ちよいと、御覧なさいな、久し振で裏門が開いたと思つたら、大変ですわねえ、あれ、あんなに水が、随分しどい音だこと、堤をもう越したんですとさ。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳子　知ってらっしゃる癖に、しどいわ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "リラの若木を植えたとき富美子は泣いた、二人で小さな立札に、来太が「むらさきはしどい」と書いたあと、富美子はそれに添えて「また逢う日まで」と書きながら泣いた。",
              "citation": {
                "source": "花咲かぬリラ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少しどいてくれ、旦那にちょっと話があるんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
