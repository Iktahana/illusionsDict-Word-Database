    },
    "definitions": [
      {
        "index": 1,
        "gloss": "diagnosis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と母は父の汗づくになつた診断衣を脱がせながら言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "畸人という通称があったが、しかし難儀な病気の診断が上手だと云う評判であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時山奥のまた山奥から出て来た病人でどの医者にも診断のつかない不思議な難病の携帯者があった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当区内の鵞口瘡は此六日を以て悉皆主治したとの話をした十二日　午前警視庁の巡回獣医来る　健康診断のためである。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄ってくれた人たちは当然のこととして、診断書のこと、死亡届のこと、埋葬証のこと、寺のことなど忠実に話してくれる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月十七日『東京朝日新聞』）　　　　　　　　　六　　　　　　結核の初期診断法　一時有名であったコッホのツベルクリンは、その後ただ結核病の診断にのみ用いられていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、橇から引っかえした日に、一人一人、軍医の診断を受けた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍医は、診断にやって来る兵士が、どれもこれも哀れげな元気のない顔をしているのを見た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、彼は、診断室を出て行くように、合図に手を動かした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は診断室の方の物音と、廊下を通る看護卒の営内靴に耳をすまして時を過ごした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで医者の診断書を取ってくる。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初は一週間の病気届、これは正規で別に診断書が要らない、其次は診断書が付て五週間の欠勤。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者の診断では卒中だということで……」と、家主はおちつき顔に答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の仕業でも無し、長屋の者どもの仕業でもないとすれば、猫婆の死は医者の診断の通り、やはり卒中の頓死ということに決めてしまうよりほかはなかったが、半七の疑いはまだ解けなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師の診断によると、おみよは何者かに絞め殺されたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "――病気だと云って診断を受けろよ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二度診断を受けたことがあるんだが。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、先生、この森と柴田の死亡診断書にゃ、坑内で即死したと書いて呉れますね。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝶々の診断をしてゐるんだ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は世間に神経衰弱という病名が甫めて知られ出した時分であったのだが、真にいわゆる神経衰弱であったか、あるいは真に漫性胃病であったか、とにかく医博士たちの診断も朦朧で、人によって異る不明の病に襲われて段気を吸うべく東京の塵埃を背後にした。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事は、机の上の医師の診断書に眼を落しながら、「君は、肺がわるいのだね？",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食餌中毒という診断だが、怪しいと仰言るんで……ヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろこれは一種の病気であると認めて、近江屋でも嫌がる本人を連れ出して、二、三人の医者に診てもらったのであるが、どこの医者にも確かな診断をくだすことは出来ないで、おそらく年ごろの娘にあり勝の気鬱病であろうかなどというに過ぎなかった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「健康診断を致しますから、八日正午、左記の病院に此の状持参にておいで下さい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数枝という女博士の診断なら、そうだわ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕たちは、この鐘の健康状態はすこぶるよろしい、と診断したのだった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃は世間に神経衰弱といふ病名が甫めて知られ出した時分であつたのだが、真に所謂神経衰弱であつたか、或は真に漫性胃病であつたか、兎に角医博士達の診断も朦朧で、人によつて異る不明の病に襲はれて段気を吸ふべく東京の塵埃を背後にした。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも母親は、兄の英吉の事に就いて、牛込に行っている、かれこれ便宜だから、大学の眼科で診断を受けさせる為に出向いた、今日がその帰途だと云う。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓉子にも米倉にも何も云わず一人で苦しんだんだ。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きびがわりいのなんのって」とあとでその男が云った、「あいつの眼は生きた人間の眼じゃあねえぜ、ありゃあおめえしんだんじんの眼だ、おらあ賭けてもいいが、あいつの躯に流れてる血は氷みてえにつめてえぜ、きっと」　平さんは三度のめしに、漬け物と味噌しか喰べない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
