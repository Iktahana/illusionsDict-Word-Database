[
  {
    "uuid": "111835c5-a279-5ff0-8816-2ecd46c1f387",
    "entry": "性懲り",
    "reading": {
      "primary": "しょうこり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
