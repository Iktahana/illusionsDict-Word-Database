          "literary": [
            {
              "text": "ウィリアム・シェイクスピア氏が成長してアール・オヴ・チャタムとなり、チャタム卿が成長して名も無き一市井人となる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルトンもスコットもスウィフトもモリエールもラブレエも、更にはシェイクスピア其の人さえもが、意外にも、驚くべき非常識、乃至、未熟を曝露するに違いないから。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人は愚か、土人さえ稀なマルケサスの裏海岸に自分で小舎を作り、唯一人（海と空と椰子樹の間に全く唯一人）一冊のバアンズと一冊のシェイクスピアを友として住んでいる（そして少しの悔もなく其の地に骨を埋めようとしている）亜米利加人もいた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "４左にシェイク右にシェイク力のかぎり、ヒピー・ヒピー・シェイク！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ヒピー・ヒピー・シェイク〉スウィンギング・ブルー・ジーンズ　二カ月後、起床音楽はがらりと変わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにストロベリーシェイク！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み物は……コーラかな」「チョコレートシェイクにしろよ」　と、高志が押しつける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのチョコレートシェイクという飲み物を、白地に赤のダンダラがついたストローですこし吸いあげた慶一は、困惑を忘れた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定、高志が低い声で、「チョコレートシェイクにしろよ」といった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チョコレートシェイクにーするーかー」　高志が、呪文とおなじようなアクセントでいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョコレートシェイクをつくるミキサーがうるさい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柾生がひと口、チョコレートシェイクを飲んで、感動したようすで、小さく奇声をあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのさ、おれ、発見したよ」　柾生が、チョコレートシェイクのなかに宝物でも見つけたように、背の高いグラスを見つめながらいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、〈ラヴ・アウェイ〉のヴォーカルをさ、でかい音で聴いて、感動しちゃった」　といって、柾生はまたシェイクを吸いあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳者花くらべ　　　　ウィリアム・シェイクスピヤ燕も来ぬに水仙花、大寒こさむ三月の風にもめげぬ凜々しさよ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳者　花くらべ　　　ウィリアム・シェイクスピヤ燕も来ぬに水仙花、大寒こさむ三月の風にもめげぬ凜々しさよ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "譯者ヰリアム・シェイクスピヤ花くらべ燕も來ぬに水仙花、大寒こさむ三月の風にもめげぬ凜々しさよ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾等はモツァルト、ラファエルを守れ、ベエトホ※ン、シェイクスピア、マルク・オオレルを守れ、われらは敢て異端の道を擇ぶ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四・五世紀、ルネッサンスの花がイタリーを中心としてヨーロッパに咲き乱れレオナルド・ダ・ヴィンチ、ミケランジェロ、シェイクスピアと人類の才能が開花したときの日本は、戦国時代だったことをはっきりと理解しなくてはならない。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、日本における新劇運動とシェイクスピアの翻訳とに自己の歴史を完成させた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェイクスピアでも『ヴィナス・エンド・アドニス』を書いた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを書いたからと云ってシェイクスピアの価値は下らない。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばサッカレー、それからシェイクスピアはもちろん、文芸｜廃頽期の詩人もまた、（と言っても、いずれの時か廃頽期でなかろう）物質主義に対する反抗のあまりいくらか茶道の思想を受け入れた。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "○彼の情熱的意力におけるわれわれの意志喪失　p.234○ドストイェフスキーよりもシェイクスピアは人間の精通者である。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが、ストラトフォード・オン・エイヴォンのことをイギリスのメッカだと言っていたが、少くともイギリス文学をかじってる者にとっては、シェイクスピアの生れた土地、シェイクスピアの骨の埋もってる土地を見に行くのは、回教徒が聖地へ巡礼に出かけるようなものである。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとっても、これまでたびたびシェイクスピアについて講義をしたこともあり、東京を立つ前には『マクベス』の翻訳を出したばかりではあり、『オセロー』にも手をつけたままで出かけて来たようなわけではあり、何かにつけてシェイクスピアには世話になってるので、かたがたお詣りしなくては義理が立つまいと思われた。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
