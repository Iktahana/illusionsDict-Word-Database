    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Judgment Day (as described in Christian tradition)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正確な事実は審判の日を待たなければ判明しない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかといって神経衰弱にかかった杞人でない限り、いつ来るかもわからない「審判の日」を気にしてその時の予算までを今日の計画の中に組み込むわけにも行かない。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして付け焼き刃の文明に陶酔した人間はもうすっかり天然の支配に成功したとのみ思い上がって所きらわず薄弱な家を立て連ね、そうして枕を高くしてきたるべき審判の日をうかうかと待っていたのではないかという疑いも起こし得られる。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それは、私たち二人にとって、最後の審判の日の※よりも怖ろしい響で御座いました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして恐ろしい最後の審判の日はじりじりと近づくのである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に来らんとする神の震怒の日に於ける彼等の仲保者又救出者として仰いだのである、「千世経し磐よ我を匿せよ」との信者の叫は殊に審判の日に於て発せらるべきものである、而して此観念が強くありしが故に彼等の説教に力があったのである。",
              "citation": {
                "source": "聖書の読方",
                "author": "来世を背景として読むべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、最後の審判の日が来つたところで誰一人罪せられる者はゐないであらう。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大袈裟にいえば、最後の審判の日が来たのかと思われる程であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、み怒りの雲の色、審判の日こそ忍ばるれ。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人の子枕す時もなし、ああみ怒り……審判の日……。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "審判の日７・25（夕）　最後審判の日――といふと耶蘇教では一番｜厳しい日で、これまで懶けてばかしゐた神様が、むつくり起き上つて、区裁判所の判事のやうに気難しい顔をして人間の裁判をする日なのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア※ン・コツブといへば、米国で聞えた記者だが、この男がある日教会へ往くと、牧師は例の「最後審判の日」といふ演題で長つたらしいお説教をしてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の果ての平原に煙幕のような蒙古風が巻き立ったかと思うと、視界はもう人類最後の審判の日のように、赤く暗く霞んで、色の附いた空気があらゆる隙間から、室内へ、机の上へ、寝台へ、そして私たちの鼻口へ、おそらくは肺の底へまで音を立てて侵入してくるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "その信徒等は彼等の感激に於て固より全く新しく明ける日の微風に包まれてゐるのを信じたが、然しそれは同時にこの世界の過ぎ去る最後の審判の日であるべきであつたのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の審判の日は近づきましたよ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはわたしの耳には最後の審判の日の喇叭のようにひびいたのです。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて朝夕に眺めた海のほのかな記憶を（ああすべてが最終審判の日に於て）彼等は果して憶い出さずに居たであろうか？",
              "citation": {
                "source": "再生の日の海を眺めて",
                "author": "――その日牢舎を出でたる一革命家の歌える",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、自分たちの運命に対するあまりに生々しい関心を人にかくそうと、最後の審判の日をひかえて背掛けクッションを織っている地主の婦人たちのことを考えて見たまえ！",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "想えば私のすべての反省も思索も、いかにこの審判の日を迎えるべきかの準備に過ぎない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界は神の善意志によって、計画的に創設され計画的に歴史発展をし、そして最後の審判の日が来ると神の世界計画は実現し終る。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "後は最後の審判の日を待つだけのようである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いなる種族が絶望的な程恐れている来るべき破滅――その審判の日、何百万という鋭い精神をより安全な未来に住む異様な身体の中へと遥かなる時を隔てて送り出さなければならなくなるのだ――が古きものどもに勝利を齎す最後の侵攻と関連があるのは歴然としていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "エイガー・ロックは、最後の審判の日のように、決定的な恐ろしい正義にあふれた顔を相手に向けた。",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その諧謔家で一見飄乎とみえる高田氏の審判の日の一文が、私の讀んだかぎりにおいては、もつとも嚴肅であり、自己への内省と、同時に人をして深思反省のうちに、同痛のおもひにたえざらしめるやうなものがあつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると京都の市内は、俄然、「最後の審判の日」のような混乱に陥った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "審判の日が目のまえに迫っている」と叫ばない者はございません。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある所では、最後の審判の日が確信されていた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
