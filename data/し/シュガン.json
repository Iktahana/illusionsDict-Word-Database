          "literary": [
            {
              "text": "朱顔、蓬なる赤毛頭、緋の衣したる山伏の扮装。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆と正月の十六日には、閻魔堂の格子が開いて、がらんとした暗い堂の正面に、朱顔に金の眼を光らせ、赤い口をかっと開いて、笏を持っていきり立った閻魔大王の姿を、しみ／″＼と眺める事が出来るのだ。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            }
          ]
        }
