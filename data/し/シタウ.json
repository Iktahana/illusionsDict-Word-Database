    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to yearn for",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ととさまえのう、と泣いて慕う子を振り切って、宗五郎は吹雪の中へ走って消えます。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北から帰って来たという小鳥たちは身籠る季節まえのまだ見ぬ雄を慕うて、囀りを立てている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだ足りない、もっとその巡査を慕うてもらいたいものだ」　女はこらえかねて顔を振り上げ、「伯父さん、何がお気に入りませんで、そんな情けないことをおっしゃいます、私は、……」と声を飲む。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに心のさびしい暗い人間は、人を恐れながら人を恋しがり、光を恐れながら光を慕う虫に似ている。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ年少の夢よ、かの蒼空はこの夢の国ならずや、二郎も貴嬢もこのわれもみなかの国の民なるべきか、何ぞその色の遠くして幽かに、恋うるがごとく慕うがごとくはたまどろむごとくさむるがごときや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から思いますと、やはりそのころ私はおさよを慕うていたに違いないのです、おさよが私を抱いて赤児扱いにするのを私は表面で嫌がりながら内々はうれしく思い、その温たかな柔らかい肌で押しつけられた時の心持は今でも忘れないのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――阿難さま、女が男を慕うまごころ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥に攻められる人間は、冷たい死を寝床のようにも慕うものであることを知ったか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大勢の人声は、皆、貴下の名誉を慕うて、この四阿へ見に来るのです。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙の大法則に引きずられて彼は今こゝに衆人の冷たい顧眄を慕うて来た。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ暑いので、誰も吹ぬけの縁を慕うのであった。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あこがれ慕う心には、冥土の関を据えたとて、夜のあくるのも待たりょうか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その見はった眼には、驚愕の色も嫌悪の色も無く、ほとんど救いを求めるような、慕うような色があらわれているのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャネットに物心がついて母を慕う時分にはカテリイヌは埃及へ行って居た若い建築技師と結婚したものゝ間もなく病死してしまった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸底の画像と違うのも仕方の無いことで、私のは謂わばまあ、田舎の耄碌医者が昔の恩師と旧友を慕う気持だけで書くのだから、社会的政治的の意図よりは、あの人たちの面影をただていねいに書きとめて置こうという祈念のほうが強いのは致し方の無い事だろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "劉秉忠を慕うの人｜道衍は其の功を成して秉忠の如くなるを得、伯夷を慕うの人｜方希直は其の節を成して伯夷に比せらるゝに至る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、」　酒井がずッと歩行き出したので、たじたじと後を慕うて、「どちらへ？",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立處其の手足を炙るべく、炎々たる炭火を熾して、やがて、猛獸を拒ぐ用意の、山刀と斧を揮つて、あはや、其胸を開かむとなしたる處へ、神の御手の翼を擴げて、其膝、其手、其肩、其脛、狂ひまつはり、搦まつて、民子の膚を蔽うたのは、鳥ながらも心ありけむ、民子の雪車のあとを慕うて、大空を渡つて來た雁であつた。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "散策子は踵を廻らして、それから、きりきりはたり、きりきりはたりと、鶏が羽うつような梭の音を慕う如く、向う側の垣根に添うて、二本の桃の下を通って、三軒の田舎屋の前を過ぎる間に、十八、九のと、三十ばかりなのと、機を織る婦人の姿を二人見た。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶像は要らないと言う人に、そんなら、恋人は唯だ慕う、愛する、こがるるだけで、一緒にならんでも可いのか、姿を見んでも可いのか。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋い慕うものならば、馬士でも船頭でも、われら坊主でも、無下に振切って邪険にはしそうもない、仮令恋はかなえぬまでも、然るべき返歌はありそうな。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……女房　人間の魂が、貴女を慕うのでございます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いますけれど、思う方、慕う方が、その女を余所へ媒妁なさると聞いた時の、その女の心は、気が違うよりほかありません。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気になるまで己を慕うている女を捨てて逃げることは、人としての行でないように思われて来たが、赤い顔の斑点と、赤茶けた縮れ毛を思うと、醜いと云うよりも寧ろおそろしい気がして、とても帰って往こうと云う気にはなれない。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二通はほとんど同時にいだししものなれど、一は母の自筆、一は親族なる某が、母の死を、わがまたなく慕う母の死を報じたる書なりき。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を慕うがために尋ねて来たのである。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "些とも早う上樣のおあとを慕うて、冥土のおん供……。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを羨みこれを慕う凡俗の群は、踵を揃えてこれに学びこれに倣って、万古に尽きせぬ濁流を人類文化の裡面に逆流させるからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし教授の職に附帯したうるさい仕事のために研究が出来なくなるという心配があれば、また適当な後任者の出来るまで当分の間だけ引受けるというのだったら、むしろ御断りになる方がいいと思う」という意味のことを忠告した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チタ子は断髪にしたうなじを紺色の海にむかってこころよさそうに左右に振って見せました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
