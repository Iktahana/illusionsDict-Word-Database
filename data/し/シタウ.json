[
  {
    "uuid": "03cf3c67-8073-5d01-a0ae-d8e0eeb470db",
    "entry": "慕う",
    "reading": {
      "primary": "したう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
