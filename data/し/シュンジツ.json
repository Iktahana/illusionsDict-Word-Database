    "definitions": [
      {
        "index": 1,
        "gloss": "spring day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてこの「春日夢」こそ、蕪村その人の抒情詩であり、思慕のイデアが吹き鳴らす「詩人の笛」に外ならないのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ一度ある小春日のわが家の門前で起った些細な出来事だけがはっきり印象に残っている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の暖かい日にはうとうと居眠りをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河が、春日大明神の帯のように、きらきら銀色に輝いて流れました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となしこの小春日にふさわしい長閑なものの名である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ雪ふらば降れ、風ふかば吹け、我が方寸の海に波さわぎて、沖の釣舟おもひも乱れんか、凪ぎたる空に鴎なく春日のどかになりなん胸か、桜町が殿の容貌も今は飽くまで胸にうかべん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦播きがすむと、彼等はこんどは、枯野を歩いて寺や庵をめぐり、小春日和の一日をそれで過すのをたのしみとしているのだ。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲のわだつみ洞なして、　　青野うるうる川湧けば、あなや春日のおん帯と、　　もろびと立ちてをろがみぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伽婢子」巻の十二に「大石相戦」と題して、上杉謙信の春日山の城で大石が二つある日の夕方しきりにおどり動いて相衝突し夜半過ぎまでけんかをして結局互いに砕けてしまった。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のどかな春日の縁側に猫が二匹並んですわっている。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そのすぐ次に、やっぱり柏木の叔父さんにすすめられて、「春日町」という綴方を投書したところが、こんどは投書欄では無しに、雑誌の一ばんはじめのペエジに、大きな活字で掲載せられて居りました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヤカアに、サイダアの空瓶を一ぱい積んで曳いて歩いている四十くらいの男のひとに、最後に、おたずねしたら、そのひとは淋しそうに笑って、立ちどまり、だくだく流れる顔の汗を鼠いろに汚れているタオルで拭きながら、春日町、春日町、と何度も呟いて考えて下さいました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日町は、たいへん遠いです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの練馬駅から東上線で池袋へ行き、そこで省線に乗り換え、新宿駅へ着いたら、東京行の省線に乗り換え、水道橋というところで降りて、とたいへん遠い路のりを、不自由な日本語で一生懸命に説明して下さいましたが、どうやらそれは、本郷の春日町に行く順路なのでありました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど、本郷の春日町まで行こうかしらと思いました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春日町」が、雑誌に載った時には、その同じ雑誌には、選者の岩見先生が、私の綴方の二倍も三倍も長い感想文を書いて下さって、私はそれを読んで淋しい気持になりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また学校では、受持の沢田先生が、綴方のお時間にあの雑誌を教室に持って来て、私の「春日町」の全文を、黒板に書き写し、ひどく興奮なされて、一時間、叱り飛ばすような声で私を、ほめて下さいました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河が、春日大明神の帯のやうに、きらきら銀色に輝いて流れました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「春日明神さんの帯のようだな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春日明神さんの帯のようだ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の日曜とて、青山の通りは人出多く、大空は澄み渡り、風は砂を立てぬほどに吹き、人々行楽に忙がしい時、不幸の男よ、自分は夢地を辿る心地で外を歩いた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し大庭真蔵は慣れたもので、長靴を穿いて厚い外套を着て平気で通勤していたが、最初の日曜日は空青々と晴れ、日が煌々と輝やいて、そよ吹く風もなく、小春日和が又｜立返ったようなので、真蔵とお清は留守居番、老母と細君は礼ちゃんとお徳を連て下町に買物に出掛けた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和な小春日がのどかに野を照らしていた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備の巡査、兵士、それから新聞社、保険会社、宗教団体等の慰問隊の自動車、それから、なんの目的とも知れず流れ込むいろいろの人の行きかいを、美しい小春日が照らし出して何かお祭りでもあるのかという気もするのであった。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も亦、寒い雨と荒い風とが見舞つて來る前の、なごやかな小春日向が續くのだらう。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の午後の陽ざしは、トシオの広い賢げな額や、健康らしく肉付きの引しまった頬に吸い寄りました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベルリンから来年の春日本へかえるんだけれど太郎さんはやっぱり残る？",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
