[
  {
    "uuid": "f1f64e8b-0731-5492-8d9c-703a511673ae",
    "entry": "質問に答える",
    "reading": {
      "primary": "しつもんにこたえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
