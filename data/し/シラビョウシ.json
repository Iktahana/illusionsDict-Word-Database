[
  {
    "uuid": "bcb17131-4928-5eac-9875-8a78bcc40a14",
    "entry": "白拍子",
    "reading": {
      "primary": "しらびょうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
