[
  {
    "uuid": "59da4953-9b2c-5350-940f-9fb631cd1e5c",
    "entry": "商標",
    "reading": {
      "primary": "しょうひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
