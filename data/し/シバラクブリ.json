    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a long time (since the last time)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして親子四人は、暫くぶりで一枚の布団にもぐりこんだのであった。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、若旦那、今日はお珍らしいじゃありませんか」　広巳が母屋へ来たことは暫くぶりであった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、今日は暫くぶりであったから、無駄話を一つ二つして、それから改めてやることにしましょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蘆の葉のおもちゃのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「ねえ、暫くぶりで熱海へでも行つて見ようか？",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出歩きを怕がって、万豊などに使を頼むのは無駄だから、これから二人がかりでそれぞれの註文主へ納め、暫くぶりで倉の外で晩飯を摂ろうではないかと御面師が促すのであった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父と英語の会話をとり交したのは全く暫くぶりだつたが、やはりこの方が具合が好かつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くぶりの好天気で私達は、一寸アツ気にとられたやうだつた。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くぶりの晴れた日の為だつたか、私達は、つい見慣れぬ風景に心を惹かれたのだつたらう、別段相談もしなかつたのであるが、ひとりでに脚がそつちへ向いたのである。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十六　暫くぶりで、一日遊びに来た姉が、その日も朝から店をあけている鶴さんや、知りたくもない植源の嫁の噂などをして、一人で饒舌りちらして帰って行った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして午後になつてから、今朝出て行くとき、木山が預けて行つた金を若竹へ環しに行かうと思つて、静枝が病気見舞ひにわざ／＼持つて来てくれた、ふじやの菓子を抱へて、暫くぶりで外へ出て見た。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは何の役にも立たぬので独り腹立てて居ると隣の主人が来られて暫くぶりの面会であるので、余は麻痺剤を服してから色々の話をした。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋奈子は、これも亦虚しく蒼白な顔に目ばかり大きく見開きながら、この真昼の部屋の日盛りへ、恐らくは暫くぶりで帰つて来たのです。",
              "citation": {
                "source": "帆影",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は暫くぶりで銭湯にはいってみたんだが……貧乏でも僕のうちには湯殿があるものだからね……、」そして彼は苦笑を洩した。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くぶりに、レストランの中でふいに現われて、変なことを饒舌って、仮面みたいな憂鬱な顔をして、今黙々として歩いてる武田自身が、形はあるが空虚だったら……。",
              "citation": {
                "source": "裸木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君と酒を飲むのは暫くぶりだね」と村田は縁側の柱によりかかりながら云った。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君とはだいぶ暫くぶりだったね。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、暫くぶりね。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の居士は座敷の方を枕にしていたので――臨終の時の姿勢もその時の通りであった――いつも座敷に坐っていた我らは暫く居士の顔を見なかったのであったが、そのいたましい脚に手を支えながら暫くぶりに見た居士の顔は全く死相を現じていたのに余は喫驚した。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日ちよつと学校の帰りの遅くなつたＨさんが暫くぶりのお風呂にはいり、「さあ今のうちに寝とかなくちや」などと冗談を言ひながら二階の寝床へもぐりこんで、とろとろつとしたかしないかの間ださうです。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は昔の学生服のかはりにフロックコートを着け、昔よりは立木の少し延び、建物の少し色褪せた寄宿舎に、暫くぶりで快濶に帰つて来た。",
              "citation": {
                "source": "朧夜",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から一ヶ月ばかり前、暫くぶりで彼が訪ねて来て、「いよいよ今度年期もあけ、御礼奉公も済ましましたので、本郷の湯島新花町百〇一番地――天神様の横を半町ほど入つた所です――に自分で店を開くことになりました。",
              "citation": {
                "source": "質屋の主人",
                "author": "宇野浩二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、暫くぶりでここへ来てみると、ここらはいいわねえ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本當に塀和さん暫くぶりね。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人で停車場を出た時、「どうだ春三郎、己まだ晝飯を食はぬのだが、二人で暫くぶりに一緒に遣らうぢやないか」と言つて取附の安料理屋へ這入つた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六その、旧婚旅行の夜の話合いが実現されて、貞之助が暫くぶりで妙子に会ったのは、九月に這入ってからであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、……こっちの湯どのは、久しく使わなかったのですが、あの、そう言っては悪うございますけど、しばらくぶりで、お掃除かたがた旦那様に立てましたのでございますから、……あとで頂きますまでも、……あの、まだどなたも。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、しばらくぶりに布川が彼を訪ねてきた。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　雄吾の父親、岡本｜吾亮がしばらくぶりで自分の郷里に帰って来た。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は登校の準備もととのい、しばらくぶりで、大木の話も聞き、幾分心にくつろぎができたところから、にわかにみ篶子の事を思うようになったのである。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保田万太郎牧野信一　きのふしばらくぶりで東京へ行き「文藝通信」の机でこれを書かうと二時間あまりもぼんやりしてゐたが久保田さんときくといつそ目の前の電話機をとりたくなつて、だがとうとうその決心もつかなかつた。",
              "citation": {
                "source": "久保田万太郎",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
