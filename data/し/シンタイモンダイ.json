        "examples": {
          "standard": [
            {
              "text": "大臣の不祥事を受けて、進退問題が浮上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自身の進退問題について、明日の記者会見で説明すると述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社全体が進退問題で揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "尤も責任を取って進退をどうこうするというのではなく、そういう進退問題になれば、「弱い商売」の校長さん達が背負わされるのだが。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、今日の、聯合組の親分衆の集まる遠足に洩れたならば、交際を知らぬ者として、進退問題になりかねない。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
