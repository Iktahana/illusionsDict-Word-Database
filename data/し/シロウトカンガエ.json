[
  {
    "uuid": "b8af9bfd-f727-5269-8827-9c5392bf96a3",
    "entry": "素人考え",
    "reading": {
      "primary": "しろうとかんがえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
