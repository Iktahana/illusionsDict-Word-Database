          "literary": [
            {
              "text": "一年じゅうで一ばんよい時候、春と秋との皇霊祭（春分の日・秋分の日）を彼岸の中日として、その前後三日の間、合わせて七日間を彼岸と名づけておりますが、世間では、時候のよい、暮らしよい時が彼岸だと考えています。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "62　新春――イランには古くから一種の太陽暦が行われ、春分の日、すなわち春の彼岸が一年のはじめとなっている。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月春分の日というのに、山の小屋のまわりには雪がいっぱいある。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山桜がいいピンク色にぽうっと山の中腹に目立つようになると、もう三月春分の日は過ぎる。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の春分の日の事であつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の春分の日の事であった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四十二年十一月二日朝（註・処刑の日）千葉覚あとがき　春分の日が近い。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
