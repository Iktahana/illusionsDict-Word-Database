        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "伝説によると、困った人々を救うため神龍が現れたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "少年は、願いを叶えるために七つの宝珠を集め、神龍を呼び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の壁画には、威厳ある神龍の姿が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天地　忽ち　大変して、神龍　氷湫より起る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "神龍氷湫より起るの句は、燕王｜崛起の事をいう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神龍子という観相家の話を聞いたんだが、きみ、幸運の黒子というのがあるんだ。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神龍子の言うことだもの、絶対に信用が置けるさ」　友人は半平の懐疑を嘲るように言った。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に因つて道士は又勢を恢復し、道佛の爭は一層の激さを加へ、朝廷も遂にその弊に堪へざりしと見え、間もなく中宗の神龍元年（西暦七〇五）に、次の如き詔を下した。",
              "citation": {
                "source": "老子化胡經",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い放浪のあとは、すっかり旧知や縁類にも見かぎられて、ひと頃は神龍院にもいたが、法師でありながら坊主の世界にも馴じめず、ついにはこんな一庵をむすんで、人からは「なに楽しみに生きているすね法師か」と、いぶかられていた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
