[
  {
    "uuid": "fedad89f-bcd6-5a65-b5a4-ebb74433c28a",
    "entry": "醜女",
    "reading": {
      "primary": "しゅうじょ",
      "alternatives": [
        "しこめ",
        "ぶおんな"
      ],
      "is_heteronym": false
    },
