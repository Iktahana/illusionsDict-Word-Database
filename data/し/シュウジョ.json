    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ugly woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "美女は美女なりに、醜女は醜女なりに、いかにも女性の心の弱さ、お洒落さ、見栄坊であることを象徴して好い。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女が化粧えば一層の匂いを増し醜女がとりつくろえば、女性らしい苦労が見えて、その醜なのが許される。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯列を矯正したら、まだいくらか見られる、――いいえ、どっちみち私は醜女、しこめです。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、くにゃくにゃと、どやしつけてやりたいほど不潔な、醜女の媚態を以て立ち上り、とっさのうちに考えた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜女が情人を探しはしめえし、もう出来たよで断られちゃ、間尺に合うもんじゃねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先地中海の大神ポセイドン、馬や鳥の形に化けて醜女怪メズサを孕ませ、勇士ペルセウスがメの首を刎ねた鮮血より飛馬ペガソス生まれた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つこれに似たのは、古ギリシアのメズサの話で、そもそも醜女怪ステノ、エウリアレ、メズサの三姉妹をゴルゴネスと併称す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "翼生えた若い極醜女で、髪も帯も、蛇で、顔円く、鼻｜扁たく、出歯大きく、頭を揚げ、舌を垂れ振るう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりペルセウス灰色髪女を訪い、そのただ一つある歯と眼を奪い、迫って三醜女怪方への道を聞き取り、また翅ある草履と、魔法袋と冥界王ハデースの兜を得、これを冒ると自分全体が他人に見えなくなる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてギリシア人は醜女怪の首を甲冑の前立てとし、楯や胸当てに附け、また門壁の飾りとし、魔除けとしゴルゴネイオン（ゴルゴン頭）と称えた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うにバシリスク自影に殺さるる話に、この醜女怪説より融通された部分が多かろう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎の話は主として支那で鬼が桃を怖るるという信念、それから「神代巻」の弉尊が桃実を投げて醜女を却けた譚などに拠る由は古人も言い、また『民俗』一年一報、柴田常恵君の説に、田中善立氏は福建にあった内、支那にも非凡の男児が桃から生まれる話あるを聞いた由でその話を出し居る。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく高之進さまがやって来て、もらってくれという、上役のお嬢さまだが、いい男がなにもすき好んで醜女といっしょになるがところはねえんですからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとあなたは、ただの一人も醜男醜女をも発見できないでしょう」「おお、――」　といっただけで、フルハタは、あとにつぐべき詞を知らなかった。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ其處へ醜女の芳ちやんが、新聞を持つて入つて來たので、知つてる癖に『モウ何時だい』と聞くと、『まだ早いから寢て居なされよ、今日は日曜だもの。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主があつたのでも無ければ、主婦が強つて頼んだのでもなく、矢張普通の女中で、額の狹い、小さい目と小さい鼻を隱して了ふ程頬骨の突出た、土臼の樣な尻の、先づ珍しい許りの醜女の肥滿人であつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ其処へ醜女の芳ちやんが、新聞を持つて入つて来たので、知つてる癖に『モウ何時だい』と聞くと、『まだ早いから寝て居なされよ、今日は日曜だもの。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主があつたのでも無ければ、主婦が強つて頼んだのでもなく、矢張｜普通の女中で、額の狭い、小さい目と小さい鼻を隠して了ふ程頬骨の突出た、土臼の様な尻の、先づ珍しい許りの醜女の肥満人であつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜女と哲学７・24（夕）　伊勢の山田から二里ばかりの在所に磯村といふ土地がある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは静が人並外れた美人だつたので、多くの男にも苦労をさせ、女自身にも悲しい事ばかり見て来たのを思ふと、もう美人は懲り／＼だとあつて、「娘が生れます事なら、いつそ醜女にしてやつて下さい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人を生ませて下さいと、願を籠めたところで、神様は滅多に承引しては下さらないが、醜女を孕ませて下さいと頼むと、大抵はお引請になる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お引請になるのは、何も神様の手並が拙くて、醜女の方が丁度手頃なからでは更々ない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜女に生れると絶念めなければならぬ、「哲学」が無くてはならぬ訳である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝子の方は所謂醜女の深なさけで、男が、女と思わず手にさわり喋りするのを、自分が卓越して居る為とか、愛されて居る為とか思って幸福に人生を麗らかにして居るところ痛ましきかぎり。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿二人、男は鮮人の飴屋さん（彼はなか／＼深切だつた、私に飴の一塊をくれたほど）、女は珍重に値する中年の醜女、しかも二人は真昼間隣室の寝床の中でふざけちらしてゐる、彼等にも春は来たのだ、恋があるのだ、彼等に祝福あれ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜女の醜を描く必要のある場合にしましても、幽霊の凄さを出す必要がある場合にしましても、それらがほんとうの意味の芸術に触れているとしますれば、きっと観る者に不愉快を与えないはずだと思われます。",
              "citation": {
                "source": "朝顔日記の深雪と淀君",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても昔なら醜女とよばれるのだが、当世では美人なのか。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋らしい部屋はタッタ四｜室しかない上に、万事がステキに便利に出来ているからね……ところで一番古く、建った当時から居るのが今云うた松井ヨネ子という二十六になる逞ましい肉体美の醜女だ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
