        "examples": {
          "standard": [
            {
              "text": "仏教では、心身一如の考え方が重視され、精神と肉体の調和を説く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の武道哲学は、心身一如の境地を目指すものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヨガを通して、心身一如の感覚を体験することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「たしなみ」が「教養」といふ言葉に変つたとき「たしなみ」のもつ「道」としての、即ち、心身一如の訓練による生活の技術的体得が忘れられたのである。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、「嗜み」の最も重要な本質は、道徳と知識と情操とが、まつたく不可分の関係で織り込まれ、知情意の最も調和したかたちを、その標準として教へ、心身一如の訓練による生活の技術的体得を目的としてゐたといふことであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
