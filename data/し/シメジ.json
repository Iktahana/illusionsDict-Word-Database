    "definitions": [
      {
        "index": 1,
        "gloss": "Lyophyllum shimeji (species of edible mushroom)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近山裏の谷間には、初茸の残り、乾びた占地茸もまだあるだろう、山へ行く浴客も少くなかった。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これ、この合羽占地茸はな、野郎の鼻毛が伸びたのじゃぞいな。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっぱ占地茸……」「一つですから、一本占地茸とも言いますの。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松茸、初茸、木茸、岩茸、占地いろ／＼、千本占地、小倉占地、一本占地、榎茸、針茸、舞茸、毒ありとても紅茸は紅に、黄茸は黄に、白に紫に、坊主茸、饅頭茸、烏茸、鳶茸、灰茸など、本草にも食鑑にも御免蒙りたる恐ろしき茸にも、一つ一つ名をつけて、籠に裝り、籠に狩る。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――山だの――浜だの、あれは市の場所割の称えだそうで、従って、浜の娘が松茸、占地茸を売る事になりますのですね。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この雨に樺色の合羽占地茸、一本占地茸。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は次第に、大分寒い、山から小僧の千本占地茸、にょきりと大松茸は面白い。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "占地茸を一｜籠、吸口の柚まで調えて……この轆轤を窄めた状の市の中を出ると、たちまち仰向けに傘を投げたように四辻が拡がって、往来の人々は骨の数ほど八方へ雨とともに流れ出す。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部落十七軒が団結して独占地主××と闘争をはじめたのは昨日今日のことではない。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いわが邦の占地制度に、もしも少しでも不明な箇条があるとすると、地名はかえってその集積と比較によって、逆にこれを我々に教えてくれることになるのである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "場合によっては勢力ある家が一手で下受けをしたために、名田の沙汰がなかったのもあるが、荘園が広大であるとか、または他の事情のために多数の武家を招いた所では、占地を分割して各人に付与せねばならぬ。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "みず、ほうな、しどけ、うど、そのほか、しめじ、きんたけなどです。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから畚に入れてある、あのしめじ蕈が釣った、沙魚をぶちまけて、散々悪巫山戯をした挙句が、橋の詰の浮世床のおじさんに掴まって、額の毛を真四角に鋏まれた、それで堪忍をして追放したんだそうだのに、夜が明けて見ると、また平時の処に棒杭にちゃんと結えてあッた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくち、しめじ、合羽、坊主、熊茸、猪茸、虚無僧茸、のんべろ茸、生える、殖える。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも松露の香がたつようで、実際、初茸、しめじ茸は、この落葉に生えるのである。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――十一月初旬で――松蕈はもとより、しめじの類にも時節はちと寒過ぎる。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇が、つかわしめじゃと申すのを聞いて、弁財天を、ああ、お気の毒な、さぞお気味が悪かろうと思うものはありますまいに。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地はそよ風しめじめと、また、透き明る日のこぼれ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨がまたしめじめと降りかけた時に、私たちは養狐場の高い板囲いの潜り戸を開けてもらっていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝茸、松茸、しめじ、松露など、小笹の蔭、芝の中、雑木の奥、谷間に、いと多き山なれど、狩る人の数もまた多し。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内知りたる少女に引かれて、巨勢は右手なる石段をのぼりて見るに、ここは「バワリア」の庭といふ「ホテル」の前にて、屋根なき所に石卓、椅子など並べたるが、けふは雨後なればしめじめと人げ少し。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩事務長が来て、狭っこい boudoir のような船室でおそくまでしめじめと打ち語った間に、葉子はふと二度ほど岡の事を思っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉の鹽燒だの、しめじの汁だの、とろゝ汁だの、何の罐詰だのと、勝手なことを云ひながら夜遲くまで飮み更かした。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉の塩焼だの、しめじの汁だの、とろろ汁だの、何の缶詰だのと、勝手なことを云いながら夜遅くまで飲み更かした。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所のしめじ茸１　十月中頃のある日の午後二時過ぎ、水が飲みたくなって台所へおりて往った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよく雑木山のなかで、しめじ茸を見つけたことがあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな場合にも、一つびとつ離ればなれに孤独を誇るようなことがなく、いつも朋輩のなかに立ち交って、群居生活を娯んでいるのが、このしめじ茸の持って生れた本性であるらしい。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "望まぬ殺生なれど向後の見せしめじゃ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後の見せしめじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "山で取れるものには、初茸、松茸、しめじ、まひ茸などがあつた。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
