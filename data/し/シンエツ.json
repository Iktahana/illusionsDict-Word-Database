    },
    "definitions": [
      {
        "index": 1,
        "gloss": "region on Japan Sea side of Japan west of Tokyo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえて言わば奥州街道から来るか東海道から来るか信越線から来るかもしれない敵の襲来に備えるために、ただ中央線の沿線だけに哨兵を置いてあるようなものである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで自然誘われて、雪国の都を見物のため、東京から信越線を掛けて大廻りをしたのであった。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では、あの信越の境にある野尻湖なども非常に好いところになつたツて言ふぢやありませんか。",
              "citation": {
                "source": "談片",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "又飛信越の界に、飛騨山脈と稱する連山あり。",
              "citation": {
                "source": "一萬尺の山嶽",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "信越線熊谷驛から入つて三峰山に登る間の溪流、それから東京山手線の池袋驛から武藏野を横切つて飯能に到り、其處から沿うて上つてゆく名栗川の溪流、共に秩父の山から出て、前のはやゝ大きく、後者は極めて小さい流であるが、小さいなりにいかにも清らかなすが／＼しい溪である。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の乘るべき信越線の上りにも下りにもまだ間があるのでその間に舊宿まで見送らうと云ふのだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の乗るべき信越線の上りにも下りにもまだ間があるのでその間に旧宿まで見送ろうと云うのだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは信越の山々が、微かな月の光を含んでいる空気の中に、朧に浮いて見える。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信越線の或る停車場に降りると、細かい雪がちらりちらりと舞うように落ちて来た。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ信越地方の二月の雪を衝いて、けさの一番汽車で発って来たのであるから、古河君は骨まで凍ってしまった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺草の十二階の上から、信越線の汽車の中から、北埼玉の野から、利根川の土手の上から、更に最も近くはつきりと見えたるのは、東北幹線の小山驛附近からであつた。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南埼玉の一郡から徴集されたものが三百余名、そのころはまだ東武線ができぬころなので、信越線の吹上駅、鴻巣駅、桶川駅、奥羽線の栗橋駅、蓮田駅、久喜駅などがその集まるおもなる停車場であった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃信州南佐久の臼田まで行かうと思ひ立つことがあつて、家族のものを引き連れ東京を出ようとしたが、折柄利根川増水の噂で信越線もにはかに不通の時であつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを信越線迂回に代えて貰うことは出来よう。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信越の國境を形づくる山の一つである。",
              "citation": {
                "source": "霧の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "信越の境に跨るこの三山の雄大な景色を、ぢつと眺めて居たくなつたからである。",
              "citation": {
                "source": "霧の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車東海道は箱根附近の線路破かいされた為金沢から信越線にゆき、大宮頃迄だろうと云う。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりに居た海軍大佐金沢午後七時〇五分着同三十分信越線のりかえのとき、急行券を買う、そのとき私共と同盟し自分は私共の切符を買ってくれるから、私共はその人の荷物を持ち、席をとることとする。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯歳先我游于信越之間。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日、信越の旅から来たのですか、東京はあたたかですね。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷包み一つの私が、上野から信越線に乗ると、朝の窓の風景は、いつの間にか茫々とした秋の景色だった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも十年ばかり前に静岡から信越地方を荒しまわった有名な殺人強盗だったそうだ」「……殺人強盗……」「そうだ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の方日本海に向つて大きく開けてはゐるが、他の三方は皆山で、特に東方は上信越の山々が屏風を重ねたやうに屹立して居る。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕焼の紅の雲限り無く乱るる中の美くしき月　西妙高から初まつて東信越の山々に終る大きな夏の空には真赤な夕焼雲が絵具皿の絵具のやうに散らかつてゐる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "信越線などは、雪にうずもれて、人夫が汽車を掘り出すと云うさわぎだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "信越線　さて、それから月日がながれた。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "信越線を　昨夜もすこし雪が降ったのだ。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩平の話によると、長野から三四時間の旅程で、すでに越後の温泉ではあるが、信越国境を越えてまもない山のどん底に、松之山温泉といふものがある。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊野から飯山鉄道に乗り換へて、信越国境をすぎたところに、外丸といふ重畳の山また山にかこまれた山底の村落があつて、一行はそこに下車した。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
