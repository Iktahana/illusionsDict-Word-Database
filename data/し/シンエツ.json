[
  {
    "uuid": "368ed052-39be-5f0a-ac52-3597e8070cb5",
    "entry": "信越",
    "reading": {
      "primary": "しんえつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
