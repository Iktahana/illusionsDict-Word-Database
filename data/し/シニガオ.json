        "index": 1,
        "gloss": "face of a dead person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の死に顔は、安らかに見えた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子は死に顔美しく真に眠ってるようである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今つくづくとわが子の死に顔を眺め、そうして三日の後この子がどうなるかと思うて、真にわが心の薄弱が情けなくなった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい死に顔も明日までは頼まれない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きに寝ている彼女は枕を横にはずして、蒲団から少し乗り出したようになって仰向けに横たわっていたが、その結び髪は掻きむしられたようにおどろに乱れて、額をしかめて、唇をゆがめて、白ちゃけた舌を吐いて、最期の苦悶の痕がその死に顔にありありと刻まれていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして青島、おまえひとつこの石膏面に絵の具を塗ってドモ又の死に顔らしくしてくれ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　俺……じゃない、俺の兄貴の死に顔をちょっと見せてくれ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、親父の死に顔も、夜具の下に寝かしてあるのを覗いて見るには見たが、別に悲しくも何ともなかったので困ってしまった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊奈子の恐ろしい死に顔を見た瞬間に、彼女の真実を知ったからであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務員風の男は頭蓋骨をメチャメチャに砕かれていたが、その悽惨な死に顔は、真正面に眼を当てられない位であった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御検視の済んだものを、わたくし共がいじくるのもいかがですが……」と、半七は親類や番頭にことわって、座敷に横たえてある多左衛門の死に顔の覆いを取りのけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に蝋燭をかざしながら、まずその死に顔を覗いて、次にその咽喉のあたりを検めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "委細の事情を澹山から聞いて、彼は娘の死に顔を悲しげに眺めていたが、やがて何を考えたか、いたずらに恐怖の眼をみはっている奉公人どもの方に振り向いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせん生かす術はないと知りながら、かれは男の死に顔をしみじみと覗きたかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に顔をよく拝見いたしましょう」　三宅平七が進み出て、形相もぶきみに変わった死に顔をしげしげ見しらべていたが、おどろいたように叫びました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉なぞは御丁寧にも、絞首台にブラ下っている彼女の死に顔までマザマザと見届けて、何度も何度も魘されながら松子にユリ起されたと言うから相当なものであろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三津子さんの死に顔も早く見たいと思いましたのと、もう一つにはその最期のありさまも委しく知りたいと思ったからです。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚を長く、頬骨が立って、眼をなかば開いた清三の死に顔は、薄暗いランプの光の中におぼろげに見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔にかけてある手拭を少しまくって、かれはその死に顔をちょっと覗いて、隅の方へ引きさがると、お留は茶を持って来て、ふたたび丁寧に会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「死に顔や寝顔まで、にせ物はまねことができぬはずです。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｐのおじさんは、春日町の空家にいた女の死に顔を見て、たしかに川上糸子だと判断なさったでしょう。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが須田町で、ゆうべ轢かれた男の死に顔だ」　と申しました。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（つくづくと俊寛の顔を見る）何という恐ろしい死に顔だろう。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても顔は躰中での一番大切な場所であるが、大雷はその死に顔を――肉｜爛れ蛆涌き血涸れた顔を見事な活顔に返したのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ声の雨に交る中に、破れ筵を敷いた姫君は、だんだん死に顔に変つて行つた。",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "サタンの死に顔か、メデュサの首かと思われる乱脈な青筋を顔一面に走り出さしたまま、手探りをするようにしてドクトルの椅子の方へソロリソロリと近付いて来るのであった。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「罌子の花」を吹き終った武丸は尺八を霊前に捧げ、音絵の枕元に進み寄り、死に顔を見て黙祷し涙に掻き暮れた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「生き顔より、死に顔のほうがよいようじゃな。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　仰向けになった水夫の死に顔。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
