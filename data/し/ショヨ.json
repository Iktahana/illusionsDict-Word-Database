[
  {
    "uuid": "9fc6ea92-9e7b-58a0-8495-5ccc457879b1",
    "entry": "所与",
    "reading": {
      "primary": "しょよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
