          "standard": [
            {
              "text": "企業の収益性を高めるために、コスト削減に取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この商品の収益性は高いが、市場競争も激しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "投資家は、その企業の収益性を重視して投資判断を下す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "保護期間を延長し、著作物からの収益性や資金調達力を高め、新たな創作活動に投じる資金を増大させることにより、コンテンツ創造サイクルの活性化と国際競争力の向上を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その窮極の目的は、残された収益性に富む大企業をして安々と独占の甘い汁を吸わせるところにあった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
