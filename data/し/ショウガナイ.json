    "definitions": [
      {
        "index": 1,
        "gloss": "there's no (other) way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "好きなのだから仕様がないという嗄れた呟きが、私の思想の全部であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きなのだから仕様がない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八釜しくて仕様がないや」「八釜しい奴あ、耳を塞いどけよ」「そうじゃねえんだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松は「仕様がないねえ坊さん」と云って涙ぐんだ。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも仕様がないから、政夫さんの所へ電報を打った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「臭いな、こんじゃ仕様がない。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えゝい、仕様がない。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ、仕様がないじゃないか！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな骨膜炎をいつまでも置いといちゃ場所をとって仕様がない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又徴兵に取られて馬鹿らしいが、仕様がない位いにしか思っていない人々もあるだろう。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな、しかし一寸した慾にとらわれていちゃ仕様がない。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仕様がない奴だ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文句を云うたって仕様がないや。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人は、どんなことになっても仕様がない、と決心した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、気にかゝって仕様がないんだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと隅ッこの人目につかんところへ建てるとか、お屋敷からまる見えだし、景色を損じて仕様がない！",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり仕様がないわい。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってせっかく釣って帰っても、今｜小父さんの言った通りにネ、昨日は、こんな鮒なんか不味くて仕様がない、も少し気の利いた魚でも釣って来いって叱られたのだもの。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵っておいたって仕様がないし、そうかといってウッカリ気心の知れないところに持って行ってお勧めする訳にも行きませんからね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ながらモノスゴクて仕様がないんです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか先生との雑談中に「どうも君の国の人間は理窟ばかり云ってやかましくって仕様がないぜ」というようなことを冗談半分に云われたことがある。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結極余るところが借金を残す位ゐのもので、何うにも仕様がないのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子は再び独言ち、「それでは死んでも仕様がない。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　綾子は失望の悲声を放ちて、「ええ、どうしても仕様がないのか！",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と横ざまに浴せかけると、訓導は不意打ながら、さしったりで、杖を小脇に引抱き、「学校へ通うのに足場が悪くって、道が遠くって仕様がないから留めたんだ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃ、張って張って仕様がないから、目にちらつくほど待ったがね、いざ……となると初産です、灸の皮切も同じ事さ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらに感傷的の気分に浸っていても仕様がないので、うるさく附き纏って来る藪蚊を袖で払いながら、わたしは早々にここを立退いた。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう仕様がないと諦めかけると、清原君は俄に智慧を出して、今夜ここに早川雪洲夫人が来ているかと訊くと、来ているという。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな商売になっちゃア仕様がないよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗くって仕様がない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
