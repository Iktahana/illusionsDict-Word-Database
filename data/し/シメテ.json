        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黒のサージの背広を着て、テカテカに光るネクタイを締めてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前には、雁木の凹みのように、小さな峰が分れて、そこから日本アルプスの禿げた頭が、ぐいと出ている、雪の線が二筋三筋ほど、芒に白い斑が入ったように、細く刻まれて、荒ららかな膚に、美しい白紐を引き締めている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩方に窓掛を締めてやれば、その人のためには夜になり、午前に窓の鎧戸を明けてやれば、その人のためには朝になるでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業というものは片っぽうで先走った思い付きを引締めて、片っぽうはひとところへ噛り付きたがる不精な考えを時勢に遅れないように掻き立てて行く。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意の闖入者と花子とが緊と抱き締めて、ものも云わずに黒い地面にうずくまったからである。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋モスの着物に、紅帯を締めて、さげ髪に紅色のリボンを結んでいるのを見て、最初は一日恋愛の女学生かと思ったのです。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女は何故か憚るやうにあわてて扉を締めて、置いた火鉢を抱へ直すとけむつぽい顏を横に曲げながら、私の側に近寄つて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、俯向いたまま、何故か堅く唇を噛み締めてゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた扉を締めて、出て行つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物は完全な襤褸でそれに荒繩の帯を締めていたような気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十日ばかり前に来たときに、その娘は麻の葉絞りの紅い帯を締めていなかったかね」と、半七は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすぼらしい茶の背広に、間に合わせらしい不調和な赤ネクタイを締めていながらも、それこそ新劇の二枚目かと思われる、生白い貴公子然たる眼鼻立の青年であったが、それが今更のようにビックリして純真らしい、茶色の瞳を大きく見開き、薄い、小さな唇をポカンと開いた姿は、一層ういういしい子供らしい恰好に見えた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を見下している四ツの顔が皆、白い歯を現わして冷笑しているのを見ると、たちまち眼を釣り上げ、歯を喰い締めて今一度、心の底から唸った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめたと思ってナイフで突き外して、中に入って、もとの通りに締めて、廊下の突き当りの袋戸から蚊帳と蒲団を出して応接間に敷いて、大の字になりながら窓際に並べてある朝顔の鉢を見ているうちに、グッスリと睡ってしまった。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い健康な全身の弾力を、両方の掌にギュッと握り締めて左右のポケットに突込んで……。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手をポケットに突込んでシッカリと握り締めているから……酔っていた形跡もない。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうちに来ると花子さんは何より先に押入れをあけて人形を見つけますと、抱き締めて飛んでよろこびました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相島は仕切りの襖を締めて廊下に出て、其處の押入れから茶碗を二つと土瓶と茶筒とをつかんで來た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田も仕切の襖を締めて床に就いた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は油断はすまいと弛む心を引締めているつもりでも、どことなく、やれ安心、早く災難から脱れ度いという気持が湧き出して来た。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を締めてしまおうかと思っているところへ、年少の出前持が寒そうに帰って来た。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先に腕車に乗ったのは、新しい紺飛白に繻子の帯を締めて、銀杏返に結った婦人。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十四　しばらくするとお雪は帯の端を折返して、いつも締めている桃色の下〆を解いて、一尺ばかり曳出すと、手を掛けた衣は音がして裂けたのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と小児のように、柔い胸に、帯も扱帯もひったりと抱き締めて、「御覧なさい、お月様が、あれ、仏様が。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は十七、八らしい、髪は油気の薄い銀杏返しに結って、紺飛白の単衣に紅い帯を締めていた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　市郎は痛む足を踏み締めて、例の毛綱を再び我が胴に緊と結び付け、綱を力に精一杯伸び上って、傍の高い岩に飛び付こうとしたが、何うも足が自由に働かぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は近頃財布の紐を締めていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸い腮から恰好のいい首すじへかけて透きとおるように白い……それが水色の着物に同じ色の羽織を着て黒い帯を締めて魂のない人形のように美しく気高く見えた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼して……あとを締めて……それから、その鼓を四ツともここへ……」　その言葉の通りに妻木君は影のように動いて四ツの鼓を未亡人と私の間に並べ終ると、その傍にすこし離れてかしこまった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何度云つても同じだが、フォルムに就いての理念のないといふことが、当今文学人をして彷徨不安ならしめてゐる第一の事だと思ふのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
