          "literary": [
            {
              "text": "文中「ひき移り」を「しき移り」となし、「ひる前」を「しる前」に書き誤っているのは東京下町言葉の訛りである。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんのお気に入ろうと思って、乃公にまで恁※に御愛嬌を振撒くのだろうが、豪気だの豪勢だのという下町言葉を使っては、気位ばかり妙に高いお花姉さんに好かれる筈がない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
