[
  {
    "uuid": "db19b45c-9b29-568e-a61f-e8f0599f1d30",
    "entry": "信頼",
    "reading": {
      "primary": "しんらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
