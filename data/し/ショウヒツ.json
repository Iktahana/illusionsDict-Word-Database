        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隠約とか省筆とかだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その敍事は省筆を以て、神曲の梗概を摸寫したるものなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは唯だ省筆を用ゐて、その大概を敍して已みなんとす。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらで省筆をするのは、読者に感謝して貰っても好い。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し何れも零れる程度だと省筆を用ゐて霧を抒した歌である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその把握の確かさと、あくまでも男性的な、むしろ野性的ともいいえられる省筆法と、對象に向って執拗にくいさがって行く手際の良さは無類である。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
