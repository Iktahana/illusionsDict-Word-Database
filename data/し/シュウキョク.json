[
  {
    "uuid": "b2ccaca1-fc3f-5349-b5f3-0a40c098c489",
    "entry": "終局",
    "reading": {
      "primary": "しゅうきょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
