  {
    "uuid": "55ccf3b8-f54a-576c-80dd-fc646b82a828",
    "entry": "終曲",
    "reading": {
      "primary": "しゅうきょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
