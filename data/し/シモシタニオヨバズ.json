          "literary": [
            {
              "text": "駟も舌に及ばず、三宅君地団駄ふんだが、後の祭で、及ばない。",
              "citation": {
                "source": "探偵の巻",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○　原文「駟不及舌」は「駟も舌に及ばず」という文語訳で有名である。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈黙を守るに若かず、無用の言を吐くと駟も舌に及ばずで、忽ち不測の害をかもすことになる、注意すべきは言葉であるという道徳の箴言に類した句である。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
