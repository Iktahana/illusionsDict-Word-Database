        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見ると柿色の囚人服を着た外山直堂であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、青い囚人服を着ていたとすれば、その場は無事に通り過せなかっただろうが、その時銀造はチマ子が差入れてくれた洋服を着ていたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの長閑な例――奇妙な囚人服を着せられ道路工事に使役されている土人の囚人の所へ、日曜着の綺羅を飾った囚人等の一族が飲食物携帯で遊びに行き、工事最中の道路の真中に筵を敷いて、囚人達と一緒に一日中飲んだり歌ったりして楽しく過すのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論囚人服を着たままですから、夜しか人里に出られなかった訳でしたが、私は盗みというものを絶対にしない方針でしたので、どこまでも青いお仕着せ姿で、鳥獣と同じ生活をして行かなければなりませんでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以外には何の準備も出来ない囚人服のまま、舞台裏から飛出して来たばかりの、金ピカ洋装の彼女と手に手を取って、涯てしない原始林の奥を目がけて、盲滅法に突進したのですからね。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒血だらけの引っ掻き傷と、泥と、ホコリに塗みれた素跣足の上に、背縫の開いた囚人服を引っかけて、太い、新しい荒縄をグルグルと胸の上まで巻き立てている彼の姿を見たら、大抵の者が震え上がったであろう。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の脱獄後の彼は、どこまでも囚人服を着換えなかった。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に囚人が男も女も民家に見る労働者よりも身綺麗に感ぜられたのは、その一定した浅葱色の囚人服のためであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前十一時、彼女は白布の囚人服のままで手を縛られて馬車に乗せられ、コンコルド広場へと運ばれた。",
              "citation": {
                "source": "パリの地下牢",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が出所したあとで、私の囚人服や独房内が、大勢の看守の手で大騒ぎをして取調べられていることだろうと思って、噴き出したくなった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色の囚人服に灰色の囚人帽をかぶった雑役は、水気の多いその食べものを、乱暴にバシャバシャという音をたててわけていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人カフェーっていうんで、そこじゃ給仕がみんな横だんだらの囚人服を着ていて、バーテンダアは看守のなりだよ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒルハウス嬢の囚人服があつらえたようにぴったりだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人服を着替え、うまい食事が欲しかったのです。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずうずうしい詐欺師が着ていた本物の囚人服があった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒルハウス嬢の上着を引っかけて、囚人服のまま実際にここへ来ている。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱獄囚は例の太い縞の囚人服のまま、その中へまぎれこんで、追手の目をくらます。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸内では囚人服の仮装とは妙案妙案と拍手をあびる。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
