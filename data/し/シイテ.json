        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何か強いて申上げようとすれば次のような事で御座います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて空虚を充たそうとする自覚的努力の余勢がかえって空虚その物を引展ばすようにも思われた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いていおうならば北斗南面して看るという唐ようの古語にでも表現を譲るより仕方はあるまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は身体を丘の芝に上から掴み押えられた窮屈な形を強いて保ちながら愕き以上のものに弄られている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いてそれらしいものを娘の言葉の中から捕捉するなら娘がいったいくたたびか迎える辛くも新鮮な青春、かくて遂に老ゆることを知らずして苦しくも無限に華やぎ光るいのち。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて訊くと「あんな伯母さんのことを気にかけるものではありません」「仔細あって私たちは交際ってはいません」「あれで、なかなか裏に裏のある女でね」「あんな大きな山に住えば誰だって評判はよくなるさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にっこりと笑った三要は払子を打って法戦終結を告げ、勝負は強いて言わずに、次の言葉を発しました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その味が自分たちのような、情味に脆い性質の人間を痺らせるのだろうと思いますよ」　強いて同感を求めるような語気でもないから、私は何とも返事しようがない気持をただ微笑に現して頷いてだけいた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて形容詞のなかへ入れられないような人間同志が無上の信頼と哀楽と相憐とを共にして生きて居る。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合には本来の意味内容のほかに強いて他の新しい色彩を帯びさせられたものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう話せば話すほど悲しくなるからとて強いて一同寝ることにした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が良人が所為のをさなきも強いて隠くさじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて延ばそうとすると千切れがちである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その店は卸し屋で小売はしないのであったが、強いて頼んで二つだけ売ってもらったそうである。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをも強いて振り落して全く新しい天地を見出そうと勉めているのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても我慢して見て、強いていいところを捜してやろうという気になれないのである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "代価を強いて取らせて破片だけを持って帰るのもあまりにぎごちない窮屈な気がする。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドでは宗教上の迷信から太陽を強いて直視するために内障眼を起す者が沢山ある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いてどっちかに入れなければならないとなりますれば、旧思想の方へ入れてお貰い申しましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮨の食べ方は巧者であるが、強いて通がるところも無かった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて押し黙っていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、私の眼鏡を見て、強いて近眼らしくよそおうとしているものと睨んだのである。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしＳの判断が本当であったとしたら、つまり私は自分の想像の中で強いて憐れな蜂を殺してしまって、その死を題目にした小さな詩によって安直な感傷的の情緒を味わっていた事になるかもしれない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて云えば天気の晴曇や日常の支障というような偶然の出来事のために一日早く見付けるかどうかという事が問題になるだけであろう。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢屋の主人は五年まえに世を去って、今では後家のお豊がひとり息子の後見役でこの大きな店を踏まえているのであるから、彼女が飽くまで行者を信仰して、わが子の祈祷になんの故障もない限りは、ほかの奉公人どもが強いてそれをさえぎるわけには行かなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅の木谷と柿本は、身に疵があるのに、強いてそれをかくして笑うような中尉の笑い方に目をとめた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰るべきわが運ならば、強いて止まらむと乞いたりとて何かせん、さるべきいわれあればこそ、と大人しゅう、ものもいわでぞ行く。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雜木林の出つ鼻の落葉の上に風呂敷をしいて坐り込んで向ひの丘を寫し始めた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生愛想笑いをする癖が、悔やみ言葉の間に出るのをしいてかみ殺すのが苦しそうであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
