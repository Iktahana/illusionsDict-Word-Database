[
  {
    "uuid": "802bbc09-40ee-59b0-ae33-28bb8c06e3c6",
    "entry": "信受",
    "reading": {
      "primary": "しんじゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "belief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "観測器械を入れたテントのそばには無線電信受信用のアンテナが張ってある。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神その真正において信受せる者、いかで呟くの必要があろうか。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてこの要求はナザレのイエスを独子として信受して初て満たさるるものである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『譚海』一二に、日光山には走り大黒というあり、信受の者｜懈怠の心あらば走り失せてその家に座さず、殊に霊験ある事多し、これは往古中禅寺に大なる鼠出て諸経を食い敗り害をなせし事ありしに、その鼠を追いたりしかば下野の足緒まで逃げたり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "純真に生きる――さうするより外に私が生きてゆく道はなくなつた、――この一念を信受奉行せよ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其の頃にはまだホンの噂話だけであった短波長無線電信の送信受信の実験にとりかかっていました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教は歴史的に釈迦によって開顕されたのであり、我々におけるこれが信受も歴史的に決定さるべきものである。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこの受け難い人身を受け、この聞き難い法を聞いたとすれば、速かにこれを信受しなければならぬ。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "当知我於五濁悪世行此難事得阿耨多羅三藐三菩提為一切世間説之難信之法是為甚難仏説此経已舎利弗及諸比丘一切世間天人阿修羅等聞仏所説歓喜信受作礼而去。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実秀の妻室も深くこの消息の教えを信受してよき往生の素懐を遂げたという。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは電信受付口で青木家に電報を書いた。",
              "citation": {
                "source": "愚かな父",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、またこんなにこくめいに発信受信を記していた弟が、八通の葉書の外に封書を送ったものとすれば、それを記していないはずはありません。",
              "citation": {
                "source": "日記帳",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女さまは、つむぎ車ぐらいもある、大きなしんじゅの上に腰かけていてね、そのまわりには、女官たちと貴族たちがひかえていたんだけど、その人たちばかりじゃなく、女官たちの小間使いと、またその小間使いの小間使いや、貴族たちの侍僕と、またその侍僕たちが、ずらっと、ならんでいたんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまがくださる、なぐさめのしんじゅなのだよ。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみと、しんじゅうするくらいに、きみを好いてくれるような、そんな、編輯者でも出て来ぬかぎり、きみは、不幸な、作家だ、と一語ずつ区切ってはっきり言った。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、その子は、つかつかと、糸車ほどの大きなしんじゅに、こしをかけている、王女さまのご前に進みました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのきているきものでも、光るしんじゅでも、きれいな宝石でも、それから金のかんむりでも。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しんじゅと、ほうせきがたくさんほしい。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お父さんはおまつりで、ふたりの姉がたのんだとおり、きれいなドレスと、しんじゅにダイヤをかいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "出てくる出てくる　あれあれごらん、黄金のかみの毛　まっ赤なほぺた、水晶のまなこ　しんじゅの白歯、かわいざかりの　男と女、町の子どもは　皆あつまった。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿さま、お召しでござりますか」　銀のスズをならすようなかわいらしい声、ふりかえると右手の方、枕にちかく、魚群をかきわけて、一匹の人魚が、桃色しんじゅの肩を水のうえにだして、みごとな黒髪をサッと水の上にただよわせるのでした。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色ガンの、しゅすのようにつややかなはねの上には、しんじゅのような水のしずくがたまっていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
