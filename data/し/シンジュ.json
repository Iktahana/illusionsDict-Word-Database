    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mystic spell",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『記』にまたいわく、猴王作ったてふマントラ・シャストラ（神呪論）を講ずれば力強くて神のごとくなるという。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水の西の淵には九つの頭を有する悪龍が棲んでいて、土地の少女を其の生贄として取り啖っていたが、満巻上人の神呪によってさすがの悪龍も永く蟄伏し、少女の生贄に代えて赤飯を供えることになった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "般若波羅蜜多は、是れ大｜神呪なり。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この『心経』の本文には、「是れ大｜神呪、是れ大｜明呪、是れ無上呪、是れ無等等呪」といって、四種の「呪」が挙げてありますが、要するに、これは般若波羅蜜多は、最も勝れた仏の真言だ、ということをいったものです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまず第一に、「是れ大神呪なり」とは、神とは霊妙不可思議という意味ですから、これ大神呪なりということは、われら人間の浅薄な知識では、容易に測り知ることのできぬ、霊妙不可思議なる仏のことばだということです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、破壊神呪咀の神は、自分の正面に来るものしか見えないのが特性です。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、忙しがって衝突して首の附け根を折るウォウル街の株屋や、地下鉄で自ら進んで「｜春の鶏」に足を踏まれたがる「神呪された胡桃」の多いのを目的てに、紐育で接骨医を開業しました。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主が大吉義神呪経の吸血伝説を信じているように、貴方がたも大変な誤ちを冒そうとして居ります。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしか、あの日に寂蓮尼が、大吉義神呪経の中にある、孔雀吸血の伝説と云う言葉を云ったっけね。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、いつぞやの『ウエビ地方の野猟』と、大吉義神呪経の図書番号とが、入れ違いになっている事なので、意外にも片方になかった記述が、セントジョンの著述にある挿話から発見されたのだよ。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十日夜戌の刻堂内の明を消して、生贄にする僧（貞云、名所図絵に俗とあるは古い式で、後には僧を以て之に代へたものか）を座せしめ、衆僧も暗中に居て、代る／＼陀羅尼や神呪を大声に唱へて、彼の僧を一時祈り殺す。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女さまは、つむぎ車ぐらいもある、大きなしんじゅの上に腰かけていてね、そのまわりには、女官たちと貴族たちがひかえていたんだけど、その人たちばかりじゃなく、女官たちの小間使いと、またその小間使いの小間使いや、貴族たちの侍僕と、またその侍僕たちが、ずらっと、ならんでいたんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまがくださる、なぐさめのしんじゅなのだよ。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみと、しんじゅうするくらいに、きみを好いてくれるような、そんな、編輯者でも出て来ぬかぎり、きみは、不幸な、作家だ、と一語ずつ区切ってはっきり言った。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、その子は、つかつかと、糸車ほどの大きなしんじゅに、こしをかけている、王女さまのご前に進みました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのきているきものでも、光るしんじゅでも、きれいな宝石でも、それから金のかんむりでも。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しんじゅと、ほうせきがたくさんほしい。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お父さんはおまつりで、ふたりの姉がたのんだとおり、きれいなドレスと、しんじゅにダイヤをかいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "出てくる出てくる　あれあれごらん、黄金のかみの毛　まっ赤なほぺた、水晶のまなこ　しんじゅの白歯、かわいざかりの　男と女、町の子どもは　皆あつまった。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿さま、お召しでござりますか」　銀のスズをならすようなかわいらしい声、ふりかえると右手の方、枕にちかく、魚群をかきわけて、一匹の人魚が、桃色しんじゅの肩を水のうえにだして、みごとな黒髪をサッと水の上にただよわせるのでした。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色ガンの、しゅすのようにつややかなはねの上には、しんじゅのような水のしずくがたまっていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
