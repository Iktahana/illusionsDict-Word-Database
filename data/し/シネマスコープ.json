          "literary": [
            {
              "text": "特にシネマスコープといった画面を横長に取った作品では、歪みは大きくならざるを得ません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "影男の眼前一尺に近づいて、シネマスコープの大写しになって、赤いよだれをたらしながら狂笑した。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイヤル・ハワイアン・ホテルの、シネマスコープ映写設備を持つ、特別に豪華な造りの広い部屋だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ日が高いからというので、有楽町に廻って、シネマスコープを見たが、その道でも、映画館の中でも、尾行者らしい者は、どこにもいなかった。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
