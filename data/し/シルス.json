    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to write down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甞ては私にも、金のペンで記すべき時代があつた！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく同じような事を二度は書きたくないから、前に書かなかったと思うことだけを記すことにする。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方が無いから、Ｎさんが、それからおつしやつた、氣持のいい言葉を、歪曲すること無く、そのまま次に書き記す。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒ヶ岳の麓、台ヶ原の客舎に昼餐を了りたる束の間に、禿筆を舐ぶりて偶感を記す、その文を成さざる、冀くは我が興の高きを妨ぐるなからむ。",
              "citation": {
                "source": "山を讃する文",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮方面の案内者は、深沢弥作といって、親切な男であったことを附記する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物語を書き記す作者のもとへは、下町のある知人の紹介で和歌を学びに来たのであるが、そのとき彼女はこういう意味のことを云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に言語などを機械的に暗記する事の下手な彼には当時の軍隊式な詰め込み教育は工合が悪かった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主に口授を筆記するのであったが、たまたま何かの教材の参考資料として、英国製で綺麗な彩色絵の上に仮漆を引いた掛図を持出し、その中のある図について説明をした。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詳記するを許されませんがこの六ヶ月はコタエマシタ）　近く病院が移動するらしいですから、その時また、お便りします。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ不正を企るのならば、百三十六｜個の麻雀牌の背中の竹の木目を暗記するなどは、その努力感だけでも僕には寧ろ氣持がいい。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の顛末を記録するためには先ずわが家のラジオの歴史を略記する必要がある。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより一説ある處、何の大晦日を逃げた癖に、尊徳樣もないものだと、編輯の同人手を拍つて大に嘲けるに、たじ／＼となり、敢て我胸中に蓄へたる富國經濟の道を説かず、纔に城の俤を記すのみ。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台堀と油堀とを連ぬる小渠は一条のみならず、また木場附近の大和橋及び鶴歩橋の架れる一渠その他の小渠は、一これを記する能はざればなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永代橋より下流は川幅甚だ濶く、かつ上に説けるが如く分岐して二となるを以て、便宜上先づ西流東流の二つに分ちて記すべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ○下田川と称する名称のことを未だ説かざりしが、明治以前の雑書に時に下田川の名を記すものは、別に一水の流れをなすありて下田川と呼ぶところあるにはあらず、実に永代橋下流即ち隅田川本流の佃島近きところを指していへるのみ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "荼枳尼天の形相、真言等をここに記するも益無きことであるし、かつまた自分が飯綱二十法を心得ているわけでもないから、飯綱修法に関することは書かぬが、やはり他の天部夜叉部等の修法の如くに、相伝を得て、次第により如法に修するものであろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとにかくそういう種類の考えも、少なくも一つのヒントとしては役立つであろうと思うので、不謹慎のそしりを覚悟してついでに付記する次第である。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも一つのヒントにはなりうると思うからついでに付記する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらもすべて大胆すぎた想像であるが一つの暗示として付記する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――太郎記す………◇第三の瓶の内容　オ父サマ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山を望めば、心も消え入らんばかり懐し」同二十六日――夜十時記す「屋外は風雨の声ものすごし。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが毎日同じ事を繰り返している間にあらゆる興味は蒸発してしまって、すっかり口上を暗記するころには、品物自身はもう頭の中から消えてなくなる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "序にこの宝永の噴火の被害のひどかったことを記すと、その被害地の恢復に幕府は三十五年間から七十年余もかかったところがある。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に記すべき事がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く、爰に記すものは皆事實なりと。",
              "citation": {
                "source": "怪談会　序",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩は区々たる一二｜鼠輩を相手に論議する事を好まずと雖も、陋劣なる平凡主義者の実例として更に些か記する処なき能はず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は、これを記すのに張合がない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（第一、こゝを記す時、七月二十二日の暑さと言つたら。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、遺憾ながら、この晴の舞台において、紫玉のために記すべき振事は更にない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十六年二月校訂の時しるす）本書は昭和十二年五月内務省主催第二回神職講習会における講義を速記したものであって、昨年三月｜神祇院で印刷に附して関係者に頒布せられたが、今回｜書肆の請により同院の許しを得て新たに刊行したものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
