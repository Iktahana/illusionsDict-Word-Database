    "definitions": [
      {
        "index": 1,
        "gloss": "belonging to (a group, organization, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＊　それから、私たちは、文学の事はクラブで、政治、経済上の闘争は、それ／″＼の所属の団体で、とハッキリして、運動に入つた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九七―一九一三年の間、しばしば所属のヨット、イレネ号に、国王や王子その他のいわゆる Elder Brethren と一緒に乗込んで燈台の検分をしたり、燈光や霧報（fog-signals）の試験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の所属で、各種科学の特殊な専門的題目の研究所として看板をかけた処では、比較的にいくらか自由である。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし農民と、工場プロレタリアとは、その所属する階級がちがっている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云えば、十挺の鉄砲と、それに相当する弾薬、所属品が売れたことだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田山花袋の「一兵卒」は、日露戦争に、満洲で脚気のために入院した兵卒が、病院の不潔、不衛生粗食に堪えかねて、少しよくなったのを機会に、病院を出て、自分の所属部隊のあとを追うて行く。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の名はシビリアコフ号、これがソビエト政府の北氷洋学術研究所所属の科学者数名を載せて北氷洋をひと夏に乗り切ったものであるということが新聞で報ぜられた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君のうちの希望者は、けだしいつもの例により、そのノートをば拙者に示し、さらに数箇の試問を受けて、所属を決すべきである。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してそうならば、私もいまから自分の所属を分明にして置く必要がある。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にあらゆる一切の表現は、この二つの所属の中、何れかの者に範疇している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん吾人の知ろうとする詩も、この二つの所属の中、どっちかの者でなければならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に「生活のための芸術」が求めるものは、より燃焼的で温熱感に富んでるところの、音楽の範疇美に所属している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳的精神はどんなものでも、本質に於て一種の詩的精神であり、詩という言語の広い所属に含まれてる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの本質的なる韻文の定義に対し、散文の定義は「非音律本位の文」である故、この意味の言語ならば、自由詩は、決して散文に所属されない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に詩の本質は、常に必ず「生活のための芸術」であって、真の芸術至上主義には所属できない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の専門学校級の生徒は、いまと違って、社会から一個の紳士としての待遇を受けていたので、その所属の学校の名刺を所持している学生も多かったが、しかし、こんな出鱈目な肩書の印刷されてある名刺は、実にめずらしいものであった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三人とわたくしは、また、舎宅に住んでいる安宅先生に所属のグループでもありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸の中は煌々と照るシャンデリアの下に、ワニスが冷く光るデスクを一つ置き、人は誰もいないで、壁に掲げられているこの店に所属する製造工場の写真額があるだけの店があります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "××街の大劇場○○座が今度経営困難に陥り米国の富豪某氏所属のデパートとなった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお詳細は不明であるけれども、平安朝時代にその梅津家の一人が九州筑後高良山玉垂神社所属の田楽法師として下向し、久留米市の南方一里ばかりの所に現存する朝日村を所領として家業を伝えた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽の家元はそれぞれ自流所属の舞台、楽屋、住宅を持ち、自流の能の演出、発表に必要な舞い手、又は謡い手として必要な内弟子を養っている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　電話が自働式に変わると同時に所属局が「小石川」から「大塚」に移り、さらにまた番号がもとより三〇〇〇だけ数を増した。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新前には藩の調練場であったのが、そのころは県庁の所属になったままで荒れ地になっていた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所属倶楽部、英印倶楽部、タンカービル倶楽部、バガテル骨牌倶楽部」　そしてその余白に、ホームズの達筆で、「ロンドンで第二の危険人物」　とある。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールダショットのロイヤル・マロウズ所属のバークリ大佐が殺されたと目されているのだが、これを僕が調べている。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＣＯＭＰＵＴＥＲ』という雑誌の一九七七年三月号に載った「パーソナル・ダイナミック・メディア」という記念碑的な論文の最後に、彼がユタ大学に博士論文として提出した「ザ・リアクティブ・エンジン」や、所属していたゼロックス社パロアルト研究所の技術レポートとしてまとめた文献に関する記述がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友人の影響に加え、所属していたプロダクションの好奇心旺盛な社長に「いっしょに勉強しよう」と誘われたこともあって、私はコンピューター言語のベーシックで、プログラムを書く作業に熱中し始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "所属していた会社の倒産があり、その後、スポンサーを見つけて新しい雑誌を起こしていた魚岸さんは、自分の雑誌で一部を連載したいと申し出てくれます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿書きが増えてくるとオレはなぜ自分が編集プロダクションに所属しているのか分からなくなり、会社を辞めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたしは、大田黒君の所属艦に宛名を書きながらＲにいつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
