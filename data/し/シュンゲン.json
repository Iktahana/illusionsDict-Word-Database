[
  {
    "uuid": "8b77e546-0aaa-55ca-843b-951ec0ea5a39",
    "entry": "峻厳",
    "reading": {
      "primary": "しゅんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
