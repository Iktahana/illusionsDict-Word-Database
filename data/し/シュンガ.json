    "definitions": [
      {
        "index": 1,
        "gloss": "shunga",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春美といって二十六歳、かつて某浪花節寄席の持主の妾をしていたことがあり、旦那は南五花街の遊廓で誰知らぬ者のない稀にみる漁色家で、常に春画春本淫具の類を懐中にしている男であると、女は何を思い出したのか何もかも千恵造に打ちあけた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその頃から、春画のコピイをして密売しました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその薬品を得たいばかりに、またも春画のコピイをはじめ、そうして、あの薬屋の不具の奥さんと文字どおりの醜関係をさえ結びました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして手に入れたのか、一人が春画を持って来た。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友達は、春画を買おうといった美しい少年であった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四年十月四十四年の春から秋にかけて自分の間借りして居た旅館の一室は古い土蔵の二階であるが、元は待合の密室で壁一面に春画を描いてあつたそうな、それを塗りつぶしてはあつたが少しづつくづれかかつてゐた。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は勿論、全身を赤はだかにして、手足から乳のたぐいに至るまでいっさいを写生する――今日のモデルとは意味が違って、いわば一種の春画である。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は笑えなかったが、日本の春画がつねにユーモラスな筆致で描かれている理由を納得したと思った。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本邦で書箱｜鎧櫃等に、春画を一冊ずつ入れて、災難除けとしたなども、とどの詰まりはこの意に基づくであろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅から帰つて来てからでは、例の奥女中の条が好い、春画を見る条、つゞいてあのくさりかたびらの条、あれが滑稽に書いてあつて、そしてちつとも滑稽でない。",
              "citation": {
                "source": "西鶴小論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "春画だつて芸術であれば構はない。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡な春画の他に、血を流す美少年、猛獣に喰われる美女なぞの絵を愛好する。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛色の変ったのでは、春画を描いて学資を作って美術学校を出たのが居る。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の春画がボサボサに紙に毛が立つほど、何度も、何度もグルグル廻された。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき春画には幽霊味があり、よき宝石にも幽鬼味がある。",
              "citation": {
                "source": "妖異むだ言",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那、春画だよ、ほら！",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "停まるが早いか、くだんの靴磨き少年をはじめ、例の春画売り、絵葉書屋、煙草屋、両替屋、首飾屋、指輪屋、更紗屋、手相見、人相見のやからが翕然と集合して来て、たちまち身動きが取れなくなる。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "１　マルガリイダに内証でいつ写したものか、リンピイは、品物の一つ一つに、例の白熊テレサの裸体写真や、それから、テレサと黒輝石のような印度人の火夫との春画しゃしんやなんかを上手にひそめていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁縫師の女房から本が借りられなくなると、ゴーリキイは若いのらくら男女の寄り合い場となっている街のパン屋で、副業に春画を売ったり猥褻な詩を書いてやったり、貸本をしたりしている店から、一冊一｜哥の損料で豆本を借り出した。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "春信や師宣の春画も立派な裸体群像だと私は考えていますが、猥感を主体としているために人前だけははばかる必要があるのです。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足のうまさの現れを私は昔の春画において最も味い得るものと思う。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の、のでん賭博というのは、数人寄って賽を転がしている鼻ッ張が、田舎者を釣りよせては巻き上げるのですが、賭博場の景物には、皆春画を並べてある。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者が春画を見てては釣られるのです。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオリス・ドニでもなし、そうかと云って――」　近藤は鼻眼鏡の後の眼を閉じてしばらく考に耽っていたが、やがて重々しい口を開こうとすると、また大井が横合いから、鉈豆の煙管を啣えたままで、「つまり君、春画みたいなものなんだろう。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところでどうでしょう、春画などと云う物は、やっぱり西洋の方が発達しているんですか。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一概に春画と云いますが、まあざっと三種類に区別するのが至当なので、第一は××××を描いたもの、第二はその前後だけを描いたもの、第三は単に××××を描いたもの――」　俊助は勿論こう云う話題に、一種の義憤を発するほど、道徳家でないには相違なかった。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゅんとヒトツトシだが、おしゅんがまだ人の見さかいもつかぬうちに、猿の子はもう木にも上れば、しまいにはおしゅんの子守までするようになった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯篠老人は、季節がよくなると来はじめる、と云ったようだが、こんなことにもしゅんがあるのかもしれない。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
