    "definitions": [
      {
        "index": 1,
        "gloss": "fine brush (for writing square style Chinese characters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つ一つ「帽子」を脱ぎ取って縁側へ並べたり子芋の突起を鼻に見立てて真書き筆でキューピーの顔をかき上げるものもあった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時尋ねると、極細い真書きで精々と写し物をしているので、何を写しているかと訊くと、その頃地学雑誌に連掲中の「鉱物｜字彙」であった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下で、雁皮紙を横綴にしたものへ、真書き筆で、こまごまと父への手紙をかく。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、大版の美濃紙を以つて、極細の真書きに墨汁を含ませ、その毛筋のやうな線を縦横に引いて「銅版画」を「毛筆画」に写してゐる。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒は行儀よく鋏で截られていて、なかに日本の雁皮紙にしんかきでぴっしり書き埋めた厚い手紙が入っていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、泰造がロンドンに行っていた足かけ五年の間に、まだその頃三十歳にかかる年ごろだった多計代は、雁皮紙を横にたたんで、そこへしんかきのほそくこまかい字をぴっしりつめて、何百通もの手紙をかいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
