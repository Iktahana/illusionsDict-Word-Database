    "definitions": [
      {
        "index": 1,
        "gloss": "exhibitor (at a trade show, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "展示会場の入り口で、出展者専用のパスを受け取り、自分のブースの設営準備に取り掛かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商談会では、出展者とバイヤーが熱心に名刺交換を行い、新商品の導入に向けた具体的な条件交渉が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "イベントの最後には、出展者たちが集まって記念撮影を行い、成功を祝って互いの健闘を称え合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大半の出展者がジャンクから取った部品でどうにかやりくりして安く仕上げたシステムを並べている中で、早稲田大学の学生であるという西は、数百万円はするのでないかと思われるＨＰ製の機器を接続し、オルガンの自動演奏システムを組んで悦に入っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
