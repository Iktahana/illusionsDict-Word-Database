[
  {
    "uuid": "f3353a0f-4c77-5f05-bb3c-26b39a1b0aa0",
    "entry": "宗祖",
    "reading": {
      "primary": "しゅうそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
