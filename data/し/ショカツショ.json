    "definitions": [
      {
        "index": 1,
        "gloss": "taxation office serving a specific area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
