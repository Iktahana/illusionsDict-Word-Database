        "examples": {
          "standard": [
            {
              "text": "病院の受付で診察券を提出して、問診票に記入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日は歯医者だけど、うっかり診察券を忘れてきてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての病院だったので、診察券を作るのに少し時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三七　受付で、診察券を買って、外科の待合室で順番を待った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「艶子は診察券を買わなかったのだ」「前に買って持っているのかもしれない」「もし持っているなら受付へだね――うん、レントゲン科の受付へだ、少なくも出さなければならないはずだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
