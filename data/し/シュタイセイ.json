[
  {
    "uuid": "9f8023a2-1fca-56a9-bd9e-83c1f2450858",
    "entry": "主体性",
    "reading": {
      "primary": "しゅたいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
