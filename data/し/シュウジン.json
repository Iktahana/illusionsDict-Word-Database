    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prisoner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河原に冬の枯草もえ重たき石を運ぶ囚人等みな憎さげに我れを見て過ぎ行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央に望樓ありて、悲しく四方を眺望しつつ、常に囚人の監視に具ふ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にばたばたと飛び立った胸黒はちょうど真上に覆いかかった網の真唯中に衝突した、と思うともう網と一緒にばさりと刈田の上に落ちかかって、哀れな罪なき囚人はもはや絶体絶命の無効な努力で羽搏いているのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一歩進んで姓名の代りに囚人のように三一六五八九二四といったような番号をつけるのも最合理的な一方法であるかもしれないが、そうなるのはやはり悲しい。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲罰日誌そのものゝなかには囚人の悲慘がユーモアに包まれて寫されてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男達の中には、甲冑の下に奧深く、あたかも囚人のやうに、その死を閉ぢこめて置いた者もあつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろへまわした両手を背中で項に引きつるようにされていた囚人は、項からだけ繩をときほぐされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かせないように囚人の頭と、背を支える二人の地方がこづきあげた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、囚人をのせてきた俥夫だけは、不吉げに悄れこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒に肩を怒らした機関車を先に立てて、囚人のようにつながって来る貨物車の群れが見える。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "開場式のお歴々の群集も畢竟一種の囚徒で、工場主の晩餐会の卓上に列なる紳士淑女も、刑務所の食卓に並ぶルンペンらも同じくギャングであり囚人の群れであるように思われてくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば極貧を現わすために水道の止まった流しに猫の眠っている画面を出すとか、放免された囚人の歓喜を現わすのに春の雪解けの川面を出すとか、よしやそれほどの技巧は用いないまでも、とにかく文学的の言葉をいわゆるフォトジェニックなフィルミッシな表現に翻訳しなければならない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思い切ったる死に狂い見よ」「青天に有明月の朝ぼらけ」と付けたモンタージュと、放免状を突きつけられた囚人の画像の次に「春の雪解け川」を出した付け合わせと、情は別でも、手法においてどれだけの差別があるか。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時囚人は、どんな心持だらう、どんな心持だらう、その時銀座はいつぱいの人出、浅草もいつぱいの人出。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、どやどやと人の足音がして、真先に黒服の看守が立つて、二組の囚人が門の外へ出て来た。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人がどうして居るだらうと思つて、じつと考へ込んで居るときには、赤煉瓦の高い塀と、黒い鉄の門と、柿色の衣物を着て鎖でつながれた囚人の姿とがいつでも目に浮んで来る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の目を見ない瞳はどんよりと濁り、頬は蒼ざめ、さかやきはのびて穢くるしくなつて居たあの時の囚人の顔が、自分の良人の顔と一つになつて、まざまざと闇の中でも見えて来る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の疲もあり、蒸々する晩でもあり、不寝番の控室てはとろとろと仮寝の鼾も出ようと云ふ真夜中に、けたゝましいもの音、やにはに飛出した囚人。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "開かれるときは此後永久に来ないかのやうに、堅い厳しい戸締の音が、囚人の頭に響いた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑つて笞を受けた囚人は、後には泣いて追慕の涙に滲んだ弔詞を受ける先覚者である。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると柿色の囚人服を着た外山直堂であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」若い弁護人は、殊更に気丈さを装ふらしき此男の囚人姿を目送した。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢内の習慣で、拷問をうける罪人があるときは、牢名主その他の古顔の囚人どもが彼に対して色々の注意をあたえ、拷問に堪え得る工夫を教えて、たとい責め殺さるるまでも決して白状するなと激励するのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおそろしい根くらべにも打ち勝って、かれは無事に牢内へ戻って来て、他の囚人どもを驚かした。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "未決の囚人であるから、かれはいわゆる役附の待遇をうけるわけには行かなかったが、実際はその以上に優遇された。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢名主の声がかりというので、彼は普通の囚人とは全然別格の待遇をうけて、他の囚人どもを手下のように使役するばかりでなく、三日に一度ぐらいは鰻飯などを食って贅沢に生活していた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎はその晴衣を身につけて牢内から牽き出されると、それを見送る囚人一同は、日本一、親玉、石川五右衛門と、あらゆる讃美の声々をそのうしろから浴せかけた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて迂闊に放免するわけにも行かないので、そのまま獄屋につないで置くと、その囚人がある夜ひそかに獄卒にささやいた。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの幾らかで酒と肉とを買って内所で囚人にも馳走してやると、それから五、六日経って、囚人は又ささやいた。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
