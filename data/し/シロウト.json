    "definitions": [
      {
        "index": 1,
        "gloss": "amateur",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俳人としての室生犀星は、要するに素人庭園師としての室生犀星に外ならない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は素人考えで何でも楽器は指の先で弾くものだから女に適したものとばかり思うていたが中々そんな浅いものではない。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような変化がどうして起こるかはわからないが、いちばん直接な原因はやはり血液の循環の模様が変わったために脳の物質にどうにか反応する点にあると素人考えに考えている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の素人考えではこの方法論はかなり突きつめて研究さるべき問題のように思われます。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした茫漠たる冬田の中に一羽くらい鴫が居るのを見付け出すということは到底｜素人には出来ない芸当であったが、さすが専門家の要太の眼には、不思議なフィルター・スクリーンでもあるかのように、実に敏感に迅速にそれを発見するのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上はただ全くの素人の想い出話のついでに思い付くままの空想を臆面もなく書付けて見ただけである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生は唯美しいとばかりで不注意に見過して居る秋の森の複雜な色の諧調は全く臆病な素人繪かきを途方にくれさせる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこんな試験は素人では出来ぬ。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弧灯と白熱灯の外に、なお素人のあまり知らぬ有用な電灯が二種ある。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって職業上の名の小そのとだけでは、だんだん素人の素朴な気持ちに還ろうとしている今日の彼女の気品にそぐわない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人の中には思いがけない素人や芸人もあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺の「ボンネットを一度水車小屋の磨臼に抛り込んだ以上」は、つまり一度｜貞操を売物にした以上は、今さら宿命とか身の行末とかそんな素人臭い歎きは無い。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人らしいものを求める。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄人から見れば素人は不粋である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のプレイが素人目に見てもそれぞれちゃんとはっきりした特徴があって面白い。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客中の本職の素人が臨時に頼まれて出て来たのかと思うほど役者ばなれがして見えた。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが物理学のかなり深いところを探究しているつもりでも、時々子供や素人から受ける質問が往々にして意外に根本的な物理学の弱点にふれる事を見るのである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者と素人との意思の疎通せざる第一の素因は既にここに胚胎す。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに素人画家のスケッチのようなものだと思って読んでもらいたいのである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へ帰ると世界中の学者や素人から色々の質問や註文の手紙が来ている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから其小刀は素人作の桐の柄がすえてある。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人ながらも、何ら生ある音を聞き得ない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の通俗講演の聴衆三百人ほどの中には専門家も居れば素人も居た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この理窟を素人流に応用すると、歯を噛み合わせる動作によって緊張努力の気持が幾分かは助長されるという効果があるのかもしれない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論これらはほんの素人の慰み半分の小型映画作品であったのでこういう厳重な批評をするのは無理であろうが、これでもおおよその水準を窺うことは出来るであろうと思われる。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはむしろ自分のような純粋な素人の評の方が却って適切であり得るかもしれない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の技巧に関する伝統が尊重された時代には、芸術の批評権といったようなものは主に芸術家自身か、さもなくば博学な美術考証家の手に保存されて、吾々素人は何か云いたくなる腹の虫を叱り付けていなければならなかった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか道灌山へ夏目先生と二人で散歩に行った時、そこの崖の上で下の平野を写生していた素人絵かきがあった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、そんなことで筆頭などゝ認められても、格別嬉しくもないが、そも／＼私が寫眞を初めたのは、十一二の時分のことで、年｜號にすれば、明治三十五六年、流行｜物どころかしろうとに寫眞など寫せるものではないといふやうな考へのある時｜代だつた。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の紹介で、或寺の一室を借りるつもりであつたが、たづねて行つて見ると、いろ／＼取り込みのことがあつて、この夏は客の世話が出來ないと云ふので、またその住持の紹介を得て、しろうとの家に置いて貰ふことになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
