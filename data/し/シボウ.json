[
  {
    "uuid": "4efe87d2-a7ea-5afd-890b-f5902be8807e",
    "entry": "志望",
    "reading": {
      "primary": "しぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
