[
  {
    "uuid": "6e07ecf5-e33a-57ce-a62f-7c3ecd883f5f",
    "entry": "死魄",
    "reading": {
      "primary": "しはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "waning moon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "くづれる肉體蝙蝠のむらがつてゐる野原の中でわたしはくづれてゆく肉體の柱をながめたそれは宵闇にさびしくふるへて影にそよぐ死びと草のやうになまぐさくぞろぞろと蛆蟲の這ふ腐肉のやうに醜くかつた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀を戀する人わたしはくちびるにべにをぬつてあたらしい白樺の幹に接吻した。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――荒寥地方――くづれる肉體蝙蝠のむらがつてゐる野原の中でわたしはくづれてゆく肉體の柱をながめた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはくさ／＼しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まがつみのうしはく山か。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒山の狹沼うしはく。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アグネス」と、わたしはくりかえした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「声が駄目なの――自分でもあたしはくだらないことを気にすると思つて誰にも云はないんだけれど、どうしても我慢出来ないつてことが解つたのよ。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度はいつ来るな、お前」「この次の土曜日には帰る」「それまでに少しはどうかならんか」「どうだかわからんけれど、月末だから少しはくれるだろうと思うがね」「少しでも手伝ってもらうと助かるがな」　清三は返事をしなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはくわしい内情を知らなかったが、菫坡老人は一方、やまと新聞社に籍を置いていながら、一方には東京日日新聞社の印刷部を監督しているらしかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはくずしかけている膝を直した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は驚いて、どうしたのかと夫人の顔を見つめますと、夫人は、「先生、わたしはくやしいです。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、わたしはくやしいです。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "是においてか同行者中少しはくつろぎたりとてやや帰思を緩うする者あり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう経済主義的な考えかたに、わたくしはくみすることができない。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにわたしはくやしくってたまらない。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしはくらげといって竜王の御家来さ。",
              "citation": {
                "source": "くらげのお使い",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはくひしんぼで食道樂からばかり菜の花漬をおぼえてゐたのではないが、あると聽いてうれしかつた。",
              "citation": {
                "source": "春宵戲語",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたしはくくくと笑った。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁の説を詮じつめれば、夜見或は、根と言ふ名にこめられた、よもつ大神のうしはく国は、祖々に常夜と呼ばれて、こはがられて居たことがある、と言ひ換へてもさし支へはない様である。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "壓はおそはく・うしはくの義の「壓す」から出たものでなく、また「大」に通ずる忍・押などで宛て字するおしとも違ふ樣だ。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、相良惣三らのこころざしはくんでやっていい。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはくよくよ思いながらうとうとねいった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでわたしはくやしくなって気を入れて勉強した。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはくたびれたし、ねむたかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはくらくらとした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、わたくしはくやみにも行けば告別式にも行つた。",
              "citation": {
                "source": "萩",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世間の亭主はどんなもんか、少しはくらべて見るがいいんだ」「恩にきせるなんて――卑怯ですよ」「俺が卑怯かどうか、伸子にきいてみろ」「ほら、とうとうあなたの、伸子にきいてみろ、が出た！",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この重荷の下でわたしはくずおれたりはしないだろう、その重荷がどんなに大きくたって！",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどんな風評で、いつ誰から出たか……そして、いかなる動機であなたの身にまで及んだかということも、やはりわたしはくだらない話だと思います。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
