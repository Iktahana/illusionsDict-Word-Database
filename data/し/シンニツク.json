    "definitions": [
      {
        "index": 1,
        "gloss": "to go to bed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さて夕食が終わって、私は寝に就く前に、しずかに煙草をふかそうと思って、甲板へ登って行った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "並の席より尺余床を高くして置いた一室と離屋の茶室の一間とに、家族十人の者は二分して寝に就く事になった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔は戸を閉じ、帷を垂れて寝に就くと、夜なかに女の姿が見えなくなった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝九時脱稿、十時寝に就く。",
              "citation": {
                "source": "雲の日記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆聞き慣れた祈祷の文句と歌調を耳に宿して寝に就く。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸締りの音蚊帳を釣り寝に就く午後十一時より十二時迄　枕もとの時計の音のみ聞えて天地は極めて静かな。",
              "citation": {
                "source": "夏の夜の音",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝に就くのは十時である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日のこと、それは自習時間といつて、夕食後から寝に就くまで、自習室に籠つてそれぞれ学課の予習復習をしなければならぬ時間であつたが、私の少年の胸にかねがね鬱積していた疑問の爆発する機会が来た。",
              "citation": {
                "source": "いわゆる「反省」は我々を救うか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪の心地にて早く寝に就く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮家に帰り孤燈の下に独粥啜らむとする時、俄に悪寒を覚え、早く寝に就く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど年賀に行くべき処なければ、自炊の夕餉を終りて直に寝に就く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉辺更に葡萄酒を傾けて寝に就く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "窗を開いて寝に就く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子と炉辺にキユイラツソオ一盞を傾けて寝に就く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は知っていた、山々の奥の国なるヴァルパ、ニガアの廊から流れ下る流れの水も今日の彼はもう飲まない、今日の彼は例の如く夕日に見惚れて時を過ぐしやがて洞に帰って来てまだ人間というものを知らぬ河水に引かれながら立っている藺の上に寝に就くのではないということも知っていた。",
              "citation": {
                "source": "人馬のにひ妻",
                "author": "ロード・ダンセイニ　Lord Dunsany",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は其の客が軈て寝に就く時になつて初めてそれと悟つた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "該地に滞留すること八日｜維時、その月二十八日夜、寝に就く。",
              "citation": {
                "source": "妖怪報告",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ソクラテスの言わるるには、「人あり、その寝に就くに、数｜壜に熱湯を盛り脚冷を防ぎけるに、その夜、エトナ山の噴火口辺りを徘徊したりと夢みし」と。",
              "citation": {
                "source": "妖怪報告",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "船客、一人の寝に就くものなし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "セエラは寝に就く時、また新しい厚い敷蒲団と、大きな羽根枕のあるのを見つけました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けてはじめて寝に就くというようなことになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜光虫の誤りだと判ったとき、整備兵たちはどんな思いでまた寝に就くのであろう。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼は上機嫌で、具足をつけたまま仮寝に就く。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
