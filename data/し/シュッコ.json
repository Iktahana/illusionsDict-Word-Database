    "definitions": [
      {
        "index": 1,
        "gloss": "delivery from a storehouse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は出庫前の機関士席に腰を降した膝の上で、バラバラと頁を繰っては、思わない味方を得たような気持です、と云っていた。",
              "citation": {
                "source": "指導物語",
                "author": "或る国鉄機関士の述懐",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこだって毎日行く。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、舜一なんだけれども、みんなはいつでもしゅっこという。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういわれても、しゅっこは少しも怒らない。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからみんなは、いつでもしゅっこしゅっこという。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、しゅっことは、いちばん仲がいい。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこも、大きな白い石をもって、淵の上のさいかちの木にのぼっていたが、それを見ると、すぐに、石を淵に落して叫んだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、木の上で手を額にあてて、もう一｜度よく見きわめてから、どぶんと逆まに淵へ飛びこんだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しゅっこが云った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、手をふってそれをとめた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としゅっこが云った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、とうとう、しゅっこが云った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十四日　しゅっこは、今日は、毒もみの丹礬をもって来た。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども毒もみは卑怯だから、ぼくは厭だと答えたら、しゅっこは少し顔いろを変えて、卑怯でないよ、みみずなんかで、だまして取るよりいいと云って、あとはあんまり、ぼくとは口を利かなかった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りしゅっこは、そこら中を、一｜軒ごとにさそって歩いて、いいことをして見せるからあつまれと云って、まるで小さなこどもらまで、たくさん集めた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこが、あんまり急いで行くもんだから、小さな子どもらは、追いつくために、まるで半分｜馳けた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな急いで着物をぬいで、淵の岸に立つと、しゅっこが云った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこが、大威張りで、あの青いたんぱんを、淵の中に投げ込んだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは大へんまじめな顔で、きちんと立って水を見ていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこはびくっとしたけれども、まだ一しんに水を見ていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、しばらくきまり悪そうに、しゃがんで水を見ていたけれど、とうとう立って、「鬼っこしないか。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこが、ぼくにもはいらないかと云ったから、もちろんぼくは、はじめから怒っていたのでもないし、すぐ手を出した。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、はじめに、昨日あの変な鼻の尖った人の上って行った崖の下の、青いぬるぬるした粘土のところを根っこにきめた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいにとうとう、しゅっこ一人が鬼になった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこはまもなく吉郎をつかまえた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとしゅっこが、吉郎、汝、上流から追って来い、追え、追え、と云いながら、じぶんはだまって立って見ていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」三郎は立って、口を大きくあいて、手をひろげて、しゅっこをばかにした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとしゅっこは、さっきからよっぽど怒っていたとみえて、「ようし、見てろ」と云いながら、本気になって、ざぶんと水に飛び込んで、一生けん命、そっちの方へ泳いでいった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
