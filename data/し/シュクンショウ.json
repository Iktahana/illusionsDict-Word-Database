        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の独創的な演技は審査員の心を捉え、映画祭で見事殊勲賞を受賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎年、最も社会に貢献したボランティア団体に、この殊勲賞が授与される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "殊勲賞の副賞として、海外研修への参加権が与えられることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
