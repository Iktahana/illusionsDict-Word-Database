    "definitions": [
      {
        "index": 1,
        "gloss": "to do (indicating contempt for other person's actions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
