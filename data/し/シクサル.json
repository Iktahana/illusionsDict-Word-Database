        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伊三郎が、そんなことをしくさるんなら、こっちだって、黙って引っこんでは居れんぞ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし、人間のずるい、金の融通のきく奴が、うまいことをしくさるんだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもだ、おやじは俺が大の自慢で、長男は俺の後嗣ぎ相当に生れついているが、次男坊はやくざな暴れ者だで、よその空でのたれ死でもしくさるだろうと、近所の者をつかまえて眼を細くしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また出て、魅しくさるずらえ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見識｜面をしくさる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きさまは……おれが愛ちゃんに頼んだになぜよけいな事をしくさるんだ」　とそういって威丈高になった倉地には葉子はもう目もくれなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これあ悪魔が嚇かしくさるだけぢやわい！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで普段は田圃の取り合ひをしくさる連中までがそこばつかしは御免を蒙つとります。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇吉は、立ちはだかって、勘助を見ていたがやがて、「何でえ、何しくさるでえ」とつめよせて来た。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンムニストは鞭の代りに書付を出しくさる！",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時折り、竹鋏を持ち出した爺さんに塵芥箱の中をかきまわされて大根の尻っぽだの出し昆布の出殻をつまみあげられては、「勿体ないことをしくさる。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コレ、嫁は今時分まで何をしくさるだ。",
              "citation": {
                "source": "麦畑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといふ悪戯をしくさるのぢや！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "――邪魔をしくさるのに違えねえだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞に宿が出てたから、わざ／＼やつて來て、昨夜電話をかけるとペケ、忌々しいから無理にも押し込んでやらうかと思うたが、まア／＼辛抱して、今朝早う來て見ると、次ぎの間で待たしくさる。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゾラの小説「土」に、ある慾深の若い百姓が雹に降られて天に向って拳をふり上げ、「何ちゅう事をしくさるか」と怒鳴るところがあるが、無理はない。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、汝らア騒がずと見物しとれ」「何をぬかしくさる！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後ちと気をつけてものをいわっしゃい」「よけいなことを吐かしくさる！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土砂降り雨の中にだれが物好きにそんな余計なことをしくさる奴がある！",
              "citation": {
                "source": "蒲団",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女と思うて、馬鹿にしくさるか」と、子どもの母親は、柿売りに、むしゃぶりついた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見え透いたことをこの女は、婆に隠しくさる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き分けてくれい』『勝手なこと、云いさらすわっ』『其方共とて、無益な怪我をしてもつまるまいが』『脅しくさるぞ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
