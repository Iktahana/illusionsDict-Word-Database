        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある状態ではたしかに医師訓練のレベルが落ちないわけには行かなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "小を視て大に、微を視て著しくんば更に來れと。",
              "citation": {
                "source": "術三則",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいいから、切れっ端か麻をすこしくんねえか」「あい、ようがす」　店の炉のまわりに胡坐をかいていた若い者が奥へはいって麻緒を持って来ると、半七は框に腰をおろした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな馬鹿なことを、何うしても云はすやうな芝居をしくんで彼女は、云はせたのだ。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "音蔵さんをなきものにすれば、やがてはあのご家内も思いをかけた兄の手にはいる道理、あやまって人を切らして、その弱みにつけこんでおどしたら、わたしも弟に身をまかせるだろうと、兄弟ふたりがたくみにしくんだわなだったのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇通で芝居の所作事をしくんだ壽阿彌に斯の如き滑稽のあつたことは怪むことを須ゐない。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、つくづくなさけなさそうに、しくんしくん、泣きだしました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お母さまが、いまお祖母さまの顔のなかに生きている……）　と末起の、心の傷がしくんしくんと疼きはじめる。",
              "citation": {
                "source": "方子と末起",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しくん、しくん、しゃくりあげました。",
              "citation": {
                "source": "ルンペルシュチルツヒェン",
                "author": "RUMPELSTILZCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹のグレーテルは、涙をだして、しくんしくんやりながら、にいさんのヘンゼルにむかって、「まあどうしましょう、あたしたち、もうだめね。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私、おままごとのとき、しくんですの。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、奥平壱岐のしくんだひきょうなはかりごとだったのです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、適塾の書生にかいぼうしてもらえば、くすりにするくまのきもが、うまくとれるとかんがえてしくんだものですから、くまのきもさえとれれば、用事がすんだわけでした。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ死骸は出ないけれど、とても生きていらっしゃろうとは思えない」　敵であるはずの源三郎……彼に対して恋心をいだいたばっかりに、丹波と二人でしくんだせっかくの芝居はいまだにらちがあかない。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハートの　クイーンが　そのあたりに　あかい　バラの　きが　ほしいって　いったらしいんだけど、　なのに　かわいそうに　このにわしくんたちは　おおまちがいを　しでかして、　かわりに　しろいのを　うえちゃったんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにあいつは、わたしがあいつのためにしくんでおいた芝居で道化役を演じることになるだろう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなふうにして、親方が余興にしくんだ狂言はあっけなく結末がついた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人間の一生なんてものは、はじめッから、そういう風にしくんであるんだ……　――ところが、世間には、そうでない人もいるから口惜しいのよ。",
              "citation": {
                "source": "三の酉",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『若宮一座』の話だって、いまになってみりゃァ、チョコと楽天坊主とが勝手にそうしくんだ仕事で、ほんとうに若宮君に、そんな気があったかどうかそれさえ分らなくなって来ているんじゃァないか。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たとへば、女厄坂をあがつたところに“絵馬堂”がある、といふよりも、女厄坂と男厄坂とのあひだが“絵馬堂”になつてゐる、あるひは、巧みにその空きが“絵馬堂”にしくんである、といつたはうが適切であるやうな、すこしのスキもムダも許さない建造への構想に、ぼくは、すくなからず驚いた。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはあなたを興奮させるために、われわれのしくんだことで、あの男があなたにしゃべるように、わざと風説を放ったんですよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽけっとこぞう、よくきがついたな」「で、ぼくをどうしようというの」「きみのほかに、こばやしくんも、ここへとじこめるのだ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、きみのぽけっとから、しょうねんたんていだんのばっじをだして、みちにまいておいたから、いまに、こばやしくんが、きみをたすけにやってくるからな」４「おまえは、ここにはいっていろ」　二十めんそうは、ぽけっとこぞうを二かいのへやにおしこめてしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんは、すぐに、むせんでんわでけいしちょうへしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんたちは、二十めんそうのへやをさがしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十めんそうは、あそこにいる」　こばやしくんが、だいのうえにすわっているぶつぞうをゆびさしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんたちが、おいかけてのぼっていくと、「あっ」たいへんです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
