  {
    "uuid": "f30ee82a-15a3-58a2-a870-54a4b0a388a9",
    "entry": "勝運",
    "reading": {
      "primary": "しょううん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "luck at winning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝運の波に乗っている源氏に背むいて、落ち目の平家に味方して、何の益があろう。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その常勝男の背後に、柄の悪そうなやくざ者が立っており、勝運を不運な若者からもぎ取っており、時々、背の高い荒っぽそうなアメリカ人からも半クラウン銀貨を巻きあげている。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "「将軍、何だって、せっかくの勝運を、図に乗せないで、退がったのですか」「都を出るとき、管輅に卜を観てもらったら、彼がいった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこそは――　と前線の直義からは、尊氏のいた摩耶山麓へ、意気さかんな伝令があり、　――きっと勝運をひらいてみせます。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
