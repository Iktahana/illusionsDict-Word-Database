[
  {
    "uuid": "a0190736-797f-55b4-bad9-48fd08d2921a",
    "entry": "商運",
    "reading": {
      "primary": "しょううん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "luck in business",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｓは戦後の新興業者で商運は好調だった。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草商事も急変する世の移り変りには勝てず、商運まったく行きつまり、借金で首がまわらない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪放な一力の女房役として細心に各地の情勢、各商人の動勢、相場の動きを察し、よく手綱をしめて一力を輔佐し、商運隆々として巨万の富を築くに至ったのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも彼を孤立の中へと追いやった影を吹き払うためかのように、また今すぐにとは言わないまでも商運の尽きる日が近いのではないかと。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
