    "definitions": [
      {
        "index": 1,
        "gloss": "feigned ignorance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
