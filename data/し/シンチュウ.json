  {
    "uuid": "c321dc97-d2fc-5e3d-b924-bbdc705901ce",
    "entry": "親中",
    "reading": {
      "primary": "しんちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
