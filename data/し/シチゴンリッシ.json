        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この頃私は七言律詩を二十ばかりも作って、紅楼の興味や何かを聞かじり半分に詠って、小牧始めの同塾生にも示し、また我藩の山本とか、医者で詩をよくした天岸桝玄などにも見せた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "客人は肥前人であったが、席上で七言律詩を作って先生に示した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」となした七言律詩がある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と題する七言律詩一首がある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "詠物｜凡七十九題、七言律詩一百首を載せている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
