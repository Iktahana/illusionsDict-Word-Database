        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そればかりか、今年ロシアが蟹工船の漁夫供給問題の復仇として、更にカムチャツカの、優良漁区に侵出してくることは分りきっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後「兼ねる」役者が輩出し、更に立役の真女形の真骨髄への侵出が盛んになつた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて百年がかりで宇宙艦隊を組織すると、いよいよアトランティス帝国は宇宙に侵出する。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星基地は宇宙侵出計画をはじめとする様々な目的のために建設され、火星の表面は地球人が宇宙服なしで活動できるように、酸素量・気温・気圧・重力など、地球とほぼ同じ環境に改造された。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙侵出開始から四千年の歳月が流れる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
