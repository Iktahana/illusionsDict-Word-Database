        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この下の毛氈だって、これはミシェルがコオラッサンだって持って来てくれたものなんだし、このクションの天鵞絨だって、イギリス人がスキュタリだからどうだとか、ビザンチンがどうだとかいって、かつぎ込んで来てくれたものばかりなのよ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦が、ベッドへ腰を降ろすと同時に、ロボットは、投出していた両手で――右手は、ベッドの端を左手で下の毛布を掴んだ。",
              "citation": {
                "source": "ロボットとベッドの重量",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "三沢の話、臍の下の毛（三十三の女の）徴兵よけのまじない。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレーギンとマリーナ、向い合せに腰かけ、靴下の毛糸を巻いている。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お腹の下の毛の生えたところにも、少しの實體感のわいせつを見ることがなかつた。",
              "citation": {
                "source": "帆の世界",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "第百六回　舞踏緑林の園遊　まず園遊で林の木の下の毛氈を敷いたような青草の上へ花段通を敷き、その上へいろいろの御馳走を列べ、それを喰いつつ酒を飲みあるいは謡いあるいは舞う。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手たちは服を着ようとは全然考えないらしく、下の毛布のあいだから様子をうかがっていて、その変な恰好が子供たちを大いに面白がらせていた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "話を聞くと、屍体とはいえまだ脂っけがたっぷりで、腋の下の毛なんぞも真黒けだってなあ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっとして、向うむきになった城介の顔をのぞくと、鼻孔からクリーム状のどろどろしたものが流れて、下の毛布にまで垂れている。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "□□きんの母はんが下に呼んでお云いやはった事だワ、あんまりお百合ちゃんと仲よくして居ると変に思う人があるといけないってナ云ってやはるさかえ『何が変やろ』云うたらナ母はんがお怒りやしたのけど一寸もわけが分らんさかえ考えてるのやー」　こんな事をお妙ちゃんはいかにも心配そうに大切そうに云って居る。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「博士さまの、その頭の鉢巻きは、どうしたのけえ」「作十よ。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは風邪をひきそうだ」「ちぇッ、慾のねえお父つぁんだ」「慾はあるが、おれの慾はじみちな慾さ」「べらぼうめ、慾にじみちも新道もあるものか、だが、そりゃあそうとして、オイ、馬公」「なんだと、答えたいが、時に伊兵衛ちょッと待ってくれ」「おや、いやに改まって、どうかしたのけえ？",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
