        "examples": {
          "standard": [
            {
              "text": "劇場で、情感豊かな新内節の語りに深く感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新内節は江戸時代に庶民の間で人気を博した芸能である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は幼い頃から新内節を習い、その継承者として期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "和歌よりは俳句をよろこび、川柳になり、富本から新内節になった。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど友達なかまで新内節がはやっていて、佐八も半年ばかり稽古にかよっていたときだったが、それもぴたりとやめて稼ぎに稼いだ。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "むじな長屋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
