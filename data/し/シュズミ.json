        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の郷里の習慣では生きているうちから法名を墓石に彫り付けてあって、朱墨を入れてあるのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に右の諸書には初め朱墨の文が分つてあり、後尚白墨の文が分つてあつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是本は伊沢氏の遺物で、朱墨の書入があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は好い気になって、書記の硯箱の中にある朱墨を弄ったり、小刀の鞘を払って見たり、他に蒼蠅がられるような悪戯を続けざまにした。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "店先ニ腰掛ケテ舊知ノ主人ト挨拶ヲ交シ、中国製ノ最良ノ朱墨一｜挺、小指大ノモノヲ金二千圓デ購ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ハ竹翠軒デ求メテ来タ硯ヲ取リ出シテデスクニ置キ、ユックリ／＼ト朱墨ヲ磨ル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挺ノ朱墨ヲ先ズ半分程磨リオロス。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ナニ、チョット」「朱墨ヲ磨ッテ何ナサルノ？",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒イ墨、又ハ黒イ肉ノ場合モアルガ、朱墨ヤ朱肉ノ場合モアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱墨ノ硯ト毛筆トヲ盆ニ載セテソノ上ニ運ンダ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物ニ朱墨ガ附キハシナイ？",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「絶対ニ着物ニハ附ケナイ、朱墨ヲ塗ルノハ君ノ足ノ裏ダケダ」彼女ハ云ワレル通リニシタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに直衛は、宗兵衛の右手を見て、朱墨が付いているぞといい、それから表情をひき緊めた。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着替えをした直衛が居間へはいってゆくと、宗兵衛は茶托へ茶をちょっとそそぎ、それで懐紙を濡らして、指に付いた朱墨を拭いていた。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、朱墨を卸ろす丸硯だった。",
              "citation": {
                "source": "夕顔の門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
