    "definitions": [
      {
        "index": 1,
        "gloss": "center of a noh stage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
