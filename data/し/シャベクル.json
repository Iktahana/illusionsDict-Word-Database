        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、一度話し出すと止まらず、延々と喋くる癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "同窓会で旧友たちと再会し、懐かしい思い出話に花を咲かせ、夜が更けるまで喋くり続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、新しい趣味について興奮して、友人に一日中喋くり続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それゆえ、これを読んで下さるかもしれぬ数多い方々の中に、私の親しい友達の一人二人を数えこみ、手紙のように、喋くるように楽なものを書きたい。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鋤」の中でもいつかしらみんなが食糧の問題を盛に喋くるようになった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日来りて知りもしないで画の事を種々しゃべくるをアが徐かに制して、今そこに色料を砕き居る小僧に笑わるるから知らぬ事を言いたもうなと言った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊を踊る、しゃべくる、物を煮る、酒を飲む、色をする、考えて御覧なさい、どこにもこれより好い事はありませんぜ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、ベラベラしゃべくるわけじゃ無えから気が附かねえ者あ、まるきり気が附かねえ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、あの紳士は、フランス語、イタリー語にゴルフ語しゃべくるぜ」　ジュネ※に於ける国際連盟の都市衛生顧問は、世界に於て最も衛生施設の行届いた都会としてロンドンをあげるだろう。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、子供ふたりで勝手にしゃべくるように、少し騒ぐがいい。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
