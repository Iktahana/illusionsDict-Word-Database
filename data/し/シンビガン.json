    "definitions": [
      {
        "index": 1,
        "gloss": "aesthetic sense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
