    "definitions": [
      {
        "index": 1,
        "gloss": "to play a trick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで、蝶子、ここは一番芝居を打つこっちゃ。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "延子の心はほんとうに正当で純なのだ、俺だけが悪いのだ、俺は自分勝手に低いレベルで極めて下賤な誰も見て呉れない独り芝居を打つて勝手に焦れてゐるのだ。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこぞこのあたりの駕籠宿に参って、至急にこれなる乗物、飛脚駕籠に仕立て直して参れ」「どうなさるんでござんす」「ちと胸のすく大芝居を打つのじゃ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっきょく彼は大外交家であって、如斯の大芝居を打つことによって、物質界の王を倒すか精神界の王倒れるかを試験してみたものと解すべきであろう。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客達は親爺の前で斯んな芝居を打つのが余つ程面白い！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男優達は皆な近村の若い農夫で、閑を利用して芝居を打つてまはるのである。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこの空漠の背景を利用して更に景を盛り輪をかけた臺帳を作り大芝居を打つことが跡を絶たない。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまく芝居を打つぢやありませんか、そして、まんまと関門をくゞり抜けて、自分は誰かの名前をつかつて、まんまと早い船に乗つて、日本へ戻つて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あのゴンクールの銃先を真向に見ながら、あれだけの芝居を打つなんか、とても吾々には出来ません。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ同じ歴史の舞台に大芝居を打つた徳川家康もやはり豊臣秀吉のやうに光彩を放つてゐなければならぬ。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互に芝居を打つて歩いて面白い夜もあつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セチ辛い浮世だ、そうでもないヤクザが、僅の餬口にあり付こうと、柄にもない芝居を打つこともある。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月興行から盆狂言へと飛ぶ、小屋のあそんでゐる間に、廉価の芝居を打つたのが起りだと言ふのである。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平橋村は村が小さいので、自分で芝居を打つことが出来ないから、毎年趙荘にいくらかお金を出して一緒に芝居を打つのである。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、天光光氏を家出させるに、これだけの芝居を打つ以上、園田氏が政治生命をこの結婚に賭けていることは大であろうから、フタをあけてみて、その政治生命がうまいようにいかないと、血路を他にもとめるのは自然であろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大和の奴がこんな芝居を打つようじゃ、今村に泥を吐かせる確証がねえような気もするなア」「どうも変だな。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホントに安心して目をつぶるか、シマッタとあわてふためくか、それとも死にぎわの一芝居というんでコケオドカシの大芝居を打つか。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "數年の後忠義者の猿芝居を打つた喜三郎は、醜いが人柄の良いお駒と夫婦になつて、僅かに加島屋の店を保つて行つたといふことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "酒屋忠僕",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のこの行進は愈々以て高潮した市民の好奇心をもう一ト煽り煽り立て、急速に膨張した夕陽新聞の地盤を確固不動なものにしようという、社長兼編集長、幸田節三の秘策中の秘策で、その名も芽出たい「鶴の子石鹸」とタイアップし、「瑞兆祝賀会」の名に仮りて古今未曽有の大芝居を打つことになったのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハツ、ハツ、ハツ、ハツ、刀を見たかつたのか、二人で相談をして、つまらない芝居を打つたんだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "弱い浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方へ行つて惡事を重ね、近頃江戸へ歸つて來たと言つて執拗く昔の綟を戻すやうに言つて來ましたが、私は相手にしなかつたので、私にいやがらせをするつもりで、そんな芝居を打つたんです」「さうか、何處に居るんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "盜まれた十手",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラツ八を溝へ叩込んだ女はその妻｜綱手、これは大變な女丈夫で、素姓を包んで南部家の奧に仕へ、兵粮丸の機密を知つて、幸ひ夫秀實の手に殘つて居る福岡城以來の南部兵粮丸を種に、乾坤一｜擲の大芝居を打つたのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で相談して賀奈女を殺し、二人で相談してこんな芝居を打つといふ微妙な細工は、半次や助七の智惠では出來さうもなく、それほど深い巧みがないとすれば、お互に疑はれた業腹さで、相手より強く／＼とのしかゝつて爭ひ續けてゐたのでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "佛喜三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で相談して賀奈女を殺し、二人で相談してこんな芝居を打つという微妙な細工は、半次や助七の智恵では出来そうもなく、それほど深い巧みがないとすれば、お互に疑われた業腹さで、相手より強く強くとのしかかって争いつづけていたのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏喜三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宜い心掛けだ、――が、お前は誰を相手にして芝居を打つてゐるか忘れたんだらう、――俺のところへ驅け込んで、聟の身代りを頼んだ時から、俺は臭いと睨んだよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は氣も心も良い女だが、お源はありや賢さうな馬鹿だよ、――庄兵衞は、主人を害める段取りを拵へると、伊三郎が金に困つてゐることを知つて、主人の金を融通するのだから、どんなことがあつても默つてゐろと約束して、五十兩の金を握らせ、それから、あれだけの芝居を打つたのだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "小判の瓶",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
