[
  {
    "uuid": "21314a2e-aded-59cb-a453-7056d40a15ec",
    "entry": "新修",
    "reading": {
      "primary": "しんしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
