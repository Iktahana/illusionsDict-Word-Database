  {
    "uuid": "c36d7495-24f9-561b-9a68-1a57c93df9c1",
    "entry": "深秋",
    "reading": {
      "primary": "しんしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deep autumn (when the autumn has reached its climax)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは庭園に種えられてある常緑の花木で衆花既に凋謝した深秋の候美花を放くからすこぶる人々に愛好せられている。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこのヒガンバナが花咲く深秋の季節に、野辺、山辺、路の辺、河の畔りの土堤、山畑の縁などを見渡すと、いたるところに群集し、高く茎を立て並びアノ赫灼たる真紅の花を咲かせて、そこかしこを装飾している光景は、誰の眼にも気がつかぬはずがない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深秋といふことのあり人も亦十月二十一日　鎌倉草庵、小句会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
