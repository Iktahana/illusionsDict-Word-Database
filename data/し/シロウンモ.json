        "examples": {
          "standard": [
            {
              "text": "白雲母は、キラキラとした光沢が特徴の鉱物である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "花崗岩の中には、白雲母の結晶がよく見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "白雲母は、その耐熱性から様々な工業製品に利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "長い湯から上って体を拭くと、分解した白雲母の細片が皮膚からキラキラと銀光を放つ。",
              "citation": {
                "source": "黒部峡谷",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母岩から分解されて、湯に晒らされた白雲母の細片が、このはかない現し身に、荒唐にして典麗な、原始的の装飾を施してくれたのだった。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
