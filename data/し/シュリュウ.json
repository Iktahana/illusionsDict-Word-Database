    "definitions": [
      {
        "index": 1,
        "gloss": "(the) mainstream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
