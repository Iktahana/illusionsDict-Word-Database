[
  {
    "uuid": "a6a9e1c4-87a5-5c8c-9077-131abfc49c52",
    "entry": "信徒",
    "reading": {
      "primary": "しんと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "layman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "キリシタンを禁じた時代の宗教の熱心さと、信仰の自由を許されて後の信徒の熱心さとの比較でもそうである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由を許したとて、信徒の数にしても決してそう驚くほど多くはならないのである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいって来る信徒らは皆入り口の壁や柱にある手水鉢に指の先をちょっと入れて、額へ持って行って胸へおろしてそれから左の乳から右の乳へ十字をかく。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年始めてイタリアのお寺でこの懺悔をしているところを見ていやな感じがしてから、この仕掛けを見るごとに僧侶を憎み信徒をかわいく思います。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベナレスの聖地で難行苦行を生涯の唯一の仕事としている信徒を、映画館から映画館、歌舞伎から百貨店と、享楽のみをあさり歩く現代文明国の士女と対照してみるのもおもしろいことである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう気の早い信徒たちが二百人ぐらい席について待っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の哲学はこの二語を以て既に千六百万人の世界各地に散在する信徒を得た。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は阿弥陀仏の化身親鸞僧正によって啓示されたる本願寺派の信徒である。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは能登、越中、加賀よりして、本願寺まゐりの夥多の信徒たちが、其の頃殆ど色絲を織るが如く、越前――上街道を往來した趣である。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ我れの諸弟子諸信徒のうち、汝より聖なるものはなく、汝より邪慾のものはない。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪｜船場目ぬきの場所にある旧舗の主人で鼈四郎の父へ深く帰依していた信徒があった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後は「へえー」と平伏して直ぐに座を立ち、信徒が帰依の高僧を供養する心構えで酒飯を饗応すべく支度にかかりました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の信徒で工事手伝いの男女の一群上手よりどやどやと出て来て舞台の下手へ入る。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信徒一『や、これでまあ御影堂の仕事もすっかり終った。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からは土塀の方の手が足らんちゅうから、あちらの手伝いに廻ったろかい』信徒二『そやそや。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも手の足らん箇所を見付け次第、そこへかぶりついて是が非でも此の月末の親鸞さま御正忌会のお※夜までには美んごと拵え上げにゃ、わてらの男が立たん』信徒三『わてらの男なぞどうでもええ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御門徒衆、一統の男さえ立てばええわい』信徒二『そりゃまあそうや。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ門徒一同のずんと男が立つわけじゃ』信徒四『お堂が斯う立派に出来てみると、早く中身の親鸞さまの御影像もお迎え申し、据わるところに据わって頂かんことにゃ、何となく落付きが悪い。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏造って魂入れずと言うこともあるからなあ』信徒一『そりゃわいどもより、御先祖孝行のお上人さまの方がどのくらいそれを望んで居らりょうか知れん。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで十年前に北国へお立退きの際、お預けなされた三井寺の方へ此の間じゅうからさいさい掛合われなされたけれど、一向取戻しは埒明かんと言うことじゃ』信徒二『そりゃ初耳じゃ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息でも呉れと言うのか』信徒一『こまかいことは知らんが、何でもややこしい難題やそうな。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もう往のう往のう、明日はまた朝早いぜ』信徒二『御影像を返さんとはけしからん三井寺のやつじゃ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはもともと……』信徒みなみな『まあええ、われが心配することは無い。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）阿闍梨（嘆息）『蓮如どのは、よい信徒を持たれた。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――黄髪の伴天連信徒蹌踉と闇穴道を磔負ひ駆られゆくごと生ぬるき悔の唸順々に、流るる血しほ黒煙り動揺しつつ、印度、はた、南蛮、羅馬、目的はあれ、ただ生涯の船がかり、いづれは黄泉へ消えゆくや、――嗚呼午後七時――鬱憂の心の海に。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の信徒が夜間燈を滅して會合したと云ふ記録（Clemens Alexandrinus ※ 2）があるが、眞僞不明である。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、有能な実際的科学者で、忠実な大英国の技術官で、敬虔なスコットランド教会の信徒で、かの基督教のキケロといわれるラクタンティウスの愛読者で、又、骨董と向日葵との愛好者だった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この長い年月に亙っての、宣教師を始めとした熱烈な伝道は、国禁を忍んで秘かに帰依する幾多の信徒をつくった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは十月二十二日の事であるが、その翌二十三日、有江村の郷士佐志木作右衛門の邸に信徒が集って居るのを耳にした代官林兵右衛門は単身乗り込んで、天主の画像を奪い破り、竈に投じた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍従の信徒達もこれを見ては起たざるを得なかったのであろう。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
