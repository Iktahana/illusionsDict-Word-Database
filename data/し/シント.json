    "definitions": [
      {
        "index": 1,
        "gloss": "new capital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毒酒の宴は愈橋といふところを京の山崎に擬らへ、相馬の大井津、今の大井村を京の大津に比し、こゝに新都が阪東に出来ることになつたから、景気の好いことは夥しい。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二年四月四日、長知公は新都東京へ上られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろルキウス・アンネウス・フロルスの「ローマ史摘要」を見ていたら、ロムルスがその新都市に胸壁を築いたとき、彼と双生児のレームスが「こんなけちな壁なんかなんにもならない」と言ってひととびに飛び越して見せた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元より民の疾苦を顧みるの入道ならねば、野に立てる怨聲を何處の風とも氣にかけず、或は嚴島行幸に一門の榮華を傾け盡し、或は新都の經營に近畿の人心を騷がせて少しも意に介せず。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫は新都｜善售の漢方医として栗園と並称せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又その所領の望みでも今は平家に縁故の多い西南海の所領を人々は目ざしたけれども新都に遠く離れた東北の庄園は誰も望むものはなくなってしまった。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとは既にあれて、新都はいまだならず。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然、新都の老若は声を斉うして、旧都に還らむことを求めたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "○治承四年十月二十三日　入道相国福原の新都を去り、同二十六日京都に入る。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の町の建設は紀元前四世紀の初葉で、それまではイオニア人の都市ナクソス（タオルミーナの南四キロ、今のスキソ付近）が栄えていたのを、ディオニュシウス一世はギリシア勢力絶滅のためにそれを破壊すると同時に、シケリア人をしてタウロスの山腹に新都市を建設させた。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で繁栄は千年以上つづき、中期王朝時代に上流のテバイの新都が始まるまで首都だった。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンリ・レインプールの『中世』に拠ると、その時アラビアの侵入軍は破壊したバビロン城砦の付近に陣営を張ったまま長駆してアレクサンドリアを攻略し、帰って来てその陣営の位置に新都市を経営した。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後トルコ人がエジプトに勢力を得て、フスタトの北部（即ち今のカイロ市内の区域）に新都市を拡げ、マスル・エル・フスタト或いは略してマスル（またミスル）と呼んだ。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九六九年八月五日の夜、ガウハル将軍は新都市の設計を完了して、砂原に繩張をし、占星者が天体を観測して、吉兆の瞬間に鐘を鳴らせば、最初の鋤が入れられるように用意して、土工たちは合図の鐘を待っていた。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでカヒラと新都市は命名されたが、アラビア人の伝説で火星は不吉の兆とされていた。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、翌月の事、家持の生前東宮｜大夫として事へて居た早良皇太子が、新都造営主任であつた藤原種継を暗殺せしめられた事件が起つた。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ひさかたの雨の降る日をただ独り山辺に居れば欝せかりけり　〔巻四・七六九〕　大伴家持　大伴家持が紀女郎に贈ったもので、家持はいまだ整わない新都の久邇京にいて、平城にいた女郎に贈ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "真向からこれを亡す手段がないので、天智天皇は皇居を近江に移してこの勢力の自然の消滅を狙つたが、この勢力の援助なしには新都の経営も自由ではない。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理にこしらえた新都会　元来宝塚は、大阪市と神戸市より程近い地点にあって、美しい六甲の峰つづきである譲葉嶽の山麓に位して、生瀬の渓谷から奔流して来る武庫川の早瀬にそうた、すこぶる風光明媚な景勝の地であるので、新温泉場の出現とともに来遊客は非常に増加した。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し新都百般の経営既に成った後之を非難するは、病の膏盲に入った後治療の法を講ぜんとするが如きものであろう。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "新都会趣味の、新耽美派の文学満天下に謳歌されてゐた佳き時代である。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "都うつりの時、新都に住家をつくるため、壊せる家は壊して材木にして筏を組み、賀茂川、桂川に浮べて運び、あるいは持てる家財を運んだあと叩き壊して川に打ち捨てたのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年を四かえりまでに過ぎ来にし　　おたぎの里の荒れや果てなん咲き出ずるはなの都をふり棄てて　　風ふくはらの末ぞあやうき新都　この年六月九日、新都の政事始めとして、造営の計画が練られた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "新都建設は進まず、人心は浮雲のごとく、すでに住んでいた民はその土地を失い、新たに移ってきたものは家の建築に苦しみ、何れも皆心落ちつかずに茫然となる始末である。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見　しかしながら新都の建設は少しずつ進んでいった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "福原にどうやら新都らしいおもかげが出てきたが、凶変の重なった夏もすでに過ぎ、秋はすでに半ばである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "福原の新都に落ちついた公卿たちは月見に出かけた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐々に賑いをみせてきた新都福原にひきかえ、荒れた田舎がここにあった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りのまえの日、というものは、清潔で若々しく、しんと緊張していていいものだ。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雨の夜、父は他所の宴会に招かれて更けるまで帰らず、離れの十畳はしんとして鉄瓶のたぎる音のみ冴える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
