          "literary": [
            {
              "text": "東洋では鍼術を行うが、これはほとんど無効らしい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち鍼術であり、細い針を患部にあるていど深く挿し込む治療法である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "体表面には鍼術を行うことができる約388箇所があり、長い経験によりどこが危険であるかが教えられ、たとえば動脈は避けるべき経路として示されている（第10図）（第11図）。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
