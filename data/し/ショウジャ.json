    "definitions": [
      {
        "index": 1,
        "gloss": "prosperous person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "盛者必衰は免かれ難い因果とはいいながら、団菊左の諸名優を相手にして、「弁天おてる」や三千歳を演じていた青年美貌の俳優が、こうした蕭条の終りを取ろうとは――。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛者必衰の理とは謂ひながら、權門の末路、中々に言葉にも盡されね。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙羅双樹の花の色、盛者必衰の理を現す。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛者必滅とは常に人の唱へ来つたことで、始めあるもの必ず終りあるは、これ生滅の法である。",
              "citation": {
                "source": "人類の将来",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娑羅双樹の花の色、盛者必衰の理をあらわす。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「祇園精舎の鐘の声、諸行無常の響あり、沙羅双樹の花の色、盛者必衰の理をあらはす……」　もとよりそれは本格の平家でありましたけれど、門付けをして歩いて、さのみ人の耳を喜ばすべき種類のものではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいわゆる盛者必滅の理を説くには、少しまだ早過ぎた時代の事であった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――盛者必衰ノ理、とそれを歌った古人の世界観が現代にもあてはまるかどうかしらないが、個人にものがれえない死があるから、平家滅亡の史詩にもやはり今の私たちにつながっている何かはあろう。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただよう平家は、これからが、いわゆる平家物語の哀々たる人間詩を高く奏でながら末路の一すじをとってゆくのであるが、勝者の源氏方にも、義経の行動や頼朝の家庭を中心として、もう盛者必衰の芽が育ちかけていた。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、なんですけど、雨もこんなに降りますし、もう日も暮れかけてますから、私の家へまいりましょうじゃありませんか、拝借したお銭もお払いしとうございますから」　許宣は女の家へも往きたかったが、姐の家に気がねがあるので往けなかった。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きイちゃん、お弾きよ――先生、少し陽気に行きましょうじゃアございませんか？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、なんですけど、雨もこんなに降りますし、もう日も暮れかけましたから、私の家へまいりましょうじゃありませんか、拝借したお銭もお払いしとうございますから」　許宣は女の家へも往きたかったが、姐の家に気がねがあるので往けなかった。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、それならここで一つ、景気よく前祝として乾杯しょうじゃないか」「よかろう。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は用事があるなら夕飯を八時として、サン・ミシェルの支那飯店で待つことにしょうじゃないか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう叔母が亡くなってからは私一人で、小女が二人いても相談相手にはならず、だんだんやりきれなくなって、平賀さんに相談してみますと、初めにこれこれ出そう、そして月々百五十円、但し向う三年間のことにしょうじゃありませんかって、はっきりしています。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、丁度私もこの節、暇を貰って、異った空気を吸いに出掛けようと思っている矢先、どうでしょう、一｜所に付合っては下さらんか、そうして旧事を皆忘れてしまいましょうじゃありませんか。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうつもりでもなかったんですけれども、自然の勢で、いつかそうなってしまったんでしょう」「でしょうじゃいけません。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あちらへ行きましょうじゃないの、ね？",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行きましょうじゃあないの」「うむ」　道の嶮しさ、自然から受ける威圧。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいごんじの　おしょうは　てんかに　かくれない　がくもんの　ふかい　おしょうじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
