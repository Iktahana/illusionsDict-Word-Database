[
  {
    "uuid": "e21636a6-5979-5f70-ad5d-d06e6b02ebe8",
    "entry": "抄出",
    "reading": {
      "primary": "しょうしゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "taking excerpts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "記者は下にその主要部分を抄出してみたい。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "石橋君の著にはその大黒様の所を抄出したままで誤字も多少あれば、今は本書から引こう。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "句稿整理、第六句集孤寒抄出版のために、――所詮は身すぎ世すぎのみじめさ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "外崎さんはおおよそこれだけの事を語って、追って手近にある書籍の中から抽斎に関する記事を抄出して贈ろうと約した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに『前田文正筆記』、『津軽日記』、『喫茗雑話』の三書から、抽斎に関する事蹟を抄出して添えてあった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは諸書について、主に弘前医官に関する事を抄出したものであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書の下巻は未刊行のものださうで、頃日箕山さんは蘭軒の伝を稿本中より抄出してわたくしに寄示してくれたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ先づこれを抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此にその「秋郊詠所見七首」の引を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の詩は五首あるが、抄出すべきものを見ない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の起居を知らむがために此に抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此にその叙実の段を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て北宋｜槧本に就いて本草経の文を抄出し、「神農本草経」と題したもの一巻がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此書を徳さんに借りて、多少の価値ありと認むべき数条を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此に柏軒の日記を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し此池田全安は現存者にして或は時代相違ならむかとも被存、若し同名異人なるときは、無用の穿鑿に可有之候へ共、兎も角も左に宿所姓名抄出、御一報申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子中此人は嶺松寺に葬られざるが故に、わたくしは特に寺名を抄出した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にわたくしは榛軒詩存中より、「嘉永三庚戌冬夜直舎即事」の詩を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此書の刊行せらるべきシヤンスは、※斎詩集に比して更に小なるを知るが故に、今序の全文を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは当時の幕府医官の風俗を徴証せむがために此に抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此乗船問題は松田氏の語る所であるが、伊沢良子刀自は当時多紀安琢、津軽玄意の柏軒がために草した歎願書を蔵してゐるから、わたくしは此に抄出して松田氏の談を補はうとおもふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは下にこれを抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時治療に任じた医家五人が連署して江戸に送つた報告書を此に抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百二十八　わたくしは柏軒門人清川安策孫の事を記して、清川氏の家乗を抄出し、嘉永五年には六十歳、嫡男にして岡藩に仕へた徴は二十六歳、次男孫は十五歳であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此より其後を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは先づ其後の日記中より目に留まつた件々を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは其詩を録せずに、中に見えてゐる応酬の人物を抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "直の事は洞谷の子なるを以て特に抄出する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の事實は棠園さんの手書中より抄出したものである。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀行は市河三陽さんが抄出してくれた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
