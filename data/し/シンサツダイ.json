    "definitions": [
      {
        "index": 1,
        "gloss": "examination table (at a doctor's office)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
