[
  {
    "uuid": "023caa05-3a6c-55de-b924-8e5b778865e9",
    "entry": "吝い",
    "reading": {
      "primary": "しわい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stingy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "羊飼はひどく吝い男でしたから、初のうちはなかなか承知しそうにもありませんでしたが、三人が口を揃えてうるさく強請むので、ぶつくさ呟きながらも引請けるには引請けました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが『御留守居さんの出立に、山猫はちと吝い』といった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の使いの用件を聞くと、はしたない奉公人の末は、「さすがに、吝い御大将。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初、彼は其を私がしわいからだと解したらしい。",
              "citation": {
                "source": "素朴な庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○二人のしわい四十すぎの独身男と夫との散歩　浜中、Ａ、銀座、　浜中、独身男らしく、洋品店などしきりにのぞく。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "順二郎のは、しわいのではなくて、気質から来る周密なやりかたなのであった。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、あのしわいＡが、書簡箋は、上にゴッホの絵のついた今まで買ったこともないようなものを買って来て居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって、一週間もおひとり占めにされては決してしわいことを云うのではないけれども、辛いところもある。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、しわいという感じが先で、私は腹立たしく思うのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しわん棒が義理のつき合いに骨折るなんて例は天下にありませんしね、詩を自分から溢らす人間がしわい性根ということもあり得ません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに対しては、しわいという評は当りません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
