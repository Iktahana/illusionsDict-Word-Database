        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薄暗い湿っぽい朽葉の匂のする茂みの奥に大きな虎杖を見付けて折取るときの喜びは都会の児等の夢にも知らない、田園の自然児にのみ許された幸福であろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年九月二十九日の早朝新宿駅中央線プラットフォームへ行って汽車を待っていると、湿っぽい朝風が薄い霧を含んでうそ寒く、行先の天気が気遣われたが、塩尻まで来るととうとう小雨になった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　何故、憲兵隊へつれて来られたか、その理由が分らずに、彼は、湿っぽい、地下室の廊下を通って帰るように云われた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五重の塔は湿っぽい暁の靄につつまれて、鳩の群れもまだ豆を拾いには降りて来なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下八百尺の坑道を占領している湿っぽい闇は、あらゆる光を吸い尽した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿っぽい空気にまじって、血の臭いが鼻に来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならば夕凪の蒸暑く重苦しい時刻であるが、今夜は妙に湿っぽい冷たい風が、一しきり二しきり堤下の桑畑から渦巻いては、暗い床の間の掛物をあおる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿が少くても五六｜疋、湿っぽいはなづらをずうっと延ばして、しずかに歩いているらしいのでした。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな、湿っぽい、洞穴に、弱々しい、切なげなその声が幽かに聞えて、二人は思わず戦慄した。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い湿っぽい岩穴は全く尽きて、人々は大いなる谷川の畔に出た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい百日紅の下にある石の井筒には、一面に湿っぽい苔がむしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "風通しの良い部屋とはどこをもってそう言うのか、四方閉め切ったその部屋のどこにも風の通う隙間はなく、湿っぽい空気が重く澱んでいた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半身を両手で支えて、ジロジロと眼を見開いてみると、自分の頭の上には誰の仕業かわからないが、湿っぽい木炭の俵が一枚、横すじかいに載せてあった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汐時のすこし湿っぽい畳の小座敷で、社長は無事見学祝いだとか、何とか云っては日本酒の盃を挙げている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樹の根が崩れた、じとじと湿っぽい、赤土の色が蚯蚓でも団ったように見えた、そこにね。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹立ちに薄暗い石段の、石よりも堆い青苔の中に、あの蛍袋という、薄紫の差俯向いた桔梗科の花の早咲を見るにつけても、何となく湿っぽい気がして、しかも湯滝のあとを踏むように熱く汗ばんだのが、颯と一風、ひやひやとなった。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、陰気な、湿っぽい音で、コツコツと拍子木を打違える。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは隣家の高い二階家に遮られて、東に面した窓口から、僅かに朝の半時間ばかり、二尺くらいの陽が射しこむきりで、微暗い湿っぽい家であった。",
              "citation": {
                "source": "前妻の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……風が冷く、山はこれから、湿っぽい。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "びしゃびしゃ……水だらけの湿っぽい井戸端を、草履か、跣足か、沈んで踏んで、陰気に手水鉢の柱に縋って、そこで息を吐く、肩を一つ揺ったが、敷石の上へ、蹌踉々々。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗くて床が低く妙に湿っぽい感じのする部屋でしたけれども、二間ほどの窓が開いていて、明りがそこから射し込むのですからその前にいる人の姿は明暗の影を帯びてはっきり見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊「今夜は妙に湿っぽいじゃないか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の幽霊草というのは曼珠沙華のことで、墓場などの暗い湿っぽいところに多く咲いているので、幽霊草とか幽霊花とかいう名を付けられたのだが、ここらでいう幽霊藻はまったくそれとは別種のもので、水のまにまに漂っている一種の藻のような浮き草だ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生のサモアとは似てもつかない・この冷々した・湿っぽい・鉛色の風景が、私を何時しか、そんな状態に変えていたのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "降雨のあとに湿っぽい雪がたくさん降って、それが樹冠にへばりついてその重量でへし折られたそうである。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、湿っぽい林道の両側には熊笹の藪が高くなり、熊笹の間からは闊葉樹が群立して原生樹林帯はしだいに奥暗くなっていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし草なんてものは、ことに（あの人殺しのあったころのように）暖かくて湿っぽい時候には、ほんの一日のうちに二、三インチも伸びるものだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタリとも言わず……あまつさえ西洋｜室の、ひしとあり、寂として、芬と、脳へ染る、強い、湿っぽい、重くるしい薬の匂が、形ある箔のように颯と来て、時にヒイヤリと寝台を包む。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、風がまたどこからか吹いて来て、湿っぽい、蒼臭い、汗蒸れた匂が、薬の香に交って、むらむらとそこらへ泳ぎ出す。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ切った脳の中に、その臭気ばかりが一つ一つ別々に描かれて、ああ、湿っぽいのは腹籠りで、蒼臭いのは蝮の骸、汗蒸れたのは自分であろう。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
