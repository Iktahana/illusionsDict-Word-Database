[
  {
    "uuid": "5b2422a3-06c8-5e3f-bba5-87370f4df5a7",
    "entry": "疾呼",
    "reading": {
      "primary": "しっこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
