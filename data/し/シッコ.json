      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shout",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なるほど貴様は社会主義労働運動の急を大声疾呼したさ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、貴様の大声疾呼の後ろはからっぽだったじゃないか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は気を抜かれていささか手持不沙汰、今更｜疾呼しても張合無ければ、少々｜声音に加減をして、「汝等、ここをどこだと思ってる。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と三吉｜眼を刮きて疾呼すれば、わいわいと鯨波を揚げて蜘蛛の子の散るがごとし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心は疾呼して渠を責めぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は疾呼の譴責に遭いては慚悔し、また踴躍の教峻を受けては然諾せり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、李陵韓延年速かに降れと疾呼しつつ、胡軍の最精鋭は、黄白の幟を目ざして襲いかかった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観世流は上懸で声の出所が違うのだから節も違わなければならぬ」　と大声疾呼して大いに上懸式の謡い方を鼓吹した一事を以てしても十分に察せられるであろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "露国の崩壊によって一九一八年西方に大攻勢を試みたルーデンドルフはこれを殲滅戦略の断行と疾呼する。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾後［−毎期］議会ニ於テ大声疾呼其拯救ノ策ヲ求ムル茲ニ十年、而モ政府ノ当局ハ常ニ言ヲ左右ニ托シテ之ガ適当ノ措置ヲ施ス［＋コト］ナシ。",
              "citation": {
                "source": "直訴状",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩が「心理遺伝」の恐しい事を、大声疾呼して主唱する所以の第一は、それが斯様にして精神病者に現われるばかりでない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西晉の太康元年に郭欽、元康九年に江統、相前後して徙戎論をたてまつり、内地に雜居せる塞外種族の處置の急務なることを、絶叫疾呼したのはこの故である。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "然り、桑樹に対して太息する玄徳、青山を望ンで黙測する孔明、玉璽を擁して疾呼する孫堅、蒼天を仰いで苦笑する孟徳、蛇矛を按じて踊躍する翼徳、彼等の時代は漸に来りし也。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格と技能を兼ね具えた上に、特に美の含有量の多い良寛様の書は、私の知る限り徳川期の第一人者であることを大声疾呼して擱筆したい。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "適ま大声疾呼して、国を誇り民を負むものあれど、彼等は耳を閉ぢて之を聞かざるなり。",
              "citation": {
                "source": "漫罵",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときにあたって、役人が「伝家のさび刀」をかつぎだして、われこそは「思想の善導者」である、と大声疾呼したところで、誰かまじめにこれを受け取る者があろう。",
              "citation": {
                "source": "役人の頭",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは体を労られるため、一つは粘液質の鈍感者流が自分の云っていることが自分に解らず、その為め人にも解るまいと、そこで眼を怒らせ声を大にし、丁寧に疾呼反覆するあの悲しむ可き喜劇なるものを、踏襲する必要が無いためとで、いつも氏は低声で物を云われる。",
              "citation": {
                "source": "小酒井不木氏スケッチ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は実にかかる大権謀を以て、自から「宝刀染め難し洋夷の血」を疾呼せり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本科学など口にすべからざる非常時に、日本科学を疾呼し、今世界科学に伍し得ない国情に陥った時に、世界科学を論ずるのは、いずれも言葉の遊戯である。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁論大会のようなものをちょっと覗いてみると、髪をぼうぼうにした学生が、紋附の羽織などを着て、官学閥の打破とか、機会均等とかいうことを、大声疾呼して大いに熱弁をふるっていた。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも大岡の屋敷まえと知っての挑戦であろう」　太い眉がひくひくとすると、忠相は低く足もとの大作を疾呼した。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわしながら、左膳がとっさに足にかけた煙草盆の灰神楽で、左膳自身は早くも壁を背負って立った猪突の陣、独眼火をふいて疾呼した。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでマルクスの流れを汲んでいる者は、マルクスの主義は空想的でない科学的であると大声｜疾呼している。",
              "citation": {
                "source": "マルクス主義は科学にあらず",
                "author": "山川健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとさらにこれに代って立ち現れたる一人は、大声疾呼「驚くなかれ諸君よ」の冒頭を以て、まず聴衆の鼓膜を破ったのである、彼は狂せんとする人々を押し静めて、さて説いて曰く、「諸君！",
              "citation": {
                "source": "太陽系統の滅亡",
                "author": "木村小舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚮ニ選レテ衆議院議員トナルヤ、第二議会ノ時初メテ状ヲ具シテ政府ニ質ス所アリ、爾後議会ニ於テ大声疾呼其拯救ノ策ヲ求ムル茲ニ十年。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかれっ」　と、大声疾呼の下に、竿も折れよ、旗も裂けよとばかり、打振り打振り、励ましていた。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかし――彼がそこから躍ろうとしたせつなには、金吾もすでに、彼の姿をそこに見つけて、「おのれ――ッ」　疾呼して日本左衛門を捕えました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庇が波形に曲ったり垂れ落ちかかったり、障子紙が一とこま一とこま申合わせたように同じ形に裂けたり、石垣の一番はしっこが口を開いたりするという程度からだんだんひどくなって半潰家、潰家が見え出して来た。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学嫌いの生徒は日本に限らないと見えて、モスコフスキーの云うところに拠ると、かなりはしっこい頭でありながら、数学にかけてはまるで低能で、学校生活中に襲われた数学の悪夢に生涯取り付かれてうなされる人が多いらしい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いつでも大きな方のはしっこ（big end）をつかまえてかかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
