      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "within a company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ社内にある小さい石の鳥居が無難である。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの硬派、軟派は、新聞社内の二つの区別じゃ勿論なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のことはないまるで子供の使いで、社内でも、おい子供、原稿用紙だ、給仕、鉛筆削れと、はっきり給仕扱いでまるで目の廻わるほどこき扱われた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日経つと、社内で評判の美貌の交換手を接吻した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "社内、舞手と我等の外殆ど人影無く、俗塵絶ゆ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この永機は明治初年の頃に向島の三囲社内の其角堂に住み、後芝円山辺に家を移して没した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから松源や雁鍋のある広小路、狭い賑やかな仲町を通って、湯島天神の社内に這入って、陰気な臭橘寺の角を曲がって帰る。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、その醤油買いの帰りに博多の櫛田神社の前を通ると、社内に一パイ人だかりがしている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、社内にあって良い地位を虎視眈眈とねらっている連中ならば、たとえば編輯長の前ではあくまで慇懃であってもらいたいものだが、しかし先ず新参の見習記者には用のない話だ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の性質としましては、あまり人なかに出るのは適当じゃないと思いますので、なるべく社内でやるような仕事をしたいと思います」正直な言葉だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入社員のみじめな負目が皮膚にこびりつき、ひとびとの視線が何れも軽蔑の色を泛べているように大袈裟に感じられたので、自然豹一の社内に於ける態度は、醜いほどぎこちなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "居ること約半年、社内に動搖があつて七人ほど打ち揃うて其處を出た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "貧乏首尾無し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが前のと違つてどうもその社内の空氣が面白くなく、前社同樣二十五圓の月給をば二箇月分か貰つたが出社して事務をとつたのは僅々五六日であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "貧乏首尾無し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし雑誌に掲載されたものならともかく、博士論文や企業の社内文書となると、関係者の厚意を期待しなければ読むことはできません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見には印刷としか思えないものが簡単に作れるとなると、社内用の文章も多少はレイアウトを工夫して、レーザーライタでプリントしたくなってきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＰＣ―９８０１にとって社内のライバルのような立場にあったＰＣ―１００という機械を作るときには、「パーソナル・ダイナミック・メディア」を作ろうと、はっきり意識していたと言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "以降、社内のメールシステムを使って、足抜けの段取りが練られました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "となればやはりいかざあなるまいと駆け付けてみると、なんと師匠、いきなり今度は社内のスタッフにレッド・ペーパーを突き付けるではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パーソナルコンピューターのビジネスがちょっとうまくいったものだから、我々の開発スタッフは殿様商売を気取り始めた」といきなり社内に向かって二通目のレッド・ペーパーを突き付けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして第三の社内の殿様化に関しては、競争の導入によってこれを粉砕していくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この成果を踏まえてたとえば新聞用語フィルターといったものが用意され、このルールにしたがって用字を整理してくれれば、社内文書の類でも漢字の乱用に歯止めがかけられる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社内にも松杉がおい茂っていて、夏なんぞは蝉の声がそうぞうしい位です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "七番と云うのは、社内電話で編輯の番号でした。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなくとも長きもの神馬の尾髪、神子の袖、上臈のかもじと『尤の草紙』に見る通り、昔は神の乗り物として社内に飼う馬の毛を一切截らなんだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州田辺の紀の世和志と戯号した人が天保五年に書いた『弥生の磯』ちゅう写本に、厳島の社内は更なり、町内に鹿夥しく人馴れて遊ぶ、猴も屋根に来りて集う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今日と雖も文人の生活は猶お頗る困難であるが二十何年前には新聞社内に於ける文人の位置すら極めて軽いもので、紅葉の如き既に相当の名を成してから読売新聞社に入社したのであるが、猶お決して重く待遇されたのでは無かった。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それから後は社内の余興的の催しは一、二度あったそうだが、半公開的に大袈裟に催したのはただ一回ぎりであった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　第二期の失意煩悶朝日社内における葛藤不平・国際的危機・『平凡』前後・実際的抱負　が、それにもかかわらず、世間は盛んに嘖々して歓迎し、『東朝』編輯局は主筆から給仕に到るまでが挙って感歎した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが私の劇作の舞台に上せられた第二回目で、作者自身が武田勝頼に扮するつもりであったが、その当時わたしは東京日日新聞社に籍を置いていたので、社内からは種々の苦情が出たのに辟易して、急に鬼太郎君に代って貰うことにした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮気のお相手はんは……」　鼻の低い妓がきくと、去年の十二月、大阪の新町から先斗町へ来て「進駐さん」といわれている芸者が、「判ってまっしゃないか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
