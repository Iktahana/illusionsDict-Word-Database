        "examples": {
          "standard": [
            {
              "text": "医学部では、病気の早期発見のために診断学を深く学ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の専門は臨床診断学で、特に希少疾患の診断に長けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の画像診断学は、これまで見つけられなかった病変を明らかにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし洋医方の診断学も亦心臓機能を等間視してはゐない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は疑いなく診断学者として優れており、これは彼の長期にわたる種々で費用がかかる医学教育および彼の判断の偉大な自然力によるものであった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は教わらずに解剖学的および診断学的な考え方を苦労して作り出さなければならなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "17世紀の生理学、18世紀の病理学、および19世紀の初めにおける臨床医学や診断学が、解剖学の見通しによって支配されていたことに読者は気がつくことができた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
