[
  {
    "uuid": "3f72c2ff-de9e-5c1b-8087-263e7d29ec93",
    "entry": "森林",
    "reading": {
      "primary": "しんりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
