    "definitions": [
      {
        "index": 1,
        "gloss": "in accordance with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は疲れてガツカリしながら従いて行つた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　（従いて笑ひながら）本当に。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君の厳父には、私は未だお目にかかった事は無いが、美事な薬鑵頭でいらっしゃるそうで、独り息子の忠太郎君もまた素直に厳父の先例に従い、大学を出た頃から、そろそろ前額部が禿げはじめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも福岡市でも竹原といへば知らない人もないつて言つて好い位な家なんですから、余りお粗末にやれば……」　それは奥さんに従いて来た奥さんの声だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に従い来る山々｜山骨黄色く現われてまばらなる小松ちびけたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読む人その心して取捨よろしきに従い給え。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあに先生さ従いでさぃ行げばいいんだじゃ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなぞろぞろ従いてくる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我動くところに虹も亦従いて動く。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガドルフの百合宮沢賢治［表記について］●底本に従い、ルビは小学校１・２年の学習配当漢字を除き、すべての漢字につけた。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の門、植木屋の庭、花屋の店など、坂下を挟みて町の入口にはあたれど、のぼるに従いて、ただ畑ばかりとなれり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知りたる女にあらねど、うつくしき顔の笑をば含みたる、よき人と思いたれば、怪しまで、隠れたる児のありかを教うるとさとりたれば、いそいそと従いぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような醜い形をして、私が外出すればかならず影のごとくちゃんと私につき従い、少年少女までが、やあ、へんてこな犬じゃと指さして笑うこともあり、多少｜見栄坊の私は、いくらすまして歩いても、なんにもならなくなるのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあに先生さ従いでさぃ行げばいゝんだぢゃ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなぞろぞろ従いて来る。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉のお母さんの梟はまるで帛を裂くやうに泣き出し、一座の女の梟は、たちまちそれに従いて泣きました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドラ［※１］の網宮沢賢治［表記について］●底本に従い、ルビは小学校１・２年の学習配当漢字を除き、すべての漢字につけた。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉のお母さんの梟はまるで帛を裂くように泣き出し、一座の女の梟は、たちまちそれに従いて泣きました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の月日は忽ち逝き、僕は首尾よく学校を卒業しましたが、猶お養父の言葉に従い、一年間更に勉強して、さて弁護士の試験を受けました処、意外の上首尾、養父も大よろこびで早速其友なる井上博士の法律事務所に周旋して呉れました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月の偈が唱声三昧に入るに従い、青年、箸と椀をさし置きしきりに涙を拭き出す。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人の恋は、此の世の人々に感銘し、人々の享くる感銘に従い、そこに色々違った二人の恋の姿が創造されて、しばらく此の世の中に残るとしても、然しそれが二人の目的と何の関わりがあるので御座いましょうか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕丁は、ひょこひょこと従い続く。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕丁相従い床几を提げ出づ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは低気圧だよ、あいつに従いて行くことになったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも付従いて行ったら生命を取られるかも知れねえだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹長以下これに従い一列に並ぶ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のある日は、棒は斜めになりますが、その傾きは風の程度に従います。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といいつつ女房を見返りて、「おい、御女中をお連れ申して進ぜなさいと、命つけられて内儀は恐々手を曳いて導けば、怪しき婦人は逆らわず、素直に夫婦に従いて、さもその情を謝するがごとく秋波斜めに泰助を見返り見返り、蹌踉として出行きぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お言葉に従いますわ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸を殺して従い行くに、阿房はさりとも知らざる状にて、殆ど足を曳摺る如く杖に縋りて歩行み行けり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
