        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "予は今後断じて神に依らず、予自身の手を以て、予が妹明子をこの色鬼の手より救助す可し。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
