[
  {
    "uuid": "c0dc0d0b-992e-5772-b62e-799d1583e20c",
    "entry": "照尺",
    "reading": {
      "primary": "しょうしゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sight (of a firearm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "店の主人は子供に物を言って聞かせるように、引金や、弾丸を込める所や、筒や、照尺をいちいち見せて、射撃の為方を教えた。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ては眩し、痛々し、笑ふよしなし、小船は動き、輪に廻り、また一線に歎けども落ちつかむ、狙ひ射たむとぞ燥れども、照星は照尺を超え、銀の櫓櫂は日輪光に欺かる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥が枝を渡つたのか、それとも照尺を縮めたのか――私には鳥の姿は見へなかつたが、何だか私は、厭に生真面目にてれ臭つたやうなあまりに能なし気な思ひで、よた／＼と伴いて行くと、待つ間もなく、間一髪、発砲の音で私は、思はず、ドキツとして蛙のやうに飛びあがつた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィデも、長濤に阻まれて、照尺を決めることが出来ない。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四千メートル」の語は、あまねく右舷及び艦の首尾に伝わりて、照尺整い、牽索握られつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の主人は子供に物を言って聞かせるように、引金や、弾丸を込める所や、筒や、照尺を一々見せて、射撃の為方を教えた。",
              "citation": {
                "source": "女の決闘",
                "author": "オイレンベルク　Herbert Eulenberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対の透明の中に置かれた絶対に覚醒せる、いわば照尺ゼロの凝視だけではないのか。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼の照尺ゼロの凝視のなかに見出されるものは、彼がいみじくも「凍原とエスキモー」と名づけたところの、いわゆる八〇年代のロシア生活の泥沼だった。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼の照尺ゼロの凝視のなかに見出されるものは、彼がいみじくも「凍原とエスキモー」と名づけたところの、いわゆる八〇年代のロシヤ生活の泥沼だった。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうきれぎれの疑問が道益の念頭を擦過したが、娘の幸福を脅かす毒蟲を取って捨てたい、射ち殺してやりたい、踏みにじってやりたい一途な悪念にとりつかれていた折だったので、照尺を睨むなり、「かったいめ、よくも娘をたばかし居ッた」と曳鉄をひいた。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兵隊さんとしては照尺を良家の令嬢につけたのが寧ろ目っけものだ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
