    "definitions": [
      {
        "index": 1,
        "gloss": "day or date of an invitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「展覧会の招待日みたいだ。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「展覽會の招待日みたいだ。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が収まったので上野二科会展招待日の見物に行く。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ招待日が来るとＹ博士の家族と同格になって観覧に出かける。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事をしていると『中央美術』から電話が掛かって今日が二科会展覧会の招待日であることを想い出させられた。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸暑さが丁度大正十二年九月一日の二科招待日を想い出させた。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月三日の月曜日の午後に、わたしは編集局へ顔を出すと、編集長の渡辺亨君がすぐにわたしを呼んで、きょうは千歳座の招待日であるから見物に行ってはどうだと言った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちの招待日は三月二日で、芝居は午前九時開場、狂言は「廿四孝」と「山姥」と「お染久松」とで、粂八は八重垣姫と山姥を勤めていたが、どちらの役も無論に団十郎張りであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月五日　ペンクラブの招待日だが、招待の最中に、出席者の一員が南條氏に、これを英国のペンクラブだと思ってくれては困ると打ちあけたそうだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夕暮」の絵の下図も出来ていたことだし自分としても気分のいい構図だったので何とかして招待日までに間に合わせたかったので、無理だと思ったが一年一度の制作を年のせいで間に合わせなかったなどと思われるのが残念さから、負けん気を起こして、これもまる一週間徹夜をつづけた。",
              "citation": {
                "source": "健康と仕事",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間頑張って招待日にはどうにか運送のほうが間にあったので嬉しかった。",
              "citation": {
                "source": "健康と仕事",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにもあの日は二科の招待日であったから、上野公園というまず理想的な避難所に初めからいたために、私はただ驚いていさえすればそれでよかった。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "招待日に紋付など着用して会場に立つ勇気さらに出でず。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸おどる招待日の印象をこゝに書きとめることは、今の僕にとつてまことに感慨無量である。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは招待日の当日は病人がひとりもなくなったことによっても知れる。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日　土　今日、サロン・ドートンヌ〔秋の画廊〕の招待日だ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか、ポルト・サン・マルタン劇場であったと思いますが、招待日の廊下は、まさに株式取引所を思わせるような騒々しさで、甲論乙駁、感嘆と憤慨との入り交る、興奮のルツボと化したそうです。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昭和十年から十五、六年頃までの時分であったろうか、毎年、九月一日が、二科会と美術院の展覧会の招待日であった。",
              "citation": {
                "source": "茂吉の一面",
                "author": "宇野浩二",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　工芸室は国展の名物で、いつも楽しみにして出掛けるが、良くて安いものは、招待日の朝出掛けて行って、既に赤札とはどう云うわけだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の招待日に父と見に行って、父がこの絵は動いている一寸いい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど二科会と美術院の招待日で、自分は長女をつれてそれに出かけるために、少しく早めに昼食をとっていたのであった。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物食堂の四階レストランデンツーの招待日で、ポタアジュ、ブフアラモド、冷鶏とシャベット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あひにく今日が各社の招待日だったさうでくさる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、明日の記者招待日だけはたのむと言ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
