[
  {
    "uuid": "607e42b4-0160-52e4-adfc-70074d697511",
    "entry": "商大",
    "reading": {
      "primary": "しょうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
