    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commercial college",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "商大生になってから、はじめての御入来である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "商大へはいったからって、人種がちがってたまるものか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "商大生、慶ちゃんの妹である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「商大はいいからねえ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この売るということが、お話しのほかで、買い手もないといった頃、その頃の堂々たる大名、旗本の家屋敷、あるいは豪商大家の寮とか別荘とかいうものでも、いざ、売り払うとなると二束三文、貰ってもしようがないと貰い手もない時節であるから、この蠑螺堂を、壊し屋が買った値段も想像されます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は商大の專門部へはいれ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『帝大新聞』、『三田新聞』、『法政大学新聞』、『関西学院新聞』、商大の『一橋新聞』等は代表的なものであった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其一は蘭軒の祖父信政の妻の里方、菓子商大久保｜主水が寿筵の詩である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤十字病院前を南に行つて西側に、雑貨商大久保増太郎と云ふ叟が住んでゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」蘭軒の父｜信階の養母にして信政の妻であつた伊佐の生家、菓子商大久保｜主水は庚午の歳に猶店を今川橋に持続してゐて、棠軒は当時の主水と往来してゐたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお取調の結果、兇漢大米虎市の持っていた出刃庖丁は二日前、府下××町××番地金物商大野利吉方で兇漢自身が求めたもので同金物店の雇人某は、大米の顔を比較的よく覚えていたためまったく同人の買ったものなることが明かとなった。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上には東京商大の人々が立てた岳樺の小枝があって、それに一行の名前を書き入れた中山彦一様の名刺がバットの空箱に入れて挟んであった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、商大の高瀬氏来訪、話し、経済のような社会科学が、学として完成するにはどれ丈哲学的要素を重大とするか、哲学者として相当の権威を持たなければ、経済学としても価値ある体系は作れないと話され、考えるところあり。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれどももう来年になれば、弟も商大を卒業するし、妹も女学校の四年になるでしょう。",
              "citation": {
                "source": "文放古",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それに、勝安房守様より下渡された五千両の軍用金で、銃器商大島屋善十郎から、鉄砲、大砲を買取り、鎮撫隊の隊士一同、一人のこらず所持しておる、大丈夫じゃ。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、急に、「どれ、それぢや、こつちはお委せして、わしは出掛けて来ます、午前中に農商大臣と会ふ約束があるから……」　一戸一人以上の勤労奉仕は、それでも、十一戸十五人といふ出動率を示した。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋の配給だけで健康を保って行けないのは、いつかも議会で農商大臣も認めていましたね」「君は、甚だ記憶がいいね」「そこで、政府でも地方の官庁でも、都会民に一坪農園とか二坪農園をやれといいますが、一坪や二坪でなにができますかね。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "建碑について尽力した人の重なるものは、その時には既に世を去っていた成島柳北と今日なお健在の富商大倉某らであった事が碑文に言われている。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "商大を爆破するためだという。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "多忙な自分もほかならぬ商大の最後を弔うべく、実はその群集の中の一人となったのだ。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上田辰之助という商大教授は、「ファシズムの救国の原理は永遠」という。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "大倉喜八郎の祖父、越後北蒲原郡｜新発田町の豪商大倉｜定七の墓碑銘を、頼山陽が頼まれて、起筆して曰く、「余｜嘗て謂ふ古の豪傑。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれはね、お友達の兄さん……熊岡嶺太郎つていふ人……もと商大にゐたのよ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また今日の試みに当っては美濃口時次郎教授及び東京商大図書館の御配慮によって希覯図書を接見するの便宜を与えられた。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長の頭から東半球西半球の話になって、お互に大発見をしました」「僕は商大も三年の後輩です」「商大ってことをよく御存じですね？",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お家からお通いですな」「はあ」「両親健在、商大出身。",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京商大の杉村助教授の細密な思索によっても、左右田経済哲学は依然として左右田経済哲学に外ならない。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "局外批評乃至局外批評家に就いての議論を、目に触れた限り目を通して見たが、その内で唯一つ問題の核心を突いているように思われたのは、春山行夫氏（『神戸商大新聞』）の感想文だったと云っていい。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば三六年七月には東京商大の某教授が謄写版刷りの不穏文書を配布して召喚された、等々。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
