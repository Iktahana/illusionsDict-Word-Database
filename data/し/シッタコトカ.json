    "definitions": [
      {
        "index": 1,
        "gloss": "I don't give a damn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなことわしの知ったことか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「知ったことか、あんなやつらも、手配も。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "日時計に、書類、知ったことか。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女子の知ったことか、だまれ」「だまらんよ、私はそんなことは嫌いじゃ、そんな恐ろしいことは……」「あほう、何をぬかす、だまれ、だまらんと豪い目に逢わすぞ」「逢わされてもかまわん、私はそんなことは嫌いじゃよ」　伯父の声がその後に聞えた。",
              "citation": {
                "source": "参宮がえり",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れようが、雨が降ろうが、それをおれが知ったことか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那のわれわれと同じに搾られている大衆の知ったことか！",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の知ったことか。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やい、手前が課長だろうが、部長だろうが、班長だろうが、こちとら知ったことかえ！",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の生活に向って、俺の知ったことか！",
              "citation": {
                "source": "生活について",
                "author": "――地方の青年へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "深雪、わしと、京へ行って、小太郎の便りを待て」「はい、でも――父の墓へ、一寸――」「墓へ詣って父が喜ぶか、天下のために働いて、父が喜ぶか、女子などの知ったことか。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うう、汝の知ったことかい」「知るも知らんもありゃしない。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいどこで、手に入れたんだい」　帆村探偵は、服のしずくをおとしながら、そういうと、「な、なんだって」　と、トラ十は、急にこわい目つきになり、「そ、そんなことは、お前らの知ったことか。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、そんなこたあおれの知ったことか。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、畜生、貴様の知ったことか、とそんな気持で、彼は女学生の讃美歌合唱を頭の中に描きながら、ばかばかしく声を張り上げる。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長平は不愉快だったが、しかし自分のことが原因で夫婦別れをしたと云う以上は、一方的に押しつけられたものでも、オレの知ったことかと突き放すこともできない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "出るところへ出るサバキなんざア、ベラボーめ、男の知ったことか、と威張り返って済む話ではないから、こう言われると、さすがの親方も二の句がつづかぬのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なぬ、そんなの知ったことか、あれめを片づけておじゃれ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なぬ、そんなの知ったことかえ、とにかくあれめを片づけておじゃれ！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の抜道を斜に歩く俺のような渡世人にゃ、この世の中がどうなろうと知ったことかい。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇帝が返電を出そうと出すまいと何でわれわれの知ったことか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥八　　手前の知ったことか。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟梁の佐太郎を殺し、お萩を誘拐し、板倉屋の主人を殺した曲者は、先生の言葉一つで、見当がつくのですぜ」「それを私が知ったことか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰でも宜い、その女を手に掛けるとは、あまりと言えば不仁」「何を、其方の知ったことか、――それより、今頃此の山にうろうろするのは怪しい奴ッ、それッ」　奥村主殿が手を挙げると、六人の若党、三方からパッと飛び付きます。",
              "citation": {
                "source": "天保の飛行術",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓の玩具なんぞふり廻してまだ一人前の男にもなってないキューピットの果して知ったことか？",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の抜道を斜に歩く俺らのような渡世人にゃ、この世の中がどうなろうと知ったことかい。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――冗談じゃない……様子なんていいか悪いか知ったことか。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく聞きとれないので、面倒くさくなり、「もういい、義十なんか知ったことか」と云い返したが、そう云う自分の声で眼がさめた。",
              "citation": {
                "source": "霜柱",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……フン、自分で勝手にきめたって、あたしの知ったことか」「そげんこつかい？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み食いの跡始末まで、知ったことか。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
