        "examples": {
          "standard": [
            {
              "text": "東本願寺は、真宗大谷派の本山として多くの門徒に信仰されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の祖父母は、熱心な真宗大谷派の信徒だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真宗大谷派の教えは、阿弥陀仏への絶対的な帰依を説く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、この時に今日の東西本願寺――本願寺派本山のお西と、真宗大谷派本願寺のお東とが分岐した。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
