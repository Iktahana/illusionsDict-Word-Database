        "examples": {
          "standard": [
            {
              "text": "彼は少し神経質的なところがあり、些細なことにも過敏に反応する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神経症的な完璧主義は、時に仕事の効率を妨げることがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「彼の神経症的な言動は、周囲の人を困惑させることもあったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ブレイクは過去の邪教の驚くべき痕跡を発見したのだが、その邪教に関する知識によって悪化した本人自身の過剰な想像力と神経症的な不均衡とを考えれば、最後の逆上した走り書きを解釈することができる。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
