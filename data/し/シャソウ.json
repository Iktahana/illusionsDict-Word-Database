[
  {
    "uuid": "ccc751f8-72a7-52fc-acdc-21171143bb93",
    "entry": "車窓",
    "reading": {
      "primary": "しゃそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "train window",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車窓偶感の掻き集めに過ぎざるものぞ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり車窓に目醒むれば汽笛は闇に吠え叫び火焔は平野を明るくせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台以北は始めての旅だから、例により陸地測量部二十万分の一の地図を拡げて車窓から沿路の山水の詳細な見学をする。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅虫温泉は車窓から見ただけで卒業することにした。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は默つて車窓に向ひ合つてゐた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　裏街を行く車窓にメインストリートの上層の華美な電飾が反映していた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しいつもの時間になって、オテル・ド・ロンの鉄門が見え出すと妾は佐野の亢奮し、やつれた顔が車窓に映るような気がして、慌てて車内の空隙に現れた心影を妾は払いました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は着ていた猫の舌で一杯の衣服を脱いで、しかつめらしく恋の密輸入物をトランクにしまうと一寝入りするつもりで車窓からボスニヤ平原に咲く砂糖黍の花の香いを嗅いでいるうちに、すっかり追想的になってしまったのだ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨かれた車窓に、西紅葉の横顔がスプリングのついた船舶に乗船する女のように輝いていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの林や、立木が遠い山を中心に車窓の前をキリ／＼廻転して行った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに先刻の手早き藝當が其效果を現はして來たので、自分は自分と腹が定まり、車窓から雲霧に埋れた山々を眺め『走れ走れ電車、』　圓太郎馬車のやうに喇叭を吹いて呉れると更に妙だと思つた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話をしながら徐行していると、車窓の外を通りかかった二三人の学生が大きな声で話をしている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方の山などは二十万分一でことごとく名前がわかり、付近の地形は五万分一と車窓を流れる透視図と見比べてかなりに正確で詳細な心像が得られる。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時赤羽行きの汽車が朝日をまともに車窓に受けて威勢よく走って来た。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "石狩の野は雲低く迷ひて車窓より眺むれば野にも山にも恐ろしき自然の力あふれ、此処に愛なく情なく、見るとして荒涼、寂寞、冷厳にして且つ壮大なる光景は恰も人間の無力と儚さとを冷笑ふが如くに見えた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白なる顔を外套の襟に埋めて車窓の一隅に黙然と坐して居る一青年を同室の人々は何と見たらう。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が今しも車窓より眺むる処の雲の去来や、樺の林や恰度それであつた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓を隔てゝゐる爲めに、聲が少しも聞えないので、殊更ら私の感じを不思議なものにしてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山駅で水戸の三人武者とも別れて、後はただ一人、俄かに淋しくなれば数日以来の疲労も格段に覚えて、吾輩は日光の鮮かに照す汽車の窓から遠近の景色を眺めていると、吾輩に向い合って腰掛けていたのは頬骨の高いハイカラ紳士、物をもいわず猿臂を伸ばして、吾輩が外を眺めている車窓の日除け扉を閉ざす。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラットホームに汽車がはいると、伝三郎は妻を叱りとばしながら、右往左往し、やっと車窓に、船司の顔を見つけた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　不意の声をたてたのは反対側の車窓から氏を見た子供であった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓の眺めは例によつて例の如しであるから退屈の餘りの時間を雜談に消すほかはなかつたが、安成子は職分に忠實なので、しきりに八景論を提出して老人の談話を引出さうとつとめる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こんなことを語つたり思つたりしてゐる中に、晴れたり曇つたりする日の右手の車窓には梅雨の雲の間に筑波の山が下總の青田の上、野州の畑の上から美しいその姿を見せ、左方の日光つゞきの山々はなほ薄雲の中に隱れてゐて、早くも宇都宮に着き、やがて日光驛に着いた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓には梅雨にはいつて間もない小糠雨がけむつてゐる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私もやがて車窓に身を凭せながら眼を閉ぢたが、あたり憚らない政黨屋の話聲は相變らず小うるさく耳についてくる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、雜誌を傍に投げ捨てると、私は車窓に顔を凭せかけて眼をつぶつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は車窓から身を起しながら、薄眼にそつと女の方を振り返つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすきの穂が車窓にすれすれに、そしてわれもこうの花も咲いていた。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹田を過ぎ、東淀川の駅を過ぎると、やがて南側の車窓に、北野劇場のネオンサインが見え、大阪はもう夜であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "編笠の中から車窓を覗くと、いつの間に建ったのか、駅前に大きな劇場が二つも並んでいた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
