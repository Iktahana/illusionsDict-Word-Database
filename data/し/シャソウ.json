  {
    "uuid": "f7b97b5f-b112-5a16-9a68-d1f1025793cb",
    "entry": "社僧",
    "reading": {
      "primary": "しゃそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "priest attached to a shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オサカベとは言ず、天守櫓の脇に此祠ありて其の神に事ふる社僧あり、城主も尊仰せらると。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当社僧の復飾に、仏像を神体とするものの取り除きに、大菩薩の称号の廃止に、神職にして仏葬を執り行なうものの禁止に――それらはすべて神仏分離の運動にまであふれて行った国学者の情熱を語らないものはない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ、大宮神社の神官、社僧などが、大勢して、出迎えに見えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし社僧等が名づけて供花といった風習とても、なお何れの点まで仏法の教えに基づいているかを考える必要がある。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "男鹿では足利時代の終わりに近くなって、本真二山の社僧が相前後して、真言山伏の宗派に転属したことがあった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
