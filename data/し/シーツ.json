        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白いシーツのように見えていたのがそれで、静かに立ち騰っている煙は男がベッドで燻らしている葉巻の煙なんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時に疲れが出たらしく、両手をベッタリとシーツの上に突くと、声をひそめて力強く呼んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお末は医師の家の二階の手広い一室に運ばれて、雪白のシーツの上に移された。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して空をつかみシーツを引きさく無残な苦悶の間には、ぞつとする程恐ろしい昏睡の静かさが続いた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四つになる女の子は寝床の中で、白いきれいなシーツの中に寝ていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが伯母の居間です」　といううちに妻木君は左側の押し入れの襖を無造作にあけて、青白い二本の手を突込んで中のものを放り出し初めた……縮緬の夜具、緞子の敷布団、麻のシーツ、派手なお召の掻い巻き、美事な朱総のついた括り枕と塗り枕、墨絵を描いた白地の蚊帳……。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シバラク　スルト、ウシロノ　カゴカキガ、「シーツ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　マヘノ　カゴカキモ、「シーツ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヤウサンハ　クルマニ　ノツテ　ムチヲ　フリアゲ、「シーツ」ト　イヒマシタ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩序ある生活と、アルコールやニコチンを抜いた清潔なからだを純白のシーツに横たえる事とを、いつも念願にしていながら、私は薄汚い泥酔者として場末の露地をうろつきまわっていたのである。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活は秩序正しく、まっ白なシーツに眠るというのは、たいへん結構な事だが、（それは何としても否定できない魅力である！",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幾晩もこの白いシーツの上に白毛布を包んだ白いカバーを引っかけて眠った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の卓子の上に、シーツに包まれて横たわっている故人の遺骸を私は見た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は猛烈な勢なので、やむを得ず、みんなで彼をベッドに（シーツや縄で）括り付けた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽根布団の下は真赤な血に染ったシーツばかりである。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのシーツの中央には何かあって手を突込んでみると、下はからになっているらしい。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅の方に小さくなって軽く咳をしていたが、彼が引き寄せた途端、激しく咳き出して、白いシーツの上に喀血した。",
              "citation": {
                "source": "蚊帳",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいにみがかれたクルミのからの上に、スミレの花びらをシーツ、バラの花びらをしきぶとんにしたきれいなゆりかごです。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "血走った白眼を剥き出して、相手の顔をクワッと覗き込んだが、乱れた髪毛の中を一眼見ると、そのまま両眼をシッカリと閉じて、シーツの上にのけぞった。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学生のＵ・Ｓが近頃の作品（映画）を発表するから――と云つて僕の部屋の壁にシーツをはりつけました。",
              "citation": {
                "source": "サンニー・サイド・ハウス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして涙はあとからあとからみなぎるようにシーツを湿しながら、充血した口びるは恐ろしい笑いをたたえてわなわなと震えていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さし込んで来たようで……あ、あ」　といいながら、目をつぶって、床の上に寝倒れると、木村の手を持ち添えて自分の脾腹を押えさして、つらそうに歯をくいしばってシーツに顔を埋めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩でつく息気がかすかに雪白のシーツを震わした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しその位置を動かすと白さをそのままな寒い感じがシーツから逼って来るのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は震える手で枕をなで回したり、シーツをつまみ上げてじっと握り締めてみたりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりです……　葉子は身もだえもできない激痛の中で、シーツまでぬれとおるほどな油汗をからだじゅうにかきながら、こんな事をつぎつぎに口走るのだったが、それはもとより言葉にはならなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーツを思いきりつかんでいた手を放して、弱々と額の所をなでると、たびたび看護婦がぬぐってくれたのにも係わらず、ぬるぬるするほど手も額も油汗でしとどになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子は、朝眼が覚めると、寝床の白いシーツの上に、緑色の窓掩を透して、朝の朗かな光が、戯れているのを見ると、急に幸福な感じで、胸が一杯になった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の白い寝衣、白いシーツ、白い毛布に、夜目には赤黒く見える血潮が、ベタ／＼と一面に浸んでいる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の寝台のシーツを取ると、それを小さく引き裂いて、母の傷口を幾重にも幾重にもくゝった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
