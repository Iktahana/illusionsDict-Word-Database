[
  {
    "uuid": "1ed56afc-bf04-56b9-8398-86912298abe2",
    "entry": "出版業",
    "reading": {
      "primary": "しゅっぱんぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
