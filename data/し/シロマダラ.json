    "definitions": [
      {
        "index": 1,
        "gloss": "Oriental odd-tooth snake (Dinodon orientale)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "背のあたりに白斑二つ三つある赤毛のめす子である。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "白斑の四足で、面が人間よ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づくと白斑の犬である。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前生の仇が犬になって、あとをつけて追って来た、面の長い白斑で、やにわに胴を地に摺って、尻尾を巻いて吠えかかる。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから黒んぼの鰌すくいだが、これも汗みどろの大吐息で、顔から手から白斑になってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと、両手でウントコサと擁え込んだのを見ると驚くべし、直径一尺五寸余もあろうと思われる雅味のない大皿に盛りも盛ったり、恐らく十人前は焼いたであろうところの部厚な白斑の玉子焼きである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年一月、渋柿）　　　　　　　＊「三毛」に交際を求めて来る男猫が数匹ある中に、額に白斑のある黒猫で、からだの小さいくせに恐ろしく慓悍なのがいる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はまず黒白斑の牛と赤牛との二頭を牽出す。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれない人たちには、荒れないような牛を見計らって引かせることにして、自分は先頭に大きい赤白斑の牝牛を引出した。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛疫の牛というのは黒毛の牝牛赤｜白斑の乳牛である。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は先づ黒白斑の牛と赤牛との二頭を牽出す。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れない人達には、荒れないやうな牛を見計らつて引かせることにして、自分は先頭に大きい赤白斑の牝牛を引出した。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹は一面に白斑のある鳥で、雪の山と名づけられた名鳥であると老人は説明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなとよ、たゞの鳥なれど、赤染色のはねばうし、黒斑白斑の綾模樣紅梅、朽葉の色ゆりて、なに思ふらむ啄木のつくづくわたる歌の枝。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "出はいりの時に生徒でいっぱいになる下駄箱のあたりも今はしんとして、広場には白斑の犬がのそのそと餌をあさっていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶事に用いる三つ羽箒には野雁の尾羽を好しとするが、その中でも黒に白斑のあるのを第一とし、白に黒斑のあるのを第二とし、数寄者は非常に珍重するので、その価も高い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "お熊の兄の宇兵衛は堀江の浜で偶然に拾って、白斑と黒斑の尾羽をたくわえていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "光りの消えた砂浜を小急ぎに、父を真中にやって来ると、白斑の犬が一匹船の横から出て来た。",
              "citation": {
                "source": "海浜一日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、痺れがどこからとなくやってきて、身体中を所嫌わず、這い摺るようになると、今まで見えていた血の管の色が、妙に黝ずんできて、やがて痺れも一個所に止まってしまい、そこが白斑みたいに濁ってくるんですとさ。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折矢田平が父より夢中に授かりし片袖を、白斑の鷹来て攫み、飛去る。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "白斑の大きな木馬の鞍の上に小さい主人が、両足を蹈ん張って跨がると、白い房々した鬣を動かして馬は前後に揺れるのだった。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛色は真っ黒で、胸に月輪形の大きな白斑を有している。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずイトススキは葉の極めて狭長なものであり、シマススキは葉に白斑のあるものであり、タカノハススキは葉に矢羽の斑のあるものである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室内にあるタイヨウベゴニア（大葉ベゴニア）は、大なる深緑色葉面に白斑があって、名高い粧飾用の一種である。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る限り褐色や渋色をなすりつけた黒白斑の大岩塊が、縦に欹ち横に伏して、頭上二、三尺の高さに不恰好な階段を築き上げている、私達は取りつき端もない階段の下に立って、未練らしく手足を掛けて見たりなどした、夫でも水の鉋に削られた岩の屑が堆く積って、易々と乗り越せる所もあった。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、もとはこんもりと棗形に刈り込まれて居たであらうと思へる白斑入りの羅漢柏である。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は一庭の樹を照らし、樹は一庭の影を落し、影と光と黒白斑々として庭に満つ。",
              "citation": {
                "source": "良夜",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ば隠れて、上背のある優雅な女性が、黒いドレスに鮮やかな白斑を散らした衣装で、誰かを待っているかのようだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
