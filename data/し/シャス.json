[
  {
    "uuid": "7c822887-2e84-5bce-8132-5424631674b4",
    "entry": "謝す",
    "reading": {
      "primary": "しゃす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行"
      ],
