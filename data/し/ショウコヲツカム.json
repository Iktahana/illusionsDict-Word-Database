        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを明らかにすればあるいは何か確たる証拠を掴むことが出来るかも知れないと思つていたのだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田沼を弾劾し失脚させるには、そういう私生活方面の、的確の証拠を掴むことも、大いに必要あろうではないか。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その証拠を掴む為に、わしは昨日から一睡もせず苦労しておりましたのじゃ。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが無実の証拠を掴むまで婚約者に近寄らないと誓いました。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "証拠を掴む為に、汚いスパイ組織に入り込んだのです。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
