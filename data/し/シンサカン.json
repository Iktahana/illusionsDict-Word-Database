    "definitions": [
      {
        "index": 1,
        "gloss": "examiner (e.g. patent examiner)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
