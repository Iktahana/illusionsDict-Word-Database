[
  {
    "uuid": "30fb5e94-2bd3-5a30-9ac9-853b20bd5f04",
    "entry": "真剣",
    "reading": {
      "primary": "しんけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
