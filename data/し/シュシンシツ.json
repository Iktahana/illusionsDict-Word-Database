        "examples": {
          "standard": [
            {
              "text": "新しい家では、主寝室から海が見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の主寝室は、シンプルながらも落ち着いた家具で統一されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが独立したので、夫婦は主寝室をより快適な空間に模様替えした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "建物の東側には、いまは川島が自分のものとして使っている主寝室があった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の東側は、バルコニーから順に、八畳の和室、その押入れ、浴室と洗面、クロゼットのある主寝室、そしておなじくクロゼットのついた、ひとまわり小さい洋室だ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主寝室を執筆の部屋に、そしてひとまわり小さい部屋を執筆の準備のために使うことに、日比谷はきめていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
