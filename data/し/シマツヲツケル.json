[
  {
    "uuid": "3fe40bdf-29d8-558d-adf7-8f8444930585",
    "entry": "始末をつける",
    "reading": {
      "primary": "しまつをつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
