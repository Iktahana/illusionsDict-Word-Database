        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空ぐるま軋るを見れば、上岨を尻毛振る赤馬、ひようひようと吹かれゆく馬子、みな寒き冬のものなり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の尻毛や亜麻の極柔かい弾力の強いもので、目庇までも薄い上等のエナメル皮や何かが使ってある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻毛が時々ピシリ／＼と身體を打つた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩小屋から、尻毛でピシリピシリ馬が身体を打っている音が聞えた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でもあの小柄な、性質の賢い狆が、頭の毛を振つたり尻毛を振つたりしながら畳の上を歩き廻つたその足音を聞くことが出来るやうな気がする。",
              "citation": {
                "source": "犬",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々｜私にこの馬を撫でさして御くんなんしょ」　光沢を帯びた栗毛の腰の辺を撫下し、やがて急に尻毛を掴んで、うんと持上げて見ました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々私にこの馬を撫でさして御くんなんしょ」　光沢を帯びた栗毛の腰の辺を撫下し、やがて急に尻毛を掴んで、うんと持上げて見ました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見た一頭の黒い牝牛は尻毛を動かして、塩の方へ近いて来る。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
