        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不備が見つかって審査の対象外となった失格者には、後日メールで通知が送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "たとえ試験で一度失格者となったとしても、来年また再挑戦するチャンスはある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "失格者たちの名前が掲示板に貼り出され、会場には重苦しい空気が漂った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "学者などのうちにはほとんど人間失格者のごとき人がある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、世俗の人がややもすれば学者をぼんやりした人間失格者のごとくいう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる風あるものは人間失格者としか思われぬ。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼らは平和失格者なのである。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後ニューフェース筆頭の大物でありながら、同時に最大の落第生失格者たるものは日本共産党であったが、この反対に、ニューフェースの及第生は何ものであろうか。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもあなたが、今後いかに生くべきかという問題で、誰かに相談したかったら、礼子さんは相談相手として、まず第一の失格者です。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もし鳥や花がかれらの標準にてらしてわたしを吟味するとすれば、わたしはどの点でも失格者とみとめられないであろう。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "死亡者名簿が出来とらんし、失格者も増えるかも知れん。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
