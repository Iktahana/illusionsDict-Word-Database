        "examples": {
          "standard": [
            {
              "text": "舞台に紗幕が下りて、幻想的な雰囲気が作り出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紗幕の向こうに役者の影がぼんやりと見えて、物語への期待が高まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "照明の当て方によって、紗幕が透けたり隠れたりする効果が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最初は降るともなく舞い下っていたその雪は、六時七時と追々に量を増してひとしきり激しく降りつのったが、八時になると紗幕をあげたようにパタッと降りやんで、不意に切れはじめた雪の隙間から深く澄んだ星空が冴え冴えと拡がっていった。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
