[
  {
    "uuid": "f44a47f5-0606-5d8d-8d7e-ffe787379f65",
    "entry": "首尾一貫した",
    "reading": {
      "primary": "しゅびいっかんした",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
