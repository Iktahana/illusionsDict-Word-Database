    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hearing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "途中、警官の不審尋問にあったが、私がついていたので、なんでもなく済んだ。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄二　些か不審尋問の形をそなえていますね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、脚の捻挫でしたね」「はあ、パトロール中に不審尋問をしてゐた相手が、いきなり逃走を企てましたので、その後を夢中で追ひかけました。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査はわたくしの上着を剥取って所持品を改める段になると、平素夜行の際、不審尋問に遇う時の用心に、印鑑と印鑑証明書と戸籍抄本とが嚢中に入れてある。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "不審尋問にひっかかって身体をしらべられても、キンタマには手をやらない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地ならいざ知らず、ここで女郎買いへ行くのに、そんなものを持って行ってはまずいと思ったからだが、昨日も実は総督官邸の様子を探りに出かけたとき、不審尋問に万一ひっかかった場合を考えて、ピストルを地袋へ隠して行った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "養父の代筆で、――あれが肺病だって言って来たが本当か、一番おそろしい病気だから用心してくれ、たった一人のお前にうつると、皆がどんなに心配するかわからない、お母さんはとても心配して、この頃は金光様をしんじんしている、一度かえって来てはどうか、色々話もある。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもそのゝち一ねんとたゝぬあいだにまったくめしいになりまして、かみしんじんもいたしましたがなんのきゝめもござりませなんだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
