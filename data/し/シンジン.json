    "definitions": [
      {
        "index": 1,
        "gloss": "faith",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かくて私は詩壇に、他力信心といふものを一度考へてみて貰ひたい。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のいろは骨牌では、イが「犬も歩けば棒にあたる」であるが、大阪の方では「鰯の頭も信心から」で、絵札には魚の骨から金色の後光がさし、人々のそれを拝んでいる様が描いてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近きベンチへ腰をかけて観音様を祈り奉る俄信心を起すも霊験のある筈なしと顔をしかめながら雷門を出づれば仁王の顔いつもよりは苦し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、「旦那Ｔ「神信心って奴もやって見るとまんざら悪かァ御座んせんね」　と言って「急ぎやすから御免なせえ」と其の儘スタスタと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎が、Ｔ「成る程ね、神信心もまんざら悪かァ無え筈よ」　と言われて三次真赤になった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達がこれからの悪い運命を待つために妾は貴方のためのよい信心家になるのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも御信心の人がありましょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御信心だね」と、半七も笑って会釈すると、小娘も笑って挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云い訳をするのも野暮ですが、そこの妹があたしのところへお稽古に来るもんですから」「じゃあ、そのおっかさんも御信心なんだね」と、半七は何の気もつかずに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御信心も御信心ですけれど、すこし心配事がありましてね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なかなか御信心だねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈祷料は思召しなんですけれど、ひとりで二｜歩三歩も納める奴があるそうですから、たいしたものです」「それはまあそれとして、その行者は工面のよさそうな信心ものを奥へ連れ込んで、なにか秘密の祈祷をして多分の金を寄進させるというじゃあねえか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "久次郎どのは毎夜かかさず通って来るのは、まことの心からの信心ではない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "信心者からの奉納物らしい目録包みの巻絹や巻紙や鳥や野菜や菓子折や紅白の餅なども其処らにうず高く積まれてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "義母などの信心から、天理教様に拝んでもらえと言われると、素直に拝んでもらっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の天窓も信心から、それでも命数の尽きぬ輩は本復するから、外に竹庵養仙木斎の居ない土地、相応に繁盛した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に娘が十六七、女盛となって来た時分には、薬師様が人助けに先生様の内へ生れてござったというて、信心渇仰の善男善女？",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "観行院様は非常に厳格で、非常に規則立った、非常に潔癖な、義務は必らず果すというような方でしたから、種善院様其他の墓参等は毫も御怠りなさること無く、また仏法を御信心でしたから、開帳などのある時は御出かけになり、柴又の帝釈あたりなどへも折々御出でになる。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書なんてものは信心でもしない限り滅多に読んでみる気がしないものですし、その本を持ち伝えた先祖代々の人も、それがソンナ本だって事を云い伝える事も出来ずに、土蔵の奥に仕舞い込んで御座ったんでげしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アダムとイブが、神様を信心し過ぎて肉慾を軽蔑している間は、子供が生まれなかった。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十五万石の大目付、丸潰れと来たなあ」「それでももしや、お熊の縁談から起った意趣、遺恨じゃないかと思うて、襟半の方へ探りを入れてみると、花婿の半三郎も、今は隠居しとる父親の半左衛門夫婦も、神信心の律義者という評判に間違いないらしい」「それは毛頭間違いない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが仏教の第一歩で、心を信ずるゆえにこれを信心と言います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信心も何もなかつたが、なあ、揃ひも揃つた、あなたがたのお情――あの娘も聞かつしやれ。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……父親は法華宗のかたまり家だったが、仕事には、天満宮を信心して、年を取っても、月々の二十五日には、きっと一日断食していた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことや既に仏果を得て、勇猛精近の行堅固に、信心不退転の行者なれば、爾き黒暗闇の裡に処しても真如の鏡に心を照せば、胸間｜霽れたる月のごとく、松の声せず鏡の音無きも結句静処を得たりと観じ、寂寞として水晶の数珠｜爪繰りて泰然たり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「対手は婦人だ、それに、お百度を踏もうという信心者だから、遣損なったら、威すと可い。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――木戸錢はおろか、遠方から故々汽車賃を出して、お運びに成つて、これを御覽なさらうとする道徳家、信心者があれば、遮つてお留め申す。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうした世間だ、もう以前から、村一統鐘の信心が消えている。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "養父の代筆で、――あれが肺病だって言って来たが本当か、一番おそろしい病気だから用心してくれ、たった一人のお前にうつると、皆がどんなに心配するかわからない、お母さんはとても心配して、この頃は金光様をしんじんしている、一度かえって来てはどうか、色々話もある。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもそのゝち一ねんとたゝぬあいだにまったくめしいになりまして、かみしんじんもいたしましたがなんのきゝめもござりませなんだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
