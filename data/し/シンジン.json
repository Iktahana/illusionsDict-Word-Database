  {
    "uuid": "f5c6228a-ada7-50ef-8f97-bafe2e18f651",
    "entry": "審尋",
    "reading": {
      "primary": "しんじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
