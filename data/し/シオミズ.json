    "definitions": [
      {
        "index": 1,
        "gloss": "salt water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若し、彼女が、長い航海をしようとでも考えるなら、終いには、船員たちは塩水を飲まなければならない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから長い間には、タンクの水は些も減らない代りに、塩水を飲まねばならなくなるんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま川の流れてゐるとこに、そっくり塩水が寄せたり引いたりもしてゐたのだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "環境には何ら科学的の刺戟はなかったが、塩水に卵の浮く話を聞いて喜んで実験したり、機関車二台つけた汽車を見てその効能を考えたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木乃伊を作るには始め塩水に死体を漬け種々の樹脂の類を塗って固めたものらしい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートサイドでレモンの皮のはいった塩水で嗽をしてスエズ運河の両岸の夜景に挟まれて身の丈を長くした妾は天晴れ一人前の女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一千九百二十六年三月廿〔一字分空白〕日、塩水撰をやった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも塩水｜選をかけたので恰度六｜斗あったから本田の一町一｜反分には充分だろう。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならいままでは塩水選をしないでやっと反当二｜石そこそこしかとっていなかったのを今度はあちこちの農事試験場の発表のように一割の二斗ずつの増収としても一町一反では二石二斗になるのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなにもほんとうにいいということが判るようになったら、ぼくは同じ塩水で長根ぜんたいのをやるようにしよう。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩水選をする間は父はそこらの冬の間のごみを集めて焼いた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」タネリは辛い塩水の中でぼろぼろ涙をこぼしました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま川の流れているとこに、そっくり塩水が寄せたり引いたりもしていたのだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなカンテラ一つと、形の色々の金槌二つ三つとを持って、船の二重底に這い込み、石炭がすでに真黒になって、油の様にとろりと腐敗したままに溜って居る塩水の中に、身体を半分浸しながら、かんかんと鉄※を敲き落すのである。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品種や土壌によりますがなあ、さうですなあ、陸稲一反歩となるというと、可成いろいろですがなあ、その塩水撰したやつとしないやつでもちがいますがなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「はあ、その塩水撰したのです。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待「ははあ、塩水撰した陸稲の種子と、土壌や肥料にもよりますがなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "食塩水が止血に効くことを知っていたのだろう。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎が呑み過ぎて胸が苦しいといったので、初乃は塩水を取りに行った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎にのますべき塩水のことが一寸忘れられた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａはその中に、幾度か塩水を飲み込んで噎せた。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "処を沖へ出て一つ暴風雨と来るか、がちゃめちゃの真暗やみで、浪だか滝だか分らねえ、真水と塩水をちゃんぽんにがぶりと遣っちゃ、あみの塩からをぺろぺろとお茶の子で、鼻唄を唄うんだい、誰が沖へ出てベソなんか。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて口を押え、「食塩水……」をくれと情ない声を出すと、はいと飲まされたのは、ジンソーダだ。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は忍び足で台所へ行き、塩水でうがいをして、それから顔も手も洗って寝床へ帰った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王ともかく本人をとて召し見ると、かの男王の前で金を吐く、王女馬の腹帯もて彼を縛り塩水を呑ませ鞭うつと玉を吐くを、王女拾い嚥みおわる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは至極平凡な、ただの塩水であった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この塩水と人殺しとは、決して無関係ではないんですよ。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
