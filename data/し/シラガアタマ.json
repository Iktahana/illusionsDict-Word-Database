    "definitions": [
      {
        "index": 1,
        "gloss": "gray or silver haired (grey)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで尊敬を忘れずに心易立てをも敢てする老僕の態度で、スタニスラウスの白髪頭の上へ首を屈めて云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこの上は我慢も遠慮もない、その翌朝例の如く食事を初めた時に、私は番人夫婦に向って、「お前さん達は長年この別荘に雇われていなさるのかね」と、何気なく尋ねると、夫の方は白髪頭を撫でて、「はい、私しは当年五十七になりますが、丁度四十一の年からここに雇われて居ります」と云う。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　重蔵も漫ろに三十年｜前の夢を辿って、谷川の流に映る自己の白髪頭を撫でた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪頭の甚右衛門は帳場から顔を出して、笑いながら挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中庵主　　　　右三章　　　　　　　　　　　　　　　　　　　　山頭火しるす夜、樹明君がバリカンを持つて来て、白髪頭を理髪してくれた、ありがたい、言語同断ありがたかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋だか初冬の夕だかに斯んな田圃から町の方へ、黄ろい大きな前歯をむき出したお婆さんが一人白髪頭をふりさばいて黙つて歩いて行く――こんなことが凄いやうに描いてありはしませんでした？",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が馬車に乗ってたら、関所の因業なおじさんは、ちっとも通行税とらないで、一寸白髪頭をこすって、低い幌馬車見送った。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが白い麻の支那服を著て、一等の談話室の、ラジオの黒い喇叭が二つ背中合せに立っている緑の大卓を前に控えて、ポケットから大きな眼鏡を取り出すと、白髪頭をひと振り振って両耳へ掛ける。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この白髪頭の媼の事を桂屋では平野町のおばあ様と言っている。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンが白髪頭をのぞけた。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしたり……」　主人が白髪頭を上げて眼を丸くした。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人俵からは老人の白髪頭が出ていた。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだけな婆さんは、枕、こんなに濡らして……」　お美代はこう言って、お婆さんの白髪頭を持ち上げ、濡れた枕を裏返しにしてやった。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色の朝の服を着て、白髪頭にパナマ帽を被つてゐる。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪頭がしかもはげあがって、見ちがえるほどじじになっていた。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労に苦労を重ねて、疲れ切ったような祖母の顔、垢づいた白髪頭に穴のあいた手拭を巻きつけている。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "用人の詰めている部屋を覗くと、十太夫も小さい机に倚りかかって、半分は眠ったように白髪頭をかしげていた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十太夫は一切の役目を終った上で、白髪頭を剃り丸めたいといった。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程この街で、一番珍しい奇妙な風体をしている、一番｜長生の白髪頭の老人を見付け出して、その人の身の上話しを聞かしてもらえば、屹度面白い新規の話を聞く事が出来るに違いない。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに暫くの間立って待っていると、間もなくよい都合に向うから、お誂え通りの奇妙な風体をした白髪頭の人が遣って来たから、姫は天にも昇らんばかりに喜んで、いきなりその人の前に駈け寄って袖に縋りながら十円の金貨を出して、身の上話をしてくれと頼んだ。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして今の話で、この間赤い鸚鵡が云った一番｜長生の白髪頭の奇妙な姿をした老人というのはお爺さんでもお婆さんでも何でもなく、この白髪小僧の事に違いないことがわかった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　全く――白髪頭の、小さな白いエヴァンスの顔だった。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありやうを言へば、少し罪な話だけれど、祖父の白髪頭がすつかり洗ひ水でずぶぬれになつて、西瓜や甜瓜の皮をいつぱい引つかけた態は、まつたく滑稽だつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆく春くれゆく春のかなしさは白髪頭の蒲公英のむく毛がついついとんでゆく風がふくたびとんでゆき若い身そらで禿頭。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い取散らかした室の隅に、臥床が設けてあつて、汚れた布団の襟から、彼方向の小い白髪頭が見えてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ白髪頭の小使が入つて来て用を聞いたので、女は何かお菓子を買つて来いと命ずる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親達が失望して情ながる面は手紙の上に浮いて見えるけれど、こうなると妙に剛情になって、因襲の陋見に囚われている年寄の白髪頭を冷笑していた。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎娘は今日か明日かとお迎へを待つてゐるうちに、とうと八十年の月日を過して、白髪頭の婆さんになつてしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに衝立つてゐた門番の爺さんは、にこ／＼もので出て来て、丁寧に白髪頭を下げた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その途端、今まで隣の大男の影になつてゐた白髪頭がふと眼についた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
