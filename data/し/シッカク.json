    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disqualification",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生あるもの、すべて世の中になくてかなわぬ重要の歯車、人を非難し、その人の尊さ、かれのわびしさ、理解できぬとあれば、作家、みごとに失格である。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉は咄嗟に、デカダンス失格を宣言する光栄に浴したいと、思った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一册の標題された詩集の中に、そのテーマやスタイルを異にしてゐる種種雜多の詩が書かれてるのは、藝術品としての統一がなく、内容上の美的裝幀を失格してゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の見るところの事実に照して、正直に、大胆に真理を言えば、現にある口語自由詩の殆ど全部は、すべてこの点で落第であり、詩としての第一条件を失格している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら著者自身が最初に失格している詩人であるから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間失格」という題にするつもりである。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、いまは不吉な敵国の言葉になったが、パラダイス・ロストをもじって、まあ「人間失格」とでもいうような気持でそんな題をつけたのであって、その日記形式の小説の十一月一日のところに左のような文章がある。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間失格、あたりまえのことである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち、質問者の心理の底にまではいっておれば、結局解答者は失格さ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに良く出来た答案でも、永い時間掛って書くようなのは、新聞記者としては失格だという編輯長の意見だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弁護士さんのようにものわかりよい親があったとして、その娘さんが廃嫡されれば戸主ではなくなるのだから、戸主としてもし与えられる何かの権利があれば、社会的な性質のそれを先ず失うこと、我から失格して、妻の幸福を守らなければならないということにもなる。",
              "citation": {
                "source": "今日の耳目",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　私は夢の中で或る失格をした。",
              "citation": {
                "source": "断片",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "失格した自分は、もうこゝでは何一つ取り戻しやうがない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はその頃、「展望」に連載する小説「人間失格」にとりかかっていた。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は後に「人間失格」を読んで、あれに覗き出してる暗い影に心打たれた。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者などのうちにはほとんど人間失格者のごとき人がある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、世俗の人がややもすれば学者をぼんやりした人間失格者のごとくいう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる風あるものは人間失格者としか思われぬ。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は老衰を、失格を、出來事を嫌惡する。",
              "citation": {
                "source": "色褪せた書簡箋に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子様でなければ人格がない、なんていうのじゃない、失格といったってえらいという事でもなければ、偉くないという事でもない、個人の思想なり観念なりを中心とするのである。",
              "citation": {
                "source": "おはなし",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度出るのは、「櫻桃」・「人間失格」、それに「ヴィヨンの妻」――皆故人の名を、その時々に、一段づゝせりあげた作物である。",
              "citation": {
                "source": "水中の友",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴィヨンの妻」や「人間失格」も、かう言ふ範疇に入れて、私は見てゐた。",
              "citation": {
                "source": "水中の友",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は、十三の数をひねくったり、人間失格、グッドバイと時間をかけて筋をたて、筋書き通りにやりながら、結局、舞台の上ではなく、フツカヨイ的に死んでしまった。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間失格」「グッドバイ」「十三」なんて、いやらしい、ゲッ。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰が死にそこなって、生きかえったら、いずれはフツカヨイ的に赤面逆上、大混乱、苦悶のアゲク、「人間失格」「グッドバイ」自殺、イヤらしい、ゲッ、そういうものを書いたにきまっている。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は、魔法つかいに失格せずに、人間に失格したです。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、太宰は、人間に失格しては、いない。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、人間失格、グッドバイ、それで自殺、まア、それとなく筋は立てゝおいたのだろう。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「女性失格」だろうと自分でそう思います。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
