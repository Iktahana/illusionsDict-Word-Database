        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三、四年前までは、この家へ二、三度遊びに来たこともあり、こうした応接間の空気などにも、特別に感じ入りもしなかったのであるが、やや切端つまった就職者として来ているせいもあって、新子は何か不思議な圧迫を感じるのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "官公立と私立とから平等に採用して欲しいというような、先の先まで考えた就職者側の注文もあった。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は就職者氏名というところに瀬戸さんが出ていました。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿部義資だの、小林千代子だの、就職者来り、くたびれる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
