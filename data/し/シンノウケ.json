    "definitions": [
      {
        "index": 1,
        "gloss": "imperial prince's family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
