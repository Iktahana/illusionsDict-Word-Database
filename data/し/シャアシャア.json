        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　兄はしゃあしゃあとして、得意になっていたが、まだ女学校を出たばかしの花嫁は、婚礼の晩つんなに幸福そうに見えなかった。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てしゃあしゃあしていることだろう――と井深君は思った。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "この百日紅に油蝉がいっぱいたかって、朝っから晩までしゃあしゃあ鳴くので気が狂いかけました。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、しゃあしゃあと書けたであろう。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、相手の男だったが、仲人をいれず、自身でしゃあしゃあ出向いて来て、持子さんをいただけないかと言ったのである。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼になる気持で……などと云うたら口を縫いこむぞといいきかされていた美津子は、いけしゃあしゃあと、わてとあんたは元から許嫁やないのといった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "細々とした暮しだとうなずけるほどの椙のやつれ方だったが、そんな風にしゃあしゃあと出て行く後姿を見ればやはりもとの寺田屋の娘めいて、登勢はそんな法はないと追いついてお光を連れ戻す気がふとおくれてしまった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎の出た猿のようなこの老人は、どこへでもしゃあしゃあと押しだして往って、何人とでも顔馴染になりました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のしゃあしゃあながれる音もきこえました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やい、生けしゃあしゃあとした面をするな。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあげくに木村はしゃあしゃあとわたしを妻にしたいんですって、義一さん、男ってそれでいいものなんですか。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は何をそんなに事々しくたしなめられる事があるのだろうというような少ししゃあしゃあした無邪気な顔つきで、首をかしげながら夫人を見守った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし正井はしゃあしゃあとして平気なものだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "景が島の景色のいい話を女中から聞きながら私は何故だか広やかな浅瀬の中に大きい円い石が無数に散らばって、水がそれらの間をしゃあしゃあざあざあと流れ騒いでいる――そんな処を想像していた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はしゃあしゃあとして、付近にある他のアパートに住んでいたのであった。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生けしゃあしゃあとした面をしていても、どいつの腹が白いか黒いか、おれがもう睨んでいるのだ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、こいつ等、いけしゃあしゃあとした面をしていたって、どの鼠が白いか黒いか俺がもう睨んでいるんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちに比べると、世間の人はそれこそしゃあしゃあしたもんや。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥土のところへできたやつは、絞ればしゃあしゃあ水のように出ますが、水飴のように濃く固まってぽたりと落ちます。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんたは、よくもそんな値をつけてしゃあしゃあしていられますねえ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と君はしゃあしゃあ答える。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と君は、しゃあしゃあとして答える。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美妙はしゃあしゃあと答えて、「別荘行きも、もうお止めさ。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を汚されながら、しゃあしゃあとそのことを打ち明け、涙一滴こぼさないのですもの。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみると、しゃあしゃあと酒なんか飲んでいる。",
              "citation": {
                "source": "早春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし精根ここにつきて余儀なければしゃあしゃあとして悲鳴を唄う曲芸も演じます。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの時のしゃあしゃあとした態度はどうだ！",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
