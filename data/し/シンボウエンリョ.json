    "definitions": [
      {
        "index": 1,
        "gloss": "far sight and deep design",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
