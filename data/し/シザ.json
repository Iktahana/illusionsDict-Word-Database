    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vantage point",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間を塩で食うような彼等も、誇張して無気味がる処女のように、後しざりした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の縁などに立つて庭を見降すと、體を下に投げ出したくなるやうな衝動に襲はれて、はつとうしろにしざつたり、部屋の本箱の抽出にしまつてある五連發の短銃の事をひよいと、思ひ出すとそれを夢中で取り出してどかんと自分を打つてしまひさうな氣がして恐ろしくてたまらなかつたやうな經驗もやつぱりその當時の事だつた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松を火にたくゐろりのそばで　よるはよもやまはなしがはづむ　母が手ぎはのだいこんなます　これがゐなかのとしこしざかな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "としこしざがなだど。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "にらみ合う時間ばかり長くて、刀の先がちょっとさわったと思うと両方一度にぱっと後ろへ飛びしざってまたにらみ合う。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松を火にたくいろりのそばで　よるはよもやまはなしがはずむ　母が手ぎわのだいこんなます　これがいなかのとしこしざかな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物干しざおのようなものにひょろひょろ曲がった針金を張り渡したのは妙に「物ほしそう」な感じのするものだと思う。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたけはぎごちなさそうに人見から少し座をしざった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やにわに長い手を伸ばされて、はっと後しざりをする、娘の駒下駄、靴やら冷飯やら、つい目が疎いかして見分けも無い、退く端の褄を、ぐいと引いて、「御夢想のお灸であすソ、施行じゃいの。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "里心が着くかして、寂しく二人ばかり立った客が、あとしざりになって……やがて、はらはらと急いで散った。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と囃しざま、糸に繋ったなり一団になったと見ると、大な廂の、暗い中へ、ちょろりと入って隠れてしまった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とひょこひょこと日和下駄で駆出しざまに、門を飛び出ようとして、振返って、（やあ、皆も来てくれ。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、野ウサギや、家ウサギが、くしざしにされて、火の上でぐるぐるまわされていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼の前に重なり合った草の茎の隙間から見るテニスコートの白い一直線の上を、ソロソロと後しざりして来る薄茶色のセイラアパンツであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち加速度を以て、胸焼きこげるほどに海辺を恋い、足袋はだしで家を飛び出しざぶざぶ海中へ突入する。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しばし、お名あがり家ととのうたるのちは、御兄上様御姉上様、何条もってあしざまに申しましょうや。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も體裁を言ふには當らない、ぶちまけて言へば、馬鹿な、糸七は……狐狸とは言ふまい――あたりを海洋に變へた霧に魅まれさうに成つたのであらう、然うらしい……　で幽谷の蘭の如く、一人で聞いて居た、卷莨を、其處から引返しざまに流に棄てると、眞紅な莟が消えるやうに、水までは屆かず霧に吸はれたのを確と見た。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を悪しざまにののしったのは、誰であったか。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "求めもせぬに、私に、とめどなき告白したる十数人の男女、三つき経ちて、必ず私を悪しざまに、それも陰口、言いちらした。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子、』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうして半※を畳みながら、行儀よく膝に両の手を重ねて待ったお嬢さんに、顔へ当てるように、膝を伸しざまに差出した。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横笛だけは、お嬢さんを三人で包んで立った時、焦茶の中折帽を真俯向けに、爪皮の掛った朴歯の日和下駄を、かたかたと鳴らしざまに、その紋緞子の袴の長い裾を白足袋で緩く刎ねて、真中の位置をずれて、ツイと軒下を横に離れたが。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろんどろん、」　と、あとしざりに、「……帯だって出来るわ、この半※。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さても迷惑、』と仰有つたが、御手の錫杖をづいと上げて、トンと下ろしざまに歩行び出らるゝ……成程、御襟の唾掛めいた切が、ひらり／＼と揺れつゝ来らるゝ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言い返しざまにひょいと家の中へ飛び込むのだったが、その連中の中に魚屋の鉄ちゃんの顔がまじっていると安子はもう口も利けず、もじもじと赫くなり夏の宵の悩ましさがふと胸をしめつけるのだった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁の男が入口に立ち塞って、自分を見て笑いながら、じりじりとあとしざりをして、背中の藁を中へ押しこめているのである。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやと思つて、あとしざりをして屋根の上を見ますと、小さな一ぴきの小猫が、前後も考へないで冒険して、その高屋根の上までのぼつたものゝ、下りるには、足がゝりがないために、ミヤオミヤオと人のたすけをもとめてゐるらしいのです。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
