[
  {
    "uuid": "c830fd23-fa0a-5c3a-a54e-818e9cceaca6",
    "entry": "視座",
    "reading": {
      "primary": "しざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
