[
  {
    "uuid": "6485c42e-a5e0-5fd7-8171-0ce730aabcb1",
    "entry": "触手",
    "reading": {
      "primary": "しょくしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
