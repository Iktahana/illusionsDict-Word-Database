        "examples": {
          "standard": [
            {
              "text": "修院長は、修道院の精神的な指導者である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しく任命された修院長が、信徒たちに挨拶した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この修道院は、歴史的に多くの著名な修院長を輩出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "曰く、ベルトルト・ヴァルスタイン伯、フルダ公兼大修院長パッヘンハイム……　そこまで来ると、熊城は顔でも殴られたかのようにハッと身を引いた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
