    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's party (held in the beginning of the year, i.e. usually in January)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一体、天神様の境内で、恩を謝す心を決して以来、その機会がなかった処、翌年一月、伊予紋で、大学出の人の新年会があった。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は午後四時より向島の八百松に新年会ありとて未だ還らざるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸髷嫌い１・13（夕）　江戸堀の支部で開かれた愛国婦人会の新年会に、多くの夫人達は白襟紋服で出たが、そのなかに、たつた一人広岡浅子女史のみは洋装で済ましてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　何でもそれによると、Ｈの教師をしてゐる学校が昨日赤坂の或御茶屋で新年会を催したのださうである。",
              "citation": {
                "source": "東京小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生クラス会を催せば車夫も新年会忘年会を開く。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉館の新年会のこと「三田文学」に「谷崎潤一郎氏の作品」（？",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏も四五へん入れるドジョウ汁　戦争中、物資不足で口にはいるものなら按摩の笛でもよい、といっていた時代に、神田のタナゴ釣り新年会で、千葉県大和田へ行った。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田沼からバスで平戸橋付近を釣ったのだが、タナゴ釣り会といっても、新年会のことで、土地の大きな農家で酒やヤミの物が買えるというので、釣るよりもそのほうが目あてであった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "座を挙げて恋ほのめくや歌かるた明治三十九年一月六日　新年会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスクかけ仄かに彼の眉目かな一月二十九日　丸之内倶楽部新年会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おでかけかい」「えゝ、学校に忘年会と新年会の芝居の稽古があるのよ」「じゃア、そこまで一緒に行きましょう」「お園さんに悪くないの」　お園は又、大きな冴えた笑いをたてた。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年会の折、専務の名倉氏が僕の姓名を利用して洒落を言った。",
              "citation": {
                "source": "ロマンスと縁談",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日の晩は新年会と称して、おやしき内のものが集まる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「先生は新年会のお福引きをお考えになりましたか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のところは正月でもおもしろいことがちっともない」「新年会がおもしろかったございませんか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ帰り、新年会の打ち合せ、時節柄、夜おそく迄やる食べ物屋が無くて困る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから築地の瓢亭へ、座の新年会で行く、ジョニ・オカの黒をとっといて呉れた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十二日（金曜）　十一時半から芝三椽亭で清和婦人会の新年会、今年初めてのオザ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大辻が明日あたり新年会をやらうと言ふ、皆あまり進まぬが、結局、むかし家あたりへのすことゝなる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネ後、新年会、むかし家へ、川口・東を我々で招く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二回終り、すぐに山春の新年会へ顔出し、十円会費おさめてすぐ帰る、馬鹿な話。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時から丸の内会館で加藤家親類の新年会。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れて名古屋株式取引所の新年会で一席（100）。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "之がすむと八重垣クラブへ行って、一々会の新年会で挨拶代りにやらされる（20）、済むと京都へ向ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
