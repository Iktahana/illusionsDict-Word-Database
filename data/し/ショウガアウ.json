        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヴァン・デル・ヴェルドは、一体無口な男だったが、このブルウス・テイラアとは、性が合うとみえて、珍らしく饒舌だった。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういうものか、この土地は、なしに性が合うとみえるだ。",
              "citation": {
                "source": "金が出ずに、なしの産まれた話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんそれでかえって性が合うのかもしれなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――性が合うと言うものか、他人のような気がしない、お頼殿さえその気なら、この後は私の家へ引取って、娘どもの姉分になって貰おうと思っているよ」「旦那の御配偶は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも性が合うというのであろうか、直政はつねづねかれに目をかけていて、特にわが子直孝の守役に抜擢したくらいであった。",
              "citation": {
                "source": "青竹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
