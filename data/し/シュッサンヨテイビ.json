          "standard": [
            {
              "text": "出産予定日まであと一ヶ月になり、入院のための荷物を準備し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定期検診の結果、赤ちゃんの成長に合わせて出産予定日が数日修正された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出産予定日が近づくにつれ、期待と不安が入り混じった複雑な気持ちになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十月二十七日　〔巣鴨拘置所の顕治宛　駒込林町より（代筆　封書）〕　十月二十七日（今日はああちゃんの出産予定日なり）ですけれども幸い今のところは平穏無事で丸いお腹は納っているので、私達は二階で何日ぶりかのゆっくり手紙書きを始めました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十八日が咲枝さんの出産予定日でしたが、本人の予感では、十一月三日の夜らしいそうです、アナオソロシ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            }
