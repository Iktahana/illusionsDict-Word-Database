[
  {
    "uuid": "757fbc36-b9c6-5807-98b1-8477315eeff3",
    "entry": "主になる",
    "reading": {
      "primary": "しゅになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
