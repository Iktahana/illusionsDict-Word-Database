[
  {
    "uuid": "618e44fc-dec1-5010-8858-08917f3656ae",
    "entry": "歯髄",
    "reading": {
      "primary": "しずい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pulp (of a tooth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "歯が浮いて、酢ッぱい汁が歯髄にしみこむのをものともせずに、幾ツも、幾ツも、彼女はそれをむさぼり食った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはうそだが、しかしずいぶんおもしろい話だとおもう。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、可心一代は、ずッと川下へ庵を結んで、そこから、朝夕、堂に通って、かしずいて果てた、と言います。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれと一しょに館へ来い」　　　　　――――――――――――　関白師実の娘といったのは、仙洞にかしずいている養女で、実は妻の姪である。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての点に源氏の理想にする貴女らしさの備わった人であったから、源氏はたいせつにかしずいていた。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のほうは子供の数が少ないのだから、思いがけぬ所で発見した娘だとも世間へは言っておいて、貴公子たちが恋の対象にするほどにも私はかしずいてみせる」　源氏の言葉を聞いていて、右近は姫君の運がこうして開かれて行きそうであるとうれしかった。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいそうにかしずいてみせよう、まだ成っていない貴公子たちの懸想ぶりをたんと拝見しよう」　と源氏が言うと、「変な親心ね。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子がちゃんと倉地にかしずいてそこにいるのを全く無視したようなずうずうしい態度が、ひがんでしまった葉子の目には憎々しく映った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何宗であるにせよ、仏にかしずいている身で、生臭なんぞ用いるやつにろくなものはねえや、ひとっ走りいってしょっぴいてこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹山の家には古風な大きい雛段が飾られて、若い美しい姫が腰元どもと一緒にさびしくその雛にかしずいている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹山の家には古風な大きい雛段が飾られて、若い美しい姫が腰元どもと一所にさびしくその雛にかしずいている。",
              "citation": {
                "source": "島原の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしずいぶん日本語がうまいですね。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれに嬌えこむ気になって、「しかしずいぶん茶気のある人で、わたくしは偉いと思いますが？",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が後宮の競争に失敗する悲しい運命を見たかわりに、この宮を長い将来にかけて唯一の慰安にするまでも完全な幸福のある方にしたいと女御は大事にかしずいていた。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夫人の生んだ二、三人は皆相当な相手を選んで結婚をさせてしまった今は、自身の姫君のためによい人を選んで結婚をさせるだけでいいのであると思い、明け暮れ夫人は姫君を大事にかしずいていた。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人もの中で最も大切にかしずいている娘とだけ聞いていましたから、守の子だろうと信じてしまったのですよ。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今の平馬の言葉で聴けば、行方を晦ましたという当の娘は、極めて身分の高い人に、かしずいている女性だという――　三斎の娘の浪路こそ、公方に仕えて、大奥随一の寵をほしいままにしているということは、どこの誰でも知っている。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯母さん、あたしずいぶん骨を折って手に入れたのよ。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九　これより先、女興行師の元締お角さんは、お銀様にかしずいて鳴海の宿を先発して、熱田の宮に参詣を試みたところです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "物慣れた老女が一人かしずいて席を周旋し、老船頭が一人船をあずかって迫らない形をしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……この日頃まめまめしく、よう呉服かしずいてくれた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしずいぶん材料にお銭がかかるなア。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏世帯を苦にせず病夫にかしずいている世話場の呼吸だ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛込戸塚、千駄ヶ谷、新小川町、そのほか白秋はたいてい一軒の家を借り、ひとりのばあやに炊事をさせていたが、このばあやは二十年も白秋にかしずいていて、白秋もばあやにたよっていたようである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしずいぶん有名な語になったものだ。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "元ロマノフ帝室に仕えて、あの薄命に終った美しいお姫様にかしずいた、マルガレッタ牧野という、国籍を日本に持つ女です。",
              "citation": {
                "source": "呪の金剛石",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしずいている給仕たちは、ぬき足で動きまわっていた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、婦人たちが小屋のそばでかしずいている一人の訪客にあいさつするようにと、呼びよせられる。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "美容師はようやく満足の意を表すると同時に、こういう人間の流儀で、自分のかしずいた者に、卑屈なほど丁重に礼を言った。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婦人のそばにもまた、一人の店員が孜々としてかしずいている。",
              "citation": {
                "source": "神の剣",
                "author": "GLADIUS DEI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
