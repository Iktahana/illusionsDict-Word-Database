        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ショーファーより早く、後部座席の人間がおり、それを一瞥して、慶一は山崎と顔を見あわせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーファーが後部左のドアを開き、つばの大きな白い帽子がふわりとただよい出て、それを追うように長いヒールが突きだされた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか命じられたのか、ショーファーはいちど動きかけてとまり、二度三度とうなずき、急ぎ足になって反対側にむかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田、あれ」　ブルーのスーツケースをもって、親子のうしろに控えていたショーファーが、あ、すみません、と高志にあやまって、スーツケースをおろし、車のほうにひきかえした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーファーがもどり、高志に紙袋をさしだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーファーがドアを開け、紺のブレザーを着た令子がおりたった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
