          "literary": [
            {
              "text": "映画には、どこかに必ずしわ寄せがある。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "しわ寄せがなければ、劇ではなくてドキュメンタリーである。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうしわ寄せを突いてはいけないのだ。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評家は、屡々そういうしわ寄せを非難するが、ストーリー以前に逆らっては、話にならない。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            }
