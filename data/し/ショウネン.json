      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "野獣のやうな病熱さをもつた少年の日の情慾。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの影は、いぢらしくも恋を恋する少年の日の可憐な真情を訴へた彼の『抒情小曲集』であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには少年に特有なあの美しい感傷と、生娘のやうな純潔の気高さがあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の『愛の詩集』に於て友の語るものは、もはや少年の花やかな幻想ではなくして、荒廃したまことの人生と現実とに接触した、彼が最初の魂の驚きを語るものでなければならぬ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "（實際に言つて、詩人は精神の永遠的な少年である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　芥川君の文學は、そのあまりに文藝的であると共に、またあまりに少年的な、少年的であることに於て著るしい。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に芥川君の文學は、少年客氣の文學だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの日の印象ほど、芥川君の眼における少年らしさ、風貌における書生らしさを見たことがない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に彼はその病弱の體躯の中に、無限の精力に溢れた「少年客氣の勇」をもつてゐたのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の詩人宿命生涯を貫く萩原朔太郎　僕は少年の時、島崎藤村氏と薄田泣菫氏の詩を愛讀した。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏と泣菫氏とは、少年時代の僕にとつて共に同じやうに好きであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、――美少年だ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点高橋新吉は或は不良少年の心理に似てゐるのだが、彼の無意識的な善良さが人々の中に生きてゐるうちにさうなるのは当り前なのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古來歴史上の大科學者、例へばガリレオや、ワツトや、ニユートンや、エヂソンやが、その少年時代に於て、いかに夢想的な子供であり、いかにフアンタスチツクな童話の愛好者であつたかを、彼等の教育者等は知らないのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからして人々は、早くその少年時代に、空を飛翔する鳥人の夢や、自動的に走る車の夢やを忘れてしまつた。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白梅や誰が昔より垣の外　昔、恋多き少年の日に、白梅の咲く垣根の外で、誰れかが自分を待っているような感じがした。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の日に感じたものは、春の若き悩みであったところの「恋を恋する」思いであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波宜亭少年の日は物に感ぜしやわれは波宜亭の二階によりてかなしき情感の思ひにしづめり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日より、常にその河邊を逍遙し、その街路を行き、その小旗亭の庭に遊べり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は少年時代に黒岩涙香やコナン・ドイルの探偵小説を愛読し、やや長じて後は、主としてポオとドストイェフスキイを愛読したが、つまり僕の遺伝的な天性気質が、こうした作家たちの変質性に類似を見付けた為なのだろう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ではあちこちの翻訳物を引受けたり、少年雑誌の英文欄などを手伝って、どうかこうかはやっている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚釣幾度か釣り損ねてようやく得たる一尾に笑靨傾くる少年帰ってオッカサンに何をはなすか。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチの軸木を並べてする色々の西洋のトリックを当時の少年雑誌で読んではそれを実演して友達や甥などと冬の夜長を過ごしたものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ少年雑誌などというものの存在を知らなかった頃の冬夜の子供遊びにはよく「火渡し」「しりつぎ」をやったものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの樹の実の記憶には数限りもない少年時代の生活の思い出がつながっている。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時少年時黝い石に夏の日が照りつけ、庭の地面が、朱色に睡つてゐた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛い顔をしてらあ、ホラ、口ん中に汗が流れ込まあ」　彼は、暫く凭れにかかって、少年を観察していた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミドリちゃんのにいさんの敏夫くんは、しょうねんたんていだんいんなので、ミドリちゃんもそういうたんていみたいなことがすきなのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しょうねんたんていだんいんの敏夫くんが、ざんねんそうにいいました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
