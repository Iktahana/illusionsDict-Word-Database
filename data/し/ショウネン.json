[
  {
    "uuid": "9e6d2846-8951-5655-b62c-c5c0b1b8674f",
    "entry": "少年",
    "reading": {
      "primary": "しょうねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
