    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浪之助引戻して蹴倒しさんざんな目に会わす。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるるるん　おほしさんおほしさん　ぴかりぴりるるん　かしわはかんかの　　　かんからからららん　ふくろはのろづき　　　おっほほほほほほん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるゝゝん　おほしさんおほしさん　ぴかりぴりるゝん　かしははかんかの　　　かんからからゝゝん　ふくろはのろづき　　　おつほゝゝゝゝゝん。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいらは、まだおみこしさんを拝んでいないんだ。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「画家のたけしさんです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「紹介状はありませんがたけしさんは今はずいぶん偉いですよ。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸たずねますが、ひなげしさんたちのおすまいはどの辺ですかな。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お茶わかしさんが歌をうたいたくないのなら、それでもいいじゃありませんか。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに忠告しておくけど、あそこにいる、しっぽなしさんを信用しちゃいけないわよ。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日は、うちのほうの大掃除だったので、台所直しさんや、畳屋さんもはいっていて、お母さんも箪笥のものを整理して、そのときに、この風呂敷が出て来て、私がもらった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お茶わかしさんがうたわないというなら、かってにさせたらいいでしょう、おもての鳥かごには、小夜鳴鳥がいて、よくうたいます。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのるじるしさんは、以前雑誌に載せていた『るじにっき』をエキスパンドブックにまとめて、横丁に出品していました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こやつら何をしたのじゃ」「いいえなに、このおめかしさんの髪へ触ったとか触らないとか言ってね。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬしさんこそ、小芳さんとやらに岡惚れしんすなえ」「腰本黒鍬左衛門とはちと手筋が違うわい。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿七人（例の二人連れの猿まはしさんとまた泊り合せた）、その中の遍路夫婦は小さい子供を四人も連れてゐる、無智と野卑と焦燥とを憐れまずにはゐられない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菓子屋の「おきしさん」も美しい人であった。",
              "citation": {
                "source": "四条通附近",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのころは言葉もかけなかった令嬢たちも、次第にうち解けて、こんな冗談をきくたびにキャッキャッと笑って、「おもしろいせむしさん」だと評判し合った。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「考へてみなさいよ、――福ずしさんと遊びに行くからと云つて、うちの旦那に暇が貰へると思つて？",
              "citation": {
                "source": "一の酉",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天野さんの――化粧品問屋――×さんはおとなしく、金物問屋のおぬひちゃん、袋物問屋のおよしさんその他の人たちも醜いのはなかった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはもうほんとうのいのししさんなんだぜ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸芸の取締り兼、酌のとりかたを教える師匠番によばれたのが、吉原の廓からおよしさん（現今は某氏夫人である）と、品川から常磐津のおしょさんのおやすさんの二人。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな悪強そうな人も死んだのか、十六の年結婚したとしさんはどんな気持で一生をつれそったのかと思う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーラスはソプラノが呉光子さんと呉乙女さんで私より一級上、橘ヤスノさんが私の同級生、それに分教場にいた鈴木よしさんと志賀ちよさん。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だろうかと、あたしさんざん考えたあげく、お金のことらしいと思いました。",
              "citation": {
                "source": "千代次の驚き",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
