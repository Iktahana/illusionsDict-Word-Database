  {
    "uuid": "dd82314b-5703-5935-957f-d2b7fb61513c",
    "entry": "試鑽",
    "reading": {
      "primary": "しさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
