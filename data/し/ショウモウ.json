[
  {
    "uuid": "c0efb8f9-bd3d-5c6e-9df8-640d76b59e42",
    "entry": "消耗",
    "reading": {
      "primary": "しょうもう",
      "alternatives": [
        "しょうこう"
      ],
      "is_heteronym": false
    },
    "grammar": {
