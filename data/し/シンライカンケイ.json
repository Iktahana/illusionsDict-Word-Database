        "examples": {
          "standard": [
            {
              "text": "医師と患者の間には、何よりも信頼関係が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期的なビジネスを成功させるには、パートナーとの信頼関係が不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夫婦の信頼関係は、日々の小さなコミュニケーションで育まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「父」というのは、神が創造主であり、指導者であり、人格であることを、人間に対するいっそう個人的な親しみの信頼関係において示した名であり、かつこれによってエホバは民族的な律法のわくを全く脱して、民族・人種のいかんを問わず、すべての人間の神として拝されるに至ったのである。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信頼関係は持てる人なのです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
