[
  {
    "uuid": "593b5856-4f73-58dc-be8c-dc598af5164f",
    "entry": "進駐軍",
    "reading": {
      "primary": "しんちゅうぐん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
