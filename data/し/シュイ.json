[
  {
    "uuid": "4ca11fff-7915-58a5-9097-b86674cf9eba",
    "entry": "首位",
    "reading": {
      "primary": "しゅい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
