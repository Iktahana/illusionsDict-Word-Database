[
  {
    "uuid": "ce29877f-984b-5928-987d-cb4e415a62f6",
    "entry": "修繕",
    "reading": {
      "primary": "しゅうぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "repair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういうのはおそらくその後何かの機会に何遍となく同じ記憶の復習をし修繕を加えて来たために三十年後の今日まで保存されているのであろう。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の子供は、コムプレッサー、鍛冶場、変電所、見張り、修繕工場、などを見て歩いたが、その親たちは見当らなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな崖崩れで道路のこはれたあとがもう荒まし修繕が出来てゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな崖崩れで道路のこわれたあとがもう荒まし修繕が出来ていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わたし達、室内電線を修繕しに来ました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電線修繕の仕事が終りました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の蒔田という電気器具商の主人が来て修繕した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその修繕するところに附纏って、珍らしそうに見ているうちに、彼女にいくらかの電気の知識が摂り入れられた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三人は修繕中のサン・ドニの門を潜って町の光のなかに出た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局私はこの油の漏れる和製の文化的ランプをハンダ付けでもして修繕して、どうにか間に合わせて、それで我慢する外はなさそうである。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の強気な毛むじゃらの足は、縁日で買ったような両翼を修繕しては、飛行を継続する。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんなことを云うにつけても、おしかは、清三に学資がいるがために、家の修繕も出来ないのだということを腹に持っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日前靴を修繕にやったので古いゴツゴツの靴をはいていたがそれが邪魔で堪らない。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで時々故障が起っても、別に大した不便を感じないのであるが、それでもやはりその時々に修繕のために元買った百貨店へ持って行った。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが修繕する度に眼に見えて機械の感度が悪くなるのであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつか放送局でラジオ相談所として推薦した本郷の某ラジオ屋へ試みに修繕に出したら、今度は断然｜桁ちがいに感度を低下してしまって、もう拡声器では聞かれなくて、テレフォンでやっと聞こえるようになってしまった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理科の学問をしているのに、どうして自分でラジオ機械を修繕しないのかと聞かれることがある。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの修繕までは手が届きかねるという人は自分のみならず他にもおそらく多いであろうと思われる。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくもわれらは従来経験的事実の要求に応じて、物理学的概念の内容にたびたび改革あるいは修繕を施して来た。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画では電話局の故障修繕工夫が主人公になっている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "網は時々風にやぶれたりごろつきのかぶとむしにこはされたりしましたけれどもくもはすぐすうすう糸をはいて修繕しました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網は時々風にやぶれたりごろつきのかぶとむしにこわされたりしましたけれどもくもはすぐすうすう糸をはいて修繕しました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに私のニッケル側が壊れたから、これ幸いとその時計を持って上京して、おやじに新しいのを買ってくれといったら、おやじは仔細らしく私のニッケル側をゆすぶって見たあげくケロリとして、「使えるだけ修繕して使え」　と言って知り合いの時計屋を教えた。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械に狂いの生じたのを正作が見分し、修繕しているのらしい。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊を見ながら私は断水の不平よりはむしろ修繕工事を不眠不休で監督しているいわゆる責任のある当局の人たちの心持ちを想像して、これも気の毒でたまらないような気もした。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと買った店へ電話で掛け合ったら、取りには行かれないが持って来れば修繕してもいいという返事であった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "修繕師のほかには一人もなかったかもしれない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何年前に最後の修繕師がここに昇ったのだろう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その橋は短かったが修繕し立ての橋板はまだ生木の潤いを帯びていて音を含んでなつかしく響いた。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の午後、カラスたちは、カラス山の巣をしゅうぜんしましたが、そのあとで、すばらしい見つけものをしました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
