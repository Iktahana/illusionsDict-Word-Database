        "examples": {
          "standard": [
            {
              "text": "仕事の打ち合わせに遅れそうだったので、首都高に乗って一気に都心まで駆け抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "首都高の入り口は右車線にあることも多く、慣れていないドライバーにとっては合流が難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「夜の首都高をドライブすると、高層ビルの間を通り抜ける近未来的な景色が楽しめるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "新宿通りを麹町方向に進み、迎賓館前を通って首都高速に乗る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "首都高速を降り環七通りを進んで行く。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座通りを京橋に向けて左側の歩道を歩いていき、首都高にさしかかる少し手前だ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
