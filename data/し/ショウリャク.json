        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでこの改正暦のことをジュリアン暦と名づける。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから淳仁天皇の御代になると、西暦七六三年からこの大衍暦が唐同樣に我が朝廷にも採用されて、爾後約百年の間、この暦が日本の正暦と定められたのである。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月……」と題して七言律一首が続けられてゐる。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月……」と題して七言律一首が續けられてゐる。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月……」と題して七言律一首が続けられている。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月…」と題して七言律一首が續けられてゐる。",
              "citation": {
                "source": "山越しの彌陀",
                "author": "釈迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一条院の御時正暦四年五月廿一日　菅神に正一位左□臣を贈らる。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼道も、あの家は正暦年間より一度も火災に遭うたこともないめでたい家、住み古したれど、当座のご用に献じたいと申し立ておるとか。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
