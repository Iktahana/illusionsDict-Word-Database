          "standard": [
            {
              "text": "試合前、コーチの叱咤激励を受けて、選手たちの士気は最高潮に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君ならできるはずだ！」という上司の叱咤激励を胸に、プレゼンに臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時には厳しく叱咤激励してくれる友人の存在が、今の僕には何よりありがたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、時代に流されながらも愛情だけはたいせつに育てていくということを忘れない点で、ただやたらに叱咤激励する連中とは根本的にちがっているよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
