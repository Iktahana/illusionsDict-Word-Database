[
  {
    "uuid": "2403773f-cad3-5540-8e89-66481c75b8a9",
    "entry": "出社",
    "reading": {
      "primary": "しゅっしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going to work (e.g. in the morning)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大正何年であったか正月の三日に、国原がフロックコートで初出社をすると、左手の甲に仰山らしく繃帯をしている。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ当の芋倉長江画伯が、死人のような青い顔に宗匠頭巾、灰色の十徳という扮装で茫々然と出社して来た。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "○翌日出社した時は私の頭にもう某君の事は無かつた。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日出社されたしと短かく書いてあった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは毎日一度はかならず出社する以外に、東京にある親戚や先輩や友人をたずねて、平素の無沙汰ほどきをしなければならないので、働くと遊ぶの暇をみて諸方へ顔出しをすることも怠らなかった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつら時すぎゆきて隣室の時計二時うつ、いざ出社せむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日九時に出社すると、いきなり郵送用の帯封へ宛名を書かされた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時きっちりに出社すると、帳簿の整理をやらされた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間経ったある朝、豹一が出社して間もなく、白い縮のシャツの上へ薬剤師や医者の着る白い診療服のようなものを羽織った男が、自転車を押してはいって来て、柱時計を見上げ、「あ、五分遅刻したぞ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿でびっしょり汗をかきながら出社すると、社長は、「これは、これは」と、驚いた顔をして見せた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年一回昇給するその翌日は、必ず洋服を着変えて出社し、「おかげをもちまして質受け出来ました」と真夏にわざと冬服である。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旨編輯長に言うと、「いったい、誰に行かせたんや」「土門です」「土門君をここへ呼びなはれ」　しかし、土門はまだ出社していなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "入社してから半月経っていたのだが、全くの見習記者に過ぎぬ豹一は、仕事らしい仕事も与えられず、ただ意味もなく毎日出社しているだけのことだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の疲れですっかり寝すごしてしまった豹一が出社したのは、もう十一時近かった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが前のと違つてどうもその社内の空氣が面白くなく、前社同樣二十五圓の月給をば二箇月分か貰つたが出社して事務をとつたのは僅々五六日であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "貧乏首尾無し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは蚊帳のなかで碁を囲んで夜ふかしをした為に、田島の奥さんに起されたのは午前十時、田島さんは予の寝ているうちに出社したという。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には薄々感づいて沼南の口占を引いて見たものもあったが、その日になっても何とも沙汰がないので、一日社務に服して家へ帰ると、留守宅に社は解散したから明日から出社に及ばないという葉書が届いているんだから呆気に取られてしまった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても会社へ出て、働く気にもなれなかったが、家にいて京子に監視されながら、悶々としているよりも、まだ会社の仕事をしている方が気がまぎれそうな気がしたので、いつもよりは三十分も遅れて出社した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川が出社したのを見ると庶務課長の宮田が、タイプライターで打った書類を持って、村川の机に来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫は夏の終であったが、彼は、初て出社すると云うのに、白地の木綿絣を着て居るに過ぎなかった。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず毎日出社すべき義務さえも強いようとはしない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人とも夜勤の番だったので、夕方の五時に出社して、夜中の十一時に社をひきあげることになっていた。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも、出社の時刻はおくれても、退社の時刻は一分間だっておまけをしないなまけ者だった。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日も出社すると、渡辺君はわたしを呼んで、きょうも芝居の招待があるから行きたまえと言った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くる日もつづけて出社すると、きょうは何処からも招待状が来ていなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は新聞社に出勤しているので、わたしは出社の前に築地の家を訪問していたが、午前中は居士も執筆に忙がしかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらに対して俄かに一種の反感をもつようになったわたしは、あくる日出社すると直ぐに劇評を書いた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
