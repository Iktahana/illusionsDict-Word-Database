    "definitions": [
      {
        "index": 1,
        "gloss": "leaving the (repair) dock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何んでも荷物の積込みが遅れたとかって船主の督促で、昨晩日が暮れてから修繕が終ると、その儘大急ぎで小蒸汽に曳航されて出渠しました。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで出渠の作業が始まる。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の方に草苅籠を背負つて鎌を持つた子供が一人、秋の野を行く繪があつて、下には四句｜何故生荊棘佳人意漸疎久因重輪下｜黄金未出渠　斯う刷つてある。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の方に草刈籠を背負って鎌を持った子供が一人、秋の野を行く絵があって、下には四句｜何故生荊棘佳人意漸疎久因重輪下｜黄金未出渠　こう刷ってある。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　職長は、時計を示しながら、「三時四十分に出渠できないと、一日延びますが」「それは、いかんです」「会社こそ困ります。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
