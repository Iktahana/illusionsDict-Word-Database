  {
    "uuid": "875b0a32-f25b-5251-af79-5ee50a775a3a",
    "entry": "士業",
    "reading": {
      "primary": "しぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "professional occupation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、ワシレンコは一種の志士業者で、右翼団体の天竜会が養っているそうだが、ひどい結核患者で見る影もないよ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三六　女子の弁護士　昔ローマでは、女子が弁護士業を営むのを公許したことがあって、ホルテンシア(Hortensia)、アマシア(Amasia)などという錚々たる者もあったとか。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論法をもって推すならば、男子にも弁護士業を禁ずることにせねばなるまい。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "三六　女子の弁護士　昔ローマでは、女子が弁護士業を営むのを公許したことがあって、ホルテンシア（Hortensia）、アマシア（Amasia）などという錚々たる者もあったとか。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
