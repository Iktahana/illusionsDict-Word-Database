    "definitions": [
      {
        "index": 1,
        "gloss": "true courage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何が故に畏るゝ、曰く、国民の元気充溢し、百般の業の上に其真勇を睹ればなり。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅舎君は真勇の人であると思ふ。",
              "citation": {
                "source": "川端茅舎句集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "真勇は必ず微笑をもって事を断ずる。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
