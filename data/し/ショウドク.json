[
  {
    "uuid": "58b6472c-8646-58f8-9e6a-2caf5b7e86a1",
    "entry": "消毒",
    "reading": {
      "primary": "しょうどく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
