      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disinfection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アルコールで消毒はされるかもしれないがあまり気持の好いものではない。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の如く消毒衣に服を着かえて。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は遂に一口を試むるの勇気もなかった十四日　暖かであるから出産牛のあと消毒を行わせた。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月十一日『東京朝日新聞』）　　　　　　　　　十七　　　　　　船内の消毒　船中で鼠を駆り、また消毒をするために亜硫酸瓦斯を用うる事があるが、その効験に関する詳細な調査の結果に拠れば、鼠や害虫の類はわずかに〇・五プロセントの亜硫酸を含む空気で二時間も燻せば絶滅する事が出来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月十八日『東京朝日新聞』）　　　　　　　　　八十　　　　　　水の消毒　空気中に電気の火花を通ずる時一種の臭気を帯びたるいわゆるオゾン瓦斯が出来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この性質を利用して飲料水等の殺菌消毒をする法が近年欧洲諸国で行われている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法で消毒すればどんなバクテリアでも残らず死んでしまう、そして蒸餾水などとはちがって水の固有の味が少しも変らぬという利益がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、消毒藥の何處となく漂ふ病室の中はお前の呻き聲に靜寂が破られるだけだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術前の體の消毒の爲めに運搬車が來て、一先づお前を消毒室へ運び去つて行つた時、急に呻き聲の消えた靜かな病室の中に、私は兄とお前の母と顏を見合せてぢつと押し默つてしまつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのままお前の身を案じるやうに消毒室の方へ出て行つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『消毒が濟んだら直ぐに取り掛かるよ‥‥‥』と水島は云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほんとに大丈夫だらうね‥‥‥』と、消毒著に著換へた私が其處に這入つて手術臺に面した窓際に立つた時、メスの刄を調べてゐた水島はかちりとそれを硝子臺の上に置いて、また低い聲でかう私に耳打ちした。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日｜実習が済んでから農舎の前に立ってグラジオラスの球根の旱してあるのを見ていたら武田先生も鶏小屋の消毒だか済んで硫黄華をずぼんへいっぱいつけて来られた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ならばフォルマリンか何かで消毒するだろうが、あのころそういう衛生上の注意が行き届いていたかどうか疑わしい。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大丈夫よ――かみゆひさんは、きれい好で、それは消毒が入つて居るんですから。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同斉しく愕然として、医学士の面を瞻るとき、他の一人の看護婦は少しく震えながら、消毒したるメスを取りてこれを高峰に渡したり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を大きく振って、「印度洋の特有な悪性の瘧らしい」22　忽ち船全体に大袈裟な消毒が始まる。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐ツてゐても消毒室の煙突だけは見える。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜柑の消毒や、堆肥小舎の積みかえなぞもそのままにしておいて下さい。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様のオヤジのだけれども消毒してあるから大丈夫だ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、その電話機、すぐ消毒したほうがいいぜ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら数日の後に其の接眼の縫目が化膿した為めに――恐らく手術の時に消毒が不完全だったのだろうと云う説が多数を占めている――彼女は再び盲目になって了ったそうである。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから湖のもくもくから遥々採って来た柳のひげ根の消毒したものを大事そうに縄に挟んで沈めた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は膝頭に突きささっている鉛の弾を簡単にピンセットで撮み出して、小さい傷口を消毒し繃帯した。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病者は消毒藥を盛りたる壺中に喀痰するも、路傍に喀痰するも、其の自體に關しては何等の差を生ぜずと雖も、社會の此が爲に受くる差は決して少くは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この緑の風呂敷を、電燈を覆うのに使用したわけは、けれども、その不潔の風呂敷の黴菌を、電球の熱でもって消毒しよう、そうして消毒してから、ながくわが家のものとして使用しようなどの下心からではない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどいのになると一日に五六度オキシフルか、昇汞水で手を消毒しないと、落付いて仕事が出来ぬというようなのがある。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから　ベッドは　かんぜんしょうどく、　あんかと　ゆたんぽで　あたため　かわかすのです。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
