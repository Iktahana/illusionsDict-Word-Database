    "definitions": [
      {
        "index": 1,
        "gloss": "I can't die and leave things this way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
