    "definitions": [
      {
        "index": 1,
        "gloss": "in a drenched manner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから新吉の傍まで来るとちょいと顔を覗いて、――おまえ西班牙人か、しっぽりとやんな。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しっぽりと頼みますぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "意気な殿御にしっぽりと。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、この雨じゃねえか、しっぽりぬれるには場所が違わあ、手間ア取らせねえで、はっきりいいなよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "待っているからね、ゆっくり急いでおいでなせえよ」　花のふぶきをひらひら浴びて、小降りの雨にしっぽりぬれて、花びら散り敷く道を山下めがけていっさん走りでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃな、そなたとて二人して、ふた夜三夜しっぽりと参籠致しますかな」「いいえ、そんなこと、――わたしあの、知りませぬ」　くねりと初い初いしげに身をくねらして、パッと首筋迄も赤らめたあたり、三十年増が化けたものなら正に満点。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっぽり語り合うているまに、舟めが岩淵まで連れてくれようぞ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃ、奥州、いっそ成田屋を撒いてどこぞでしっぽり濡れてみるか」「お口さきばっかり……。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "売られた喧嘩でも喧嘩のあとはまた、しっぽりとしていいもんじゃ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いお馬は、主かいな今宵帰して、いつの日か濡れにくるかや、しっぽりと抱いて、あかした移り香のさめて、果敢なや、肌寒の朝の廓の霜景色霜にまごうか白い馬「とくらあ――あちちちち」　一人の若い衆が、湯の中から、飛上った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵も、雪に、しっぽりと、卵酒でもこしらえて六つ下りに戸を閉めて二人の交す、四つの袖、「ようよう、俺らあ、酔ったよ。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭が「さ、あちらで、旦那、もう、一踊、ここは、貸切りでござりますゆえ」「おた、おた、おた、逢うたその夜は、しっぽりと、のう、番公」　庄吉は、いきなり、番頭の首をかかえて、頬をなめた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "家政婦の小林と芝山は、その頃は小林の部屋でしっぽりよろしくやっていたので、主人を手にかけるどころじゃなかった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "※露にもぬれてしっぽりと、伏猪の床の菊がさね……　彼は悠々と唄いつづけた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今夜あたりあの二人め、ほんとにしっぽり濡れるかもしれない。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、糸の調子を下げまして、「では、お稽古いたしましょう」　と、三味線を取り上げ、※春雨に、しっぽり濡れる、鶯の……。",
              "citation": {
                "source": "両面競牡丹",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍には盗んでゆかれそうな街灯がポツンと立っていて、しっぽり濡れたアスファルトの舗道に、黄色い灯影を落としていた。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの変りやすい空模様思いがけない雨なるものは昔の小説に出て来る才子佳人が割なき契を結ぶよすがとなり、また今の世にも芝居のハネから急に降出す雨を幸いそのまま人目をつつむ幌の中、しっぽり何処ぞで濡れの場を演ずるものまたなきにしもあるまい。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっこは一晩、しっぽりと濡れて行ったか」「恐れ入りやした。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、この会体の知れない恐怖感に、しっぽり全身を漬けて、それをじぶんだけのものとして酔い痴れていたい気もちもあった。",
              "citation": {
                "source": "あの顔",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに向島の自分の寮へ運ばせておいて、あとから行ってしっぽり楽しんでやろう。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝繁き山桜の葉も花も、深い空から落ちたままなる雨の塊まりを、しっぽりと宿していたが、この時わたる風に足をすくわれて、いたたまれずに、仮りの住居を、さらさらと転げ落ちる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれのは、長々しっぽりよ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　ドードーめぐりで長々しっぽり　なんともけったいな絵づらのご一行がほとりにお集まり――羽を引きずった鳥さんたちに、毛がぴたーとなったむくじゃらたち、みんなずぶぬれで気持ち悪くていやな気分。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
