        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "坂の方から門内へ流れる秋のつめたい雨水は、傾斜にしたがって犬小舎の底をも洗い、敷き藁をじっとりぬらしている。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏が黄色い敷き藁を狂気のようにかき回していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "褪せた匂いのする牛のそばに敷き藁の中に寝ころんで、クリストフはパンをかじった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、かわいそうなことには、しきわらの上に、ポトポトと血のしたたったあとが残っているのです。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――徒歩立ちの面々はすぐ新しきわらじをは穿け。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
