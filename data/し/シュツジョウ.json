      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "participation (in a tournament, match, race, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっとも、チャンピオン・テオドラが最近、オドトリアムのハイ・アライに不出場も或は、もしかすると。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、こういうロシア映画でいつもおもしろいと思うのは出場人物のタイプの豊富さであるが、これは他の欧州諸国では得られない天然の制約によるものであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷窪の家には、湧き水の出場所が少し変ったというので棕梠縄の繃帯をした竹樋で池の水の遣り繰りをしてあった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの十一月に、シャモの大試合があって、その試合に全部出場させるつもりで、ただいま訓練中なんだが、ぶざまな負けかたをしたやつだけをひねりつぶして食うつもりだ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又野は皆から勧められて渋々角力に出場したが、懸賞附の五人抜にはどうしても出なかったので、賞金は柔道の出来る構内機関手の手に落ちた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "拡声機の声「女子青年団の行進は終りました、次は女子職員の百｜米徒歩競争であります、出場の先生はすぐ御用意下さい」清子、キッと顔を上げる。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物市場の出場時刻が切れるので、爺はうっかりしていることができなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェセックス賞杯　出場預け金一頭五〇ソヴリン（欠場時半額没収）、一着副賞一〇〇〇ソヴリン、四歳・五歳馬限定。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あるイカサマ師の手に落ちていたのを見つけ出し、勝手ながら連れ戻したままの姿で出場させた次第です。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝統あるサッカー部が全国大会への出場を果たすと、当初は彼らの勝利を讃える原稿が載りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は猶竊かに馬の跡を慕うて舟の出場に逐ひすがる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中にエンヂンを取り付けて競技会へ出場させて見ようと考へてゐる。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ年の秋、Ｔ中学と対校マラソンが催された時、二人は選手の任を帯びて出場した。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後の事情から考えて見てもこの疑問の渡欧費は全部が本屋から調達したのでなくとも、後暗い金の出場が別にあったとは思われない。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼自ら紅軍に大将として出場したのである。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、紅軍の大将たる忠直卿は、自ら三間柄の大身の槍をりゅうりゅうと扱いて、勇気凜然と出場した。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この楯は、つい先頃村の酒場で、バツカスの灌奠祭を行ふた時の余興の仮装舞踏会に、私達三人はスパルタの兵士に身をやつして出場したのであつたが、紋章の代りに私が花文字をもつて書き誌したボール紙の楯であつた。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "音頭大会の日取は未だ決らないが、出場者の多くは面をかむらうといふことになつて、日々に註文が絶えなかつた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村の競馬といふのは主に、その馬の持主が騎手になつて出場するといふ――奇妙な風習であつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重や百合子も、嘗ては晴れのレースに出場した経験を有つ身であつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　武一がラツキイを駆つて、馬場を廻つてゐるところに滝本達が来て――此方も三人のカタリーナを出場させて選手権を争つてやらうではないか、無論三人とも勇んで承諾したから――といふことを告げると、「左う決まれば――」　と武一は雀踊りして叫んだ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「来年の春は、ロシナンテの騎手になつて懸賞競馬に出場して見ようか知ら……」　私は、急行の三等列車に乗つてゐた。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "音頭大会の日取はまだ決らないが、出場者の多くは面をかむろうということになって、日々に註文が絶えなかった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中にエンヂンを取り付けて競技會へ出場させて見ようと考へてゐる。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "競技に出場する程の凧になると一つの胴片の直径が五尺近くもあつたに相違ない、一つの胴片を一人の男が捧げるに充分だつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾等万一今回の試合に敗れたるあかつきは翌年度の出場権をコロンビア大学に譲渡の止むなき絶壁に瀕せるなり。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな間にも、もはや彼の出場を待ち構へた観客席の方からは、ヘンリー、ヘンリーと呼びあげる声が次第に物々しかつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫と白のユニフォムをそろへた「Ｗ」、海老茶と黄の「Ｐ」、そして緑と真紅の「Ｈ」大学の選手団は、夫々の出場口から、ブラス・バンドを先頭に、国旗席の前に整列して、大統領の握手を待つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジャッキー、俺達は二回戦に出場するといふところなのに、そんな亢奮に炎えてゐる暇はないよ。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの大学生であつた先代が、これを着て仮装行列に出場したところの写真を私は見たことがある。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
