[
  {
    "uuid": "ae264998-b2b3-5531-a42d-448b37d93f7e",
    "entry": "出場",
    "reading": {
      "primary": "しゅつじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
