    "definitions": [
      {
        "index": 1,
        "gloss": "assumption (of office)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "就任早々、一週を五日として、六日目毎に休日を與へ、授業も毎日午前中だけにしたい、それゆゑに生徒が怠けるとは思はれない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時レーリーからマクスウェルに送った手紙を見ると、ウィリアム・タムソンは決定的に辞退したから、是非ともマクスウェルが就任してくれるようにと勧誘している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう環境の下にレーリーは遂に就任を承諾した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクスウェル付きの demonstrator が辞任したあとへグレーズブルックとショー（R. T. Glazebrook & W. N. Shaw）が就任した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "就任当時は従来やりかけていた「水のジェットに対する電気の作用」などをやっていたが、そのうちに彼の頭の中では大規模の仕事の計画が熟しつつあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "就任式の仰々しい行列は彼にいささか滑稽に思われたようであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーが公衆の面前に現われた最後は心霊学界の会長就任演説（一九一九）をした時であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が長崎の県知事をしていたときに、招かれて、こちらの区長に就任したのでございますが、それは、ちょうど私が十二の夏のことで、母も、その頃は存命中でありました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英邁勇敢なるルーズヴエルト氏が大統領に就任せし時以来、一部国民の精神は著しく其感化を受けしものゝ如く、表面に黄金を崇拝する事に変りはなけれど、其精神に於ては英雄崇拝を以て本義と為し或者は尚武練胆の気風を皷吹し、或者は米国魂に加ふるに日本魂の精萃をすら吸収し伝播せんと企てつゝあるが如し。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長就任式の行列が新市長と官飾を連れ忘れただけだ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の紹介の辞についで其の先生が壇に上り、就任の挨拶をした。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしは、将軍自身が死一等を減ずることなどがあったが、越前が就任してからは、そんな事は一度もなかった。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大学を出て就任したばかりであった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろこの新百合ケ丘というところ、この地に支店を持つ某銀行幹部によれば「駅から二キロ圏内で年収数千万円の高額所得者が一万人を下らないのでは」という土地柄で、就任当時はこの幹部、数億円単位の預金がボンボン入ってくるものだから目を回したという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎院就任の初めの儀式は古くから決まった神事の一つで簡単に行なわれる時もあるが、今度はきわめて派手なふうに行なわれるらしい。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて農民文学懇話会員作家諸君は、一般的意味に於ける農民小説を書くよりも、近く産組中央会々頭に就任すると噂される有馬氏のために産組小説を執筆する機縁を今後恵まれるだらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳列換えは前総長時代からの予ての計画で、鴎外の発案ではなかったともいうし、刮目すべきほどの入換えでもなかったが、左に右く鴎外が就任すると即時に断行された。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外は各国博物館の業績に深く潜思して、就任後一、二回落合った偶然の咄のついでにも抱負の一端を洩らしていた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等官の教授を栄としたわけではないが、露語科の主任たる恩師古川の推挙を満足して喜んで就任した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い旧語学校の同窓の川島｜浪速がその頃警務学堂監督として北京に在任して声望隆々日の出の勢いであったので、久しぶりで訪問して旧情を煖めかたがた志望を打明けて相談したところが、一夕の歓談が忽ち肝胆相照らして終に川島の配下に学堂の提調に就任する事となった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭は生中文名が高く在留日本人間にも聞えていたので、就任の風説あるや学堂の面々は皆小説家の提調を迎うるを喜ばなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大道良太氏東京電気局長に就任と共に市長永田秀次郎氏の辞表提出云々」　と大みだしが付いて、永田市長の談が掲載してある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（某氏就任の辞）「立毛差押」「立入禁止」「土地返還請求」「過酷な小作料」――身動きも出来なように縛りつけられている内地の百姓が、これ等に見向きしないでいることが出来るだろうか。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを一緒にすると、18751909　 8　42──3834　次ぎに仏蘭西大統領の誕生が一八六〇年、就任が一九一三年、治政が四年、年齢が五七歳。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを一緒にすると、18601913　 4　57──3834　次ぎに米国の大統領ウヰルソン氏の誕生が一八五八年、就任が一九一三年、治政が四年、年齢が五九歳。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから井口氏のあとへ秋山好古氏が軍司令官として就任して来た時には、副官はほつとした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫煙禁止　グラントと言へば、南北戦争の将軍として、また十八代目の米国大統領として名高い人だが、この人が大統領に就任してから当分の間、田舎の自宅からワシントンへ汽車で通つてゐたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "大モルトケが参謀総長就任の時（一八五七年心得、一八五八年総長）はなお陸軍大臣の隷下に在って勢力極めて微々たるものであった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏なばかりに師範の五年間を屈辱の中に過し、それをやっと「向学心」と「学問の光明」のために忍従していよいよ教師となった彼は、「希望と理想と満足とがひとりでに胸をしめ上げて来る」という状態で就任する。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "広田元首相の入閣、馬場元蔵相の入閣と企画庁長官就任交渉、平生※三郎氏への入閣交渉、其の他の極めて皮相な現象だけを見ても、之が林内閣の広田内閣による修正という相貌を呈していることは否定出来ない。",
              "citation": {
                "source": "近衛内閣の常識性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
