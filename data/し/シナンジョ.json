        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "停留所のうしろは柔術指南所だった。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔術指南所はもう寝しずまっていた。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Padua の武藝指南所で遊戲に供する力士を奴隷の中から養成してゐたのが一揆の源になつて、智略ある Spartakus を首領に戴いたのである。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢雄は高槻の学校の近くにある将棋指南所へ毎日通つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝京阪電車を降りると学校へ行く足を指南所へ向け、朝寝の松井三段を閉口させた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢雄は進級試験の日にも指南所へ出掛け、落第した。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "左京流小太刀ならびに山住流含み針指南所とふた道かけたこの看板がすさまじいじゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "書道指南所がそうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "門柱に掲げられた表札の文字は年月の雨風に洗はれて既にもう道往く人の眼には認められなかつたが、近視眼者のやうに好く／＼顔を近づけて験べると文字だけが円味を湛えて浮びあがつてゐる墨痕に「藤龍軒天狗流兵術指南所」と読まれるのであつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、町家の子どもは町の師匠に通うのが普通ですが、下町と違って山の手には町の師匠が少いという事情もあり、たといその師匠があっても、御屋敷へ稽古に通わせる方が行儀がよくなると云って、わざ／＼武家の指南所へ通わせる親達もある。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私立の二校は江戸時代の手習指南所から明治時代の小学校に変ったものであるから、在来の関係上、商人や職人の子弟は此処に通うものが多かった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何氣なく欄干に身を倚せると、恰度饂飩屋の座敷の向ふに、謠曲指南所の一室が突出てゐると見えて、川添のあけ放した軒に簾をかけた中で、ひとくさりづゝ男の聲について、聲量の極めて乏しい女の聲で熊野を稽古してゐるのであつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道指南所というよりも、倶楽部と云った方がよさそうである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それよか、善光寺の境内に元祖｜藤八拳指南所という看板が懸っていたには驚ろいたね、長さん」「這入って一つ遣って来やしないか」「だって束修が要るんだからね、君」　こんな談話を聞いていると、健三も何時か昔の我に帰ったような心持になった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、どこでそんな結構なことを教はつて來たんだ」「近所へ越して來たんですよ、――その親孝行とお行儀の先生が」「親孝行指南所と言つた看板でも出したのか」「そんなものは出しやしません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
