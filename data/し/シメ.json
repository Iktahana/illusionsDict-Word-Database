    "definitions": [
      {
        "index": 1,
        "gloss": "tying up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黒のサージの背広を着て、テカテカに光るネクタイを締めてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "種崎の渡しの方には、茶船の旗が二つ見えて、池川の雨戸は空しく締められてこれも悲しい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨の中を漂ひながらいつだか消えてなくなつた、あの乳白の※嚢たち……今や黒い冬の夜をこめどしやぶりの雨が降つてゐて、わが母上の帯締めも雨水に流れ、潰れてしまひ、人の情けのかずかずも竟に蜜柑の色のみだつた？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前には、雁木の凹みのように、小さな峰が分れて、そこから日本アルプスの禿げた頭が、ぐいと出ている、雪の線が二筋三筋ほど、芒に白い斑が入ったように、細く刻まれて、荒ららかな膚に、美しい白紐を引き締めている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入っては、私は虫が嫌いなので、障子を締め切ってしまうと、あっちでも、こっちでも障子の外で、カサカサカリカリと忍び音がする、嘴や鬚で、プツリと穴を明けて、中を覗き込んで、呪っているのではあるまいかと、神経が苛々する。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五合目では、実際人の気も変る、誰もわらじの緒を引き締める。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻かれた奴あ、ギュッと巻き締められて、息の根を止められちまわあな。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔や、帯の締め工合で、そいつが何であるかを見て取った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気はガットで締められていたため、数年前と些も違わないで溜っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「穴ん中にゃいないや、捲上小屋にいるかも知れないよ」　小林の子が、小さな心臓を何物とも知れぬ不安に締めつけられながら言った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までも、嫌悪感と云ふものは幾度か、殆んど数へ切れない位に私の首を締めつけた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "後れ走せに馳けつけた巴里の巡査が二人を軽く押し込んで扉を締める。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその時までも、肌に抱き締めあたためていた子どもを、始めて蒲団の上へはなした。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすっかり戸口を締め切って蠅を殺してしまってから仕事にかかる必要があったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "辺りを見廻し雪枝の肩に手を掛けて、Ｔ「御助勢致す　その代り……」　と言ってギュッと雪枝を抱き締めんとする。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の戸を締め、モデルを見てたゆたう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩方に窓掛を締めてやれば、その人のためには夜になり、午前に窓の鎧戸を明けてやれば、その人のためには朝になるでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方今に己達のゐるのを知らずに、寺院の戸を締めるだらう。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人は這入って戸を締めた。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心して戸口を出て跡を締めた。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この場合は窪んだ腹に緊く締めつけてある帯の間に両手を無理にさし込み、体は前のめりのまま首だけ仰のいて「お母さあん」　と呼ぶ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭石の根締めになっていたやしおの躑躅が石を運び去られたあとの穴の側に半面、黝く枯れて火のあおりのあとを残しながら、半面に白い花をつけている。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業というものは片っぽうで先走った思い付きを引締めて、片っぽうはひとところへ噛り付きたがる不精な考えを時勢に遅れないように掻き立てて行く。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意の闖入者と花子とが緊と抱き締めて、ものも云わずに黒い地面にうずくまったからである。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "リー・シー・ツワンは米良を抱き締めた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い首巻きを締めるように、肥満した男の太い呼吸がばったりやむと、人口的な都会の性格が夥しく牀にふれた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋モスの着物に、紅帯を締めて、さげ髪に紅色のリボンを結んでいるのを見て、最初は一日恋愛の女学生かと思ったのです。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから中座の筋むかい、雁治郎飴の銀杏返しに結った娘さんから、一｜鑵、ゆいわたを締めつけるように買ってきた包のなかから、古典の都市がちらちら介在する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台から跳ねあがる音がして、黒いスカートのもとから素足のままで、フランのワイシャツに汚れたネクタイを締めながらスマ子女史は英介氏の部屋にやってきて、ストーブのまえでうずくまりながら、――お仕事できたらしいわねえ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族旅行と木箱との過剰は最早、世界をして理知にて笑はしめ、感情にて判断せしむるなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
