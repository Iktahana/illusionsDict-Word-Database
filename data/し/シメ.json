  {
    "uuid": "b4c58afd-ca1b-5b24-a2b0-43495e216e19",
    "entry": "シメ",
    "reading": {
      "primary": "シメ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hawfinch (Coccothraustes coccothraustes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、せんだつて私のところから借りて行つたシメノンの探偵小説を風呂敷から出して、「うまいですね。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、シメノンたらいふひと。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横腹押さえて三次シメタと思った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人兵士諸君　日本帝国主義ブルジョアジーハ、諸君ヲシテ、銃ヲ携エ砲ヲ持チ、急速ニ山東ノ地ニ来ラシメタ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那ノ労働者農民ノ国民革命運動ヲ、血ヲ以テ窒息セシメタ各国ノ帝国主義ハ、干渉カラ土地掠奪ニ移ロウトシテイル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本帝国主義ハ、真先ニ掠奪スルタメニ有利ナル戦略的状勢ヲ利用シテ、諸君ヲコノ地ヘ来ラシメタ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太ッタ大資本家共ハ、鈴文ヤ松駒ノ如キ階級的裏切者ヲ買収シ、諸君カラノ搾取ヲマスマスヤサシクシ、諸君ノ妻ヤ子ヲ、飢ニヒンセシメ、諸君ヲモ絞殺スル反動ノ城塞ヲ固クスルモノデアル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍、独裁官田中ハ、諸君ヲ山東ニマデヨコサシメタル田中ハ諸君ノ階級ノ最悪ノ敵デアルコトヲ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竿を手にして、一心に魚のシメ込を候った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私たちが持っていたものは、一本のエンピツと、ナイフと、一冊のノートブックと、一個のムシメガネと、水を入れた三本のビール瓶と、小さな新約聖書が一冊と……それだけでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、そんなものを集めて来ると、ムシメガネで、天日を枯れ草に取って、流れ木に燃やしつけて、焼いて喰べました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人とも、聖書を、神様とも、お父様とも、お母様とも、先生とも思って、ムシメガネや、ビール瓶よりもズット大切にして、岩の穴の一番高い棚の上に上げておきました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ五五・四デシメートルとあるのを換算するとまさに一丈八尺強、恐ろしく長いものである。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プットバリーの講師にレヴェレンド・シメオン・ピジョンと云う人があった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　シツカリト　カナヅチヲ　ニギリシメテ、コウババカリノ　マチヘ　マツスグ　アルイテ　ユキマシタ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲で一寸話が大戻りをするが、私も十五六歳の頃は、漢書や小説などを読んで文学というものを面白く感じ、自分もやって見ようという気がしたので、それを亡くなった兄に話して見ると、兄は文学は職業にゃならない、アッコンプリッシメントに過ぎないものだと云って、寧ろ私を叱った。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はジョルジュ・シメノンという人の探偵小説を読みはじめた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今日のお昼は小海老を喰べに行きますの、オンフルールの、サン・シメオンへ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イベットは老紳士との会話で小田島に知らせるランデヴウの場所（サン・シメオン）を聞かせた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レストラン、サン・シメオンの野天のテーブルで小海老を小田島に剥がさせ乍ら、イベットは長い睫を昼の光線に煙らせて、セーヌの河口を眺めて居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンリ・シメレの監督で、仕事は大いに捗っているようだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、うちのヘンリ・シメレ君は斯うした彼の種族一般と何処か違っている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏和な、我がへンリ・シメレも今日、「浜（アピア）の白人は厭だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通訳はヘンリ（シメレ）。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンリ（シメレ）が実に良く働いて呉れる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天ノ命、二十世紀ノ第一年ヲ以テ此ノ法案ヲ起草セシメタルヲ拜謝ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔者娘ヲシテ其ノ母ニ背カシメンガ爲メニ來レリト云ヘル者アリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代世界ヲ展開セシメタル三大發明ノ中火藥ガ人類ヲ殺スヨリモ甚シク、印刷術ノ害毒全世界ノ頭腦ヲ朽蝕腐爛シ盡クセリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩ヲ誤ラバ宗祖ノ建國ヲ一空セシメ危機誠ニ幕末維新ノ内憂外患ヲ再現シ來レリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ納付ヲ避クル目的ヲ以テ血族其他ニ分有セシメ又ハ贈與スルヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
