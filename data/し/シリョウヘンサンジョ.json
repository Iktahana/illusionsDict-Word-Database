        "examples": {
          "standard": [
            {
              "text": "日本の近代史研究において、東京大学史料編纂所は中心的な役割を果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、古文書の調査のため、大学の史料編纂所に長期間滞在した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "史料編纂所が公開したデータベースは、多くの研究者に利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "史料編纂所から出る、武将連の肖像によくある、尻太・尻跳ねの眉が、しやれかうべの様に、作つた顔に、つけてありました。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大史料編纂所では、みつからない。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日記は史料編纂所で写しをとったが、それが印刷にでもなれば、かなり貴重な資料となるであろう。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大の史料編纂所の人とか源平史を専攻している歴史家などが、この「新・平家」に好意のある会合までして、素材や忠言を惜しみなく示してくれたことなどありがたく思っている。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
