        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一体、あそこに飾ってあった賞牌ってのは、コルテ市の射撃会で、部落の若いものがとった一等賞の記念。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをしているのだろうと思ってのぞきに行くと、パパは射撃会用のピストルをケースから出そうともがいていた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "射撃会が流行りだすとすぐやめてしまう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう射撃会にも行けないんだね」「敗けた以上、それくらいのことは当然だ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をきらせながら、大きな声で、「キャラコさん、きょう射撃会があるのよ。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はずかしくて、出て来られないのよ」　けさの射撃会のことで、腹を立てているにちがいない。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
