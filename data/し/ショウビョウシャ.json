    "definitions": [
      {
        "index": 1,
        "gloss": "the sick and wounded",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ベッドには、一人の患者がいなくなると、また別の傷病者がそのあとへやって来る。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」護送に行く看護長が廊下から叫ぶと、防寒服で丸くなった傷病者がごろ／＼靴を引きずって出てきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田口は看護長の返事を待ちながら、傷病者がうまく橇に身を合わそうとがた／＼やっているのを見ていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個大隊分遣される、それゃ、内地へ帰る傷病者の知ったことじゃない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍医は、白い顔を傷病者の視線から避け、わざと降る雪に眼を向けていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日の午後三時に政府は臨時震災救護事務局というものを組織し、さしあたり九百五十万円の救護資金を支出して、り災者へ食糧、飲料水をくばり、傷病者の手あて以下、交通、通信、衛生、防備、警備の手くばりをつけました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから傷病者の救済に奔走しながら、九月に入ると遽かに原子爆弾症患者が激増して来るが――この辺の状況は広島の場合とほぼ似てゐる――遂に永井氏も前から職業病として持つてゐた原子病が再発して病床に倒れてしまふのである。",
              "citation": {
                "source": "長崎の鐘",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷病者にして攻撃に参加し得ざるものはこれに先だち悉く自決せり。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "下なる浮動病室には、まだ傷病者等がゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "野戦病院の病棟も、その他の建物という建物も、傷病者の呻きでみちている。",
              "citation": {
                "source": "日本名婦伝",
                "author": "谷干城夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷病者は殖え、脱走者は絶えない。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
