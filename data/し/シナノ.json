    "definitions": [
      {
        "index": 1,
        "gloss": "Shinano (former province located in present-day Nagano Prefecture and parts of Gifu Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "信濃の浅間山、飛騨の硫黄岳、遠くの火山から、吹きなぐれた灰でもあろうか……空は曇り切って、どんよりと、眠むそうな顔をしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺の痩せた稚い樹が出て来て、その中から山桜の花が、雪のように咲いている、四月の色は北岳の北の尾根から、信濃金梅の傾斜を伝わって、この森林にまで、流れ込んでいる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の権現は信濃の国｜浅間大神と、一神両座の垂迹と信ぜられていたところから、浅間菩薩ともいい、富士｜浅間菩薩とも呼んだりしたが、本元の浅間山の方は、一の鳥居があるだけで、御神体は、山そのものに宿るとしてあるから、神社の鎮座がない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが甲斐と信濃の境、鳳来附近から、一気に押し寄せて来ているのだから驚く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人辻本工学士に拠ると信濃越中の国境に聳えている祖父ヶ岳は、「種蒔き爺さん」が笊を持った具合に現われるので、山腹雪解の頃、偃松が先ずその形に蔓って、出るのではないかという話である、偃松の仲間入は最もおもしろい。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに多数を意味する接尾音をつけた「シンヌ」はたくさんな山地でこれが「信濃」に似るなどちょっとおもしろいお慰みである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木田久老の『信濃漫録』の中にも龍麿の説を信用しないようなことを書いております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭申すやう、吾等去年、音にきゝし信濃なる彼の木曾の掛橋を通り申すに、橋杭立ち申さず、谷より谷へ掛渡しの鉄の鎖にて繋ぎ置き申候。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して秀次関白が罪を得るに及んで、それに坐して近衛殿は九州の坊の津へ流され、菊亭殿は信濃へ流され、その女の一台殿は車にて渡された。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の坂東太郎、浪花の丹波太郎、九州の比古太郎、近江あたりの信濃太郎、これらは雲の出づる方により負はせたる名なれば、けしうもあらず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八が岳は、ね、もっと信濃へはいってから、この反対側のほうに見えるのです。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば隅田川、淀川、信濃川、めいめい違った相、形の特色を持っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……信濃の秋の山深く、霜に冴えた夕月の色を、まあ、何と言はう。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、汽車に乗り、浅間の山の噴煙を眺め、絵のごとき信濃の国を過ぎて夜の十一時というに上野着。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "足跡は常陸、磐城、上野、下野、信濃、越後の六ヶ国に亘り、行程約百五十里、旅行日数二週間内外、なるべく人跡絶えたる深山を踏破して、地理歴史以外に、変った事を見聞し、変った旅行をしてみようというのである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　信濃國蒲原郡産の床屋職人で、氣取つたのが、鮨は屋臺に限る、と穴子をつまんで、「む、この鰌はうめえや。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃国東筑摩郡松本中が粗相をしても、腹を立てる私ではない。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、婆々どのの言うことに――やや親仁どのや、ぬしは信濃国東筑摩郡松本中での長尻ぞい……というて奥方、農産会に出た糸瓜ではござらぬぞ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃国東筑摩郡松本中は鵜でござる。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃国東筑摩郡松本中の評判じゃ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その客はおせんの馴染で、四谷｜信濃町に住んでゐる三十｜俵取りの國原次郎といふ者である。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃川からとれるようです。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃川を下っているのだ。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘、とはっきり知りながら、汽車に乗り、馬車に乗り、雪道歩いて、わたくしたち親子三人、信濃の奥まで、まいりました。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、信濃の、その山宿で死にました。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日、壬辰、鷹狩を禁断す可き事、守護地頭等に仰せらる、但し信濃国諏訪大明神御贄の鷹に於ては、免ぜらるるの由と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、丁亥、天晴、安念法師の白状に依りて、謀叛の輩を、所々に於て生虜らる、凡そ張本百三十余人、伴類二百人に及ぶと云々、此事、濫觴を尋ぬれば、信濃国の住人泉小次郎親平、去々年以後謀逆を企て、輩を相語らひ、故左衛門督殿の若君を以て大将軍と為し、相州を度り奉らんと欲すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとしの二月にも信濃国の住人、泉小次郎親平といふ人が、相州さまを憎んで亡きものにしようと内々謀逆を企ててゐたのが、未然に露顕して鎌倉中が大騒動になつたといふ事件がございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日、辛未、霽、将軍家の御持仏堂の御本尊、運慶造り奉り、京都より渡し奉らる、開眼供養の事有る可し、信濃守行光奉行として其沙汰有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして近代人といふのは、多いか少いかこのむしなのではないか？",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
