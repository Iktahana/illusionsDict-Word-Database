[
  {
    "uuid": "a2145a54-1c1b-53bc-913b-86dc38fd36e5",
    "entry": "死後",
    "reading": {
      "primary": "しご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
