        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十管入が品切れている時は三管入を三箱買うて行った。",
              "citation": {
                "source": "薬局",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも傍にあれば何本でもあるだけ打つから、面倒くさいが、毎日十本宛しか買わないことにしてるんです」　顔を見に来た訳じゃないと、その言葉はヒヤリと合理的で、翌日敏子は思わずつんとして、ヒロポン品切れです！",
              "citation": {
                "source": "薬局",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンコ屋で、品切れになっていたのかも知れない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて編集の仕事に携わり、何冊か自分でも本を出してきた私は、たくさんの本が増刷の予定のないまま品切れ扱いとされる、こうした背景を承知しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き手と契約して本作りの権利を独占している出版社には、それゆえ「品切れです」の一言ですませるのではなく、読者に届ける責任をかなう限り果たして欲しいと思います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き手の知名度や人気を背景にして、大量に売れるものが書店の目に付く場所を占領する一方で、じっくりと売れていった優れた本が品切れのまま放置される。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその日は二十九日と限られ、江戸じゅうの家々が一度に牡丹餅をこしらえる事になったので、米屋では糯米が品切れになり、粉屋では黄粉を売切ってしまった。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜酒を求めしに、品切れなりといふ。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『ブリタニカ』と『センチュリー』とを同時に提供していた時で、丁度『ブリタニカ』が品切れになっていた時であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "売り手は他店にもう品切れと踏んでいるから、吹っ掛けて出る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしが行かれる間があれば好いんだがな……」「一寸と買ひ憎い品物だね品切れぢやないかしら！",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど生憎品切れで、買わずにかえったそうだ」　霧原警部の顔は、この会話をきくと同時に、急に活気づいた。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの店にもマツチが品切れ、タバコの吸へないには少々まゐつた。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "『音楽未満』という著書が品切れになった。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして本は切り刻まれ、品切れのまま放置される。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし給仕を信用すれば、スタアだけは生憎品切れだつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし給仕を信用すれば、スタアだけは生憎品切れだった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、一番大きい――だが、金五円しかしないのを送ろうとしたら、店員が「品切れです、五円のは」と、云った。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "又「只今、五円のは品切れになりまして、明日なら出来ます」と、最初に云えば私は「じゃ三円のを二つ」と、云ったかも知れない。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく先生が品切れにならない。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物といっても、ただ普通の川蟹で、しかも品切れのことが多い。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川蟹が品切れになっても、一般に愛用される海蟹は決して店に置かなかった。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山書店　原稿わたし「現代の心」〔欄外に〕第七十二信十月二十五日『明日への精神』十部かって来ようとしたら品切れ、五日に増刷の由。",
              "citation": {
                "source": "日記",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『世界婦人』に、わたしの獄中で執筆したクロポトキンの『自敍傳』と『パンの略取』とを一度に發表しましたが、その増頁號は飛ぶやうに賣れて、忽ち品切れになりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それを見ると、いま、どんなものがあるか、なにが品切れかということが、すぐに分るようにしてある。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ、くまのいが、品切れで困っているのですから、値をよく買いますよ。",
              "citation": {
                "source": "猟師と薬屋の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
