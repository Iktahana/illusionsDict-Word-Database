          "standard": [
            {
              "text": "毎週水曜日は、おばあちゃんの定期的な診察日だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "予約が必要な診察日と、予約なしで受け付けられる診察日がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来月の診察日は、旅行と重なってしまったので変更したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "産婆の診察日に彼女は顫えた。",
              "citation": {
