[
  {
    "uuid": "7727a02e-fbb0-5bbf-8fcb-c71a0b6fa8c1",
    "entry": "彰義隊",
    "reading": {
      "primary": "しょうぎたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Shōgitai (group of former Tokugawa retainers opposed to the Meiji government and fought in the battle of Ueno)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おなじみの西郷銅像と彰義隊の碑も現に自分の頭の上何十尺の土層の頂上にあると思うと妙な気がする。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月十五日、市村座と守田座の開演中に、上野彰義隊の戦闘あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ無事に行つたかと思ふと、又彰義隊の反抗、奧羽の戰爭があるといふ風である。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "女形、二枚目に似たりといえども、彰義隊の落武者を父にして旗本の血の流れ淙々たる巡査である。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十五日官軍東叡山を囲みて彰義隊を討つ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次郎は老いたる母と若い妻と幼い娘とを知己のかたにあずけて、自分は上野の彰義隊に馳せ加わった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この場合、忌といえばどんな乱暴をされるか判らないのと、ここらの者はみな彰義隊に同情を寄せているのとで、どこの家でも彰義隊の落武者を拒むものは無かった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の四方を取りまいた官軍は、三河島の口だけをあけて置いたので、彰義隊の大部分はその方面から落ちのびたが、三河島へゆくことを知らなかった者は、出口出口をふさがれて再び江戸へ引っ返すのほかはなかった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺に彰義隊の戦死者を葬ってあるのは、誰も知ることである。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの墓もやはり円通寺にあるので、勘次郎は彰義隊の墓と共に拝んで帰った。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以来、彼は彰義隊の墓へまいるときには、かならずかの親子の小さい墓へも香花をそなえるのを例としていた。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "石原治三郎が四谷の屋敷を出て、上野の彰義隊に加わったのは、その年の四月中旬であった。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊らとは成るべく衝突を避けて、無事に鎮撫解散させるのが薩長側の方針であったから、直ぐには攻めかかって来ない。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊士も一方には防禦の準備をしながら、そのあいだには徒然に苦しんで市中を徘徊するのもある。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊と八百屋お七と、もとより関係のあるべき筈はないが、彰義隊の一人石原治三郎は唯なんとなくお七の墓に心を惹かれたのである。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に彰義隊の屯所の上野界隈は、昼でも悠々と飯を食っている客は少かった。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊の敗れたその日の夕七つ頃（午後四時）に、治三郎は根津から三河島の方角へ落ちて行った。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらに住むものは彰義隊の同情者で、上野から落ちて来たといえば、相当の世話をしてくれると思っていたのに、彼は情なく断るのである。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云っても、彰義隊に加わったわけじゃあない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は向島の小さい穏かな住居で、維新の革命も彰義隊の戦争も、凡て対岸の火事として安穏に過して来ました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊討伐、会津討伐と、息もつかずに戦火の間を駈けめぐったおそろしく胆の太い藪医者だった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは初めにも申した通り、文久二年の出来事で、それから六年目が慶応四年、すなわち明治元年で、江戸城あけ渡しから上野の彰義隊一件、江戸中は引っくり返るような騒ぎになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき藤崎さんは彰義隊の一人となって、上野に立籠りました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "官軍がなぜ彰義隊を打っちゃって置くのか、今に戦争がはじまるに相違ないと江戸中でも頻りにその噂をしていました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊の戦死者のふところに経文をまいていたのは沢山ありました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新富座の方は、「皐月晴上野朝風」と「釈迦八相」と「勧進帳」と「近江源氏」という列べ方で、そのうちでも一番目の彰義隊が最も世間の噂に上った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前興行の「め組の喧嘩」に味を占めて、東京人に思い出の多い上野の彰義隊一件を脚色して上演した興行政略が再び図にあたって、新富座では上野の戦争をするという評判が開場前から市中にひろまった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの今日でまだよく纏まらないが、やはり六幕にはなりそうもないと答えると、それでは彰義隊か何かをむすび付けて、なんとかして六幕ぐらいの物にしてくれないと時間の都合がわるいから、是非にたのむと言って帰った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
