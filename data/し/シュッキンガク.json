        "examples": {
          "standard": [
            {
              "text": "出金額の明細を確認したところ、身に覚えのない引き落としがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一日の出金額に上限を設けることで、不正利用の被害を最小限に抑える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算オーバーを防ぐため、今月の合計出金額を帳簿に記録しておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、これより先三井家は三千万円で財団法人「三井報恩会」を設立し「社会事業その他公益的施設の経営又は助成、及び有益なる学術研究を工業農業其他の産業に応用する実験費援助」の名による第一回支出金額を決定させたということである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
