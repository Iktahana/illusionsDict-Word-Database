    "definitions": [
      {
        "index": 1,
        "gloss": "Shanghan Lun (treatise on traditional Chinese medicine compiled by Zhang Zhongjing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "素問と難経とを二三行ずつ、傷寒論と病源候論とを五六行ずつ訳させられたのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞亭は文台の平生を叙して、「受学赤松滄洲翁、蚤歳継先人之志、潜心長沙氏之書、日夜研究、手不釈巻、三十年如一日矣、終大有所発揮、為之註釈、家刻傷寒論是也」と云ひ、凹巷は「聞先生終身坎※、数十年所読、唯一部傷寒論、其所発明、註成六巻、既梓行世」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "時時就質傷寒論之疑義。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒が去つた直後に、留守宅に傷寒論輪講の発会があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日より傷寒論講釈相始候処、諸君奇講甚面白し。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百九十六　榛軒の留守に会して傷寒論を講じた人々の合作柬牘には、渋江抽斎の次に岡西玄亭が書いてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "村片は傷寒論を講ずべき人ではない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭が傷寒論を講じ、柏軒が聴者中にあつたことが此に由つて知られる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "元春は嘗て傷寒論排簡を著し、又詩を賦し、墨竹を作つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奴等が二千年来｜垢染みた傷寒論を土産にして、国に帰て人を殺すとは恐ろしいじゃないか。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "之ヲ傷寒論ニ対検スルニ、馳駆範ニ差ハズ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳昌胤の百中傷寒論なども名を見れば分る。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭寒足熱は延命息災の徴と傷寒論にも出ている通り、濡れ手拭は長寿法において一日も欠くべからざる者である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄八丈に坊主頭、老眼鏡に傷寒論と言つた型の如き調子。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "釣針の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭に黄八丈の袷、黒｜縮緬の羽織に短かいのを一本きめて、讀めさうもない漢文の傷寒論を懷にし、幇間と仲人を渡世にしてゐる醫者は、その頃の江戸には少なくなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭に黄八丈の袷、黒縮緬の羽織に短いのを一本きめて、読めそうもない漢文の傷寒論を懐ろにし、幇間と仲人を渡世にしている医者は、その頃の江戸には少なくなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
