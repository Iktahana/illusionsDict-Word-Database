    "definitions": [
      {
        "index": 1,
        "gloss": "color graphics adapter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
