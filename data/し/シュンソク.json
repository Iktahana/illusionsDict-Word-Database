    "definitions": [
      {
        "index": 1,
        "gloss": "swiftness of foot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
