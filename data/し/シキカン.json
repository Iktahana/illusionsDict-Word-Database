[
  {
    "uuid": "e4bf2a76-a4e1-5c67-af1e-71cdd74b4769",
    "entry": "指揮官",
    "reading": {
      "primary": "しきかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commander",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "将校の動きも、隊長も指揮官も、相手方の部隊の様子も、軍隊の背後に於ける国内の大衆の生活状態も、そこに於ける階級の関係も、すべて戦争と密接な切り離せない関係を持っている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおのおのが持っている任務と力量とを彼は指揮官のように知っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸にこみ上げてくる喜びをじっと押し殺して、参謀の提出した方略を採用する指揮官のように、わざと落ちつき払いながら鉛筆を動かし始めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こうしてこの国のほうが、負けそうになっていたときに、ペテロという、ひとりの馬にのったわかい指揮官が、めざましいはたらきをしたおかげで、みかたは元気をもりかえし、とうとう、敵をうちやぶってしまいました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就が鼓の浦へ上陸しようとする時、雨が頻りに降ったので、輸送指揮官の児玉｜就忠が、元就に唐傘をさしかけようとしたので、元就は拳を以て之を払除けた。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "指揮官野津大佐は、敵弾を、一つは革帯に、二つは軍刀に受けた程である。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は間断なく到着するので、私は指揮官のやうな号令を、のべつに叫び続けなければならないのである。",
              "citation": {
                "source": "山を降る一隊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにア、心羞ずる事甚だしく新婦の房へ入らず、厠に行くふりして庭に飛び下り、馬に乗って泣きながら走り出で、インドに渡り王の近衛兵の指揮官まで昇り、面白｜可笑しく十年を過した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将をはじめとして並居る指揮官、歩兵、工兵、砲兵と列をつくつて陣どり、勝手の知れた城中の要所にかくれて、どつとばかりに襲撃する、逃げまどふ敵を挟みうちに追ひつめる、それツ！",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて貴族軍の総勢は凡て敵方の桟橋の入口に集りましたので、さて、一気に突喊しようと、指揮官が剣を抜いて、「進め――総攻撃！",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長谷部少佐を指揮官として、決死の戦闘員十五名がのりこんだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこだ」「指揮官、あれです」長谷部少佐は、水兵の指す海面を見た。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、助けてやれないか」「ああ指揮官、心臓は微かながらまだ動いています。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生自身と外に一人を除いては皆軍人許り、ヒヨウと気たたましい非常汽笛が鳴ると、指揮官の少尉殿は忽ち「伏せツ」と号令を下した、軍人は皆バタ／＼と床に伏した。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬礼の際「頭右」と号令をかけ指揮官は刀を前に投げ出します。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに面式の防禦をしている敵を攻撃するに各兵、各部隊の自由にまかせて置いては大きな混乱に陥るから、指揮官の明確な統制が必要となりました。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りに広く散開しかつ衝突を行なう際に指揮官の手許に充分の兵力が無くなる危険があったから、秩序が回復するに従い散兵を制限する事を試み、散兵、横隊、縦隊の三者を必要に応じて或いは同時に、或いは交互に使用した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如き状態に於て中学校以上を卒業したとて一般の兵は二年または三年在営するに対し、僅か一年の在営期間で指揮官たるべき力量を得ないのは当然である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また軍隊教育は平等教育を一抛し、各兵の天分を充分に発揮せしめ、特に優秀者の能力を最高度に発展せしむる事が必要であり、これによって多数の指揮官を養成せねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち指揮官ははっきり自分の意志を決定する。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "１、指揮官の優秀、およびそれを補佐する指揮機関の整備。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに指揮官が優秀でも、千変万化の状況は全く散兵戦術時代とは比較にならぬ結果、いちいち指揮官の指揮を待つ暇なく、また驚くべき有利な機会を捉うる可能性が高い。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンは最左翼の大集団を直接掌握し、同時に全軍の指揮官であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一ないし第三軍を一指揮官により統一運用したならばあるいは国境会戦に更に徹底せる勝利となり、仏第五軍、少なくも英軍を捕捉し得たかも知れぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の手法、映画の持っている便利なテンポを全く無視する程腰を据えて沙漠とその沙漠をラクダに乗って横切って行く土民とイタリー人の指揮官の一隊を写している。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "登場する人物は少数のイタリー指揮官と、銃を与えられて、整列すること、敬礼すること、同じ黒い皮膚を持った沙丘の彼方の土民を射撃することを正当化されているリビヤ土人の一隊である。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　汽車が千葉近くなった時、輸送指揮官の看守長が、ちょうど甥どもを初めて自分のうちへ連れて行く伯父さんのような調子で、（実際この看守長は最後まで僕等にはいい伯父さんだった）いろいろその自分のうちの自慢をしながら、左側の窓からそとを指さして言った。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前線から帰った人から、最後まで残ったのは兵士であって、指揮官は飛行機で疾うの昔に引揚げてしまっていたという話を、戦争が終ってからは屡々聞くようになった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は軍の指揮官であり、諸大名間の交渉役であり、政治家でもあり、また地方の支配者など――封建時代の武士のやる役職にはすべて就いた。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
