    "definitions": [
      {
        "index": 1,
        "gloss": "old, white fox (trad. said to have supernatural powers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」ヘー有難うこれから当世白狐伝を御覧に入れる所なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟端で聞くとも無しに此の話を聞いて居た、女賊白狐のおしまが、そッと微笑んだ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、　丁度今旅籠に着いて足を洗って居た白狐のおしまが、その声を聞いて、アレッと言った顔。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝街道の茶店　白狐のおしまが休んで居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狐こんこん白狐、お嫁ほしけりゃ、とってやろよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平右衛門はひらりと縁側から飛び下りて、はだしで門前の白狐に向って進みます。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて平右衛門もあまりといえばありありとしたその白狐の姿を見ては怖さが咽喉までこみあげましたが、みんなの手前もありますので、やっと一声切り込んで行きました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お稲荷、稲荷さんと云うんだね、白狐の化けた処なんだろう。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、黒痘痕の眼も輝き、天狗、般若、白狐の、六箇の眼玉も赫となる。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気｜洋燈が煌々と燿いて書棚の角々や、金文字入りの書や、置時計や、水彩画の金縁や、籐のソハに敷てある白狐の銀毛などに反射して部屋は綺麗で陽気である、銀之助はこれが好である。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲馬の天幕の前には三角耳の眼の細い象の子が、赤と金との鞍掛けに飾られて、まだ初々しい灰色の曲り鼻をあげあげ客呼びしていると、それと対って、白狐とも化け猫ともつかぬ絵看板の、「これはこのたび奥州｜気仙沼は何とか何兵衛の女房お何が生み落しましたる血塊童子でござい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、夕暮の微光の中に、妖気を吐き尽した白狐の如く端然と坐った夏姫の姿を横あいから眺めた時、如何に自分の運命がこのものの為に高い価を払わねばならなかったかを巫臣は始めてマザマザと感じた。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな莫迦げた踊りを（白狐のような夏姫も所詮は操られたにすぎぬのだ）己の一生の無意味さが他人事のように眺められたのである。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他に、駿州の鎮守総社大明神に神使として目されていた白狐が居たのが、義元出発の日、胸がさけて死んで居たとも伝える。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白狐に、大切な人間の頭を、赤禿げにされていられるかい！",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥居も祠も、悪い使いをするとの白狐をも撲り殺してやろうと考えた。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、白狐だかなんだか、撲っ殺してくれっから。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一予審調書に依れば、被告は相当な御礼寄進をなさざれば、直ちにお使いの白狐が飛び出して田畑を荒らし、その他再び病気を発するなど、顕然なる罰を受けるものと称して、金銭、米穀、反物、田畑、山林などを寄進せしめ、これを私有し、贅沢なる暮らしをしていたではないか？",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはここらに年｜経る白狐だぞ」「畜生、よく名乗った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "白狐の襟巻をした彼女の頬が、ちやうど彼の顔と並ぶくらゐに、体を持たせかけて、手を彼の膝についてゐた。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜風の寒いをりは、Ｉ子もそろ／＼白狐衿捲を想ひ出す季節であつた。",
              "citation": {
                "source": "彷徨へる",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夜な／＼正一位樣の御使なる白狐が來て寢る處とかいふ事で、かの鰯の頭も信心柄の殊勝な連中が、時に豆腐の油揚や干鯡、乃至は強飯の類の心籠めた供物を入れ置くところである。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今自分は、落葉した木槿垣を透して、此白狐の寢殿を内部まで窺ひ見るべき地位に立つて居たのだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、自分のひやりと許り愕いたのは、敢て此處から、牛の樣な白狐が飛び出したといふ譯ではなかつた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "にも不拘、常に此新山堂下の白狐龕を無賃の宿として居るといふ事も亦、自分の聞き知つて居る處である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄笑をして俯向き乍ら歩いて來る彼は、軈て覺束なき歩調を進めて、白狐龕の前まで來た。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　此お夏は今、狹い白狐龕の中にペタリと坐つて、ポカンとした顏を入口に向けて居たのだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夜な／＼正一位様の御使なる白狐が来て寝る処とかいふ事で、かの鰯の頭も信心柄の殊勝な連中が、時に豆腐の油揚や干鯡、乃至は強飯の類の心籠めた供物を入れ置くところである。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今自分は、落葉した木槿垣を透して、此白狐の寝殿を内部まで覗ひ見るべき地位に立つて居たのだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
