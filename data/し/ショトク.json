    },
    "definitions": [
      {
        "index": 1,
        "gloss": "income",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "数理に関する彼の所得は学校の教程などとは無関係に驚くべき速度で増大した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は「人生の所得者」である。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んやこの世の中には僕の如く、物質上にも精神上にも、無益な浪費ばかりをして、何一つ所得するところもなく、人生を悔恨に終る人々がすくなくないのだ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が彼を羨望して、人生の「所得人」と言ふのはこの爲である。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう能力の獲得が一人の人間の精神的所得として、そう安直な無価値なものであろうとは思われないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすべての人心の所得をその真の源まで追跡する事が出来たら、この世界がいちばん多くの御蔭を蒙っているのは、最も独創力のある人々であった事を発見するだろう。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は、各国の帝国主義に尻押しをされて、絶えまなく小競合を繰りかえす軍閥の苛斂誅求と、土匪や、敗残兵の掠奪に、いくら耕しても、いくら家畜をみずかっても、自分の所得となるものは、何一ツなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田信長より前は、禁庭御所得はどの位であったと思う。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその高慢税は所得税などと違って、政府へ納められて盗賊役人だかも知れない役人の月給などになるのではなく、直に骨董屋さんへ廻って世間に流通するのであるから、手取早く世間の融通を助けて、いくらか景気をよくしているのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし現在の科学の所得は、すでに科学の究極的に獲得しうるすべての大部分であると考え、吾人の残務はただそこかしこの小さい穴を繕うに過ぎぬと考えればプランクの説はもっともと思われる。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学はたよりない人間の官能から独立した「科学的客観的人間」の所得となって永遠の落ちつき所に安置されたようにも見える。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはその上に元禄以降大正昭和に至るまでのあらゆる所得を充分に吸収消化した上でもう一ぺん始めから出直さなければならないであろう。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方跡を掃くと一合位は砂に交つた溢米が彼の所得となつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことや金一百円、一銭銅貨一万枚は、これ等の細民が三四年間粒々辛苦の所得なるを、万一｜咄嗟にこの大金を獲ば、蓋し異数の僥倖にして、坐して半生を暮し得べし。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、私も小児の時分｜稽古をして、少しは所得があるので、馬車会社へ住み込んで、馭者となった。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の行程七里、そして所得は、――銭四十三銭に米八合。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の行乞所得米一升六合　銭四十一銭途上一杯の酒、それこそまさに甘露！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は山口を行乞しよう、六時出立、九時着、行乞三時間、三時帰庵、行乞相はよかつた、所得もわるくなかつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得銭　四十五銭　　　　米　一升三合　　今日の買物煙草　四銭　　　　焼酎　十一銭端書　六銭　　　　味噌　八銭途上で拾ひあげた句七つ。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭　二十一銭今日の所得　　　　　　　　　　行程五里。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "所得――銭四十四銭に米一升三合午後は東御嶽観音様へ詣でる、青葉、水音、蝉がなき鶯がなく、とてもしづかな山村だつた、そこから赤郷へ河鹿聴きに出かけたが、暑くはあるし、興味もうすらいだので途中から引き返す、徃復三里の散歩だ。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭　四十三銭今日の所得　　　　　　　　　　行程七里　　　　　　米　一升六合此度の敬治居訪問はほんとうによかつた、敬治君にもよりよく触れたし、奥さんのよいところよくないところも解つた、敬坊万歳、どなたも幸福であれ。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得　　米　六合　　　銭　九銭　　　外に句、十三。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "米　二升二合　　　　　　　　　酒　　　弐十銭今日の所得　　　　　　　　　　今日の買物　　　　　　銭　二十六銭　　　　　　　　　ハガキ　三銭この二合の酒はとてもうまかつた、文字通りの甘露だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯（鯖の煮付、茄子の煮込、沢庵漬）　朝食（味噌汁、煮豆、沢庵漬）所得（銭三十銭、米三升）今夜はお布施のおかげで、日本酒三合いたゞく。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得は銭二十銭と米四升。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "行程五里、所得は米四升二合、銭卅七銭。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得は銭十八銭、米四升一合。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "買物いろ／＼、――酢、醤油、石油、煙草、端書――行乞四日間の所得はすつかり無くなつてしまつた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得は　銭弐十六銭、米弐升八合。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
