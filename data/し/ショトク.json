  {
    "uuid": "d82ee675-ea7a-5943-ad1e-ef195383f575",
    "entry": "諸徳",
    "reading": {
      "primary": "しょとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
