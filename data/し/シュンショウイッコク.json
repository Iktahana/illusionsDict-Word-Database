          "literary": [
            {
              "text": "「春宵一刻、價千金、か。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宵一刻、――」などと、つまらぬ事を呟きながら木の虚から這ひ出ると、オヤ　ナンデセウ　サワグコヱミレバ　フシギダ　ユメデシヨカ　といふ事になるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春宵一刻、価千金、か。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の詩人は悩ましげにも、「春宵一刻価千金」と歎息している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君乗せし黄の大馬とわが驢馬と並べて春の水見る夕　春宵一刻千金とまでは進まぬその一歩手前の夕暮の気持を象徴的に詠出したものであらうか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宵一刻｜価千金、ここばかりは時を得顔の絃歌にさざめいている。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着いた先は小梅の大きな寮、隅田川から水を引いた池の上には、見事な遊山船を浮べて、春宵一刻を惜しむの長夜の宴を、昨日も今日も開いているのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
