[
  {
    "uuid": "aebc54a8-7b0b-5e4a-b21e-8ec2528c76ed",
    "entry": "櫛比",
    "reading": {
      "primary": "しっぴ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "standing (close together) in a row",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜明前には奥漢鉄路で捕えられた二百名からの党員が銃殺されて、珠江に投げ棄てられた死体が河畔の摩天楼の下に櫛比して河底に埋もれ、蛋民によって水葬されたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜町というところは、今は人家｜櫛比してその面かげもありませんけれども、むかしは鄙びていて、風流人に縁のある土地で、下町では八丁堀茅場町辺と対立していたという話であります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "池上の寮は、やゝその昔の俤をとゞめたものらしく、この人家櫛比の中に在ってはちっとも目立ちませんが、門の中へ入ると、もとは隅田川から鴎に混って小鴨がひょこり／＼と浮いて入って来たという、その水門口の跡の残っている池が中心で、石だけの中の島に、やゝ勾配のある柴の橋が架っております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家の櫛比と煤煙が近づき、車はその中へ突入します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺望遠く及びて、高原の下青松の間、人家の櫛比するものあるをみる。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "十數年前には、沮洳蘆荻のみなりし地に、鑛泉宿、料理店、賣店、櫛比して、わざ／＼電車も通ずるに至れり。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩道には大きな自然石が出鱈目に敷かれて、漁村のような原始的な建物が櫛比している。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわえ込みの木賃宿 hotel para pernoitar の軒灯がななめによろめいて、ちょうど理髪屋みたいな、土間だけの小店が細い溝をなかに櫛比している。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛比した宿屋と宿屋との軒のあわいを、乗合自動車がすれすれに通るのであるから、太い木綿縞のドテラの上に小さい丸髷の後姿で、横から見ると、ドテラになってもなおその襟に大輪の黄菊をつけている一群は、あわてて一列縦隊をつくり、宿屋の店先へすりついて、のろのろと進むのである。",
              "citation": {
                "source": "上林からの手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛比した人家の屋根の波を踰え、鈍く光りつつ横わっている港の展望、福済寺は、長崎港の一番奥、東北よりの丘陵の上に位している。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨークのあの摩天楼の櫛比した上に巨大な破壊力がおちかかる時の光景を想像すれば、どんな蒙昧な市民も、それが、ノア洪水より、惨な潰滅の姿であることを理解するだろう。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時人々の前には、眼界遙かに穏やかな入海と、櫛比した町々の屋根が展開される。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡三四町書肆｜櫛比す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした方々が、白壁の小家が櫛比するこの狭衝の町、また、イラクのバグダットと肩をならべる世界一暑い首府の――ムスカットを見ちがえるように飾ってしまったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆の信仰あつく、参詣の人は絶えず、廟前には小店が櫛比して、浅草の仲見世の観がある。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "西側に櫛比した矮い店舗が、どれも粗末な古著や古道具を並べてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の道は、工事中の活動写真館があったり、空地があったりするが、その先は人家が櫛比して省線の停車場になっている。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで往来の右側と来ては、全く形容のしようもないほど、小さい、貧弱な、和洋折衷の――色ばっかりが、けばけばしく、造作からいえばやにっこい、数え切れないほどの住宅が――調子のこわれた音楽のように、文字通り目茶苦茶に櫛比していたが、それは全く見る人の心を、都会嫌忌にまで導くに足りた。",
              "citation": {
                "source": "畳まれた町",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギゼーの町は小さくはあるが、街の中央の道路には、軽快な電車も通っているし、小綺麗な旅館も櫛比しているし、椰子の樹蔭も諸所にあって、金字塔見物の遊覧客に、気に入られそうな町である。",
              "citation": {
                "source": "木乃伊の耳飾",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポツポツやけのこりの鉄骨が立って居るばかり、櫛比した通並は一目で本所まで見晴せそうだ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家が独立して周囲に立木がある為に、人家櫛比の街道筋を除いては、村の火事は滅多に大火にはならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの軽井沢は、文化風の建物が櫛比して賑やかな都会となっているが、そのころはまだ北佐久郡東長倉村の一集落で、茅葺屋根の低い家並みが続いていて、ペンキ塗りの外人の避暑小屋は落葉松の林のなかに、ばらばらと数えるほどしか見えなかった。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに退いて世の交りを断たん事を欲し妓家櫛比する浅草代地の横町にかくれ住む。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "左京神別中　間人宿禰　神魂命五世孫玉櫛比古命之後也。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁家櫛比し水田渺茫として海に連る。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正七八年の頃、浅草観音堂裏手の境内が狭められ、広い道路が開かれるに際して、むかしから其辺に櫛比していた楊弓場銘酒屋のたぐいが悉く取払いを命ぜられ、現在でも京成バスの往復している大正道路の両側に処定めず店を移した。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（宏壮な建物が櫛比してあるといい度いが、場所によるとそれ程にはいかぬ。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国広小路の現況「往時は、観物、辻講釈、百日芝居と甚だ雑沓の巷なりしも、近年旧態を一掃して、商家櫛比、殷賑の市街とはなりにき。",
              "citation": {
                "source": "両国界隈",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向うの茫洋たる砂漠には、成吉思汗軍の天幕、椀を伏せたように一面に櫛比し、白旄、軍旗等｜翩翻として林立するのが小さく俯瞰される。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬だけがときどきぴしっぴしっと尾を振って、横腹に飛びつこうとする蠅を叩き落としていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
