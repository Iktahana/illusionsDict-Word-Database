          "standard": [
            {
              "text": "膨大な調査結果を、報告書のために十ページ程度に縮約する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典文学の名作を、子供向けに内容を縮約して出版する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の演説は、現代社会が抱える問題を実に見事に縮約したものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "手にとってやりおえるまでの時間は、あらゆる縮約形を用いたとして……少なくとも一五分。",
              "citation": {
                "source": "三枚の学生",
