        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宅の白猫の顏に少し似てゐるが、あの喇叭のやうな恰好をして、さうして禿頭のやうな色彩を帶びた鼻面はセンシユアルでシユワイニツシである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ白猫の母は宅の飼猫で白に雉毛の斑点を多分にもっていたが、ことによると前の白猫と今度の「白」とは父親がおなじであるか、ことによると「白」が「ボーヤ」の子であるかもしれないと思われた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて思い当るのは、一と頃ときどき宅へ忍び込んで来る猫の中に一匹のアンゴラ種らしい立派な白猫があった、それが、もしかすると「白」の父親か祖父ではないかと思われるのであった。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）そうだとすれば宅の白猫ＤはそのＢ＝Ｃ猫の血族か。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一匹の白猫で、しかも前脚二本を高くあげて、後脚二本は人間のように突っ立っているのを見た時に、女房もはっと息をのみ込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ほどから露路をあちらへ行ったりこりこちらへ来たり、二匹の白猫が盛んに追っかけあいをしていたのであるが、この時ちょうど私の眼の下で、不意に彼らは小さな唸り声をあげて組打ちをはじめたのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この互いに絡み合っている二匹の白猫は私をして肆な男女の痴態を幻想させる。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその部下の一番書記は白猫でした、二番書記は虎猫でした、三番書記は三毛猫でした、四番書記は竃猫でした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな事務所のまん中に、事務長の黒猫が、まつ赤な羅紗をかけた卓を控へてどつかり腰かけ、その右側に一番の白猫と三番の三毛猫、左側に二番の虎猫と四番のかま猫が、めいめい小さなテーブルを前にして、きちんと椅子にかけてゐました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」白猫が云ひました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "白猫が入つて来ました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」白猫も忙がしさうに仕事にかかりました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時かま猫は力なく立つてだまつておじぎをしましたが、白猫はまるで知らないふりをしてゐます。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一番書記の白猫が、かま猫の原簿で読んでゐます。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある草は白猫の柔毛の感じ忘れがたく、いとふくよかに温臭き残香の中に吐息しつ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが中にただひとつ、飛び跳ぬるもの、そは誰が愛せし白猫ぞや。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳酪の白猫がまだ睡つてゐる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しい、苦しい、まるで獣芝居に出てくる白猫の役者のやうに初めは白い毛皮の身のまはりを嘲笑つてゐた人間の浮かれ心までが、遂には真実に淫逸な四足獣の悩ましい悲念に帰つてゆくのではないかとさへ思はれる位、霧は怪しくふりそそいでくる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、何時か彼等の姿が消え、その代りに塚の上には、今度は白猫が一匹いる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、白猫の周りに、灰色、三毛、黒、と、あらゆる毛色の猫共が、幻のように音も無く、鳴声一つ立てずに忍び寄って来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういへば今は白猫がゐなくなつてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば今は白猫がいなくなっている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に、すこぶる好々爺な白猫がやって来る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の立春の宵に、外から帰って来る途上、宅から二、三丁のある家の軒にうずくまっている大きな白猫がある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには手飼の白猫が眼を怒らして牙をむきだして唸っていた。",
              "citation": {
                "source": "一握の髪の毛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この腕白猫めは頗る健啖家で、少とやそっとのお裾分では満足しなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその翌日、猫のいたずらと云って貼り換えさせた障子のやぶれは、徳次郎という白猫のいたずらの跡であろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "観世物小屋で囃し立てる猫の踊りは皆こうして仕込むので、富蔵もふた月ほどかかってこの白猫を馴らした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
