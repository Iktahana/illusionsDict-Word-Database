    "definitions": [
      {
        "index": 1,
        "gloss": "worldly wisdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
