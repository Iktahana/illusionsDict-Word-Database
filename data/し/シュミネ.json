        "examples": {
          "standard": [
            {
              "text": "冬の夜、シュミネの中でパチパチと薪が燃える音を聞きながら読書をするのが至福の時だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "欧州の古い洋館には、美しい石彫りのシュミネが今もそのまま残されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "煙突掃除を怠ると、シュミネから出る煙が室内に逆流してしまうので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "中央には岩のやうなシュミネがあり、入口近いところにピアノが一台光つてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
