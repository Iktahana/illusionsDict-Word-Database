        "examples": {
          "standard": [
            {
              "text": "製品の「使用頻度」が高いほど、耐久性への要求も高まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このアプリケーションは「使用頻度」が非常に高く、多くのユーザーに愛用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、このカフェの「使用頻度」が上がって、すっかり常連になっちゃったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "けれど、『岩波国語辞典』と『リーダーズ英和辞典』という最も使用頻度の高い二つは、マシンで引いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに追加する、第三水準第四水準を決める新しい規格では、実際に日本語の文献の中で使われた実績があることを要件とし、使用頻度も勘案しながら文字を選んでいくという。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった二百字の暗号文にしろ、日本文字の使用頻度の統計とだいぶん違っている。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
