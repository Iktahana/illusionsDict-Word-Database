    "definitions": [
      {
        "index": 1,
        "gloss": "compartment (of a train)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
