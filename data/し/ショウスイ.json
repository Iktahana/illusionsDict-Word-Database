  {
    "uuid": "9f45b7de-27f7-54cc-b38d-92ec62152ea2",
    "entry": "傷悴",
    "reading": {
      "primary": "しょうすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great grief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "髪は乱れてあお白くしょうすいした顔にへばりつき、死人のように呼吸も絶え絶えに昏倒している。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "しろうと考えというものかも知れないが、雪国で生れて秋なかばからの一冬にかけて、太陽を見ることのできないせつなさにしょうすいするような思いで育った私が、冬の頭上に連日かがやいているのどかな太陽を見れば、もう雪国は終ったと考え、越後平野を関東平野と同じように考えてしまうのも当然だと思うのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、それは、最初からこの男が極度にしょうすいしていたために、今さら目立たないためでもある。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行くの」「アア……別に……」「馬鹿にしょうすいしているじゃないか。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
