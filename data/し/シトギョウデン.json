    "definitions": [
      {
        "index": 1,
        "gloss": "Acts of the Apostles (book of the Bible)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
