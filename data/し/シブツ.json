      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "private property",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一時間ばかり椅子でボンヤリしているうちに、伍長と、も一人の上等兵とは、兵舎で私の私物箱から背嚢、寝台、藁布団などを悉く引っくりかえして、くまなく調べていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、ほかの看護卒の、私物箱や、財布をも寝台の上に出させ、中に這入っている紙幣を偽物かどうか、透かしてたしかめた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼の寝台の上には、手帳や、本や、絵葉書など、私物箱から放り出したまゝ散らかっていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、無断で私物箱を調べられるというような屈辱には馴れていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉永は、松木の寝台の上で私物を纏めていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンペラから、毛布から、背嚢から、私物まで、すっかりひっくりかえされてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年のこと、九段竹橋の近衛歩兵第一連隊第四中隊（特に明記して置く）に一年志願兵としているうちに、或る晩の事、私の私物筥に風呂敷に包んだ餅が隠してあるのが発見された。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武芝は敵せないから逃げ匿れると、武芝の私物まで検封してしまつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両日中は二人とも荷ほどきしたり、私物をうまく置こうと悩んだりしながら時間をとられたが、終えると徐々に腰も落ち着いてきて、新しい環境に慣れ始めていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の事業、全財産のみならず、私物一切奉納して、奉公いたします。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "野口はくだらぬ私物を大事にして、人から托された国宝的な図書を焼いてしまった、と後世に悪名を残すのは私ですよ。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中、少尉は、階級章もつけず、新品の被服と私物らしいワイシャツを着こみ、コードバンの長靴を光らせ、銃のことを鉄砲、帯剣をサーベル、軍衣袴を洋服といい、少尉は中尉を旦那、中尉は少尉を何々君と呼ぶといった砕けかたで、陸軍の将校の感覚はまったくなかった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうち監視員は附近の工場から交代で出る気のいい労働者だったが、間もなく市の革命委員会からルトミンという男が専任になってやってくると、いままでいくらか保持されていた礼儀も規律も一挙に消えうせ、廃帝の私物を平気で攫って行ったり、意味なき苛酷な規定をつくって皇女たちの編物まで禁じてしまった。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ入院して、本部の命令で、家族は私物をもって一応かえるようにということだとあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のスーツケースは城介の私服や私物を入れて帰るためのものである。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすぐに私物を整理して、迎えを待った。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな不安というか虚無的な気持というか、私物の整理をしていても、それが心の底に引っかかって、酒でも飲まなきゃやり切れなかったな。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで聖地では私物を全て預かります。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく見ていたが、厳秘と書いてあるところから、ことによると他人に見られたくない父の私物か、と思い、そのまま元へ返そうとして、そして、あっと声をあげた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私物と判断出来るものは、ひとまとめにすべてお返ししました」「不思議なものは、ありましたか」「ロッカーにはレインコートや傘などで、デスクについてもおなじでした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェシの置き忘れた私物だそうで、渡したがっていた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、私物をまとめるために、ダッシュウッド邸に数日滞在するのはかまいませんが」「ではどうしろと言うんだ？",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸宅に行って、私物を探していたとのこと。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "私物もまとめました。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "混乱に乗じて、私物を持ち出されていないか見に行こう」　二人の小さな居間は空っぽ、寝室も空っぽ、何もない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間にベッドを一台持ち込み、一週間数シリング前払いして、私物の代わりに信用させるってのはどうかね。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿人の私物を値踏みするから、荷物がない人は全く信用しない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて解放され、ヘアデールパークへ行き、私物を全部引き取った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ私物を取りに来たところ、あなたにつかまったのです。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、官の廩倉も公卿の私物もほとんど他へ移されており、疎開民家ときてはなおさらで一ト釜の粟すら残してはいなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
