        "examples": {
          "standard": [
            {
              "text": "この絵画は、真珠光が印象的な海の風景を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜空に浮かぶ月は、まるで真珠光を放つ宝石のようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の指輪は、真珠光を帯びたオパールがはめ込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天の一方には弦月が雲間から寒い光を投げて直下の海面に一抹の真珠光を漾わしていた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶくは、石鹸でつくったものよりも一層美しくて、真珠光に富んでいた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
