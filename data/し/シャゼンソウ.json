      {
        "index": 1,
        "gloss": "plantain (esp. Asian plantain, Plantago asiatica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
