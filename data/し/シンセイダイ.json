        "examples": {
          "standard": [
            {
              "text": "恐竜が絶滅した後、新生代に入り哺乳類が繁栄した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地球の歴史は、大きく古生代、中生代、新生代に分けられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新生代の地層からは、さまざまな哺乳類の化石が発見されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこに登っておれは助かるか助からないか、事によったら新生代の沖積世が急いで助けに来るかも知れない。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後で、天地創造がふたたび繰返され、新世界、すなわち、新生代がはじまった。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸にはあまり湾入がなく、地質は新生代で、ほぼ等高の山脊が連り、樹木はない。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
