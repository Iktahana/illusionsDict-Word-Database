[
  {
    "uuid": "859f5139-e722-575a-94cf-170e1ada528c",
    "entry": "新大陸",
    "reading": {
      "primary": "しんたいりく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "New World (esp. the Americas, but also Australasia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地球が今の世代になって彼らを襲う危険の性質も異って来、かつての避難所ももはや意味をもたなくなったにもかかわらず、現在新大陸にいる駱馬は、死や危険の予覚を得た際には、皆必ず昔の彼らの祖先の避難所のあった場所を指して逃れようとするという。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリッシーの陶器製造に於いても、コロンブスの新大陸発見に於いても皆そうである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、問題は、ＦＭの世界では、まだ新大陸が発見されていないことだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから合衆国が新大陸に威張っている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの白奴交易網に引っかかった女の多くは、新大陸の植民地でその売春婦としての教育を卒業する。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの新大陸の發見なぞよりは遙かに遲れた後の發見である。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の薄暗い三等室には、トランシルヴァニア、モラヴィア、ヘルツェゴヴィア、ポドリア、シュワビア、カアランドなどという、聞いたこともない中世紀的な欧羅巴の隅々から、新大陸に憧憬れて亜米利加へ出稼ぎに行く移民の女達が、子供の寝顔を見守って物思いに耽っていた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へて云へばアメリカ發見即ち新大陸發見も決して偶然に起つたことではない。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論イタリーのコロンブスが發見したのであるが、彼をしてさういふ新大陸を發見せしむるに至つた最も有力なる原因は蒙古が起つたことと非常に關係して居る。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣く愛讀されるに從つて、愈※大なる刺戟を歐洲人に與へ、この刺戟が遂に新大陸の發見といふ世界史上の大事件出現を促す一大原因となつたのである。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて彼コロンブスは西暦一四九二年の八月のスペインのパロス（Palos）の港から出帆して西に向ひ、同年の十月に今のアメリカ大陸の西海岸に近いキユバ（Cuba）附近に到着して、所謂新大陸を發見といふ意外の大功名を遂げたのである。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しコロンブス自身は、歐洲とアジアの中間に、前人未知の新大陸の存在することなどは夢想もせなかつたから、彼の到着した土地は無論アジアの東端で恐らくマルコ・ポーロのヂパングであらうと確信して居つた。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が國を黄金國などとは、勿論訛傳若くは誇張としても、之が爲にコロンブスの新大陸發見の如き、歴史的に重大な事件を惹き起して居れば、この訛傳若くは誇張は、世界にとつて寧ろ幸福といはねばならぬ。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "地中海は曾て列國競爭の舞臺であつたが、新大陸發見と共にその時代は過ぎ去つた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊６　アメリカは、新大陸に神話を創り出そうともがき、ロシアは、旧大陸の神話を亡ぼそうともがき、地中海は、自分の神話をもてあまし、東洋は西洋の神話に媚を送り、西洋は東洋の神話を手にとって当惑する。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人はまず、この人間が、地中海産か、新大陸生まれか、シベリヤの落胤か、よく見究めた上で動かなくてはならぬ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "九・二七　　　　　＊44　新大陸について。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新大陸と機械文明とを呪ったボオドレェルは、近代に育てられたところの伝統の子である。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今まで狂熱に達していた彼の名声が、たちまちどさりと落ちて、広い新大陸に誰一人として彼と握手するものが無くなってしまったので、ゴーリキはやむを得ずそのまま亜米利加を去った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "メェフラワァは、約三百年前、信仰、生活の自由を享けん為に、欧洲からはる／″＼大西洋を越えて、亜米利加の新大陸に渡った清教徒の一群ピルグリム、ファザァスが乗った小さな帆前船である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商品化された巨大な流れの中に、ローマ法王からのがれて、新大陸にメイフラワー号で上陸した人々から生まれでたアメリカが一九五〇年代にいたって、世紀の新しい担い手となってくるということを、幾人の人が予見しえたであろう。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がヨーロッパを離れて新大陸の荒野に住むにしても、あの魔ものが渇望している同感の最初の結果は子どもの生れることだろうが、そうすれば、この悪魔の一族か地上に繁殖して、人間の存在そのものを、不安な、恐怖にみちた状態にしてしまうかもしれない。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は人種的迫害の事情の下に日本人の社会にも又米国人の社会にも接近する事が出来ず、唯だ独り遣瀬のない思ひを抱いて、新大陸の海岸一帯を蔽ふ松の深林ばかりを散歩してゐた。",
              "citation": {
                "source": "海洋の旅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば一度ニユーヨークに着して以来到る処燈火ならざるはなき此の新大陸の大都の夜が、如何に余を喜ばし候ふかは今更申上るまでもなき事と存じ候。",
              "citation": {
                "source": "夜あるき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "新大陸の方は、マヤの文明が花を開きかけた頃から、画面の中へ入れるようにするのも、一案である。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応旧大陸の方で国家間および民族間における弱肉強食の錯綜した動きを充分見せたところで、新大陸を登場させる。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンブスのアメリカ発見などというのは、映画が終る十分くらい前になって、やっと出てくるので、それまで新大陸の登場を待つわけにもいかないであろう。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠洲のシドニー・サン紙は、新大陸の発見者なりとおめおめ吐かす酔どれ水夫どもは鉄鎖に縛して海に投げこむべきにあらずや？",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ボードレール「航海」）　という詩の一句を報道に代え、新西蘭タイムスを通じて発表した新大陸発見の囈言を体よく黙殺してしまった。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャクルトン第一回南極探検に同行したことのあるシドニー大学のデヴィス教授だけは、いくぶん好意のある意見を発表していたが、知識も用意もなしに南極の岸に行きついた、日本人の無知の熱情に驚異の念を感じるといったくらいのところで、もちろん新大陸発見のことではなかった。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
