[
  {
    "uuid": "3956022d-4455-5235-a1a6-da90e4ea8554",
    "entry": "白々しい",
    "reading": {
      "primary": "しらじらしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
