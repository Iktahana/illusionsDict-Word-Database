    "definitions": [
      {
        "index": 1,
        "gloss": "the true, the good, and the beautiful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「わたしは真善美についてかいています。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみと、なやみにせめつけられ、真善美についてなにをいったところで、おおくの人には、牝牛にばらの花をくれたようなものでした。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる人間文化の意義は、宇宙に於ける意味に於て、真善美の普遍価値を発見することに外ならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛮野より文化に進みたるは左までの事にあらず、この至妙なる霊能霊神を以て遂には獣性を離れて、高尚なる真善美の理想境に進み入ること、豈望みなしとせんや。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒユーマニチーを人間に伝ふるは、独り地平線的思想の任にあらず、道徳は到底固形の善悪論にあらざれば、プラトーの真善美も、ミルトンの虚想も、人間をして正当に人間たる位地に進ましむるに、浩大なる裨益あることを信ずるなり。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "実在の真善美は直に自己の真善美でなければならぬ。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く考えて見れば世の中に絶対的真善美という者もなければ、絶対的偽醜悪という者もない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ありやうがあるべきやうであるとき、そこに真善美がある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし真善美の理想は終極するところ一つの理想すなわち人生終極の理想で Sollen の因って生ずるところである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらはプラトーが真善美とやらを説いたからとて、それに従はざるべからずとは思はず。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "混乱している犯罪の真只中へ飛び込んで行って彼の『霊妙なる直感』によって犯罪事件の解決をし、犯人を発見するように、広い芸術の曠野の中へ彼は堂々と這入って行って彼の『霊妙なる直感』に依って其処から『真善美』を掴んで来る……多くの芸術家の大概の者は何等かの性癖を持っているが夫れをホートン氏も持っている。",
              "citation": {
                "source": "喇嘛の行衛",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそのやうな気持のなかにどういふものがあるかといふと、それは今日日本でも倫理で教へてゐることで、所謂真善美といふやうな三つの要素に対する極めて純真な憧憬であります。",
              "citation": {
                "source": "大政翼賛会と文化問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが中等学校に行く頃、或は中等学校へ行かない者が家庭の仕事を手伝ひ、若しくは商店、工場等に働きに行くといふ頃になつて、自分の生活の中にこの真善美といふものを一体どういふ風にうち樹てるかといふことに就て迷ひだす。",
              "citation": {
                "source": "大政翼賛会と文化問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、政治の中に真善美といふこの三つの要素を目標とする一つの理想があるかないか、それが政治の現実の面で十分明瞭にさういふ青年たちの心に刻み込まれるやうにすることです。",
              "citation": {
                "source": "大政翼賛会と文化問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして古い習慣や道徳に自我の欲望を屈服させ同化させることを「大人らしい」やり方と考へ、さういふ諦めの中の静かさが本当の人間の最後の慰めであり真善美を兼ね具へたものだといふ風に考へるのだ。",
              "citation": {
                "source": "欲望について",
                "author": "――プレヴォとラクロ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術は如何なる時にも永遠なるもの、絶対なるもの、真善美のために戦はれてきた魂の足跡であるが、決してかゝる秩序の軽率な味方ではなかつた。",
              "citation": {
                "source": "エゴイズム小論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "真善美の三位一体を人間そのものに求めると、白痴にでも突き当る以外に手がなさそうだ。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "真善美などと大そうなことを言ってみても、その具体的な限界は案外そのへんにしかないように思う。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も気狂病院に入っているとき考えたのだが、真善美なんてもっと人間が進歩すると区別がなくなるだろうが、そのとき、今あるもので一番そういう状態に近づいているものはチエホフだと思った。",
              "citation": {
                "source": "スポーツ・文学・政治",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "真善美なんて過程と段階の区別はなくなって来るものなんだ。",
              "citation": {
                "source": "スポーツ・文学・政治",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちの理想は真善美と童貞マリヤの純潔を汚さぬ生涯にあつたのだ。",
              "citation": {
                "source": "母を殺した少年",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の理想は真善美と、童貞マリヤの純潔だつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間誰しも異性の長所というものは、本能的な理想として所有するものでもありそれが真善美の秘密の支えでもあるのだから、異性に扮し表するところの女らしさ、男らしさは全人格的な活動によって完成されるものであり、また純粋でもありましょう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも強いて一言でいって見るならば、真善美が兼ね具わっているというの他はない。",
              "citation": {
                "source": "良寛様の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる真善美を兼ね具えたものというべきであろう。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "真善美はつねに並べ称して人の理想とするところであるが、その性質を比較すると真と善美との間にはいちじるしい相違がある。",
              "citation": {
                "source": "いわゆる自然の美と自然の愛",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
