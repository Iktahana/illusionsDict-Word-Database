    "definitions": [
      {
        "index": 1,
        "gloss": "to wag one's tail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
