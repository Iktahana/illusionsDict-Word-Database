    },
    "definitions": [
      {
        "index": 1,
        "gloss": "family positioned to accede to the shogunate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「尤もそこは女だけに、将軍家の御落胤というほどの大きな触れ込みをしないで、男の天一坊ほどの評判にはなりませんでしたが、小さい女天一坊は幾らもありましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドド……胴と……足が……ベベベ別々に……ワワワワァ――ッ……」　時は徳川十一代将軍家斉公の享和二年三月十一日、桃のお節句以来、晴れ続いた朝のことであった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方を将軍家だ思うて、橋から青竹を差出します。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日、癸卯、晴、鶴岳宮の御神楽例の如し、将軍家御疱瘡に依りて御出無し、前大膳大夫広元朝臣御使として神拝す、又御台所御参宮。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、庚戌、将軍家御疱瘡、頗る心神を悩ましめ給ふ、之に依つて近国の御家人等群参す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿九日、己巳、雨降る、将軍家御平癒の間、御沐浴有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ただお一人、さきの将軍家右大臣さまの事を思ふと、この胸がつぶれます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御台所さまはそれを聞いて、え堪へず、泣き伏しておしまひになりましたが、尼御台さまは、なほも将軍家のお顔から眼をそらさず静かな御口調で、ご存じかの、とあのお方にお尋ねなさるのでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿九日、丁卯、兵衛尉清綱、昨日京都より下著し、今日御所に参る、是随分の有職なり、仍つて将軍家御対面有り、清綱相伝の物と称して、古今和歌集一部を進ぜしむ、左金吾基俊書かしむるの由之を申す、先達の筆跡なり、已に末代の重宝と謂ひつ可し、殊に御感有り、又当時洛中の事を尋ね問はしめ給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疱瘡が御平癒とは申しても、あれほどの御大病でございましたので、さすがに御余気が去らぬらしく時々わづかながらお熱も出ますので、そのとしは、鶴岳宮の一切経会、放生会、またその他のお祭りにも将軍家のおいでは無く、もつぱら御ところの御奥におひきこもりでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年目の、将軍家が二十歳におなりのとしの二月二十二日に、はじめてお参りなされたのでございますが、当時の人たちは、将軍家がそのお顔の御疱瘡のお跡をたれかれに見せたくなくて、お宮にも、おでましにならなかつたのだらう等と下品な臆測をしてゐたやうでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、ただ、将軍家が鶴岳宮の御霊に御遠慮なさつただけの事だと私どもは考へて居ります。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家のおたのしみは、お歌、蹴鞠、絵合せ、管絃、御酒宴など、いろいろございましたけれども、何にもまして京の噂を聞く事がおたのしみの御様子でございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と将軍家も微笑んでおつしやいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この清綱さまは、もともと御台所さまのお附きのお侍で、御台所さまはご存じのとほり前権大納言坊門信清さまの御女子、十三歳の御時に鎌倉へ御輿入に相成り、その時には将軍家も同じ十三歳、さぞかしお可愛らしい御夫婦でございましたでせう。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家の、しんから尊敬して居られた方は、御先祖の八幡太郎義家公、それから御父君の右大将さま、そのお二方のやうに私には見受けられました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子に乗つてとりとめの無い事ばかり申し上げて恐れいりましたが、とにかく、お若い頃の将軍家の御日常は決して暗いものではございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日、甲辰、和田左衛門尉義盛、上総の国司に挙任せらる可きの由、内々之を望み申す、将軍家、尼御台所の御方に申合せらるるの処、故将軍の御時、侍の受領に於ては、停止す可きの由、其沙汰訖んぬ、仍つて此の如き類、聴されざる例を始めらるるの条、女性の口入に足らざるの旨、御返事有るの間、左右する能はずと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二心なく将軍家にお仕へ申して居られまして、将軍家との間も極めて御円満の御様子に見受けられました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、五月のなかば、いいお天気の日でございましたが、尼御台さまは御奥へお越しなされて、将軍家と静かに御物語をなされ、私も謹んでお傍に控へて居りましたが、まことにのどかな、合掌したいくらゐの御立派な御賢母と御孝子、仕へるわが身のさいはひをしみじみ思ひ知りました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのお口元には、いかにも、お若い将軍家がお可愛くてならぬといふやうな優しい笑みをたたへていらつしやいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和田モ老イマシタカラ　将軍家は老忠臣の和田左衛門尉さまを、それまでも何かとごひいきになさつて居られました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、しかし、」尼御台さまには、そのやうに素直な将軍家を、おいとしくてならぬのでございませう、将軍家のお気をお引きたてなさるやうに殊更に高くお笑ひになつて、「御父君は御父君、和子には和子の流儀もあらうに、ま、それからさきは女子の差出口など無用になされ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴い、謂はば霊感に満ちた将軍家と、あのさつぱりした御気性の上に思慮分別も充分の相州さまとの間に、まさか愚かな対立など起る道理はございませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓の試合は将軍家も心から楽しさうに御覧になつて居られました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家は、賑やかな事がお好きでございましたから、何かにつけて宴をおひらきなされて、皆の遊びたはむれる様をしんから楽しさうに、にこにこ笑つて眺めて居られます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうも私は宴会は苦手で、」と入道さまはちらと将軍家のはうを見て、「武芸のあとの酒盛りならまあ意味もあつて、我慢も出来るといふものでございますが、なんともつかぬ奇妙な御酒宴もこのごろは、たくさんあつて。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのことが　いつか　しょうぐんけにも　きこえました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
