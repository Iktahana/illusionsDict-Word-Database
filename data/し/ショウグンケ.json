[
  {
    "uuid": "d1513119-b55e-559d-8407-a68477f5430a",
    "entry": "将軍家",
    "reading": {
      "primary": "しょうぐんけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
