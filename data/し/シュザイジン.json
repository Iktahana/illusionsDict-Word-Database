        "examples": {
          "standard": [
            {
              "text": "空港の到着ロビーは、凱旋帰国した金メダリストを待ち構える膨大な数の取材陣で埋め尽くされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい表情を崩さない監督を、大勢の取材陣が幾重にも取り囲んで容赦のない質問を浴びせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記者会見の開始数分前、取材陣の間でマイクの設置や照明の調整が急ピッチで進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ライフ」の取材陣が来訪予定である。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
