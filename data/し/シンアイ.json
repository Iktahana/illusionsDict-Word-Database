[
  {
    "uuid": "b21f465d-ceb9-587d-9b82-f3def76a251c",
    "entry": "信愛",
    "reading": {
      "primary": "しんあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
