[
  {
    "uuid": "7d4563b1-f243-5565-9297-26330acd6422",
    "entry": "神聖視",
    "reading": {
      "primary": "しんせいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
