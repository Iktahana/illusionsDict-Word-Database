[
  {
    "uuid": "866ced44-14e0-584c-b52d-7513f82a6e7f",
    "entry": "新兵",
    "reading": {
      "primary": "しんぺい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
