[
  {
    "uuid": "cd186503-d91e-52ef-ad75-214541a3292a",
    "entry": "暹羅",
    "reading": {
      "primary": "シャム",
      "alternatives": [
        "シャムロ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
