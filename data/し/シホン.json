[
  {
    "uuid": "4e31954f-93ab-56f4-8e9e-ef8cc74e9479",
    "entry": "資本",
    "reading": {
      "primary": "しほん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
