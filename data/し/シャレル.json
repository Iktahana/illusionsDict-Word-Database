[
  {
    "uuid": "9d37f5ee-418b-5738-9147-8aa797b1440f",
    "entry": "洒落る",
    "reading": {
      "primary": "しゃれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
