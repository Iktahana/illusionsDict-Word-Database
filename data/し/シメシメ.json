          "literary": [
            {
              "text": "縄帯をしめしめ当もなく小走りにあるいてる若者もあつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると松次郎はしめしめ、といった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し思い知らしてやるのだ」といって、一しめしめたところ、法師は泡を吹いて気絶した。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでだよ、まずこれでしめしめ、五十両は二つ分け、二十五両ずつまんまとふところにしまっておいて、いっぺえ祝い酒をやろうかいと、ところもあろうに道のまんなかで飲みだしたその酒が、あにはからんや毒酒だったのよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "めぐりあい「しめしめ、電気鳩をうごかすきかいが手にはいったぞ。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめしめ」　西尾は側の机をコツコツと叩いてみたり、抽出しを開けてみたりした。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラジル焼酎を飲りながらアマゾン奥地の、「神にして狂う」河の話をきっとやるだろう……と私は、しめしめとばかりに舌なめずりをしながら、彼の開口を待ったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラジル焼酎を飲りながらアマゾン奥地の、「｜神にして狂う」河の話をきっとやるだろう……と私は、しめしめとばかりに舌なめずりをしながら、彼の開口を待ったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめしめ、出てきたら胴上にしちゃえ」　珍らしい物、珍らしいことを、何よりも好んでいた江戸の人々は大作の放れ業を、大胆さを、渇仰して、超人のように称え出した。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ大通へ出られないのかなア」「早く円タクでもつかまえないと駄目だぞ」「ああ、しめしめ。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめしめ、これですてきなごちそうにありつける。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめしめ」「お前んところに、チーズはないか」「そんなもの、とつくにありませんよ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョーカがいいの」「浮気させてもらって、背広をもらう、しめしめだ」「浮気出来なくて、真珠をかわされるあなたは、ちっとかわいそうだこと。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しめしめ」　鉄瓶のお湯をひとたらし、二たらし、いよいよ羊羹をグジャグジャに溶かせ、そいつをお六の頭のなかへ、めちゃめちゃに塗り込んでいった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめしめ　――　これで　きまり　――　はたして　ねらった　いじょうの　できばえです。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこへ、入口の方から笑いながら、ヨロヨロと小走りにもどって来る花岡）花岡　ヘヘ、しめしめ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しめしめ、是で川本の奴をあっと云わせてやれるぞ」　伊藤青年は本部へ無電を打ちながら、会心の笑をもらすのであった。",
              "citation": {
                "source": "流血船西へ行く",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボッと景気のいい音を立てて燃え上った青い炎の上に、しめしめと手をやると、もちろんいい加減離れた上へやったのだが、――熱い。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から水を飲み通しで、一時間おきぐらいに小便が出るようになって、しめしめと俺はほくそ笑んだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しめしめ」　と照彦様が手をたたいた。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五点」「しめしめ」「つぎも二十五点の問題です。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかして、儂が彼女に対して何かのサインを見せたら、この強欲女どもがしめしめとそれを利用して儂の狂気を立証してしまう、そんな事態を恐れたために彼女は儂から離れていったのではないだろうか。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
