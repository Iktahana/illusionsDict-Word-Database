[
  {
    "uuid": "1b89a148-35f6-5f6f-ba19-ba471af5200c",
    "entry": "商才",
    "reading": {
      "primary": "しょうさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
