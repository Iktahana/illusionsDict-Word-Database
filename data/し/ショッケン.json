[
  {
    "uuid": "a1c0dc3c-4251-5309-afcc-b69f9c865339",
    "entry": "職権",
    "reading": {
      "primary": "しょっけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's (official) authority",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正に上司の儀容であるが、勿論職権止むを得まい。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊後、大目付の職権以って申し付くる。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に対して職権を示そうなどとは勿論かんがえていないので、わたしは個人的に打解けて訊いた。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が余を大統領に選定したにしろ、余は大統領たるの職権を信ずるところに従って振うばかりである」ゼルコフ「きさまは気が変になっているんだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "次期大統領の改選あるまで、臨時に大統領の職権を行使する。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは獅子文六という方は喜劇を経験したでしょう　〔以下四枚分欠〕　きのうの読売に各地人権擁護委員会に訴えられた人権蹂躙事件の五〇パーセントは警官の職権濫用であった。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「結論的に私が申しあげたいのはわれわれを被告としたあの検事諸君こそまさに公務員法違反であり、職権乱用の非国民である。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうなれば、職権上そのまま看過しがたいところである。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴動の一種だと言うので、知事の職権でミシガン州国民軍フリント支部が非常召集されて群集に当っている。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡検使の職権で純之進が大吟味を試みた結果、奇怪なる犯罪が暴露した。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは判事の気持ちを被告の孤独な気持ちの中へ全く職権から放れて入り込ませるのに力があつた。",
              "citation": {
                "source": "マルクスの審判",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に本官は今日只今職権を以てこの手段をこの法廷に強いようとするものではない。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれに致しましてもその人格に於て、又はその名声に於て、天下に嘖々たる若林博士が、九大医学部長の職権を利用しつつ、念を入れ過ぎる位に念を入れて仕上げた仕事ですから誰が疑点を挿み得ましょう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ですから君等の職権で、勝手な報告を作って出されたらいいでしょう。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨロシイお前が男を立てたなら俺も男だ、職権を捨てゝまでもお前の妻子を助けてやろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「必ずしもそうではありませぬ」「然らば裁判長は職権を以て、証人が支倉より聞知した告白を、当法廷に於て陳述する事を要求する」　宮木判事はきっと宣告した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主君の愛妾の兄の家ゆえに、町奉行の職権を犯してまでも、処置をしに参ったか？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、既往の損害は、行政官たるもの、何等の処分をなすべき職権なし。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　というようなことから始まって、車掌は職権をかさに呶鳴りたてる。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この明治三年は朝廷から再度の藩制の改革があって、これまでの大少参事の外、大属少属、史生、庁掌、を置かれて、なお、藩知事の職権も制限せられ、或る事件以上は一々朝廷の指揮を仰がねばならぬという事になった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに軍事または外交に従事する人々は、たとえ大いにその手腕を揮わんとしても職権以外に出られぬ。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この動物はなぜここに集めてあるのですか」　長戸検事は職権をふたたびふるいはじめた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは室内をいちおう捜査しますから、さようにご承知ねがいたい」「職権をもってなさるのですから、とめることはしません。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はあわてて警部を戸口に近いところへひっぱって行き、「こまるですなあ、そう大きな声を出しては……」「職権を行使しているのに対し、きみはそれをとやかくいう権利はない」「こまった人だ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "職権をもっておたずねいたしますが、ここに怪人がいたはずですが、今どこにおりますか。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件に関し本員は、既に世上の問題となりたる禁止不法の批難を、ここで繰り返さうとするものではありません……本員はただ検閲官が、その職権を行使するに当つて、果して十分なる配慮と機宜を得たる処置を取られたかどうかといふ点について、一般の注意を喚起したいと思ふのであります。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "職権をもつて、取締りができぬわけはなささうに思はれる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の容貌は職権を有する人に適当するように、自然に馴らされたのか、あるいは強いて粧っているのか知らないが、一方に厳正を示すとともに、むしろ人好きのするようなふうであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "妖物",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
