    "definitions": [
      {
        "index": 1,
        "gloss": "there's no (other) way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "牧野は酔ふと仕方がないといふのが牧野さんの周囲の人達の定説であつたのでもあらう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は胃酸が込み上げて来さうで仕方がない。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仕方がない』などと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから聖書を出して読みはじめたのだが、何処を読んだのかチツトも記憶がない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは無理からぬことであるから仕方がない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仕方がない、もう好い！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉弾で歌ふより仕方がないのだ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私自身まだ相対界が好きなのだから私は無頼漢の奴隷になつてなくちやならなくとも仕方がない。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではどうにも評論の仕方がない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僕らの日本人が、日本の文字で直接に読み、日本語の発音で朗吟し、日本の伝統で味覚する外に仕方がないのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷を綿入に着かえて重くるしいのに裾が開きたがって仕方がない。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長の処へ挨拶に行ったら、仕方がないまたやるさと云ってくれた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の試験にしくじった時もやはり仕方がないと思ったが、その時の仕方がないと今度のとは少し心持が違う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年のは何処か快活な、希望の力の籠った「仕方がない」であったが、今度のにはもう弱い失望の嘆声が少し加わったように思われる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに俺に食ってかかったって、仕方がないじゃないか、な、ちゃんと嘆願さえすれば、船長だって涙金位寄越さないものでもないんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆やられたんじゃ仕方がないからな。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小品は気分本位の夢幻的なものであって、必ずしも現行の法令に準拠しなければならない種類のものでもないし、少なくも自分の主観の写生帳にはちゃんと青い燈火が檣頭にかかったように描かれているから仕方がないと思ったのである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日かいた繪を見ると、繪の下の方に此の布切れがぶら下つて居るやうな氣がして仕方がない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "利慾の外に何物もない人達が戰時の風雲に乘じて色々な際どい仕事に手を出し、それが殆んど豫期された筈の變動の爲に倒れたのはどうにも仕方がないとしても、さういふ人の妻子の身の上は考へて見れば氣の毒である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦揺れの方は今日では別にこれを防ぐ工夫がないようで、物足りないが仕方がない。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片親の父に相談してみても物堅い老舗の老主人は、そんな赤の他人の白痴などに関まっても仕方がないと言って諦めさせられるだけだった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧するのが面倒でしないのは仕方がない。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能的なものが運命をそう招いたと思うより仕方がない。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒の老成後の倫理道徳観が中学校で教わった所と如何ほど懸隔しても仕方がない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に書いてしまったものを今更悔いても仕方がないが、一度慚愧の念に襲われては、何事にも無頓着なる予と雖も、さすがに躊躇するのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更二人を叱って見ても仕方がない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は可哀相だけれど……もう考えまい、考えたって仕方がない、学校学校……」　独口ききつつ眠りに入った様な訣であった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は学校へ行ってからも、とかく民子のことばかり思われて仕方がない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になっても寝ると仕方がないから、なるたけ人中で騒いで居て疲れて寝る工夫をして居た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でも盆踊りというとその夜を思い出すが、不思議な錯覚から、その時踊っていた妖精のような人影の中に、死んだその人の影がいっしょに踊っていたのだというような気がしてしかたがない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
