        "examples": {
          "standard": [
            {
              "text": "彼は自らの信念を首尾貫徹し、ついに夢を実現させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一度決めたことは首尾貫徹するのが我が社の社風です」と社長は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "議論において首尾貫徹することは、相手の信頼を得るための第一歩だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "此の如き考の起るのは、つまり触覚が他の感覚に比して一般的であり且つ実地上最も大切なる感覚であるから、この感覚より来る者を物の真相となすに由るので、少しく考えて見れば直にその首尾貫徹せぬことが明になる。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら氏の魅力は決してその思想の首尾貫徹にあるのではなくて、却って外部から来る諸思想の新陳代謝にあるからだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
