[
  {
    "uuid": "b5c8f1e6-cbc2-5728-9bba-c64d042ababf",
    "entry": "詳論",
    "reading": {
      "primary": "しょうろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
