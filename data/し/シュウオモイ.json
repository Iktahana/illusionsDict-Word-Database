    "definitions": [
      {
        "index": 1,
        "gloss": "worrying about one's master's affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
