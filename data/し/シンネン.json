[
  {
    "uuid": "c94487b6-6571-57dd-95a6-f2cd9dadc372",
    "entry": "信念",
    "reading": {
      "primary": "しんねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
