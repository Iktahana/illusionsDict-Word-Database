[
  {
    "uuid": "e9def7f3-b720-5efb-bac4-71853dba9f98",
    "entry": "娼婦",
    "reading": {
      "primary": "しょうふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
