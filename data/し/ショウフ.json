      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prostitute",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからまた女の結髪が昔の娼婦などの結うた「立て兵庫」にどこか似ているのも面白い。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波うつやうな髮の上に紫いろの帽子をかぶつた娼婦たちも近づいてくる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娼婦たちははげしく挑まれるので、着物なぞも破けてしまふ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の前身は外人相手の娼婦なので、魑魅子には東洋の古典の絵巻にあるような繊細なこころは、あいにく持っていなかったが、女取引所にあらわれる体温によって花咲いた男性の手管を、侵略に委せて刺青した、肉体的異国的な地図と感情を失ったエモーションの波、そこに愛情の新らしい鋳型を僕は見出すのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――……あなたを娼婦として、僕はおつき合いしたいんです。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると、天界ホテルの海辺に面したダンス・ホールで、マリを先頭にして十三人の娼婦が一列に並んで健康のための体操をはじめたが、何故かお六ひとりその列に見えなかった。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "詠仙里の娼婦だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娼婦はすっかりあわてゝしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅い着物の娼婦達は、もう沢山というのに、なおも一ツずつの握り飯を強いられていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときふと邪慳な娼婦は心に浮かび、喬は堪らない自己｜嫌厭に堕ちるのだった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁夫や税吏や娼婦やマグダレナのマリヤやザーカイやの間にまじつた基督の顏を見る樣に思つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予てうわさの、宿場の娼婦と寝たんべい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、そのようなことを平気でする芸者や娼婦すら、こういう男の気持を、単なる移り気だと見て、責めるのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉にとっては、ブルジョワの娘も、長屋の娘も、いや、娼婦もたいした変りはない筈だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小菊と松島との情痴の物語は、単に情痴といって嗤ってしまえないような、人間愛慾の葛藤で、それが娼婦型でないにしても、とかく二つ三つの人情にほだされやすいこの稼業の女と、それを愛人にもった男との陥りやすい悲劇でもあろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵そう言うけれど、君は娼婦型でないから、それはそうだろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば吾々は、西洋人がその一人の女に課する二つの要求――家庭に於ける母性と社交に於ける娼婦性――とを、初めから厳重に分離されて、家庭には妻をおき、社交界には芸者をおき、夫々別々の分業観から専門に教育して来たのである。",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら一人の女について、矛盾した二つの情操（母性型と娼婦型と）を要求するのは、概ね多くの場合に於て、その両方を共に失ひ、家庭の母性としても完全でなく、コケツトとしても不満足であるところの、不幸な物足りない結果になるから。",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に商店の番頭のＹは、非常にセンチメンタルな調子で、ある娼婦と心中未遂に到るまでの捨て鉢な戀の告白をしました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娼婦の涕は紅涙と賞へられ、狼心の偽捨は慈悲と称へらる。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら寡婦のうち衣食に窮するままに、辺境守備兵の妻となり、あるいは彼らを華客とする娼婦となり果てた者が少なくない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之はかなり立派で、止り木にとまつたまゝうつら／＼とうたた寢するところなど、仲々に澁いものがあり、娼婦の衣裳を纏うた哲學者だ、などと喜んでゐたのだが、到頭餌のやり忘れで死なせて了つた。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子組合の共同家屋に未婚の女が泊り込んで、炊事をする傍ら娼婦の様な仕事をするのである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻があれ程淫奔で、娼婦が斯くも貞淑だという事実は、卑屈なギラ・コシサンにも竟に妻の暴虐に対する叛逆を思い立たせた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴女には、聖母のような清らかさと、娼婦のようなエロがあるんだって！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供と油断したが、これは天性の娼婦である。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉興に羅愛愛という娼婦があったが、容貌も美しければ、歌舞音曲の芸能も優れ、詩詞はもっとも得意とするところで、その佳篇麗什は、四方に伝播せられたので、皆から愛し敬われて愛卿と呼ばれていた。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それが娼婦と淫売婦とに限られてあった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つはすなわち麩、その残りの粗悪品からは、糊にする生麩（しょうふ）ができた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（むらまつ　しょうふう、三三・一〇）",
              "citation": {
                "source": "猫料理",
                "author": "村松梢風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
