    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cause of victory",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その行軍の眼にも止まらぬ早業が、あの戦の勝因だつたのです。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子爆弾が一つの勝因ではあったであろうが、考えてみれば、勝利の決定的要素は、この十万人の研究組織をつくることのできたアメリカの国家機構の壮大なる運営才能であったというべきであろう。",
              "citation": {
                "source": "歴史の流れの中の図書館",
                "author": "――個人的なものから集団的なものへ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
