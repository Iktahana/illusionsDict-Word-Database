    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(music of) wind through pine trees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しのびで、裏町の軒へ寄ると、破屋を包む霧寒く、松韻｜颯々として、白衣の巫女が口ずさんだ。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝｜琴平町、松韻社。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間の松韻亭は、翠簾をかかげ、水を打ってあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
