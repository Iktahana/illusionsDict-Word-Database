        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正面玄関の上り口では、やっと閑散の身になった案内係の少女達が他愛もないおしゃべりに夢中になっていました。",
              "citation": {
                "source": "気の毒な奥様",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お子様が急病だそうです、至急正面玄関へ。",
              "citation": {
                "source": "気の毒な奥様",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらからも、こちらからも立派な紳士が立ち上って正面玄関へ殺到しました。",
              "citation": {
                "source": "気の毒な奥様",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとすぐ、何かカチャリという音を耳にしたのですが、どうも正面玄関の蝶番のようで。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを上がった踊り場は、正面玄関から上がれる飾り立てられたもうひとつの階段の反対側に当たる。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の考えでは、講師は正面玄関から戻ってくるから、姿が見えるはずだった。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてうねり曲ねつてゐるうちに、ホテルの本館正面玄関から、左手の日本館へと引込まれた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの方には甚だ失礼ですが、これから、正面玄関で全部の方の身体検査をします。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三場青木邸の正面玄関、芦田、牧、ほかに七八名の警官が、出てゆく男女の客の身体検査をしている。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "テラスの外も、正面玄関の平面より一階ぶんはさがっていて、これまた、テラスわきの階段からおりるか、寮の周囲をめぐる、ローラーコースターのように、曲がりくねり、上下する、舗装道路から入っていくようになっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからもめるんだよ」　靴を履きかえるわけではないが、寮長室と事務室にはさまれた正面玄関を、土足で強行突破するわけにもいかないので、慶一は儀式的に下足室を通り抜けながら、靴拭きを蹴飛ばし（これでドロが落ちることもある）、簀の子を踏み鳴らしてホールに出た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま一階の廊下を突っきって、反対端の非常口から出るのと、中央の正面玄関から出て、外をいくのと、どちらが目だたないだろうか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちんと、窓やヴェランダのドアのカギを締めるよう指導されているし、正面玄関も非常口も、消灯をすぎれば錠がおろされる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆れたことに、非常口やヴェランダのように、人目につきにくい場所ではなく、高志は堂々と正面玄関の錠をはずしにかかったらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "テラスから部室のヴェランダにいこうとしたが、もうどうでもよくなり、テラスの手すりにもたれて、正面玄関側を見おろした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は左に花壇のある石段を登り、日本信徒発見記念のマリヤ像の立っている正面玄関の右手扉を云われた通りに押して見た。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い木の門を入ると、細長い石が行儀よくしいてあって、お寺の正面玄関につづいている。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾条もの赤旗で飾られた正面玄関の石段に立って、群集と一緒に街の上手を見渡すと、来るゾ！",
              "citation": {
                "source": "勝利したプロレタリアのメーデー",
                "author": "――モスクワの五月一日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川は私の所持品を調べたのち、「さ、留置場へ行こう」　先に立って高等室を出、警察の正面玄関横から登る階段とは違う狭いガタガタした裏階段を下り、刑事室の前に出て、右手つき当りの鉄格子入りのくもり硝子の戸をコツコツと叩いた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左近はゲラの包みをポケットにねじこんで、勇みたって広大な住田邸の正面玄関を訪れた。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面玄関の間には、両側に出迎への面々と思ぼしい男女、いづれも、魚族のいづれかを形どつた衣裳を纏ひ、長い廊下や、途中のいくつかの広間には、ところどころ、護衛が立つてゐて、恭しく敬礼する。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸っぷちに、神奈川県の警察部の自動車がいるでしょ……あたし、なんだか、恐いのよ」　正面玄関の土間で、髪をとばされないようにネッカチーフで頬冠りをすると、ガラス扉にうつった姿は、それなりにショウバイニンのスタイルになっている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話では、すまないことなんだよ……あいつらが集めていた赤札（軍票ドル）を、青札（本国ドル）と換えてやったら、それがガン札だなんて、ムチャな言いがかりをつけるんだから……」　正面玄関の扉があくたびに鳴るブザーが、ほのかな音をつたえた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の木曜日に、伸子はその正面玄関の黒くよごれた鉄唐草の車よせの下から入って行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的な十月の夜、コサック革命軍の機銃にまもられていたスモーリヌィの正面玄関の柱列や、銃をかかえたまま無数の人々がそこを駈け上り駈け下りした正面階段には、伸子たちがのぼってゆく一九二八年の六月の或る朝、夏の爽やかな光線と、微かに夏草のにおう微風があった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後に私は一階までエレベーターでひそかに下降して、正面玄関と玄関から道路のすじみちをしらべ上げ、逃亡にまよわないように見て廻った。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面玄関の脇の、便所の隣りのその小部屋には、朝も昼も夕方も、まるっきり日が当らなかった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使頭のグライスは、どこにいても珍らしいほど無口な胆汁質の大男だが、正面玄関のホールを歩きまわつたり、ときにはポーチの横の窓から表の白い道が海のほうに伸びているのを見たりしながら、なんとなくおちつかないようすであつた。",
              "citation": {
                "source": "緑色の人",
                "author": "THE GREEN MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちのいるのは正面玄関の向って左手の二階。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つき当りの自動車のとまっているところが病棟の正面玄関です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
