    },
    "definitions": [
      {
        "index": 1,
        "gloss": "main wings (of an aeroplane, airplane)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翌日、早くから工場へやってきたので、主翼工程の管理をしている技師に預け、硬度計をあてて形材の硬度を計る、簡単な仕事をやらせていたが、それから一と月ほどしたある朝、柚子のことで、憲兵の訪問を受けた。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼の先端がケインを斜めに押しのけ、畑にめり込んだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "首がなかったり、主翼の端が欠けていたりする。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "気味の悪いほどに大きな主翼だけを持った怪獣が、海の底から飛び立とうとしている前触れのようだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い船体のような胴の背に、主翼を背負っていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼には片側二基ずつ、四つのプロペラ・エンジンがついていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼の端にフロートがひとつずつ下がり、水平尾翼は垂直尾翼の頂上に一直線だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼のちょうど下あたりで胴体はもっともふくらんでいて、そこからまっ白く、飛沫が機体の両側へ斜めにあがった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴体の最前部から後尾にかけて、そして主翼の両端のフロートが、いっせいに海面を削った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着水時に胴体が跳ねあげる大量の海水を、いかにして主翼のプロペラに当てずにおくかが、飛行艇を設計するときの重要なポイントになる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼の下のドアが開いた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔を感じさせるずんぐりした胴体に、左右一基ずつエンジンのついた、いかにもバランスのよさそうな主翼には、誰もが懐かしさを禁じ得なかった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＣ―３の主翼のうしろにドアがある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客機の玩具に主翼を取りつけたり」「若いのに色気がある。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右等しい路面の広がりは、カワサキと一体になったぼくの体から主翼をのばしたような安定感を、ぼくにあたえてくれる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼は、錯覚のなかで、ぼくを路面から離陸させてくれる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
