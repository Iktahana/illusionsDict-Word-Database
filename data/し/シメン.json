[
  {
    "uuid": "04da9d22-bfe0-5d30-a784-77c18cde8ced",
    "entry": "紙面",
    "reading": {
      "primary": "しめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
