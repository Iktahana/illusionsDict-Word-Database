    "definitions": [
      {
        "index": 1,
        "gloss": "posthumous name (based the deeds one has performed in their lifetime)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今ノ人諡号墓銘等ニ於テ諛媚誣罔、毫モ其ノ人ニ倫セザルノ標目ヲ以テスル者徃々少ナカラズ。",
              "citation": {
                "source": "青塚ノ説",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藁屋文集」の「奉斎祀本居桜根大人而於大前祈白詞」によれば、八月頃に、宣長大人の教へ子田中翁の許に行つて、長い疑問を問ひ訊し、更に桜根大人の諡号を書いて貰つて帰国した。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諡号して聖武天皇といふ。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国｜未曾有の仏法を興隆した聖徳太子とは、厩戸皇子の諡号にほかならない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇の御｜諡号も光孝天皇までなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の帝紀御撰述、諡号御定め等、勅諚にて学習院に抑付けられたき事なり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土手と柵とに拠って武田勢の進出を阻み、鉄砲で打ちひしごうと云うのであるが、岐阜出陣の時、既に此の事あるを予期して、兵士に各々柵抜を持たしめたと云う。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
