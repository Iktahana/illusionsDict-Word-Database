    "definitions": [
      {
        "index": 1,
        "gloss": "four sides (boundaries) of a property",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
