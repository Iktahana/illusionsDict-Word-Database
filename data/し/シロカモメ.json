        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二度目の津軽海峡は、波高く風すさび、白鴎絹を裂くが如く悲鳴して、行きし時には似ぬシケ模様に、船は一上一下さながら白楊の葉の風にひるがへるが如く、船室は忽ちに嘔吐の声｜氛々半余歳、塵臭漸やく脱し難からむとするに至つて、乃ち突如として帰去来を賦しぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて又、遠く上りて、また白鴎の如し。",
              "citation": {
                "source": "南洲留魂祠",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚下山雉の渡を帆かけて行く渡舟、さながら白鴎の如く、矚目爽快を極む。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をあげると、潮の満ちた川の上を、白鴎の群が縦横に飛びまわっている。",
              "citation": {
                "source": "緑衣の女",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "差出人は白鴎社・雑談会・立野智子女史とあり、曰く、インチキ文学｜撲滅論（枚数十五枚）を書くべし云々とある。",
              "citation": {
                "source": "インチキ文学ボクメツ雑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは明朝に至るを俟つて品川湾頭に飛ぶ白鴎に問ふ可し十二月十二日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "采女橋を渡るに白鴎羣をなして溝渠に浮び餌をあされり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て浅草代地河岸に住みし時、二月三月の頃には白鴎屡羣をなし人家の屋根をかすめて飛ぶを見たり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔禁奢令出デテ城中粛タリ／復ビ遊船ノ水津ニ簇マル無シ／好在白鴎沙上ノ月／最モ円ナル夜ハ最モ閑ナル人ニ属ス〕　十二月二十四日は枕山が父竹渓の十七年忌に当るので、梅痴上人は枕山のために竹渓父子の知人を増上寺の学寮に招いで盛大なる法筵を営んだ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "池のあたりを見廻すと、折柄春風に小波が立ち、紫鴛白鴎が楽しげに飛び交いしている。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め鉄牛の門をおとずれたが『美人すぎるから駄目駄目』と断わられ、白鴎を師としたが、居るうちにやはり弟子を過まるからと断わられ、その後は自力で大成し、江戸郊外の落合村の泰雲寺に住み六十六で終っている。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
