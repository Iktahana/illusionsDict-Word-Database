[
  {
    "uuid": "02750d66-1b14-518d-80d8-423b3e1bd2d6",
    "entry": "志徳",
    "reading": {
      "primary": "しとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Shitoku era (of the Northern Court; 1384.2.27-1387.8.23)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――法律も何もないシベリアでウンとおたのしみをしとくんだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな土を遊ばしとくんは勿体ない。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなずるい手段で来ると知っとりゃ、前から用意をしとくんじゃったのに……。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「支配人がやる商売ならどんなに大げさにやらかしたって、一向、見て見ぬ振りをしとくって云うんだが、親爺のようなぴい／＼のするこたア、いけねえって云うんですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が、しょっちゅう、こいつをキュウキュウさしとく必要があるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、五日も六日も、そのまゝ放たらかしとくなんて、平気でそんなことがぬかせる奴は人間じゃねえぞ！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家だって、千歳さんが慶四郎さんとは一番遠慮なくしてたんだから」「でも、お父さまが、どう仰有るかしら」「それは、私がとりなしとくわ」　千歳は、姉のいう言葉が、いちいち尤もだとは思った。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸では不可えや、前垂を貸しとくれよ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――でも今お貰いが掛ってせかれてまっさかい、今夜のとこはかんにんしとくれやす。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いま、返しまっさかい、堪忍しとくなはれ」「ふーン」　小沢は思わず亀吉の黒い顔を、黒い顔だなアと微笑しながら、見つめた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「下手くそやぞ、お前らの掏り方は……」「今夜はじめてだす」　次郎は蚊の鳴くような声を出して、「――かんにんしとくなはれ、大将」　と、ぺこんと頭を下げた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そや、お前らわいを掏りけつかったさかい、監獄イ行かんならんぞ」「かにしとくなはれ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけはかにしとくなはれ、カンゴクだけは……」「ほな、刺青をするか」　針助の声は急に凄んだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は両袖を胸へ抱え上げてくるりと若い料理教師に背を向けながら、「参ったことにしとくわ」　と笑い声で応けた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病人に何だって、こんなばかなことをさしとくのだ」鼈四郎はモデルの娘に当った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳だが親はもう働かせながら勉強さしています」　青年が何気ない座談で聞かせて呉れたその言葉は、かの女に、自分がむす子に貢いで勉強さしとくことが、何かふしだらででもあるような危惧の念を抱かした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を関いつけないときは、幾日でも平気でうっちゃらかしとくが、いざ関う段になるとうるさいほど世話を焼き出す、画描き気質の逸作は、この頃、かの女の憂鬱が気になってならないらしかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、少年男女をこういう自然の中に放ち飼いにしとくと遂にこうなるのでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると嘉六はわたくしを呼び止めて振返えらせ、「始めにお話しとくのを忘れましたが、あなたの捜索のことやら、それにばあさんが歿くなって家が寂しいことになるので、自分はこちらのおふくろさんのお勧めにより、当分、こちらに引移ることになりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――楓はお洒落で、幹を裸で天日に曝しとくのを嫌う。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りあたしも身状は正しくしとくから」　わたしはこれも承知した上、かの女自身の誓いをも信じた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あっけにとられている他吉を押しのけて、「わてが炊きま」　竈の前にしゃがんで、懐ろから紐をだして来て、たすき掛けになり、「あんたはあがって、懐手しとくなはれ」　五十一ときいたが、竈の火が顔に映って、随分若く見えた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとうちにも抱かしとくなはれ」　赤ん坊を抱かせてもらった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あとで、主人がお邪魔するかも判れしまへんさかい、なんぞ帳面づけの用事でもあったら、さしとくなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよなら、精落さんようにしとくれやっしゃ」　蝶子が玄関の戸をあけた拍子に、君枝の眼に空がうつった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄ちゃんはただにしとく」　ハアハア息を弾ませながら、娘は言った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ない」「ほな、任しとくれやすか」「うん」　私は乾いた声で言って、塩の味のする茶を飲んだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話帳に本名を出しとくような狐狸とは段違いの怪物だからウッカリした事は出来ないと思ったからだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東煮屋をやると聴いて種吉は、「海老でも烏賊でも天婦羅ならわいに任しとくなはれ」と手伝いの意を申し出でたが、柳吉は、「小鉢物はやりまっけど、天婦羅は出しまへん」と体裁よく断った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと直ぐ降りて来て、「どうぞお二階へお上りやしとくれやす」と言った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
