          "literary": [
            {
              "text": "何は措ても、余所ながら真砂町の様子を、と思うと、元来お蔦あるために、何となく疵持足、思いなしで敷居が高い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、その他の言語と比較すると、日常的に人間が使っている言葉とはもっともかけ離れており、学ぼうとする者には敷居が高い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ、敷居が高い、御無沙汰、御無沙汰！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守じゃ仕方がない」　と何うも敷居が高い。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
