        "examples": {
          "standard": [
            {
              "text": "植物の葉の付き方には、らせん状の斜列が見られることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この植物の葉序は、典型的な斜列を示しており、フィボナッチ数との関連が研究されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「図鑑で、葉の並び方の斜列について調べてみたんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
