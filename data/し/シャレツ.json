          "literary": [
            {
              "text": "すると全体の車列も止まり、十人ばかり何事かと前に出てきた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎馬隊や歩兵の一部はたちまち馳けおりてまた向うへ登って行ったが、鈍々たる猛牛の鉄車隊は、やや遅れたため、車列一団になって、そこを越えかけた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
