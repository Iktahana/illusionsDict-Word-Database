    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうした田舎の塵塚に朽ちかかっている祖先の遺物の中から新しい生命の種子を拾い出す事が、為政者や思想家の当面の仕事ではあるまいかという気もする。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠が上り下りして、森らしくなる、杜鵑がしきりに啼く、湯治の客が、運んだ飜ぼれ種子からであろうが、栂の大木の下に、菜の花が、いじけながらも、黄色に二株ばかり咲いていた、時は七月末、二千｜米突の峠、針葉樹林の蔭で！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい自分の望む種子さへ播けばひとりでにどんどんできます。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの言葉の内容はもはや箇々の物件を離れて、それぞれ一つの「学」の種子になっている。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでない場合でも、何かしら考える事の種子くらいにはならない事はあるまい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前の講義を聞いていると、たった今、朝食のときに吾々の話していた問題がもう講義の種子になっているのを発見することがしばしばあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少しよく捜したら貴重な未来の新思想の種子がこの忘れられた古い書物の中からいくらも拾い出せそうな気もする。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木と遺伝　樅などの種子を播いてその生長の遅速を試験してみると、低い土地から取って来た種子の方が高地から取ったのに比してよほど生長が早いという事がスイスやオーストリー辺で確かめられた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお一般に種子の重さや生長期の長短あるいは病にかかりやすい度などもその種子を採った母樹の土地によほど関係するそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこういう樹の種子を選ぶには播種すべき土地に応じて適当な処の産を用いねばなるまいという事を論じている人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいめい、好み好みの場所に席を取って、鮨種子で融通して呉れるさしみや、酢のもので酒を飲むものもあるし、すぐ鮨に取りかかるものもある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うものが運命なら運命のぎりぎりの根元のところへ、向うものが事情なら、これ以上割り切れない種子のところに詰め寄って、掛値なしの一騎打の勝負をしよう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕など麻雀はしばしば細君と口喧嘩の種子になるが、これが臨戰前だときつと八｜卦が惡い。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不毛の地に最初の草の種が芽を出すと、それが昆虫を呼び、昆虫が鳥を呼び、その鳥の糞粒が新しい植物の種子を輸入する、そこにいろいろの獣類が移住を始めて次第に一つの「社会」が現出する。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の仕事のカタログを製したりするよりは、むしろ未来の仕事の種子の整理に骨折っているらしいのが、常に進取的なこの人の面目をよく表わしていて面白いと思う。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩は麦の種子を食う。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と技手云へば、種子やまくらんいこふらん、　　　　ひとらかすみにうごくともなし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「種子をまちがへたんでせう。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "種子が間隔を正しくまっすぐになった時はうれしかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい自分の望む種子さえ播けばひとりでにどんどんできます。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から葭籬のもとに、いつのこぼれ種子やら朝顔の二葉土を離れて、我がやどすてぬといへる発句の趣向をあらはす。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、有から有が生じるとすれば、そこに有の種子を仮定する必要を生じて来るのであるが、この種子の考え方においてエピキュリアンはその先輩同輩に対して実に比較にならぬほど進歩している、あるいはむしろ現代の原子観に肉薄した考え方をしている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその一箇条として各種の生物に特有な性状の親から子へ遺伝する事実に論及し、そして心もまた「定まれる種子」を有する事を仮定しなければこの現象は説明し難いと言っているのは注目すべきである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは近代物理学の大家が、生命の種子を天来の発生物に帰せようとしたつたない説をあざけるようにも聞こえる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "圧縮によって熱の種子が絞り出されるという言葉もおもしろい。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷電の火の種子が一部は太陽から借りられたものであるとの考えも正鵠を得ていると言われうる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、にこにこしながら、人々とあくしゅしていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牛、ミルクに、ソップにバタ、しゅしゅらしゅんげ（髯の事）の長いナッポレオンだね、そうら三杯酢は、すっぱいものだね、猫とんびにかっぱの屁ったれかっぱ、とって投げほい」というのである。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「組合へ、顔出しゅしょうかと思うとったが。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "音は「しゅしゅっ」というふうに聞えた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
