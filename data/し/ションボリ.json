        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高く釣った蚊屋の中にしょんぼり坐っているのは年とった主婦で、乱れた髪に鉢巻をして重い病苦に悩むらしい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張りモンパルナス裏のしょんぼりした寄席のボビノで開くべきであろう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそうしながら、しょんぼりとして女の前に立つ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が小さな小屋の前を通ってその前にしょんぼりひとりの子供が立ってこっちを見てゐるときなどは思はずほうと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物も言い得ないで、しょんぼりと悄れていた不憫な民さんの俤、どうして忘れることが出来よう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝茶店の外　夕やけ小やけ……　半五郎の帰った後、源兵衛一人、表に出て、しょんぼり床几に腰掛けている。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が小さな小屋の前を通ってその前にしょんぼりひとりの子供が立ってこっちを見てゐるときなどは思はずほうと叫び出したいと思ったほどでした。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新盆のゆうべには、白い切子燈籠の長い尾が、吹くともない冷たい風にゆらゆらとなびいて、この薄暗い灯のかげに若い師匠のしょんぼりと迷っている姿を、お仲はまざまざと見たと近所のものに顫えながらささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこに、お里もしょんぼり立っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺を夕方しょんぼり行ったり来たりしてゐたのを見た人もあると云った。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が小さな小屋の前を通ってその前にしょんぼりひとりの子供が立ってこっちを見ているときなどは思わずほうと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その笑い声が、潰れたように丘へひびいて、それから遠くへ消えたとき、タネリは、しょんぼりしてしまいました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんてしょんぼりしているんだろう」　肩の表情は痛いたしかった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人は膝をついて坐ったが、前へ伸上るようにして、黄昏にしょんぼり立った私が姿を透かして見て、（何か用でござんすかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二十一「しばらくしょんぼりしていたっけ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧が晴れかかった時に、線路の横の畑の中に一疋の駄馬がしょんぼり立っているのが見えた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "らんぷの黄色い燈火の下でしょんぼり草双紙をお読みになっていらっしゃる婆様のお美しい御姿、左様、私はことごとくよく覚えているのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い長い廊下の片隅に、白くしょんぼり蹲くまって、かなり遠くから見たのでございますから、ふいるむのように小さく、けれども確かに、確かに、姉様と今晩の御婿様とがお寝になって居られるお部屋を覗いているのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が小さな小屋の前を通って、その前にしょんぼりひとりの子供が立ってこっちを見ているときなどは思わず、ほう、と叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "買え」「買ういわれがない」　画かきは顔をしかめて、しょんぼり立ってこの喧嘩をきいていましたがこのとき、俄かに林の木の間から、東の方を指さして叫びました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中はうすいうすい霧のやうなものでいっぱいになり、西の方からあの梟のお父さんがしょんぼり飛んで帰って来ました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "童子はしょんぼり庭から出られました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎はじつに申しわけないと思って、足の痛いのも忘れてしょんぼり肩をすぼめて立ったのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中はうすいうすい霧のようなものでいっぱいになり、西の方からあの梟のお父さんがしょんぼり飛んで帰って来ました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪を乱して、血の色のない顔をして、薄暗い洋燈の陰にしょんぼり坐っているこの時のお源の姿は随分｜憐な様であった。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずらりと見渡した皆がしょんぼりする。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "房の切れた、男物らしいのを細く巻いたが、左の袖口を、ト乳の上へしょんぼりと捲き込んだ袂の下に、利休形の煙草入の、裏の緋塩瀬ばかりが色めく、がそれも褪せた。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其奴の間夫だか、田楽だか、頤髯の凄まじい赤ら顔の五十男が、時々長火鉢の前に大胡坐で、右の叔母さんと対向になると、茶棚｜傍の柱の下に、櫛巻の姉さんが、棒縞のおさすり着もの、黒繻子の腹合せで、襟へ突込んだ懐手、婀娜にしょんぼりと坐っているのが毎度と聞く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、」　温泉の口なる、花室の露を掻潜って、山の裾へ出ると前後になり、藪について曲る時、透かすと、花屋が裏庭に、お雪がまだ色も見え分かぬ、朝まだき、草花の中に、折取るべき一個の籠を抱いて、しょんぼりとして立っていた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見た処でも、しょんぼりした脚にも気が入っているようですけれど、今しがたは、すっかり魂を抜き取られて、ふわふわ浮き上って、あのまま、鳥か、蝶々にでもなりそうですね。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
