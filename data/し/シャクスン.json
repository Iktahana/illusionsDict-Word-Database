        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たちまち染人が、歳ごとに染むるところの綾帛の尋丈尺寸を籍して簿となし、合囲するに遇う。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "尺寸の小幀でも椿岳一個の生命を宿している。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の傑作の多くは下町に所蔵されていたから、大抵震火に亡びてしまったろうと想像されるが、椿岳独特の画境は大作よりはむしろ尺寸の小幀に発揮されてるから、再び展覧会が開かれたら意外の名幅がドコからか現れるかも知れない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "初恋一　瑠璃子夫人を、あの太陽に向って、豪然と咲き誇っている向日葵に譬えたならば、それとは全く反対に、鉢の中の尺寸の地の上に、楚々として慎やかに花を付けるあの可憐な雛罌粟の花のような女性が、夫人の手近にいることを、人々は忘れはしまい。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "初恋一　瑠璃子夫人は、あの太陽に向つて、豪然と咲き誇つてゐる向日葵に譬へたならば、それとは全く反対に、鉢の中の尺寸の地の上に、楚々として慎やかに花を付けるあの可憐な雛罌粟の花のやうな女性が、夫人の手近にゐることを、人々は忘れはしまい。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "稗蒔　尺寸の天地をも愛する江戸ッ児は常にその景情を象って、自然の美に接せねばやまぬ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてかれらは自然に憧れ、かくてかれらは尺寸の別天地を占むるに算盤珠を弾かぬのだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭と灯籠　稗蒔の穂延びして漸く趣薄うなり行くにつれ、江戸ッ児の愛自然心は更に箱庭に馳せて、やがて尺寸の天地を新たに劃する。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "……不別治生以長尺寸。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "水行くほかに尺寸の余地だに見出しがたき岸辺を、石に飛び、岩に這うて、穿く草鞋の滅り込むまで腰を前に折る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽に踏む余地を尺寸に見出して、安々と踵を着ける心持がやっと有ったなと思ううち、もう後ろから前へ押し出される。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの増殖率の盛んな事は別項「特殊部落の人口増殖」中に述べた通りであって、もとは相当の田畑を部落内に有していたものも、今は尺寸の耕地を余さなくなっているのが常である。",
              "citation": {
                "source": "特殊部落と細民部落・密集部落",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さならば、里町間とか、丈尺寸とかいう単位を設け、何里の道とか、何尺の紐とかいうているが、一本の紐を見て、目分量でその長さを測るときには頭の中で、その紐を一尺ずつに境を付けて考える。",
              "citation": {
                "source": "境界なき差別",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余ヤ菲才浅学ニシテ府県ニ文部省ニ奉職シ育英ノ任ニ叨リ、尺寸ノ功ナク、常ニソノ職ヲ曠シクセシコトヲ羞ル耳。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早く荷物を纏めて、この残惜しい野営地を後に雪渓を東に向って下り始める、茫々たる霧は雪と溶け合って、涯りの知れない鼠色の天地は、眼のあたり尺寸の間に限られて、五、六歩の先に立った南日君の姿さえ掻き消すように失せている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの大空大地を製造するために彼等人類はどのくらいの労力を費やしているかと云うと尺寸の手伝もしておらぬではないか。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その試験の成績によるに、竹の尺寸、風呂敷の有無、さらに関係なきものなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地はその尺寸を歩々に利用する者があって始めて甲乙の区別が日常の会話の上に入用になって来る。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何物でも、たとい尺寸の地面でも、彼らにとっては親愛なのだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていうには、「三軍いま尺寸の功もなく、帰するところそれがしらの罪も軽くありません。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "尺寸長短、機動性能、すこしも違わないものが製作された。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "別ニ生ヲ治メテ以テ尺寸ヲ長ズルナシ。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
