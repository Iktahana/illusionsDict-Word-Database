        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ダラダラと下ったところに往還が通っていて、向う角の消防ポンプ置場も、つき当りの呉服屋も、もとのままある。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "城もこれに参加して、新しい消防ポンプを一台寄贈してくれたんです。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんわたしたちはまず、父につれられて消防ポンプのところへいきました。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この煙草屋の隣りは、ここの町会の消防ポンプの置場になっていた。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はコカコラの広告にしたって、真っ赤な消防ポンプじゃなかった。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
