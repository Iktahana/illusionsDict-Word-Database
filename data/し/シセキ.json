  {
    "uuid": "8c26a717-4e65-5dcb-a1ef-476eee679d62",
    "entry": "史跡",
    "reading": {
      "primary": "しせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
