[
  {
    "uuid": "e6e58a09-6102-5302-a19f-5df878e1ca4c",
    "entry": "史籍",
    "reading": {
      "primary": "しせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
