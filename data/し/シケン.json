    },
    "definitions": [
      {
        "index": 1,
        "gloss": "personal opinion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "附録の「芭蕉私見」は、全く文字通りの一私見にすぎない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお「蕪村論」は、先年著者の個人雑誌『生理』に連載して、一部読者の好評を博したものであり、附録「芭蕉私見」は、他の雑誌に掲載したものに、多少別に筆を加えたものである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "附録　芭蕉私見芭蕉私見　僕は少し以前まで、芭蕉の俳句が嫌いであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分などはもとよりこの六かしい問題に対して明瞭な解答を与えるだけの能力は無いのであるが、ただ試みに以下にこの点に関する私見を述べて先覚者の教えを乞いたいと思う次第である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上はただ一個の学究の私見で一つの理想に過ぎない。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう題目については従来多くの先輩の各方面からの所論や説述があり、私自身にもすでにいろいろな場所で繰り返して私見を述べて来たことであるから、今さらにまた同じことを繰り返したくないような気がする。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかつて雑誌「思想」の昭和二年九月号に出した「備忘録」の中で、生命の起元に関する未熟な私見を述べた際に、生命の胚子は結局原子そのものに付与するのが合理的であるという考えを述べておいた。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "緒論で断わってあるとおり、以上の所説は、特殊な歴史と環境とをもった一私人の一私見に過ぎないのであって、おそらく普遍性の少ない僻説であろうと思われる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはむつかしい問題であるが、私見によると、二つの対象が対立して、それが総合的に一つの全体を完了する、いわば弁証法的とでも言われる形式を備えるのが「切れる」の意味であるらしく思われる。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画と連俳との比較については岩波版日本文学講座中の特殊項目「映画芸術」の中に述べてある私見を参照していただきたい。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また連俳の心理と夢の心理の比較や、連俳の音楽との比較や、月花の定座の意義等に関する著者の私見は雑誌「渋柿」の昭和六年三月以降に連載した拙稿を参照されたい。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今までに幾｜度も私見たことのある人で、何でも小児の時は物見高いから、そら、婆さんが転んだ、花が咲いた、といって五六人人だかりのすることが眼の及ぶ処にあれば、必ず立って見るが、どこに因らず、場所は限らない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なるほど、道化の華の方が作者の生活や文学観を一杯に盛っているが、私見によれば、作者目下の生活に厭な雲ありて、才能の素直に発せざる憾みあった。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに好んで私見を立て、小智に任じ、傍門小徑を望んで走るのは、其の意蓋し惡むべからずと雖も、其の終や蓋し善からざるに至るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと早くから、来よう、来ようと思ったんだけれど、極が悪いしねえ、それに私見たようなものには逢って下さらないでしょうと思って、学校の帰りに幾度も九段まで来て止したの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今までに幾度も私見たことのある人で、何でも小児の時は物見高いから、そら、婆さんが転んだ、花が咲いた、といつて五六人｜人だかりのすることが眼の及ぶ処にあれば、必ず立つて見るが何処に因らずで場所は限らない、すべて五十人｜以上の人が集会したなかには必ずこの紳士の立交つて居ないといふことはなかつた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其二は、自らの主義、人間は Passion の動物なれば、少くとも自家の私見、善く言ひて主義なるものに拘泥することなき能はず、故に若し一の私見と他の私見と撞着したる時に、近頃流行の罵詈評論に陥ることなきにしもあらず。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりやあ君一個の私見だ。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敬ですが、あなたの方が却て一個の私見ではありますまいか。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、尚ここに別項を設けて、今｜些しハッキリと私見を述べておきたいと思う。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私見だが、やつは抜け目のなさで、ロンドンでは四番目だ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに好んで私見を立て小智に任せ脇道を望んで走る者はその意を悪くむべきでないが、その結果は決して良くはないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式ということを、悪いこと、取るに足りないことのように思って、妄りに私見に拠り私意を立て、折角聖賢が民人の為に設け説かれた形式に外れようとするのは、真に危なく殆いことで、一時の愉快はあっても終生の悔いがここに萌さないとも限らない、浅薄で愚かな事である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは私一個の私見であって、探偵小説はすべてこうでなければならぬなどというのではない。",
              "citation": {
                "source": "私の要求する探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『しかし私大層好きです、そのような人、私の一番の友達、私見る好きです。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾宮沢賢治落ちしのばらの芽はひかり樹液はしづにかはたれぬあゝこの夕つゝましくきみと祈らばよからんをきみきたらずばわが成さんこの園つひにむなしけん西天黄ばみにごれるに雲の黒闇の見もあへず",
              "citation": {
                "source": "開墾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥お峯が引出したるは唯二｜枚、殘りは十八あるべき筈を、いかにしけん束のまゝ見えずとて底をかへして振へども甲斐なし、怪しきは落散し紙切れにいつ認めしか受取一｜通。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………………………………………　お峯が引出したるは唯二枚、残りは十八あるべき筈を、いかにしけん束のまま見えずとて底をかへして振へども甲斐なし、怪しきは落散し紙切れにいつ認めしか受取一通。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………………………………………　お峰が引出したるは唯二枚、殘りは十八あるべき筈を、いかにしけん束のまゝ見えずとて底をかへして振へども甲斐なし、怪しきは落散し紙切れにいつ認めしか受取一通。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の幼児を抱きたるが、夜深けの人目なきに心を許しけん、帯を解きてその幼児を膚に引き緊め、着たる襤褸の綿入れを衾となして、少しにても多量の暖を与えんとせる、母の心はいかなるべき。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
