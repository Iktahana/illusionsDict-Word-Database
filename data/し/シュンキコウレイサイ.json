        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春季皇霊祭、春分、彼岸の中日。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼岸七日の真中を中日という、春季皇霊祭に当る。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その時分に、作文の稽古もはじめられてゐて、「天長節を祝す」とか、「春季皇霊祭日に山に登るの記」とかの課題で、文章らしいものを書かされるやうになつてゐた。",
              "citation": {
                "source": "花より団子",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "春季皇霊祭と秋季皇霊祭を中心にしてその前後には多少の差があるにしても、夏や冬に比すれば平分に近い。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春はなるほど事実からいって日永の代表者たる資格はないが、しかし今まで夜が長くって日の短かかったのが彼岸の中日（春季皇霊祭）になって昼夜平分し、それからだんだん日の方が永くなって夜の方が短くなる。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
