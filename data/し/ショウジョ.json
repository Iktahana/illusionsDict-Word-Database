        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "promotion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのうちに、たまたま、新聞に誰それは今度｜勲三等になつたとか、勲一等を貰つたとかいふ所謂昇叙の報道がでる。",
              "citation": {
                "source": "文化勲章に就て",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくも気をつけはしないけれど、……（しょうじょう）よりもっと小さくって煙のようだね。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろなめずらしい草を集めましたよ――じじばば（春蘭）だの、しょうじょうばかまだの、姫龍胆だの。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "（飲む）とかなんとか、上品めかして言いますけど、ありようは、ただ、なんでもいいから飲みたいのよ緑川美沙、実は、女しょうじょうだあ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のしょうじょがにげ出そうとしていますと、あっとおどろくようなことがおこりました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学一年の宮田ユウ子ちゃんという、ついこのごろなかま入りをした、たったひとりのしょうじょだんいんです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　しょうねんたんていだんのたったひとりのしょうじょだんいん、宮田ユウ子ちゃんは、ルビーでできた赤いカブトムシをもって、じぶんのうちのせっこうざいくのこうばにはいって、なにかやっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
