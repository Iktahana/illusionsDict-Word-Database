  {
    "uuid": "a4da57b2-192e-5bc9-9e55-d85e2137a479",
    "entry": "生所",
    "reading": {
      "primary": "しょうじょ",
      "alternatives": [
        "しょうしょ",
        "うまれどころ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "birthplace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その事で生所を立ち退きチーリンスのプレツスに寄るうち、プの妻アンテアその若くて美なるに惚れ込み、しばしばヤイノを極むれども聴かざるを怨み、かえってベが自分に横恋慕すと夫に讒す。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "得幼時侍蘭軒先生所筆記医談若干条。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（註に曰く……呉一郎の生所は事実と相違せる疑あり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからばすなわち白居易の詩に、「｜平生所厚者　｜昨夜夢見之」　とあるように、日ごろめざめているときに高尚な善良のことを想っていると、夢にこれを見るものならん。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "二五　人一生所遭、有險阻、有坦夷、有安流、有驚瀾。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和廿年十二月新生所載）",
              "citation": {
                "source": "亜米利加の思出",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和二十年十二月十日草）（昭和廿一年二月新生所載）〔一九五四（昭和二九）年二月二八日、中央公論社『裸体』〕",
              "citation": {
                "source": "冬日の窓",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先生のような人こそ、養生所という特殊な施設にはうってつけの人なんだな。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二年まえからのことだそうで、森半太夫の話によると、一昨年の秋に、三人の娼婦が養生所へ救いを求めて来た。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "養生所へ帰って来た去定は、独りでしきりにそう呟いていたそうである。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのことは半太夫から聞いたし、養生所の病室にはいまでも二人、去定が引取って来て療養している女がいた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで去定は、そういう事情なら養生所へ引取ると云いだした。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな例はざらにはないだろうが、養生所へ逃げて来た三人の女たちがそうだったし、現在もみくみ町で幾軒かそういう家がある。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が長崎へ遊学したときのもので、各科の病理や解剖、治療、調剤にわたる記録で、この養生所の見習医になったとき、去定に求められて呈出したものであった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗みをした、ということはともかく、師を裏切ったとか、友を売った、などという言葉には意味がありそうだし、大名諸侯や富豪から、礼をつくして迎えられるほどの腕を持っていて、いまだに妻も娶らず、養生所で独り不自由なくらしをしていることにも、なにか仔細がありそうに思えた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "養生所へ伴れてゆかれるかもしれないということばかり心配していたが、三日まえの朝早く、誰も気がつかないうちに逃げだしてしまった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田五庵は養生所の医員である、父の玄丹とともに、御徒町で町医を開業しているが、親子二人とも、かよいで養生所の診療に当っている。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "という母親の望みで、子をおろしてくれるようにと、養生所へ頼みに来た。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、登どの」と源伯は云った、「こなたの養生所勤めも一年になるが、新出先生と話しあった結果、来年三月の期変りから、こなたは目見医にあがることになった」　登は訝しげな眼をした。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長崎遊学から帰ったとき、すぐその手配をする約束であったが」と源伯は続けた、「新出先生に事情を話して相談したところ、いちおう養生所へ引取ろう、ということになったのだ」　遊学している留守に、ちぐさという婚約者にそむかれたことは、若い登にとって相当ないたでであろう。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ養生所などの多忙で変化のある生活に当らせるほうがよい、養生所のほうでも新らしい医学が必要だ。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことで、登の意志も問わず、帰るなり養生所へ入れたのである、と源伯は語った。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "養生所へ帰るとすぐに、登は森半太夫の部屋を訪ねた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、養生所に残ることについては、むずかしそうだな、と首をかしげた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "養生所へ帰ると、重傷のけが人が運びこまれたところで、登と半太夫とは二刻あまり坐る暇もなかった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし先生」と彼は反問した、「この施薬院……養生所という設備は、そのために幕府の費用で設けられたものではありませんか」二　去定は一方の肩をゆりあげた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俗に施薬院ともいわれた「小石川養生所」は、もとより貧しい病人を無料で診察し治療するのが目的であって、病状その他の事情によっては、かよいでなく、入所して治療を受けられることもすでに記したとおりである。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、そういう施療を受けることを嫌って、町内の者や家主などがすすめても、どうしても養生所へ来ようとしない者が少なくなかった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくも気をつけはしないけれど、……（しょうじょう）よりもっと小さくって煙のようだね。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろなめずらしい草を集めましたよ――じじばば（春蘭）だの、しょうじょうばかまだの、姫龍胆だの。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
