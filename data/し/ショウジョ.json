          "literary": [
            {
              "text": "なお典獄は威儀｜厳かに、御身の罪は大赦令によりて全く消除せられたれば、今日より自由の身たるべし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……葉ぼたん抜かれる今年も暮れる今年も今夜かぎりの雨となりそれでは昭和五年よ、一九三〇年よ、たいへんお世話になつた、各地の知友福寿長久、十方の施主災障消除、諸縁吉祥ならんことを祈ります。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "心頭の印銘はことごとく消除し去れり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくも気をつけはしないけれど、……（しょうじょう）よりもっと小さくって煙のようだね。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろなめずらしい草を集めましたよ――じじばば（春蘭）だの、しょうじょうばかまだの、姫龍胆だの。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "（飲む）とかなんとか、上品めかして言いますけど、ありようは、ただ、なんでもいいから飲みたいのよ緑川美沙、実は、女しょうじょうだあ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のしょうじょがにげ出そうとしていますと、あっとおどろくようなことがおこりました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学一年の宮田ユウ子ちゃんという、ついこのごろなかま入りをした、たったひとりのしょうじょだんいんです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　しょうねんたんていだんのたったひとりのしょうじょだんいん、宮田ユウ子ちゃんは、ルビーでできた赤いカブトムシをもって、じぶんのうちのせっこうざいくのこうばにはいって、なにかやっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
