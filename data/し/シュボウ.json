[
  {
    "uuid": "84926d9a-fdd3-5cc4-b6f7-e8d16a0e0a64",
    "entry": "首謀",
    "reading": {
      "primary": "しゅぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
