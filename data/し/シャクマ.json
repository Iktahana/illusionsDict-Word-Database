        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、絶えず、空家の二階から、おとし穴のやうなＮの借間を訪問した。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の借間はその一番奥の二階屋であるが、上の往来からはそんなところにこんな一廓があらうとは気づかれもしない程低く、一帯が薄暗気であつた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度引越した小さい家は、高台ではあるが元の借間程見晴しはない。",
              "citation": {
                "source": "春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああカーボン卿、ドイツ空軍のために、こんなに行き亘って爆撃されたのでは、借間が高くなって、さぞかし市民はたいへんであろう」「おお金博士。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "借間の払底をはじめ、そのほかわれわれイギリス国民を困らせることが実に夥しいのです。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は弟夫婦の借間の四畳半で弟と遅くまで飲み、その翌日も夕方まで飲んで、六時過ぎ頃の汽車で上野を発つた。",
              "citation": {
                "source": "浮浪",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "★）　クランチャー君の借間は附近が悪臭のない場所ではなかった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやっていく通りも街を引きまわされた上、栗の果横丁そっくりの借間のある二階の一室へ案内された。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この辺はべたに借間があるんで、心配はいらんさ。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七九六年にミュースに移ったが、これは車屋の二階のささやかな借間であった。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代わり奥の方の部屋部屋から、リッペヴェフゼル夫人の借間人どもが、ほとんど総出でばらばら飛んで来た。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "借間人たちは、近親知友に突然の不幸が起こった時、もっとも親しい間柄でさえいつも認められるかの奇怪な心内の満足感をいだきながら、一人一人戸口の方へじりじりと引っ返した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチンコフの家では、もう新しい借間人を知っていて、庭番がすぐに道を教えてくれた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年夏から両親の家を出たが、このころには借間を何度か変えながら仕事をつづけたようである。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この冬からアルヒミステン街に借間。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七年三十四歳アルヒミステン街の借間からパレ・シェーンボルンに移る。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、辛抱しきれなくなって、なかばかんしゃくまぎれに、なかばうっとりして、非常な勢いで、金の日の丸めがけて、一息に落っこってやりました。",
              "citation": {
                "source": "雷神の珠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんしゃくまぎれに鉄の棒を折り曲げて、外へ暴れ出してやろうと、何度となく、そのおりの鉄棒に飛びついたかしれません。",
              "citation": {
                "source": "白いくま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それからまたもやかんしゃくまぎれに、たてつづけに十ぺんばかり、力いっぱいに呼鈴をしゃくった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が熱くなって、つい口数が多くなるにつれて、かんしゃくまぎれにしゃべってしまったので、昨日としてはもう二つめの失策なのであった……それから後も、この朝はまるでわざとねらったように、不愉快な事ばかりあとからあとから起こった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と頭ごなしにどなりつけましたが、そのかんしゃくまぎれに、「よべ！",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
