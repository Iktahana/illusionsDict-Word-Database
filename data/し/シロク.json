      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fourth of nine traditional astrological signs (corresponding to Jupiter and south-east)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「私は一つ上……」「四緑なう。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は一つ上……」「四緑のう。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が六白星だから、七赤、八白、二黒の日は吉で九紫、三碧、四緑の日は凶であるなどと、朝刊の九星を気にしたり、カードのペーシェンスが、一度でパッと揃えば、吉。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに母の四緑木星も六白金星とは合はぬと判つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二の厄年が七年前に濟んだ未の八白で、「あんたのお父つあんと同い年や」と言つてゐるが、父に聞くと、「やいや、乃公は亥の四緑で、千代さんより四つ下や」と首を振つてゐた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度親戚の家の巽の方角に便所がある家があって、そこに丁度四緑の年にあたる娘があったが、久慈の母はそれを心配しつづけ家を変るようとしきりに奨めたことがあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　卯の年に生れて九星四緑に当るものは浮気にて飽きやすき性なりといへり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後巌谷四緑君来訪。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鈴――文久元年、かのとのとり、四緑、木星、柘榴木。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "今いっそう詳しくこれを案じてみるに、お鈴は辛酉は総じて種子であって樹木の生々を意味するから四緑の柘榴木とすべて木で出ている。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人が羊の三碧で姉さんが四緑なんだから。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一白　　二黒　　三碧　　四緑　　五黄　　六白　　七赤　　八白　九紫　これを時に配し、日に配し、月に配し、年に配し、五行、相生、相剋の理に考えて吉凶を判ずるなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "四緑に生まるる人は、常に愚痴なることをいい、人を疑う心あるがため、家内むつまじからず、損失をすることあるべし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数が一より九までありて、これに一白、二黒、三碧、四緑、五黄、六白、七赤、八白、九紫の名を付し、これを年に配し月に配し、日および時に配し、かつ、これを五行生剋の理に考え、人の生年月を繰りて吉凶を鑑定する規則である。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もうぢきですから元気を出しておもしろくうたって行きませう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さまだとて金滿家の息子株が藝人たちに煽動られて、無我夢中に浮かれ立つとは事が違ふて心底おもしろく遊んだのではありますまい、いはゞ疳癪抑へ、憂さ晴らしといふやうな譯で、御酒をめし上つたからとて快くお醉ひになるのではなく、いつも蒼ざめた顏を遊ばして、何時も額際に青い筋が顯はれて居りました。",
              "citation": {
                "source": "この子",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕はなるべく詳しく話すよ、おもしろくないと思ったら、遠慮なく注意してくれたまえ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにオリジナルな変異の産物でも当代の多数の観賞者が見てちっともおもしろくなかったり、ひとり合点で意味のわからないようなものは、わざわざ勦絶に骨を折らなくても当代の環境で栄えるはずはないであろう。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりまた、ちょっと見ると変なようでも読んでいるうちにだんだんおもしろくなって来るようなものがあれば、だれがなんと批評しようが自然に賛美者の数を増してくるであろう。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械の活動美を取り入れたフィルムもあるが、やはりこしらえものは実に空疎でおもしろくない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、なんらかの方法でこの保存ができたとして、そうして数十世紀後のわれらの子孫が今のわれわれの幽霊の行列をながめるであろうということは、おもしろくもおかしくもまたおそろしくも悲しくもあり、また頼もしくも心細くもあるであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もうじきですから元気を出しておもしろくうたって行きましょう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞんざいで、おもしろく思えなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの癖で、不愉快な場面を非人情に見る、――そうすると反対におもしろく見えて来る――その気持がものになりかけて来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松島園より下は少許の草生地を隔てゝ墨田堤を望む花時の眺めおもしろく、白髯の祠の森も少しく見ゆ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論おもしろくないものや、味のないものや、平凡のものを持囃したのではない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "芍薬　牡丹は幹の老いからびて、しかも眼ざましく艶なる花を開くところおもしろく、芍薬は細く清げなる新しき茎の上にて鮮やかに麗はしき花を開くところ美し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの両者が共同し、その上に機械的の計算や統計を担当する助手の数人の力をかりることができれば、仕事はかなりおもしろく進行しそうに思われる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはなかなか容易でないが、もしできたらかなりおもしろく有益であろうと思う。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハネの黙示録の第九章に示された恐ろしい蝗の災いを欧州大戦における飛行機にうまく当てはめておもしろく書いてある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
