[
  {
    "uuid": "78bbd015-0dbb-5f5d-919b-1aba178fb2cd",
    "entry": "四緑",
    "reading": {
      "primary": "しろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
