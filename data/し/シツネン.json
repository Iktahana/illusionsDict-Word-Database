        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大へんわかりきった事で恐縮ですが、僕なぞ時々此のわかりきった事を失念してとんだ恥を晒します。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、取紛れて失念をしようとした。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失念った※」と叫んで暫時我を忘れて茫然としたが、たちまち気を取り直して、側に放げ棄てておいた自分の鉄砲を取り上げるや否や、駆け出そうとすると、何物にか躓いてばったり仆れた。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその縁談に於いては甚だ不熱心であり、時たま失念していたりする仕末であった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三十種類くらいの同人雑誌に載っている全部の作品の中で、天才の作品は井伏さんのその「山椒魚」と、それから坪田譲治氏の、題は失念したけれども、子供を主題にした短篇小説だけであると思った。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやらしい「芸術的」な装飾をつい失念したから、かえって成功しちゃったのだ。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違ひのないやう、出来るだけ気をつけてお話申し上げるつもりではございますが、それでも万一、年代の記憶ちがひ或いはお人のお名前など失念いたして居るやうな事があるかも知れませぬが、それは私の人並はづれて頭の悪いところと軽くお笑ひになつて、どうか、お見のがし下さいまし。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、東北の寒さを失念してゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その貴方様、水をフト失念いたしましたから、精々と汲込んでおりまするが、何か、別して三右衛門にお使でもござりますか、手前ではお間には合い兼ね……」　と言懸けるのを、遮って、傾けたまま頭を掉った。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、何せれいの家の建て直しに、着て出る着物の調整に、やっさもっさ、心をくだき、あまりの向上心に、いきおい守るほうを失念してしまっていた。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と兄は、ほとんど一歩毎に呟いて、ひとり首肯き、先刻の怒りは、残りなく失念してしまっている様子であった。",
              "citation": {
                "source": "一燈",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長吉の名前に、朱筆がないのは、将軍家の御失念かも知れないが、やはり人間のあやまちを正す天意かも知れないと思う。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年は何をするか――一九三〇年に対する私の希望・抱負・計画――牧野信一　ある先輩が経営することに決つた其鰤敷魚場は今月（十一月）から来年の六月迄房州の何某村（村名を今ちよいと失念した）で行はれる。",
              "citation": {
                "source": "来年は何をするか",
                "author": "――一九三〇年に対する私の希望・抱負・計画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は記事を書いて、そのことも失念していたのですが、しばらくして友人の保証人になって、二五ポンドの支払い礼状が送られてきてしまいました。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "前野氏のことを、とんと失念いたしていた。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "主君の御前ということもつい失念してしまったと見え、その二重瞼の美しい目を半眼に閉じながら、うつらうつらと仮睡に落ちようとしている。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝罪されたことに仰天して、疑問が解決していないことは失念した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から三十数年の昔で明治の終り頃であつたが歳月の記憶も失念してゐるし、記憶も全く薄らいで仕舞つたが思出のままを書いてみることにする。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失念致しましてございます」「よろしい、満点、その方がいい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでもう一度ほめられようと、「失念致しましてございます」「今度はいけない、零点だよ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "失念ということがあるものか。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文しておいた酒をとうとう持つてきてくれなかつた、失念したためか、信用がないためか、……どちらでもよろしい、……酒に囚はれるな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五十五回　暗の中の一物　余が何よりの失念は蝋燭を買い調えて来なんだ一事で有る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、その節快く御承諾下されたので、我々共は今日の参るのを指折り数えて待っておった次第で」「なんでござったかな、敵討なんどと、左様な大事件をお引受け致したか知らん」「御失念では痛み入る。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代は自分の好きなその広場を今まで忘れていたのを思うと、いつもより千鶴子に心を奪われていた自分の失念のさまもまた思われるのであった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それを時々失念して、「わしはね」と、云っては皆に嘲笑された。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後、私は蒲団の事については、長々と母へ礼状を書き送ってやったのであるが、枕の事については、礼の一言も、私は失念したかの形にして書き添えてはやらなかった。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの指導者側の婦人たちは、私たちに対して自覚を叫ばれ、内省を奨められるのですが、私たちから見れば、自覚といい内省ということが何よりも「我々の生活の理想は如何」という第一義的なことに向けられねばならないことを、かえってそれらの婦人たちは失念しておられるように思われます。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に読んだのは佐川春水氏が「銀行盗賊」と改題して訳述した「赤髪組合」か、それでなければ訳者を失念したが、太陽か又は太陽と同型の雑誌に発表された「青い宝石」で、どっちが先だったか確かな記憶はない。",
              "citation": {
                "source": "ドイルを宗とす",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御重役へ届け出でてお許しが出たか」「いや、その辺、とんと、失念仕って――」「こやつ、引っ捕えい」　侍は、一足引いて、浪人達に、顎で指図した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
