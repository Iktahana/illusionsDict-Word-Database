[
  {
    "uuid": "dcfa7785-2926-54a2-aa60-e329ca4d1d87",
    "entry": "祝する",
    "reading": {
      "primary": "しゅくする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to congratulate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは、ポーラとの結婚を祝する座員ばかりの水入らずの宴会の席で、ポーラがふざけて雌鶏のまねをして寄り添うので上きげんの教授もつり込まれて柄にない隠し芸のコケコーコーを鳴いてのける。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又李白の子を祝する句に曰く、揚杯祝願無他語、謹勿頑愚似汝爺矣。",
              "citation": {
                "source": "聞きたるまゝ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、としよりの爲には此の暖な日和を祝する。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "散策子はむくと起きて、ひそかにその幸福を祝するのであった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……窈窕たるかな風采、花嫁を祝するにはこの言が可い。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを祝する意味に於いて、だ、（一升瓶とさかなを両手にぶらさげ部屋にはいり、部屋の上手の襖をあけ）おうい、おうい。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "老生の初陣を慶祝するが如き風情に有之候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他なし、社会のために祝するなり。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "街を走る吹聽人はいふも更なり、今咲き出づる「アネモオネ」の花、高く聳ゆる松の末より空飛ぶ雲にいたるまで、皆我を祝する如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "牽牛織女のおめでたを、下界で慶祝するお祭りであろうと思っていたのだが、それが後になって、女の子が、お習字やお針が上手になるようにお祈りする夜なので、あの竹のお飾りも、そのお願いのためのお供えであるという事を聞かされて、変な気がした。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主仰天して彼を捉え打っていわく、汝死人に遇わば愍んで今後かかる事なかれと言うべきに多く祝するは何事ぞと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同時に入露以前から二、三の露国革命党員とも交際して渠らの苦辛や心事に相応の理解を持っていても、双手を挙げて渠らの革命の成功を祝するにはまた余りに多く渠らの陰謀史や虐殺史を知り過ぎていた。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、先生の喜壽を祝すると共に、二三の思出を記すに過ぎない。",
              "citation": {
                "source": "井上先生",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の一代の盛典を祝するために、僕は今、僕の心からなる記念品として、「恋愛曲線」なるものを送ろうとして居る。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮羊君来庵、観そこなつた五人の斥候兵の話などを聞く、娘さんの出生を祝する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心の平静をとりもどした、私は日に日に刻々燈みつつある、と自信し自祝する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "総選挙の結果は一見無産派の前途を祝するように見られる。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「書後」の筆を投ずるに臨んで敬んで君の健康を祝する。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百十七　わたくしは渋江抽斎の日乗に、柏軒と狩谷氏たかとの合※を祝する詩歌、俳諧、俗謡があつて、中には稍褻に亘つたものゝあつたことを語つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にわたくしは渋江伊沢等諸名家の現存せる末裔の健康を祝する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「賛成※」といずれもその洞内に赴き、ありたけの蝋燭を点じてその中に坐り、各自にブランデーを注いだ洋盃を高く差し上げ、桂田博士の音頭で「日本帝国万歳」を三唱すると、その声は遍く洞内に響き渡って、谺はさながら月がこの一隊を祝するように、「月世界探検隊万歳※」と唱え返した。",
              "citation": {
                "source": "月世界跋渉記",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶衆客皆杯を挙げて主人の健康を祝するや、ユウゴオ傍なるフランソア・コツペエを顧みて云ふやう、「今この席上なる二詩人｜迭に健康を祝さんとす。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず劈頭のヒットを祝するつもりで一杯傾けるかナ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世界中のお祝するお誕生日」である。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十二年十二月のはじめ、神保光太郎の結婚を祝するために十數人の先輩友人が集つた會合に、先輩の一人として列席してゐた彼は、その會の半ばに、突然立ち上つて、微醺を帶びたまま、自作の詩を朗讀した。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又舊暦の正月に、三河萬歳とて、古風なる衣裳を着けたるものが、鼓太鼓を携へ、毎戸に來て祝詞を唄ふは、徳川家康公の萬歳を祝するの遺禮なりと云ふ。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に私の予想が狂うのは、今度三浦に始めて会った時を始めとして、度々経験した事ですから、勿論その時もただふとそう思っただけで、別段それだから彼の結婚を祝する心が冷却したと云う訳でもなかったのです。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――鬼塚元帥は、黒馬博士｜坐乗の魚雷型快速潜水艇を認めて、博士の健在を大いに慶祝するものである」「おお、そうか。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は大に古賀君の為めに此転任を祝するのである。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は大いに古賀君のためにこの転任を祝するのである。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
