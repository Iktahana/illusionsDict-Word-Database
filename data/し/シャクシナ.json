        "examples": {
          "standard": [
            {
              "text": "冬の鍋物には、新鮮な杓子菜がよく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "畑で採れた杓子菜を使って、おひたしを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スーパーで買った杓子菜は、シャキシャキとした食感が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は畑から担いで帰った葱やしゃくし菜などを谷川を洗いましたが、その冷たさ、それからは路を歩いても、子をおぶった女などが手を赤くして菜を洗っているのを見ると（これまでは少しも目につかなかったのに）限りなき同悲の情が起こります。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "温厚なゴルドン、常識にとんだゴルドン、しかも少年たちにはきびしく毎日の学課を責めて、すこしもかしゃくしないゴルドン。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵理子の父親はぎくしゃくしなくなった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
