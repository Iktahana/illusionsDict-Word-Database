        "examples": {
          "standard": [
            {
              "text": "この補助金の申請人は、厳格な審査基準を満たす必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パスポートの更新手続きには、申請人本人が窓口に出向く必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複数の申請人が競合し、最終的に一社がプロジェクトを落札した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、申請人がしつっこく願うと、役所は、あらゆる資料が蒐集されるやいなや、決定の前に、もちろん全体との連関において、すべての書類、したがってこの最初の願書も仔細に検討されるのだと付け加える。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
