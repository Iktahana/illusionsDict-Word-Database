    "definitions": [
      {
        "index": 1,
        "gloss": "Shimane Prefecture (Chūgoku area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
