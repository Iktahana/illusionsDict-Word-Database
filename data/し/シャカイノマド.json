        "examples": {
          "standard": [
            {
              "text": "「あれ、ちょっと、社会の窓が開いてるよ！」と友人が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議中に気づくのは恥ずかしいので、外出前には必ず社会の窓をチェックする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、うっかり社会の窓を開けたまま一日を過ごしてしまったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｎ・Ｈ・Ｋでさえも主婦の労働と、職業上の労働とをどう調節するかということについて社会の窓で放送しました。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、一ツはラジオの社会の窓だそうだが、ラジオが探訪する以上は直前に新聞記事でもあったはずだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
