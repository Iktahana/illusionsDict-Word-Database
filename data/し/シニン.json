    "definitions": [
      {
        "index": 1,
        "gloss": "corpse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死人に口がないのだから、なお、いやだ。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞ死よ――はたは死人よ……やさしくるほし！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多くの物の中で、就中最も感銘が深かつたのは、彼のシベリア流刑記を自傳した「死人の家」であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人は、もう冷たくなりかけていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、死人と、病人とを中へ入れろ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の顔でも手でも青みを帯びた不快な黄色に見え、唇などはまるで死人のようになる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "線香を立てて死人扱いをするのがかあいそうでならないけれど、線香を立てないのも無情のように思われて、線香は立てた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人を嫉むものはありませんから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人なら誰も嫉みは致しますまい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて暫く空を睨みいて、忽ち激しき運動にて両手を顔に覆い、両肱を机に突き、死人の如く動かずに坐りいる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どんな小さな瀕死人でもがその市立病院に一直線にはひつて行かうと思ひつめさへしたら、サガン公爵ですら、その行列を止まらさない訣には行かない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀕死人は強情張りだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人等や、女等や、死人等に會ふことを要求し、それから彼自身の死ぬことを要求するのだつた、要求し、そして叫び續けてゐるのだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、この突然の闖入者の濃い髯でかくれた、中年の苦悩に刻まれた古銅色の顔、霜枯れた衣服の下で凍った靴に、死人のような膚が覗いているのを見た。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、近東行きの列車が巴里を出発する間際になって、ジョージ・佐野は死人のように、蒼ざめて一行に加わりました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、お前の體は死人のやうに横はつてゐて、口だけが動いてゐるのだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はまた死人のやうに眠つてゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の上に殘つた足跡だの、死人が左手に掴んでゐた三本の縮れ毛だの、節穴からのぞいた鋭い瞳だの不思議な老人の出現だのと、好奇心は刺戟され、空想は活溌にはね廻り、作中の探偵と共に祕密を探る異樣な快感に醉はされながら、讀み始めると、私は終りまで本を離せなかつた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人のやうな顏をして僕の歸つて來たのを見て、宿の者は如何なに驚いたらう。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら菰をきせて河岸の柳の下に横たえてある男の水死人はたしかに藤吉に相違ないので、附き添いの人々も今更におどろいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、死人に口無しで確かなことは判りませんが、前後の事情から推して行くと、そう判断するよりほかはないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺は死人を弔うにふさわしく、支那式に、蛇頭や、黒い布でしめやかに飾られていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人も、土地を買わなければ、その屍を休める場所がない。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人が、地獄か、極楽かで、その金を出して、自分の休息場を買うのである！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口をいえば骨董は死人の手垢の附いた物ということで、余り心持の好いわけの物でもなく、大博物館だって盗賊の手柄くらべを見るようなものだが、そんな阿房げた論をして見たところで、野暮な談で世間に通用しない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は祖母とならんで寝ころがりながら、死人の顔をだまって見ていた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生胆取りだの死人使い、奴隷売買、人殺し請負いナンテものは西洋人でなくちゃ出来ない仕事だと聞いておりましたがマッタクその通りだと思いましたナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさながらに地獄に堕ちた死人の形相であった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔が一つ一つにタマラナイ程引き歪められているのは、死人の腥い臭気に鼻を撲たれているせいばかりではなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
