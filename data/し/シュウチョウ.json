[
  {
    "uuid": "d0af3f92-a942-5515-8659-405980a9da29",
    "entry": "酋長",
    "reading": {
      "primary": "しゅうちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chieftain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「トバスキー酋長、徳望あり。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "酋長のむすこがライオンに食われる場面がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この酋長の子が食われたので、映画師らは酋長に合わせる顔がないといってしょげる場面はどうも少し芝居じみる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼は孤独で専制的な酋長の眼のように淋しく光っていた。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "和蘭陀のは騷がなかつたが、蕃蛇剌馬の酋長は、帶を手繰つて、長劍の柄へ手を掛けました。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道頓堀から糸屋の娘……女朝日奈の島めぐりで、わしが、ラバさん酋長の娘、と南洋で大氣焔。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなにチッテ族の酋長のような南洋色になっても」　社長は、「ある――大いにある」と怒鳴ったが、誰も酔いの上の気焔と思って相手にしない。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち其地の酋長を以て津軽郡領とす。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和又｜三仏斉国の酋長を俘として献ず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャクは、美しく若い男女の物語や、吝嗇で嫉妬深い老婆の話や、他人には威張っていても老妻にだけは頭の上がらぬ酋長の話をするようになった。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャクは、美しく若い男女の物語や、吝嗇で嫉妬深い老婆の話や、他人には威張つてゐても老妻にだけは頭の上がらぬ酋長の話をするやうになつた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「積丹土人の酋長の娘の話でしょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか Kambodscha の酋長がパリに滞在していた頃、それが連れて来ていた踊子を見て、繊く長い手足の、しなやかな運動に、人を迷わせるような、一種の趣のあるのを感じたことがある。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの土地はその昔、原住民の酋長によって支配せられ、シナの明朝に封ぜられて王となって、爾来引きつづいて燕京に入貢していたが、のちにシャムに併合せられた。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンリは元来サヴァイイ島の酋長の息子なのだが、欧羅巴の何処へ出しても恥ずかしくない立派な青年だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティヴロン氏、或いはストレーヴン氏（彼の名を正確に発音できる土人は少かった）或いはツシタラ（物語の語り手を意味する土語）が、富豪であり、大酋長であることは、最早疑いなきものと彼等には思われた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "各地方の大酋長にして、此の五つの称号の全部、もしくは過半数を（人望により、或いは功績により）得たる者、推されて王位に即くなり。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｊ・Ｂ・ステェア「サモア地誌」――　一八八一年、五つの称号の中、「マリエトア」「ナトアイテレ」「タマソアリィ」の三つを有つ大酋長ラウペパが推されて王位に即いた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、全く莫迦莫迦しいことに、王、副王以下各大酋長の決議で「サモア支配権を英国に委ねたい」旨を申出そうとしたのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "独兵の追跡を逃れて森から森へと身を隠していた前王ラウペパの許に、或夜、彼の腹心の一酋長から使が来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「頭の無い蜥蜴が酋長会議の壁を走った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "列座の諸｜酋長に向って、マターファが余を紹介する。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同行者――母、ベル、タウイロ（うちの料理番の母で、近在の部落の酋長夫人。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（白人に立てられた傀儡ではない）彼等の心から推服する真の王者へと贈られた・大小酋長からの献上品だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の持参したビスケットの缶と共に、「アリイ・ツシタラ・オ・レ・アリイ・オ・マロ・テテレ」（物語作者酋長・大政府の酋長）と紹介される声を私は聞いた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、物語作者酋長の番が来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は「王より大酋長への贈物」である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は族長だ、ヴァイリマ部落の酋長なのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
