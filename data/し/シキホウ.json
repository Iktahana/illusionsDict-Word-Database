    "uuid": "3dfdf544-d197-5c09-829c-5f4abd105298",
    "entry": "式法",
    "reading": {
      "primary": "しきほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
