          "literary": [
            {
              "text": "それが昭和の日本人の作る漢詩の心得である。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切はそこを標準としなければならぬ、そこを標準とすることによつて、初めて昭和の日本人が漢詩を作ると云ふことに意義が見出されるのである。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、彼らは昭和の日本人を指さして、異口同音に、「気狂い！",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和の日本人は秋晴れの日、山に遊ぶことを言うにハイキングとやら称する亜米利加語を用いているが、わたくしの如き頑民に言わせると、古来慣用せられた登高の一語で足りている。",
              "citation": {
                "source": "十九の秋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし両先生とも、何といっても、大正昭和の日本における傑出した学者であった。",
              "citation": {
                "source": "長岡と寺田",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今この門外に立って見ると、大正昭和の日本を記念する巨大な議事堂が丘の上から見おろしている。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
