        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "臣夙夜祗み懼れ、敢て寧処せず。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤松陰撰の墓誌に、「君既寡、子皆幼、而持操屹然、凡事皆遵奉遺命、夙夜勤苦、教育二孤、終致其成立」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前日の事、すでにすでにかくの如し、後日の事、またまさにかくの如くなるべければ、我が党の士、自から阿らず、自から曲げず、己に誇ることなく、人を卑むことなく、夙夜業を勉めて、天の我にあたうるところのものを慢にすることなくんば、あにただ社中の慶のみならん。",
              "citation": {
                "source": "中元祝酒の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生夙夜膝下に陪し戦々兢々たり。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夙夜、憂思シテ恐ル、将ニ天下危ウカラントスルヲ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "命をうけて以来、夙夜憂歎し、付託の効あらずして、以て先帝の明を傷つけんことを恐る。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
