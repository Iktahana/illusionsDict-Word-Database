          "literary": [
            {
              "text": "はははは」　老紳士は、声たからかに笑って、消防士においたてられて立ちさった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで邸宅は消防士と警察の支配下だが、大損害はないそうだ」　両手をポケットに突っ込み、口笛を吹きながら威張って部屋から出て行った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸内にはロングタウンから来た警察と消防士がいる。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸内は消防士と警官以外入れないと、警部がラルフに言うので、ジョージ卿に尋ねた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかさず、どっと笑いが湧き上がると同時に、にわか消防士の命も救われた。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々大量の火の粉がバサバサッと降り注ぎ、近接の木造家屋に落ちるが、周囲の屋根に登った消防士がすぐ炎を叩き消している。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防士らにはまだやるべきことが山積みだ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜を徹して消防士や有志の一団が水不足地域へ貴重な水をせっせと運んでいる。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりのしょうぼうしが、それをかけのぼっていきました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうぼうしは、二十めんそうをつかまえました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
