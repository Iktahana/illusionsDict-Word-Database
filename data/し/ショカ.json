    "definitions": [
      {
        "index": 1,
        "gloss": "early summer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "われはつちを掘り、つちをもりて、日毎におんみの家畜を建設す、いま初夏きたり、主のみ足は金屬のごとく、薫風のいただきにありて輝やき、われの家畜は新緑の蔭に眠りて、ふしぎなる白日の夢を畫けり、ああしばし、ねがはくはこの湖しろきほとりに、わがにくしんをしてみだらなる遊戲をなさしめよ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま初夏きたる、野に山に、榮光榮光、榮光いんよくの主とその僕にあれ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け放された窓からは初夏の風がサカンに頬や帽子の鍔に吹きつけてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏の夜空の中に、電気広告の様々なのが、消えたり点つたりする下を、足を投げ出すやうな心持に、歩いてゆくことは、まるで亡命者のやうな私の心を慰める。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "更衣野路の人はつかに白し　春着を脱いで夏の薄物にかえる更衣の頃は、新緑初夏の候であって、ロマンチックな旅情をそそる季節である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした初夏の野道に、遠く点々とした行路の人の姿を見るのは、とりわけ心の旅愁を呼びおこして、何かの縹渺たるあこがれを感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句もやはり、そうした主観的郷愁の一咏嘆であるが、特に心の詩情を動かしやすく、ロマンチックで夢見がちな初夏の季節を、更衣の季題で捉えたところに、句の表現的意義が存するのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保のいちばんいい季節は、晩春四五月から、初夏の六七月へかけた時期である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の伊香保は、自然としても初夏のそれに劣るが、何しろ悪いことは、文字の通りの意味で雑鬧混雑を極めることである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に晩春より初夏へかけ（ここの赤裸々となるは、夏期わずかの間に候）最も歴々と仰がるべく、夏にても、形は明確に、白雪山を埋むる今にても、こを恋人とせる小生の目には、同じ雪に蔽われながらも、この鳥形のみは粗き山の膚（元より白色）の中に、滑らかに平に浮び出で居候が、認められ候。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏五月の頃、富士の嶺の雪が溶け始めるのに人間の形に穴があく部分がある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く凝って澄んだ東北特有の初夏の空の下に町家は黝んで、不揃いに並んでいた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者も今年初夏頃の某誌にもはや充分意を尽したつもりの恋愛論を発表しました故、論筆として諸氏に見える余裕のものを多く持ちません。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクに乗ったり、歩いたりして、一行は荒川放水路の水に近い初夏の景色を見て廻った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏の明るい陽射しも消し尽せぬ人間の憂愁の数々に思われる。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○フレッシュの苺クリーム、ブライトな日傘、初夏は楽しい。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは多分初夏の頃であったかと思う。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といふ思ひが、初夏の海風のやうに湧いてくるとき、その思ひの高まる時ほど、實際に樂しいものはないだらう。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外には初夏のしつとりした空氣が流れてゐた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が今年ももはや初夏の季節で、河鹿など涼しそうに鳴かせる時分だ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は若葉の美しい初夏の頃だつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも去年一昨年あたりはまた少々｜興味が戻つて來て、一｜週間に一｜度ぐらゐの程度で和田英作｜畫伯や小宮豐隆先生と時々手｜合せの出來る近｜所の球突塲へ通つてゐたが、昨年の初夏兩親の家から別居して、赤｜坂區新町に家を持ち、馴染のその球突塲が遠くなるとともにまた殆どやめたやうな形になつた。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい二三年前までは毎年初夏になるとあの感傷的な苗売りの声を聞いたような気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつじはもうすっかり散ったあとであったが、ほんの少しばかりところどころに茶褐色に枯れちぢれた花弁のなごりがくっついていたことと、初夏の日ざしがボーイのまっ白な給仕服に照り輝き、それがなんとも言えないはかない空虚な絶望的なものの象徴のように感ぜられたことを思い出すのである。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが年を取るうちにいつの間にか自分の季節的情感がまるで反対になって、このごろでは初夏の若葉時が年中でいちばん気持のいい、勉強にも遊楽にも快適な季節になって来たようである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初夏」の人物は昨年のより柔らかみが付け加わっている。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯体のような若芽に煙っていた欅や楢の緑にももう初夏らしい落ちつきがあった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は過ぎても、初夏の日の長い、五月｜中旬、午頃の郵便局は閑なもの。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺りは荒川西より東に流れて、北の岸は卑湿の地なるまゝいと荒れたれば、自然の趣きありて、初夏の新蘆栄ゆる頃、晩秋の風の音に力入りて聞ゆる折などは、川面の眺めいとをかしく、花紅葉のほかの好き風情あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場を出るとさわやかな初夏の風が上野の森の若葉を渡って、今さらのように生きていることの喜びをしみじみと人の胸に吹き込むように思われた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
