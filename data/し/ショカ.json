  {
    "uuid": "02b1cbd9-5ff4-56a6-a28a-b5ebee4370fb",
    "entry": "暑夏",
    "reading": {
      "primary": "しょか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
