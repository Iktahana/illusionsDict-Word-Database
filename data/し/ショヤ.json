    "definitions": [
      {
        "index": 1,
        "gloss": "bridal night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眼光鋭く、意気激しく、いずれも拳に力を籠めつつ、知らず知らず肱を張りて、強いて沈静を装いたる、一室にこの人数を容れて、燈火の光｜冷かに、殺気を籠めて風寒く、満洲の天地初夜過ぎたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢には釜の声、遥に神路山の松に通い、五十鈴川の流に応じて、初夜も早や過ぎたる折から、ここの行燈とかしこのランプと、ただもう取交えるばかりの処。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夜も過ぎた屋根越に、向う角の火災保険の煉瓦に映る、縁結びの紅い燈は、あたかも奥庭の橋に居て、御殿の長廊下を望んで、障子越の酒宴を視める光景！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や初夜過ぎの寂として、四辺へ響いたが返事がない。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おゝ、銀河が見える――初夜すぎた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年も初秋の初夜過ぎて、白井氏が玉川べりの実家へ出向いた帰りだと云って、――夕立が地雨に成つて、しと／＼と降る中を、まだ寝ぬ門を訪れて、框にしつとりと置いて、帰んなすつた。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……寝ようという時、初夜過ぎた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女というものはたいてい結婚の初夜には、見合いの席以外に顔を見たことのない男に、体を許しますね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば新婚初夜に於ける権右衛門の態度だ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どうして勢がこんなであるから、立続けに死霊、怨霊、生霊まで、まざまざと顕れても、凄い可恐いはまだな事――汐時に颯と支度を引いて、煙草盆の巻莨の吸殻が一度｜綺麗に片附く時、蚊遣香もばったり消えて、畳の目も初夜過ぎの陰気に白く光るのさえ、――寂しいとも思われぬ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこれから物語ろうと思ういきさつの男女も、このような微笑の初夜を得るように、私は衷心から祈っている。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは仏法東漸の源、初夜後夜の鐘は　いつも鳴る。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "追加の雪の題が、一つ増しただけ互選のおくれた初夜過ぎに、はじめて約束の酒となった。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼光鋭く、意気激しく、いづれも拳に力を籠めつつ、知らず知らず肱を張りて、強ひて沈静を装ひたる、一室にこの人数を容れて、燈火の光｜冷かに、殺気を籠めて風寒く、満州の天地｜初夜過ぎたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや初夜｜過となりました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夜すぎてのちともすればその翼もて人の面を蔽うことあり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目出たいと騒ぐ初夜の儀式は、メスの祭典だ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木崎の借りていたアパートの一部屋で過した初夜の蚊帳を、木崎は八重子と二人で吊った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、初夜は一緒に寝たんだろう」「ところが、前の晩徹夜したので、それどころじゃない。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎鷹は初夜に眼の冴え、夜をひと夜、あさりするそな。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の濃青の、頬の横を、蒸すは黝朱の初夜の雲。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この海や涯し知られね、この荒れやはかり知られね、初夜過ぎて、また後夜かけて、闇ふかく翼ふる千鳥、この雨を、また稲妻を、ひた濡れてかがやく千鳥。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夜過ぎて夜の幽けさとやなりけらし。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夜過ぎてまた後夜ふけて、なほなほにどよもす声の、おそらくは夜の明くるまで。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此海や涯し知られね、この荒れや測り知られね、初夜過ぎて、また後夜かけて、闇ふかく翼ふる千鳥、この雨を、また稲妻を、ひた濡れて乱るる千鳥。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夜過ぎて夜の幽けさとやなりけらし、ふりいでにけり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は金で買われて来たらしいが、しかし体を売るのは死ぬよりもいやだと、意外な初夜の言葉だった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か用があったら、いつでもそう言ってよこしておくれなんしょや。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "お倉が嫁いて来た頃ですら、村の者が来て、「旦那、小屋を作るで、林の木をすこしおくんなんしょや」と言えば、「オオ、持って行けや」とこの調子で、毎年の元旦には村民一同小泉の門前に集って先ず年始を言入れたものであった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お延はその絵葉書を机の上に並べて見て、「お俊姉さま、私にも一枚画いておくんなんしょや」　と従姉妹の技術を羨むように言った。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
