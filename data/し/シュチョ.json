    "definitions": [
      {
        "index": 1,
        "gloss": "one's chief (literary) work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "散文も少々あるやうだが、詩集アムール・ジョーヌは彼の主著である。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主著“Apologeticus”の他“Ad Martyres”“De Baptismo”“De Poenitentia”など、宗教上の著述が多い。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくすれば目的の主著は過多にして而も不充分なる事例のために膨大となり過ぎるのを免れることが出来るであろう」、と。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も吾々が直ちに気付かずにはいられないように、之はニュートンの主著『自然哲学の数学的原理』の根本的な三法則（それは経験に基いた法則である）の先天的基礎でなければならない。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――本著『自然科学の形而上学的原理』の名称が、ニュートンの主著である処の『自然哲学の数学的原理』に対応することは注目に値いする。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼のすべての著作について、『正信偈』や『和讃』のごとき一種の韻文、また仮名で書かれたもろもろの散文のみでなく、特に彼の主著『教行信証』についても言われ得ることである。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『教行信証』という外題で知られる彼の主著の内題は『顕浄土真実教行証文類』と掲げられている。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショウペンハウエルもその主著に次のごとく論じている。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品について「食品の混ぜ物処理および調理の毒物」（1820）は数多いアークムの著書のうちの主著と言うことができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "主著の二十三冊の詩集に八冊の随筆集、七冊の釣魚の書物、外に二冊の発句集をその生涯にのこした。",
              "citation": {
                "source": "〈我が愛する詩人の伝記〉（補遺）",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の主著『正法眼蔵』の第一章は、この廃院において、右のごとき社会的環境の下に、書かれたのであった。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがリードの主著（Inquiry into the Human Mind on the Principles of Common Sense）が、人間の外部的諸感官の問題から出発していることは多少の注意に値する。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア滞在中主著『人間の頭脳、労働の本質、一職工の書ける。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて彼の主著によれば、カント哲学の欠点は統一と体系とに乏しいことに存する。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来ニュートンの科学上の功績とその組織的な方法（夫は『自然哲学の数学的原理』という主著の名称がよく説明している）は、広く当時のイギリス、フランス、ドイツ其他の啓蒙学者を、動かしたものである。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何冊かの本を書いているが主著である１冊だけが残っている。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエトロの医学における主著は「哲学者と特に医学者との違いのコンキリアトール（調停者）」であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは同時代人であったがサントリオはハーヴィより15歳年上であり彼の主著は「心臓と血液の運動」より14年前に刊行された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の主著「医学の基礎」は死後の1648年に息子によって刊行された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "主著「完全な医事行政の体系」の最終巻が1817年に刊行されたときに彼は72歳であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の主著のことを忘れてはいなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めて主著をものする時になった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の主著はまだ終了してはいないで述べたいことがもっとあった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒー「神の飲み物」は素晴らしく主著の第５巻の執筆は急速に進展した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は死ぬまでウィーンに留まり再び盛大に開業をし主著の第６巻を書いた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　コルヴィザールは自分の主著をモルガーニの例にならって「診断徴候によって研究し解剖学によって確認した病気の座ならびに原因について」と命名したかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥールーズ、モンペリエおよびパリで学び1798年には主著である「哲学的疾病論」を刊行した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに1839年に彼の主著であるモノグラフ「打診聴診についての論考」が刊行された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンテーニュはこの人の主著 Historia de diis gentium を蔵していた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "諭吉は一｜夫一｜婦をしゅちょうし、もちろん、自分でもそれを実行しました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
