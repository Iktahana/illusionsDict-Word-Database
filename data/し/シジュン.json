[
  {
    "uuid": "5864ebea-4b9f-57b8-a3f8-dde8352787b3",
    "entry": "諮詢",
    "reading": {
      "primary": "しじゅん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
