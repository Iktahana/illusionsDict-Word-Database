    "definitions": [
      {
        "index": 1,
        "gloss": "discourtesy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「失礼ですが、おいくつで？",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君が見ないさきに僕が拝見するのは失礼だと思ったから、ほんのちらと瞥見したばかりだが、でも、桜の花のような印象を受けた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「失礼でございませうが、私は日本の酒は飲めないんで……」と言つて、「イヒヽヽヽ」と追従笑ひをした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はあまり立入った質問だと思ったのでつい失礼な返事を出してしまった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあつたが自分達の盆の餅をすゝめて、さうして此人達から新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあったが自分たちの盆の餅をすすめて、そうしてこの人たちから新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ずいぶん失礼ね」「どうせあなたは偉いのよ」みち子は怒って立上った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ではわたくしどもは失礼いたします。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授はじぶんも手袋をはめてないのに気がついて　あ失礼と云ひながら室を出て行った。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼ですがあなたはＫさんですか」ちょっとそう云って聞いてみたいような気がした、と同時に、それが自然に何のこだわりもなく云えるまでに到達していない自分を認識することが出来たのであった。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝て居なくてはいけないなんの病中に失礼も何もあつたものぢやアないそれとも少し起きて見る気なら僕に寄りかゝつて居るがいゝと抱き起せば居直つて。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは『失礼ですが貴方の顔が著しく猿に似ているという事実が貴方の学説をひどく左右したのだと思います』というのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま来客でもあって応接していると、肝心な話の途中でもなんでも一向｜会釈なしにいきなり飛込んで来て直ちに忙わしく旋回運動を始めるのであるが、時には失礼にも来客の頭に顔に衝突し、そうしてせっかく接待のために出してある茶や菓子の上に箔の雪を降らせる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの画家は花というものの意味がまるで分らないのではないかという失礼千万な疑いが起るくらいである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに汚ない話で失礼。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の一人がつかつかと傍へ寄り、　「失礼だが、若しやお前さん武井の安五郎さんの身内で神沢の小五郎さんとは仰しゃいませんか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえね、ひょっと妾と入れ違いに帰って居るかも知れないから」　「妾もう失礼しますよ、源兵衛さん、御邪魔しました」　「あ、お帰りかね」　「さようなら」Ｓ＝茶店の表　お勘婆さん、帰って行く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛が、　「清水の次郎長さんとか仰言いましたが、お前さん、やくざ渡世の人だろう」　「そうだ、爺つあん」　お静戻って来て　「はい、縫いますわ」　「あ、こりゃどうも済まない」　源兵衛が、　「失礼だが、此処は堅気の年寄りの住居だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、手前共親分が石松つあんに色々御厄介に相成りましたそうで、親分に代りまして厚くお礼申し上げます」　と菓子包か何かを差し出して、　「失礼で御座いますが、どうかお納めなすって……」　源兵衛、考え込んでいる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実ァ儂は急ぎの用事が御座いますので、これで失礼致します。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあんまり失礼だと思いまして」　貝原がようやくまともに向けた顔を真直ぐに見て、さびしい声で小初は云った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼とか恥かしいとか云っている世の中じゃないと思うわ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ですが、奥さんは必要なもののありかをご存じですか。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "チタ子はひどく憂鬱そうな顔をして狭苦しい椅子に埋れていましたが、私が、自分の席へ誘うと、黙々として私の卓子にやってきて、　――失礼ですが、妾を天下茶屋の家まで送ってください。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先方は全く石井翁に気がつかなかったものと見えて、翁に声をかけらるるといきなり飛びたって帽をとり、「コレはコレは石井さんですか、あなたとはまるきり気がつかんで失礼しました。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし滅多に鯉なんぞは釣れませんでした」「そりゃあ失礼ながら、あなたが下手だからでしょう」と、老人はまた笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、失礼でございますが、お店へあがりましてもよろしゅうございましょうか」と、女は忍びやかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜ御不承知と云われます」「失礼ながら御屋敷の御家風が少し気に入りませんから」「異なことを……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用でございましたらば、わたくしから直々に申し上げます」「いや、そのような失礼があってはならぬ」と、式部はさえぎった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（失礼いたしました。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
