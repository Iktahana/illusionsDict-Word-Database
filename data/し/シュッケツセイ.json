          "standard": [
            {
              "text": "脳の血管が破れて出血性脳卒中を引き起こし、緊急手術が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのウイルスは感染すると出血性の症状を引き起こし、致死率も高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "皮膚に出血性の斑点が現れたら、すぐに専門医を受診してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは還流血液中の血小板が破壊され、出血性素因を生じたものと思われる。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉塞性黄疸でこのビタミンの吸収に障害のある出血性の患者や、抗ビタミン物質を含むスウィートクローバー干し草を食べていた家畜に、このビタミンは治療効果があった（84）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
