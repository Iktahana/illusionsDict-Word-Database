    },
    "definitions": [
      {
        "index": 1,
        "gloss": "head (of a household)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんなが何を話したか別段記憶しないが、ともあれみんな文学青年が先輩を詣でた式のことで、主人は間もなく退屈した。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、自分が自分の主人たり得てはゐない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は次第に気の毒さうにしはじめ、そのうち少し私を「脳不足」だといふ意味の目配せを主人やお主婦さんと交すやうになつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人やお主婦さんの方でも「御尤も」といふ顔をしてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて貧困の家に育ち、肉親の愛にめぐまれずして家庭的、環境的の不遇に成長した人々は、そのかつて充たされなかった心の飢餓を、他の何物にも増して熱情するため、後に彼が一家の主人となった場合、その妻子の忠実な保護者となり、家庭を楽園化することに熱心である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仕事をしている時のヘルンは、最も気むずかしやの八釜しい主人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら神にならずして、だれが眞に完全に、自分自身の主人になり得るか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな田舍臭い百姓歌の主人公が、灯ともし頃に羽織をきて、新宿の宿場を漂泊して居るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、妙な美談の主人公になろうとして、こんな事を言っているのではありません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのなあ、遠い親類の主人が死んだんださうだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公ラスコリニコフの心理と言行とが、小説の最初から大尾まで、魔法のやうに僕の心を引き捉へて居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕はニイチェを讀んで居たので、あの主人公の大學生が、ナポレオン的超人にならうとイデアした思想の哲學的心境がよく解り、一層意味深く讀み味へた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白痴」を讀んだ時は、主人公の精神病的な異常氣質が、たまたま僕とよく酷似してゐる點があるので怖くなつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その小説の主人公である白痴の貴族が、丁度その僕と同じ精神変質者であったからだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴の主人公は、愛情の昂奮に駆られた時、不意に対手の頭を擲ろうとする衝動が起り、抑えることが出来ないで苦しむのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張、不如帰の女主人公を思はせるやうな、少しく旧式な温順さをもつた、どこか病身らしい細顔の女たち――である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤の埃の中にして捨松ここに思ふ樣老店の主人三代の暖簾をくぐる町人は幾度同じ夢を見て繰り返したる榮落に街の繁華は見たるなり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳を聾する亂調に入興ありたる擧動やお竹つらつら思ふ樣こは夕暮を酒にして主人の笑を見んと也忠義ぶりなる店の子が賢かりける可笑しさよ。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもう五十を越した、人の好さそうな男であるが、主婦はこれも五十近所で、皮膚の蒼黄色い何処となく険のあるいやな顔だと始め見た時から思った。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人夫婦の外には二十二、三の息子らしい弱そうな脊の高い男と、それからいつも銀杏返しに結うた十八、九の娘と、外には真黒な猫が居るようであった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "養子に離れ、娘にも妻にも取り残されて、今は形影｜相弔するばかりの主人は、他所目には一向悲しそうにも見えず、相変らず店の塵をはたいている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この紙屋というのは竹村君と同郷のもので、主人とは昔中学校で同級に居た事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の妹で十九になる娘が居て店の奥の方でちらちらする時がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の出入りは忙しそうであったが、主人は相変らず落着いて相手になっていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中学校を出るとすぐに生真面目な紙屋の旦那になっている主人と、自分のような人間との境遇の著しい違いを思い較べていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室津の宿屋の主人はかなりのお婆さんであったが、われわれ二人の中学生の初旅を珍しがって大変にもてなしてくれた上に「珍しいものを見せて上げよう」と云って持出して来たのが一巻の絵巻物であった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐田太左衞門氏は、ゆゐしよある老舖の御主人にして、これまた、長者のふうあり、もののわかりのよきこと無類、三四年前、私と一緒に銀座うらを漫歩せしことありしが、私をしてまるで、鏡花、荷風などの老文士とともに在るが如き思ひを懷かしめた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "細木香以に就いては、森鴎外くはしくこれを述べて居る故、われら小倉袴のぶんを以てかれこれ言ふべきではないが、通人とは、世人が考へて居られる如き、藝者末社をひきつれ、自らを何のや主人と稱して長唄の稽古にいそしみ、その巷に於いて兄さん兄さんと呼ばれて居る樣の、そんなふざけたものではないやうである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもう客の事なんか忘れてゐるのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
