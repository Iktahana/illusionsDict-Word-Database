  {
    "uuid": "7f9df880-9724-5945-8494-ac43fdd8cb53",
    "entry": "主人",
    "reading": {
      "primary": "しゅじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
