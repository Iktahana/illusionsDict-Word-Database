        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裏漉しの香ひそのものこそ香ひらしく染み出して来る。",
              "citation": {
                "source": "香ひの狩猟者",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると飽くまで白い頬に裏から朱を溶いて流したような濃い色がむらむらと煮染み出した。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが額際へ来て何時もの様に蒼白く変つてゐる辺に、汗が少し煮染み出した。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて天井を見上げると、桧の板を深紅に染めて生血が四角に染み出している。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「む」と思わず呼吸を呑み、再び天井を見上げたとたん、四角に染み出していた板の血がヒラヒラと剥げて落ちて来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕も首も胸も太い西を包む空気が、彼の内から染み出してくる圧力を受けてじっとりと密度を増していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその後彼女以外の――仮に３と呼ぶとすれば、３と云ふ女と馴染み出した。",
              "citation": {
                "source": "貝殼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼に反感を生じ、彼以外の――仮に４と呼ぶとすれば、４と云ふ男に馴染み出した。",
              "citation": {
                "source": "貝殼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが額際へ来て何時もの様に蒼白く変っている辺に、汗が少し煮染み出した。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助の額からは汗が※染み出した。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ創口の方はそっとしておかないと、危険ですから」　彼はこう注意して、じかに局部を抑えつけている個所を少し緩めて見たら、血が煮染み出したという話を用心のためにして聴かせた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助の額からは汗が煮染み出した。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は、家計をやりくりして行くのに一層苦しみだした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食後の散薬を呑んだかとおもうと、間もなく妻は吐気を催して苦しみだした。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今の今、眼の前に苦しみだしている妻が死に吹き攫われてゆくのかどうか、彼にはまだわからなかった。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまままた病床に横たわった御息所ははなはだしく苦しみだした。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がまた疼痛に苦しみだし、頓服の鎮痛剤があいにく無くなっていたので、夜分ながら、医者のところへ薬を貰いに行った。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、なか／＼天気になる模様がないばかりでなく、ちよつとした風邪の心地でゐた子供が、だん／＼苦しみだしてきました。",
              "citation": {
                "source": "シャボン玉",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、自分がたべたとき、へんな味だと思いましたが、ああ、あいた、あいた、あいたたたッ」　ピート一等兵は、とつぜん顔をしかめ、自分の腹をおさえて、くるしみだした。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸っとその家に落ちついて、まあこれでいいと思っていると、突然薫さんが癪をおこして苦しみだした。",
              "citation": {
                "source": "花を持てる女",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、私は、急速に外界をなつかしみだした。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が赤くなるのは一滴ものめなくてムカムカ吐き気に苦しみだした時なのだが、人はそうとは知らないから、オヤ、今日は大そうゴキゲンですね。",
              "citation": {
                "source": "人生三つの愉しみ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しみだして十分間ほどの短時間であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車で聖路加へ運ばれ、意識不明のまま二十五日の払暁まで保っていたが、間もなく苦しみだし、七時ごろ息をひきとった。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "車輪が砂利を噛んできしみだした。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午後から、親子は腹痛と下痢で苦しみだしたのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが――そういう彼の気ぶりや、弟子たちの支度を見て、慈父を失うように悲しみだしたのは、国司の萩原年景をはじめ、この国の頑是ない土民たちであった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「黄信は討死にしたらしい」　と、俄かにみな悲しみだした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を狙って、見事に相手を斬って仆したことは仆したが、いかにも、無造作だったことと、弦之丞にしては、余りにもろかったと気がついて、天堂一角、「や、これは、いぶかしい」　と、すぐに自身の得意をあやしみだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いくら射ても、射ても※は燦爛として、位置も変らないので、射手の兵は怪しみだし、やがて近づいてきて、「や、孫堅はいない」「※ばかりだ」と、立騒いでいた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
