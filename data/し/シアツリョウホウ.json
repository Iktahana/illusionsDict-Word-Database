        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ねえ、ツルちゃん、戦争中は、皇大神宮に指圧療法、終戦後は、寝釈迦、お助けじいさん、一家ケン族みんな信仰しなきゃア、カンベンしてくんないんですからね。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "連盟のその香月さんと言うのも結局指圧療法の先生みたいな。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十三日　〔巣鴨拘置所の顕治宛　山口県島田より（封書）〕　四月二十一日夜　　第三十四信　今下へ近所の細君で指圧療法をする人が来ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "指圧療法の市川といふのが来り、三十分やる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "市川が待ってゐて指圧療法を行ふ、当分つゞけると肩のこりなどとれると言ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "市川の指圧療法を受ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終ると、市川来り、指圧療法を行ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "指圧療法氏待ってゐて、早速やる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出ると、指圧療法は三十分。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出る、市川来り指圧療法をやり払ひをすませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
