        "examples": {
          "standard": [
            {
              "text": "歌舞伎の演目の中でも、白浪五人男は特に有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "白浪五人男の劇中歌は、今でも多くの人に歌われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来月、劇場で白浪五人男の公演があるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あのう、白浪五人男の稲瀬川の勢揃ひの場で、それぞれツラネの台詞がありますね。",
              "citation": {
                "source": "或る日の小せん",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸文化は、泥棒までを、白浪五人男のやうに理想化して、これに“美”をすら見ようとしてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
