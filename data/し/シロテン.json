  {
    "uuid": "dfdd6160-2fb8-598c-9e94-7d4a0f148a43",
    "entry": "白天",
    "reading": {
      "primary": "しろてん",
      "alternatives": [
        "はくてん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "white deep-fried kamaboko",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おでんには、この白天が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "炙った白天に生姜醤油をつけて食べるのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "郷土料理の煮物には、必ず白天が入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "南京鼠　上着は白天鵞絨、眼は柘榴石、それから手袋は桃色｜繻子。",
              "citation": {
                "source": "動物園",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白天鵞絨の蓋を明けると、一つには真珠の、他の一つには土耳古玉の指環がはいっている。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらをごらんなさい、花も、葉も、枝も、すっかり白天鵞絨ではございませんか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒天使は今や白天使と変じた。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた少し間をおいて、前の茶碗よりずっと小ぶりな白天目に緑いろの抹茶をたたえ、足の運びもゆるく、貴人にたいする作法どおり、物静かに秀吉のまえに置いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣外には、白天地の夜を、吹雪が吹き暴れていた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
