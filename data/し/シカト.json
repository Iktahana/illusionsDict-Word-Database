  {
    "uuid": "dd4df0d0-8729-50c4-b634-363f2175a9af",
    "entry": "確と",
    "reading": {
      "primary": "しかと",
      "alternatives": [
        "しっかと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "certainly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、昭公が一緒に居たのは、確とおなごかな。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉のやすらかなるは極めてよし、言葉の確と実際に協ひたるは、ひときはよきなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで古い莚をかけるか何かして確と番をしておんなさい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当然の結果として肝心の正確という事が常に犠牲にされがちである事はだれもよく知るとおりである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし茶目気分｜横溢していてむつかしい学科はなんでもきらいだという悪太郎どもにとっては、先生の勤勉と、正確というよりも先生の教える学問のむつかしさが少なからず煙たくもあったらしい。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を挙げて日本橋を見ると晴れた初夏の中空に浮いて悠揚と弓なりに架かり、擬宝珠と擬宝珠との欄干の上に忙しく往来する人馬の姿はどれ一つとして生活に自信を持ち、確とした目的に向って勇ましく闘いつつある姿でないものは無い。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "確とそうならば、これは是非書き遺して置き度い。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二一課　橋は流れて水は流れず　私たち鰹節をナイフで削るときには、鰹節を確と握り押えてナイフの方を動かして削ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤熊は星が痛そうに、額を確と両手で蔽い、「ところが、そうでない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干に確と両手を掛けた、が、熟と黙って、やがて静に立直った時、酔覚の顔は蒼白い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕丁　私が、確と圧えておりますればこそで、うかつに棄てますと、このまま黒蛇に成って※り廻りましょう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　多津吉は確と腕を拱いた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鏨をば押頂き、確と懐中に挿入れた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲れながら、姿見の裡なる、我にまがう婦の顔にじっと見惚れて、乱れた髪の水に雫するのさえ確と見た。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、先生が夏の嘉例として下すつた、水色の絹べりを取た、はい原製の涼しい扇子を、膝を緊めて、胸に確と取つて車上に居直つた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸を横行する黒いものの形を確と見覚えておかねばならん。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は駕籠の手に確と縋った。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見向いた時、畦の嫁菜を褄にして、その掛稲の此方に、目も遥な野原刈田を背にして間が離れて確とは見えぬが、薄藍の浅葱の襟して、髪の艶かな、色の白い女が居て、いま見合せた顔を、急に背けるや否や、たたきつけるように片袖を口に当てたが、声は高々と、澄切った空を、野に響いた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、天女のようだとも言えば、女神の船玉様の姿だとも言いますし、いや、ぴらぴらの簪して、翡翠の耳飾を飾った支那の夫人の姿だとも言って、現に見たものがそこにある筈のものを、確と取留めたことはないのでございますが、手前が申すまでもありません。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものように黄昏の軒をうろつく、嘉吉｜奴を引捉え、確と親元へ預け置いたは、屋根から天蚕糸に鉤をかけて、行燈を釣らせぬ分別。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そして、後は、」　と美しい女は、白い両手で、確と紫の襟を圧えた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と肩を斜め、手を、錆びたが楯のごとく、行燈に確と置く。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手で、挫ぐばかり確と膝頭を掴んで、呼吸が切れそうな咳を続けざまにしたが、決然としてすっくと立った。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄上に逢うたらばそのおもむきを確と申傳へてくりやれ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男か女か確とは判らぬ、唯蒼白い顔が朦朧と浮き出したかと思う間もなく、四辺は再び旧の闇に隠れて了った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて立ツてゐても爲方が無いから、後へ引返す積りで、ぼつ／＼歩き始めたが方角とても確と解ツてゐなかツた。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、これは甚だロマンチックの仮説でありますけれども、この小説の描写に於いて見受けられる作者の異常な憎悪感は、（的確とは、憎悪の一変形でありますから、）直接に、この作中の女主人公に対する抜きさしならぬ感情から出発しているのではないか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いざとなれば死にさえすればいいのだ」鼈四郎は幼い時分から辛い場合、不如意な場合には逃れずさまよい込み、片息をついたこの無可有の世界の観念を、青年の頭脳で確と積極的に思想に纏め上げたつもりでいる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつを、あの青みどろを、しかと掴んで計算し、その在りのままの姿を、克明に描寫し、黒白確實に、表現し、それを、やさしい額縁にいれて呈出したい。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜なくやと試みたれど、さらに声の聞えねば、俄かに露の身に寒く、鳴くべき勢ひのなくなりしかと憐れみ合ひし、そのとし暮れて兄は空しき数に入りつ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
