    "definitions": [
      {
        "index": 1,
        "gloss": "promotion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、卒業まぎわになって、清三は高商が大学に昇格したのでもう一年在学して学士になりたいと手紙で云ってきた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎は既に一万円近くの金を貯めた、馴染の女郎を身請けしてかこってしまうと、彼の放蕩は急に昇格して芸者遊びになり、そしてハイカラ振ってその頃道頓堀に出来た大阪名物カフェ美人座にもしげ／＼と通った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日で嫌気がさしてしまったが、近いうちに記者に昇格させてやると言われたのを当てにして、毎日口惜し涙を出しながら出勤した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月×日　昨夜八時半頃ロイドと自室にいると、ミタイエレ（十一・二歳の少年召使）がやって来て、一緒に寐ているパータリセ（最近、戸外労働から室内給仕に昇格した十五・六歳の少年、ワリス島の者で英語は皆目判らず、サモア語も五つしか知らない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした人たちは弘徽殿の女御がだれよりも早く後宮にはいった人であるから、その人の后に昇格されるのが当然であるとも言うのである。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に先年｜合祀を強行して、いわゆる基本財産の多寡を標準とし、賄贈請託を魂胆とし、邦家発達の次第を攷うるに大必要なる古社を滅却し、一夜造りの淫祠を昇格し、その余弊今に除かれず、大いに人心｜蕩乱、気風壊敗を致すの本となった。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇格問題や徴兵猶予、又は無試験入学に関する各種の運動、又は官私立の区別撤廃といったような叫びが起った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、これはやっぱり、今日の教授昇格が自分の心を苦しめるのだ。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまり此の大神宮を昇格させようとする事なのです。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先は、ますます修行を積み、やがて守護靈さんにまで昇格するのを目標として勵むのである。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "義太夫を呼べ　専門学校昇格問題できこえた文部大臣Ｎ氏が、ある時、知合の二三人に誘はれて廓に行つたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「感心をしない」ということは、昔は「感心をする」という積極的な心理作用の反対の状態を示すための、極めて消極的な影の薄い言葉にすぎなかつたはずであるが、現在では「感心をしない」ということ自身が独立した一つの能動的心理作用にまで昇格してしまつた観がある。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日本女子大学と英学塾とは早速大学に昇格するための運動を開始した。",
              "citation": {
                "source": "女の手帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立大学の昇格申請が最近においてなされたが、注目すべきことは申請の全部が文科系統の学校であることである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテリングは、今日まで長く補祭の一人として勤めて、教会の善き仕事のために、いつも先頭に立って人一倍働いて来たので、その謝恩の意味で、今夜の集会で全教会員に押されて長老の地位に昇格することになっていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテリングは長老へ、ロスリッジはその後任の主席補祭へ、夫れぞれの昇格式があるので、教会員の殆んど全部が出席していた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで明治三十九年に、從來中祀とて、二等祭祀の待遇を受けて居つた孔子の祭典を、急に大祀に昇格させ、天地・宗廟と同等の待遇をすることとなつた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば明治になって新に士籍とはいわれまいが、広い意味に於ける士の族に昇格したものが沢山ある。",
              "citation": {
                "source": "平民道",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに見えることは、ふりがうたに昇格した事実である。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌右衛門になることは、必しも芸の昇格を意味しない。",
              "citation": {
                "source": "自然女人とかぶき女",
                "author": "――新歌右衛門に寄する希望――",
                "note": "青空文庫"
              }
            },
            {
              "text": "代宣者の感情や、呪言伝承・製作者らの理会や、向上しまた沈淪した神々に対する社会的見解――呪言神の零落・国社神の昇格から来る――や、天子現神思想の退転に伴ふ諸神礼遇の加重などが、其である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "河内国は昇格し、河内職をおかれた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "百川もこれに伴ふて昇格し、河内職の太夫になつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "工科系統の学校増設、収容人員の倍加が著しい戦時色の現れであり、師範学校の昇格は、国民学校の重要性を一段と認識させるに役立ちました。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇格した学校も少なくない。",
              "citation": {
                "source": "改善は頭から",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永山という村名は兵団長の名をとったのであろうが、彼が新設第七師団長に昇格して、旭川に鎮将となったのは明治二十七年のことである。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間よりも地べたにおり、人間よりも妄執と一しょにいるのだから、人間よりも鼻持ちならないのだから、人間に昇格することはあっても、落ちるはずはない。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを室内照明に使ふのは、アセチレンガスが昇格したのでなければ、使ふ人間が下落したのである。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によつて照子の家計切廻しの助手といふ触込みであつたが、こんどは中学生だといふので信用が増して、半ば秘書役に昇格させられた形だつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "各省の調査部も一時は調査局にまで昇格したことがあった。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
