[
  {
    "uuid": "5c9d05f7-8afd-5c25-a8ea-5c20355fbf0f",
    "entry": "種痘",
    "reading": {
      "primary": "しゅとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
