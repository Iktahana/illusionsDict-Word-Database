    "definitions": [
      {
        "index": 1,
        "gloss": "sampling food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シナ人が常食の高粱も再三試食したことがありますが、これは食えない事もありませんでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半搗米がなか／＼うまい、玄米も試食したい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日亀千代の前に出る膳部は、例によつて鬼番衆と云ふ近臣が試食した。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、猫肉試食などに対する興味を私も失った。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稲を試食した後だから、別の方法をとる村々もあつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで数年前ある冬の夜、虎の門のさる料亭で狸汁の試食会をやるという話を伝えきいた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は待望の機きたれりとばかりその試食会へ駆けつけた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、狸汁のことについては長い間忘れていたのだが、団栗のことから狸の身の上に思い及び無用の興を催していたところ、つい最近友人が訪ねてきて、ちかごろに狸の試食会をやろうではないかというのである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、僕ら数名が試食した上、これなら食えると感じたなら、一番この際、狸公を世の中へ出してやろうではないか、と友人は熱心に説明するのであった。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一堂に会して試食しなかったというのは、めいめい家へ持ち帰り自由に料理して食った方が、各人それぞれ異なった趣好によって、狐肉の美味の真髄を探ることができるであろうという申し合わせであったからである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむを得ないから、友人に試食の報告をきいて狐の風味を想像しようと考え、二、三日後数名の友人と会したのである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき撃ち取った羆を友人数名と共に、小石川富坂の富士菜館へ持ち込み、南支の広州からきた料理人の手にかけて、十数種類の支那料理にこしらえ、さまざまに試食したことがあったけれど、その折りのおいしさもさることながら、老妻の手にかけた月の輪熊の醤は格別である。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽の産物だといって、じゃがいもパンの試食をさせられ、十銭の包みを一つ買い込んだ、あとで食べて見たら相当に風味がよかった。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国の終戦後たべる物がまだ出揃はず、家庭でパンやビスケットを焼いてゐる時分に、粉の中にバタをすこしばかり交ぜて焼きながら、そのバタの量で柔らかみが少しづつ違ふのを試食してゐる時だつた。",
              "citation": {
                "source": "身についたもの",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンに着いたら、なにはおいてもビーフステーキを試食するのを楽しみにしていましたが、残念なことに、ここではまだ肉が配給制度なので思うにまかせず、まだこの念願は叶えられずにいます。",
              "citation": {
                "source": "デンマークのビール",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "食用ガエルは、日本でも盛んに使われていますが、なんのこともなく、別においしいとも思ったことはありませんでしたが、シティ・グリルで試食してからというもの、食用ガエルに対する認識を新たにしました。",
              "citation": {
                "source": "ハワイの食用蛙",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいよいよふしぎになって、残りの一尾を今度は用心しいしい丁寧に試食してみたが、やはり、わたがない。",
              "citation": {
                "source": "鮎ははらわた",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで数年前ある冬の夜、虎の門のさる料亭で狸汁の試食会をやると言ふ話を伝へきいた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は待望の機きたれりとばかり、その試食会へ駈けつけた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、狸汁のことについては長い間忘れてゐたのだが、団栗のことから狸の身の上に想ひ及び、無用の興を催してゐたところ、つい最近友人が訪ねてきて、ちかごろに狸の試食会をやらうではないかと言ふのである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、僕等友人数名が試食した上、これなら食へると感じたなら、一番この際狸公を世の中へだしてやらうではないか、と友人は熱心に説明するのであつた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一堂に会して試食しなかつたと言ふのは、銘銘家へ持ち帰り自由に料理して食つた方が、各人それ／″＼異つた趣好によつて、狐肉の美味の真髄を探ることができるであらうと言ふ申し合せであつたからである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむを得ないから、友人に試食の報告をきいて狐の風味を想像しようと考へ、二三日後数名の友人と会したのである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし若鶏の肉にも似ているが、鰒の刺身のようでもあるのう、貴公はもう試食済みか。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、試食どころではない、常食にしちょる。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでだ、同好の士を語らい、これを料亭へ持ち込んで、多勢して試食してみようではないか、という豪勢な次第となった。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は見たことはないが、手に入れば試食してみたいと思っている。",
              "citation": {
                "source": "蝦蟇を食べた話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理人はせっかく手がけたものが充分食べられなかったり、手がつけられなかったりした場合は、もう一ぺんこれを生かして、自分達の味覚研究として、試食するくらいの機転がなくてはならない。",
              "citation": {
                "source": "残肴の処理",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい材料を使って、手塩にかけたものが客の腹加減から用を足さないで戻ってきた場合、またもう一度これを生かす工夫に心して、自分たちの同僚のもので、試食研修してみるくらいの興味を持たなくては失格である。",
              "citation": {
                "source": "残肴の処理",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞見はなかなかトボケた人で、この横浜を見に来たよりも、実は牛肉の試食に来たと白状する。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
