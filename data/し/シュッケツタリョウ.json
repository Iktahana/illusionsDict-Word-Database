        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兵士Ｃに至っては脚部の出血多量で死したのである。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕を一本放しちまえば、あとは出血多量で極楽へ急行だよ。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "頸動脈をするどい刃物で斬られて、出血多量で死んだと思います」「自殺ですか。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために兵曹長は、重傷を足に負い、出血多量で人事不省になってしまった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "出血多量というやつで、今朝がたに輸血までしたのですが、ここらで気がついてくれればいいのですがねえ」　と言った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その血をみせえま」と和助は続けた、「そのまま連行すれば、出血多量で途中で死んじまあだぜ」「そうだ、死んじまあだ」とみんなが口ぐちに喚いた、「一町といかねえうちにおっ死んじまうだ、銀がそれほどの罪を犯したかえ、死げえにするほど悪いことをしたかえ」　私服たちは立停った。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
