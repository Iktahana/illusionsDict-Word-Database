  {
    "uuid": "442d4f6d-5446-5d6a-8d40-0f20814862d1",
    "entry": "掌底",
    "reading": {
      "primary": "しょうてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "palm heel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かくても媚びて、家鴿のやうやうなづむそのさまや、片羽あげても移れかし、いざ、掌底の宮のうへ。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまらにをやらふ（喫）るがねや、一つき二つき、ゑらゑらにたなぞこ（掌底）うちあぐるがねや、三つき四つき、言直し心直しもよ、五つき六つき、天足し国足すもよ、七つき八つき。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "善しと匂へる花瓣は徒に凋みて、惡しき果は熟えて墜ちたりおのづからわが掌底に、生温きその香をかげば唇のいや堪ふまじき渇きかな。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
