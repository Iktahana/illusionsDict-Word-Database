[
  {
    "uuid": "3b7de6be-f209-54ff-a969-4831e5f5cb4e",
    "entry": "小弟",
    "reading": {
      "primary": "しょうてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "little brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右に付小弟次第に譫語す、宜しく妄聴し給はる可く候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小弟二男ニ生れ成長ニ及まで家兄に従ふ。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十一月　溝淵広之丞あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "是小弟長く浪遊して仕禄を求めず、半生労苦辞せざる所、老兄ハ小弟を愛するもの故、大略を述。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十一月　溝淵広之丞あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "益御安泰可被成御座候然ニ先頃ハ罷出段相談候より余程夜の明候気色、重役共又｜竊に小弟にも面会仕候故、十分論申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月十四日　木戸孝允あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小弟も二月十日ニ長崎より下の関まで帰着仕候事ニ御座候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十四日　河田左久馬あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、其御地ニ御留りニて、つがふよろしけれバ別に御出浮被成ずてもよろしく、小弟可後便申上候時を御まち奉願候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十四日　河田左久馬あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "○其内、土佐国の勢がよ程なおり、長崎ニ出たる参政後藤庄次郎共、小弟に面会、十分議論致したりしに、大ニおもしろき勢、当年七八月の頃ニハ、土佐も立なおりて、昔日の長薩土となりハすまいかと相楽ミ申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十六日　三吉慎蔵あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時小弟ハ土佐人高坂龍次郎と申て出かけ、色々おかしき談ありしが、変りたる事なし。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十六日　三吉慎蔵あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "其余の事ハ不分明、小弟思ふニ、三吉大夫が陸軍をおさめたまいし時ハ隊中一同皆報国の赤心を振起し、大夫の賢なるをかんじ居候よし也。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四段小弟ハヱゾに渡らんとせし頃より、新国を開き候ハ積年の思ひ一世の思ひ出ニ候間、何卒一人でなりともやり付申べくと存居申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中助太夫事、別ニ小弟の志を憐ミ、且積年の思ひも在之、不屈して竊ニ志を振ひ居申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五段先日御耳ニ入レし時内※仰せられしニ、三慎ニあらざれバ自ラ出行致したしと、小弟誠ニ幸也。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六段此月の初より長崎ニ出、大洲の船の来るをまち申べしと思ふ内ニ、小弟先日中風けニて床ニおり候ものから、心ニまかせず彼是する内ニ、大洲の船と共に長崎ニ廻るよふニならんかと思ひおり候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の流レハ十里斗なりと、小弟｜曽而長崎ニニて聞しニ何とも相似たる咄し也。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし御自身御出ニならずとも御同心の故を以て、其割ニ当ル金御出被遊れバ、小弟も外ニ人おつのるに及バず。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小弟をして海援長と致し、諸君其まゝ御修業被成候よふ、つがふ付呉候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年四月二十八日　菅野覚兵衛、高松太郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫で小弟が曰ク、私し出崎の上ハ此度の紀土の論がどふかた付申かも｜不被計、故に小弟が命も又不被計、されども国を開らくの道ハ、戦するものハ戦ひ、修行するものは修行し、商法ハ商法で名。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月五日　三吉慎蔵あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "御聞取可被下」小弟是より長崎へ廻り不日ニ上京仕候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月五日　長岡謙吉あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "是が来らぬと聞けば、小弟に限りなげき死に可申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月下旬　佐々木高行あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上此頃の上国の論は先生に御｜直ニうかゞい候得バ、はたして小弟の愚論と同一かとも奉存候得ども、何共筆には尽かね申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月二十日　木戸孝允あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小弟下ノ関居の日、薩大久保一蔵長ニ使者ニ来り、同国の蒸汽船を以て本国に帰り申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月二十四日　渡辺弥久馬あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して然らバ小弟亦薩長二藩の督責を免れず。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月十三日　後藤象二郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小弟｜者御国ニて五十金、官よりもらいしなり。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月中旬　後藤象二郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小弟思ふニ、御国表の不都合の上、又、小弟さへ屋鋪ニハ入ルあたハず。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月十八日　望月清平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、思ふニ、大兄ハ昨日も小弟宿の事、御聞合｜被下候彼御屋鋪の辺の寺、松山下陳を、樋口真吉ニニ周旋致させ候よふ御セ話被下候得バ、実ニ大幸の事ニ候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月十八日　望月清平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "度※小弟ニ参り相談致し候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月二十二日　陸奥宗光あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小弟が手より金一万両出セとのこと也。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月二十二日　陸奥宗光あて",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
