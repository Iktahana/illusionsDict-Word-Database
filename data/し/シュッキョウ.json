[
  {
    "uuid": "47e190bd-7c4c-59b0-8c92-97fb8d490742",
    "entry": "出京",
    "reading": {
      "primary": "しゅっきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
