    "definitions": [
      {
        "index": 1,
        "gloss": "to die down (of a fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
