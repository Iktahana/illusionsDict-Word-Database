[
  {
    "uuid": "62cff0d7-b478-5296-b34a-57af2b5f57d0",
    "entry": "商策",
    "reading": {
      "primary": "しょうさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "business policy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "群衆は窓から投げられたひと塊の砂糖を目がけて集まる蟻のように、百貨店の取った商策に雲集してきたのであった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校野球においてそうであるばかりでなく、商魂商策においても似た地位にあるようだ。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後銀座通に再び柳が植えられた頃から、時勢は急変して、妓家酒亭の主人までが代議士の候補に立つような滑稽な話は聞きたくも聞かれなくなったが、その代りカフェーの店先にも折々｜鎧をきた武者人形が飾られ、骨董屋の売立広告にも「珍品の砲列を布き廉売の商策を回す」などいう文字を見るようになった。",
              "citation": {
                "source": "枇杷の花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上、申し述べました事は百貨店対抗策の一端に過ぎませんが、要するに小売商人が、従来の如く自己本意の商策を弄せず、社会の進歩、生活の向上発展に寄与するの精神をもって、合理的研究を怠らないならば、すべての難問題も容易に解決し得らるる事を確信致します。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、父の放漫なやり口や花柳界における遊び方は、いくら外人相手の商策上の必要もあったといえ、ひとの目に余るものがあったにちがいない。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "風車の別荘に罐詰とされた商策の捕虜たちは、理平のたくみな歓待に日を忘れて、出帆の朝の間際まで、完全に、二日二晩を、そこで沈酔していた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
