        "index": 1,
        "gloss": "first half of a tea ceremony (in which the charcoal is set and light food served)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
