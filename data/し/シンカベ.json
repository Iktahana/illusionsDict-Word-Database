    "definitions": [
      {
        "index": 1,
        "gloss": "wall with exposed timber pillars",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
