    "definitions": [
      {
        "index": 1,
        "gloss": "advocate (of a theory or principle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かくてこそ、かの成巧者達が、大抵頸の硬い中庸主義者であり、殆んど理論なくカンでばかり体験し、苦労を咬み殺した人達であることが分ります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　さうよ、あなたみたいに、常識主義者ぢやないことよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　常識主義者が考へるとするとねえ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あゝさう、常識主義者つてのも河島さんが言つたのだつたけ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男一足下つて首をクネクネ廻して、頸の凝りを直す）夢だ…………常識主義者だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文學上における主觀主義者――それ故にまた浪漫主義者――としての私の立場は、芥川君の「あまりに文藝的な」「あまりに觀照的な」態度を好まなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に一方の眼から見れば、彼は超人的な藝術至上主義者だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自我崇拝主義者（となつた）であつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、甞て私が人々が伝統から学ぶことを余りに等閑にしてゐることを唱へるや、或る人達は私を伝統主義者の如くに思つた。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は伝統主義者であるのでも、ないのでもない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車を降りて、別れる時に、「恋なら恋のやうに神剣にな、君はダラダラしてゐる……」　従兄が彼の肩に両手をかけて人道主義者のそのワザとらしい親切さで言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の断じて立言し得ることは、蕪村が単なる写生主義者や、単なる技巧的スケッチ画家でないということである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規一派の俳人が解した如く、蕪村は決して写生主義者ではないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点で芭蕉も、蕪村も、西行も、すべて皆楽天主義者の詩人に属している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は決して、子規一派の解した如き浅薄な写生主義者ではないけれども、対象に対して常に即物的客観描写の手法を取り、主観の想念やリリックやを、直接句の表面に出して咏嘆することをしなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国枠主義者の観念は、すべての輸入した外国文化を、無理にこじつけて、不自然に創作しようと努力する。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の文豪である大トルストイが、救世軍的人道主義者として擔がれたり、通俗モラルのセンチメンタリストとして、女學生の涙劇的ヒロイズムの對象であつたりしたことを考へると、今から考へて全く馬鹿馬鹿しく滑稽である。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々と玄関を構えてる医者の家へ、ルンペンか主義者のような風態をした男が出入するのを、父は世間態を気にして、厭がったのは無理もなかった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂利己主義者ではないのであらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、女はおれを高邁な理想主義者だと思つてゐるらしく、なかなか誘惑してくれない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "造作は永久に取付けない――」　併せて彼はフランス主義者だ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ何とかいう西班牙の無政府主義者の女ね。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども俺は快楽主義者だ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと云って彼は有りふれの社会主義者でもなければ共産党でもない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鴫立つ澤の秋の夕ぐれ」などといふ歌をよむと、昔の厭世主義者の詩境がよくわかる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが感覺派といふ言葉が、もし感覺主義者を意味するならば、彼の本領は反對である。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの虚無主義者と看做されている主人公の医学生に賛同しているというので、貴族｜等は作者を攻撃する。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその作の性質から自然探偵小説的な匂のするクロポトキンの『革命家の思出』ステプニヤツクの『虚無主義者の經歴』、ロオプシンの『青白い馬』など、何れも愛讀した。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
