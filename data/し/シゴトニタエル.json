          "literary": [
            {
              "text": "けれども努力さへすれば、充分複雑な仕事に堪えるといふ自信があつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がもし失脚して、彼と同様の地位に置かれたら、果して何の位の仕事に堪えるだらうと思ふと、代助は自分に対して気の毒になつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども努力さえすれば、充分複雑な仕事に堪えるという自信があった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がもし失脚して、彼と同様の地位に置かれたら、果してどの位の仕事に堪えるだろうと思うと、代助は自分に対して気の毒になった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "安逸を貪る者は、この仕事に堪えることができぬ。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
