    "definitions": [
      {
        "index": 1,
        "gloss": "social page (of newspaper)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
