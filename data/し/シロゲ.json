    "definitions": [
      {
        "index": 1,
        "gloss": "white (horse coat color)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戯れ絵のように、儀礼的な刑事部屋で、あぐらをかいた白毛のまじった老警部が私に言った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの狗子白毛にて黒斑、惶々乎とし屋壁に踞跼し、四肢を側立て、眼を我に挙げ、耳と尾とを動かして訴えてやまず。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そもそもこの八溝山というのは、全く海抜三千三百三十三尺という不思議な高さで、山中には三水と唱える金性水、竜毛水、白毛水の清泉が湧き、五つの瀑布と八つの丘嶽とまた八つの渓谷とがあって、孰れも奇観だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "日南に霜が散ったように、鬢にちらちらと白毛が見える。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸の口から覗いていたらしい白毛の大猿が、すぐ横手の草の上に坐って大塚の方を見ていた。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下に敷いた白毛布の上には、所狭く鑿も鉋も散かり放題。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幾晩もこの白いシーツの上に白毛布を包んだ白いカバーを引っかけて眠った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはお雪より三倍も年老つた、白毛の盲目馬である。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺は伐仆した木を薪にして、隔日の午前に、白毛の盲目馬の背につけては、麓の町に賣りにゆく。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の上や、耳の尖端に生えている白毛。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　後頭部に心持ち黄色い白毛が半月型に残っているのを綺麗に櫛目を入れていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毛を冠った睾丸がぶらぶらとさがった。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅三爺は、白毛混じりの無精髯にかこまれた厚い唇を、いやに尖らして、その高貴な煙草――自分ではかつて一度も買ったことのない、一年に一度くらいの割合で、珍しい相手から一本を限度として与えられる、貴重な煙草の真の味わいを味わいつくそうと努めた。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偖て、それではこれから……」　笠松博士は、半分ほども銀色の白毛の混っている長い顎鬚を静かに扱きながら、私達学生席の方を、学生の一人一人の顔を睨みつけるような眼をして、錆のある声で朗々と続けて行った。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毛｜茸生僧の払子のごとく美麗言語に絶えたるを巨勢の医家に蔵すと観た者に聞いた人からまた聞きだ。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "年｜歴た物で鼻｜尖に白毛生じ、背には小木生じて花の白く咲けるよりこの名を負いしという。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毛まじりの髪が乱れかかっているところなど、物凄いような気がした。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その國の司の乘つてゐる斑白毛の馬を中心に七八人ごたごたと渦を卷いてゐるその一行の群が、見馴れた山にも、湖水にも、橋にも、または最後まで別れかねて見送つて來た人達にも別れ別れて、遠く遠くさびしい悲しい野山の旅をして行くさまが、何のことはない、屏風の繪か何かのやうにかれ等の眼の前に動いて行くのであつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東泉先生は其肥大の躯を白毛布の上にドシリと下して、心安げに本を見始める。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は少年の頃｜白毛の仔犬を飼つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は暖かなるままに足の上に白毛布一枚を掩ひて着蒲団を用ゐざりしほどに足冷えたれば湯婆を呼びしなり。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毛黒髪の馬のおもちやにさへ赤き台の車はつけてあるべし。",
              "citation": {
                "source": "わが幼時の美感",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄養不良らしい蒼ざめた鈍い土色の顔を白毛まじりの灰色の濃い髯にうずめて、その中からあまり大きくもない眼をぎょろぎょろと光らしていた。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡っていた百姓風の大きい男は白毛糸の首巻の上で目を瞠り、瞬きをせず、膝にとりおろした黄色い風呂敷包の上に両手をおいているのであった。",
              "citation": {
                "source": "東京へ近づく一時間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の臭いとも乳の臭いとも分らない肌のにおいをかぎながら、「頬っぺ」をなさったことが御ありですか、　私は、貴いものを拝すようにもう一遍その白毛の小靴をまるめて、箱に入れた。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉢の側――右腕に肩から白毛糸のショールを巻きつけ、仰向いた胸の上にのせた手帖へ、東洋文字を縦に書いて居る。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼつぼつ白毛のまじった顎鬚をもじゃもじゃとのばした下男階級の男が、手織飛白の上衣にくるまって乗っていたが、これは謂ゆる小者という名前で通っている人物である。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それはこの親爺の白毛髭のせゐでもなければ、その勿体ぶつたあしどりのせゐでもない。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、意外なことを云うものだと不思議そうに黙ったことがあるが、漁村の白毛の老婆の美醜などいままで誰も気にとめたことはなかったのだろう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毛まじりの太い眉の下に、小さい引っこんだ眼が赤くただれていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
