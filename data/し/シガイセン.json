[
  {
    "uuid": "8c717b3f-efc4-504d-ab4f-9fcf66d3a80c",
    "entry": "市街戦",
    "reading": {
      "primary": "しがいせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
