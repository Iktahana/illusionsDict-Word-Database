        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "息子が勉強を渋っていたので、少し尻をたたいて励ました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい企画を始めるにあたり、上司が私たちの尻をたたいてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも、迷っている友人の尻をたたいて背中を押してあげる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一般のめあき階級は女の尻をたたく触感以外かくも美しく複雑な触覚の世界があったのかということを教えられることとなるであろうと思ったのである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "……清五郎、とにかく母家へ知らせて来い」　蒼くなって顫えている清五郎の尻をたたくようにして母家へ追いたててやってから四人で数負を離家へ運び入れようとしていると、母家へつづく柴折戸を引き離すような勢いで押しあけ、バタバタと駈けて来たのは末娘のお節。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
