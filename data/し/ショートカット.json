          "literary": [
            {
              "text": "この子、つきあい悪いのよ、高志さん」　と、もうひとりの髪をショートカットにした子が、わきからこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おごって」　と、またショートカットが返事した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐る恐る建物の裏手をのぞいてみるとショートカットの女が犬を押えつけて何かしようとしているところだった。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
