  {
    "uuid": "ecd0b226-6909-5cdc-be15-09db5d8656b3",
    "entry": "初生",
    "reading": {
      "primary": "しょせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
