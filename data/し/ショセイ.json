    "definitions": [
      {
        "index": 1,
        "gloss": "student",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると『それ貝が鳴った』とばかり、夫人を初め女中や書生たちが大騒ぎをし、先を争って離れの書斎に駈けつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のやうな書生流儀で、どうもこの人と交際ができるかどうか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のおどおどしてまごついてる樣子をみると、彼は直ちに態度をかへ、急に平易なざつくばらんな調子になつて、心おきなく書生流儀で話しかけた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの日の印象ほど、芥川君の眼における少年らしさ、風貌における書生らしさを見たことがない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷像の方へ行きたれども書生の群多くてうるさければ引きかえしパノラマ館裏手の坂を下る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、楠さんの細君が亡くなり、次にひどく酒飲みになった楠さんも若死をしたこと、亀さんが医師の家に書生をしていて、後に東京へ出て来てどこかの医者の代診をしているという噂を聞いたように思うだけである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、私のやうな一物もない貧書生に娘を與へて、さぞ内心、淋しいことであらう。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住所を搜し、こちらからお訪ねして、なほ精しく故人の御遺徳をも伺ひ、それから、私ごとき非文不才の貧書生に、この活字日誌の使用を御許可下さるかどうか、改めてお願して、そのおゆるしを得て、はじめて取りかかるべき筋合ひのものであるとは、不徳の小文士と雖も、まづは心得て居りました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて代わりの人のあるまで辛抱してくれと、よしやまだ一介の書生にしろ、とにかく一家の主人が泣かぬばかりに頼んだので、その日はどうやら思い止まったらしかったが、翌日は国元の親が大病とかいうわけでとうとう帰ってしまう。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の歿したのちは男の手一つで女中や婆あやや書生を使い、私を育てて来た父には生甲斐として考証詮索の楽しみ以外には無いように見えたが、やはり寂しいらしかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私と主人との結婚話が決まると、その日から灰吹掃除を書生に代ってやらせた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑゝ言ふ事を聞かぬ我まゝ者め、何うともお爲と捨てぜりふ言ひて心ともなく庭を見るに、ぬば玉の闇たちおほふて、物の黒白も見え分かぬに、山茶花の咲く垣根をもれて、書生部屋の戸の隙より僅かに光りのほのめくは、おゝまだ千葉は寢ぬさうな。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しるべの燈火かげゆれて、廊下の闇に恐ろしきを馴れし我家の何とも思はず、侍女下婢が夢の最中に奧さま書生の部屋へとおはしぬ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古袴など取り出でて十年昔の書生にいでたたんと支度ととのえなどす。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、ひどく窮乏してゐた書生時代から、彼はさういふやり方で生活して居た。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は勇躍して立ち、過去の全財産を捨て、再び素裸の一文學書生となつて、さらに新しい美と生活を創造すべく始めるだらう。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は田舍の野暮つたい文學書生のやうに、髮の毛を垢じみて長くはやし、ステツキをついて肩を四角に怒らせてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌から言へば、君は猪のやうにゴツゴツしてゐたし、おまけに亂暴書生の如く肩を怒らし、ステツキを突いて高下駄を引きずり歩いた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが僕は君とちがつて、相ひ變らず昔の未熟なままであり、今日尚依然として巷路に彷徨する老書生だ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの「老書生」といふ言葉が、この頃非常に好きになつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいつ迄たつても老書生で、大家になることのできない人間なんだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌ばかりでなく、全體の態度や、言葉づかいや、言行からして、何となく田舍新聞の記者とかゴロツキ書生とかいふ類の者を思はせる所があつた。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の室生君の一場は、昔の粗野な書生的友情が囘想されて、取りわけ私にはなつかしかつた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地間最早小山某といふ畫かきの書生は居なくなる！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と太く書生ぶって、「だから、気が済まないなら、預け給え。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとやがて人の気はいがして、左方の上り段の上に閉じられていた間延びのした大きな障子が、がたがたと開かれて、鼠木綿が斑汚れした着附に、白が鼠になった帯をぐるぐるといわゆる坊主巻に巻いた、五分苅ではない五分｜生えに生えた頭の十八か九の書生のような僮僕のような若僧が出て来た。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以前から先輩の読み物であった坪内氏の「当世書生気質」なども当時の田舎の中学生にはやはり一つの新しい夢を吹き込むものであった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年になって母にたびたび聞かされたところによると、当時の自分はひどく鉄道馬車に乗るのが好きで、時々書生や出入りのだれかれに連れられてはわざわざ乗りに行ったものだそうである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
