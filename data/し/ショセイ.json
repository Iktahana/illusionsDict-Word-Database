    },
    "definitions": [
      {
        "index": 1,
        "gloss": "birth parents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸野氏は隻手の声だの父母未生以前だの因縁所生の身。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして因縁の所生によって簡素な生活を生涯守られるだけの遺産をうけた一処女、身を幸とも不幸とも判断しかねて居るのです。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁所生の果である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我昔所造諸悪業　　皆由無始貪瞋痴従身語意之所生　　一切我今皆懺悔　この口唱が一しきり済んで、娘達のまぼろしの一めぐりしたあとへ、屋敷内のありとあらゆる倉々の俤が彼の眼の前で躍り始めた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神の國」が理想境であると共に、現實世界は初より惡魔の所生であるから、其間には社會方面に對する哲學を容るべき餘地が無い。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上先夫人の所生）◇三女千代　明治四年未九月晦日生る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　併し、私達の詩的感情は、何が故にと、その植物固有の、所生や境遇や季節による生理的必然の作用としての生理的変化を探究しようとするのではない。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はその科学的見地から離れて、それらとりどりの植物が、いつの季節に、いかなる境遇において、最も強く私達の美的感覚に触れるかを、その所生の境遇と外囲の関係とにおいて、その植物固有の美的表示を知ろうとするだけである。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　例えば、菌、苔、藻草のような植物でも、その所生の境遇と外囲の関係とによって初めて私達の詩的感覚を打つのである。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、丘陵、高山、原野、沼沢、砂地、海辺、田圃、河畔、庭園など、その土地に在る植物の美を知るには、その植物それぞれの所生の状態、季節や気象に伴うて現わす変化、又は花と昆虫、或いは果実と鳥との関係というように、一々その自然との関係に就いて観察する必要があると思う。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "在所生まれで、ふだんから小力のある彼女が、半狂乱の力任せに絞めつけたので、孱弱い男はそのままに息がとまってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十一日我昔所造諸悪業――皆由無始貪瞋痴――従身口意之所生――一切我今皆懺悔――カルモチンのおかげで、やつとねむつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……我昔所造諸悪業皆由無始貪瞋痴従身口意之所生一切我今皆懺悔一切我今皆懺悔、そして私は新らしい第一歩を踏み出さなければならない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "我昔所造諸惑業皆由無始貪瞋癡従身口意之所生一切我今皆懺悔　　　合掌　　　ぐうたら手記□昼は働き夜は睡る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "我昔所造諸悪業皆由無始貪瞋痴従身口意之所生一切我今皆懺悔ああ、一切我今皆懺悔、私はお位牌に額づいて涙するばかりである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包みの中には、彼女が療養所生活の中であきずにかき綴った作文の帳面がいく冊かしまわれていた。",
              "citation": {
                "source": "病菌とたたかう人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――我昔所造諸惑業　　皆由無始貪慎痴従身口意之所生　　一切我今皆懺悔衆生無辺誓願度　　煩悩無尽誓願断法門無量誓願学　　仏道無上誓願成一切我今皆懺悔――煩悩無尽誓願断――一月一日　時雨、宿はおなじく豆田の後藤といふ家で。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "我昔所造諸惑業　　皆由無始貪瞋痴従身口意之所生　　一切我今皆懺悔衆生無辺誓願度　　煩悩無尽誓願断法門無量誓願学　　仏道無上誓願成　七月二日　同前。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "我昔所造諸惑業、皆由無始貪瞋痴、従身口意之所生、一切我今皆懺悔、――ほんとうに懺悔せよ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁所生、物は在るところのものに成る。",
              "citation": {
                "source": "『鉢の子』から『其中庵』まで",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊佐の所生には親に先つた信栄、信階の妻曾能の外、猶一子金十郎があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇の所生の幼女れんは当歳である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田安石の棠軒養母の所生なることは、重て註することを須ゐぬであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "養玄は嘗て一たび柏の所生の女梅を娶つて、後にこれを出したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "レミヤ所生の男児をそのように永く無名の子として放置しておく時は社会生活上あらゆる不都合を生ずる事になるので、この一事を以てしてもこの事件は一日も早く解決しなければならぬ事になる。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち当法廷に参列しているレミヤ所生の男児は、まだ東西を弁ぜざる嬰児である。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家所生の言葉「振っている」「高等遊民」「露悪家」「月並み」等の言葉の文壇に行われるようになったのは夏目先生から始まっている。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう言う作家｜所生の言葉は夏目先生以後にもない訣ではない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "久米正雄君所生の「微苦笑」「強気弱気」などはその最たるものであろう。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお又「等、等、等」と書いたりするのも宇野浩二君所生のものである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
