    },
    "definitions": [
      {
        "index": 1,
        "gloss": "firstborn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして私の座ぶとんの上へおろして、その上で人間ならば産婆のすべき初生児の操作法を行なおうとするのである。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草綱目』に、〈猿初生皆黒し、而して雌は老に至って毛色転じて黄と為る、その勢を潰し去れば、すなわち雄を転じて雌と為る、ついに黒者と交わりて孕む〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヨルマット砦建立の際一方の壁が繰返し落ちたので或る初生の兒を生埋すると最早落ちなんだといふ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の兄上の初生児も取られていた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花の蔭の黒いジメジメした土の上に初生児の頭ぐらいの白い丸いものが見えます。",
              "citation": {
                "source": "卵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初生児の意識の如きは明暗の別すら、さだかならざる混沌たる統一であろう。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金策に出でてひねもす歸らざる老父を思ひつつ夜の戸とざす柿の實の初生り賣りて得し金を神にそなへて額づくわが老父わがのぼる脚榻に昨夜の霜おけり高き小枝に柿の實ちぎる柿の實は乏しくなれり柿の落葉あつめて今宵火を焚きにけり　ほか二首であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本常陸国の農家の子で、地方に初生児を窒息させて殺す陋習があったために、まさに害せられんとして僅に免れたのだそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜初生児の行末を謀り、之を坊主にしても名を成さしめんとまでに決心したるその心中の苦しさ、その愛情の深さ、私は毎度この事を思出し、封建の門閥制度を憤ると共に、亡父の心事を察して独り泣くことがあります。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱散養生とあれば花見も宜し湯治も賛成なり、或は集会宴席の附合も自から利益なれども、其外出するや子供を家に残して夫婦の留守中、下女下男の預りにて、初生児は無理に牛乳に養わるゝと言う。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有様を形容すれば、あたかも初生の小児にいまだ智識の発生を見ざるもののごとし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの大都市の産院ではこの間違いを防ぐ為に、初生児の指紋は取り悪いから、蹠紋を取ることにしています。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初生の人類より滴々血液を伝え来れる地球上譜牒の本系なり。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初生の人類より滴々血液を伝え来れる地球上譜※の本系なり。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らんとするは、ほだされず模ねず、雑らず、従はぬ、初生本来の我なるを、消えよ」と云へば、諸声に泣き、憤り、罵りぬ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初生牡蠣を乾いた布巾の上へ載せてよく水を切って深い皿へ玉子の黄味ばかり溶て牡蠣をその中へ入れて掻き廻すのだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三つは何れもアシの事ではあるが、しかし支那の説では初生の芽出しが葭でそれがもっと生長した場合が蘆で、そして充分成長したものが葦であり葦は偉大の意味だと書いてある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和譯P.184　１．初生兒の生聲は、凡そ人間なるものの發する最初の聲である。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちアシの初生のもの、すなわち食うべき蘆筍の場合のものを葭といい、なお十分に秀でず嫩い時を蘆といい、十分に成長したものを葦といい、葦はすなわち偉大を意味するといわれる。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛らしい寝台の上には初生児たちがガーゼに包まれて一つづつ置いてある。",
              "citation": {
                "source": "水に沈むロメオとユリヤ",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "初生児は皮膚で呼吸する動物のやうにまるで音を立てない。",
              "citation": {
                "source": "水に沈むロメオとユリヤ",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "（上略）設有人病者、必迎獅子至病人室中、周視一巡、以祓除不祥、初生小児、将渠含至獅子口中、謂容易長大云々。",
              "citation": {
                "source": "獅子舞雑考",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩尻云、人之初生以七日為臘、人之初死以七日為忌、一臘而一魄成、故七七四十九日而七魄具矣、一忌而一魄散、故七七四十九日而七魄散矣。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初生れたての竜神は皆茶ッぽい色をして居る。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはれアポローンに先づ盟へ、リキエー生れの銀弓の　100神に初生の子羊のすぐれし牲を捧げんと、聖なる都ゼレーアに君の歸郷のあかつきに。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "860かくして二人青銅の兜に※を投げ入れて、振り搖がせばチュウクロス先に當りていやすぐに、弓勢強く切り放つ、されど初生の仔羊のすぐれし牲を捧ぐるを神アポローンに盟せず。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "初生りの柿を青竹で作った小さな籠にいれ、子供に背負わせると息災にそだつという俗習がある、みよは青柿をながめながらそれを空想した。",
              "citation": {
                "source": "日本婦道記",
                "author": "箭竹",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人が生きていたら、そしてあの初生りの柿が一つでも熟れていたら、いまごろは青竹で籠をあんで、安之助の背に負わせて、あやうげな足どりであるくさまを良人と共に笑いながら見ていたであろう。",
              "citation": {
                "source": "日本婦道記",
                "author": "箭竹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことは余計なお世話だよ」「僕は長男だから、初生りだ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
