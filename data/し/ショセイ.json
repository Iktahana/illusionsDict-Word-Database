  {
    "uuid": "cd440744-3898-5beb-a78c-44a41c0748c9",
    "entry": "所生",
    "reading": {
      "primary": "しょせい",
      "alternatives": [
        "しょしょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
