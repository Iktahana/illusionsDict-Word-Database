        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "父も母も誰も知らず、諸国漫遊の途次、一昨年の秋、この富山に来て、旅籠町の青柳という旅店に一泊した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○水戸黄門、諸国漫遊は、余が一生の念願也。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋ねる人がございまして、諸国漫遊に出でましたが、あまりによく似たお姿のため、とんだ粗相をいたしました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一方森田屋を説き、ふたたび海へひっぱり出し、一方諸国漫遊中の、秋山要介へ使いを出し、助太刀を依頼したのであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナニサ、俺らの思うには、ああいう立派な殿様だ、時頼さんの心意気で、諸国漫遊に出られたんだろう」こう云ったのも地廻りらしい男。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
