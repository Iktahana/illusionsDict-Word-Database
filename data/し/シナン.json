[
  {
    "uuid": "b21574e7-3560-5bd8-9b9d-7aaf5a761b57",
    "entry": "指南",
    "reading": {
      "primary": "しなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
