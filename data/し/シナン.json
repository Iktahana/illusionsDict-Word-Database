      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "instruction (in martial arts, performance, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けだし有明氏の夫人が※花の指南を職として居られるからである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　兎も角　当時、宮本武蔵の名は　津々浦々に響き渡っていたＳ＝道場の表　念流剣道指南、森脇左十郎の門外である。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝吉原神道流剣道指南　　　　　白倉源五左衛門の看板Ｓ＝道場の表　格子窓から覗き込んで居る人々。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔術指南と骨つぎの看板をあげた道場から出た若い男は自動車屋へはいつた。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、大野ともいわず、九郎兵衛とも名乗らず、単に遊謙と称する一個の僧となって、小さい草堂を作って朝夕に経を読み、傍らには村の子供たちを集めて読み書きを指南していた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人、芹川進君を紹介します、先生の御指南を得たい由にて云々という大まかな文章である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか紹介状の文句のとおりに、「御指南を受けに来ました。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お歌の事に就いては、また後でいろいろとお知らせしなければならぬ事もございますが、十三、四歳の頃からもうあのお方は、新古今集などお読みになり、さうして御自身も少しづつ和歌をお作りになられて、その十七歳の頃には、もう御指南のお方たち以上の立派なお歌人におなりになつて居られたのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お揃ひで社寺へお詣りなさる事も度々ございましたし、またお花見や、お月見、また船遊びなどには、いつも御台所さまをお誘ひになり、殊にも和歌会や絵合せの折には、御台所さまは、それこそ、なくてかなはぬお方で、将軍家に京風の粋をお教へ申し上げるお優しい御指南役のやうにさへ見受けられました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの子は、どういうものか若殿村丸のお気にいりで、蛸よ蛸よと呼ばれて、いつもお傍ちかく侍って若殿にけしからぬ事を御指南申したりして、若殿と共にげらげら下品に笑い合っているのである。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "停留所のうしろは柔術指南所だった。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔術指南所はもう寝しずまっていた。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Padua の武藝指南所で遊戲に供する力士を奴隷の中から養成してゐたのが一揆の源になつて、智略ある Spartakus を首領に戴いたのである。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "房八郎は去年から伜に番入りをさせて、自分は隠居の身となったが、ふだんから丈夫な質であるので、今でも大勢の若い者を集めて弓術の指南をしている。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田藩一刀流の指南番、浅川一柳斎の門下随一という自信もあった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまるところお手前はまだ若いし、拙者のこれまでの指南にも大きな手抜かりがあった事になる」「いや決して……万事、私の不覚……」「ハハ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、敵手の中の主立たる一人は黒田藩の指南番浅川一柳斎と名乗り、五十前後の長身にて、骨柄逞ましき武士なること。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肝玉を踏み潰し、吠面かゝし呉れむと意気込みて、いよ／＼腕を磨きければ二十一歳の冬に入りて指南役甲賀昧心斎より柳生流の皆伝を受くるに到りぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが老巧の粟生氏の技倆を以ってしてもナカナカ翁の指南通りに出来ないので、何度も何度も遣り直しを喰っている。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢雄は高槻の学校の近くにある将棋指南所へ毎日通つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝京阪電車を降りると学校へ行く足を指南所へ向け、朝寝の松井三段を閉口させた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢雄は進級試験の日にも指南所へ出掛け、落第した。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "元と亞拉伯の産なるが、穉き時より法皇の教の庭に遷されて、こゝに生ひ立ち、今はこの學校の趣味の指南役、テヱエル大學院の審美上主權者となりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみならず、令夫人が音楽を教えて、後室が茶の湯生花の指南をするのであるから。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり在来の辻斬りと同じように持ち槍の穂の冴えをためすのと、自分の腕の働きを試すのと、この二つであろうとは誰でも思い付くことであるので、江戸じゅうの槍術｜指南者やその門人たちが真っ先に眼をつけられたが、その方面では取り留めた手がかりもなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "この槍突きの一件で、お父様にも少々おたずね申しに出たことがございました」　女装の少年は七兵衛に見あらわされた通り、当時下谷に大きい町道場をひらいている剣術指南内田伝十郎の息子であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩下左内という奥州浪人は、四、五年前からここに稽古所を開いて、昼は近所の子供たちに読み書きを教え、夜はまた若い者共をあつめて柔術や剣術を指南していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが不断から武芸を指南するのも、こういう時の用心ではないか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が再度まで尋ねるのは、貴殿を非凡の人だと聞き及んで、物事を相談し、場合によつては指南を受けようと思ふからである。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事も米の飯に味噌汁、野菜の漬物や煮魚を食い、夜は二三合の日本酒を晩酌にたしなんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
