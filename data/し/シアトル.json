        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "菜の花畠、麦の畠、そらまめの花、田境の榛の木を籠める遠霞、村の児の小鮒を逐廻している溝川、竹籬、薮椿の落ちはららいでいる、小禽のちらつく、何ということも無い田舎路ではあるが、ある点を見出しては、いいネエ、と先輩がいう。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "久兵衛は夕陽の光を背に浴びて、※条とした冬枯の田舎路を歩いていた。",
              "citation": {
                "source": "雁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいう通り、僕の町へ行き着くにはこの田舎路を三里あまりもがたくって行かなければならないのだから、暑い時にはまったく難儀だ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう言ったら、臆病とか弱虫だと笑うかも知れないが、人通りの絶えた田舎路をこんな女と道連れになって行くのは決して愉快なものではない。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから満洲の田舎路を日本の里数で約三里も歩かせられては堪まらないと思ったので、堀部君は途中で供のシナ人に相談した。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋を乗つたのが終列車で、加けに汽車の中でひとりでポケツト壜の酒を空けてしまつたほどであつたから、真暗な田舎路に降りるよりは、一層家族のゐる小田原へ赴く筈だつたのに、やはり自分は此処の駅に降りたものだ。",
              "citation": {
                "source": "二日間のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟋蟀のやうに瘠せ衰へてゐる私は、これからさきどうして生きのびてゆけるのかと訝りながら、真暗な長い田舎路をよく一人とぼとぼ歩いた。",
              "citation": {
                "source": "死について",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足の列は街を通り抜け、白い田舎路を歩いて行きました。",
              "citation": {
                "source": "誕生日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は母と一緒に田舎路を歩いてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は狭い田舎路に行き詰つたので、二人は下におりた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、並木のまばらな田舎路をドライヴして馬家溝に横川、沖ほか四烈士の墓を見た。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱い海岸の砂地の反射にぐったりとした妻は、陽の翳ってゆく田舎路を歩いて行く。",
              "citation": {
                "source": "苦しく美しき夏",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐったりとした四肢の疲れのように田舎路は仄暗くなってゆくのだが、ふと眼を藁葺屋根の上にやると、大きな榎の梢が一ところ真昼のように明るい光線を湛えている。",
              "citation": {
                "source": "苦しく美しき夏",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎路のことで一片の吸殻も見つからなかつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "井師と二人で田舎路を歩いて居た時、ふとよく晴れた空を流れてゐる一片の白雲を見上げて「秋になつたねえ」といふたつた一言に直に私が共鳴するのです。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に熊笹の生い茂った吹井戸を控えて、一軒の茶見世が橋の袂をさも田舎路らしく見せていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに空はあくまで晴れ、雲切れ一つなく、彼等の歩いてゐる田舎路は右手にきらめく河を見下して、白くはつきりと浮び上り、ふり注ぐ日ざしと温かさで噎せるほどだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かえでの木を車の上に乗せて、ガラガラと田舎路を引いて町の方へとゆきました。",
              "citation": {
                "source": "葉と幹",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の晩方、彼はさびしく思いながら田舎路を歩いていますと、不思議なことには、このまえじいさんにあったと同じところで、またあちらから箱をしょってとぼとぼと夕日の光を浴びながら歩いてくるじいさんに出あいました。",
              "citation": {
                "source": "どこで笛吹く",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、からすは田の上や、圃の上を飛んで田舎路をきかかりますと、並木に牛がつながれていました。",
              "citation": {
                "source": "馬を殺したからす",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は、黙って、はだしのままおばあさんに連れられて、田舎路の方をさして歩いてゆきました。",
              "citation": {
                "source": "角笛吹く子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、さびしい、あまり人の通らない田舎路を、どこまでもまっすぐに歩いてゆきました。",
              "citation": {
                "source": "角笛吹く子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜夜に凍った田舎路を、一つの提燈に先を照らし、彦七と利右衛門とは歩いて行く。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は七つか八つの子供であったし、おまけに幼い時分から極めて臆病な少年であったから、こんな夜更けにこんな淋しい田舎路を独りで歩くのは随分心細かった。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクタアがこの経験をした直後、田舎路を歩いて行くと、二人の中年配の、相当な身なりをした日本人が、通り過ごす我々に向って、非常に丁寧なお辞儀をした。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "油障子に、ほだ火のあかりがゆらゆら揺れる田舎路沿いの馬肉屋は、空想的な少年の眼には、冒険小説に出てくる大魔窟ほどに怪奇だった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市の大きい美しさは、フッド火山を有するポートランド市の如く、レイニーア火山を高聳させるシアトル市の如く、富士山を西の半空に、君臨させるところに存すると考えられる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く東の海には犬吠が横わり、夢見る様な水平線の彼方を、シアトル行きの外国船らしい白い船の姿が、黒い煙を長々と曳いて動くともなく動いていた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シアトルに着くと、海岸の町は、一帯の霧雨にくもらされて居た。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＣの車にて見物　美くしき小家、　　二十六日　L. A. を立ち、サンフランシスコ着　　二十七日　Thanksgiving Day. 夜立つ　　二十九日　シアトル。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
