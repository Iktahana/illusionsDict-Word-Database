        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう意味で宿命論者だ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの詩に見る宿命論的な暗鬱性は、全く思索生活の情緒に映じた殘像である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ほとんど宿命論的な恐怖に俺は追込まれている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあるかも知れえせんね」「そんなことがあるかも知れない」　外記は綾衣のような宿命論をもってはいなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験小説家を宿命論者であると批難するものもある。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら、ゾラによれば実験小説家は決定論者ではあるが、宿命論者ではない。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿命論と決定論とは全く別のものである。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその友達は彼のことを今度のことから、実に旧式な迷信的な宿命論者だと云って嗤ふのであった。",
              "citation": {
                "source": "縁起に就いて",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると外気の温度が幾分か下降し、蒸されるような家の中に居たたまらぬという理由もその一つであったが、主なる理由は近代人の絶望的な、宿命論的な心の発現であった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンブロゾーは、そこまで社会の現象を探求したのであったがそこからは元へ戻って、だから犯罪型の人間は目下地道に暮していようと先天的な犯罪可能者であるという宿命論めいた断言を強めているのである。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "性的な欲望を満たすことは喉の干いた時一杯の水をのむにひとしいという言葉の最も素朴な理解が、恋愛、結婚に対する過去の神秘主義的封建的宿命論の反撥として、勇敢に実行にうつされた。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、人間も自然の中に生れたものであるという関係からだけ自然の力と人間の交渉を見て、人間も窮極には自然に敗けるのが宇宙の必然であるという風な、科学的らしく見えるが実際は観念的な宿命論のような結論を引き出していることも少くない。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「歴史過程の合則性」を新カント派の連中は宿命論　運命論にまで歪めている。",
              "citation": {
                "source": "「若い息子」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの心霊性を無知といい、シナの謹直を愚鈍といい、日本の愛国心をば宿命論の結果といってあざけられていた。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ貴方、それを露西亜的宿命論というそうではございませんか。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或国堅苦しく、うはべの律義のみを喜ぶ国、しかも、かるはずみなる移り気の国、支那人ほどの根気なくて、浅く利己主義なる国、亜米利加の富なくて、亜米利加化する国、疑惑と戦慄とを感ぜざる国、男みな背を屈めて宿命論者となりゆく国、めでたく、うら安く、万万歳の国。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、君が徹底した宿命論者なら、宿命に反逆するという宿命も存在しうることを否定しまい。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪の垢ほど先を制せられても、取り返しをつけようと意思を働かせない人は、教育の力では翻えす事の出来ぬ宿命論者である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も申上げました通り、私は宿命論者でありまして、この仕事は私ひとり、相棒がおりません。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は宿命論者ですから、一度きまった宿命を変える意志を所持しておりません。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千万か、ガマか」「なるほど、宿命論をお見それして、すみませんでしたね。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルードンは自由主義派の経済学者に宿命論者という形容詞を冠せたが、これはセイのためであった。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、宿命論者となって、大自然の無情を儚むと同時に、一方では、被圧迫者の立場から、現在の都会中心制度、都会商工業制度から来る搾取階級の無法を恨み呪うようになってしまった。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前は、出版業者は自分の職をわきまえていないと言い、医者は医者の心得を呑み込んでいないと言い、人は値打ちだけのものしか得られないと言い、自分は宿命論者だと言い、今は好い時機だと言い、シナ人はもうこっちの茶を飲んだと言い、英国人は旅行中座席を独りで占領すると言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨を折って失敗するのは愚だと悟ったから、近頃では宿命論者の立脚地から人と交際をしている。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味では吾々は道徳的に決定論・宿命論のものだ、意志の自由は本当ではない。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした機械的な決定論或いは宿命論のための用語となる。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――因果性を機械論的に理解すれば、それは決定論乃至宿命論となる。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
