    "definitions": [
      {
        "index": 1,
        "gloss": "Hundred Schools of Thought (during China's Spring and Autumn period and Warring States period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古注に「異端とは諸子百家の書を謂うなり」『疏』と説くのは、指摘が親切過ぎて、却って大切な要点を失う。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "活気の少い朱子学が盛に行われて、諸子百家の書や活気ある宗教が禁ぜられたのは、専ら沖縄人の生存上の必要からであった。",
              "citation": {
                "source": "進化論より見たる沖縄の廃藩置県",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は実に仏蘭西学の大家たるのみでなく、亦漢学の大家として諸子百家窺わざるはなかった。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ハ）上記以外の書籍、殊に『詩經』『書經』及び諸子百家の書は、一切民間に所藏することを禁じ、必ず禁令發布後三十日以内に官省に差出さしめて、之を燒棄した。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に科学というものを知らなかった上古の人間も学としての形態の充分ととのっていない支那や日本の諸子百家の教えも、また文字なき田夫野人の世渡りの法にも倫理的関心と探究と実践とはある。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは即ち聖人のいふ思うて學ばざるものであつて、それが即ち諸子百家の雜説の因つて來る所である。",
              "citation": {
                "source": "章學誠の史學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "論衡の説には、經書は久しく缺けて、その佚文が諸子百家に出て居る。",
              "citation": {
                "source": "支那古典學の研究法に就きて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは官が職を失つて、各分れた諸子百家は諸子百家といふ風に分れるところから目録の必要が出て來る。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "明和尊王事件というのは「柳子新論」「院政記略」「省私録」等の名著を著わし、諸子百家の学に通じ、わけても兵学に堪能であった甲州の処士の山県大弐と、その友の藤井右門とによって、企てられた事件であって、小幡の城主織田｜信邦の家老の、吉田｜玄蕃をはじめとして、数百人の門弟があずかった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼のあとには、彼の学派のみならず、諸子百家が撩乱として現われてくる。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚書ではなし、礼記ではなし、四書五経のうちには、大衆という文字はねえ……してみると、諸子百家、老荘、楊墨、孟子、その辺にも大衆という文字は覚えがねえが……でも、どこかで見たようだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ大学者だから、諸子百家の学問から、医学に至るまで、学問という学問に通じておいでなすったが、ことに兵法軍学の方の大家でなあ、人の気づかない意見を述べたものだから、江戸の方のお役人から睨まれてい申した。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「上は天文から下は地理にいたるまで、三教九流、諸子百家、古今の興廃、聖賢の書およそ眼を曝さないものはない」と秦※はあえて大言を放った後で、「――呉の国ではいったい、何歳になったら学士として世間に通るのですか。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
