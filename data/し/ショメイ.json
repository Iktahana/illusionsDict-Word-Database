    "definitions": [
      {
        "index": 1,
        "gloss": "signature",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いずれ、へんな名士の書であろうと思い、私は軽蔑して、ふと署名のところを見ると、双葉山である。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日附の所に D. Berolini d. 19. mens. とあって下に総長の署名がある。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一枚哲学部長の署名のあるこれもラテン語の入学免状を貰った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ四十歳にもならぬのだが、しかし、よほど前から自分の事を翁と署名し、また自分の家の者にも「お爺さん」と呼べと命令してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は署名帳を出して、私に物書けというから、三、四行したためた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治39年１月『馬醉木』署名　　　　左千夫",
              "citation": {
                "source": "八幡の森",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治33年10月『日本』署名　　　左千夫",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正２年３月『アララギ』署名　　　　左千夫",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもない　矢張男等が云う通りにちがいないようであった明治34年２月『ほとゝぎす』署名　　本所　さちを",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治33年10月『ほとゝぎす』署名　　本所　幸男",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "承知しながらもとうとう長居になって夕飯をもてなされ七時頃にいとまもうした附記是は赤木格堂が為に先生の病情を見のまま記して送れるなり明治参拾四年二月十五日明治34年３月『俳星』署名　伊藤左千夫",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今思つてゐる事が役所で取り扱つてゐる書類であつたら、これからその書類の下の端へ、よぢれた草の茎を組み合せたやうな字で「スタニスラウス・フオン・ヰツク」と署名しようとしてゐるとたんのやうに、ナイフは握られてゐるのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と署名のある、リルケの死を悼む文が載せられてゐる。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれ、へんな名士の書であらうと思ひ、私は輕蔑して、ふと署名のところを見ると、双葉山である。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千七百八十年に独逸で出版されたヤツの第一版なんで、おまけにその見返しの処にぬたくっている持主署名をよく見ますと、どうしてもシルレルとしか読めません。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここへ署名したまえ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしと云つてすぐ署名捺印した。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その窓際の机に向って署名となると、是非ここが気に成るように斜違に立てました。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其当時、飛騨国の地頭職は藤原姓を冒す飛騨判官朝高という武将で、彼も蒙古退治の注進状に署名したる一人であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺書には宛名も署名もしてなかったが、まがいもない老先生の手蹟でこう書いてあった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎朝、新聞紙上で諸兄の署名なき文章ならびに写真を見て、かなしい気がする。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品を、作家から離れた署名なしの一個の生き物として独立させては呉れない。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐちかくのトンネルの入口にも「天下第一」という大文字が彫り込まれていて、安達謙蔵、と署名されてある。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづ、その縣のおもな新聞社へ署名して一部づつ贈呈した。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、その県のおもな新聞社へ署名して一部ずつ贈呈した。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今存している同書は朝散大夫著作郎慶保胤撰と署名してある、それに拠れば保胤が未だ官を辞せぬ時の撰にかかると考えられるからである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの新聞で披露する、諸種の義捐金や、建札の表に掲示する寄附金の署名が写実である時に、これは理想であるといっても可かろう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても孤島に流されているアグリパイナと、ネロの身の上を恐ろしきものに思い、可哀そうでならぬから、と誰にとも無き言いわけを、頬あからめて呟きつつ、その二人への赦免の書状に署名を為した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連署者には大英百科全書に執筆せる諸學者も總て之に加はり、日本で熟知せらるるスペンサー、ユーゴーなども特に數行を書添へて署名しました。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
