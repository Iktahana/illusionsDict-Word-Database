[
  {
    "uuid": "79fbfc22-7c96-5ac6-b168-0fa79b30857f",
    "entry": "新品",
    "reading": {
      "primary": "しんぴん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
