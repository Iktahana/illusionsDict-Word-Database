    "definitions": [
      {
        "index": 1,
        "gloss": "heat of summer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "疳高い甘え声が、真昼の暑熱が漸く鈍い渾然さをみせた夕刻の空気の中を、矢のやうに走つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し健康は害してゐたが、日によつてはその暑熱が私を街へ誘惑することもあつた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "大橋より川上は小蒸気船の往来なくして、たゞ川船、伝馬、荷足、小舟の類の帆を張り艫櫂を使ひて上下するのみなれば、閑静の趣を愛して夏の日の暑熱を川風に忘れんとするの人等は、大橋以西、製紙所の上、川の南西側に榛の樹立の連なれるあたりの樹蔭に船を纜ひて遊ぶが多し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月にはいると、盆地特有の猛烈の暑熱が、じりじりやって来て、北国育ちの私は、その仮借なき、地の底から湧きかえるような熱気には、仰天した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱のために気が遠くなるなどは、私にとって生れてはじめての経験であった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は暑熱をいい申しわけにして、仕事を怠けていて、退屈していた時であったから、早速行ってみることにした。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月、暑熱は極点に達した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九夏三伏の暑熱にも怯げず土佐炭｜紅は魚屋の御用聞きなどを呼入れて、世話女房の酌で一杯やるといつた無事な日常、世人も羨む位であつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱や、寒冷や、雨雪や、飮酒や、日光直射や、異常の食物や、甚だしき飢や飽や、浴後の薄衣や、皮膚の不潔や、すべて病因たることは、盡く自己の判斷と、他の批判と、即ち一個的及び相互的の注意によつて、之を避けねばならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河の夏はかうして凡ての心を重く暗く腐らしたあと、池の辺には鬼百合の赤い閃めきを先だてゝ、※くが如き暑熱を注ぎかける。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤンキーでもアイヌでも歌わせれば歌えそうにも立ちつ坐りつしていたが、それもただ千年も万年も続けば続きそうな日の丸の独り口説にいよいよ気を腐らしたものか、または八月の暑熱に倦じて軽い眩暈でも起したものか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、極彩色の孔雀がきらきらと尾羽を円くひろげた夏の暑熱と光線とは、この旅にある父と子とを少からず喜ばせた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは城を降りると、再び暑熱と外光の中の点景人物となった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白い細かな泡と泡とが、緑に、青に、紅に、薄黄に、紫に、初めは紫陽花、終まひには、小さな宝玉に分解して数限りもなく夏の暑熱と日光とに光る、呟やく、泣く、笑ふ、嘲る……恍惚と見入つて居ると、コツコツと隣の厚い壁板を向ふで敲く。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め、幸村は暑熱に兵の弱るのを恐れて、冑も附けさせず、鎗も持たせなかった。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の西端にはモールトリー要塞（４）があり、また夏のあいだチャールストンの塵埃と暑熱とをのがれて来る人々の住むみすぼらしい木造の家が何軒かあって、その近くには、いかにもあのもしゃもしゃした棕櫚（５）の林があるにはあった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱・寒冷・雨雪・飲酒・日光の直射・異常な食物・甚だしい飢え・飽食や浴後の薄着・皮膚の不潔等がすべて病因となることは、尽く自分の判断と他の批判と、即ち一個的および相互的の注意によって之を避けなければならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれに加えて時々、オゾンを発生する波の激しい海岸とか、または気温の激変のない海辺近くとか、または大気の湿気や暑熱の無い高燥の地、ないしは砂地土壌の土地とかであるならば、いよいよその人に物質的利益を供給する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうち、寒暑とあるは寒冷の地、暑熱の地を指すので、これら皆地方の特徴と人の身心との関係に就いての観察を語ったのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雲ひとつ無い炎天から降り濺がれた暑熱は、湯気程にも濃い陽炎となつて芝生からも庭木の間からも向方のトタン張りの屋根の上からもユラ／＼と炎えたつてゐる。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河の夏はかうして凡ての心を重く暗く腐らしたあと、池の邊に鬼百合の赤い閃めきを先だてゝ、※くが如き暑熱を注ぎかける。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、極彩色の孔雀が燦々と尾羽を円くひろげた夏の暑熱と光線とは、この旅にある父と子とを少からず喜ばせた。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは城を降りると、再び暑熱と外光の中の点景人物となつた。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらでだに元気の無い、色沢の悪い顔を、土埃と汗に汚なくして、小い竹行李｜二箇を前後に肩に掛け、紺絣の単衣の裾を高々と端折り、重い物でも曳擦る様な足調で、松太郎が初めて南の方からこの村に入つたのは、雲一つ無い暑熱盛りの、恰度八月の十日、赤い赤い日が徐々西の山に辷りかけた頃であつた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱盛りをうつら／＼と臥てゐたお柳は今し方起き出して、東向の縁側で静子に髪を結はしてる様子。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丘にただ一本、夏の暑熱を避ける日影を作るために伐り殘した柳の大木は薄緑に芽ぐみ、陽にけぶつてゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　午後になって、暑熱が加わって来ると、子供は一層弱って来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のなかは、どこも彼処も長い日の暑熱に倦み疲れたような懈さに浸っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉の黄ばみかかった桜や銀杏の梢ごしに見える、蒼い空を秋らしい雲の影が動いて、目の下には薄闇い町々の建物が、長い一夏の暑熱に倦み疲れたように横わっていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
