[
  {
    "uuid": "a8668cd1-3731-5a2b-ad5e-b271497755c7",
    "entry": "社外",
    "reading": {
      "primary": "しゃがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
