    },
    "definitions": [
      {
        "index": 1,
        "gloss": "letter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は伯に手渡さなければならぬ信書を携へて來た。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉と徳川氏との長湫一戦後の和が成立して、戦は勝ったが矢張り徳川氏は秀吉に致された形になって、秀吉の勢威隆々となったからであろうか、後藤基信をして政宗は秀吉に信書を通ぜしめている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア信書の往復や使者の馬の蹄の音の取り遣りでは無くなった、今正に上方勢の旗印を読むべき時が来たのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白の威勢や、三好秀次や浅野長政や前田利家や徳川家康や、其他の有象無象等の信書や言語が何を云って来たからと云って、禽の羽音、虻の羽音だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野は国もとやら、友人やらへ、当分ここにいるおもむきの信書を書いた。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の信書を見やうなんとそんなことを僕がする筈がない、屹度中傷でせう。",
              "citation": {
                "source": "媒介者",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六十五　茶山は書を槐庵に与へた後、又一箇月の間忍んで蘭軒の信書を俟つてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信書の祕密ていふやないか。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実は一面から見ると彼等が米本国に家庭を持たない証拠である……彼等が一人残らず、一種の無頼漢、もしくは国際ゴロの集団である事を証拠立て得る可能性のある事実と認められるのであるが、もし又、そうでないとすれば、彼等は何等かの理由で表面上、本国との信書の往復を禁ぜられているものと見なければならぬ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその信書の表記や内容に依って、何等かの秘密が漏洩しそうな虞れを抱いている一種の秘密団体とも見られる訳で、いずれにしても尋常一様の曲馬団とは思えない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩倉公と往復の信書なほ幾多現存する。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して其の苟も鉱毒事件に関する者は信書と印刷物と其の新と旧とを問はず尽く之を押収し去れり。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに西に帰り、信書しばしば至る。",
              "citation": {
                "source": "将来の日本",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだしきは簡単なる手紙をもって、自分の姓名と生年月日とを認め、これに現在の職業を書き加えて、他に発展の途を講じたいが、何をなしたらよかろうかと、あたかも卜者に尋ねるがごとき信書がくる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその端書を他の信書といっしょに重ねて、乱箱の中に入れた。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と千代子との間柄はその後何らの発展も見ないが、信書の往復はいまだに絶えない、そうしてその信書はきっと父母が眼を通した上で本人の手に落つるという条件つきの往復であるという事まで確めた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと前後して、老蝮の松永弾正が、信書をよせて、信長が兵を率いて上洛するなら、自分も一肌ぬいで助力する、あなたこそ次代を担い、天下に号令すべき大将だと、うまいことを言ってきた。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行が政宗のいい加減な信書を国王や教皇に奉呈しても相手にされなくなったのは仕方がなかったのだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時女中が一封の信書を彼の書斎に届けた。",
              "citation": {
                "source": "恩人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして彼は、机の抽斗から一通の信書を取出した。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "信書の不法開封者は死刑に処せられた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の青年は信書の自由すら與へられないのであらうか。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東中尉はセルロイド製の信書管を足にはめた二羽の伝書鳩を手に持って、雪渓の中央まで進み出た。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後各所から放った六羽の鳩も、一羽残らず帰ったそうであるが、今回の分と最後に駒ヶ岳の頂上から放った二羽との外は、如何した訳か信書管を紛失していたそうである。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マードック先生とは二十年前に分れたぎり顔を合せた事もなければ信書の往復をした事もない。",
              "citation": {
                "source": "博士問題とマードック先生と余",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "推理の算数的的確さと、それを潤飾する博識、これがコナン・ドイルのしんしょうであります。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくじぶんをさばくことができたなら、それは、しょうしんしょうめい、けんじゃのあかしだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まったくあれがしんしょうである――。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも村で二番目のしんしょ持ちだというのだ。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつあいい、こいつあ乙なもんだ、元祖ゆうれい貸屋、きっとひとしんしょう出来るぜ」　弥六はこう云って悦喜した。",
              "citation": {
                "source": "ゆうれい貸屋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
