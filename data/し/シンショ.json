[
  {
    "uuid": "4cdd0b8b-efc0-5aaa-ab35-9fd4b9c35e49",
    "entry": "信書",
    "reading": {
      "primary": "しんしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
