        "examples": {
          "standard": [
            {
              "text": "材料力学では、物体にかかる**主応力**を計算することが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この構造設計では、最大**主応力**が許容値を超えないように考慮されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "有限要素法解析により、複雑な形状における**主応力**分布が可視化された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "また鉄筋コンクリートで船を造る場合に主応力の方向に鉄筋を入れるという最も合理的な施工法に関する特許を得ている。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
