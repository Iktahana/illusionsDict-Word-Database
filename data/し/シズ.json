[
  {
    "uuid": "49e287ac-f214-52ae-989b-2b4fd57c2d40",
    "entry": "賤",
    "reading": {
      "primary": "しず",
      "alternatives": [
        "せん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
