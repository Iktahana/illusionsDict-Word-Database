[
  {
    "uuid": "18f01afc-3b51-545e-9fae-c065e85e7c39",
    "entry": "手術",
    "reading": {
      "primary": "しゅじゅつ",
      "alternatives": [
        "しゅずつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
