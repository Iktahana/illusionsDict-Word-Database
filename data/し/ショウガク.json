[
  {
    "uuid": "b9b4716c-0b9c-5246-add6-1cfe982526d4",
    "entry": "小学",
    "reading": {
      "primary": "しょうがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elementary school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "思へば小学校の頃からだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村といふのはその叔母の末つ娘の亭主で小学教員、その末つ娘なる郁子といふのは産院にゐるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けばその後また横浜の小学校に転任したさうであるが、ナニ、ブラ公なぞが訪ねた所で誰が喜ぶものでもあるまい。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "就職試験を受けにいって、小学校の算術の問題を提出されて、大いに狼狽している姿と似ている。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、映画見物の小学生が十人ほど焼死しました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だったと思います。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、映画見物の小学生が十人ほど焼死しました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山奥の村に、新しく小学校が設けられる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校では、毎年創立記念日に学童の作品展覧会が催される。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今年七ツになる、先達小学校に入学したばかりだつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅に墨だらけになつた小さな机が置いてある他には、小学の教科書とボロボロの学校鞄とが机の下に抛り込まれてゐるだけだつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も祖母も、耕二の話の時には兄が級長をしてゐた小学時代を引き出した。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小学の頃よく父から出て行けと言はれた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度も小学から私の不可ないことを知らせた手紙が来た時なぞ、父はそれを仏壇にのせて泣いた後、取りあへず手近にあつた六百円を出して、私にアメリカに蜜柑揉ぎにでも行けと言つたことがあつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父と今年小学に這入つたばかりの弟の声だ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学の放課の鐘の、あの黄ばんだ時刻を憶ひ出すとして、タダ物だと思ひきれるか？",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕の風変りな性格が、小学生時代から仲間の子供とちがって居たので、学校では一人だけ除け物にされ、いつも周囲から冷たい敵意で憎まれて居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校から中学校へかけ、学生時代の僕の過去は、今から考えてみて、僕の生涯の中での最も呪わしく陰鬱な時代であり、まさしく悪夢の追憶だった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校の理科の時間にＴＫ先生という先生が坩堝の底に入れた塩酸カリの粉に赤燐をちょっぴり振りかけたのを鞭の先でちょっとつつくとぱっと発火するという実験をやって見せてくれたことを思い出す。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学時代にかかりつけの家庭医は岡村先生という当時でももう相当な老人であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めての時はまだ小学時代の事で、大方の事は忘れて仕舞った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐山岳会長若尾金造氏が待ち受けて、一とまず常磐町の同氏邸宅前まで、自動車で伴い行かれ、ここで弁当などを積み込み、大沢照貞氏と、田富小学校長｜輿石正久氏が加わり、自動車で八ヶ岳の高原へと走らす。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、家を出る時に、小学校に今年上つた女の児が、「お母あさん。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜だつたので、小学校四年の男の子も、私もそれを聞いてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも子供だけにはこんないたずらをさせないように家庭や小学校で教えるといいと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋根には静岡何某小学校と大きく書いてある。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い婦人で小学校の先生らしいのが両腕でものを抱えるような恰好をして拍子をとっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
