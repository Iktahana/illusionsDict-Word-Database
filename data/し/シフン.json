[
  {
    "uuid": "a7500ef4-77b2-5eb8-909b-6f89a77ea7df",
    "entry": "脂粉",
    "reading": {
      "primary": "しふん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rouge and powder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのたびにはら／＼して女優の美貌から脂粉がはげおちた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂粉の気の少い処だから、此の青い燈籠を携ふるのは、腰元でない、女でない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺があれの脂粉の香をいつくしみ初めて、一切の淫蕩を捨て去つてから二十年になる。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "多摩川に沿って近頃三業組合まで発達した東京近郊のＦ――町は見物人の中に脂粉の女も混って、一時祭りのような観を呈した。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝に書いてある女、新しい詞で形容すれば、死の天使を閾の外に待たせて置いて、徐かに脂粉の粧を擬すとでも云うような、美しさを性命にしているあの女が、どんなにか岡田の同情を動かしたであろう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑酒と脂粉の席の間からも、其の道が、常に耿々と、ヤコブの砂漠で夢見た光の梯子の様に高く星空迄届いているのを、彼は見た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたるかな、衰へたるかな、只だ是れ屍の脂粉を傅けて行くものゝみ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "南渡の後呉俗もっとも盛んで、皆脂粉を傅け盛んに粧飾し、針縫を善くし、呼んでいう皆婦人のごとし。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で沼南夫人は百舌や鴉の中のインコのように美しく飾り立てて脂粉と色彩の空気を漂わしていた。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、行きついたその吉原は、灯影に艶めかしい口説の花が咲いて、人の足、脂粉の香り、見るからに浮き浮きと気も浮き立つような華やかさでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱脂粉乳とコッペパンを脱出したむこうに、詰襟が待ちかまえていることを思い、慶一は自殺しようかと考えたが、日本に人間として転生する恐怖におびえ、思いとどまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、なまめかしい脂粉の香いが玄石の鼻をうった。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻の匂いが脂粉の匂いと混って来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の人々と彼等の財布を狙ふ街の人々と、温泉の匂ひ、脂粉の香り。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年に『女人芸術』に「放浪記」を発表して文学的登場をした林芙美子と、一九二〇年に短篇「脂粉の顔」をもって登場した藤村（宇野）千代の文学的足どりには独特なものがある。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「脂粉の顔」という短篇小説が時事新報の懸賞に当選して、藤村千代（宇野）という作家の名が人々に記憶されはじめたのは、大正十年のことであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の愛らしいもろさ、人のよいようなはかなさ、嫋々たるところを近代の脂粉のなかに我から認めて、女としてそこへ我が身をもたせかけ行くポーズにあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが女道士になっているから、脂粉の顔色を※すを嫌っていたかと云うと、そうではない。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人々は脂粉の気が立ち籠めている桟敷の間にはさまって、秋水の出演を待つのだそうである。",
              "citation": {
                "source": "余興",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば此のおぼろに乗じて狐も跳梁しよう……草のいきれと花の吐息とは、靄に溶けた月光の中にしのぶ狐の脂粉を思はせた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ツインガレラの顔は脂粉に荒らされてゐる。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂粉に彩どられた傾国の美こそなかったかも知れないが、美の価値を、自分の目の好悪によって定める、男の鑑賞眼は、時によって狂いがないとはいえない。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中でボートが擦れ違う度びに、脂粉の匂いがしばらく尾を曳いて水面を流れて来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿った樹の幹の間に前から漂っていた脂粉の匂いが歩く身体に纏りついて追って来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚脂粉の香ある新しき西洋手拭一本、屍体の前に置かれたる机の下に落在せるが、右は加害者の所持品にして、右兇行に使用したるものと認めらる。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "教坊の楽と脂粉の香のまじる夏の夕に会へるものかな　昭和八年八月高野山の夏期大学の講義を終へた夫妻は大阪へ出て然る人の饗宴に列した、南地宗右衛門町の富田屋らしい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の考へでは、脂粉のいらぬ年齡になつても、正しく恥ない日日を送るために入用だと思つてゐる。",
              "citation": {
                "source": "鏡二題",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の、キラキラかがやくまっ白な胸、脂粉、歌声、ルーレットの金掻き棒の音。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方から目明しふんぞり七兵衛がふんぞり返って急ぎ足に来る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大袈裟な言葉をのべつ幕無しふんだんに飛び出させる京伝の口を、寧ろ皮肉な眼付きをして、じろじろ見遣るばかりであった。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
