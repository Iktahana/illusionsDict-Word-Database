    "definitions": [
      {
        "index": 1,
        "gloss": "intense antipathy (like a blazing fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
