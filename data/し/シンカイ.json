[
  {
    "uuid": "7c05b5b0-709e-5d93-aca7-afc5e84d4886",
    "entry": "深海",
    "reading": {
      "primary": "しんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
