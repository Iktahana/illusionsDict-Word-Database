        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吾々人間の浅墓な智慧などでは到底いつまでたっても究め尽せないほど不思議な真言秘密の小宇宙なのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "摩訶不思議なる此の真言の秘密はただ詩人のみが知る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春黒雲峡を乱れ飛び　　技師ら亜炭の火に寄りぬげにもひとびと祟むるは　　青き Gossan 銅の脈わが索むるはまことのことば雨の中なる真言なり　　来々軒浙江の林光文は、　　　　　　かゞやかにまなこ瞠き、そが弟子の足をゆびさし、　　凛としてみじろぎもせず。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真言宗の坊主の印を結ぶのを極めて疾くするようなので、晩成先生は呆気に取られて眼ばかりパチクリさせていた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍術というのは明治になっては魔法妖術という意味に用いられたが、これは戦乱の世に敵状を知るべく潜入密偵するの術で、少しは印を結び咒を持する真言宗様の事をも用いたにもせよ、兵家の事であるのがその本来である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日経巻第二に荼枳尼は見えており、儀軌真言なども伝来の古いものである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "荼枳尼天の形相、真言等をここに記するも益無きことであるし、かつまた自分が飯綱二十法を心得ているわけでもないから、飯綱修法に関することは書かぬが、やはり他の天部夜叉部等の修法の如くに、相伝を得て、次第により如法に修するものであろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では平安朝の伝教大師の日本天台、弘法大師の真言密教をはじめ、鎌倉期になって法然、親鸞、日蓮、道元らの諸祖の新興仏教の出たのもこのためであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の平安朝時代から伝統が続いて来ている伝教大師の天台宗、弘法大師の真言密教は、さとりの修業と信仰の安心立命と兼用であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に平安朝に興った二大新仏教は、伝教大師の日本天台、弘法大師の真言密教であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺は久圓寺といつて、真言宗である。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで拙僧は望み通りに、真言秘密の御祈祷をしてやって、出て来た孩児はこれこれの処に埋めなさい……とまで指図をしておいたが……それがソレ……その骨じゃ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真言宗の坊主の印を結ぶのを極めて疾くするやうなので、晩成先生は呆気に取られて眼ばかりパチクリさせて居た。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかれ男　（故更に厳粛の貌を装ひ）や、それこそは邪法の内秘、吉利支丹宗門の真言、軽々しうは教へられぬ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八宗の中にも真言宗には、秘密の法だの、九字を切るだのと申しまして、不思議なことをするのでありますが、もっともこの宗門の出家方は、始めから寒垢離、断食など種々な方法で法を修するのでございまして、向うに目指す品物を置いて、これに向って呪文を唱え、印を結んで、錬磨の功を積むのだそうでありまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある真言｜寺の小僧が、夜分墓原を通りますと、樹と樹との間に白いものがかかって、ふらふらと動いていた。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実、珈琲から珈琲の煙が立つやうに内心の深みから素直に心の吐息を掻き立たせてその融合渾沌のさかひに怪しい芸術の矜持と魔力とを物静かに薫らし得る純一な詩人の歓会はまた何にもかへがたい真言秘密の妙諦である。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "志玄は、「あなたが真箇にしないなら、正体を現わしてお目にかけましょう」　と言って、印を結んで真言を唱え、錫杖を振りあげて、「早くもとの形にならないか」　と言うと、狐の女は悶絶して倒れ、元の狐となって血を吐いて死んだ。",
              "citation": {
                "source": "老狐の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る程に此寺の住持なりし彼の和尚は、もと高野山より出でたる真言の祈祷師にて御朱印船に乗りて呂宋に渡り、彼地にて切支丹の秘法を学び、日本に帰りて此の廃寺を起し、自ら住持となりし万豪｜阿闍梨と申す者に侍り。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ人間の浅はかな知恵などでは到底いつまでたってもきわめ尽くせないほど不思議な真言秘密の小宇宙なのである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んだか山師のようでもあるが、また真箇に真言の行者のようでもある。",
              "citation": {
                "source": "仙術修業",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真言宗の秘密儀と同じく、何の説教講釈を用いず、理論実験を要せず、ひとえに神社神林その物の存立ばかりが、すでに世道人心の化育に大益あるなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音のとなりにも鳳閣寺という真言宗の寺があって、芝居の鳴り物はその寺の境内からきこえて来るのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仏様がお禁じになりました真言秘密の法も陛下には御伝授申し上げました。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "『部多大教王経』には、真言で部多女を招き妹となし、千｜由旬内に所要の女人を即刻取り来らしむる法あり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、苦手の人蟹を掴み、少時経つとその甲と手足と分れてしまうという、『仏説穣麌梨童女経』は、蛇を死活せしむる真言を説いた物だ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シワその志を感じ風神ナラダして真言を彼女の耳に吹き込ませたに、ナラダこれをその子宮に吹き込む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫よりつねにあまのよむきよふ一部、それでしんごんの所へいけバしんごんのきよふ、いつかふしうゑいけバいつかふしうのきよふをよみこれハとまるやどの事ニて候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
