    "definitions": [
      {
        "index": 1,
        "gloss": "to bind up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうした讀書から自然に覺えた探偵ごつこ、自分の友達の多少｜魯鈍なのを兇賊に仕立てたりして、それをわら繩で縛り上げる敏腕な探偵は、私の少年時代のある時の姿だつたから……。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "管八　言うことを肯かんと縛り上げるぞ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとかして倉地を縛り上げるまでは葉子は甘んじて今の苦痛に堪え忍ぼうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時代は、縛り上げる力さえあれば理由は要らなかったのである。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、もう縛り上げる罪人の種が尽きたとみえ、いちばん最後に手ぶらでミルク屋を出ようとした土工体の男は、入口に立ち塞がっているこの青年が邪魔になったとみえ、「退け！",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に狸が死んだふりをして落ちてくるから、そうしたら、縄で縛り上げるがよい」　しばらくして老人は、南天の杖をふり上げて、非常に大きな声で叫びました。",
              "citation": {
                "source": "狸のお祭り",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "じたばたすると縛り上げるぞ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると舞台裏から、二人の黒衣の人物が現はれて、白い太い縄で、彼女のからだを脚から腰、腹から胸もとへと、両腕もろとも、がんじがらめに縛り上げる。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵二三人、木華里の肩から腹へかけてぎりぎりに縛り上げる。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸の態度は明かに金次郎を庇つてゐるに違ひありませんが、かう巧にいひのがれられると、まさか若い娘を縛り上げるわけには行きません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お此お糸",
                "note": "青空文庫"
              }
            },
            {
              "text": "透き通るようなとろりとした肉づき、大きいうるんだ眼、そしてグミのように熟れた唇と美しい歯並みが、物いう毎に妖しい魅力を撒き散らして、土蜘蛛の巣を掛けたように、男の全生命を縛り上げるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ出した者があつたら、誰でも構はない、一人殘らず、縛り上げるのだ」「何を搜しや宜いんです、親分」「白い帶だよ、丸グケの帶だよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "月待ち",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　×　　　　　　×　平次が堀周吉その他の惡者を縛り上げる間に周吉に荷擔した親類達はコソコソと逃げ出しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらもなか／＼の腕前で、組んだまゝ庭へ轉がり落ちたのを、縛り上げる迄には、平次も手を貸さなければならなかつたのは大したことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの幽澤",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日まで窮命させませう、繩と手拭を――」　平次は正體もない森三をキリキリと縛り上げると、猿轡を噛ませて、物置の中へ放り込みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "風太郎の手口は百も承知ですから、風の如く通つて歩いた後を嗅いだところで何の匂ひも殘つては居ず、此上は、例の通り品物を返しに來るのを待ち伏せて、有無を言はさず縛り上げる外はなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "大盜懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "男でも女でも構わねえ、髷の中が湿っているか、元結が濡れている者があったら、その場で縛り上げるんだ、解ったか」　平次の命令は細々と行届きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "風太郎の手口は百も承知ですから、風のごとく通って歩いた後を嗅いだところで何の匂いも残ってはいず、この上は、例の通り品物を返しに来るのを待ち伏せて、有無を言わさず縛り上げる外はなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大盗懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　平次が堀周吉その他の悪者を縛り上げるあいだに周吉に荷担した親類たちはコソコソと逃げ出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日まで窮命させましょう、縄と手拭を――」　平次は正体もない森三をキリキリと縛り上げると、猿轡を噛ませて、物置の中へ放り込みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "縛り上げるといきなり泣き出して、五十兩やるから見遁してくれ――つて言やがる」「どうせそんなことだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "縛り上げるといきなり泣き出して、五十両やるから見遁してくれ――って言やがる」「どうせそんなことだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪問者は彼が寝台の傍に紐を用意していたのに気づいており、彼が言うには夢中遊行のために毎晩両の踵を縛り上げる必要があるらしい。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎戻ってきて松王を縛り上げる。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ直ぐに申さぬと縛り上げるぞ」「いけねえ」　と、いうやいな、不伝は、駈け出して、ばっと、往来へ逃げ出した。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人たちは、そうして子供たちを遊ばしといて、自分たちの方は、まだ鉄砲のない頃でしたから、弓や石投機械や刀や棒など、てんでに何か武器を持って、森の木の陰や村の家の陰なんかに隠れて、今に鬼が出て来たら、打ち殺すかしばりあげるかしてやろうと、じっと待ちかまえました。",
              "citation": {
                "source": "天狗笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "細引きで、しばりあげるんだ」　警部のさしずにしたがって、しばろうとしましたが、怪人は、きちがいのように、手足をバタバタやって、なにかさけんでいます。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ、事件の依頼者をしばりあげるなんて法はありません。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なかのひとりがこうさけぶと、閃々たる小太刀の陣は霜の歯車のように、かれのまわりをグルリとめぐって、有無をいわさず、蛾次郎を高手小手にしばりあげる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
