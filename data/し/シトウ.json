[
  {
    "uuid": "3f040ffd-5c87-5ad4-9a6c-c51e434faac7",
    "entry": "死闘",
    "reading": {
      "primary": "しとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
