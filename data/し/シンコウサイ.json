        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地元の神社では、毎年秋に盛大な神幸祭が開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神輿が町を練り歩く神幸祭は、多くの見物客で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、神幸祭の行列を見るのが何よりの楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日は陰暦の十月十五日、宮市天満宮の神幸祭である、追憶果てなし、詣りたくてたまらないが、質受が出来ない、小遣がない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今日は陰暦で十月十五日、宮市天満宮の神幸祭である、おもひではつきない、共に裸坊となつておもしろがつたＡ君はどうしてゐるだらう？",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
