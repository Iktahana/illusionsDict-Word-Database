        "index": 1,
        "gloss": "festival celebrating the (temporary) transfer of a shintai away from its main shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
