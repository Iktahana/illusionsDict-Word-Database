[
  {
    "uuid": "f7744831-0f43-5808-a63f-ea2eb6217b37",
    "entry": "商魂",
    "reading": {
      "primary": "しょうこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commercial spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "他の兄弟の様な、生馬の眼をぬく商魂がなかったのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山城屋宗右衛門のその一瞥で、屋敷の隅々までも見透すほどの鋭い眼光は、彼が江戸諸大名の御用商人として、一代に巨万の富をかち得た偉れた彼の商魂によつて磨き出されたものである。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童には背景に水に対する恐怖があるが、ホームパソコンの裏にあったのはカアチャンにマシンを売り付けたいという商魂だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに商魂で鍛え上げたような矢部も、こいつはまだ出くわさなかった手だぞと思うらしく、ふと行き詰まって思案顔をする瞬間もあった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "将曹は、欠伸をして「商魂士才で、如才が無い、薩摩の殿様お金が無い、か」　と、呟いて「これは？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　小工業と商業でもつ桐生はおのずから個人的な都市で、したがって商魂もたくましい。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商魂たくましい町に住んで何かこの町の特色的なものを見たかときかれると、私は小学校中学校の校庭がそろって広大なのにビックリしたと答えたい。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校野球においてそうであるばかりでなく、商魂商策においても似た地位にあるようだ。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟市のように女の子の性行を男の子の標準にした都市も珍しいが、カラッ風と商魂と浮き沈みを生きぬく力が町の魂のような桐生も、実は案外女性的な町だ。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬九層倍の旺盛な商魂によって宣伝これつとめている他国の業者のめざましい生気にくらべて、シンは強いのかも知れないが、表情は暗い富山の行商の姿であった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら命の瀬戸際だって、商魂を忘れちゃ実業家じゃないよ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと商魂をもっての経営のみを念願としているからであります。",
              "citation": {
                "source": "陶芸家を志す者のために",
                "author": "―芸術における人と作品の関係について―",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然うなぎがいないからではなく、それを獲るのに人件費がかかるからで、問題は商魂にある。",
              "citation": {
                "source": "鰻の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "商魂のつよい男が三人おった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "商魂抜群のアンチャンだそうで」　甚だ意外な話であった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "商魂があって、金ができるし、隆々と、いい顔だそうですよ」　ジイサンは他の所番地を示した。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主には惜しい商魂商才、生活力旺盛であるから、お経なんぞあげない方が稼ぎになろうというものだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商魂があったからである。",
              "citation": {
                "source": "大阪人と科学精神",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを為しとげた功績の一半は「もうかりまっか」が「おはよう」の代りになるという商魂にある。",
              "citation": {
                "source": "大阪人と科学精神",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商魂が生まれたのは、大阪に政治の中心が無かったからであろう。",
              "citation": {
                "source": "大阪人と科学精神",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実業家が政治、即ち権力と結びつき易いところには、こういう商魂は生まれない。",
              "citation": {
                "source": "大阪人と科学精神",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪人は科学と縁遠いとよくいわれるが、私には案外深いところで、大阪の商魂に科学精神と通ずるものがあるように思われる。",
              "citation": {
                "source": "大阪人と科学精神",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たがいに識見を交換し、結束をかたくして攘夷派の圧迫に耐え、一日も早く、日本をして文明の恩恵に浴さしめ、新時代を招来して、その波に乗って巨利を博そうという商魂志心。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あとから段々木村さんが、イギリスの商魂ということを云い出してね。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのがイギリスの商魂なんだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のうちにあっては、例えばスノーデンがヘーグでは100パーセントの英国人で英国の利害を主張している時、それを支持するロンドン中流男女は、自然的公園の樹蔭をスコッチ・テリアをつれパイプとともに散策しつつ彼らの沈着な商魂を放牧した。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、きわめて純粋な英国式解釈で、一般大英国人の社会奉仕の観念につき、商魂につき強固な社会的訓練および｜公平な勝負の価値について古物的な東方からの客を啓蒙する。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この合理化を非合理化だと叫んでいるのは、英国人の商魂という特殊性を没却した第三インターナショナルの指令のままに誤った戦法を繰返しつつある小数運動者ばかりではないかと。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「英国人の着実な商魂が実際においてどれだけの働きをしているかと云うことは、炭坑夫安寧協会の仕事を見ても分る。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、その同じ着実な商魂が考え出した英国炭坑における合理化と云うことは、二年前（一九二七年）に比べると十六パーセント減の労働人員によって前年より千三百万頓増大した採掘量を持ち、労働者の賃金は一交代九シリング六ペンスから九シリング一ペンス１／２に落ちて死傷率が高くなったという事を意味する。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
