        "examples": {
          "standard": [
            {
              "text": "当院の診療時間は午前9時から午後5時までとなっております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "診療時間外でも、緊急の場合は対応いたしますのでご連絡ください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ええと、ここの診療時間は何時からだっけ？」彼はスマートフォンの画面を覗き込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――二メートル四方ほどの待合室には、ニスの剥げた木の腰掛と、タバコの吸い殻だらけで火のない火鉢があり、壁に貼った診療時間割の紙も、一隅がやぶれて垂れさがっていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
