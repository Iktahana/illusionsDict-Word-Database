[
  {
    "uuid": "78029bfe-4ac9-5efe-af08-7aef0ff32c24",
    "entry": "親疎",
    "reading": {
      "primary": "しんそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "degree of intimacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふだんから、かの女は地球上の土地を、自分の気持の親疎によって、実際の位置と違った地理に置き換えていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、人から無心を言われるとき、私はそれに応ずるか応じないかは、その人と自分との親疎によって定める。",
              "citation": {
                "source": "私の日常道徳",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大名の取締りは最も重要問題だが、徳川氏の一族たる親藩と、関ヶ原役以前から家臣であつた譜代と、関ヶ原までは徳川の朋輩であつた外様とを、大小親疎に従つて、その領土を犬牙錯綜させて配置し、牽制の妙を極めたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその客の親疎によって、「あなた大層お見限りで」とか、「どうなすったの、鼬の道はひどいわ」とか云いながら、左の手で右の袂を撮んで前に投げ出す。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、子に対する親の愛ですが、親の目には幾人子供があろうと、その間には甲乙、親疎の区別はありません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "観月感慨無量、戦線をおもひ銃後をかへりみる、遠近親疎、有縁無縁、南無阿弥陀仏。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ後輩として、Ｏ―先生との個人関係の親疎や、愛敬の度合ひなどが、Ｏ―先生の歿後、いつの間にか、遠心的に二人を遠ざからしめてしまつた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜しく親疎の理を明にし、内外同一なることを審にすべし。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "交遊断片豊島与志雄　親疎さまざまの程度の友人達のことをぼんやり考えてみて、そのうちから、思い出すままの断片的印象を書き綴ってみることにする。",
              "citation": {
                "source": "交遊断片",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと親し疎しこの世に我住まずなりなん後も青からん空　十年後私が死んで地上に居なくなつた場合の秋の空を思ふと、やはりけふの様に青い事だらう、さう思つて改めて空を見ると、空の青さが親疎二様に見えて来る。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に根本たる孝【弟】と絶縁せざる以上、仁の範圍が如何に擴大されても、その範圍の中に、親疎を附すべき餘地が存せねばならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は儒教の仁と墨家の兼愛とを區別せんが爲に、仁と義とを併せ説き、仁を行ふには必ず義によつて、親疎の差別を立つべき必要を説き、義を離れた、換言すれば孝【弟】と絶縁した仁は、儒家の仁でないと主張した。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば『唐律』（鬪訟律一）に據ると、他人を毆打した罰は笞四十であるが、一族の尊長を毆打した場合は（鬪訟律二）、その親疎の關係に應じて、左の如き重き罰を加へる。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの罰の加重、若くば輕減は、親疎の關係に比例して程度を異にして、尊長より卑幼に加へたる非行は、近親なればなる程その罰を輕くし、卑幼より尊重に加へたる非行は、近親なればなる程その罰を重くした。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（８）孟子は墨家の兼愛は親疎の差別を無視せるものとして、墨子兼愛是無父也と排斥して居る（滕文公下）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『孝經』にも親疎の差別を無視し、若くは逆施する者を排斥して、不愛其親。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（10）支那では古く親屬の親疎を喪服によつて區別する。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體家族又は親屬間の事件は、親疎に斟酌して解決を圖らねばならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して親疎の區別は、喪服の制を標準とする。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "親疎の感情を超越してるらしかった。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "態度が違ふのは無意識と云つてよく、なによりも親疎の感情と警戒心の強弱に一切が左右される。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "而欲不以存亡有親疎。",
              "citation": {
                "source": "遺篇",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "客に親疎を問わず、好悪を選ばずとはこの人のことだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな顔ぶれを集めての催しである上に、主人の松雲は相変わらずの温顔で、客に親疎を問わず、好悪を選ばずと言ったふうの人だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して古事類苑の案には、貞丈の説妥当ならずとし、古記の記事によれば、「其の地に予め一大穴を鑿ち、火葬の後に其骨を墓に収めずして、之を粉砕し、親疎を択ばず皆此に蔵するを謂ふか」と解している。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "千利久は茶器の新旧可否を鑑定して分限者になった男だが、親疎異同によって、贋物を真物、新を古と言い張って、よく人を欺いたということである。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした場合の彼の男らしい態度と弁明の如何によつて、彼女は親疎を決しようとしてゐるかのやうでもある。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方を公平に取扱かっているつもりでいながら、彼は常に親疎の区別をその間に置いていた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この伝説を捕えて道元は次のごとく言っている、――正伝なきともがらは、この四人の弟子の解するところに親疎あるによって達磨の評言もまた皮、肉、骨、髄と深浅を区別するのだと考える。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "販売の仕方　私はお得意に対しては、親疎遠近の別なく、いっさい平等に売るべしと主張いたします。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
