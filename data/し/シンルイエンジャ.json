[
  {
    "uuid": "48e4daf9-c4b6-5090-ab44-a7d73cef2b5a",
    "entry": "親類縁者",
    "reading": {
      "primary": "しんるいえんじゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
