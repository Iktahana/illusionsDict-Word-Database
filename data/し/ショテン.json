  {
    "uuid": "14f1b072-fcf3-5502-a434-1bbd254a92c3",
    "entry": "諸天",
    "reading": {
      "primary": "しょてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "various deities",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女たちは諸天使の近くにゐる、青いみ空の奥の奥で、神の御母の頌歌を唱つて！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その磁場は諸天体にも感応し反対に諸天体の磁場もまたこれに影響する。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし密教の大道理からいえば、荼枳尼も大日、他の諸天も大日、玄奥秘密の意義理趣を談ずる上からは、甲乙の分け隔てはなくなる故にとかくを言うのも愚なことであるが、先ず荼枳尼として置こう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに従って護法の諸天、神将達が絢爛なる武装にて控え居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天のＡ　――何しろあの男は生れが上品だし、年は若いし。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天のＢ　――丁度店先きの拵えものの菓子の見本のようなものだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天のＡ　――だから仏様が、ちゃんと箝まった役をふって下さる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天のＢ　――阿難の弱った姿がまた美しい。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天のＡ　――いくさの途中だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（空中の場面に於ける目※連その他諸天神将達が雲の上にて台詞を交し居るうちにも、背景の夜の空はキネオラマ式に移り動き、恰も舞台の人物とそれらを乗せたる雲が空中を飛揚し行くような錯覚を起さしめる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の中央にて護法の諸天善神達と、呪いの方の眷属等と戦う。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法を護る諸天善神達は絢爛なる甲冑に槊、剣、戟、金剛杵、弓箭にて働く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち呪いの眷属達は諸天善神達に打ち敗かされ、一人々々雲の上より突き落され、遂に掃蕩され尽す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのト書きに於て、諸天善神と呪いの魔の眷属の働きを、それは闘争にも見え舞踊にも受け取れると書いた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲界の諸天は氣を泄らして樂となすといふ語が佛書にあるが、天部にも及ばぬ人間だの畜生だのは、氣と血とを併せ泄らして樂とするから堪らない。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおあとには、継体、安閑、宣化、欽明、敏達、用明、崇峻、推古の諸天皇がつぎつぎにお位におのぼりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりの寺は、どこにも、へだて、戸じまりを置かないから、朝づとめよりして夕暮までは、諸天、諸仏。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に劣らずインドまた古来竜を神視し、ある意味においてこれを人以上の霊物としたは、諸経の発端｜毎に必ず諸天神とともに、諸竜が仏を守護聴聞する由を記し、仏の大弟子を竜象に比したで知れる。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "回教学有数の大著、タバリの『編年史』にいわく、上帝アダムを造り諸天使をしてこれを敬せしめしに、エブリスわれは火より造られたるにアダムは土で作られたから、劣等の者を敬するに及ばぬといい、帝｜瞋りてエを天より逐い堕す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "好んで妓楽を観聴し戒緩だった者この楽神に転生す、布施の果報で諸天同様楽に暮すと仏説じゃ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天これを見て偈を説いていわく、〈瞋恚闘諍間、中において止むるべからず、羝羊婢とともに闘い、村人｜を作る処へ羊来り盗むを、火を掻く杖に火の著いたまま取り上げて打つと羊毛に燃え付いた。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームス・ローの『回教伝説』に、帝釈の天宮に住む天人、名はノルテオクが天帝の園に花を採る若い天女に非望を懐いた罰として、天帝を拝みに来る諸天神の足を浄める役にされたが、追々諸神の気に入ってついに誰でも指さして殺す力を得た。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時諸天｜偈を説いて曰く、頭を断たぬ内は殺したと言えぬ、また起ちて能くかくのごとき業を作す、事宜に随って他を損ずるも害と名づけず、白膠王の子を害したもののごとしと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも仏教に梵教の諸天を入れたごとく、キリスト教に欧州在来の諸神を尊者化して入れたので、ついに年中尊者の忌日を絶やさず、万の事物に守護の尊者を欠くなきに至った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレ　　諸天善神、願はくは此神聖なる式に笑ませられませい、ゆめ後日悲哀を降さしまして御譴責遊ばされますな。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸天体は神々であるとの信仰のために天文学は神様に関する教え、すなわち、宗教の一部になった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼が、地球は諸天体の中で何ら特別に選ばれたる地位を占めるものでないという説の最初の言明をしているのは注意すべきことである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、諸天体は無限に広がる透明なる流体エーテルの海の中に浮んでいると説いた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『諸天体はそれぞれある力の作用をもち、それを地球に及ぼしているということは、経験によって実証される。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
