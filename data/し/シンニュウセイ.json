        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "厳かな入学宣誓式が行われて、自分も大勢の新入生の中にまき込まれて大講堂へ這入ったが、様子が分らないのでまごまごしていると、中に一人物馴れた日本人が居ていろいろ注意してくれて助かった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新入生一人一人に総長が握手をするというので、一列に並んで順々に繰出して行った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりとしてそれでいて何だか堅苦しそうにしている新入生はおかしなものだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ来年はみんな僕らのようになってまた新入生をわらう。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のだらし無さを、新入生のせいにしようとしているのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生たちはすべて、この美しい異國人に愛されようとひそかに祈つた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互ひにまだ友人になりきれずにゐる新入生たちは、教室のおのおのの机に坐つてブルウル氏を待ちつつ、敵意に燃える瞳を煙草のけむりのかげからひそかに投げつけ合つた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生たちはすべて、この美しい異国人に愛されようとひそかに祈った。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いにまだ友人になりきれずにいる新入生たちは、教室のおのおのの机に坐ってブルウル氏を待ちつつ、敵意に燃える瞳を煙草のけむりのかげからひそかに投げつけ合った。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻下に薄髭を生やし、私より少し年上のように見えたが、でも、緑線を附けた医専の角帽はまだ新しく、帽子の徽章もまぶしいくらいにきらきら光って、たしかに今秋の新入生に違いなかった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは、他の新入生たちと疎遠になるのも当り前の話で、その松島遊覧の船でひとりの新入生と顔を合せた時も、私は、ひやりとして、何だかひどく工合が悪かった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日、制帽をかぶって来ない新入生が二人いました。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は何ちゅうても学やなあ」　と、しきりに囁いていたが、やがて新入生の姓名点呼がはじまると、他吉は襟をかき合わせ、緊張した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭が近づいたので誰もそわそわして落ち着かず、新入生の歓迎コンパだと称して毎晩のように京極や円山公園へ出掛けて行くらしく、その自由さが豹一には羨しかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援団委員の希望、そして足を食止め易いのは新入生たちであった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一の子供じみた頭や、むやみに上着の袖の長い如何にも新入生らしい服装をなめて掛かったのか、委員は、「推戴式に出ないと、承知せんぞ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内に百五十人の新入生が皆釣合はぬ新調の製服をつけてぞろ／＼と登校した。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐治君も新入生の組を受持つた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生は胸に動悸を覚えた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　新入生は泣き出しそうになって、やけに声を高めた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服ひとつとっても、金糸のエンブレムがついた紺のブレザー、レジメンタル・タイ、グレイのスラックス、というフォーマルなもの、そして、ふだん学校や寮で着る、衿なし上着にオープンシャツの校服、という二種類があり、いろいろ行事のある入寮入学前後は指示が複雑で、新入生を悩ませた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知らぬ新入生は、三階をとおりすぎて、四階へいこうとするので、慶一は、「どこへいくの」と問いただした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま寮長室を出ようとすると、「それにさわるんじゃない」　と、新入生が低い声で慶一にいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生の受付は三時からだから、まだ、準備ができていないんですって。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがサロンだそうだから、ちょいと待たせてもらいましょう」「――新入生？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一年坊主は高志とワラの部屋、二〇二の新入生で、ふたりはこいつを義晴と呼んでいる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに、新入生諸君の参加をお待ちしています。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一の部屋の新入生、嶋野だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、うれしいことに、さっそくふたりの新入生をお客さまに迎えています。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
