[
  {
    "uuid": "64ae0620-7487-5efe-be46-c77ea8c0ef1a",
    "entry": "痺れ",
    "reading": {
      "primary": "しびれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "numbness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "待ってる方は痺れを切らしても、逃げると云う事はないからね。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆れた夢に痺れさせられかけていた翁の心は一種の怯えを感ずるとぶるりと身慄いをした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さめて見たら枕が無闇に固くて首筋が痺れていたそうである。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで堅い枕、頸の痺れ、新聞記事の感電、電気をあつかっている友人、その助手と云ったような順序にこの夢の発展の径路が進行したのではないかと想像される。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴いてゐてさへも身の痺れるやうな寂しい遣瀬ない声、その声が今夜も向うの竹林を透してきこえる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その熱中が、母と子を何も考えず、意識しない一つの気持ちの痺れた世界に牽き入れた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最う其だけで痺れるばかり。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人は潜水業者であったが、ある日潜水から上がると身体中が痺れて動けなくなったので、それを治すためにもう一遍潜水服を着せて海へ沈めたりしたが、とうとうそれっきりになってしまった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間の恍惚の痺れ。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻想を起さす為めに世紀末のフランスの廃頽詩人たちが喫んだアッシという土人の煙草なぞはおよそ不健康な恍惚の痺れです。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その患者は時折癲癇のようにひっくりかえり、不断でも体の方々が痺れたりするそうです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝までに身体が凍え痺れる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にはまだ痺れきらない真心が閃いて居ると思はれたからである。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧に似たる細雨は隙間もなく瀟々と降頻って、濡れたる手足は麻痺れるように感じた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は馬鹿だ、確に頭が痺れてゐる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "痺れるだけ痺れさせて置く氣だ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "痺れきツた腕を摩りながら、徐ら起｜上りざま母親はと見れば、二畳に突ツ俯したまゝスウ／＼鼾を立てゝゐる。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は指が痺れるほど冷たくて、とてもいい気持よ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子もこの老婦人が、初めから芸者風情と見くびっているようには見えず、わが子の愛人としての情愛も一応は受け取れるので、少し話の長いのに痺れを切らしながら、じっと聴いていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一は秋口だけに、「さあ、ことだ」とベッドの中で脅えながら、何度も起き上ろうとしたが、意識が朦朧として、身体もまるで痺れているようだった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの惨ましさに痺れてぽかんとなってしまった鼈四郎の脳底に違ったものが映り出した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その恨みの相手が結局誰だか判らないので、口惜しさに今度は身体が痺れて来る。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "媚薬の痺れにも似た中欧の青深い、初夏の晴れた空に、夢のしたたりのように、あちこちに咲き迸るマロニエの花。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその感情と、この眼の前の媚かしい青年に対する感覚だけの快さとが心の中に触れ合うと、まるで神経が感電したようにじりりと震え痺れ、石灰の中へ投げ飛ばされたような、白く爛れた自己嫌悪に陥った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛熱い触覚が、やや痺れてゐる左の手の指先きに噛みつくと、いはうやう無い快感が興奮した神経と咄嗟に結びつき、身体中がせいせいと明るくされるやうである。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は左の手の中で一本湯鑵の胴に触らないで痺れたままの感覚で取残されてゐる例の疱瘡で短くなつてゐた人差指をも、公平にこの快味に浴させようと、他の四本の指を握り除け、片輪な指だけ、湯鑵の胴にぢりりと押つけた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何だかと痺れた樣になつてよく働かない自分の頭を、金太郎は齒｜痒く思ひながら考へた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかははねがすっかりしびれてしまいました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永らく坐りつづけていたあとで足がしびれて歩けなくなる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、しびれた足の爪先をいくら揉んでもたたいてもなかなか直らない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
