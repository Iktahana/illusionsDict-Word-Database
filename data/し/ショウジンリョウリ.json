[
  {
    "uuid": "b3b4a2ba-738b-54b5-98e4-eb9c40779fe8",
    "entry": "精進料理",
    "reading": {
      "primary": "しょうじんりょうり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
