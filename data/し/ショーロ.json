        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてある種の外国人はソヴェト文学はファデーエフやショーロホフによって代表されるという概括に反対して、いや、今でもエセーニンの人気は大したものだ、と抗議した。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファジェーエフの「壊滅」、ショーロホフの「静かなドン」などはよい作品だが、国内戦は局部的に扱われているのである。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーロホフの「静かなドン」はドン地方のコサックの階級闘争史だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき古本やの話に、この頃ショーロホフの小説などなかなか出るようになった由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーロホフの『開かれた処女地』には、共同農場に於ける小家畜（禽）共有の失敗が詳しく描写されている。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
