[
  {
    "uuid": "f8cfa708-e4d1-539d-8280-ff146e90fb00",
    "entry": "昇殿",
    "reading": {
      "primary": "しょうでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
