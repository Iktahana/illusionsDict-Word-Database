[
  {
    "uuid": "b87563ec-4bab-5c94-8cb8-67491d9d0ae8",
    "entry": "支払う",
    "reading": {
      "primary": "しはらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
