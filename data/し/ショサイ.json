      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "study",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "予て飛行機作りがその先生の道楽だと聞いてゐたから、それは正しく先生の書斎に相違ない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎に仕事をしている時のヘルンは、周囲のちょっとした物音にも、すぐ『私の考え破れました』といって、腹立しくペンを投げた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人が書斎の掃除をしたり、家事の雑務をしたりする時、ヘルンはいつも不機嫌であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少し休息し、書斎に入って仕事をする。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人でさえも書斎に入ることは許されなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの悪い病です』といって、中々許してくれないので、書斎はますます乱雑になるばかりであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時の夜などに、ヘルンの書斎から法螺貝の音が聞えて来ると、それが広い家中に響き渡って、ボオボオと余韻の浪をうって伝って来る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると『それ貝が鳴った』とばかり、夫人を初め女中や書生たちが大騒ぎをし、先を争って離れの書斎に駈けつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "叱り飛ばされた妻君は引き返したその足を直ぐに長男の書斎に運んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが聞えなくなつてから間もなくして、その時書斎で読書してゐた耕二の兄は、机の前の障子の中硝子から弟（一字不明）口笛を吹きながら仰向勝に耕二（五字不明）を、みた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄は書斎に来た。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――書斎に半日でも落ちついてはゐないのだから。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父に隠れて喫つてゐた煙草が懐にあつたので、それが御飯の時若しか転んで出でもすると不可ないと思つてそれを書斎に持つて行つて本棚の後に投げて置いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は好い加減に胡魔化して、書斎に帰つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "可なり思ふ様に詩の出来た私は、近頃になく晴々しい気持になつて、もう書斎にヂツとしてゐられなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎から裏の方をみると、田の中を一条に二哩近くも続いた、元軽便車の通つてゐた路が、まだ午前らしい日に輝いて見えた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "のこのこと書斎を出て行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあきらめて書斎まで戻つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか同郷の先輩の書斎で美しい絵のついた長方形の浅いペン皿を見た事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表装でもしておくといいと思いながらそのままに、色々な古手紙と一しょに突込んであったのを、近頃見せたい人があって捜し出して書斎の机の抽斗に入れてある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の思ひ出は悲しい書斎の取片附け彼女は直きに死なねばならぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "また子を生むといつでもその子を取り上げられるので色々隠し場所を変えた末に、とうとう主人の書斎の書棚の奥に隠した猫もある。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上が二階の書斎で手紙を書いていると女中が山崎の来たことを告げながら「これを頂戴いたしました」といって干鰈の沢山入った籠を見せた。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は寝坊であったが夜は時には夜半過ぐるまで書斎で仕事をしていたそうである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他には客間にあったオルガンを書斎に移したくらいで、外には別に造作を加えるようなことはしなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の書斎は無頓着にいつでも取り散らされ、大きな机の上は本や論文でおおかた埋められてほんのわずかの面積だけが使われていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから朝飯まで書斎で書信の開封。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯後書斎で手紙の返事、十時に助手のゴルドン出勤、その日の仕事の打合せ、午前中は大抵読書か書きもの、Phil. Mag. か Ann. d. Ph. が来ると安楽椅子で約半時間それに目を通してから書棚へ入れる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機や潜航艇の所在を探知する方法について絶えず軍務当局から相談を受け、また一方では国民科学研究所と航空研究顧問委員会の軍事的活動の舞台でも主役を勤めていたので、その頃の彼の書斎は机の上も床の上もタイプライターでたたいた報告書類などで埋まっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
