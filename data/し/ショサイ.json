  {
    "uuid": "ecdf8147-d798-53b2-a934-d02497c20c96",
    "entry": "所載",
    "reading": {
      "primary": "しょさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "printed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "｛４｝『哲学雑誌』、第二十四巻、第二百六十四号所載。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋子の理解によれば、僕のあの文（改造所載芥川龍之介の死）は、芥川君に對する冒涜であり、自己尊大であり、故人を恥かしめたものであるさうだ。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が二月號の同じ雜誌に、同じ文藝春秋子がまた僕の毒舌を、僕の新潮所載の文（室生犀星に與ふ）について書いてる。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雜誌・椎の木所載・室生犀星君の心境的推移について・參照）それは最近出版された彼の詩集『故郷圖繪集』を見た時、最も明白に直感された。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィアレジオからの二番目の手紙、即ち、本誌所載の手紙は、それに對するリルケの返事である。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一）宅の近所のＡ家は新聞所載のＡ家と同一か。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は近着の Geographical Review. Oct., 1932. 所載の記事から抄録したものである。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他日機会があったらもう少し補充してまとめたいと思っているが、本書所載の他の論文にしばしば引き合いに出ている関係上参照の便宜のためにこのままここに採録した次第である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一六年一月、「白樺」所載）",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本集所載の連作には、夫として父としての真実が樹明的手法で表現されている。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君を訪ね、さらに久芳さんを訪ねる、週間朝日所載の、井師『酒と水』とを読ましてもらふ、そこには私の事がまざ／＼と書いてあつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋子の理解によれば、僕のあの文（改造所載芥川龍之介の死）は、芥川君に対する冒涜であり、自己尊大であり、故人を恥かしめたものであるさうだ。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が二月号の同じ雑誌に、同じ文藝春秋子がまた僕の毒舌を、僕の新潮所載の文（室生犀星に与ふ）について書いてる。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサヒグラフ所載のものであって、児島喜久雄というひとの解説がついている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸冊子「散文」十月号所載山岸外史の「デカダン論」は細心｜鏤刻の文章にして、よきものに触れたき者は、これを読め。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸冊子「非望」第六号所載、出方名英光の「空吹く風」は、見どころある作品なり。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂きわれをさびしがらせよ閑古鳥「日本浪曼派」十一月号所載、北村謙次郎の創作、「終日。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　改造十一月号所載、佐藤春夫作「芥川賞」を読み、だらしない作品と存じました。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史文学所載の貴文愉快に拝読いたしました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの日大審院長は本件の豫審終了を認め、特別刑事部の公判に附する決定を與へ、其決定書と共に檢事總長より本件犯罪摘要（十日東京朝日新聞所載記事中「大陰謀の動機の一項則ちそれなり）を各新聞社に對し發表し、各新聞社は號外を發行したり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正六年の「曼陀羅」創刊号所載。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの『おかる勘平』が同年の暮、日比谷の松本楼で開かれた“PAN”大会席上に於て、私自身に依て朗読せられ、その翌年同詩所載の『屋上庭園』第二号が風俗壊乱としてその筋より発売頒布を禁ぜられたといふ事実が、之をして愈意義あらしめ、私達をして益亢奮せしめたものである。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正二年十一月十五日發行、アララギ　第六卷第十一號　伊藤左千夫追悼號所載）",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "（談話）（大正二年八月十日發行、ホトトギス　第十六卷第六號所載）",
              "citation": {
                "source": "知己の第一人",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正二年八月一日發行、中央公論　所載）",
              "citation": {
                "source": "簡易銷夏法",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十二年一月二十五日發行、爲櫻　第三十五號所載）",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
