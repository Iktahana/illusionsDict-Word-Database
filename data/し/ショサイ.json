[
  {
    "uuid": "2bc221ab-0561-526b-924d-d87b39668605",
    "entry": "書斎",
    "reading": {
      "primary": "しょさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
