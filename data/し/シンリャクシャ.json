    "definitions": [
      {
        "index": 1,
        "gloss": "invader",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蜂は又自らの生活の根城を死守して屡侵略者を刺した。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは湖畔に出て侵略者を迎え撃った彼等も名だたる北方草原の騎馬兵に当りかねて、湖上の栖処に退いた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭と右手だけは、侵略者が斬取って持って帰ってしまった。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは湖畔に出て侵略者を迎へ撃つた彼等も名だたる北方草原の騎馬兵に當りかねて、湖上の栖處に退いた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭と右手だけは、侵略者が斬取つて持つて歸つて了つた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級といい習慣といい社会道徳という、我が作れる縄に縛られ、我が作れる狭き獄室に惰眠を貪る徒輩は、ここにおいて狼狽し、奮激し、あらん限りの手段をもって、血眼になって、我が勇敢なる侵略者を迫害する。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年秋風が立ちはじめると決って漢の北辺には、胡馬に鞭うった剽悍な侵略者の大部隊が現われる。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮ヲ領有スル結果ヨリ見テ、恰モ百萬圓ヲ貯蓄シタル結果ヨリ見テ、其レガ高利貸ニヨルト忠實ナル勞働ニヨルトヲ考査セズシテ等シク守錢奴ト詈リ侵略者ト誣ユルハ昏迷者ノ狂言ナリ、重大ナル罪惡ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ガ積極的發展ノ爲メニ戰フコトノ單ナル我利私欲ニ非ザルコトハ、他ノ民族ガ積極的覺醒ノ爲メニ占有者又ハ侵略者ヲ排除セントスル現状打破ノ自己的行動ガ正義視セラルル如ク正義ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究所にある一グラムのラジウムを、人類と科学とのために侵略者の手から安全にしなければならないと決心したからであった。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背景とし、侵略者としての本質をかたるエピソードとして、土方という隊長の階級的タイプを一貫して描きつつ、主人公野田その他の性格と動きとを蒙古の原始的生活の前に描き出さるべきであった。",
              "citation": {
                "source": "予選通過作品選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "台湾、朝鮮のような植民地または中国、満州のような半植民地に発展していた人たちは、その土地と社会が本来は他の民族に属するものであって、そこで日本人は侵略者の立場をもっている事実を忘れた、優越感に安住していたのではなかったろうか。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年八月十五日から植民地在住の日本人にあらわに思い知らされた敗亡する侵略者としての足どりは、それらの人々にいってみればさか恨みの感情をもたせたとも思われる。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九七年に鉄幹の詩集『天地玄黄』が、アジアにおける侵略者としての、日本の最初の勝利のうたい手としてあらわれた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の考えでは、僕の留守の室に将校達が詰めかけていた時こそは、正に敵国人が秘密防禦要塞を作っていた此の山奥の地点を、わが陸軍の飛行隊が空中から襲撃を行ったときに当るのであって、憎むべき侵略者の一団は悉く飛行機から打ち落す爆弾によって殺害せられたのです。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に自分を生ませた男が、最も卑劣な侵略者なら構うものか、そうあらせろ、自分が、母と自分の血を浄めて見せるぞ。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人々が個人としてどんなに聰明でも、侵略者の位置にたったとき、真実はその人からかくされる。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代日本の権力が、中国に対してはいつも侵略者であったという悲しむべき事実から、同じ東洋のわたしたちも、パール・バックの鏡によって、真実の中国への愛をよびさまされたのであった。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品には自分たちの生命と、ともにある自分たちのソヴェトの生活を護ろうとして、言葉尠く、勇気と、智慧と、あらゆる堅忍とを以て侵略者と闘ったウクライナの男女農民の姿が見事に描きだされている。",
              "citation": {
                "source": "新世界の富",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流血の果てに得た一つの土地が、無智な侵略者の爲に壓制を敷き、民衆を烏合とあなどり、失政を氣づかないおろかさといふものは、ダイヤモンドの價値を知らない日本の女のこゝろと何か通じあつてゐるやうに考へられ、停滯しきつてゐるこのごろの軍政に眞鍋はそれを感じるのであつた。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやって初めてカイロを見た時、私は昔の侵略者たちが此の辺からそれを俯瞰して勇躍した心持を想像した。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしエジプトはエジプト人のエジプトでなければならぬとするならば、今のエジプトは侵略されたままのエジプトであり、カイロは侵略者の都市だから、エジプトは本来のエジプトでなく、カイロはまたエジプトの首都ではないということになりそうだ。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空地には古代エジプトの文化と無関係の侵略者が押し入り、断えず争ったりいじめ合ったりして来たのである。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国人は黄河の洪水と同じように侵略者をうけいれて、無関心に自分の生活をいとなんでいるだけのことだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回の戦争の結末にてらしても、色仕掛にまるめられて侵略者の道案内をつとめたなどという親分は、いずれの国に拘らず、国民に愛されないのかも知れない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の領地をさいて、侵略者の祖神を祀る霊地に捧げるほど奉仕的な忠義者であったが、意外にも世間の受けが悪く、天皇家の史家も芸術家もサジを投げて、忠義な彼を愚かなピエロにしなければならなかったのかも知れない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの鉄道ができあがった時に、それが侵略者の大砲を運搬する道になるのを見るだろう。",
              "citation": {
                "source": "青年に訴う",
                "author": "AUX JEUNES GENS",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十七日（金）　日本を侵略者と呼んだスターリンの演説に対し、政府は新聞雜誌に一切の批評を許さない。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "往年ケプロンについてなにがし調べたおぼえのある私は、彼らの胸に一片の侵略者の野望が含まれていなかったことを断言することができる。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして或時は、悪だくみを持つた侵略者に対して、螫毛の鞘を払つて、大いに自分を主張するために飛びかゝつてゆく。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
