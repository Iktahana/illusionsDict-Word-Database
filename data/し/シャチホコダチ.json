          "literary": [
            {
              "text": "ああしてあばたの大将が、今度こそはてがらにとしゃちほこ立ちをして出かけたうえは、あわててあとを追っかけていったとて、けんかになるばかりなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがおりおり玄関で手塚と腕押しをしたりしゃちほこ立ちをしたり、近所の子どもをからかったりする人とは思えない。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "その合間には、しゃちほこ立ちをしたり、とんぼ返りをしたりしました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
