    "definitions": [
      {
        "index": 1,
        "gloss": "to sob convulsively",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
