    "definitions": [
      {
        "index": 1,
        "gloss": "(camera) shutter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
