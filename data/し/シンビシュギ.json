        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "オスカー・ワイルドは、審美主義の代表的な作家として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作品は、内容よりも形式や美しさを重視する審美主義の傾向が強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "審美主義は、芸術における美の追求を第一とする思想である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "茶の原理は普通の意味でいう単なる審美主義ではない。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは審美主義の禅であった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現論と審美主義とは分離することができ、また分離して考えられねばならぬ。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代日本のこうした文学主義は併し芸術至上主義や審美主義とは大分本質を異にしている。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "審美主義は単に感情が知性や意志に対して優位を占めているという主張以上のものではない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "通俗大学はまた、頽廃的な彫刻や詩や音楽など、極端に貴族的な審美主義のはけ口であった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
