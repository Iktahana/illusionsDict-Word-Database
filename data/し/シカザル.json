    "definitions": [
      {
        "index": 1,
        "gloss": "earthenware toy portraying a monkey sitting on top of a deer (often a bell)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
