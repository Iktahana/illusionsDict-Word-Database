    "definitions": [
      {
        "index": 1,
        "gloss": "foreman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "紅は、なお気がかりらしく、今度は恐る恐る、上目遣いに職長の方を見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人の内川、職長の小山、大津、守田、会計の岩井、みな、コセ／＼した内地に愛想をつかして、覊絆のない奔放な土地にあこがれ、朝鮮、満洲へ足を踏み出した者ばかりだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長、一歩も、門から出さない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い、小さい子供の身体、皮と骨だけになって、脚かたかたになっていた……社員、職長笑う。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人も、職長も、古参の社員も、嫌悪した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、慌てゝ、自分が燐寸工場の職長であること、逃亡を企てた工人を捕まえに行ったこと、自分の工場にも兵タイを泊めてやっていることなどを説明した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高取は、職長を殴りつけて、工人への給料を全額、暴力で払わしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫番（工場の）のところまで何歩あるか、何秒かかるか、それだけをゆっくり歩くことを、なぜ職長はとがめるか、職長は労働者か、それとも何か、とそんなふうに愚の骨頂のようなことから、その他さまざまなことが、僕の頭を根限り追いまくった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の熟練には、職長も文句が出なかったんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "職場々々の「職長」さえもビラを持っていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年の職工や職長はワイシャツを着て、それにネクタイをしめた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ボール盤の側に、四五人の職工とパンパン帽をかぶった職長が集って、ワイヤー・プレーを跛に吊したグレーンがガラ／＼と寄ってくるのを見ていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り職工の職長が手を挙げた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長は手先きをお出で／＼をするように動かした。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "大テーブルを囲んで、狐の似顔にされた工場長以下職長、社員が、職工に「馬の糞」の金を握らしている。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長さえその仲間に首を差しこんできた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな関係を持っている職長などは顔色をなくして、周章てゝいた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、森本が工場の入り口で「タイム・レコーダー」を押していると、パンパン帽をかぶった仕上場の職長が、　――大変だぜ！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長は鶴見あたりの工場から流れて来た「渡り職工」だった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストライキになったら、専務より先きに、この職長をグレエンにぶら下げて、下から突き上げしてやるんだ、と仕上場では云っていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長は二人位しか工場に姿を見せていない。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長が両手を後にまわしながら、機械の間を歩いていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝことには、職長が二人位しかいないことだった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　職長たちが話しながら、ゾロ／＼事務所から帰ってきた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械についていた職長がそれを見ると、周章てゝ走って行った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕上場の見張りの硝子戸の中から、「グレエン」職長が周章てゝ飛び出してきた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれ以上職長にはどうにも出来なかった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長は目論見外れから工合悪そうに、肩を振って帰って行った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "職長がくるりと振りかえって、職場を見廻わした。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
