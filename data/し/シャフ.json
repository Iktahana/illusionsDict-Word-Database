[
  {
    "uuid": "fda0b2a2-7299-513a-8859-be9910df79f0",
    "entry": "写譜",
    "reading": {
      "primary": "しゃふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
