    "definitions": [
      {
        "index": 1,
        "gloss": "all night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春先とはいえ、寒い寒い霙まじりの風が広い武蔵野を荒れに荒れて終夜、真っ闇な溝口の町の上をほえ狂った。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁船のともす赤い火影が、終夜、江の島の岸を彷徨うた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父も弁公も昼間の激しい労働で熟睡したが文公は熱と咳とで終夜苦しめられ、明け方近くなってやっと寝入った。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の貫きて真直に通う路あり、車もようよう通い得るほどなれば左右の梢は梢と交わり、夏は木の葉をもるる日影鮮やかに落ちて人の肩にゆらぎ、冬は落ち葉深く積みて風吹く終夜物のささやく音す。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ――楼に入ると直ぐに楼の女から雲水僧の到着を聞かされたので、国太郎の全身は殆ど僧に対する一つの探求心になって、客たちを成るたけ早く部屋々々へ引き取らせ、自分は馴染の太夫の部屋に起きていて終夜、魯八を間者に使って雲水僧の消息を一々探り取らせた。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――其頃、風をなして行はれた試驗間際に徹夜の勉強、終夜と稱へて、氣の合つた同志が夜あかしに演習をする、なまけものの節季仕事と云ふのである。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア、これからは又々斷食、此日も空しく暮れて夜に入つたが、考へると此後吾等は如何になる事やら、絶望と躍氣とに終夜眠らず、翌朝になつて、曉の風はそよ／＼と吹いて、東の空は白んで來たが、最早起上る勇氣もない、『えい、無益だ／＼、糧食は盡き、※船は見えず、今更たよる島も無い。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や本島の主人公なる櫻木海軍大佐の健康は言ふ迄もなく、此頃では殆ど終日終夜を、秘密造船所の中で送つて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて當日は、二十｜里近く進んで日が暮れたので、夜は鐵車をば一大樹の下蔭に停めて、終夜篝火を焚き、二人宛交代に眠る積であつたが、怒り叫ぶ猛獸の聲に妨げられて、安らかな夢を結んだ者は一人も無かつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出雄少年も二名の水兵も默して一言なく、稻妻は終夜吠え通しに吠えたので餘程疲れたと見え、私の傍に横つて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ生命を、我に与えよ、と鼻頭を撫でて牛に言い含め、終夜芝を刈りためたを、その牛の背に山に積んで、石を合せて火を放つと、鞭を当てるまでもない。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は昨夜雨中を駈廻った上に、終夜殆ど安眠しなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "・朝から小鳥はとべどもなけども・かうしてこのまゝ死ぬることの、日がさしてきた・壁にかげぼうしの寒いわたくしとして・寒晴れ、誰もゐない火の燃えてゐる・晴れてうつくしい草の葉の霜・庵はこのまゝ萌えだした草にまかして　二月十二日春日和です、私は終日終夜、寝床の中です。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日終夜、寝床で読書、ひもじくなれば餅をたべて安らかに。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の林や木立は、冬の暴風雨の夜、終夜唸り通し悲鳴を擧げ通して其の死滅の影となツたのだ……雖然鬪は終ツた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし間違ツたら、終夜歩いてゐる事に覺悟を定てゐたが、たゞ定て見たゞけの事で、中々心から其樣な勇氣の出やう筈が無い。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざや終夜供養したてまつらむと、御墓より少し引きさがりたるところの平めなる石の上に端然と坐をしめて、いと静かにぞ誦しいだす。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蟹の話をいたしませう、月夜の蟹の痩せてゐるのは、砂濱にうつるおのが醜い月影におびえ、終夜ねむらず、よろばひ歩くからであります。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝、彼が母屋の中央の贅沢な呉蓙の上で醒を覚ます時は、身体は終夜の労働にぐったりと疲れ、節々がズキズキと痛むのである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は昨日、その四畳半を去つて、一家と共にこゝの中津川の水の音涼しくも終夜枕にひびく新居に移りぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小著の中に、其の雲が時雨れ／＼て、終日終夜降り續くこと二日三日、山陰に小さな青い月の影を見る曉方、ぱら／＼と初霰。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "終夜が波の響と風の音と、それに雑多の――それは帆檣に降る、船室の屋根の上甲板に降る、吊ボートに降る、下の甲板に降る、通風筒に吹きつける、欄干に降る、――雨の音であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は体から火の炎々と燃えている奇怪な男に、終夜追いかけられた夢を見ていたのであった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未熟な芸を御所望とならば、今宵は朝まで御覧に入れましょう」　八郎は其の夜終夜病人の前で幸若舞を舞うて見せた。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "タヌンガマノノの方から終夜、太鼓と喊声とが聞えた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大久保利通は、悒鬱の余り、終夜｜睡る事が出来なかったと云う。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の夜は終夜｜烈しい半市街戦が行われ、両軍とも死傷が多かったが、結局幕軍不利で淀まで退却した。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで大騒ぎになって家の者が皆起き、女の死骸を表座敷に移して、その頭を合わせるようにして置き、皆で泣きながら終夜ごたごたと騒いだ。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、陳はまだ心配でたまらないので終夜眠らないでさまよい歩いた。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれらを要約すれば、何か怪しいものが船の周囲を終夜飛びあるくというのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
