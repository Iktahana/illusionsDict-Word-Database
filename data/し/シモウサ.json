    "definitions": [
      {
        "index": 1,
        "gloss": "Shimōsa (former province located in parts of present-day Chiba, Ibaraki, Saitama and Tokyo prefectures)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "待ってましたと計りに関白の方では、此の大石を取れば碁は世話無しに勝になると、堂々たる大軍、徳川を海道より、真田を山道より先鋒として、前田、上杉、いずれも戦にかけては恐ろしく強い者等に武蔵、上野、上総、下総、安房の諸国の北条領の城々六十余りを一月の間に揉潰させて、小田原へ取り詰めた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度公の薨ぜられた其年に将門は下総に勇ましい産声をあげたのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に良持は下総介、従五位下、長田の祖である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄人は奈良朝に当つて、下総少目を勤めた人であつて、浄人以来下総の相馬に居たのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘は何にせよ将門が京より帰つて後数年にして発したので、其の場所は下総の結城郡と常陸の真壁郡の接壌地方であり、時は承平五年の二月である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門記に其の闘の時の記事中見ゆる地名は、野本、大串、取木等で、皆常陸の下妻附近であるが、野本は下総の野爪、大串は真壁の大越、取木は取不原の誤か、或は本木村といふのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵は進んで下総堺の小貝川の川曲に来た。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「負け碁は兎角あとをひく也」で、良正は独力の及ぶ可からざるを以て下総介良兼（或はいふ上総介）に助勢を頼んで将門に憂き目を見せようとした。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同六年六月二十六日、十二分に準備したる良兼は上総下総の兵を発して、上総の地で下総へ斗入してゐる武射郡の径路から下総の香取郡の神崎へ押出した。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで将門は明かな勝利を得て、府の日記へ、下総介が無道に押寄せて合戦しかけた事と、これを追退けてしまつたことをば明白に記録して置いて、悠然と自領へ引取つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年十二月二十九日の符が、今年九月になつて、左近衛番長の正六位上｜英保純行、英保氏立、宇自加｜支興等によつて齎らされ、下毛下総常陸等の諸国に朝命が示され、原告源護、被告将門、および国香の麾下の佗田真樹を召寄せらるゝ事になつた、そこで将門は其年十月十七日、急に上京して公庭に立つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、同年五月十一日に京を辞して下総に帰つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年八月六日に下総境の例の小貝川の渡に良兼の軍は来た。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "良兼、護、今は父の後を襲ふた常陸大掾貞盛、良兼の子の公雅、公連、それから秦清文、此等が皆職を帯びて、武蔵、安房、上総、下総、常陸、下野諸国の武士を駆催して将門を取つて押へようとする。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "良兼が死んでは、下総一国は全く将門の旗下になつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "興世王もこれには憤然とせざるを得なかつたが、根が負け嫌ひの、恐ろしいところの有る人とて、それなら汝も勝手にしろ、乃公も勝手にするといつた調子なのだらう、官も任地も有つたものでは無い、ぶらりと武蔵を出て下総へ遊びに来て、将門の許に「居てやるんだぞぐらゐな居候」になつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "維幾は怒つて下総の官員にも将門にも移牒して、玄明を捕へて引渡せと申送つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "維幾も後には業を煮やして、下総へ潜かに踏込んで、玄明と一合戦して取挫いで、叩き斫るか生捕るかしてやらうと息巻いた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門は、件の玄明下総に入つたる以上は下総に住せしめ、踏込んで追捕すること無きやうにありたいと申込んだ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "下総は延喜式で左馬寮御牧貢馬地として、信濃上野甲斐武蔵の下に在るやうに見えるが、兵部省諸国馬牛｜牧式を見ると、高津牧、大結牧、本島牧、長州牧など、沢山な牧があつて、兵部省へ貢馬したものである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古より東国には未だ曾て無い大動揺が火の如くに起つて、瞬く間に無位無官の相馬小次郎が下総常陸上野下野を席捲したのだから、感じ易い人の心が激動して、発狂状態になり、斯様なことを口走つたかとも思はれる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」然る間に前下総国介平良兼、数千の兵を起し、将門を襲ひ攻む。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門背走相防ぐ能はざるの間、良兼の為に人物を殺損奪掠せらるゝの由は、具さに下総国の解文に注し、官に言上しぬ、爰に朝家諸国に勢を合して良兼等を追捕す可きの官符を下され了んぬ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門の弟の将頼は下野守に、上野守に常羽御厩別当多治経明を、常陸守に藤原玄茂を、上総守に興世王を、安房守に文室好立を、相模守に平将文を、伊豆守に平将武を、下総守に平将為を、それ／″＼の受領が定められた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄明等大敗して、下野下総｜界より退いた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口村は水口村の誤で下総の岡田郡である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『少し風邪を引いて二日ばかり休みました』と自ら欺き人をごまかすことのできざる性分のくせに嘘をつけば、人々疑わず、それはそれはしかしもうさっぱりしたかねとみんなよりいたわられてかえってまごつき、『ありがとう、もうさっぱりとしました。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもうさんざん彼女を引っ張りまわした挙句だったし、私もかなり歩き疲れていたので、この上｜廻り道をする気にはなれずに、私は心ならずもその別荘の前を通り抜けて行くことにした。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕作はどこにいるんだ」「あ、昌仙さまでございますか」「そうだ、呂宋兵衛さまをお落としもうさにゃならぬ、うまい逃げ口が見つかったとは、どこだ」「ここです――ここです」「どこだ、そちはどこにいるんだ」「ここですよ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
