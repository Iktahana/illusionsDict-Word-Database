        "gloss": "wooden box for carrying books on one's back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "机と書笈と夜具と人力車へ載せて笠の破れた洋灯を君が手に持って書生の引越のように車の後から尾いて来ればそれで済むだろう。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの真景をも其座にうつしとりたるを添て贈りしに、玉山翁が返書に、北越の雪｜我が机上にふりかゝるがごとく目をおどろかし候、これらの図をなほ多くあつめ文を添させ私筆にて例の絵本となし候はゞ、其｜書雪の霏々たるがごとく諸国に降さん事｜我が筆下に在りといはれたる書翰、今猶｜牧之が書笈にをさめあり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
