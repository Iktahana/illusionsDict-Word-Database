    "definitions": [
      {
        "index": 1,
        "gloss": "divergent opinions abound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
