[
  {
    "uuid": "e7a40e41-f1f7-5e20-90d3-d3c31912c4a1",
    "entry": "称名",
    "reading": {
      "primary": "しょうみょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
