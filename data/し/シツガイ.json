    "definitions": [
      {
        "index": 1,
        "gloss": "outside (the room, building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
