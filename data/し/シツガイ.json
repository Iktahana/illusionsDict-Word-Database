        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかるにこれらの温度や気流等はまた室内のみならず室外全宇宙の現象の影響を受けぬ訳には行かぬ。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声が室外へ漏れんように小さく囁き合った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室外の廊下に出て見ると高木さんや中川さんの顔も見えた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎が這入って行くと、領事館からついてきた、帽子にエビ茶の鉢巻のついた若い巡査は、二人が、ちょっと顔を見合して室外に出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に出口の板戸を背にして、木像のごとく突立ちたるまま両手を衣兜にぬくめつつ、身動きもせで煙草をのみたるかの真黒なる人物は、靴音高く歩を転じて、渠等を室外に出しやりたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦は毎朝これらの花鉢を室外へ持ち出して水をやってくれた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室外には舷に碎くる浪の音、檣頭に走る風の聲、艦橋に響く士官の號令。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この景この時、室外に声あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と得三室外へ躍出づれば、ぱっと遁出す人影あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "得右衛門は得三の名を呼びて室外におびき出し、泰助は難無く室内に入りて潜むを得たり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に出口の板戸を背にして、木像の如く突立ちたるまま両手を衣兜にぬくめつつ、身動きもせで煙草をのみたる彼の真黒なる人物は、靴音高く歩を転じて、渠らを室外に出しやりたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとは知らず彼は古い世界の片すみの一室にただ一人閉じこもっていて、室外の世界も彼と同様に全く昔のままで動いているような気がしていたのである。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の関係しているある研究所の居室の室外にこの木の大木のこずえが見えるが、これが一様に黄葉して、それに晴天の強い日光が降り注ぐと、室内までが黄金色に輝き渡るくらいである。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇汞水の金盥と並べた、室外の壁の際の大きな器に、氷嚢から氷が溶けたのを、どくどくと開けていました。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔はおどろいて、さては他に姦夫があるのかと、憤怒に堪えぬままに起き出でて室外をさまよっている時、おぼろの月のひかりに照らされて、彼女は屋上から飛び降りて来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "室外に蓙を敷かせて坐る。",
              "citation": {
                "source": "月の東京灣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けが近づくと彼は室外へ出て、広い庭や野菜畑のあひだを逍遥した。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣がけでは室外へ出られないなんて、夏、浴衣がけで散歩も出来ないとなると、何時まで経つても外人本位だね。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしどもは少し用事ができておくれましたが、こんなにおそくまで室外にいらしってお寒くはありませんでしたか。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田川博士の船室には夜おそくまで灯がかがやいて、夫人の興ありげに高く笑う声が室外まで聞こえる事が珍しくなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今朝の寒さを言ふと、机の上で日記帳を見やりながら、「室内三度、室外零度でありましたからなア。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今朝の寒さを云うと、机の上の日記帳を見やりながら、「室内三度、室外零度でありましたからなア」　という発音の中に私は彼が東北生れの訛を持つことを知った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父が、面と向ってのお世辞に、苦り切っている有様が、室外にいる瑠璃子にもマザ／＼と感ぜられた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして完全にイワノウィッチを室外に放逐するための、最後の努力をしようとしていた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどダシコフが、イワノウィッチを室外に引きずり出した時、奇妙に押し潰されたような拳銃の音が響いたかと思うと、大きいダシコフの身体がよろよろと室内に転げ込んだまま、激しい音をさせながら、そこに、へたばってしまった。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は声が室外に漏れないように気を配って、私の耳のすぐそばへ口をもってきて読んでくれました。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "室外の廊下に思い余って、誰かが立ちすくむ様子らしい。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓にはシェードがおろしてあるし、鍵穴にもふたがしてあるので、光は全く室外には洩れない。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を直ぐに室外につまみだしたのも、単に喜助という少年を嫌ったのではなくて、実は自分が薬学についての専門家であることに恐怖を感じて、排斥したものに相違ない）　喜助は、大きな泣き声を、いつの間にか、やさしい泣き逆吃に代えて、こんな想像をめぐらしていたのであった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときまで壁を背にして傍観していた美しきミルキ夫人は、この様子に愕いて自分もともに室外へ飛びだそうとした。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
