    "definitions": [
      {
        "index": 1,
        "gloss": "conduct",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「いやいや、大して違ひはありますまい」と語尾を上げて、爺々ィが云つた、「音羽屋の方が所作はうまいかしれないが、ハリマ屋の方はスゴミがあるツ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのことはない、あやつり人形の所作でも見ているような心地がした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の何かしら廻り諄い所作の道具に使われて、命を失いかけている小雄鹿を、その男と共に、無駄なことの犠牲になった悲運のものと思うだけだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして興味を牽いて救われるのは、その男が唖者のように表現の途を得ないで、いろいろに感情の内爆や側爆のこういう所作をすることである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは何事か判らなかった店の者は余計なことをすると思って、少年の所作を途中で妨げたり、店先に立つ段になると叱って追い放ったりした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの町々でも少年の所作に変りはなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにメリサンドが長い髪を窓外のペレアスに投げかける所作には「いき」なところは少しもない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一枚の紙片に書いた覚え書によって講演し、実験をやって見せる時にはちょっと手品師のような所作をして聴衆を喜ばせたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この巫女の所作にもどこか我邦の巫女の神おろしのそれに似たところがありはしないかという気がするのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも愛の所作は消えないのではないが、それがため、あなた達は――胸から膝まで――すつかり黄金の甲冑で、かためられてしまふ。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからともよは湊がいつまでもよそばかり見ているときは土間の隅の湯沸しの前で、絽ざしの手をとめて、たとえば、作り咳をするとか耳に立つものの音をたてるかして、自分ながらしらずしらず湊の注意を自分に振り向ける所作をした。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫じゃ猫じゃでも踊りゃあしめえし、手拭をかぶって、浴衣を着て、跣足でそこらをうろうろしているところは、どうしても正気の人間の所作じゃありませんぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかよくはわからないが、とにかくこれは非常に艶めかしい所作であることは事実である。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ているうちに私はだんだん彼らの所作に惹き入れられていた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞で見るとソビエトの五か年計画の一つとしてハバロフスクに百三十キロの大放送局を建設し、イルクーツク以東に二十キロ以上の放送局を五十か所作るということである。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……台所で働く女中の身体のこなしまでも、しかもそれが練達洗練された三昧に入っている所作である限り……その心境がその仕事に対して純一無雑である限り……そこに能楽の型と同じ真実味の横溢した「人間美」が後光を放っているではないか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するに、吾々の日常生活に於ける所作や発声は、その目的が何であるに拘らず、真剣に鍛えられて来るに従って、「能」のソレに近づいて来る。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその中で、毅然として勝敗の外に立ちつつ、全局を支配して行く名将の心境（というものがあるとすれば）、それこそ正に舞曲を以て天命の所作と心得ている能楽師（そんな人がいるとすれば）の心境と一致するものではあるまいか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに気の弱い私ですから、よしんば危いことと気がつきましたところで、とてもあの場合、武とお幸を振りきって逃げて帰るというような思いきった所作は私にはできないのでございました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの馴れた敏捷な所作だった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後の脚三｜本でのそりと留まつて、筑波の山を朝霞に、むつくりと構へながら、一｜本の前脚で、あの額際から鼻の先をちよい／＼と、其の毎に口を箕のやうに開けて、ニタ／＼笑ひで、下の流を向いて、恁う、顏を洗ふ、と云ふ所作で居た。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）媛神　花の都の花の舞台、咲いて乱れた花の中に、花の白拍子を舞っている……巫女　座頭俳優が所作事で、道成寺とか、……申すのでござります。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭の顱じゃあないけれど、額の椀の蓋は所作｜真盛り。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これだけは工夫した女優の所作で、手には白金が匕首のごとく輝いて、凄艶比類なき風情であった。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、それから、いろいろ勿体つける所作があって、やがて大坊主が謡出した。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "杖は※状の自然木なるが、その曲りたる処に鼻を凭たせつ、手は後様に骨盤の辺に組み合せて、所作なき時は立ちながら憩いぬ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "純一はしょさいなさにこれに耳を傾けた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒も余り上等ではないね」「お客次第なのだよ」「そうかね」純一はしょさいなさに床の間の方を見廻して云った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとな、雷師匠といわれた手習のおしょさんの近所に国年という絵かきがいてな、絵を教えてくれて、これも大変可愛がった。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしょさん、とおきんちゃんは叔母さんのことを呼ぶ。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
