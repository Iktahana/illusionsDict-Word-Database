        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "調査のために、図書館の資料室で専門書を借りた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学の研究室には、学生が自由に使える資料室が併設されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、昔の雑誌が整理されている資料室で、懐かしい記事を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "羽振りのよい学生はさらに何本もスチール製の本棚を運び込み、まるで資料室のように本を並べはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は資料室と化した下宿部屋に、今度はさまざまな機械まで持ち込み、築四〇年の家の床は、重みに耐えかねて沈みはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「掲示板」「青空文庫・別館」「資料室」には、来館して常連になった人や側面から支援しようといった人たちが開設してきたコーナーもある。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所、資料室、喫煙室を兼ねている。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
