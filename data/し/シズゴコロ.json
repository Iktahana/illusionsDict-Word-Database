          "literary": [
            {
              "text": "少年二人カン※スを手にさげて静心なく歩みゆく。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年二人カン※スを手にさげて静心なく歩みゆく、濡れたる油絵具のにほひ新し。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、いのちの高丘に誰ぞ角吹かば、我も亦この世の埓をとびこえて、野ゆき、川ゆき、森をゆき、かの山越えて、海越えて、行かましものと、みちのくの谷の若人、いやさらに角吹き吹きて、静心なし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るき午後のものとなき静心なさ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "耀く虚空、風絶えて、炎のころも、纏ひたる地の熟睡の静心。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑定局という十畳ばかりの室には、織物が敷詰められてあり、額は二ツ、その一つには静心館と書してあり、書棚、黒棚、ちがい棚などが目苦いまでに並べたててあり、床の間には二幅対の絹地の画、その床を背にして、久佐賀某は机の前に大きな火鉢を引寄せ、しとねを敷いていて彼女を引見したのであった。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは三代集あたりのしづごゝろは通常静心と訳するけれど、これは少しどうかとおもふ。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（勿論三代集以後には静心の意に用ゐてゐるけれど）友則の……春がすみ立ちかくすらん山の桜をことならばさかずやはあらぬ桜花みるわれさへにしづこゝろなし　といふ歌を、遠鏡に、見テヰルコチマデガ気ガソハ／＼スルハイと解してあるけれど、さうではなくて、「ことならば」がわが身へもひゞいてゐて、桜が散る。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二品卿の弟、民部卿範光という人は、後鳥羽院の寵臣であったが、つとに法然に帰依し、承元元年三月十五日五十四の時出家を遂げて静心と号した。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気危急の時に後鳥羽院が忍んで御幸があったそうであるが、その時静心は夢に法然上人を見て往生の疑なきことを申上げたということである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぼろしおぼろに映るものゝかげ、うれしと見れば悲しげに、只だかきくるゝ静心。",
              "citation": {
                "source": "小曲二十篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――第一は静心の工夫を積めと云う注意だ。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、こうして静心でいる次第です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "1847年春にゼンメルワイスは「産院の出来事によって大きく動揺させられた平静心をこの市の美術の至宝によって快復させることを希望して」ヴェネツィアに行った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉を囲んで、初秋の夜の静心をたのしみ、「――時に、いつか訊こう訊こうと思っていたが、ご舎弟の四郎｜高綱どのは、近ごろ、どうしているな？",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
