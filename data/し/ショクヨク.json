    "definitions": [
      {
        "index": 1,
        "gloss": "appetite (for food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
