    },
    "definitions": [
      {
        "index": 1,
        "gloss": "redecoration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
