[
  {
    "uuid": "9ccc5aa8-98b1-5cf9-87b4-f0c2bdb29401",
    "entry": "斜視",
    "reading": {
      "primary": "しゃし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
