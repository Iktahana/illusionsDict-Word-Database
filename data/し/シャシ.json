    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strabismus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ふんとにさ」と、おすめは小さな斜視の眼を、ちょいと見当違いの方へ光らして薄笑いをした。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心の切り方が悪いからよ」と婆やはたしなめる様に云うと、おすめは其には答え無いで突立ったまま、何処を睨むか見当の付かない様な斜視の眼を据えて、「婆やさんの長湯にも呆れるなあ、やあ垢擦りだ、やあ糠だのって」と云って口を尖らした。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは婆やが蔭でおすめの斜視を真似る時、いつも使う眼付きであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "特徴のある武田さんの笑い声を耳の奥で聴いていた、少し斜視がかったぎょろりとした武田さんの眼を、胸に泛べていた。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し斜視がかって、腋臭がある。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて氏は眼を斜視にして藤棚の一方を見詰めて居たが突然立ち上り手を延ばして藤の葉を二三枚むしり取り、元の処へ坐った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し斜視がかった眼はぎょろりとして、すれちがう人をちらと見る視線は鋭い。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は長大で、鼻が西洋人みたように鷲型で、白い眉が房々として、高い小鼻の左右に眼窩が深く落凹んで、心持ち内斜視の老眼が鋭く光っていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか隙の多さうな醜い女ぢやないかと、少し斜視掛つたその女の眼を見てゐたが、しかし女中の方は外ツ歯で鼻の頭がまるく、おまけに色が黒かつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "注に『説文』曰く、〈睨は斜視なり、劉長曰く、邪睨邪視なり〉、同上、麗服｜藐流眄、一顧｜傾城とある＊を、山岡明阿の『類聚名物考』一七六に引いて、邪視をナガシメと訓じあるを見あてた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの斜視や乱視や色盲のような見方をして、錯覚や幻覚を起こしている連中は、いずれも皆「顛倒の衆生」であります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜視睨み３・８　米国の副統領マアシヤル氏が先日議会の入り口で写真師二人に呼びとめられた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君達はむかし／＼斜視睨みの男が牛を殺さうとした話を聞かなかつたかい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斜視睨みの男は自分の助手に言つたさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『旦那、お前さんが睨んでる方へ牛の頭を持つてくんですかい』と助手が訊くと、斜視睨みの男は、『さうだよ、解つてらあね』と怒鳴りつけた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "真直に見て歩く女には、斜視と鼻の低いのとがあるものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜視と萎縮の裏にではあるが、とにもかくにも、文化哲学を目指しているというのである。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者ヘルマン・シリングはウェストフェリアの生れで年齡二十五歳、身長五呎八吋均衡の取れた體格、紅顏で濃き顎髯あり斜視である。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐辛しでも乳房へなすりつけて置いてやれ」「敏ちやん、もうお止しなさんせ、おしまひにしないと父ちやんに叱られる」　子供はちよいと乳房をはなし、ぢろりと敵意のこもつた斜視を向けて圭一郎を見たが、妻と顏見合せてにつたり笑ひ合ふと又乳房に吸ひついた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からそこへ祠の背後の窟から三人の女學生が出て、火が消えたわ、點けて頂戴よ、と言ふと、白子は薄氣味惡くニタリと笑つて、運が惡いですぞ、と言つてへんな斜視を使つて女學生をからかつた。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十近い年配で、黒のインバネスを着てゐた、目をシヨボシヨボ斜視のやうにつかふ癖のある、童顏の大きな男であつた。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は氣うとさうな斜視の眼で何處を見るともなく見つめて、依然頬には人の好ささうな微笑を漂はせてゐた。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一種の斜視に見える。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜視には斜視としての美しさがある。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや斜視そのものは美しいものだ。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その女――島子なのであるが――その島子の人工的斜視は、妖精的に美しい。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわずって片方少し斜視の眼が、キリストを見上げるマリアのような眼付になる。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は左の眼のうわずった斜視めいた眼付かも知れない。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の、斜視めいてうわずった左の眼付が、僕の眼を擽ぐる。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何もやらかしゃしねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
