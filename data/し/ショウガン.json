        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰も食する者なかりしが、金澤の人の行きて、此れは結構と豆府の汁にしてつる／＼と賞玩してより、同地にても盛に取り用ふるやうになりて、それまで名の無かりしを金澤茸と稱する由。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に赤城山、左に榛名山、自然の關門を成して、利根の本流中を貫くといふ天下無比の壯觀も、馬車の中にては十分に賞玩するに由なし。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、うなぎは名人にとって恋人にもまさるほどの、賞美賞玩おかざる大の好物。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ賞玩せぬが、ゆうべはけっこうな菓子折、散財かけて済まなかった。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄飢饉の記事は新聞に目立っているのであるが、その飢饉によって巨利を占める人々が、茶席に坐って、鉄を生まぬ日本の風土が発生させた「さび」を賞玩するのを、愛する日本の伝統は、今日の風雅と称するのである。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の構造装飾より茶器の選択に至るまで方式にかかはらず時の宜しきに従ふを賞玩すべき事なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり浮世絵画家の筆は錦絵の上で賞玩すべきものだと私は思います。",
              "citation": {
                "source": "浮世絵画家の肉筆",
                "author": "――花は霞を透してひとしおの風情があるもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "元人の骨法を得たりとて、風流好古の士、こゝに來りて賞玩するもの多かりしことは、江戸名所圖會にも見えたり。",
              "citation": {
                "source": "狹山紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "また御客に器物を賞玩してもらう上からいつても疵があれば夫れだけ御客に不安な餘計な心づかひをさせる、一寸でも危な氣のある思ひをさせるといふことは相濟まぬ次第である。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他南洋土人の原始的作品や名もない処の画家の稚拙が賞玩され、素人画が賞味され、技法の上に取り入れられたりした事も当然の事であろう。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな高い風景は、ビルディングの外、賞玩に価しない。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "地中海の岸も甚だ好風景に富んで居りますから少しく其れを御賞玩にお出に成りませんか。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶も嗜んで、みづから茶器などをつくつたが、いまもそれは「曼生壺」と稱されて、賞玩されてゐるさうだ。",
              "citation": {
                "source": "我思古人",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢島はタカ子がひらいてくれた女の世界を賞玩した。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠に入れた鮎が腐る恐れがあるとすれば、鮎を出して二枚に割き薄く塩して、河原の石にはり付け日光に晒して干物とすれば珍味として賞玩するに足りる。",
              "citation": {
                "source": "香気の尊さ",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "サツマイモはもう、日本の本来の国産でもあるかの如く流行して来ました、それと同じように、海の魚でも……海といわず、川でも、湖でも同じですが、甲に無かったものを、乙に移すこともできるし、異種類と異種類とを組み合わせて、変った風味の魚肉を賞玩することもできましょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新芽がちょうど蓮の巻葉のように細く巻かれた、ようよう長さ五分くらいのものを賞玩するのである。",
              "citation": {
                "source": "洛北深泥池の蓴菜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒だらなんぞ食う場合に、食通は必ず脇腹の薄身を賞玩する。",
              "citation": {
                "source": "西園寺公の食道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを日本がお相伴して、今に至るもお茶人たちはよろこびあい、賞玩している。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また竹田にいたしましても、やはり、あの時代の人の作として非常に賞玩されたのは、一に優美性、風流性が豊饒であったがためでありまして、竹田の画も、書もやかましくいわれたのは無理もないことだと思います。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この書道会の人が一体どれ位美的趣味があるかというと、おそらくは漢詩を作るとか、簡単に素人もちょっと書けるというようなやさしい事を目標にした、いわば幼稚な程度で出来る絵を賞玩するという程度に止っているふうがあります。",
              "citation": {
                "source": "書道と茶道",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを審美生活といってもよいし、古美術賞玩の生活と称してもよい。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術の美の具わりが薄弱なものは、賞玩価値また薄弱であるのが古来からの事実である。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが証拠に儒者の書、能筆にしてその名の史上に高きに拘らず、賞玩程度すこぶる低くして市価の廉なるは、けだし美術の美の含有量薄弱なる所以であって、単に史上の名声を購うに過ぎないからである。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、幼稚であなたより鑑賞眼の低い、つまらん賞玩家におだてあげられて、いい気持になってはだめですよ。",
              "citation": {
                "source": "河井寛次郎氏の個展を観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその花に対する彼女等の賞玩態度も推して明らかである。",
              "citation": {
                "source": "伝不習乎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "之がため鑑賞玩味の興に我を忘るる機会がない。",
              "citation": {
                "source": "百花園",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、いかに古代の支那人だとて、今の未開野蛮の民族だとて、まさかに人間を常食とし、もしくは鹿肉猪肉などと同じく、珍味嘉肴としてこれを賞玩したとは思われぬ。",
              "citation": {
                "source": "人身御供と人柱",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おくがたが清洲にいらっしゃいましたあいだは、小谷のおしろのおちましたのが天しょうがんねんの秋のこと、それよりのぶなが公御逝去のとしの秋ごろまでゞござりますから、あしかけ十年、ざっとまる九ねんの月日になります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
