        "examples": {
          "standard": [
            {
              "text": "プロジェクトの進捗状況をチームで共有する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "開発の進捗状況は毎週会議で報告される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お客様に進捗状況を細かくお伝えした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "並行して着手した基本設計と仕様検討の進捗状況を睨んでいた古山は、困難を充分予測していたはずの互換ベーシック開発に要する作業量を見誤っていたことに、早くもこの時点で気付かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "発表時点で六〇本、出荷開始時には一〇〇本を加え、つごう一六〇本のアプリケーションをそろえるという目標の達成のために、この年の秋、早水はサードパーティー各社を繰り返し訪ねては作業の進捗状況を確認していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその進捗状況の詳細を述べようとはしなかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、進捗状況は？",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
