    "definitions": [
      {
        "index": 1,
        "gloss": "dance in which the dancer quickly changes his clothes seven times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
