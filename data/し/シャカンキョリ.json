          "standard": [
            {
              "text": "雨の日はブレーキが効きにくいため、いつもより車間距離を長くとる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "車間距離を詰めすぎると、あおり運転と見なされる恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "適正な車間距離を保つことは、追突事故を防ぐための基本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『もしこれが読めるなら、車間距離のつめすぎだよ』という、この島に昔からある文句が、そのスティッカーには印刷してあった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
