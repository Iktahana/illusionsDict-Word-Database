        "examples": {
          "standard": [
            {
              "text": "醤油の汚れがどうしても落ちないので、クリーニング店に染み抜きを依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自宅で染み抜きをする際は、裏側から叩き出すようにするのがコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロの染み抜き技術にかかれば、諦めていた古い黄ばみも見事に消え去る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "まけおしみぬきで、事実を事実として見るならば、民主的文学運動におけるこの地点には、思いのほかの地すべりがある。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苦しみぬき、もまれぬいてから、人生にはどんなにしても手のとゞかぬ不幸があり、どんなにもがいても、ぬけきれない苦しみがあることや、それに対する諦めや、そしてまたそのために人をうらみ、世をうらむ心を失ってしまったことに気がついた。",
              "citation": {
                "source": "『静かなる愛』と『諸国の天女』",
                "author": "――竹内てるよ氏と永瀬清子氏の詩集――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
