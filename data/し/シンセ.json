      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "synthesizer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三つの音が協和して一つの和弦を構成するということは、三つの音がそれぞれ互いに著しく異なる特徴をもっている、それをいっしょに相戦わせることによってそこに協和音のシンセシスが生ずる。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナタハ　コレカラ　ドチラヘ　イクノデスカ」ト　シンセツナ　トシヨリハ　ワカイ　ヲトコニ　タヅネマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジッドは『狭き門』を読んだ切りで、純情な青年の恋物語であり、シンセリティの尊さを感じたくらいで、……とにかく、浅学｜菲才の僕であります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、音楽科の知り合いがいじっていたシンセサイザーには、好奇心の針が触れました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただシンセサイザーなら、シーケンサーと呼ばれる装置に演奏の手順を入力し、機械に弾かせることが可能です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局補償金は、ヤマハのシンセサイザーとコルグのシーケンサーに化けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "筺体も付いていない、基板むき出しのアップル※の互換機やＰＣ―９８０１、シンセサイザーなどでうまった下宿に、さっそく上がり込んできた元気のいいオヤジは、人なつっこそうな笑顔をはさみながら話し始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『トウケウミナブ　ジ　アンシンセヨイマヨコハマニユク』　發局は同じく靜岡だ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一にそれは作品に作者のシンセリチイがあらはれてゐることである。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者大衆は知的には鈍感であつても、作者のシンセリチイの有無を見わける力は非常に正確である。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、シンセリチイといふことは best sellers の最高の資格である。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野探偵が給仕に渡した紙片には「オオヤクンハムザイ、キヨウジユウニホウメンサルアンシンセヨ」と書いてあった。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも保子さんが私に持っていらっしゃるプレジュディスはかなり根深いものであるかも知れませんけれども、この私のシンセリティとそれとがどちらが力強いものであるかを見たい気も致します。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい非戦論を唱えてもその態度にシンセリチーがあって、やはり人格主義の空気の中にあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあったとすれば、それは世ずれのせぬ純情さ、玉のように傷つかないシンセリチイ以外には考えられない。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、保子さんが私に持つてゐらつしやるプレジユデイスは可なり根深いものであるかも知れませんけれども、この私のシンセリテイとそれとが、どちらが力強いものであるかを見たい気も致します。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、稀也さんを見送るべく熊本駅まで出かけたが、どうしても見出せなかつた、新聞を読んで帰つてくると、間もなく馬酔木さんが来訪、続いて元寛さんも来訪、うどんを食べて、同道して出かける、やうやくにして鑪板を買つて貰つた（今夜もまた元寛君のホントウのシンセツに触れた）。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "此宿はよい、ホントウのシンセツがある、私は自炊をはじめた、それも不即不離の生活の一断面だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はシンセサイザーの奏者なのだが、手だけで弾いていたのでは一度に録音できるチャンネル数が限られる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作曲家の冨田勲はムーグ※という大規模なシンセサイザーを購入し、これを使って作ったムソルグスキーの「展覧会の絵」のレコードで、話題を集めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーグ社のシンセサイザーにはとても手は出せなかったが、自作のマイクロコンピューターシステムにシンセサイザーの回路を組み合わせれば、電子音楽に挑戦できるはずだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの連載がきっかけとなって、マイコンを作り始めた人は多いと思うが、その中でも『マイコンでシンセサイザーを動かそう』というユニークな目的を持ってＭ６８００のシステムを組み上げ、活動中のクラブがある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにローランド社のどでかいシンセサイザーまで鎮座ましましている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアやＩＭＳＡＩの紹介とこれらにつなぐ入出力機器やシンセサイザーの解説記事を用意し、西は自分の名前では「ＴＶゲーム徹底調査」と題した連載記事を持った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『Ｉ／Ｏ』の創刊号は、手作りシステムをあくまでコンピューターとして使うための記事を前面に据え、ゲームやシンセサイザーの記事を脇に配する構成をとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターにテキストを読ませるスピーチシンセサイザーや、キーを押すたびに声で操作が確認できる盲人用の電卓といった製品には、マイクロコンピューターの巻き起こした変革の波が健常者のみならず障碍者まで巻き込んでいることを印象づけられ、強い感銘を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからシンセサイザーを動かすなり、鉄道模型をコントロールするなり、あるいは計算の用途に使うなり、何らかの自分なりの明確な目的を持って、さまざまな機器と手作りのシステムを組み合わせて使おうとする第二世代が生まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
