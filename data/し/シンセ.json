[
  {
    "uuid": "630ef3e1-ba9b-5db7-86b5-01f7ffcc0b8c",
    "entry": "シンセ",
    "reading": {
      "primary": "シンセ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
