        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一体いつでも小雨が降っておりますような、この上もない陰気な所で、お城の真北に当りますそうな。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真北の海に向って山の中腹にあるんだから、長い板廊下を九十九折とった形に通るんだ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（真北じゃな、ああ、）　とびくりと頷いて、（火の車で行かさるか。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私に貸さい、の、あのや、燃え搦まった車で、逢魔ヶ時に、真北へさして、くるくる舞いして行かさるは、少い身に可うないがいや、の、殿、……私に貸さい。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方ゆ流れ来ぬるや、黒星よ、真北の空に飛ぶを見ぬ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "有りとある磁石の針は子午線の真北を射せり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅ヶ崎の信玄の館が、真北にあたって聳えていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上からは真北に出た尾根を下り、一二〇〇メートルくらいから右の谷へ入ったが、この谷はあまりよくなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを真北へ進んで行った。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦雲暗し太平洋　わが海軍の主力、聯合艦隊は、小笠原諸島の東方、約一千キロの海上を、真北に向って進撃中であった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べた絶崖の間から、たれ下る大小の氷河の、最も盛んなのは、モン・ブロンの頂上から真北に落ちる二条の、近いボッソンとタコンナの氷河であった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルニナ群山の中心にあたるベルラヴィスタ Bellavista のアレトから、真北に四里にわたって流れ落ちるこの氷河の空には、四千米突に近い山々が、折り重なり入り乱れて、最高峰のピッツ・ベルニナ Piz Bernina, 4052m. も、やや右よりに仰がれる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪ロケット機の姿を、ついに真北の方角に見失いました」　　　　　５　それっきり、怪塔ロケットの行方はしれなくなってしまいました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ、ここが九十九里浜で、この上を、真北から五度ばかり東にかたむいた方向に直線をひいてみます」　といって、兵曹長は地図の上に赤鉛筆ですうっと線をかいた。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、真北の空、地上から約五千メートルと思われる高空に、空の怪物大空魔艦がうかび、しずしずこっちへ近づいてくる。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "命令一下、高射砲は一斉にグルリと旋回して砲口を真北にむきかえた。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の村からは、真北よりも東に位置して、前橋の街を裾の間へ掻い込まんばかりにして聳えている。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの山は、わが村から真北に当たって、赤城の裾と榛名の裾が、相触れようとする広い中空を占めている。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "真北よりも、少し西に位置して、群馬郡南部の平野を悉く、おのれの衣裳のうちに包んでいる。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん激しいあらしは、ベルリーヴ岬とコペー村のあいだの湖の一部を掠めて、町の真北を襲っていた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにてもはるか下界の往来では、三々五々と家路に急ぐ小学生の木底の靴音、さては、「第三版・硬党新報、夕刊巴里」と触れ歩く夕刊売りの声も寒く遽ただしく、かてて加えて真北に変った強風は、今や大束な霙さえ交えてにわかに吹きつのる様子。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "真北に向って少し下ると右手に深い古礼沢が覗かれる。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上から真北にすぐ栂の深森を下ると、道は山稜の北側を搦んで、急な空渓の上端を幾つか横切りつつ、魚の小骨のような尾根を越えて、余り激しい登降もなく、北へ北へと三人を引張って行く。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真北のほうからうねりの長い激浪が、白い波頭を揃えて息をつくひまもないほどつぎつぎに押しよせ、筏を木の葉のように翻弄した。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな安楽世界に住みながら、やはり日本が恋しくなったのか」　清兵衛は慇懃にうなずくと、真北のほうを指して、「ちょうど霧隠れになっておりますが、あれは恐山といって、北郡のしるしになる山でございます。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地はちょうど私が前に一年ばかり住んで居ったヒマラヤ山のロー州のツァーランという所から二十五里真北に隔って居る所である。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極星は、真北にあるのだから、北極星を見て、方向をたしかめることができるけれども。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度その北の雪国を思わせる風が真北に変わって山の低みから吹き下ろして来たならば、この鎌倉の春は瞬く間に後もどりして、たちまちまた昨日の冬に逆転しそうな心細さがあるのでありましたが、ただこの溝の中にはそこに確実な春がありました。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信州と越中との国境は、南は標高二八四一米のレンゲ岳（三ツ叉）に始まり、うねうねと屈曲していはするものの、大体において真北を指し、野口五郎、烏帽子、蓮華、針ノ木、爺、鹿島槍、五龍、唐松等を経て北、三千米に近い白馬岳に至る約二十里の山脈の上を走っている。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
