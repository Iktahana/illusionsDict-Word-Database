    "definitions": [
      {
        "index": 1,
        "gloss": "white silk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白絹襟巻の紳士は、涸裂れた唇に熱い珈琲のコップを思い切って押しつけた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しかつた額にはその花の冠をさせられながら……　白絹の衣をまとつた、若うどの一人は、自分は決して目を覺ますことは出來ないと氣がついた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は白絹の小袖を着て、おなじく白い切袴をはいていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の形から見て、それは一匹の白絹であるらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、たしかに、盗人の三分の理にも似ているが、しかし、私の胸の奥の白絹に、何やらこまかい文字が一ぱいに書かれている。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、十匹の蟻が、墨汁の海から這い上って、そうして白絹の上をかさかさと小さい音をたてて歩き廻り、何やらこまかく、ほそく、墨の足跡をえがき印し散らしたみたいな、そんな工合いの、幽かな、くすぐったい文字。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの不潔な虱と、私の胸の奥の白絹に書かれてある蟻の足跡のような文字とは、本質に於いて全く異るものであるという事には、私も確信を持っているつもりであるが、しかし、その説明は出来ない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（白絹帳中皓體畢呈。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十一回　空中の救ひ何者にか愕いた樣子――誰かの半身が現はれて――八日前の晩――三百反の白絹――お祝の拳骨――稻妻と少年と武村兵曹　指を屈して見ると、當日は吾等が海岸の家を去つてから、丁度九日目で、兼て海底戰鬪艇の試運轉式の日と定められたる紀元節の前日である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯巻　｜奉仕御湯殿之人所着衣也白絹也と侍中群要に見えたりとか。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝の姿は見えねど、滝壺の裾の流れの一筋として白絹の帯上げの結び目は、水沫の如く奔騰して、そのみなかみの※々の音を忍ばせ、そこに大小三つほどの水玉模様が撥ねて、物憎さを感ぜしむるほど気の利いた図案である。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな古風な家が今でも巴里に残っているかと思えるようなラテン街の教授の家へ新吉は土産物の白絹一匹を抱えてはじめて行って見た。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白絹の鉢巻は勇しくって、立派な親分さんみたいに見えるわよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へ出たとき、何か白絹でも、こっそり買って来てやろうと思っていたのだ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ第一等の女工さんでごく上等のものばかり、はんけちと云って、薄色もありましょうが、おもに白絹へ、蝶花を綺麗に刺繍をするんですが、いい品は、国産の誉れの一つで、内地より、外国へ高級品で出たんですって。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二人のきれいな少女がおそろいの白絹の服で、手に手に金のチューリップをささげてもち、まっ黒な馬にのって、両わきにしたがいました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖かい夢を柔らかなふわふわした白絹につつんだように何ともいえない心地がするかと思うと、すぐあとから罪深い恐ろしい、いやでたまらない苦悶が起こってくる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛ぶ神の白絹の御衣のお裾に触れて散るのである。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋羽二重の肉色鹿子を掛けたる大円髷より水は滴るばかりに、玉の如き喉を白絹のハンカチイフに巻きて、風邪気などにや、連に打咳きつつ、宮は奥より出迎に見えぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララは床から下り立つと昨日｜堂母に着て行ったベネチヤの白絹を着ようとした。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りらしく、その顔は、白絹か何かのように艶々しく輝いていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな硝子箱の中に古代｜裂の上に据えた七宝と、白絹の布片の上に置かれた鶏とはちょうど格好な対照であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "聖上行幸当日のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "身には袖の広い裾の長い白絹の着物を着て、上に黒狐の皮の外套を重ね、頭に碼瑙の冠を戴いて、手に黄薔薇の籠を持ちました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールバックに濃化粧、漆のような引き眉に毒々しい頬紅口紅をつけ、青地か紫色の綿紗に黒手袋、白絹模様入りの靴下に白鞣の靴の踵を思い切り高くして、虹のようなショールを波打たせながら八方に眼を配って行く……といったような女学生をいきなり不良とは断定できぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、彼の女の体は薄い白絹に包まれ、彼の女の手首には、恐らく象牙製と思われる腕輪が三つも重なっていて、それらは彼の女が耳なぞを掻くため、腕を持ち上げる度に、快い音響を発しつゝ、打ち合った。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今以絳地交龍錦五匹、注略絳地十張、五張、白絹五十匹、金八兩、五尺刀二口、銅鏡百枚、眞珠鉛丹各五十斤。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りらしく、その顔は、白絹か何かのやうに艶々しく輝いてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺のなかには白絹で叮嚀に巻かれた屍体が横はつてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "関野氏は水蜜桃の皮を剥くやうな気持で少しづつ白絹をめくつて往くと、なかから顔を出したのは、妙齢の娘で、目鼻立ち何処に一つ点の打ちやうもない大理石像のやうな美人であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
