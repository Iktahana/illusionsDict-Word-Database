  {
    "uuid": "c247d470-44ea-50c0-8709-00381bb2e7cd",
    "entry": "習俗",
    "reading": {
      "primary": "しゅうぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
