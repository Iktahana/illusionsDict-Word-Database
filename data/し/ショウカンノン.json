    "definitions": [
      {
        "index": 1,
        "gloss": "Aryavalokitesvara (manifestation of Avalokitesvara)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薬師三尊の背後は、六尺程の板敷になっていて、その奥の壇上には、聖観音の像と左右に四天王が二体宛載っている。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨川君は、薬師仏の背後の壇上にある聖観音の首に、鏡を稍下向きに掛けて置き、薬師三尊の中の月光像の背後で、線香花火を燃やしたのだ。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同寺東院堂の銅造聖観音立像もこれに劣らぬ美の最もいさぎよきものである。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし考えてみると、三月堂の不空羂索観音、聖林寺の十一面観音、薬師寺東院堂の聖観音、中宮寺観音、夢殿観音など、推古天平の最も偉大な作品は、同じくみな観音である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六薬師寺、講堂薬師三尊――金堂薬師如来――金堂脇侍――薬師製作年代、天武帝――天武時代飛鳥の文化――薬師の作者――薬師寺東塔――東院堂聖観音　日暮れ近くについた薬師寺には、東洋美術の最高峰が控えている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東院堂の聖観音がそれである。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光の反射で聖観音はほのかな赤味を全身にみなぎらした。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはこの偶然に驚きながら息をつめて聖観音を見まもった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七奈良京の現状、聖観音の作者――玄弉三蔵――グプタ朝の芸術、西域人の共働――聖観音の作者――薬師寺について――神を人の姿に――Ｓ氏の話　薬師寺の裏門から六条村へ出て、それからまっすぐに東へ、佐保川の流域である泥田の原のなかの道を、俥にゆられながら帰る。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあの偉大な聖観音の作者が誰であるかを空想して楽しんでいたのである。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖観音を作った偉大な天才は、恐らく玄弉三蔵と関係のあるものであろう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わたくしの空想した聖観音の作者は、この種の西域人である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の製作がどれほどあったかはわからないが、とにかく我々の前には聖観音が残っている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彫刻では、夢殿の秘仏が見られなかったのは止むを得ないとして、薬師寺東院堂の聖観音が、名前さえ挙げてないのはどうしたものでしょう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんあの金堂の薬師如来から大した芸術的印象を受けなかったというその日の気分では、聖観音にもあまり圧倒せられなかったかも知れません。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寂しい抒情的な気分には、聖観音の古典的な力は、あまりに縁が遠過ぎたかもしれません。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこの聖観音と薬師如来とのためにも、君の再遊を望まずにはいられません。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聖観音には、流動体にもなり得る銅の性質を、まだ十分活かし切らない点があります。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし聖観音には、昇り切ろうとする力の極度の緊活があります。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく二つの異なった立場を認容するとき、わが聖観音は、その下半身の手法の硬さにかかわらず、たちまち世界的に意義の深い、高い地位を要求してくるのです。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖観音はこの傾向の、かなり絶頂に近いところにあるのです。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「法隆寺の壁画と薬師寺の三尊及び聖観音との間に密接な関係がありはしないか、という説は、非常に傾聴に価すると思います。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また時代の推移を考えれば、薬師寺の聖観音が天平時代に至って聖林寺の十一面観音となったように、絵画においても法隆寺の壁画は聖林寺の観音に比肩し得るほどの後継者を持たなくてはならぬ。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画が薬師寺聖観音と相応ずるものであることは何人も否まないであろう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は薬師寺｜聖観音、法隆寺壁画などにおけるごとく、直観の喜びの表現を著しい合理化の傾向と結合して遂行せるものである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師寺聖観音や法隆寺壁画のごとき作品が唐の遺品中に存せざるゆえをもって、この種の様式が西域より唐を素通りして日本に渡来したと説く学者もある。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師寺の聖観音や法隆寺の壁画は、西域文化の渡来を語るとともに、また統一と創造とに緊張した国民の心の、力強い律動と大きい感情のうねりとを現わしている。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師寺聖観音、法隆寺壁画のごとく、西域伝来の様式を示す以外にほとんど日本人の痕跡の認められないとせられている傑作にも、自分は当時の叙情詩の示すと同じき気品や緊張や感情のうねりを感じ得ると思う。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠑螺堂の窓から射し込んでいた、折からの春の夕陽が、聖観音菩薩の頬を、ほんのりと温めていたのかも知れません。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
