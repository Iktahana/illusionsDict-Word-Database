[
  {
    "uuid": "51849c38-d43c-5779-9c90-2e8b66ca327e",
    "entry": "進呈",
    "reading": {
      "primary": "しんてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "presentation (e.g. of a gift)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花を切つて高崎へでも賣りに出すのかと聞くと、唯々お客さんに自由に進呈するためだといふ。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや皆まで申されるな」　「では」となりひらが、Ｔ「この連判状は貴殿に進呈致すその代り」　と言って、Ｔ「但馬屋源兵衛を早速放免して戴きたい」　「よろしゅう御座る」と左衛門、　「では」となりひら連判状を其処へ置く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は彼と別れにのぞんで、ミケルド・モンテニュの「社会の計画の中庸を持し、運命的施設を待つ」の一句を彼に進呈した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ達のネタを一週間以内にもってくれば手附の十倍の報酬を進呈するわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度持合せていたＭＣＣかなんかを進呈してマッチをかしてやったら、「や、こりゃあ有難う有難う」と何遍もふり返っては繰返しながら行過ぎた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、よくよくの事情に敬意を表して、僕はその百円をあんたに進呈しようといっているわけだ」七「あなたも随分空想家ね」　と、弓子は笑いながら、「――よくよくの事情……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くどいようだが、この百円はあんたに進呈する」「あらッ、だめよ」　と、弓子もすかさず、「くどいようだが、この百円はお返しします」　そして、おたがい顔を見合って笑いだしたが、鶴雄は笑いやむと、「悲願っておっしゃったでしょう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、木屋町の小野屋旅館まで弓子を尾行して、弓子に面会を求め、弓子が掏摸になった原因や、弓子の姉の千枝子の話をきいて、弓子に百円を進呈したこと。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞屋さんが新聞を持つてきて、今月分だけは進呈しますといふ、タダより安いものはない、よからう。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあなたが、ほんたうに貧乏でお金がないのなら、薬は無料で進呈してもよろしい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨一羽、そのうち、とったら進呈するがね、しかし、それには条件がある。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無代進呈します、さあ、みんな持っていってくれ、信じない奴は、ばかだ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無代進呈いたします。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、百円分の薬を無代進呈する。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果集まった金が六千円、うち装飾品の実費一軒あたり七十円に無代進呈の薬の実費が十円すなわち三十軒分で二千四百円をひいたざっと四千円が、丹造の懐ろに流れ込んだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな進呈しても好いんだよ。",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）に進呈した古本「ハムレツト」の扉に“189……?”だつたか“19??”…… “Christmas ――　H, makino”と誌してあつたことを思ひ出しました。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は稍まとまつた小説を書き終ると、とても、有頂天になり、変に夢中になつて、飲めや歌への大騒ぎを演じて、手あたり次第にその辺のものを客達に進呈せずには居られなくなるのでした。",
              "citation": {
                "source": "西部劇通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "挿絵が気に入つたと云つていつまでも龍吉君はそれを手から離さぬので進呈する。",
              "citation": {
                "source": "五月六日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ町に小説家の宇野氏が病養を続けてゐた頃、不図彼の懐ろから滑り落ちたその本の体裁を賞めたので、泥酔してゐた彼は、扉のＭ・アーノルドの贈呈詩を朗読したりしながら、恭々し気に進呈などした。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと／＼私はこんな水車小屋にかゝり合ふてゐても埒があきませんので、ぶくりんの行状さへ収まるならば、おかくへの義理合ひのために直ぐにも音取家へこのまゝ進呈して、ぶくりんを働かせ度い念なのでした。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の王様といふのは、珍らしいもの好きな性質がありましたから、憤慨してゐる樫の木がおかしくてなりません、そこで茶目気を出して、踏台をお城に雇ひ入れることにしました、踏台は王様に雇はれると急に大きな声で叫びだし『悪い狼奴がどうして妾を欺まして、出世をしたか――』といふ長い文章を書いて王様に進呈しました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人、金のことは真実だと言って、女を片隅につれてゆき、とあるから、また例の千両の金の代りに鉄の棒を一本ぐっと進呈などとくるところと気を廻す読者も多かろうが、そんなことにあらず、一つの柱を叩かせると中が空虚らしく響く、この内に望みの金がある、小切りに出して使いたまえと示して旅人は去った。",
              "citation": {
                "source": "易の占いして金取り出だしたること",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「僕は村長に進呈するつもりで置いて来たのだつたが……」「何うしてそんなつまらぬ真似をしたの、これがなくなつたら貴方は風邪を引くにきまつてゐるぢやないの。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、俺が引き受けたからには、よしツ、死力を尽すであらう、俺の言葉に万一虚偽があつたら即刻命を進呈するであらう――といふやうなことを唸りながら、さう云ふ見得を切るのが得意の小原田参四郎と称ふ三百代言人であつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち落した鳥なら平気で進呈するけれど、未だ息がある鵞鳥をもう剥製にでも仕様としてゐるのにはあきれたな――兎も角、慾深だよ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……だからさ、あの写真は僕の気分に合はないものなんだから、新しく写して……それこそ、それはほんたうにエミさんのために写して進呈するといつてゐるぢやないか。",
              "citation": {
                "source": "街角",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
