      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "merchant ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "儲けるのは大阪商船と、宿屋や小商人だけである。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りの海添いに立って見ると、真青な海の上に軍艦だの商船だのが一ぱいならんでいて、煙突から煙の出ているのや、檣から檣へ万国旗をかけわたしたのやがあって、眼がいたいように綺麗でした。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商船の甲板でシガアの紫の煙をあげるチーフメートの耳の処で、もしもしお子さんはもう歩いておいでですよ、なんて云って行くんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『商船だらうか、郵便船だらうか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎ならば、異国の商船が絶えず出入りをしている土地ですから、モルヒネの睡り薬を手に入れることが出来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬二郎は商業学校を卒業して商船会社に勤めていたが、五尺たらずゆえ二十一歳とは見えなかった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは商船、たまったものでない。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ名誉ある一商船の機関長閣下よ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、我が帽子も亦我と共にこの名誉なる一商船の機関長閣下をも憚らず、傲然として笑へるが如くなりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保山の大阪商船待合所で別府までの切符を買うと、八十銭残ったので、二十銭で餡パンを買って船に乗った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、外国商人が裏面で布教し、国内のキリスト教信者の反抗も意外に強かつたので、三代将軍家光は、数度にわたつて、外国商船の往来を禁じ、遂に、寛永十六年（紀元二二九九西暦一六三九）七月、和蘭人と支那人を除く他の外国人との貿易を一切禁止したのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも水先案内の小舟についてくる満帆の商船のごとくだ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが間違がつて、樅の木より先に、和蘭の商船の壊れたのが沈んでしまつたり何かするのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "『きっとあの樅の木が今度、あの恐ろしい底へ跳びこんで見えなくなるだろうな』――ところが、オランダ商船の難破したのがそれを追い越して先に沈んでしまったので、がっかりしました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに至りて、商家蜒居と接し、商船漁舟と竝び、絃歌欸乃に交れり。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "末永大阪商船支配人の特別の依頼といい、朝日の記者、名誉ある文人としての名は事務長を初め船員が皆知っていたから、船医の外に特に一名の給仕を附添として手厚く看護し、この元気なら滞りなく無事に帰朝出来そうだと一同安心して大いに喜んでいた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは兎もあれ、十六の初旅に小蒸汽や赤い商船のかげに見た門司の海の凄いほど透きわたつた濃藍色はどんなに私をして新しい西洋の香に噎ばしめたであらう。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには舊い昔難破した商船から拾ひ上げた阿蘭陀附木（マツチのこと、柳河語）の大きな凾が濕りに濕つたまま投げ出されてあつた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、商船の無制限撃沈を試みたり、都市の空中攻撃を企てたりした責任者はある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、商船の老人がそれを見て大いにおどろき、また喜んだ気色で、しきりにそれを撫でまわしていたが、やがてその値いを訊いた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "盂蘭盆がなんだ、盂蘭盆の晩でも、大阪商船会社の船は出たり這入ったりしているじゃあないかと、僕は腹のなかで笑いながら、そしらぬ顔で表へ出ると、万兵衛は強情に追っかけてきて、漁師の舟さえ今夜は休んでいるんだから、遊びの舟なぞはなおさら遠慮しろというのだ。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "察度王時代に牧湊が中山で重要な港であったことは、『中山世鑑』に、当時牧那渡に倭人商船数多参りけるが、過半は皆鉄をぞ積みてける。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――すると御主人は、十年前に日本商船をお退きになると、直ぐにこちらへお移りになったんですね」「左様でございます」　夫人が答えた。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日は朝から曇った寒い日であったが、予想のごとく、敵の浦塩艦隊が津軽海峡に襲来して、商船｜奈古浦丸を轟沈したという知らせが来た。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょうせんかく」「朝鮮閣？",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、しょうせんかく」「朝鮮閣？",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして勝子から「しょうせんかく」といい出した。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
