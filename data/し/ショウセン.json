[
  {
    "uuid": "f919b26a-2272-5eae-b316-9e3aebe0d2c8",
    "entry": "商船",
    "reading": {
      "primary": "しょうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
