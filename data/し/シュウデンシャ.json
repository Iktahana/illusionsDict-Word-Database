    "definitions": [
      {
        "index": 1,
        "gloss": "last train (of the day)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一部の俳優達は終電車の時間を気にしていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "終電車の時間を気にしていた俳優達はほっとして、楽屋へ顔を落しに行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はハイドパークの真向ひ大理石門地下鉄ステーションへ終電車近く駈けつけた。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年の春の比芝宇田川町を経て三田の方へ往く終電車があると、風呂敷を背負って、息をせかせかとさしている六十位のよぼよぼの婆さんがひょいと乗るので、車掌が切符を切ろうと思っていると、大門と金杉橋の間あたりですうっと消えてなくなるのであった。",
              "citation": {
                "source": "終電車に乗る妖婆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ彼は舗道の両側の店の戸が閉まり、ゴミ箱が出され、バタ屋が懐中電燈を持って歩きまわる時刻までずるずると街にいて彷徨をつづけ、そしてぐったりと疲れて乗り込むのは、印で押したようにいつも終電車である。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員室のせまい暗がりのなかでふと黒く蠢いたのは、たぶん宿直の駅員が終電車の著いた音で眼をさましたのであろう。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "又その翌日、神田の同國人夫婦のところへ行き、身の上話しやら何かで、一日一晩を過ごし、やうやく最終電車に間に合つたと云つて歸つて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波から高野線の終電車に乗り、家に帰ると、私は蚊帳のなかに腹ばいになって、稿を起した。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君になるという人の勤め先を知らないようでは、結婚の費用は貸してあげないと言うと、じゃ今夜は終電車もないから泊めてくれと言う。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終電車が出たばかりだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "細々とした文章の長さの中で眼だけ光らしてゐる小林秀雄よ呪はれろ、死んでしまへ、深刻好きな君が地獄行の終電車に乗り遅れた格好だ。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにもならない迄この儘西岡と一処に飲むで夜だけを潰して終電車で家へ帰つて一刻も早く朝にしてしまはう、といふ心だつた。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから田圃の中の畦道を横千切りに近道をして走りながら、一直線に温泉鉄道の停車場へ来て、やっとこさと終電車に間に合って、一時間経たないうちに町の宿屋へ帰って参りました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けのプラット・ホームで終電車を待ってゐる二人の少女がある。",
              "citation": {
                "source": "白い呼吸",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野行も新宿行ももう終電車が通りすぎてしまって、駅員は帰り支度をしていた。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は十二時半頃まで各方面からのぼって来る終電車の音がきこえる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "終電車もみな通り過ぎてしまって、世間が初めてひっそりと鎮まって、いわゆる草木も眠るという午前二時三時の頃に、ガタガタといい、ガラガラという響きを立てて、ほとんど絶え間も無しに通り過ぎるトラックと馬力の音、殊に馬力は速力が遅く、且は幾台もつながって通るので、枕にひびいている時間が長い。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は十二時半頃まで各方面から上って来る終電車の音がきこえる。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "終電車もみな通り過ぎてしまって、世間が初めてひっそりと鎮まって、いわゆる草木も眠るという午前二時三時の頃に、がたがたといい、がらがらという響きを立てて、殆ど絶間もなしに通り過ぎるトラックと馬力の音、殊に馬力は速力が遅く、かつは幾台も繋がって通るので、枕にひびいている時間が長い。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に先日も銀座のある停留場で終電車を待つてゐた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "無学で加之に性急な終電車は、さういふ信者が夜中の街に立つてゐようと知る筈もなく、小躍りして停留場を素通りした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬ女８・24（夕）　小山内薫氏が大塚教会の女神様を信心して、終電車を引留めた話は前に言つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　お鳥が最終電車に間に合はないほどの時刻に歸つて來たことが、今一囘あつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "終電車重い響を残して帰つた・星があつて男と女・霙ふる、売らなきやならない花をならべる・霙ふるポストへ投げこんだ無心状・ぬかるみをきてぬかるみをかへる不幸はたしかに人を反省せしめる、それが不幸の幸福だ、幸福な人はとかく躓づく、不幸はその人を立つて歩かせる！",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔後終電車に跳ねられてすぐ入院したが、そのときはもう内出血が多すぎて二日目に亡くなったということである。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子が、西武線の鷺の宮で降りた時、その電車が終電車であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
