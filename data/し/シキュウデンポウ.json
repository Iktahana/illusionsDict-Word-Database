        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでうろたえた人々は直ぐに至急電報で打電し返した。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "出張教授をしている梅津朔造氏や山本毎氏等の処へ度々至急電報が飛んだ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初のうちは両氏等も倉皇として翁の枕頭に駈け付けたが、その後同じような至急電報が頻々として打たれたので、両氏も自然と狼狽しなくなった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "班長からの至急電報を頼みにきた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、早速停車場から鉄道管理局あてに次のやうな至急電報を打つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京警備司令部付、帆村荘六氏へ、次のことを、至急電報して下さい。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と至急電報を発しておいて直ちに急行で巴里へ向け出発した。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
