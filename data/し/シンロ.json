    },
    "definitions": [
      {
        "index": 1,
        "gloss": "route",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "素朴の叡智が、どれほど強力に諸君の進路を指定してくれるものであるかを知るであらう。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「いき」は肯定より否定への進路の中間に位している｛１｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり各部門においては現在既知の知識の終点を究め、同時に未来の進路に対して適当の指針を与え得るものが先ず理想的の権威と称すべきものではあるまいか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってそれから判断してその日の低気圧の進路のおおよその見当をつける事が可能になるのである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "台風の襲来を未然に予知し、その進路とその勢力の消長とを今よりもより確実に予測するためには、どうしても太平洋上ならびに日本海上に若干の観測地点を必要とし、その上にまた大陸方面からオホツク海方面までも観測網を広げる必要があるように思われる。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯の進路の出発点が始めて定まったと思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくの間船は事もなげに進路を取つて進むやうに見えた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "43　船は進路を誤って、アラスカへ着いたのであった。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く人生の進路を決定しなければならぬ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今では自分の進路は、一言で言える。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋涛万里を破るの大艦と雖ども、停滞動く事なくむば汚銹腐蝕を免かれ難く、進路一度梶を誤らば遂に岩角の水泡に帰せむのみ。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数日事なく過ごしたのち、明日はいよいよここを立退いて、指定された進路を東南へ向かって取ろうと決したその晩である。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、西南へと取った進路がたまたま浚稽山の麓を過ったとき、さすがに陵の心は曇った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、氣候の循環によつて示される尺度によつて、吾々人間生活の中に起りつゝある變轉の進路に一里塚の道標を打込むといふことが出來ないので、從つて四月の風も九月の風も、名前がちがふだけの恆信風であつて、嬉しさや淋しさの連想を伴ふ春風秋風では決してあり得ないのである。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幌馬車はそこに立っている馬や人々のために進路を遮られた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが全くわれわれの進路を妨害したために、われわれは再び投錨して、氷のとけるのを待つのほかには、どうすることも出来なくなったのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "進路は干上がった川筋で、そこなら敵の歩哨から姿を匿ってくれると思ったのだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの話がわかる程度に意識も聴力も戻ると、聞こえてくるのは、我が戦友、つまり私に進路を示した当の男が現地人のしもべを使って私を敵の手中へと売り渡したということだった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは、その誤りは、理性が真理を部分的にだけ詳細に探求してゆく傾向のために、理性の進路に起る誤りの無限の系列の一つをなすものである、と言っておけば足りるであろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発の中心となる人材の有無が、日米両グループの進路を分けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九七七年二月、サンノゼで開かれたウエストコースト・コンピューター・フェアーをのぞいた体験が、その後の古川の進路を決定づけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れたとはいえ、正しい方向に進路を向けるのはそれはそれでけっこうである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "論文に譬えると、あの婦人雑誌の「新婦人の進路」なんていう題の、世にもけがらわしく無内容な、それでいて何やら意味ありそうに乙にすましているあの論文みたいなものだということになりそうだ。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければあれ程腕のさえた沢田が進路を過る筈は絶対にない。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "希望を述べれば師範の美術部はおたがひに感化され易い傾向があるやうで、もつと各自の画境を勝手な進路でひらくべきだと思ふ、この点では現在の処頗る乱雑な嫌ひがあるが、旭中の画会は各独自的で、この点ではいゝと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間太陽日ごとに二度その進路を変えて洞中に光を直射せず。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで岸の方に曲りかけてゐた船は、急にひろ／″＼とした浪逆浦の方へとその進路を取つた。",
              "citation": {
                "source": "船路",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪と浸水とで糊よりもすべる船板の上を君ははうようにして舳のほうへにじり寄り、左の手に友綱の鉄環をしっかりと握って腰を据えながら、右手に磁石をかまえて、大声で船の進路を後ろに伝える。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは、その方へしんろをむけました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
