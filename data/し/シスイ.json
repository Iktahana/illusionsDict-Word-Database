[
  {
    "uuid": "35e75e3f-fc83-5df1-bdbc-c99a2326c39d",
    "entry": "止水",
    "reading": {
      "primary": "しすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "still water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また止水におけるは流水におけるの多趣なるに如かず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "止水明鏡のごとくにあらゆるものの姿をその有りのままに写すことができなければならない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風雅の誠をせめよ」というは、私を去った止水明鏡の心をもって物の実相本情に観入し、松のことは松に、竹のことは竹に聞いて、いわゆる格物致知の認識の大道から自然に誠意正心の門に入ることをすすめたものとも見られるのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界呑吐の元の野望敢て挫かん鉄石の、この人ありや執権時宗、観ずれば明鏡止水のごとく、断じては山河ことごとく震ふとかや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心こそ凡てのものを涵する止水なれ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にあらゆる証拠が揃っていながら「冤罪だな」と名奉行が心付き、又はなんの証拠もなくて反証ばかりあがっていながらテッキリ此奴と名判官が睨むのは、その無私公明、青空止水の如き心鏡に、被告人の鼻の表現がありありと映ったものに違いありませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画界の長老｜長原止水の如きは最も早くから椿岳を随喜した一人であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明鏡止水」という境地です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の世界――┌主観――明鏡止水なり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心澄徹、いはゞ明鏡止水の境地、よろこぶべし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わたくしの家の小園には長原止水さんの贈つた苗が、園丁の虐待を被りつゝも、今猶跡を絶たずにゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "起き出でて見れば、押川春浪と鷹野止水と也。",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや俺の心境は明鏡止水、明月天に在り、水甕に在りだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　○　夥しい作品のうちから僅かに十八篇の詩を鈔した詩集「孔雀船」の初版が、長原止水畫伯の裝幀によつて、東京銀座三丁目の左久良書房から刊行されたのは、明治三十九年の五月であつた。",
              "citation": {
                "source": "「孔雀船」解説",
                "author": "中山省三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、そこは大人物の内閣で、右から左へ曲るぐらいにこだわる量見はないのですから、光風霽月と申しますか、水従方円器と申しますか、明鏡止水の心境です。",
              "citation": {
                "source": "露の答",
                "author": "ぬばたまのなにかと人の問ひしとき露とこたへて消なましものを",
                "note": "青空文庫"
              }
            },
            {
              "text": "水もとまらず、影も宿らず、そのお尻は醇乎としてお尻そのものであり、明鏡止水とは、又、これである。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "明鏡止水とはいかないが、ウスバカにしては出来がよい。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心境は明鏡止水である。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいへ、そこは大人物の内閣で、右から左へ曲るぐらゐにこだはる量見はないのですから、光風｜霽月と申しますか、水従方円器と申しますか、明鏡止水の心境です。",
              "citation": {
                "source": "露の答",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の社会的な立場が行きづまると、すぐに明鏡止水と云ったような心境道徳を示すことによって問題を紛らせようとするし、そうかと思うと他人の私的行動に一々お節介をしないではいられない道徳癖が日本人の持病である。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "認識主観は明鏡止水でなくてはならぬと共に、凸凹していたり曲率があったりしてひねくれた歪曲したものであっては困る。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩山文相を明鏡止水の心境から辞職の決意にまで追いこんだ岡本一巳代議士は、勢いに任せて今度は小山法相の収賄問題というのを持ち出した。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当世書生気質」の逍遙の插画と長原止水の絵との時代的相異。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀は名鏡である、人は、止水の相でそれに溶け合わなければならない。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただきわめて少数のそれを待ち切れぬ者のために、大づかみな見越しを試みるならば、舟はもと内地の小さな止水の上で、発明せられたものであったとしても、是が大陸の沿海地方にまで、移し用いられるようになるのは容易でありまた自然である。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島を過ぎた頃から、客車は少しすいて来て、私たちも、やっと座席に腰かけられるようになりました。",
              "citation": {
                "source": "たずねびと",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――こんなごたごたの中にいちゃあ、向うからも見にくい、少しすいたところへ出よう」　彼らは、前へ前へと押す人なだれをよけて、税関の倉庫近く立った。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんじゃい」「あまり、人様に、おさい銭の催促をするのはよして下さい」「金持にいっているんだよ、金持の金をかるくしてやるのは、善の善なるものだ」「そんなことをいって、もし今夜、村のお金持の家へ泥棒でも入ったらどうしますか」「……そらそら、すこしすいたと思ったらまた参詣人が混んで来たよ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
