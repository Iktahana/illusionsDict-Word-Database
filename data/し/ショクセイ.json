[
  {
    "uuid": "8cb6f6d7-0087-5bd9-a713-4576611d9da8",
    "entry": "植生",
    "reading": {
      "primary": "しょくせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
