        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自然都市の到る處に色欲の享樂機關の豐富なのは驚くほどだが、それに伴ふ催欲的な存在物、つまり春本だとか、春藥だとか、催欲目的の酒だとかが非常に多い。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春美といって二十六歳、かつて某浪花節寄席の持主の妾をしていたことがあり、旦那は南五花街の遊廓で誰知らぬ者のない稀にみる漁色家で、常に春画春本淫具の類を懐中にしている男であると、女は何を思い出したのか何もかも千恵造に打ちあけた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角向う側の春本つて藝者屋へ逃げるんだつて言ふから、あたしも附いて行くと、もうそこの家は人で一ぱいなの。",
              "citation": {
                "source": "梅龍の話",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春本の藝者はあたし達を東京の藝者だと思つたらしいの。",
              "citation": {
                "source": "梅龍の話",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達の泊つた箱根の春本の藝者で小玉とか何とかいふ人が、この頃赤坂へ來てゐるのよ。",
              "citation": {
                "source": "梅龍の話",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　ささや桃吉、春本万竜、照近江お鯉、富田屋八千代、川勝歌蝶、富菊、などは三都歌妓の代表として最も擢ている女たちであろう。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "富田屋八千代は菅画伯の良妻となり、一万円とよばれた赤坂春本の万竜も淑雅な学士夫人となっている。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "春本を読む青年子女が猥セツなのではなく、彼等を猥セツと断じる方が猥セツだ。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は日本の春本を読んだが、一冊だけ相当の作品があり、種彦の作、流石に光つてゐた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は数冊の春本を読んだが、一冊だけ相当の作品があり、種彦の作、流石に光っていた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日或人のはなしに耶蘇の伝記にもぢりたるフランス語の春本及旧約聖書の体裁になぞらへし此れも仏蘭西語の春本ありし由。",
              "citation": {
                "source": "古本評判記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹田屋この日種彦の春本水揚帳、馬琴の玉装伝、其他数種を示す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜竹田屋の主人歌麻呂の春本寐乱髪といふものを持ち来る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日、竹田屋歌麻呂春本金参拾円広重の行書東海道金百参拾円を示す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹田屋春水の作と称せらるゝ春本千種の花を持ち来れり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは江戸末代の戯作者や浮世絵師が浦賀へ黒船が来ようが桜田御門で大老が暗殺されようがそんな事は下民の与り知った事ではない――否とやかく申すのは却て畏多い事だと、すまして春本や春画をかいていた其の瞬間の胸中をば呆れるよりは寧ろ尊敬しようと思立ったのである。",
              "citation": {
                "source": "花火",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "余これを以て生活に必要ならざる玩具春本の類を購うの資となす。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の石松のように乱暴者と異名を取った曲芸師春本助次郎は、タナゴ釣りの餌、玉虫を汽車の中でこしらえるとき、あのウズラの卵のような堅い殻を歯でかんで、中から玉虫のサナギを出し、マッチで細い毛を焼いて食べていた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は文春本誌九月号の新日本地図にやや具体的にタンテイの結果を書いておきましたが、いずれ本格的なタンテイ録、物的証拠のヌキサシならぬ数々をハッキリと取りそろえて、偽装のカラクリの下に隠れている真相を論証して、お目にかけるつもりです。",
              "citation": {
                "source": "飛騨の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
