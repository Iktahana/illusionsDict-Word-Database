        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バッジいわく、古エジプト人の『死者の書』に六、七の狗頭猴｜旭に向い手を挙げて呼ぶ体を画いたは暁の精を表わし、日が地平より上りおわればこの猴になると附記した。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、此書き物の脇役になる滋賀津彦に絡んだ部分が、日本の「死者の書」見たやうなところがあるので、これへ、聯想を誘ふ為に、「穆天子伝」の一部を書き出しに添へて出した。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうすると、倭・漢・洋の死者の書の趣きが重つて来る様で、自分だけには、気がよかつたのである。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、此書き物の脇役になる滋賀津彦に絡んだ部分が、日本の「死者の書」見たやうなところがあるので、これへ、聯想を誘ふ爲に、「穆天子傳」の一部を書き出しに添へて出した。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうすると、倭・漢・洋の死者の書の趣きが重つて來る樣で、自分だけには、氣がよかつたのである。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、此書き物の脇役になる滋賀津彦に絡んだ部分が、日本の「死者の書」見たようなところがあるので、これへ、聯想を誘う為に、「穆天子伝」の一部を書き出しに添えて出した。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすると、倭・漢・洋の死者の書の趣きが重って来る様で、自分だけには、気がよかったのである。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "死者の書（正篇）　　　　　　　一彼の人の眠りは、徐かに覚めて行つた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（つゞく）死者の書（終篇）　　　　　　　六ほゝき　ほゝきい　ほゝほきい。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「死者の書」　　　古都における、初夏のタぐれの対話　客　なんともいえず好い気もちだね。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そういえば、数年まえに釈迢空さんが「死者の書」というのを書いていられたではないか、あの小説には実によく古代の空気が出ていたようにおもうね。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "客　そう、あの「死者の書」は唯一の古代小説だ。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "客　全篇、森厳なレクヰエムだ、古代の埃及びとの数種の遺文に与えられた「死者の書」という題名が、ここにも実にいきいきとしている。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは釈迢空の「死者の書」を荘厳にいろどっていたあの落日の美しさです。",
              "citation": {
                "source": "雪の上の足跡",
                "author": "高原の古駅における、二月の夕方の対話",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見が読んだというのは『死者の書』である。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『死者の書』は鶴見が数年前から見たいと心がけていながら、手に入れ難かった本の一つである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見は今『死者の書』の中でその事を叙述してある一段を想い起して太い息をつく。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "機縁はすでに釈迢空さんの『死者の書』によって作られた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迢空さんは『死者の書』の結尾にこういっている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見はさきに『死者の書』を読み、感動して、動物の姿を追うて、過現未の三世に転々した。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味で折口信夫氏の『死者の書』は、いつまでも生命があるもののように思われる。",
              "citation": {
                "source": "『死者の書』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死者の書」とか、「リグ・ヴェーダ」とか「万里の長城」とか「ハンニバル」とかいうふうに、書きこんであるので、この方は話が簡単である。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう考えに導かれたのは、かつて折口信夫氏の『死者の書』を読んで、非常に強い感銘をうけてからのことである。",
              "citation": {
                "source": "千年の時差",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "程度の差こそあれ、いずれも「大人の描いた子供の絵」といささか多寡をくくっていた私も、この『死者の書』を読んだ時には、思わず愕然とした。",
              "citation": {
                "source": "千年の時差",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが『死者の書』はそういうことの可能性を示したもののように私には思われる。",
              "citation": {
                "source": "千年の時差",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『死者の書』が出てからは、もう十年あまりも経っていることであろう。",
              "citation": {
                "source": "千年の時差",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エジプト人の解剖学的知識の程度は（「死者の書」や魔術の呪文、などでの）身体の部分の数のように、ばらばらな発言だけによって判断される。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死者の書」で自涜は悪行と言われた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
