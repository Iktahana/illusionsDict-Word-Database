[
  {
    "uuid": "ba20e7cf-d02a-5571-9b89-4c9ae929e9b3",
    "entry": "賜与",
    "reading": {
      "primary": "しよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
