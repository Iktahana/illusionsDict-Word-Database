        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は死刑台へでもよいから、はやくこの部屋を出してつれていってほしいと思った。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑台なんか……なんでもないぞ！",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼からは、藤枝もやはり自分を死刑台に上らせようとする人間の一人だと見えているらしい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告人が最後まで否認しつづけて死刑台上に登つてしまつたので正確なことは判らないが、ここに当時の王冠法曹（我国の検事に当る者）のオープニング・スピーチの一節を紹介することによつて大体知り得らるると思う。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人の為に殺人をする殺人狂の中にも、裁判の結果、全く狂人として無罪を言渡される者と、一人前の人間として死刑台に上るものとの二種類がある。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑台の所まで人にかつがれて行かなければならなかったのである。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菅には死刑台の設備はなかつた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏国の革命の梟雄マラーを一刀に刺殺して、「予は万人を救わんが為に一人を殺せり」と法廷に揚言せる二十六歳の処女シャロット・ゴルデーは、処刑に臨みて書を其父に寄せ、明日に此意を叫んで居る、曰く「死刑台は恥辱にあらず、、恥辱なるは罪悪のみ」と。",
              "citation": {
                "source": "死生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく「死刑台は恥辱にあらず。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風はやむを得ないが、食料がなければ船は死刑台だ。",
              "citation": {
                "source": "釣れない時",
                "author": "君は何を考へるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑台の怪影「先生。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なあんだ、補助官は、やっぱり死刑台の地下室に待っていたのか）　執行官は安心した。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、連れだって、死刑台の下の地下室へおりていった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方が、その筋へ一方を訴えて死刑台へ送れば、次の日には自分も必ず捉えられて死刑台へ送られねばならなかったのである。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "千ちゃんを死刑台へ送ることはできない。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが住む家の門外にもこの両三年市ヶ谷監獄署｜後の閑地がひろがっていたが、今年の春頃から死刑台の跡に観音ができあたりは日々町になって行く、遠からず芸者家が許可されるとかいう噂さえある。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこんなに君を愛し君は偉大な情熱をもって僕を抱いている亡ぼされ、過ぎ去り、失われた獄の春………返らぬ命を告げられた毒殺と拷問の死刑台での、灼けるような熱情………秋空に再び萠えぬこめこじんのような蝕まれた心の傷痕………それが何であろう僕らは決して歎くまいおゝあの美しい日を誰が返してくれる！",
              "citation": {
                "source": "青春",
                "author": "献じる詞（牢獄にて）",
                "note": "青空文庫"
              }
            },
            {
              "text": "終回三十九、銀座の死刑台の事　　　　並に政府震撼するの事　四時喧鬧の絶えることない繁劇なる大都会も、しばし微睡みかける時がある。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、それにしても、この優し気な時計台が、いつの日か残酷なる死刑台になろうとは、日ごとこれを仰ぐ何びとがそれを予知し得たであろう。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ただ殺人者として、この僕が死刑台に上る丈けなのだ」「分りました。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ死刑台だ」　彼はそんなことを呟きながら、又ゴロリと仰向きになると、あぶら臭い蒲団の襟に顔を埋めた。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は誰でも死刑台へでものぼるような顔をするものじゃ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「死刑台じゃないんだよ」　三田村が横から口を出して笑った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "看守の敬意は死刑台を思わせるものだ。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がそれにのぼった後で死刑台を打ち倒す！",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
