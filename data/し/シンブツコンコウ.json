    "definitions": [
      {
        "index": 1,
        "gloss": "synthesis of Shintoism and Buddhism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
