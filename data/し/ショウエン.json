[
  {
    "uuid": "3b5df720-c538-5c84-a6d8-dbb47ce18883",
    "entry": "硝煙",
    "reading": {
      "primary": "しょうえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gunpowder smoke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こっちに散らばっている兵士の銃口から硝煙がパッと上る。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッと硝煙が上った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、硝煙の裡をぬけ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は慘たり、月下の海上に砲火迸り、硝煙朦朧と立昇る光景は、昔がたりのタラント灣の夜戰もかくやと想はるゝばかり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝煙は暗く海を蔽ひ、萬雷一時に落つるに異らず。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝煙は化粧着にも手にも残っていなかった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "現場で、船長は卓上に止められてあった大西洋の地図に頭を押しつけており、かたわらには牧師が硝煙の立つ拳銃を手に、肘を立てて構えていた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "明方よりの合戦に眼は硝煙に血走りて、舌には苦がき紙筒を噛み切る口の黒くとも、奮闘の気はいや益しに、勢猛に追ひ迫り、黒衣長袍ふち広き帽を狙撃す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明方よりの合戰に眼は硝煙に血走りて、舌には苦がき紙筒を噛み切る口の黒くとも、奮鬪の氣はいや益しに、勢猛に追ひ迫り、黒衣長袍ふち廣き帽を狙撃す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚇かしのように、こんどは艦首はるか向こうに爆弾が落ちて、はげしい閃光と、見上げるように背の高い水柱と、硝煙と大音響と波浪が起きたけれど、わが潜水艦はまるでそれに気がつかないかのように、黒鯨のようなその大きな艦体をしずかにしずかに波間に没しさったのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻をつく硝煙、真赤な火焔、ひっきりなしの爆音、それに呼応して天空高くとび上る大水柱！",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い室内はたちまち硝煙のために煙幕を張ったようになり、覘う帆村の姿が何処にあるかを確かめかねた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁を伝って昇って来る硝煙の匂いの下で、群衆はもはや最後の一団を街の一角へ吸い込ませていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、時計の蓋のガラスを検べてみましたら、表面にピストルから発射された硝煙の煤がついておりました。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私たちが生きているこの現代は、世界じゅうが一つの巨大なうごめきをしていて、硝煙の間で歴史が転換しつつある。",
              "citation": {
                "source": "ものわかりよさ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界市場の争奪のため、危機にあった欧州の空気はその硝煙の匂いと一緒に、急速に動揺しはじめた。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町は明治一〇年の西南戦争で焼失してしまったので、戦役の硝煙弾雨が消える間もなくにわかに普請された小屋の建ち並ぶ焼け野原といった印象である。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "劔が踊り、弾丸が唸り、馬が嘶きよろめく、雄叫びの声に気は遠くなり、硝煙に眼もくらんだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝煙は見る見る山をなし、敵の砲弾は雨のように彼等のまわりへ爆発した。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼は落葉だけ明るい、もの寂びた境内を駆けまわりながら、ありありと硝煙の匂を感じ、飛び違う砲火の閃きを感じた。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　硝煙は見る見る山をなし、敵の砲弾は雨のように彼等のまわりへ爆発した。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の騒ぐ姿、罵る者、橋外へ来かかった津軽の行列は槍を傾け、挟箱持は濠端へ逃げ、駕籠はよろめきながら、人数の乱れる脚の真中に――そして、柳の木の下には白い硝煙が、薄く立ち昇っている。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を上げると、御香ノ宮の白い塀の上に、硝煙が、噴出しては、風に散り、散っては、噴き出し、それと同時に、凄まじい音が、森に空に、家々に反響していた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "御香ノ宮の塀に、硝煙の中から、ちらちら敵兵の姿が見えてきた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、銃声が、硝煙が、激しくなった。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝煙の臭が、流れてきた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝煙をふんだんに使い、大道具は、本当にその一部を、舞台のうえで燃やすという派手な演出法により、観客を文字どおり煙にまいている。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、真下にあえいでいる米連主力艦隊が、必死となって撃ちあげている角砲の硝煙であった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は官軍に内通している獅子身中の虫と見られ、ある夜のごときは数十人の兵にその身辺を取りまかれ鉄砲の筒口を一斉に向けられ硝煙に包まれたことさえあった。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台の引出しには「菊童」という、さらりとした薄い粉白粉と、しょうえんじがお皿に入れてあった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
