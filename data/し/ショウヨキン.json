          "literary": [
            {
              "text": "そういうものはみなこの九一による賞与金をアテにしているのだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日に十一、二時間ずつ額にあぶらして下駄の鼻緒の芯を造って、そして月に七、八銭ずつの賞与金というのを貰っている人間の女房だ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後土地家屋の周旋業は一時非常に成績が好かったので、土地会社へ勤めていた重吉もこれまでにない賞与金を貰ったくらいで、丁度｜歌舞伎座が新に建直された時、重吉は種子の衣類に身を飾ったお千代を連れて見物に行く。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩食のときに、優勝者に与うる賞与金の募集あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その賞与金はときどき募集するが、おのおの競って出金するは妙だ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
