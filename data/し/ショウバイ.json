[
  {
    "uuid": "c8456e70-a15d-5557-b66c-ae2618d9b95e",
    "entry": "商売",
    "reading": {
      "primary": "しょうばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「いやいや、もう安宅さん……わたしの方は商売上つたりで、もうずつとくひこみですあ。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛もこのごろは商売上手になったよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して人気商売の、殊には此のプロパガンダの時代に於て、彼等が悪口の種にならぬ限りに於て自己独特の奇態を流行させようなどゝいふ野望を常に抱いてゐるといふこともよく分つてゐよう。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちは何商売だったか分らないが、その家の店先に小鳥の籠がいくつか並べてあった。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの家は維新前にはちゃんとした店をもった商人であったらしいが、自分の近づきになった頃はいわゆる「仲持」すなわち、今の土地家屋売買周旋業と云ったような商売で、口と足とさえ働かしておれば自然に懐中に金の這入って来る種類の職業であったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれくらいの事が自慢になるようであったら世の中に易者や探偵という商売は存在しない訳であり、奥歯一本の化石から前世界の人間や動物の全身も描きだすような学者はあり得ない訳である。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が他の一人に、うっかり商売気を出して仲間にまで色眼はお使いでないよと頬を打つ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々あぶく銭を男たちから絞って、好き放題なことをした商売女が、年老いて良心への償いのため、誰でもこんなことはしたいのだろう。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売女には眼もくれなかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　商売仲間の女がそろそろ場を張りに来た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里へ来る遊び客は近頃商売女に飽きた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見せかけのこの親子連が成功するかしないかと楽屋を見抜いた商売女たちや店の連中、定連のアパッシュまでがひそかに興味をもって明るい電気の下で見まもっていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっしは、鳥をつかまへる商売でね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、商売ものを貰っちゃすみませんな。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもこの「商売」が一体どのくらいの収入になるものか、今度逢ったら思い切って一つ聞いてみてやろうと思っている。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ「感傷」を売り付けるにしても小説家や映画製作者に比べてみると実に可哀相なみじめな商売である。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎むにはあまりにみじめな商売なのである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "享楽しながら商売の宣伝になるのは能率のいいことである。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位売買事件や学位濫授問題が新聞雑誌の商売の種にされて持て囃されることの結果が色々あるうちで、一番日本のために憂慮すべき弊害と思われることは、この声の脅威によって「学位授与恐怖病」の発生を見るに到りはしないかという心配の種が芽を出すことである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位記というものは、云わば商売志願の若者が三年か五年の間ある商店で実務の習練を無事に勤め上げたという考査状と同等なものに過ぎない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『永代蔵』中の一節に或る利発な商人が商売に必要なあらゆる経済ニュースを蒐集し記録して「洛中の重宝」となったことを誌した中に、「木薬屋呉服屋の若い者に長崎の様子を尋ね」という文句がある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ商売上手の手合の仕事とすれば、害のない位をモッケの幸とせねばならぬが、真面目に家庭談を為すものや、本気に家庭作物を読む人々は、先ず此の家庭の意義を、十分に解して居って貰い度いものである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分等が商売がら何よりも眼につくのは物理学の中等教科書の内容である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店の先祖がどういう訳だか店の名を付けなかったが、商売は非常に繁昌し子孫代々名無しの牛屋で通っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くからある普通の鮨屋だが、商売不振で、先代の持主は看板ごと家作をともよの両親に譲って、店もだんだん行き立って来た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、さんまじゃ、いくらも値段がとれないからね」「おとッつあん、なかなか商売を知っている」　その他、鮨の材料を採ったあとの鰹の中落だの、鮑の腸だの、鯛の白子だのを巧に調理したものが、ときどき常連にだけ突出された。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ男に対してだけは、ずばずば応対して女の子らしい羞らいも、作為の態度もないので、一時女学校の教員の間で問題になったが、商売柄、自然、そういう女の子になったのだと判って、いつの間にか疑いは消えた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで宿屋や、飲食店の商売繁栄策としても内地米が目標となる。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "饂飩屋も、お湯屋も、煙草屋も、商売の一寸した手落ちにケチをつけられて罰金沙汰にせられるのが怖い。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は商売気があって、いろ／＼なことに手を出して儲けようとしたらしいが、勿論、地主などに成れっこはなかった。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
