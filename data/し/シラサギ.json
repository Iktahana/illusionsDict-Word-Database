[
  {
    "uuid": "b3cd8271-a7fe-51b3-90da-24d5f8308702",
    "entry": "白鷺",
    "reading": {
      "primary": "しらさぎ",
      "alternatives": [
        "はくろ"
      ],
      "is_heteronym": false
    },
    "grammar": {
