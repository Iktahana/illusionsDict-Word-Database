[
  {
    "uuid": "48477f75-9aac-5035-b332-9c65355cf703",
    "entry": "試験を受ける",
    "reading": {
      "primary": "しけんをうける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
