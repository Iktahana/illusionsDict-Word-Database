  {
    "uuid": "ca7dac35-1d0d-523c-b20c-6cae37100fa8",
    "entry": "私訴",
    "reading": {
      "primary": "しそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
