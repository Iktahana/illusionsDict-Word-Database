    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the four stages of existence: birth, life, death, and limbo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちよつと四有三居訪問、「一即二」の額がまづ眼についた、井師がよく出てゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四有三居訪問、番人に誰何されたり、押売と間違へられたりした、それも旅の一興、いや、私にはふさはしい出来事だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいたより（四有三さんから、桂子さんから）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は或るデパート楼上の四有三君送別句会に出席。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月廿五日　晴、河内水源地散歩、星城子居、雲関亭、四有三居。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月廿二日　曇、あちらこちら漫歩、八幡市、山中屋（三〇・中）朝酒、等、等、入雲洞さんの厚情が身心にしみる、洞の海を渡つて、木村さんを訪ねる、酒、それから同行して小城さんの新居へ、また酒、そしてまた四有三居で酒、酒、酒。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四有三さんに――（廿三日、小倉から）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨なれば雨をあゆむ此一句（俳句のつもりではありません）を四有三さんの奥さんに呈す。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から四有三居を襲うて饗応を強要した。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……八幡で四有三君、小城さん、下関で地橙孫君に逢へなかつたのは残念だつた。",
              "citation": {
                "source": "行乞記",
                "author": "北九州行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑な因果の網目を枠に張って掌上に指摘しうるものとした事でなければならない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく經つと、やはり眞面目な顏をして部屋へやつて來て、「あの、少し値が張りますけれど、よろしうございますか。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し利巧な見ばえのするやうな人間は、これはまたヒステリイ、疑ひと卑屈に蟲食はれてしまつてゐます……かういふ手合ひは愚痴を言ふ、人を憎む、病的に讒謗を逞しうする。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この疑問はやがて天体の構造如何という事になるので、昔から幾多の天文学者の想像力を逞しうする種になっていた。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしうございます。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授はその眼を読み兼ねたやうに礼をして「お仕度はよろしうございま〔す〕か。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　汽車は峠の頂上にかかったらしく、青い信號燈や何かがぼんやりと窓の外を過ぎ、こどもはまた窓のところに、前より少しうつむいて置かれました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "園さまはどうなされた今日はまだ顏が見えぬと問はれてまさかに、今までこれ／＼で次の間に泣いて居られますとも言ひがたければ、少々御不加※で、然しもう宜しう御座りませうほどに、まあお茶を一つなどヽ民は其塲をつくろひぬ。",
              "citation": {
                "source": "經つくゑ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、浴衣を重ねし唐棧の着物に柿色の三｜尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はまだ寐ないのかえ、と障子の外から聲をかけて、奧さまずつと入り玉へば、室内なる男は讀書の腦を驚かされて、思ひがけぬやうな惘れ顏をかしう、奧さま笑ふて立ち玉へり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "良久しうありて奧さま大方醉も覺めぬれば、萬におのが亂るゝ怪しき心を我れと叱りて、歸れば盃盤狼藉の有さま、人々が迎ひの車門前に綺羅星とならびて、何某樣お立ちの聲にぎはしく、散會の後は時雨に成りぬ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "汨羅の屈原ならざれば、恨みは何とかこつべき、大川の水清からぬ名を負ひて、永代よりの汽船に乘込みの歸國姿、まさしう見たりと言ふ物ありし。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　信如が何時も田町へ通ふ時、通らでも事は済めども言はば近道の土手々前に、仮初の格子門、のぞけば鞍馬の石燈籠に萩の袖垣しをらしう見えて、椽先に巻きたる簾のさまもなつかしう、中がらすの障子のうちには今様の按察の後室が珠数をつまぐつて、冠つ切りの若紫も立出るやと思はるる、その一ト搆へが大黒屋の寮なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの帰りと覚しく、裕衣を重ねし唐桟の着物に柿色の三尺を例の通り腰の先にして、黒八の襟のかかつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわぎわしう見えて誇らし気なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「派手な浮名が嬉しうて」の言葉でもわかる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしうまく用を便ぜられないと、また少し進んで別のところへ第二の穴を掘って更に第二の試みをする。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "比重は無論空気に比べて著しく大きいが、その体積に対して面積が割合に大きいために、空気の摩擦の力が重力の大部分を消却し、その上到るところに渦のような気流があるために永く空中に浮游しうるのである。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「中」チウ→チュー、「いう」イウ→ユー、「嬉しう」ウレシウ→ウレシュー。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　信如が何時も田町へ通ふ時、通らでも事は濟めども言はゞ近道の土手々前に、假初の格子門、のぞけば鞍馬の石燈籠に萩の袖垣しをらしう見えて、椽先に卷きたる簾のさまもなつかしう、中がらすの障子のうちには今樣の按察の後室が珠數をつまぐつて、冠つ切りの若紫も立出るやと思はるゝ、その一ツ構へが大黒屋の寮なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、裕衣を重ねし唐棧の着物に柿色の三尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
