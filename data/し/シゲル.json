[
  {
    "uuid": "90e3d3ff-f3af-5f71-995b-302c2742dcb3",
    "entry": "茂る",
    "reading": {
      "primary": "しげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
