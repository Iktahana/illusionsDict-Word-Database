[
  {
    "uuid": "c2ac2bd3-b196-5c84-88c3-f6663261c0fa",
    "entry": "小冊",
    "reading": {
      "primary": "しょうさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
