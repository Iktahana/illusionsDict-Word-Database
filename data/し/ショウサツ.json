      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pamphlet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "科学の通俗講義集　近頃コロンビヤ大学で最近の科学の進歩を通俗的に講義した小冊子二十二篇を出版した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった七十一頁の小冊子である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら記録の中で毛色の変わったのを若干拾いだした記事が机上の小冊子の中で見つかったから紹介する。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の原氏著「お灸療治」という小冊子に灸治の学理が通俗的に説明されているそうである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒイタサントオルムという日本の風俗を記した小冊子と、デキショナアリヨムという日本の単語をいちいちロオマンの単語でもって飜訳してある書物と、この二冊で勉強したのであった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳に頬杖して、謄写版の小冊子に読み入つて居たすず子は、顔をあげて男の方を見た。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては、いつも思うのであるが、今日は同人雑誌の洪水時代で、毎月私の手元へも夥しい小冊子が寄贈される。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "所へある気の利いた男が出て来て、煤煙の全部を出版しやうとすればこそ災を招く恐れがあるので、そのうちの安全な部分｜丈を切り離して小冊子に纏たらどんなものだらうといふ新案を提出した。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所で「樺太のパルプ並製紙工業」という樺太庁版の小冊子や紙の見本や絵葉書を貰って、また私ら二人は一足先きへ外へ出た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜池は自ら津国名所と題する小冊子を著して印刷せしめ、これを知友に頒った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何にせよ、片々たる小冊子である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで、時とすると怪譚に筆を著けることがあって、既に『怪談』と云う小冊子まで作っているが、雑駁で不統一で、どっちから云っても欠点だらけだし、その上、後からも同種類の材料が出来たので、怪談の中からも取り、又、他の冊子へ収めてある物を取って、それを交えて更めて一冊とすることにした。",
              "citation": {
                "source": "『黒影集』の序詞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士屋ホテルの案内記のような小冊子をカバンから出して見せたりした。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度、もと岩波書店でおなじみの小山二郎君が、新たに出版業をはじめるというので、この機会にこれらの短文を集めて小冊子を、同君の店から上梓するようにしないかとすすめられた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学に行くようになってからは、小冊の地文学、地理書のようなものを数多く読み、また小説なども大いに読んだものである。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして偽牧師は、部屋べやに説教しに来たが、手には黒い袋を持っていて、そのなかは教会の小冊子しか入ってないと思われているわけだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "足尾鉱毒問題での農民のチラシ、小冊子活動はつとに有名だが、明治三十年からは大量のガリ版印刷物が残存している。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＴＰによる紙の本や、「Dairiqui 通信」と名付けた小冊子も出していますが、エキスパンドブックによる出版が、活動の太い柱になっています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海大学出版会にいた西田光男さんの仕切りで、同会の『科学サロン』という小冊子に載せてもらったこの原稿が、「パーソナルコンピューターについて書いた」と記憶に残っているものの中では一番古い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大黒天の事は石橋臥波君の『宝船と七福神』てふ小冊に詳述されたから、今なるべく鼠に関する事どもとかの小冊に見えぬ事どもを述べよう。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "附録の小冊子の来月に詩と和歌（少女文芸）を載せる事になりました。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から今日に至るまで、あらゆる本は、何んな零砕な本でも、小冊子でも、すべて人間生活の状態の『あらはれ』である。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『書生気質』は初め清朝四号｜刷の半紙十二、三枚ほどの小冊として神田明神下の晩青堂という書肆から隔週一冊ずつ続刊されたので、第一冊の発行は明治十八年八月二十四日であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、良沢が、長崎から持ち帰った小冊に、フルヘッヘンドの訳注があった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "共産、過激、虚無、その他あらゆる強烈な思想が、宣伝ビラや小冊子となって、欧州大戦の裡面を波打ち流れた――ツァールの帝国主義、カイゼルの軍国主義と戦った――そうして遂に大勝利を博した事を知っている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペン習字手本というような小冊子が流行った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「花の研究」といふ小冊子をとり出して、何時になく落ついた心地で、冒頭の一節を読んでゐた。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "田島氏の希望にそむくとは知りつつも、なおこういう小冊子を公にするに至ったのは、別に考える所があるからだ。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはヒューマニティであり、その運命であり、その文化である」と云い又「あらゆる反ソヴェートの新聞紙が、いま自分の本を利用するのが残念である」と云いつつ、ロマン・ロランその他の前もっての忠言にかかわらず、その小冊子を三ヵ月に百五十版重ねさせた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
