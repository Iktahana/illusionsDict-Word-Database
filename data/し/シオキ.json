[
  {
    "uuid": "2c37e955-cf21-5adf-9981-10d4ab34f412",
    "entry": "仕置き",
    "reading": {
      "primary": "しおき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
