    "definitions": [
      {
        "index": 1,
        "gloss": "(Edo-period) restaurant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
