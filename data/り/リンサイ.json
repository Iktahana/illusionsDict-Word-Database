          "literary": [
            {
              "text": "、ずんずんお上りんさいと言え！",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの嫁になりんさい。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしと夫婦になりんさい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そがあな男は早よ見切りんさい」「見切るかも知れんけえ、ともかく、帰るまで待ちんさい、玉井に聞いてみて、玉井が、時やんの嫁女になってもええ、というなら、なる」「そがあな、まだろこしいことより、今からすぐ、二人で、この家を出ろうや」「時やんの判らず屋」　はげしい語調だった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
