[
  {
    "uuid": "538ec117-2b1d-5b40-9fb1-7c186b748a74",
    "entry": "量産",
    "reading": {
      "primary": "りょうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mass production",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軽くおちゃらけてもいるし、最後のところなど、今にも私家版のエキスパンドブックを量産しそうな勢いです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産可能な大容量のデジタルメディアという地位は、レーザーディスクの独占物ではなくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく新しく工夫した印刷術を使いながら、イニシャルや文様を手仕事に委ねたのでは、量産というメリットが生かし切れないではないか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパにおける印刷術は、こうしてすでに量産の圧力が高まりつつあったさなかに生まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『四十二行聖書』のいびつさの根　印刷術の誕生の時点で、すでに書物を量産化する圧力がかかり始めていたことを確認して、あらためて『四十二行聖書』に立ち返ると、あくまで手写本を真似ようとする姿勢はよりいっそう奇妙に感じられます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産された印刷本の中心的な読み手となったのは、ルネサンスの中核となった人文主義者たちです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手写本のイメージを完璧になぞって生まれた印刷本はこうして、量産が可能で書物の値段を大幅に引き下げられるという自らの本質に沿った体裁を、じょじょに獲得していきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初は手写本を完全になぞり、そこからやがて量産性という技術の本質に沿って、本は一歩ずつ変わりはじめます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷術は、この器を紙の上に量産化する技術に他なりません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とここまで来て、まともなコンピューター村の住人ではあるけれど、大型やミニコンピューターのタイム・シェアリングではどうもならんぞと踏ん切った連中が、マイクロコンピューターの量産効果を自分達も活用してやれと考えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産効果に背を向けてマイクロコンピューターを使わないメインフレームの類は、ごく一部の例外を除いて今後のコンピューター環境に加わる資格を持たない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイルスに冒された僕の生命は遺伝子工学で量産されるインターフェロンに左右され、文書ファイルはネットワークに乗って金銭に化ける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九一年三月、ＡＭＤは初の３８６互換チップ、Ａｍ３８６ＤＸ―40とＡｍ３８６ＤＸＬ―40の量産出荷を開始した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九九一年三月、ＡＭＤは３８６互換チップを、続いて七月には３８６ＳＸ互換チップを量産出荷し始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産化できる部品としての頭脳を実現したマイクロコンピューターは、メインフレームやミニコンピューターの足場にひたひたとコスト切り下げの圧力の波を送り込んできた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼らは、量産部品としてのマイクロコンピューターの圧倒的なコスト・パフォーマンスの良さには、完全に負けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん開発を終えてしまえば、集積回路の量産は容易である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの時期、大ヒットの兆しを見せはじめたＰＣ用にＩＢＭが８０８８を大量に押さえてしまったために、安価な一六ビットの第一の候補である８０８８が量産ベースでは確保しにくくなっているという事情もあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのタイミングに量産機のプロトタイプを間に合わせ、実マシンでの評価に九月をあて、十月からの出荷を実現する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田は量産モデルのプロトタイプが完成した七月後半から、サードパーティーに発表前のマシンを貸与して、事前にアプリケーションの開発を進めさせようと考えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく分析してみたＩＢＭ ＰＣは量産化を意識した設計上の工夫を随所に盛り込んでおり、いくつかの特長はそのまま新一六ビット機でも生かそうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ソフトハウスへの量産型プロトタイプの提供は、九月一日から開始された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォズニアックを説得したジョブズは、部品を調達して開発者を量産にあたらせ、寮の学生の部屋をノックしては訪問販売を開始した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産の容易な集積回路にまとめている以上、ＣＰＵのコストは従来の常識とは桁外れに低く抑えられるはずだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイバネット工業の伊勢工場では、同社への製品供給が本決まりとなった時点から、量産化に向けてラインの整備が進められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本たちがＡＳＩＣの開発作業を完了し、カスタムＬＳＩの完成が近づいて量産体制が整おうとする一九八三（昭和五十八）年の二月に入っても、西の督促に対してゲイツは「待て」と繰り返すのみだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手写しするしかなくて、大変な貴重品だった本を量産する仕組みができた。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷本を簡素化し、量産可能なものに生まれ変わらせるには、幾人もの出版人によるその後の革新が必要だった。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と大声をあげて廊下を走ったら、お静に『貞吉っとん、なにいうてなはんね、ごりょうさんやがな！",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごりょうさんの背をふろで流すのも私の仕事だったが、ある日ふろ場でごりょうさんがいわれた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
