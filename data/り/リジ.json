    "definitions": [
      {
        "index": 1,
        "gloss": "director",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今度の成案などは、まだ／＼ほんの初めのことで、不完全なものでせうが、組織は農団組合を管理する理事を置いて、これが実務に当ることになるのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたしかに評判の通りシカゴ畜産組合の理事で又屠畜会社の技師です。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にも取らないで、口のなかに低声におよみなすったのが、市内衛生会委員、教育談話会幹事、生命保険会社社員、一六会会長、美術奨励会理事、大野喜太郎。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にも取らないで、口のなかに低声におよみなすつたのが、市内衛生会委員、教育談話会幹事、生命保険会社々員、一六会々長、美術奨励会理事、大日本赤十字社社員、天野喜太郎。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一部の理事及び財団の刻薄に驚く。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな内實も知らないで、世間體をばかりつくろつてゐる創立者や常任理事は馬鹿な奴だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの學校の理事は圓滿主義を以つて男爵になつた人だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "須婆田車六といって日印協会の理事だ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧藩以来福岡市内｜薬院に居住し、医業を以て聞こえている前医師会理事故権藤寿三郎氏（現病院長健児氏令兄）は梅津只圓翁の係医として翁の臨終まで診察した人であるが、嘗て筆者にかく語った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又前医師会理事権藤寿三郎氏が言葉を飾る人でなかった事は周知の事実である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "國民黨宣傳部理事である人の書齋に翁の筆のあるのは當然として、またその筆致のよしあしは別として、私にはその文句が目についた、たゞ大きく『不惑不懼不憂』と書いてある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤井さんとは以前、管理組合の理事として一緒に動きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場の論議で、著作隣接権の延長が盛りこまれていないことへの質問が、日本芸能実演家団体協議会専務理事の大林丈史委員からあった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＥＵの延長方針は、当時のＥＣ理事会指令として発せられたが、その表題は、「著作権及び著作隣接権保護期間の平準化（harmonizing the term of protection of copyright and certain related rights）」とされていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "理事会指令は、このばらつきをならし、域内の権利保護に齟齬が生じるのを防ぐという意図でまとめられたものだった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九三年の理事会指令は、著作権の保護期間を作者の死後七〇年、著作隣接権を保護の開始から五〇年と定めた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人というのは、某会社の理事安藤某という名刺をだして、年ごろ四十五、六、洋服の風采堂どうとしたる紳士であった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "で大音寺が徐ろに云ひ出すところを聞いて見ると、彼は「正義団」といふものの一員で、且又応援団の理事であつて、対一高戦が迫つた折から応援団員を物色中であるのだが、君は余程のフアンと見た、打ち見たところ稍はにかみ屋であるらしいが母校の為に団員に加はらないかと進めるのであつた。",
              "citation": {
                "source": "大音寺君！",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ、何んなに本社で歓迎して呉れると言つても、又理事級の人達のみが貰ふやうな高い旅費を呉れて、大切なお客様として随行員をつけて何処でも自動車で案内させると言つても、かれは決してそれを承諾しなかつたに相違なかつた。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "客甲――商工会議所理事高山新三郎、こちらは家内。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、会を起すについては、会則を作り、会頭、理事、評議員というようなものの必要を生じて来る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、会費のようなものも、甲乙丙の三種で、師匠分の人は甲、独立している程度の所は乙、まだ年季中の者で、弟子連中は丙というように公平に取り扱い、会の維持法等については、合理的に能く相談を致し、また会頭、幹事並びに理事部長の任期何年という事を討究の末ほぼ決定しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、理事、会長の考えで処置されるであろうというので、幹部へ持ち込んだものですから幹部の山高信離、松尾儀助、岸光景、山本五郎、塩田真、大森惟中諸氏の手に掛かることになりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "四頭の狆を製作したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことがつづくなら、いまでさえ多すぎる規則を、さらに増やさなければならないことになる」　だれもが、寮長のことを「寮長」以外の名前では呼ばないが、この人はほんとうは理事長と呼ぶべき人で、その気になれば、校長の首だって斬ることができる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では立派な熟練工で四円の日給をもらっているかたわら、城東労働組合の理事をしている。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして俺は、応援部と正義会の理事なんだが、君は応援部に入らぬかな？",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　社長の大川氏も、理事の須藤氏も、平生「毎日」の如きは眼中に無い樣な事を云つて居て、私が初めて着いた時も、喜見とか云ふ、土地で一番の料理屋に伴れて行かれて、「毎日」が例令甚※事で此方に戈を向けるにしても、自體對手にせぬと云つた樣な態度で、唯君自身の思ふ通りに新聞を拵へて呉れれば可い。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁うなると滑稽もので、さらでだに私は編輯局で一番年が若いのに、人一倍大事がられて居たのを、同僚に對して氣耻かしい位、社長や理事の態度が變つて來る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁うなると滑稽もので、さらでだに私は編輯局で一番年が若いのに、人一倍大事がられて居たのを、同僚に対して気恥かしい位、社長や理事の態度が変つて来る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話によると、何んでもあまり町の理事が頑強に反対し続けたので、とうとう夢殿村の患者達は結束して町へ乗り込み、その理事の家へ押しかけていったところが、理事は勿論、警官達も手で患者達をとめるわけにもいかず、まアまアということになってめでたく話はその場で解決したとのことであった。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
