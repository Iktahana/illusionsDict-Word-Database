          "literary": [
            {
              "text": "窓外に、五月の緑風が、輝く若葉を繙いていく。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭鼎談　昭和二十三年八月一日、東京都文京区音羽町三丁目十九番地、光文社発行の雑誌「光」第四巻第七八号に「緑蔭鼎談」と題し、伊豆熱海の緑風閣で催された長谷川如是閑、志賀直哉並に天野貞祐三君の座談会記事が掲げてあった。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑風閣へ皆で出かける、ビール飲みながら天ぷらをウンと食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻清水からの誘ひで、車で緑風閣へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝを出て、緑風閣迄歩く、海を眺めながら天ぷらを食った、建物と景色はいゝが、天ぷらはまづく、値は高い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅がうるさくて、一時間位で起き、女房・滝村と緑風閣へ天ぷら食ひに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
