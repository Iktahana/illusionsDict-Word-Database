    "definitions": [
      {
        "index": 1,
        "gloss": "idealistic thought (argument)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
