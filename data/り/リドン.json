    "definitions": [
      {
        "index": 1,
        "gloss": "sharp or blunt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
