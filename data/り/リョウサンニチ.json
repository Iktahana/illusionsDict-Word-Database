[
  {
    "uuid": "808a3af3-76e1-5f7f-8766-01ecb1b3a3cd",
    "entry": "両三日",
    "reading": {
      "primary": "りょうさんにち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
