[
  {
    "uuid": "04cac3d2-8bfc-5a6f-a2c7-2f021389930d",
    "entry": "竜骨",
    "reading": {
      "primary": "りゅうこつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
