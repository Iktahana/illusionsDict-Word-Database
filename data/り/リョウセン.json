        "index": 1,
        "gloss": "consort ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "舳に立つと、互に離れないように、艫と艫とを太い縄で結びあわせた僚船の姿が、まだ寝足りなそうに浮かんでいるのが見えた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、船に乗つて海に漁猟に出たものが、午飯時にこの小魚を焼いて食べると、そのうまさに自分の飯櫃を空つぽにした上、その近くにゐる僚船を呼びとめて、飯の残りを無心したので、いつのまにか「ままかり」といふ名で呼ばれるやうになつたといふのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜隻の僚船が従いて来る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚船二隻ぶつかったのである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
