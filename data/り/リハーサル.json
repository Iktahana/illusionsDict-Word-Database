        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リハーサルに相当する回路別の実験があり、演奏が実際の製作に相当する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生で並三ラジオに挑んだときはリハーサルからの参加だったが、テレビカメラでは編曲の基本設計にも踏み込んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "集積度が高まるにつれて回路のより広い範囲がチップに収まれば収まるほど、リハーサルと演奏に相当する創造性をほとんど問われない作業にしか関与できなくなるように思えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろリハーサルと行こうか」佐藤は煙草をすて、なれた態度で女優の不満を黙殺した。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当だったら最初からシナリオ渡されてリハーサルを済ませてからやるものなのよ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このホテルのこのダイニング・ルームに出演している、マオリのコーラス・グループのリハーサルだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その基地での最初の公演までの三日間、姉は彼女たちのリハーサル・ピアニストを務めることになった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "リハーサルをずっと見てたのだけど、マイケルは素晴らしい。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古風景からリハーサル、そして当日の舞台写真や楽屋の様子も」「そのうち見せていただけますか」「見てください」　福山俊樹の取材ノートには、高校における後藤美代子の演劇活動について、いっさい書かれていなかった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "リード・ギターにスコティ・ムーア、ベースにビル・ブラックがつき、数週間にわたってリハーサルがおこなわれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時刻前に、宮内官の案内で、ちょっと、リハーサルの説明などがあった。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
