        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "政宗は忌々しかったろうが理詰めに押されて居るので仕方が無い、何様しようも無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って火のわざですから、失敗せぬよう理詰めにはしますが、その時になって土を割ってみない中は何とも分りません。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしに取って理詰めの世界は見え過ぎて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に……と言うのは、ひどく理詰めな言い方だが、お千鶴はおれに惚れていたのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "百円の随筆を書くのに百円の煙草を煙にしては何にもならない」　そう理詰めに言うと、十吉は、「それもそうだな」　と、ひとごとのように感心していたが、急に、「あ、そうだ、煙草だけじゃない。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間の先祖は猿である」という進化論の理詰めを読んでたまらない痛快味を感じたのもその頃の事でした。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　理詰めで解決しないで、なるべく仕事で解決したらいゝ、理論や理屈の多い人は、さういふことが自分で気持をこはす種になつてゐるのではないか。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だって、こうして理詰めで攻め上げたればこそ、やっと少しずつ判りかけて来たのですから……全く、その時そこで、なんとも変テコなことが起ったんですよ。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、易者も中々理詰めな事を云ふ。",
              "citation": {
                "source": "人相見",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "川へもぐってぬれたやつを、いましがた干したばかりにちげえねえんだッ」　まことにいつもながら名人の観察は一分のすきもない理詰めです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと理詰めで考えるけいこをしろい」「なるほどね、大きにそれにちげえねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "物には順序と道理があるはずじゃから、理詰めに調べたてれば、実を吐かぬというはずはござらぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま江戸じゅうに何軒小屋が開いてるか、そいつを洗ってくるんだよ」「なるほど、やることが理詰めでいらっしゃらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ理詰めの詫びと思うが、それにても馬のせいに致したは御勘弁ならぬと仰せあるかな」「つべこべ長談義申さるるなッ、われら、そのような屁理屈聞く耳持たぬわッ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ理詰めの詑びと思うが、それにても馬のせいに致したは御勘弁ならぬと仰せあるかな」「つべこべ長談義申さるるなッ、われら、そのような屁理屈聞く耳持たぬわッ。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第五話　三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常な理詰めを心掛けた時に、新幽霊談は創造出来る。",
              "citation": {
                "source": "妖異むだ言",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一番不純のようで、その実一番理詰めでございます。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかしそんな人柄の人ならむしろ理詰めで押して行つた方がいいんぢやないかと思ひますがえ……勿論僕は爭ふつもりはありません。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうな話合ひに於て理詰めで行くといふことは危險であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなくらいならはじめから渡さないほうがいいじゃないか」　野田はこの理詰めにはたと当惑した。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自然の児である人間を片っ端から、鉄と石の理詰めの家に潜り込ませた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は、君が或る程度まで本性を回復した時を見澄まして、コッソリとあの娘に引き会わせて、色と、慾と、理詰めの三方から、君自身に君自身を無理にも呉一郎と認めさせよう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとなく雄弁になって来る女の鋭い理詰めと、その理詰めを通じて判明って来る女の頭のよさに呆れ返っているらしい。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやに理詰めだね」　朝子は、赤インクでよごれた手が気持わるいので、先に内に入った。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり理詰めと云うのであろう」「さようさよう、理詰めと云うことじゃ。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て兵法ばかりでなく、万事万端浮世の事は、すべからく総て科学的でなければならない」「科学もいい、理詰めもいい、しかしその外にも大事なものがある」紋太夫は昂然と云う。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝から雪が降りづめで、夜になって漸くやんだ。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間をわたしは殆んど走りづめに走りました。",
              "citation": {
                "source": "金比羅參り",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きづめである、啖の取りづめである。",
              "citation": {
                "source": "寢たらぬ日記",
                "author": "湘南サナトリウムの病院にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、学齢頃までは医者にかかりづめでしたよ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
