[
  {
    "uuid": "72010a01-ed23-59fe-8c02-db4908268f93",
    "entry": "流麗",
    "reading": {
      "primary": "りゅうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
