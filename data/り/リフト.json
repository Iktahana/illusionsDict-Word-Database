    "definitions": [
      {
        "index": 1,
        "gloss": "chairlift (e.g. at a ski resort)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
