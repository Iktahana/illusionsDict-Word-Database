[
  {
    "uuid": "973617f3-c91a-5824-a810-be405d8f6cc6",
    "entry": "利用",
    "reading": {
      "primary": "りよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "use",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "事そのもの、物そのものを、知る間もあらせずその事その物の利用を思つた心のせゐだ。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし作者の意味では、そうした故事や固有名詞と関係なく、単にこの易水という文字の白く寒々とした感じを取って、冬の川の表象に利用したまでであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時｜颱風の話からそのエネルギーの莫大なこと、それをどうにかして人間に有益なように利用するようにしたいというようなことを話したら、大変にそれを面白がった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風の害を避けようというのでなくて積極的にそれを利用するというのは愉快だと云って喜んでいた。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、警官の密集を利用しようとする、本能的な且つ職業的な彼一流の計画を忘れて、その小僧っ子に、いつか全幅の考えを奪われてしまった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供に固有な鋭い直観の力を利用しないで頭の悪い大人に適合するような教案ばかりを練り過ぎるのではないかと思われる節もある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文学者はこの機を利用して観測に耽り、詩人宗教家はこの間に星月夜の美観を唱い造化の偉大を頌える事が出来る。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に四十八手を分析したら槓杆の原理のみならずあらゆる力学上の原理の応用が見つかるに相違ない、例えば体量の少ない力士が大きい敵手にぶつかる場合には速度の大小でどれだけの効果があるかという事あるいは敵の運動量を利用して強敵を倒す事など物好きな学者の研究によって明らかになりそうな事である。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船は砂の中へ深く埋れて引卸しの見込みはないが、幸いにその船中に備付けの発電機と一つの汽缶とが無事であったからそのままこれを利用し、海岸まで線を引いて市中を照らしているそうな。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの事を利用して通信の目的を達するに必要な物は、第一に発信所で電波を起す装置、第二に電波をなるべく遠方に達せしめるようにする仕掛け、第三には受信所に達した電波を受取る道具、第四には受取った電波に感じてあるいはベルを鳴らしあるいは符号を書いて電波の来た事を知らせる器械とこの四つが主なものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も普通ないわゆるコヒアラーと称するものは金属の粉が電波を受けると電気をよく通すようになる性質を利用したもので、広く用いられている。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また磁石が電波を受けた瞬間にその磁力を変ずる事を利用したマルコニ式のマグネチック・デテクターと称するものもあって、これはごく遠距離の通信に限って用いられる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを利用したのがすなわちネルンスト灯である。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くして現代の一般女性たちは、内外特殊の研究家の創造発表するものを容易に採り上げて自由に利用するであろう。",
              "citation": {
                "source": "異性に対する感覚を洗練せよ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は四方海に囲まれているから海の幸は利用し尽している筈だが、たった一つフランスに負けていることがある。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械文明は電灯に半透明の硝子を用いるか、或いは間接照明法として反射光線を利用するかによってこの目的を達しようとする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの機会を利用して専売局に敬意を表すると同時に、当事者がますます煙草に関する科学的芸術的ないし経済的研究を進められて、今よりも一層優良な煙草を一層｜廉価で供給されんことを希望する次第である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次の近似だけでもそのつもりで利用すれば非常に有益なものである。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実はトーキー製作者の利用のしかたによっては、いろいろの可能性を生み出すであろう。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在でもすでにかなり利用されてはいるようである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの録音ならびに発音器械の不完全を利用して、近いピストルを遠く聞かせたり、人声を井戸の底から響くように聞かせたりすることも可能になるわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音と光との回折や透過に関する差違はトーキーでもすでにいろいろに利用されている。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象はトーキーでなく無声映画でも利用されうるであろうが、しかしトーキーだといっそう有効に応用されうるわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような能力を何か有益な事に利用したいと思って、くふうした人はあるが、まだあまり成効した人はありません。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが動機となって後にこの荘園内にあった「白鳥池」を利用して水道工事が出来、これが後に水力学の実験に利用されるようになったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この退屈な時間を利用して彼はその名著 Theory of Sound の草稿を書いていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べた「白鳥池」を利用して水力実験室を作り、色々の形の穴から水を流出させるときの孔内の圧力分布を測ろうというのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から中央階段を降りようとする途中で窓越しに東を見ると、地下鉄ビルの照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりようやく薄暗く工夫体の男｜甲走りたる声張り上げて歌い出せば商人の娘堪えかねてキヽと笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
