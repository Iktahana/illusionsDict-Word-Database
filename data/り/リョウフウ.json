    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cool breeze",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "メーツは、ブリッジで、涼風に吹かれながら、ソーファーに眠っていたが、起き上って来て、「どうしたんだ」「左舷に燈台が見えますが」「又、一時間損をしたな」と、メーツは答えて、コムパスを力一杯、蹴飛ばした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場前の百貨店の食堂の窓から駿河湾の眺望と涼風を享楽しながら食事をしている市民達の顔にも非常時らしい緊張は見られなかった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに現れる夏の夕べの涼風は実に帝都随一の名物であると思われるのに、それを自慢する江戸子は少ないようである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えていたのであるが、今年の夏｜房州の千倉へ行って、海岸の強い輻射のエネルギーに充たされた空間の中を縫うて来る涼風に接したときに、暑さと涼しさとは互いに排他的な感覚ではなくて共存的な感覚であることに始めて気が付いたのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊さへなくば夏の夕の月あかき時なんどは、特に川中に一杯を酌みて袂に余る涼風に快なる哉を叫ぶべき価ある処なりといふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、それ自身にははなはだ平凡な光景を思い出すと、いつでも涼風が胸に満ちるような気がするのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べると東京の夏は涼風に恵まれている。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、正常な天候でさえあれば、夕方の涼風を存分に発達させているということがわかったのであった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後｜風呂を浴びて無帽の浴衣がけで神田上野あたりの大通りを吹き抜ける涼風に吹かれることを考えると、暑い汽車に乗って暑い夕なぎをわざわざ追いかけて海岸などへ出かける気になりかねるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズや弁証法的唯物論のはやる都会でも、朝顔の鉢はオフィスの窓に、プロレタリアの縁側に涼風を呼んでいるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日汗水たらして働いた後にのみ浴後の涼味の真諦が味わわれ、義理人情で苦しんだ人にのみ自由の涼風が訪れるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　草市　七月十三日の夕方哲学者のＡ君と二人で、京橋ぎわのあるビルディングの屋上で、品川沖から運ばれて来るさわやかな涼風の流れにしながら眼下に見通される銀座通りのはなやかな照明をながめた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた灸の刺激が一種の涼風のごときかすかな快感を伴なっていたかのごとき漠然たる印象が残っているのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても乗れなくて乗りそこねた数人の不幸な人たちは、三十秒も待った後に、あとから来た車の座席にゆっくり腰をかけて、たとえば暑さの日ならば、明け放った窓から吹き入る涼風に目を細くしながら、遠慮なく足を延ばして乗って行くのである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目にも明るい大きな花が涼風にうなずく。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方浴後の涼風を求めて神田の街路をそぞろ歩きするたびにはこの「初恋」の少女の姿を物色する五十四歳の自分を発見して微笑する。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁う涼風の立つ時分でも、團扇を片手に、手拭を提げなどして、派手な浴衣が、もつと川上あたりまで、岸をちらほらついたものである。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　渠は涼風の来るごとに念仏して、心｜窃かに学生の好意を謝したりき。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝から急に涼風が立つて、日が暮れるともう単衣では冷々するくらゐでしたが、不思議なことにはその晩｜些つともお客が無いんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟橋の涼風が身心をさはやかにしてくれた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明月、涼風、籐椅子、レコード、物みなよろし。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "林房雄トイウ名ノ一陣涼風ニソソノカサレ、浮カレテナセル業ニスギズ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "賑いますのは花の時分、盛夏｜三伏の頃、唯今はもう九月中旬、秋の初で、北国は早く涼風が立ますから、これが逗留の客と云う程の者もなく、二階も下も伽藍堂、たまたまのお客は、難船が山の陰を見附けた心持でありますから。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼ひらけば、小春のごとも麗らかに空晴れわたり、身辺は雑木踈らに、名も知らぬ紅花｜叢咲き涼風の朝吹く汀、砂雲雀優にあがれり。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼風葉を揺かして湲水音を和し、村歌起るところに機杼を聴く。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "同伴はおもしろし、別して月も宵にはあるべし、この夜の清興を思へば、涼風｜盈ちて車上にあり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は涼風のごとく軽くなり、月光のごとく形なく、里見亭の裏二階へ忍んで行きたかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒涼たる焼石の原から、柔かい緑の丘へ、二頭の馬はたてがみで高原の涼風を切る。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰ってみたが、高原の涼風に馴れた身には、いわん方なく暑かった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学二年の夏休みに逗子へ遊びに行つて、夕方養神亭の裏の海岸を歩いて涼風に吹かれて居た時、とある別荘らしい家の門前で思ひもかけず出遭つたのが蓑田先生で、その別荘が即ち先生の別荘であつた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
