[
  {
    "uuid": "1377b863-df0a-51b3-b437-f877171e0e37",
    "entry": "涼風",
    "reading": {
      "primary": "りょうふう",
      "alternatives": [
        "すずかぜ"
      ],
      "is_heteronym": false
    },
    "grammar": {
