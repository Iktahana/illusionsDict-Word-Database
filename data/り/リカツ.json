    "definitions": [
      {
        "index": 1,
        "gloss": "making preparations for a divorce",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
