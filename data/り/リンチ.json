      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beating (inflicted as punishment)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頭の下げっぷりが悪い、生意気な者には、容赦のないリンチが行われた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リンチだ、リンチだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「リンチだ、リンチだよ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでも社員のリンチが行われた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、于、一人に、リンチを加えるだけでなく、工人全体をも嚇かしている意味を知っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、軍隊の到着以来、小山が、気に喰わない工人達に、虱つぶしに、リンチを加えるのを目撃していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンチが度重なるに従って、工人の挙動がおとなしくなってきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき向ふから一列の馬が鈴をチリンチリンと鳴らしてやって参りました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の米国人の中にでも黒人は人間と思っていない仲間があることはリンチの事実が証明する。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、まあ、その中から馬そりの鈴のチリンチリン鳴る音が、やつと聞えるのでやつぱり誰か通つてゐるなといふことがわかるのでした。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、署長室の策戦　次の日税務署長は役所へ出て自分の室に入り出勤簿を検査しますとチリンチリンと卓上ベルを鳴らして給仕を呼び「デンドウイを呼べ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "振売の時、チリンチリンと鳴らすが、似ているからって、風鐸蕎麦と云うんだそうです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話は間断なしにチリンチリンいうと、女は眼を嶮しくして耳を傾ける。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "チリンチリン、鈴をつけているのです。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いフウリンソウと、小さな白いマツユキソウとが、まるで、鈴でも持っているように、チリンチリンと音をたてながらはいってきました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん気をつけてみるとそういう不思議な鳴き方をするのは、ほとんどきまって豆腐屋のラッパが遠くから聞こえてだんだん近よって来るときか、またはたぶん豆腐屋であろうかチリンチリンと鈴を鳴らしながら前を通るときであるらしい。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィクタ・リンチ、偽造犯。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、どんな自信を述べるにしても、それが事実にもとづいてゐなければならなかつたのであるし、また敗戦者は討死をしなければ、リンチに依つて禿鷹の餌食にされたのであるから、詩を綴る間もなかつたのである。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ンナとブリンチ※ルレとの三つの心の活闘も、心理上さう大して深いところまで行つてゐるとは思はれない。",
              "citation": {
                "source": "社会と自己",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからといって、野蛮なリンチは許しがたい」　と、舎監が憤慨する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみたちがやったことは、理由はどうあれ、きたないリンチだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは『雨月物語』をやりにきたんだ」　慶一はボディブロウをくりだしたが、クリンチ状態のせいで、あまり威力はなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリンチ川の小さな支流に臨むカンバランド山脈の低い支脈の上に在る。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来、このあたりでは村人の反感を買つた人物は屡々この「担がれる」なる名称の下に、世にも惨澹たるリンチに処せられた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの戦慄すべきリンチは、季が熟したとなれば祭りの晩を待たずとも、闇に乗じて寝首を掻れる騒ぎも珍らしくはない。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と睨んでゐた折からだつたので、これが条件として執りあげられ、やがてリンチの候補者に指摘されるに至つたらしいのであるが、私として見るとそれ位ひのことで狙はれる理由にもならぬとも思はれた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来、このあたりでは村人の反感を買った人物はしばしばこの「担がれる」なる名称の下に、世にも惨澹たるリンチに処せられた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの戦慄すべきリンチは、期が熟したとなれば祭の晩を待たずとも、闇に乗じて寝首を掻かれる騒ぎも珍らしくはない。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
