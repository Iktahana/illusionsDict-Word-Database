        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「いやいや、大して違ひはありますまい」と語尾を上げて、爺々ィが云つた、「音羽屋の方が所作はうまいかしれないが、ハリマ屋の方はスゴミがあるツ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨク来タト申シタイアナタノ可愛イ手紙、今朝参リマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママサマ、少シモアブナイ事ハアリマセン。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一雄ハ深イ所デ泳イデモ危イコトハアリマセン。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年私ハ、小サイタライノオ風呂ニ二三日ゴトニ入リマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝成田様ノオマモリガ参リマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "パパハ乙吉ニヤリマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "海デ沢山遊ビ黒クナリマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナストウリ、モノサシトハサミ、カガミガアリマス、イケニフネ……」大急ぎでそれだけ読んだが、そこで息が切れた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が笑ったら、子規は、いや本当にそう思ったのだから面白いのだと云って虚子のリマークを弁護したのであった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニハカニ　クラク　ナリマシタカゼガ　ゴウゴウ　フイテキテアメモ　ザアザア　フリマシタ　春の夕立ちは、珍しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユフダチ　ヤムノヲ　マツウチニツカレガ　デタカ　オヂイサンイツカ　グツスリ　ネムリマスオヤマハ　ハレテ　クモモナクアカルイ　ツキヨニ　ナリマシタ　この月は、春の下弦の月である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりの皮肉屋であったが、ときどき面白い観察の眼を人間一般の弱点の上に向けて一風変ったリマークをすることがあった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その羅宇屋が一風変った男で、小柄ではあったが立派な上品な顔をしていて言葉使いも野卑でなく、そうしてなかなかの街頭哲学者で、いろいろ面白いリマークをドロップする男であった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「シリマセンネエ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「オクサンアリマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば日本の「アソ」、「ウス」、「オソレ」、「エサン」、「ウンセン」等に対してカムチャツカの「ウソン」、マリアナ群島の「アソンソン」、スマトラの「オサール」などがあり、またわが国の「ツルミ岳」、「タルマイ山」、「ダルマ山」に対しジャヴァの「ティエリマイ」、「デラメン」などがあるという類である。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……カエリマス」　この言葉が、あるじの胸を打った。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノ裏ニハキット墓地ガアリマス。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外、庭ノ黒土ヲバサバサ這イズリマワッテイル醜キ秋ノ蝶ヲ見ル。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対する教授の電光のようなリマークは「ヤ、貴様食ったな」というのであった、と伝えられている。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれてはじめて見た人形芝居一夕のアドヴェンチュアのあとでのこれらの感想のくどくどしい言葉は、結局十歳の亀さんや、試写会における児童の端的で明晰なリマークに及ばざることはなはだ遠いようである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はやっぱりにこにこして、何か一言ぐらい鋭いリマークをされて、そうして、それきりでゆるしてくださるであろうという気がするのである。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、プリマドンナは、自分が出るときは、赤い照明にしてもらいたい、それが、自分にはよく似合うのだから、と言いました――そして、青い照明ではいやだ、と言うのです。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、そいつどもの居る室に案内をしろ」「カ、カシコマリマシタ」　と、宿屋の主人はガタガタふるえながら立ち上って、階段を先に立って上りました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
