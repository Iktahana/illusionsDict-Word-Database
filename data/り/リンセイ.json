          "literary": [
            {
              "text": "総領事セワードはジェンキンスの報告に基づいて、本国政府に、自己を朝鮮開国交渉特使に任ぜられたいと禀請した。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方そもそもジェンキンスの報告に基づいてセワードが本国に禀請して成った対朝交渉案の実行を、公使ロウが大事をとってなかなか動かないので、セワードとしてはあせり気味の折でもあった。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
