[
  {
    "uuid": "a07d0b16-28af-506e-bf8d-4604d00fa1aa",
    "entry": "流弾",
    "reading": {
      "primary": "りゅうだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
