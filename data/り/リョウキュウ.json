[
  {
    "uuid": "84697dbc-b99a-5ce9-be92-5a7cb3556134",
    "entry": "良久",
    "reading": {
      "primary": "りょうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
