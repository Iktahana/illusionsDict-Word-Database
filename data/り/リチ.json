  {
    "uuid": "845b97e6-1413-5b94-ad0c-54fed3a8b815",
    "entry": "理致",
    "reading": {
      "primary": "りち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reason",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ですから一人もお客様がお見えにならないと手前が自分でサクラになってノソノソ降りて行きまして、本棚なぞを整理致しておりますんで……これがマア商売のコツで御座いますナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客さま、すぐに処理致します。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の言葉も、東京の言葉と、あまりちがはないやうである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "童話と教育について萩原朔太郎　近頃の子供たちの悦ぶ童話は、昔とすつかりちがつたといふ説がある。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と下女とをかわるがわる手伝いにやっていたが、立入って世話しているとまた癪にさわる事が出来て、罪もない妹に当りちらす。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に自分でも他人の書いたものを読んでいてそういう場合に出逢うとやはりちょっとそんな気がするようである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいこれに限らず彼の考える事、する事はたいがい人よりちょうど一時代だけ後れているようである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は自分などのやうに、うるさく騷がしい都を離れて、しばらく疲れた頭を休める爲にかういふ山中の自然を索ねて來るものゝある一方では又、東京では斷ち切れない色々の窮屈を束縛をふりちぎつて、一日だけ、はめを外づして暴れ※はる爲にわざ／＼かういふ土地を選んで來る人もあるのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きいどんぐり、ちいちゃいどんぐり、みいんな利口などんぐりちゃん」と出たらめの唱歌のようなものを歌って飛び飛びしながらまた拾い始める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、改良美濃紙の復刻本であったが、原図の菱川師宣のあの暢艶で素雅な趣はちらりちらり味えた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "波から来る光の網が、底の白い磐の上で美しくゆらゆらのびたりちゞんだりしました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の網はゆらゆら、のびたりちゞんだり、花びらの影はしづかに砂をすべりました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の山には他所の多くの山の概念とは少しばかりちがった色々の特徴があって面白い。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち甲はＡの眼を少し大きく見過ぎている代りにＢの眼を少し小さく見過ぎている、そのために実際はかなりちがった大きさと形をしたＡＢの眼が似ているように思われるということも可能である。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子細は、其主人、自然の役に立ぬべしために、其身相応の知行をあたへ置れしに、此恩は外にないし、自分の事に、身を捨るは、天理にそむく大悪人、いか程の手柄すればとて、是を高名とはいひ難し」とはっきりした言葉で本末の取りちがえを非難している。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンの栄華も一輪の百合の花に及ばないという古い言葉が、今の自分には以前とは少しばかりちがった意味に聞き取られるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏝で勢いよくきゅうとなでて、ちりちりぱっとくくりをつけて、パイプをくわえて考え込んで、モンパリー、チッペラリー、ラタヽパン。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然全體のいとも見事な樂しい調和に存するところの眞の精神的愉悦を取りちがへぬやうにと、私が自分の仕事に先立つて、まづ、素直に、純粹に、苛立たず、亢奮することなく、生者として（en vivant）一切の準備をするのは、それがためなのです。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて初めに書いたやうに初めて麻雀牌を見て、その牌音を聞いたといふだけなら、僕は近頃の麻雀隆盛にいさゝか先駈けするものだつたが、初めて牌を手に入れたのは大正十四｜年の秋で、それから誰に教はるともなく次第に習ひ覺えて、去年あたりちよつとその熱病期だつたとも言へる。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喇叭も吹く、斯くて棧道にかゝつてから第一の停留所に着いた所の名は忘れたが此處で熱海から來る人車と入りちがへるのである。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優のうちに久米五郎とて稀なる美男まじれりちょう噂島の娘らが間に高しとききぬ、いかにと若者｜姉妹に向かっていえば二人は顔赤らめ、老婦は大声に笑いぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "年じゅう同じように貯蔵した馬鈴薯や玉ねぎをかじり、干物塩物や、季節にかまわず豚や牛ばかり食っている西洋人やシナ人、あるいはほとんど年じゅう同じような果実を食っている熱帯の住民と、「はしり」を喜び「しゅん」を貴ぶ日本人とはこうした点でもかなりちがった日常生活の内容をもっている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "強姦でも、強盗でも、窃盗でも、自分の経験を大ッぴらに喋りちらした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、工人達が頭薬をこぼすと口ぎたなく呶鳴りちらした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は、やはりちびり／＼土地を買い集めていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことしたら、あの奥さんとこへ行って、何もかも喋くりちらしてやるから。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叔父は、磨りちびてつるつるした縁側に腰を下して、おきのに訊ねた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコはもう大悦びでそれをにがにがならべて見ていましたがふと算術帳と理科帳と取りちがえて書いたのに気がつきました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、私｜共の眼に感ずる光の波長は、　　　　　　　　　　〇、〇〇〇七六｜粍　　（赤色）　　乃至　　　　　　　　　　〇、〇〇〇四　粍　　（菫色）　　ですからこれよりちいさなものの形が完全に私｜共に見えるはずは決してないのです。",
              "citation": {
                "source": "手紙　三",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまもなく小さな小さな乾いた雪のこなが少しばかりちらっちらっと二人の上から落ちて参りました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
