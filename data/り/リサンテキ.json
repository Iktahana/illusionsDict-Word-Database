          "literary": [
            {
              "text": "永い間集合的な諸力の支配を受けていた期間と入れ代って今度は離散的諸力の旺盛な永い期間が続く。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし物理学者の方では、スペンサーの要求しているような離散的な力のいかなるものをも実際に見い出さなかったので、彼の言葉は誰も注意しないでそれ切りになっていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、一家離散的面も複雑になって来ている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
