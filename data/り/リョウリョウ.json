[
  {
    "uuid": "e238c2a9-e3f4-5218-bfd7-b6a700583b0d",
    "entry": "両々",
    "reading": {
      "primary": "りょうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
