[
  {
    "uuid": "10bcc7d6-5eee-5b07-bf4e-392c180066a9",
    "entry": "僚友",
    "reading": {
      "primary": "りょうゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
