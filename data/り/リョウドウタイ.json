    "definitions": [
      {
        "index": 1,
        "gloss": "good conductor (of heat, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
