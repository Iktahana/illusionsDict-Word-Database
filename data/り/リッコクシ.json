        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六国史などを読んで、奈良朝の昔にシナ文化の洪水が当時の都人士の生活を浸したころの状態をいろいろに想像してみると、おそらく今の東京とかなり共通な現象を呈していたのではないかと思われることがしばしばある。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六国史」を読んでいると現代に起こっていると全く同じことがただ少しばかりちがった名前の着物を着て古い昔に起こっていたことを知ってあるいは悲観しあるいは楽観するのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の『六国史』は帝家の旧記にして、華胄の旧記、諸記録は主としてその家々のことに係る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外が董督した改訂｜六国史の大成を見ないで逝ったのは鴎外の心残りでもあったろうし、また学術上の恨事でもあった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "学は仏、儒、老、荘、国典等に渉りしが、就中、唯識、六国史、万葉集、古今集、韻鏡等に精通せり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教的行動に出られる時の心持ちは、さうした側に冷淡な六国史流の記述では知られない。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝書籍目録などの分類によると、帝紀の項に、旧事本紀・古事記から、六国史及び、日本紀私記其他雑史書類までも収めて居る。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て彼の「東北日記」の原稿を見るに、その表紙の裏面に、細字を以て『六国史』云々と乱抹せるものあり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰来急に『六国史』を取ってこれを読み、古の聖君英主海外蛮夷を懾服したるの雄略を観て、慨然として曰く、「吾今にして皇国の皇国たる所以を知れり」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "また水戸『日本史』の後もこれ無く、天朝『六国史』の後も闕く。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、院中へ史局を設け『六国史』以下の闕を補う事。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "前代というならば、せめて『六国史』が京都の周囲に払ったのに劣らない注意力を、全国に払ってからにしてもらいたい。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま元禄四年までに、やっと出来あがっているのは修史義例、彰考館総目録、それと光圀が自分で筆を入れた六国史と跋ぐらいなもので――かれが胸中にもっている全体の構想からいえば、まだまだ、その下準備と、一部分の脱稿を見たというだけで、あと何十年かかるか、何代かかるか、見とおしもつかないほどだった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『六国史』などを注意して読んでみると関門を通りぬける技術というものが発達したあとがわかるような気がする。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
