          "literary": [
            {
              "text": "写したいと云えば、写す為めの謝料を取ると云うのが、先ず山本の家の臨時収入で、その一切の砲術書を貸すにも写すにも、先生は眼が悪いから皆私の手を経る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロク　　いや、それは、侮辱を受けた公職者の臨時収入だ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒサ　　それで臨時収入をふやされちやかなはねえや。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ印税の臨時収入がある。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に二回号外が発行されることもあって、忙しいことも忙しかったが、臨時収入も相当あった。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
