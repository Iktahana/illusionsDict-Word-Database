        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひとりはリーダー格の峰岸、もうひとりは慶一だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸山は、この少年団のリーダー格であった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "篁という、六人のリーダー格の男が、ゆっくりと顔を上げると、どっしりと幅のある声で、いった。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人二人、案内や人夫五人、合計七人にリーダー格として、大町、針ノ木峠、平、刈安峠、佐良峠、五色ヶ原、立山、剱、祖母谷、大黒という当時としてはかなり大きな旅行を済ませたばかりであるのに、二人の友人が東京へ帰るのを見送ると共に、また山に入ったのだから。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
