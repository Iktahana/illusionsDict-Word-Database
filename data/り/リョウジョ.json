    "definitions": [
      {
        "index": 1,
        "gloss": "consideration (for someone's circumstances)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうか御諒恕を願ひます。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "（知名の人に関係がありますので文中の固有名詞を符号にしたことを御諒恕願います）",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏名なども間違っている人があるかも知れないが筆者の記憶の粗漏として諒恕御訂正を仰ぎたい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ粗漏｜蕪雑のまま大体を取纏めて公表を急がなければならなくなった筆者の苦衷を御諒恕の程幾重にも伏願する次第である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの高齢、高徳の士、不世出の国粋芸術家梅津只圓翁の真骨頂を世に伝えたい微衷に他ならない事を御諒恕賜わらば幸甚である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "希くハ諒恕せられん事を。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪からず諒恕して頂きたい。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため貴殿にも何事も洩らさず同婦人に自由行動を執らせ候段、何卒不悪御諒恕賜わりたく、貴殿の御骨折に対しては警察当局も感謝｜致居候。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と共に、このことを読者にも諒恕して貰いたい。",
              "citation": {
                "source": "「草野心平詩集」解説",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは預め諒恕を願って置く。",
              "citation": {
                "source": "後立山は鹿島槍ヶ岳に非ざる乎",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文との多少の重複は、諒恕していただきたい。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員生産部長横山喜代治氏及び島本彦次郎氏等を始め、多くの社員各位の芳名を挙げて一々その誠意に対して感謝の意を捧げたいのであるが、却って煩にすぐる嫌なきかを恐れて簡省に致したことを諒恕せられたい。",
              "citation": {
                "source": "『言林』跋",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家の存立上、各々その国に於てある度にまで関税を課せざるべからざる事情の有る事は諒恕せなければならぬ。",
              "citation": {
                "source": "永久平和の先決問題",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の不備は諒恕を仰ぐほかはない。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのかかる徒然めいた少年時代の記も、思わず長くなって恐縮しているが、ま、あと二、三章を以て結ぶつもりであるから、併せて諒恕を希っておく。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語過程説を詳説せずに、論を進めたことは、この学説に全然未知な方々を少からず、当惑させたことと思ふのであるが、これまた、止む得なかつたこととして御諒恕を乞ふ次第である。",
              "citation": {
                "source": "国語学と国語教育との交渉",
                "author": "――言語過程説の立場における――",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子のご諒恕を仰いでおく。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠も、孝も、共に現代の青年にはただ漫然たる忠孝の文字だけがあつて、清新溌剌な將來への精神文化の信念でなくてはならないと思ふが、それに對して、この書がまだ及んでゐないことは御諒恕を乞はなければならない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご諒恕をねがいたい。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者のうちには毎日の新聞を切り抜き綴込みとして保存しておられる方もあると聞くので、ご不審を感じるさいもあろうかと、うちあけてお断わりとご諒恕をねがっておく。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御諒恕をねがいたい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者が夏の風邪ギミみたいな錯覚に襲われない要心に、まず、御諒恕を乞うというわけ。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
