[
  {
    "uuid": "4eca548d-f4ae-5379-a3a2-24e3fd55e468",
    "entry": "悋気",
    "reading": {
      "primary": "りんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
