      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "jealousy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悋気といういまわしい言葉に絶えずおびやかされながら、ひそ／＼声でお君をのゝしるのだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて、こんな時にこそ焼きもちを焼いてもらうために望んでめとった女房ではあったが、さて、実際こんな工合いに騒がしく悋気を起されてみると、あまりいい気持のものでない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "養父母の気にいられようと思って、悋気の強い女房こそ所望でございます、などと分別顔して言い出したばかりに、これは、とんでもない事になった、と今はひそかに後悔した。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた、その戻りに衣川の宿場を通ってうっかり、夜明しの茶屋などに寄って往くまいものでもなし――』源兵衛『あきれた悋気おんなだ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よっぽど悋気深い女だよ」と、妻は僕に陰口を言ったが、「奥さん、奥さん」と言われていれば、さほど憎くもない様子だ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先の辰さんの家で、ほほほほほ」　いくらか法界悋気もまじって女房はこんな秘密までもべらべらしゃべった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな女ですから、前の男の元吉に未練もなく、元吉の方でもそのあとを追いまわすこともなく、その方はおたがいに忘れてしまって、なんにも面倒はなかったんですが、ただ面倒なのは今の主人の其月で、これがなかなか悋気ぶかい男。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "御心配でせう」「私は悋気で言ふ訳ぢやない、本当に旦那の身を思つて心配を為るのですよ、敵手が悪いからねえ」　思ひ直せども貫一が腑には落ちざるなりけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば悋気深い女房に折檻されたあげくの果てに、去勢を要求された場合には、委細承知は仕れど、鰻やスッポンと事異なり、婦人方の見るべき料理でない。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本妻の悋気と饂飩に胡椒はおさだまり、なんとも存ぜぬ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恋も悋気も忘れていたが」という、その一句のなかには、迷いの世界と、悟りの世界が示されています。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち恋と悋気の世界は、つまり迷いの世界です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが恋もなく悋気もない世界は、悟りの世界です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋に泣き、悋気に悩むその声です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇の考では皆｜法界悋気で善く言わぬのだという。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「色だ、ナニ夫婦サ」と法界悋気の岡焼連が目引袖引取々に評判するを漏聞く毎に、昇は得々として機嫌顔、これ見よがしに母子の者を其処茲処と植木屋を引廻わしながらも片時と黙してはいない。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の親切５・10（夕）　むかし津山藩主の何とかいつた奥方は、余程｜悋気深い性だつたと見えて、殿の愛妾を縊め殺した上、太腿の肉を切り取り、それを羹にして何喰はぬ顔で殿が晩酌の膳に上しておいた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "悋気も女はつつしむべし、と荷風には考えられており、女に悋気せしめる男の側のことは触れられない。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たり賢しと、悋気深い手合がつまらんことを言い触して歩きます。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "四には悋気深ければ去る。",
              "citation": {
                "source": "三つの「女大学」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四悋気深ければ去ると言う。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を称して悋気深しと言うか。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水調子から意味の通じる所を拾つて見ると、逆事の手向けをする父親の歎き、なじみの人を無理にせいた悋気妻のあつたこと、其から最後の文句は後世までも鑑として残る。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未練のあるうちよ、そんなもなア」　振り切ろうとする袖をいよいよ、堅くとらえてお吉は放さず、「わしゃもういわぬ、悋気はいわぬ、あくどくいったこれまでの厭味、堪忍しておくれよ九十郎さん！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみねは込上る悋気を押え、夜延をして伴藏の帰りを待っていますと、伴「文助や明けてくれ」文「お帰り遊ばせ」伴「店の者も早く寝てしまいな、奥ももう寝たかえ」　といいながら奥へ通る。",
              "citation": {
                "source": "怪談牡丹灯籠",
                "author": "怪談牡丹灯籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦は三世という縁合のものですから少しの悋気ぐらいで私ア出て往くから一本お書きなんて、全体女が男に一本かけなんと云うのは可笑しいわけでございます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "決してりんきらしい様子を見せないでね。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が、決して、りんきやあてこすりで麗姫に逢えと云うので無いことは判り過ぎるほど判って居た。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋か、りんきか、知らねども、ほんに未練な薄あかり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても、けふ日のわがこころりんきせうとてひとり寢る。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
