[
  {
    "uuid": "c17bf816-3710-50c9-b9fb-850122128a37",
    "entry": "梁木",
    "reading": {
      "primary": "りょうぼく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beam",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その血しぶきは今でも梁木の胴腹に黒ずんで残っている。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井がないので真黒な太い梁木が縦横に渡されて見える。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも春から秋の間は蛇が梁木を渡るので鼠が比較的少ない。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は梁木を渡れといふ渡らぬといふ。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁木といふとあの高い橋のやうなのがさうだ。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十二階段、平行棒、飛越台、木馬、棚、幅飛び、棒飛び、梁木、遊動円木、天秤台、機械体操、射撃場、名前は忘れたが、穴の上に丸太が渡してある処――その上で二人の者がそれぞれ一本の腕で争ひ穴の中へ落し合ふ場所である丸太橋――。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――梁木渡り、幅飛び、棒飛び、……何れも悉く見物を感心させぬものはなかつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプの丸い影が天井の裸の梁木に光の輪をうつした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "中學生のころ、體操の時間に、高い梁木を渡らされるのが、この上もなく恐ろしかつた。",
              "citation": {
                "source": "恐怖について",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁木に昇らされる日は、（今日は、やるナ）と時間の始めに直ぐに感じたほどだつた。",
              "citation": {
                "source": "恐怖について",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブル／＼と上へ昇つてみると、鼠色のペンキを塗つた幅の狹い梁木が、もう半ば腐りかけてゐた。",
              "citation": {
                "source": "恐怖について",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に与えられた勉強部屋は屋根裏の、大きな梁木のむき出しになった凡そ美というイデーとかかわりのないものであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、兄の組は体操の時間に高い梁木の上を渡らされた。",
              "citation": {
                "source": "青草",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、半ばまで来ると、不意によろめいて、くくり猿のように梁木にしがみついた。",
              "citation": {
                "source": "青草",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はそれにはかまわずにも一度梁木の上に立ち上った。",
              "citation": {
                "source": "青草",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして兄は残りの時間じゅう、梁木の下に立たされたのだという。",
              "citation": {
                "source": "青草",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スラヴォニアはユーゴスラヴィアの一地方【イタリアの背】アペンニノ山脈【生くる梁木】森の樹木八八―九〇【陰を失ふ國】アフリカ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度教員は忿怒して学校の梁木にその童子をつるして折檻したことがある。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、次の日にその童子を学校の梁木に吊して、鞭で続けざまに打つてみんなに見せたのであつた。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月九日偽善者よ、先づ己の目より梁木をとれ、さらば兄弟の目より物屑を取得るやう明かに見べし。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛より重い古びた梁木どたりと壁土がとどめをさし、外は奇妙な灰色のぶざまにへしゃげた屋根の電線の網の人くさくて人の絶えた何里四方かの死寂。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが却つて、相持ちで、さしては見たが時雨がさ、気はあせれども足はふらふら、と歌の文句にある通り、眼中の梁木となり、ろくに何も出来ないくせに何だかあたりの空気が気に入りません。",
              "citation": {
                "source": "私のこと",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわれたとおりにいっぱいに窓をあけて、眼の下のコンクリートの中庭を見おろすと、遠い塀際の梁木に、褌一つになった孝助が、手首を繩で括られ、振り分けになってぶらさげられているのが見えた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を、と思いつつ、山内は双眼鏡を持って窓へ行き、梁木のほうを見なおすと、なるほど似てはいるが、孝助ではなかった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
