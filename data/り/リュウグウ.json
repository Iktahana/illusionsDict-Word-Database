[
  {
    "uuid": "6af8180e-9a36-52f2-b0fc-1052e64dea41",
    "entry": "竜宮",
    "reading": {
      "primary": "りゅうぐう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
