[
  {
    "uuid": "1d0c7f4a-71f1-50b8-afaf-ab0d51ceaf40",
    "entry": "陸上",
    "reading": {
      "primary": "りくじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
