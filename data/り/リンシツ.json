[
  {
    "uuid": "a3df4706-98f6-57f0-b56e-ed093619f230",
    "entry": "隣室",
    "reading": {
      "primary": "りんしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
