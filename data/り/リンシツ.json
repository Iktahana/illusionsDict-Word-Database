    },
    "definitions": [
      {
        "index": 1,
        "gloss": "next or adjoining room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正面壁右隅に隣室に通ずるドアあり。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくして、何だか堪らないやうに隣室に行く）男　「可愛くもあり、可愛くもなし」………あゝさうか、あれは「鴎」の中の台詞だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ声がして、女の啜り泣が始まる）（男、ドアの所まで行つて隣室の中をみる）男　もう仕度は出来てゐたのか。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符賣る家の闇きらんぷの火影に見れば、先きほど隣室にてなやみし、醉ひしれたるをのこなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の庭に向いた方の鴨居に水彩画が一葉隣室に油画が一枚掛っている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなれば宿帳つけに来し男の濡れ髪かき分けたるも涼しく、隣室にチリンと鳴るコップの音も涼しく、向うの室の欄干に倚りし女の白き浴衣も涼しげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を拍ちて床をのべさせ横になれば新しき浴衣の肌さわりも快く、隣室の話声遠きように聞えし後は魂いずこへか飛んで藻ぬけの殻となり電燈消しに来し事もいつか知らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと團體の靜まる頃には隣室へ子供づれの客が着いた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代が宿入りの夜など、木枯らしの音にまじる隣室のさびしい寝息を聞きながら机の前にすわって、ランプを見つめたまま、長い息をすることもあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　ある食堂の隣室に自働電話の自働交換台がある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場で悪漢が密談している間に、隣室で球突きのゲームをとる声と球の音が聞こえている。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれだけ涙が出たか、隣室の母から夜が明けた様だよと声を掛けられるまで、少しも止まず涙が出た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室の階下が工場で、その隣室の「学校部屋」に棚を吊って薬品をならべた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「へえ」　隣室の石松と七五郎が面喰った。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の襖を開いて左衛門と七兵衛が覗く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝隣室　入って来た主人。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室からルーレットの玉の転げる音が、悪魔の囁きのように妾の耳に響いて来ました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達はそれに誘われるもののように立上ると、隣室の賭博場へ這入って行きました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の踊場のジャズ・バンドが気狂のように太鼓をたたいた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌『流行』の宣伝部長のカリタは、ミサコを自室に案内すると、隣室の同棲者に三人の食事を云いつけた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　田村スマ子女史が眼覚めると、隣室で仕事をしていた「彼氏浮気もの」が、――やあ、お眼ざめですか、親愛な女史よ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とばあさんは隣室へ聞えないように声をひそませながら云った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに両人は隣室にいる大佐に気がねして、長く横たわることもよくせずにちぢこまっていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の話声に耳を傾けた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この放電のために特別に設計された高圧直流発電機の低いうなり声が隣室から聞こえて来る。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵が来て「可能的悪漢」と話していると、隣室から土人娘の子守歌が聞こえる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオナルド・ダ・ヴィンチが画を描く時に隣室で音楽を奏でさせたという話があるが、これももちろんただ音楽の雰囲気だけを要求したものに相違ない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うしろから、わく／＼しながら眺めていたお仙は、何を云うともなく支那語をくりかえして隣室へ立った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "２２＝隣室　お兼、敬四郎のとめるのもきかず箪笥から着物を出します。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
