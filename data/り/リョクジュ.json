    "definitions": [
      {
        "index": 1,
        "gloss": "green-leaved trees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
