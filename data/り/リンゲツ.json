    "definitions": [
      {
        "index": 1,
        "gloss": "final month of pregnancy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
