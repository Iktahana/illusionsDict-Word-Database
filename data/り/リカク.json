    },
    "definitions": [
      {
        "index": 1,
        "gloss": "isolation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は従来の風景論者のように、火山ばかりを抽き出して、他の山岳から離隔して、それを特色とすることを好まない、またこの頃の一部の若い人たちのように、日本アルプスからとかく、火山を継子扱いにして扉の外に突き出すことにも、与みされない。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は文学なる者をして何時の時代に於ても、必らず政治と離隔せしめざるべからずと論ずるものにあらず。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光を遮断する鉄塀は比しく彼女をも我より離隔して、雁の通ふべき空もなし、夢てふもの世にたのむべきものならば、我は彼女と相談る時なきにあらず、然れどもその夢もはかなや、始めに我をたばかりて、後にはおそろしき悪蛇の我を巻きしむるに終る事多し。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年学校生徒や士官候補生に特別の軍服を着せ、士官候補生を別室に収容して兵と離隔し身の廻りを当番兵に為さしむる等も貴族的教育の模倣の遺風である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光は自分の心に不可抗な不安と離隔と、一切を知るものの寂しさを感じて来たからだった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "法規上避病院は設けられてゐても、監視は行き屆かないから、離隔されてゐる者も近くにゐる漁船に乘つてこつそり歸つて來たり、あるひは若い男だと泳いで歸つて來たりするのだつた。",
              "citation": {
                "source": "避病院",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者の間には自然の造った溝があって、御互を離隔していた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上家が流されたのがどこで、宝物を掘出したのがどこか、まるで不明なのをいっこう構わずに、それが当然であるごとくに話して行く様子が、いかにも自分の今いる温泉の宿を、浮世から遠くへ離隔して、どんな便りも噂のほかには這入ってこられない山里に変化してしまったところに一種の面白味があった。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がホテルの寝床からそのまま父の輸出綿花事務所へやってくると、夜の疲労をぬりかくした、濃化粧したタイピストが電話機の電鍵を敲くように、昨夜の記憶を白紙にうずめていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい顔ばかりでなく、静物でもなんでも、あまり輪郭をはっきりかくと絵が堅すぎてかえって実感がなくなるようである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉の裏だけがじりじり枯れて虫に食われているのだが、それをこっそりかくして置いて、散るまで青いふりをする。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（隣の部屋から画箱を持ち出して捜しながら歌う）「一本ガランスをつくせよ空もガランスに塗れ木もガランスに描け草もガランスに描け天皇もガランスにて描き奉れ神をもガランスにて描き奉れためらうな、恥じるなまっすぐにゆけ汝の貧乏を一本のガランスにて塗りかくせ」村山｜槐多も貧乏して死んだんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、森はみどりの色をしていて、木の枝と枝とのあいだに、見えたりかくれたりするさかなたちは、美しい、高い声で、楽しい歌をうたうということも、ふしぎに思われました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもりとした大きな森のあいだには、お城や農園が見えたりかくれたりしています。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで、モミの木は、すっかりかくれてしまいました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ひらたい地図みたいになって、やがて、霧と雲の中に、すっかりかくれてしまいました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今の世の人、神の御社は寂しく物さびたるを尊しと思ふは、古の神社の盛りなりし世の様をば知らずして、ただ今の世に大方古く尊き神社どもはいみじくも衰へて荒れたるを見なれて、古く尊き神社は本よりかくあるものと心得たるからのひがごとなり。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯のあいだにかくした手紙、出したりかくしたりして、立ったまま、たいへん考えました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子のダンナサン何故へんな画ばかりかくんでしょう。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は林檎の香のごとくしみじみとふる、さくさくと、扉を透かしてふる雨はVerlaine の涙雨、赤いコツプに線を引く、ひとり顫へてふりかくる辛い胡椒に線を引く、されば声出す針の尖、蓄音器屋にチカチカと廻るかなしさ、ふる雨に酒屋の左和利、三勝もそつと立ちぎく忍び泣き。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜孟宗の図竹林幽居ひとりかくれた篁に茗荷もしろく香ににほふ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌照る日には傘を干し竝め雨ふれば提灯に紅き牡丹｜描きける柳河風俗菱採りはか揺りかく揺り桶舟に両手掻きしてその菱堀を菱売は久留米絣の筒袖に手も脛も黒く菱やとふれ来る飛翔篇太刀洗飛行場昭和三年七月二十二日、午後一時十分、愈※一期の郷土訪問飛行を決行せむとす。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき湿りかくて湿らば、竹煮草、葛、蕗の薹ややややにすずろき出でむ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい水彩画と、ピカソの絵葉書、その脇には圭子自身の製作らしい麻布に葡萄の房のアプリケが、うすよごれた壁をすっかりかくしていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒じやと言ひたいが、やはり貴方が自ら作せる罪の報で、固よりかく有るべき事ぢやらうと思ふ」　宮は俯きてよよと泣くのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから事に託して他の一、二家に入って見るとやはりかくのごとし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "騾の牝が他の馬種と合いて、子を産んだ事は時に聞くも、少なくともこの数千年間、無数の騾を畜うた内、牝牡の騾の間に子生んだ例あるやは極めて疑わし、故に馬属の諸種は現時｜相雑わって子あれども、その子同士で繁殖し行き得ぬ世態にあると、『大英百科全書』から受け売りかくのごとし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に挙げたヘラクレスのごとく自分の血統を重んずる一念よりかく行うた者ありて、自分の血統を重んずる一事が人畜間の距離絶大なるを示す所以だから。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる立派なる家に住まひながら、何を苦しんで盜賊とはなりけるぞといぶかれば、否とよ、初めよりかく家が立派なりしにあらず、盜みたる金にて建てたるものなり。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　周子は、用箪笥から、手の平に握りかくせる程小さな、古いオペラ・グラスを取り出して彼に示した。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
