[
  {
    "uuid": "1af358d8-3ae9-586b-9c7c-86e41a0e90b4",
    "entry": "離隔",
    "reading": {
      "primary": "りかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
