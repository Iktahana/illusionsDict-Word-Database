[
  {
    "uuid": "8deabf74-d02e-5209-8acb-c13a0de06ec3",
    "entry": "両方",
    "reading": {
      "primary": "りょうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
