    "definitions": [
      {
        "index": 1,
        "gloss": "gain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は学生に向っても、常に奢侈を戒めて質素を説き、生活を簡易化することの利得を説いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論深草を尋ねても鐙はなくって、片鐙の浮名だけが金八の利得になったのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶工の得た名声や利得が大きければ大きいほど、こういう事件の持ち上がる確率が大きいようである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いかにも戦時利得者らしい声を出していた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には自分になまじい物質的な利得ばかりを与えながら昔日の尊敬を忘れ去り、学商呼ばわりする世情を、気狂いのようになって悲憤慷慨することもある。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も知らぬ顔して、おのが利得にならぬことは指一ツ動かさず、ぬっぺりと世を送りくさって、みずから手は下さねど、見す見す正道の者の枯れ行き、邪道の者の栄え行くのを見送っている、癇に触る奴めらが世間一杯。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其品を御持になったればとて其方様には何の利得のあるでも無く、此方には人の生命にもかかわるものを……。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論深草を尋ねても鐙は無くつて、片鐙の浮名だけが金八の利得になつたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "開業｜当初に、僥倖にも、素晴らしい利得があった。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度の、どか利得が大穴になって、丸髷だけでは店が危い。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聴いていますと、瀬戸物町の店で大きな商取引がある傍に、そのこぼれのような微細な商取引があり、番頭格にもなれば少しの資金を都合して来ればこれを引受けて自分の利得にするのを店でも大様に黙許している。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ厭世家は此世に属する者とし言はゞ名誉にもあれ、利得にもあれ、王者の玉冠にもあれ、鉄道王の富栄にもあれ、一の希望を置くところあらざるなり、故にこの世の希望と厭世家とは氷炭相容れざるの中なる可し。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は利得の故に教会に結び、或は逆遇に苦しみて教理に帰依す、是の如きは今日の教会にめづらしからぬ実状なり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし夫れ人間の本性が全く教理を認めたるものならば、或は利得を取り或は帰依をなす元より自由にてあれど、苟くも其発心の一瞬間に卑劣なる慾情の混り居らば、其教会の汚濁、実に思ふべきなり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、賽銭寄進物の多少によってその御利益の程度を暗示して、利得を計ったものと思うが、どうか？",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の財産を投げ出しても、病人を救うのが医者の任務と心得まして、利得を計ったことは御座いません。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「竹駒稲荷の效験顕然なる事を知らせることは、間接にもしろ、被告自身の利得を計っているではないか？",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原平三に、重クロム酸加里を混入せる酒を呑ましめたることも、自分の利得のための殺人として情状酌量の余地なし。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし倶楽部からの除名と云うことは、その骨牌の不正利得で生活しているモラン大佐にとっては、まさしく身の破滅である。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでモラン大佐は、アデイア青年が、相手の不正行為のために、誤魔化された利得の計算を、正しく計算し直している時に、殺害してしまったのである。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "既ニ都市ノ私有地ヲ許サザルガ故ニ、設定セラレタル地上權ヨリ利得ヲ計ルコトヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "則チ借家ヲ以テ利得ヲ爲ス者ハ家屋其者ヨリノ利得ニシテ、地上權ニ伴フ利益ヲ計上スルヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ改造ニヨリテ男子ノ勞働者ノ利得ガ優ニ妻子ノ生活ヲ保證スルニ至ラバ、良妻賢母主義ノ國民思想ニヨリテ婦人勞働者ハ漸次的ニ勞働界ヲ去ルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ハ眞個父兄的愛情ヲ以テ、斯ル短時日間ニ此ノ道義的使命ヲ果タシ、以テ異民族ヲ利得ノ目的トセル白人ノ所謂植民政策ナルモノニ鐵槌一下セザル可カラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄は金銀と異なり、わずかな分量では利得にならぬと聞いたが、頃日米国禁鉄となってから、一粒の鉄砂も麁末にならぬような話を承る、ふとした事から多大の国益が拡がった例多ければ、妓家の黒壁が邦家の慶事を啓かぬにも限らぬと存じ、本誌紙面を藉りてその筋の注意を惹き置く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡馬よりも牝馬が好かるる訳は、駒を産んで利得多いからよりは、牝馬は嘶かず、夜襲などの節敵に覚られぬからだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの茶の十徳というは鶏や猫の五徳と事異なり、十倍の利得るといったまでの事で、この徳あの徳と一々名目を列ねたものでなかろうと土宜師へ答え置いたが、どうも自分ながら胡麻の匂いがする。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもさういふたくらみをなして彼等が利得する量といふのは一體何程であらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時利得税をうんと背負はなければならない筈の山下氏は、それだけ他人より大きな声を張り上げる資格がある者のやうに、図技けた牛のやうな調子で蔵相に挨拶した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、箱根あたりとくらべれば、全体に田舎めいてゐるが、併しそれも、悪い意味での田舎くさい感じはあたへない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
