[
  {
    "uuid": "47cb562f-73c9-55aa-a5cd-b03a9b4e0b6d",
    "entry": "竜顔",
    "reading": {
      "primary": "りゅうがん",
      "alternatives": [
        "りょうがん"
      ],
      "is_heteronym": false
    },
    "grammar": {
