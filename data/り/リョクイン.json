        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "緑陰に白のベンチを配合するといつた反映である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木々は野生えのままに育ち、春は梅桜乱れ咲き、夏は緑陰深く繁りて小川の水も暗く、秋は紅葉の錦みごとなり。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身の情緒の影で、なつかしい緑陰の夢をつくるやうな、それらの「情調ある思想」だけを語りたいのだ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の左、そこにある台※の東隣となった緑陰の中に小さな楼が見えて、白い小さな女の顔があった。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑陰の重なった夕闇に螢の飛ぶのを、雪子やしげ子と追い回したこともあれば、寒い冬の月夜を歌留多にふかして、からころと跫音高く帰って来たこともあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春去夏来新樹辺、緑陰深処此留連、尋常性癖耽閑談、不愛黄鶯聞杜鵑　その時一人の旅人が――武者修行風の若い武士が、麓の方からやって来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑陰に蓆を布いて憩ふ。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑陰や釋迦牟尼佛の像高し桃葉　川越街道を横切りて、路を王子に取る。",
              "citation": {
                "source": "飛鳥山遠足",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "樓門をひかへて、末社多く、ありとあらゆる屋宇、みな朱塗にして、緑陰の中に、燦然として、光彩を放てり。",
              "citation": {
                "source": "飛鳥山遠足",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "圧制、貧困、罪悪を以て充填されたる欧洲列国中に一個の自由、平等、平和なる瑞西を見るは、恰も渺漫たる砂漠の中に、緑陰清泉のオーシスを見るが如し、万国の社会主義者が夢寐に之を憧憬して、足一たび欧洲に入る者、皆な此処を以て慰安、休息の地となさゞる者なき、宜なり。",
              "citation": {
                "source": "筆のしづく",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の日の午後など緑陰の下にうつとりとハンモツクの上に眠つて居る若い人の白い顔が、本を持つた手と共に目に残つてゐた。",
              "citation": {
                "source": "若芽",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が物心ついたときには、海へ通ふ砂径沿ひの緑陰のしじまの深い閑かな借家に一家は住んでゐたのであつた。",
              "citation": {
                "source": "母を殺した少年",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "述斎は上遊客文」に曰く、「ソレ我ガ上ノ勝ハ桜花ニ非ズシテ実ニ緑陰幽草ノ候ニアルヲ。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑陰納涼ノ夏ニ於ケル紅樓望雪ノ冬ニ於ケル四時ノ景宜シカラザルハ無シ。",
              "citation": {
                "source": "十年振",
                "author": "一名京都紀行",
                "note": "青空文庫"
              }
            },
            {
              "text": "血まみれの衣を洗い、それを岩の上にひろげて、乾くまで緑陰に眠る。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "家貧きが上に幼時｜怙恃を失い諸方に流浪し、山本緑陰の家に食客となること三年。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠南城外歩秋晴、黄葉無風葉有声、想見家山春已尽、緑陰堆裏杜鵑鳴。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸し暑い日本の夏は少々ならず閉口であるが、それも大都会のビルやアスファルト道路の照り返しに自動車の排気ガスを脱れ出でて、青田に白鷺を見、蝉しぐれの緑陰に清泉を掬する日本の自然のなかに置かれた町や村の夏なら、緑陰に清泉の一掬に十分にしのぐこともできる。",
              "citation": {
                "source": "われらが四季感",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くべき大きさの羊歯、ありとある種類の木の植生、淡く明るい黄からこの上なく濃い青緑まで思いつく限りの緑陰。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、あるのは、郷里の家の白壁の土蔵と、軽井沢の緑陰と、二枚だけになってしまったが、これを自分の居間の壁に、広重の五十三次や、マチスのクロッキーと並べて臆面もなくかけている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は駅の近くで「緑陰書房」という古本屋を経営している。",
              "citation": {
                "source": "落穂拾い",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "――むしろ馬蠅の世界には、緑陰の涼風があり、豆の花が咲いていた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
