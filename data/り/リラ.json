        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然し中谷小林は共に緑に圍まれた郊外の夏に籠つて、シツラーやリラダンに餘念なく、いゝ生活をしながら今度の原稿を齎らして呉れた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリラーの箇所は数条の波線が平行して流れる。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一回　無人島の響人の住む島か、魔の棲む島か――あら、あの音は――奇麗な泉――ゴリラの襲來――水兵ヒラリと身を躱した――海軍士官の顏　此島は、遠くから望むと、恰も犢牛の横つて居る樣な形で、其面積も餘程廣い樣だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客は私と商人のパリロ氏と牧場主のラメツ氏と医師のフェリラ氏とそしてその他に全く得体の知れぬ二人連れの男女が乗っていた。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然パリロ氏がその二人連の方を目くばせしながらフェリラ氏に囁いた。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端の垣にリラの花が枝垂れてゐた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円柱の陰＝其処の菱提灯に薄紫のリラの一房が灯つてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がゲリラ戦に出るかも知れないからです。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日の執拗なゲリラ戦術に久しくいらだち屈していた士気が俄かに奮い立った形である。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内のじいさんを三リラで雇ったが、早口のドイツ語はよく聞き取れなかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥラ・ラ・ラ・リラ・リラ・レ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "首都圏を中心に、かなり広範に展開していた私のゲリラ的販売促進活動が、みごと功を奏したというわけではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エキスパンドブックが持っていた電子ガリ版としての可能性を、究極まで突き詰めたゲリラ精神溢れるこの発想は、インターネット上で加速していく知識の共有化に多大な貢献を成す可能性を秘めています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が家の同居人である妻アキコは、電気製品を買ってくるとダンボールごと取り扱い説明書を捨ててしまうゴリラの親戚である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがマニュアルを読むことに遺伝子レベルで禁則をかけられたこのスカートを履いたゴリラでも、マッキントッシュのアプリケーションは複数種類を日常的に自力でどうやら使いこなしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇夜の提灯にあたるこの基本ルールを学んだ段階で、日本語を喋る我が家のゴリラは、わけのわからないコンピューターをそれでも使いこなしてやろうという意欲を持った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそゴリラにコンピューターを使わせる秘訣である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし電子メールを送るためにネットワークにアクセスするたびに、我が家のゴリラは軽度の錯乱をきたす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲシュタルト崩壊に陥ったゴリラとしては、オレの書いてやったメモと首っぴきで、手探りで手順を追わざるを得なくなる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴリラを夜道に迷わせないためには、Ｗｉｎｄｏｗｓから四方を眺めさせるのが最短距離である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊この原稿を盗み見て以来、我が家のゴリラはビデオの予約録画に関してさっぱり非協力的となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最下層に陣取ってのゲリラ戦には、それなりの闘い方がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "麹町の下宿にゐた頃は夕暮時になるといつも馬海松と伴れ立つて銀座から日本橋へ歩き、グラウスとかリラなどゝいふ酒場で、小林、井伏、中村正常達に出遇つた。",
              "citation": {
                "source": "交遊記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒猩、ゴリラ、猩々に次いで人に近い猴で歯の形成はこの三者よりも一番人に近い。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃英語で『ヒューマン・ゴリラ』てふ図入りの書を作った者あり。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴリラはわが国でヒヒというと斉しく大なる猴で、ややもすれば婦女を犯す由、古来アフリカ旅行記にしばしば見える。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの書に人間のゴリラと題号を附けたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女どもはそれは何の所作事かと尋ぬると、われは人間のゴリラであると飛んでもない言を吐いたから、下女ども大いに驚き用心して爾来｜碌に近寄らず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い中で、それはゴリラがうずくまっているのと、そっくりに見えた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
