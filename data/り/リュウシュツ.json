    "definitions": [
      {
        "index": 1,
        "gloss": "outflow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つコックの工合の悪いのがあって、それから湯が不断に流出している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば美術や音楽の方面においていわゆる官学派の民間派に対する圧迫といったようなことについて、具体的の実例をあげていわゆる官僚的元老の横暴を語るのであったが、それがただ冷静な客観的の噂話でなくて、かなり興奮した主観的な憤懣を流出させるのであった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたづらに膿が流出するだけであります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学者の説によると、第一に水の流出する音が人の声を誘う、第二には浴場の壁は普通の家のように音波を擾乱するものがないためによく反響して声が充実して聞えるためだという。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それが単なる地貌学的ないし生物学的の記述でなく、文学的作品と呼ばれ得る所以は、これらの対象中に作者の人格が滲潤している点にあるが、その作者から流出したものを盛るべき容器が科学的事実である限り、その容器に科学的｜破綻があっては工合が悪いのである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べた「白鳥池」を利用して水力実験室を作り、色々の形の穴から水を流出させるときの孔内の圧力分布を測ろうというのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの容器の底に穴をあけて水を流出させれば水面の降下につれて栓と棒とが降下するのであるが、その穴の大きさをうまく調節すると二つの土器の二つの棒が全く同じ速度で降下しいつでも同じ通信文が同時に容器の口のところに来ているようになるのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙の方ではその合図の火影を認めた瞬間にぴたりと水の流出を止めて、そうして器の口に当る区分の文句を読むという寸法である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の持ちものの材木の流出を防いだり櫓台の錨に石を結びつけたりした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原動力が、刻々に、体外へ流出した。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流れが始まると、陸地の表面では上層の空気が他処へ流出するために圧が海上の同じ高さの点より低くなる。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは見る／＼流出する血を吸い取って、ゆでた伊勢蝦のように紅くなった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "根方の処の土が壊れて大鰻を捏ねたような根が幾筋ともなく露れた、その根から一筋の水がさっと落ちて、地の上へ流れるのが、取って進もうとする道の真中に流出してあたりは一面。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば大川の水のおのづからに土砂を流出するもの、極めて自然の状態をなして遠浅の海底を形づくるが中に、佃島の東の本澪の遠く南品川の沖に達すると、佃島西の上総澪の月島下流に至るとの二線がやゝ深き水路をなすあるのみ、岩礁の伏在するもなく、特別の潮路の去来するもなし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし東京前面の海の遠浅なるは、隅田川中川及び江戸川の流出する土砂の自然に堆積せるがためなれば、その砂洲の意外に広大にして、前に挙げたる二条の澪の外に大船巨艦を往来せしめがたきの観あるも怪むに足らずと言ふべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前記の浴室より、もう少し左上に当たる崖の上に貸し別荘があって、その明け放した座敷の電燈が急に点火するときにそれをこっちのベランダで見ると、時によっては、一道の光帯が有限な速度で横に流出するように見えることがある。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかかわらずグラハムの器械からは電流が遠慮なく流出した。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御摂政中の万般の施設、そのいずれとして、この御見解より流出せないものはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば我等の詩想は、それが意識されると同時に、常にこの音樂の心像と結びつけられ、互に融合して自然と外部に流出する。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本來、自由詩の動機は、文藝上に於ける自由主義の精神から流出してゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根方の処の土が壊れて大鰻を捏ねたやうな根が幾筋ともなく露はれた、其根から一｜筋の水が颯と落ちて、地の上へ流れるのが、取つて進まうとする道の真中に流出してあたりは一｜面。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて波上の炎々たる水雷火、その魚鱗火、連弾光、鵜舟の篝、遊覧船の万灯、提灯、手投げの白金光、五彩の変々たる点々光、流出柳箭、けだし参と信との花火芸術の最高を極め精を尽くし神を凝らしたものであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "褌の節約と馬糞の拾集とから得た利益を積み立てて架橋したのが大正三年の洪水で流出した。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "田地、道路、家屋、人畜の流出。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、そりゃ沼からじゃありますまいけれど、梅雨あけに水が殖えたので、底から流出したんだろうッて、貴郎がそう言っていらしったではありませんか。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其船が不幸にも航海中に風波の難に逢つて、半難船の姿になつて、積荷の半分以上を流出した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹膜に膿が流出していて、困難な手術になった。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷なる汗は又｜一時流出でぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の個性は分化拡張して、しかも稀薄な内容になって、中心から外部へ散漫に流出してしまった。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
