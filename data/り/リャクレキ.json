    "definitions": [
      {
        "index": 1,
        "gloss": "brief personal record",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むしろ故人と親しかった二、三の人が、故人の色々な方面に関する略歴や逸事のようなものを、誰にも分る普通の言葉で話して、そうして故人の追憶を新たに喚び起すようにした方がもう少し意味がありはしないか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏から父の古い人名辭典を見つけだし、世界の文豪の略歴をしらべてゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵から父の古い人名辞典を見つけだし、世界の文豪の略歴をしらべていた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠れたる偉人、梅津只圓翁の略歴は下記の通りである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜牛の略歴で御座い！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜牛の略歴でござい！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「牛の略歴」というのを読んでみると――。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はルーブルなどで実物の絵に接して、絵描きになることをあきらめた、しかし、戦後自分で書いた略歴に、絵描きのような職業をして現在に至ると書いて居るように、美しい絵を書く画家でもあった。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "てのひら自伝――わが略歴――坂口安吾　私は私の意志によって生れてきたわけではないので、父を選ぶことも、母を選ぶこともできなかった。",
              "citation": {
                "source": "てのひら自伝",
                "author": "――わが略歴――",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　×　　　　　×　弟の著作は先程略歴に述べてある通りであります。",
              "citation": {
                "source": "弟を葬る",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵は旅先ながらに土地の人たちの依頼を断わりかね、旧師のために略歴をしるした碑文までもえらんで置いて、「慶応｜戊辰の初夏、来たりてその墓を拝す」と書き残して来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔡元培の式辞があり、沈鈞儒の略歴朗読があり、宋慶齢女史の告別の辞があり、章乃器、郁達夫、田漢その他の告別の辞があった。",
              "citation": {
                "source": "魯迅さん",
                "author": "内山完造",
                "note": "青空文庫"
              }
            },
            {
              "text": "塾の明治娘　文芸家協会の会員カードを初め、よくいろんな問合せや申込書などに、略歴、本名、生年月日などの記入欄があるが、いったい、生れた月日などを、他人が何の便利につかうのだろう。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と発表のあった略歴記事のうちにこんな数行が載っていた。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このつぶやきがしばし行われた後、一人の僧侶が一対の大きな鐃が鳴った後で立ち上り、紙を大きく畳んだものを開いて、悲哀に満ちた、葬式的な音調で、蜷川の略歴、つまり彼が何であり、何をなした云々というようなことを、読み上げた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "神道だと、死者の本名と、彼の生涯の略歴とを刻む。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のような略歴であって、初めに兄、次に弟と、二人が江戸から派遣されて来たとあってみれば、国許の人々がそこになんらかの「使命」を臆測するのは人情というべきであろう。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回探検隊現地引き揚げのために、絶望視せられたヴィルダー・ゲイレック博士一行の人名左のごとし　として、一行に従った人々の名前、略歴が、大々とした肖像入りで出ているのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "学界のためその挙式を延ばして参加せるもの、は私を苦笑せしめたが、新聞はさらに引き続いて、電気技師ペリイ・パッカースン、録音技師ブラムレイ・ウェンデル以下一行中の重だった人たちの略歴を順次に掲げていた。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この定家の略歴に見てもわかるように、後鳥羽院が御譲位になると、急に和歌についての中心が生れるのであって、新古今時代の歌人を糾合されたのは、全く院のお力であることが判るのである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………………　右の本文の外に、明智の死体を発見した会社員夫人を初め二三の人の談話や、被害者の略歴、素人探偵としての手柄話まで掲載されていた。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は戦死者及公死者の略歴附の写真帖であつて、今江田島の海軍教育参考館に収めてある。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老母を介護するため小説を書き、一週間で発売し、一ヶ月で人気作家になった」　フィルが略歴に微笑んだ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "略歴は職務上知っていた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "（右の記事のあとには、明智小五郎の略歴、探偵手柄話、親友波越警部の談話等記しあれど凡て略す）　読者諸君は右の記事を読んで、事の意外に一驚を喫せられたことであろう。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
