[
  {
    "uuid": "a414e605-e7e8-5cf8-9224-e5b960d2b344",
    "entry": "良馬",
    "reading": {
      "primary": "りょうば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
