    "definitions": [
      {
        "index": 1,
        "gloss": "rotation (e.g. of a duty)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
