[
  {
    "uuid": "64898749-5143-5cca-8cdd-36e27f10a629",
    "entry": "流血",
    "reading": {
      "primary": "りゅうけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
