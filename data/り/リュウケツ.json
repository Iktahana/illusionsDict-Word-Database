      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bloodshed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "全課程を冒険者や流血者の行列にしないために発明家や発見家も入れてもらいたい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「流血の検挙をよそに闇煙草は依然梅田新道にその涼しい顔をそろへてをり、昨日もまた今日もあの路地を、この街角で演じられた検挙の乱闘を怖れる気色もなく、ピースやコロナが飛ぶやうに売れて行く。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは即ち好運を牽き出し得べき線は、之を牽く者の掌を流血淋漓たらしめ、否運を牽き出すべき線は、滑膩油澤なる柔軟のものであるといふ事實である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "排他、脅迫、防禦、突進、乱闘、流血、　ぎゃお、わお、がお、うわアああ、わお、お、お、　ハーレムとは一の成牡（ブル）を中心として成る成牝（カウ）の多くは百頭三百頭の集団である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戦苦闘のブルどもは不眠不休、飲まず食わずしかも絶倫なる精力はその残虐と流血と肉弾戦の間にも驚くべき性殖力を発揮する。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に奈良原翁は嘗て明治流血史というものを書いて出版した事があるという。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰の名のもとに行われる流血と暴力、ここに誰が荷担しているか、いっこうに秘密のままであった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは寺院に往きて、彼の救世者流血の身に擬したる麪包を乞ひ受け、その奇しき力の我を清淨にし我を康強にせんことを祷りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは即ち幸運を引き出すことの出来る綱は之を引く者の掌に流血を滴らせ、不運を引き出すべき綱は滑らかで柔らかなものであるという事実である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "國内ノ無産階級ガ組織的結合ヲナシテ力ノ解決ヲ準備シ又ハ流血ニ訴ヘテ不正義ナル現状ヲ打破スルコトガ彼等ニ主張セラルルナラバ、國際的無産者タル日本ガ力ノ組織的結合タル陸海軍ヲ充實シ、更ニ戰爭開始ニ訴ヘテ國際的劃定線ノ不正義ヲ匡スコト亦無條件ニ是認セラルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて骨に掛けず流血も少なく尻の肉を四角な片に刻み去る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛は戸辺にあって流血少なし。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那でも兵器の神威を説いたもので、越王泰阿の剣を揮えば敵の三軍破れて流血千里といい、湛盧の剣は呉王の無道を悪んで去って楚に往ったといい、漢高祖が白蛇を斬った剣は晋の時自ら庫の屋を穿って火災を遁れ飛び去った由（『淵鑑類函』二二三）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "事、ひとたび流血沙汰に及んだとすれば、農民達にいか程正義正当の理由があったにしても、士農工商、階級の相違、権力の相違が片手落ちならぬ片手落ちの裁きをうけて、結局悲しい処罰をうけねばならぬ者は、正しいその農民達なのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "依田学海先生国民之友の附録を批して曰く、「舞姫」は残刻に終り、「拈華微笑」は失望に終り、「破魔弓」は流血に終り、「酔沈香」は嘆息に終る。",
              "citation": {
                "source": "舞姫",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お招きによってどんな面白い流血事件でもあるのかと思って来たが、これは尖端嬢が目を廻しただけのことじゃないのかネ」「いや、もう死んでいますよ」「なに、こいつが死んでいるって」と大江山課長は頤で屍体を指した。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペインが流血の苦難を通じて世界文化・文学の領域の中に新しい自身の価値を創造しつつ、同時にヨーロッパの文化的良心の沸騰する発露、更新力となりつつあることを疑うものは今日いないのである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬縣での流血の闘争など、もっと色彩づよく描写され、同時に揚子江の壮大な自然や白人の日常生活の姿などが遠近をもって描き出されたら、この作品は一層面白く、芸術的な香気をもたかめたことであろうと思われる。",
              "citation": {
                "source": "「揚子江」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院の寝台の上に仰きに成ったきり、流血の止るまでは身動きすることも出来なかった。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一九一二年四月のレナの流血の大衆的大罷業以来、特に顕著になり、一九一四年の前半期には約二百万人（一九一〇年の二十倍）が罷業した。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実での暴虐、流血を神秘主義に色どって、その強烈さで、理性を麻痺させることは、ヒトラーの方式であった。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔伏字二十八字〕（この一行は復元できない）ロシア民衆の生活がいかなるジグザグの道をとおり、流血と犠牲をもって十月革命の大道へ辿りつき、更にその道を前へ前へと進んでいるかということを、その多様さ、複雑さ、矛盾のままの姿で描いた作家は、ゴーリキイなのである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザックはパリの階級勢力の移動と栄枯盛衰がその間に激しく行われた七月、二月の政変をも経験したのであったが、彼は社会的変革も要するに金をめぐってもがく人間の流血的な循環運動にすぎぬと、観たのであった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三鷹電車区の中には、たとえかけだしの党員でも年が若くてもマルクス・レーニン主義を充分知らなくても、構内に入っている電車を暴走させて人の命を奪って、これで日本の流血革命だなどといって手を叩いてよろこぶような若者はいない。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃える流血・燃える発汗・燃える頬・燃える旗――わあっ！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな箒が一本、これは濃厚な血塊で塗られてゐる所から見て明らかに流血を掃くために用ひられたもの、どうして犯人等がたま／＼かゝる罪跡證據品を遺棄する如き輕率をなしたものか吾々は想像に苦しむものである。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "三位一体は大資本、法王、軍閥で、祝福の代りに大衆の疲弊と流血があるだけだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸、病気、泣きごと、流血、殴打、ひどい言葉の愚弄、それらはどれもゴーリキイに堪え難く、肉体的な苦痛を引起すのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
