[
  {
    "uuid": "61300dec-e0f9-5a2c-a9a2-aad82911aeb4",
    "entry": "陸行",
    "reading": {
      "primary": "りっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
