    "definitions": [
      {
        "index": 1,
        "gloss": "understanding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先刻の誤解が度重り、Ｂがなんとか伸理解明せんものとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンの奇妙な言葉を、真に完全に理解し得たものは、彼の妻より外にはなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の『貞淑』とは、良人に奴婢としての善き奉仕をすることではなくして、良人の気質や性格をよく理解し、努めて良人に同化して一心同体となることの奉仕である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと後になつてから、私は漸く始めて、少し宛芥川君の眞人物を理解し出したのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　芥川君は、詩に對しても聰明な理解をもつてた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公平な理解と見識では、詩壇の最も高い純粹鑑賞に劣らなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の詩について――新しい詩壇の詩について――芥川君が聰明な理解と見解をもてることは、前述べた如く自分の常に敬服する所である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は僕を理解しない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徹底的に理解しない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は君を理解してゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに君は、君は少しも僕を理解しない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解しようとしないのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも芥川君は、私を本質的によく理解してくれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がどんな生意氣を言ひ、屁理窟をこね、憎々しく突つかかつて行く場合にも、彼は寛大に情意を理解し、決して腹を立てることがなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は彼によつて教へられ、彼によつて慰められ、彼によつてよき藝術の理解者を得た。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人に理解されず、孤獨な、寂しい墓の中に死んで行つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、内地に於いて、彼と交際を続けていた者は、私と、それから二、三の学友だけで、いずれも大隅君から、彼の理解者として選ばれたこの世で最も気の弱い男たちであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神学」としての歴史的地理的な研究は、まだまだ日本は、外国に及ばないようであるが、キリスト精神への理解は、素早いのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、今仮に詩的性情を持つ一青年があつたとして、かの成巧せる実業家、成巧せる政治家が、子供や孫、一族郎党でもゐなかつたとしたら、どんなに退屈するものであるかは、一寸理解され難いのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元来「詩」というものは、和歌も俳句も新体詩も、すべて皆ポエジイの本質において同じであるから、一方の詩人は必ず一方の詩を理解し得べきはずであり、原則的には「専門」ということはないはずである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日最近にいたって、僕は漸く芭蕉や一茶の句を理解し、その特殊な妙味や詩境に会得を持つようになったけれども、従来の僕にとって、芭蕉らの句は全く没交渉の存在であり、如何にしてもその詩趣を理解することが出来なかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に僕にとって、蕪村は唯一の理解し得る俳人であり、蕪村の句だけが、唯一の理解し得る俳句であったのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があらゆる俳句を理解し得ず、俳句を本質的に毛嫌いしながら、一人例外として蕪村を好み、彼の俳句だけを愛読したという事実は、思うにおそらく、蕪村の情操における特異なものが、僕の趣味性や気質における特殊な情操と密に符合し、理解の感流するものがあったためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ更衣野路の人はつかに白し絶頂の城たのもしき若葉かな鮒鮓や彦根の城に雲かかる愁ひつつ岡に登れば花いばら甲斐ヶ嶺や穂蓼の上を塩車　俳句というものを全く知らず、いわんや枯淡とか、洒脱とか、風流とかいう特殊な俳句心境を全く理解しない人。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして単に、近代の抒情詩や美術しか知らない若い人たちでも、こうした蕪村の俳句だけは、思うに容易に理解することができるだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が俳句を毛嫌いし、芭蕉も一茶も全く理解することの出来なかった青年時代に、ひとり例外として蕪村を好み、島崎藤村氏らの新体詩と並立して、蕪村句集を愛読した実の理由は、思うに全くこの点に存している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日俳壇に住む多くの人は、好悪の意味を別にして、等しく皆同様の観察をし、上述の「定評」以外に、蕪村を理解していないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「で、お前はどこまでも海事局で頑張ろうと云う積りかい？",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄が皮肉に、Ｔ「今日も亦お詣りかい？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "詞のはずみばっかりかい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
