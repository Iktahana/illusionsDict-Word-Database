    "definitions": [
      {
        "index": 1,
        "gloss": "(power of) understanding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
