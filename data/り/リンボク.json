[
  {
    "uuid": "d2a9c293-8fe6-5bdf-82db-0dad30f132be",
    "entry": "鱗木",
    "reading": {
      "primary": "りんぼく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lepidodendron",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見ると御母さんが、今起き立の顔をして叮嚀に如鱗木の長火鉢を拭いている。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "困ったもんだ」「困ったもんだって、藤尾さんもやっぱり同意見ですよ」　裁縫の手を休めて、火熨に逡巡っていた糸子は、入子菱に縢った指抜を抽いて、※色に銀の雨を刺す針差を裏に、如鱗木の塗美くしき蓋をはたと落した。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な形をした鱗木のたぐい。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま自分らのいる、シベリヤのツルノニア圏と呼ばれる陸成層の一部は、その際、爬虫獣と爬虫鳥と古代鱗木をのせたまま、地底深く陥没し、その上を厚い片麻岩の地殻で蔽われてしまった。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方の水平線は常に蒸気が湧き不明瞭だったが、未知の木性羊歯、蘇鉄、鱗木、封印木からなる大ジャングルが都市の外に広がり、移ろう蒸気の中、悪ふざけのように群葉が波打つファンタスティックな様を見ることができた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "変ったものを好む人には、シマノフスキーの『ロクサーヌの唄』（ＪＤ八七〇）やコーンゴルトの『いぬ梨とりんぼく酒』（ＪＦ六四）も面白かろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
