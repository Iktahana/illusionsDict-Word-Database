[
  {
    "uuid": "6cdc6880-da77-5248-81ab-395eb0601e65",
    "entry": "竜胆",
    "reading": {
      "primary": "りんどう",
      "alternatives": [
        "りゅうたん",
        "リンドウ"
      ],
      "is_heteronym": false
    },
    "grammar": {
