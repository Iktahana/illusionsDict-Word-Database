        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "りんどうはほんとによい花ですね。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしりんどうがこんなに美しいとは知らなかったわ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし急にりんどうが好きになった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さん、なんです、そんなにひとりで笑って」「政夫さんはりんどうの様な人だ」「どうして」「さアどうしてということはないけど、政夫さんは何がなし竜胆の様な風だからさ」　民子は言い終って顔をかくして笑った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は悦んでりんどうになります。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで民さんがりんどうを好きになってくれればなお嬉しい」　二人はこんならちもなき事いうて悦んでいた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、りんどうの花が咲いている。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路のへりになったみじかい芝草の中に、月長石ででも刻まれたような、すばらしい紫のりんどうの花が咲いていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カムパネルラが、そう云ってしまうかしまわないうち、次のりんどうの花が、いっぱいに光って過ぎて行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんどうの花のコップが、湧くように、雨のように、眼の前を通り、三角標の列は、けむるように燃えるように、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う岸も、青じろくぽうっと光ってけむり、時々、やっぱりすすきが風にひるがえるらしく、さっとその銀いろがけむって、息でもかけたように見え、また、たくさんのりんどうの花が、草をかくれたり出たりするのは、やさしい狐火のように思われました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにうしろへ行ってしまったから」　カムパネルラが、そう言ってしまうかしまわないうち、次のりんどうの花が、いっぱいに光って過ぎて行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こう岸も、青じろくぼうっと光ってけむり、時々、やっぱりすすきが風にひるがえるらしく、さっとその銀いろがけむって、息でもかけたように見え、また、たくさんのりんどうの花が、草をかくれたり出たりするのは、やさしい狐火のように思われました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんどうの花は刻まれた天河石と、打ち劈かれた天河石で組み上がり、その葉はなめらかな硅孔雀石でできていました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、このりんどうの花はお父さんの所の一等のコップよりも美しいんだね。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、風が来て、りんどうの花はツァリンとからだを曲げて、その天河石の花の盃を下の方に向けましたので、トパァスはツァラツァランとこぼれて下のすずらんの葉に落ち、それからきらきらころがって草の底の方へもぐって行きました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんどうの花はそれからギギンと鳴って起きあがり、ほっとため息をして歌いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トパァスのつゆはツァランツァリルリン、　こぼれてきらめく　サング、サンガリン、　ひかりの丘に　すみながら　なぁにがこんなにかなしかろ」　まっ碧な空では、はちすずめがツァリル、ツァリル、ツァリルリン、ツァリル、ツァリル、ツァリルリンと鳴いて二人とりんどうの花との上をとびめぐっておりました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにりんどうの花は何がかなしいんだろうね」王子はトパァスを包もうとして、一ぺんひろげたはんけちで顔の汗をふきながら言いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるときは洞穴のようにまっくらです」　ひかりしずかな天河石のりんどうも、もうとても踊りださずにいられないというようにサァン、ツァン、サァン、ツァン、からだをうごかして調子をとりながら言いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろの季節では、蓼、りんどう、コスモス、芒、石蕗、等々何でもよい、何でもよさを持っている。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間に、清々しい白百合と、根じめにりんどうの花が生けてあった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、りんどうじゃないでしょうか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　りんどう　同じ級に藤野というのがいた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日大雨がふって霧が渦巻き、仕事も何もできないので、みんな小屋にこもって寝ていた時、藤野の手帳が自分のそばに落ちていたのをなんの気なしに取り上げて開いて見たら、山におびただしいりんどうの花が一つしおりにはさんであって、いろんならく書きがしてあった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩、なでしこ、りんどう、女郎花などの秋の草花が咲いていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節であればこのこみちにもりんどうの花が咲いたりするだろうか。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
