    "definitions": [
      {
        "index": 1,
        "gloss": "lease",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その他にはシンハリースの ganga（川）とわずかばかり似るだけで、他にちょっと相手が見つからない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠の「イソ」というのは俚言集覧には「額より頭上をおおう所を言う」とあるが、シンハリース語の isa は頭である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、やがてアメリカの社会主義者をも立たせ、ジミーの属するリースヴィル社会党支部も演説会を開き、反対した。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ビルマや、タミール、シンガリースなどから、漸次西に向かって、ペルシア、アラビア、トルコ、エジプトへんをあさってみると、やはりいくらかの関係らしいものが認められると思った。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなの読み物では民友社のたしか「国民小説」と名づけるシリースにいろいろの翻訳物が交じっていた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一座の中にアントワーリース――原住民の名は言いにくいから、簡単にアンといっておきます。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の曲名をつけるとすると、（グラナダ）（ダルダナス）（ラ・カンパネラ）（カプリース）あんまり華美で仰山な名はいやである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオドラマはテープ化され、後にレコードやＣＤとしてもリリースされます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュースリリースなど、文書を作る機会の多い、マーケティングや広報部門のスタッフは、ページメーカーとレーザーライタの組合せに真っ先に目を向けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし一九九二年十月に、米ボイジャー社と日本のソフト制作者グループとのジョイントベンチャーによって、日本法人のボイジャージャパン（正式名称、株式会社ボイジャー）が設立されており、一九九三年三月のリリースをめどに日本語化の作業が進められている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リリースによれば、新会社の事業目的は「書籍、雑誌の出版及びパソコン関連技術開発」であるという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＶＰｉ３８６は、ＣＰＵとしてインテル製３８６ＳＸあるいはＡＭＤの３８６ＳＸＬ―25のどちらでも採用可能だが、製品性能と電池寿命を特徴とするためには、ＡＭＤの製品が最適である」リリースはエデン・グループの技術部長ニール・フリントの発言をこう引いている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手の電子音に初めて出合ったのは、ビーチ・ボーイズの「グッド・バイブレーション」（一九六六年のリリースだから、オレが中二の時だ）に使われたセラミンという代物だったろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の記憶勝れたる事、アビシニアの馬途中で騎手と離るると必ず昨夜｜駐った処へ還るとベーカーの『ゼ・ナイル・トリビュタリース・オヴ・アビシニア』に見えるが、支那でも斉の桓公孤竹国を伐ち春往き冬｜反るとて道を失うた時管仲老馬を放ちて随い行きついに道を得たという（『韓非』説林上）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーカーの『ゼ・ナイル・トリビュタリース・オヴ・アビシニア』に、氏が獅子を銃する時落ち着いて六ヤードの近きに進み、獅子と睨み合いて却かなんだ勇馬を記す。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてセイロンのシンガリース人は林中で猴が死んでも屍を見せぬといい、その諺に「白い鳥と稲鳥（パッジー・バード、鷺の一種）と直な椰樹と死んだ猴、それを見た人は死なぬはず」という。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三にセイロン特産のシンガリース藪鶏、また家鶏に似るが、胸赤く、冠黄で、縁赤く、頬と頷の垂嚢が紫赤し。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八五九年版、ノーツ・エンド・キーリース撰抄、一〇一頁）予が在英中親交したロバート・ダグラス男が玉篋卦てふ占ひ書から譯した文をタイラーの原始人文篇、二版一卷一〇七頁に引いたが「大工が家を建て初めるに先づ近處の地と木との神に牲を供ふべし。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "エピグラフとした曲は、物語中の引用の時点で、すでに本国でリリースずみのものにかぎっている（一曲だけ例外はあるが）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最新式避姙法」の書物　マリーストーブとかブラングエンとかいう人々の著書の和訳、又は「性」という文字を標題に取入れた雑誌は、記者が街頭の書物屋で見ただけでも十種近くある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一個の私見では、六千載の世界史の中、ペリクリース時代の雅典以後、今日に到る部分は、間違つた希望に依る進化、換言すれば、堕落せる希望に依る堕落、の最も大なる例である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに、汽車の食堂とチュリーストが休み出す。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス放送協会の専務理事サー・ジョンリースは議会で「放送番組の編成並に改善は聴取者からの投書を基礎にして行っている」と明言し、ドイツで昨年音楽放送を増大したが、これは聴取者よりの希望を反映したものであると発表している。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この著述の影響が一方シェリング、ヘーゲルに及ぶと共に他方フリース（又アペルト等）にも及んでいるという事だけを茲に付記しておく必要があるであろう。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーカサスの雄大極まりない山嶽を南へ縫ってウラジ・カウカアズから、スターリンの故郷チフリースまで、立派な自動車道が通っている。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝政ロシアの権力が武力で、絹、皮革の産地チフリース、石油のバクー市を掌握するための近路として拵えたものなのだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうな世代を、例へば、アウグスト・ヴィルヘルム・シュレーゲル、シュライエルマッハー、アレキサンダー・フォン・フンボルト、ヘーゲル、ノ※ーリス、フリードリヒ・シュレーゲル、ヘルダーリン、ワッケンローデル、ティーク、フリース、シェリングが形作つてゐる。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテが拾歳の時ビアトリースを見てから、終生片戀をつゞけたのは大詩人であつただけ、ませて居たので、その時すでに肉を滿足させた點があつたからで、他に嫁したビアトリースに對しては、たゞ未練が殘つて居たに過ぎなからう。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
