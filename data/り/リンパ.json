[
  {
    "uuid": "f00a0d19-a0a5-5817-beb0-670b4beb8415",
    "entry": "淋巴",
    "reading": {
      "primary": "リンパ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
