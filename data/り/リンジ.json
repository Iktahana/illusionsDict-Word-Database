[
  {
    "uuid": "f09f30a7-4d00-5200-81ca-4135953c69ee",
    "entry": "臨時",
    "reading": {
      "primary": "りんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
