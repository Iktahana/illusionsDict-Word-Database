    "definitions": [
      {
        "index": 1,
        "gloss": "li (hexagram 30 of the I Ching: fire, the clinging)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "暮春に迫る落日の前われら既にこれを見たりいかんぞ人生を展開せざらむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れまさに年老いて家郷なく妻子離散して孤獨なりいかんぞまた漂泊の悔を知らむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れの持たざるものは一切なり我れの持たざるものは一切なりいかんぞ窮乏を忍ばざらんや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ我れの持たざるものは一切なりいかんぞ乞食の如く羞爾として道路に落ちたるを乞ふべけんや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "低くてなだらかな山々が広く長く根を張っている姿も、やはりいかにも落着いたのんびりした感じを与える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なるほどさっきのおしまいの喜劇役者に肖た人はたった一人異教徒席に座って腕を組んだり髪を掻きむしったりいかにも仰山なのでみんなはとうとうひどく笑いました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ぺんうまく爆発してもまもなくガスが雨にとられてしまうかもしれませんし、また何もかも思ったとおりいかないかもしれません。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土望景詩中學の校庭われの中學にありたる日は艶めく情熱になやみたりいかりて書物をなげすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに青きを飛びさり天日直射して熱く帽子に照りぬ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此よりいかなる話の運なりしか知らねど、我等二人は忽ち又古のエトルリヤ人（昔羅馬の北に住みし民）の遺しゝ陶器の事を論ぜざるべからざることゝなりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはあはれなる少女の、獨りいかなる道の邊に蹲り居るかを思ひ遣りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年日本富まば、分に応じて外国よりいかなる大石を買い入れても大社殿を建て得べし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵庫県の東播磨港に派遣されて体験した現場では、かなりいかがわしい連中とのやり取りも含めて人との出会いを楽しみました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "となればやはりいかざあなるまいと駆け付けてみると、なんと師匠、いきなり今度は社内のスタッフにレッド・ペーパーを突き付けるではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やはりコンピューター化の新しい時代に入ったのだから、多少これまで通りいかない点は我慢してもらわないと」「もとがアメリカ生まれだから、日本語化するとどうしても問題点が残りまして」などと鼻毛を抜きつつそっくり返っていれば、アメリカ市場を抑えた標準の勢いがそがれてしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう新しい会社でコンピューター物など出しているところ、つまりいかにもＤＴＰをやりそうなところ（ソフトバンクなどその典型ね）は、そんなルールは一切無視である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺らはあ、暫くやんねえから、煙草は身體の工合惡りいから斷つたんだから何だが、酒は此れ錢は稼げねえし、ちつとでも飮めば又飮みたくなつから廢めつちやつたな、酒もはあ以前た違つて一｜杯幾らつちんだから錢くんのむやうで」彼はぶすりとして然も力のない聲を投げ掛けるやうにしていつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "聳ゆるといふよりいかにもおつとりと双方に大きな尾を引いて靜かに鎭座してゐるのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "聳ゆるというよりいかにもおっとりと双方に大きな尾を引いて静かに鎮座しているのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は思ったとおりいかなかったのでいろいろと部分部分を幾度も作りかえてついに最初の機械の百五十倍に達する感度を備えた装置を作り上げ、これで数万光年に相当する遠距離にある遊星からの無線電話もたやすくとらえたうえで、これをエスペラント語に変調して聴かれるように考案したのであった。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが運がわりいといへばわりいのだらうが、たとへそれがひとつになつても、運が好いかわりいかわからない……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はつまりいかにも健康なのであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手前の躾がわりいから、あんな我儘を言うんだ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほほこれは面白いわね」「そうなんですよ、そうなんですよ」と彼は我意を得たりとばかりいかにも愉快そうに叫んだ。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　驚いたのは千斎で、しっかと二人の裾を握りいかな放そうとしなかった。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中からおたのみしてあるのに御都合がつきませんでしょうかと、あんまりいかめしい調子で云い迫ったので向うの奥さんらしい声はへどもどしながら、少し工合が悪くて横になって居るが、もうじきあがる様に申して居りましたと返事するのをきいて、常套手段の少々加減がを腹だたしく思わないわけには行かなかった。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それらの言葉の多くを声に出して繰り返してみたりさえしたが、それがやはり先刻のとおりいかにもおかしく思われたので、彼が自分でも肚の底からふきだしてしまったのもけっして不思議ではなかった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
