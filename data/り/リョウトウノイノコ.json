    "definitions": [
      {
        "index": 1,
        "gloss": "taking pride in something mundane, thinking it is exceptional",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
