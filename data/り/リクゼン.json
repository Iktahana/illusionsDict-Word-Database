    "definitions": [
      {
        "index": 1,
        "gloss": "Rikuzen (former province located in parts of present-day Miyagi and Iwate prefectures)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上陸前に工藤が片づけられている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正保元年三月には日光山、同年九月には羽後の本荘、同三年四月には陸前、磐城、武蔵、同四年五月には、また武蔵、相模に大きな地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲冑堂　橘南谿が東遊記に、陸前国｜苅田郡高福寺なる甲冑堂の婦人像を記せるあり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慙じて蛇になった例は、陸前佐沼の城主平直信の妻、佐沼御前｜館で働く大工の美男を見初め、夜分｜閨を出てその小舎を尋ねしも見当らず、内へ帰れば戸が鎖されいた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『郷土研究』一巻八号斎藤真氏説に、陸前の駒ヶ嶽、毎年消え残りの雪が白い奔馬形を現わす、これを見て年の豊凶を占う農夫もある由。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "深さ丈餘、幅七八間、陸前海岸の平野に延びて、名取川を貫き、阿武隈川の川口に至りて止む。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉があつて、それで眺望の好いところは、此処と陸前の青根と、下野の那須と、この三つだと私は思つて居るのだが、その中でもこの赤倉は、殊に深く私の心を惹いた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間は佐渡の海府から貰つたが、今度は陸前北上川沿岸の登米町から貰つた。",
              "citation": {
                "source": "夏",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "出船入り船帆影も繁き石の巻からそのお城下までへは、陸前浜街道を一本道に原ノ町口へ抜けて丁度十三里――まさかと思ったのに、およそ退屈男程気まぐれな風来坊も稀でした。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸前国気仙郡花輪村の竹駒という所に一人の美しい娘があった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち陸前国気仙郡竹駒村玉山金山の炊事役は女でウソトキといったとなっております。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔陸前国気仙郡、今の猪川村に稲子沢長者という長者があった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ自分が閉伊郡花輪村という所で発見した狩猟の巻物、山神狩人秘法大事という写本にも、磐司磐三郎の発生地を下野国日光山のその麓としてあるけれども、奥羽地方になると陸前名取郡の磐司磐三郎山（２）をはじめ、羽前の山ノ寺縁起（３）など、その他にも諸所に万治、磐治などの住居した所が散在している。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは陸前の登米、本吉、気仙の諸郡から、陸中の東磐井、江刺（以上旧仙台領）、その他これらの地方に近接した地方にわたって行なわれている竈神とて粘土や木刻の円眼船口形の怪奇な面を家々の竈前の柱に掛けておく風習があることである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "千把萱の話一　陸前国気仙郡矢作村というに、昔、意地悪い継母があった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在に於ては、九｜州、四｜國から、陸前、陸奧、出羽の方まで掛けて三十五ヶ｜國に亘り發見されて居るので、加之横穴は一ヶ｜所に群在する例が多いのだから、穴の數を算したら、どの位有るか知れぬのである。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "お穴樣の探檢",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の峨峨の出湯に至ること思ひ断つべき秋風ぞ吹く　これは大正十三年九月陸前青根に遊んだ時の作。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "春を追いかけて陸前の地を旅立った彼らは、三月の下旬にはこの道を歩いていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿賀妻は甚助を供に連れて、馴れた陸前浜街道を東京にのぼった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「陸前からまいった」「陸前？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸前荻ノ浜の港には、夜明けとともにはいって行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "折合（をりあひ）土佐幡多　　　折木（をりき）磐城楢葉　　　折茂（をりも）陸奥上北　　　折浜（をりのはま）陸前牡鹿此ほかにも、織笠（をりかさ）陸中東閉伊　　　織島里（おりじまがり）肥前小城　　　織豊（おりとよ）尾張愛知などあるが、織笠の折笠と同じ語らしいものゝ外は、其意をたどる事も出来ぬ。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此歌常識風に漠然と、波の越える山だからと感じもし、解釈もせられて、末の松山浪越し峠など言ふ地名もあり、地質の上から波の痕跡ある陸前海岸の山を、其と定めたりして居るのは、とんだ話である。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村杳樹氏（実は柳田国男先生）が提供せられた沢山の難題問答（郷土研究四の七）の例の中、陸前赤沼長老阪で、西行に舌を捲かした松下童子が、山王権現の化身であつたと言ふ話も、多少根本の山王に痕跡のあつたものとすれば、まへの関係は一層深くなるのだが、数点の類似だけでは、愛護・皇慶の交渉はむつかしい。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が國に多い「あくたい祭り」、即、有名な千葉笑ひ・京五條天神の「朮祭り」の惡口・陸前鹽竈のざっとな・河内野崎觀音詣での水陸の口論の風習の起りは、此處にあるのである。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸前松島の宮戸島だとか、三河の吉胡だとか、河内の國府だとか、備中の津雲だとか、肥後の阿高などでは、ずいぶんたくさん人間の骨が出て、ある一つの場所からは百體三百體以上の骨が、一間ほどの距離を置いて竝んでゐるといふようなあり樣であります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれはそのあとが続かず、今の秋田県の北部地方以北は再び蝦夷の手に放任することに成った様ではありますが、奈良朝のはじめには出羽国が設置せられ、引続き陸奥（今の陸前）に多賀城を置き、秋田城との連絡を保って奥羽地方の蝦夷の経営は、着々進捗して参りました。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の各種の蝦夷の住地は、時代によりて一定せざりしなるべく、彼の蝦夷の國名たる日高見の名が、常陸、陸前の兩地に殘れると同樣に、其限界線は、必ずや我が國力の發展に伴ひて、東北に移りしものなるべし。",
              "citation": {
                "source": "蝦夷とコロボツクルとの異同を論ず之に潜みて",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
