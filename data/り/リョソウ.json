    "definitions": [
      {
        "index": 1,
        "gloss": "travelling clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ロオズ夫人にお別れした妾は、当分モスコーで暮すために旅装を整えて二つの彫像を二個のトランクに入れて、巴里停車場に車を走らせました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗亭ダリコントの熱情の女、アンナ・スラビナの周囲、旅装した中年の三人の外国人が取巻いている。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときイサックがトランクを持って旅装したまま部屋に這入ってくると、悲壮な別れの挨拶をするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "長火鉢に寄っかかッて胸算用に余念もなかった主人が驚いてこちらを向く暇もなく、広い土間を三歩ばかりに大股に歩いて、主人の鼻先に突ったッた男は年ごろ三十にはまだ二ツ三ツ足らざるべく、洋服、脚絆、草鞋の旅装で鳥打ち帽をかぶり、右の手に蝙蝠傘を携え、左に小さな革包を持ってそれをわきに抱いていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、船を下りると、すぐ旅装を調えて、ヒルテイの村に出発したのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速宿ることとして旅装をとく。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は元来ここまで一行を見送り、明日は失敬して帰京する予定なので、旅装も何もして来なかったが、新手の武者さえ馳せ加わっては、見苦しく尻に帆掛けて逃出す訳にも行かない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から、「失礼ですが、貴方……」　前刻の蓮根市の影法師が、旅装で、白皙の紳士になり、且つ指環を、竈の火に彩られて顕われた。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "因果娘は偸視て、「おや、出刃打ちの連中があすこに憩んでいなさるようだ」「どれどれ」と見向く年増の背後に声ありて、「おい、そろそろ出掛けようぜ」　旅装束したる四、五人の男は二人のそばに立ち住まりぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠一は早々に旅装を整えて帰郷の途に就いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋のころ、伊豆の沼津あたりに佳い苗があるといふことを聞いて、たちまち旅装をととのへ、顔色を変へて発足した。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　見渡すと、先刻は気附かなかつたが、痩馬の蔭に、ちらと赤い旅装の娘のゐるのが、わかつた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "才之助は、一向平気で、旅装もほどかず何よりも先に、自分の菊畑に案内し、いろいろ自慢して、それから菊畑の中の納屋を姉弟たちの当分の住居として指定してやつたのである。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」陶本の弟は、その納屋で旅装を解きながら、姉に小声で囁いた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私のうちと遠い親戚にあたるそのまちの呉服店で旅装を解いた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翁は急に旅装束をして江戸に向けて出発した。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に二疋の馬がいて傍に陣笠を冠った旅装束の武士が二人立ち、それと並んで権兵衛の下僚の者が二三人いた。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は旅装整えて戸を鎖し、鍵をば入口に住む靴屋の主人に預けて出でぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで旅装を調え、日を期して出発することになり、中堂に酒を置いて、母親と愛卿の三人で別れの觴をあげた。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙はその朝、旅装を調えて無錫へ往った。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔生は城内へ往って二三日｜後の始末をして、それから急いで旅装を調えて出発した。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はひどく喜んで、すぐ旅装を整えて、客に従いて金陵へ往ったが、その客がいろいろと頼んでくれたので、二つの芽を手に入れることができた。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶は帰って旅装束を解くと、人をやとうて亭園をしつらえさした。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥えた馬、軽い裘、ひどく立派な旅装をしていたが、嚢中には宝玉がみちていた。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は此処では好い商がないから会津の方へ往こうと云って、旅装束をして二人で家を出た。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊敬される人格者で、僧ではあるが貴族出のこの人に軽い旅装で逢うことを源氏はきまり悪く思った。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩衣などを着て、簡単な旅装をしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体の人へ餞別にりっぱな旅装一｜揃いずつを出すこともした。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月の三十日であったから、山の紅葉は濃く淡く紅を重ねた間に、霜枯れの草の黄が混じって見渡される逢坂山の関の口から、またさっと一度に出て来た襖姿の侍たちの旅装の厚織物やくくり染めなどは一種の美をなしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "関屋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
