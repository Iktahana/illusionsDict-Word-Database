    "definitions": [
      {
        "index": 1,
        "gloss": "Riga (Latvia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
