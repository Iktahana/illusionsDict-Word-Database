        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今朝成田様ノオマモリガ参リマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリガタウ存ジマス。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば家なき児レミがミリガン夫人に別れを告げて船を下りてから、ヴイタリス老人とちょっと顔を見合せて、そうしてあてのない旅路をふみ出すところなどでも、何でもないようで細かい情趣がにじんでいる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはオリガのイメイジである。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく煙管の吸口をガリガリ噛むので銀の吸口が扁たくひしゃげていたようである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「デハアリガト。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガリガリッ、ゴロゴロゴロゴロ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなびかりは、まるでこんな憐れな旅のものなどを漂白してしまいそう、並木の青い葉がむしゃくしゃにむしられて、雨のつぶと一緒に堅いみちを叩き、枝までがガリガリ引き裂かれて降りかかりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歩くたびに瑪瑙はガリガリ砕けたのです。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとあの大きな青白い光りのほうきぼしはばらばらにわかれてしまって頭も尾も胴も別々にきちがいのような凄い声をあげガリガリ光ってまっ黒な海の中に落ちて行きます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人とすれちがう時などには特に意地悪くわざわざガリガリと強い音を出す。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手でリガーを支えてバランスに気を配りながら、巧に艇身を廻転させつつ渚へ卸した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗りの青年はポケツトから小さなナイフを出してその窓の羊歯の葉の形をした氷をガリガリ削り落しました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなガリガリ骨ばかり、おや、いけない、いけない、すっかり崩れて泣いたりわめいたりむしりあったりなぐったり一体あんまり冗談が過ぎたのです。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め雲巌寺まで二里と聴いた水車小屋からは、二里は愚か無駄足をして既に四、五里は来たのに、この先まだ二里半あるとはガッカリガッカリ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（銅鑼）曹長特務曹長「大将ひとりでどこかの並木の苹果を叩いているかもしれない大将いまごろどこかのはたけで人蔘ガリガリ　噛んでるぞ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "――通称はツリガネニンジンであるが、色も同じ桔梗を薄く絞つて、俯向けにつら／＼と連り咲く紫の風鈴草、或は曙の釣鐘草と呼びたいやうな草の花など――皆、玉川の白露を鏤めたのを、――其の砧の里に実家のある、――町内の私のすぐ近所の白井氏に、殆ど毎年のやうに、土産にして頂戴する。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「罪と罰」のズヴィドリガイロフという男は、情欲の権化みたいな男だ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ズヴィドリガイロフという男が情欲の権化であることは、ズヴィドリガイロフにとって宿命的なもので、いわばこの男が背負わねばならぬ十字架にひとしい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して超凡の人では無い………としたら、北側のスリガラスの天井から射込む柔かな光線………何方かと謂へばノンドリした薄柔い光で、若い女の裸體を見てゐて、それで何等の衝動が無いといふことはあるまい。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のアリガネを合わせても、とてもその「後輩」たちに酒肴を供するに足りる筈はなかったのである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこはれた機械でキズだらけのレコードをかけてる時にそつくりで、絶えずガリガリといふ針音、ザラザラといふ雑音が響いてくる。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　トキ　ムカウノ　ムギバタケカラ　コトシニ　ナツテカラ　ハジメテノ　ヒバリガ　ソラニ　マヒアガリマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメガ　ヤムト　マヘヨリモ　イツソウ　アタタカナ　ヒノ　ヒカリガ　ソソギマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト、カゴカキノ　一リガ　ツエヲ　フリナガラ、「オーイ、ダンナア。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタツムリガ　ツノヲ　フツテルノヲ　ミテ　ヰルト、王サマハ、子ドモノ　ジブン、何ダカ、カタツムリノ　ウタヲ　ヨク　ウタツタ　コトヲ　オモヒダシマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヘノ　ナカニハ　フタリノ　トシヨリガ　ヰテ　チヨウド　ヒトツノ　パンヲ　フタツニ　キラウト　シテ　ヰル　トコロデシタガ、ハラノ　スイタ　ヲトコヲ　キノドクニ　オモツテ　パンヲ　ミツツニ　キリ、ソノ　ヒトキレヲ　ヲトコニ　メグンデ　ヤリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲトコハ　トシヨリト　ワカレテ　ナホモ　アルイテ　イキマスト、ナルホド　アノ　トシヨリガ　イツタトホリ、ハタケハ　タイハウノ　ワヤ　ウマノ　アシデ　スツカリ　アラサレテ　アリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
