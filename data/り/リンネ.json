    "definitions": [
      {
        "index": 1,
        "gloss": "samsara (cycle of death and rebirth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の信仰の中には、仏教的な輪廻永生思想があり、それがヘルンらしい純情の詩人的想像によって、一種独特の人生観にまで展開していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした輪廻の道程がもう一歩進んで堕落と廃頽の極に達し俳句が再び「宗匠」と「床屋」の占有物となる時代が来ると、そこではじめて次の輪廻の第一歩が始まるのではないかという気もする。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェーゲナーの大陸漂移説や、最近ジョリーの提出した、放射能性物質の熱によって地質学的｜輪廻変化を説明する仮説のごときも、あながち単なる科学的ロマンスとして捨つべきものでないと思われる。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る語が「ん」で終る語の次に来て複合する時、その語の頭音が、ア行音ワ行音であるものはナ行音となる（「恩愛」オンナイ、「難有」ナンヌ、「仁和」ニンナ、「輪廻」リンネ、「因縁」インネン、「顔淵」ガンネン。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）　ンの場合の連声は追々行われなくなって、ただ、「親王」「因縁」「輪廻」のようなきまった語のみに名残をとどめるに過ぎない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "口寄せ、梓神子は古い我邦の神おろしの術が仏教の輪廻説と混じて変形したものらしい。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして世界の可死を論じるために水や空気や火の輪廻を引用して種々の地文学的の問題に触れている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また地質学上の輪廻にも暗示を投げている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三番目「仇討輪廻」では、多血質、胆汁質、神経質とでも言うか、とにかく性格のちがう三人兄弟の対仇討観らしいものが見られる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを輪廻といひ、流転といふ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを輪廻といい、流転という。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に自分の青春なぞあると思ったのは、間ちがいだったと、私は東京の心理主義文化に歪められた自分の青春を抱いて、三勝半七のお園のように、「お気に入らぬと知りながら、未練な私が輪廻ゆゑ、そひ臥しは叶はずとも、お傍に居たいと辛抱して、是まで居たのがお身の仇」と呟いて、東京にさよならしたのである。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはれ、なほ爺は真面目に諳誦す、業の輪廻を。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして「輪廻三鈔」の中にあるやうな生活に入つた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原から帰つて以来の、東京麻布での所謂「雀の卵」の生活に属する者が主で、それには「輪廻三鈔」中の大部分も含まれてゐた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私の生活を知らうとする人は「輪廻三鈔」「雀の卵」と読んでそれから「葛飾閑吟集」に引き返して読んでほしい。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪廻三鈔　本集の歌で最も古いものは「雲母集」の新作や「白金の独楽」以前或は当時のものがある。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀の卵　本集は「輪廻三鈔」以後六年葛飾へ移るまでの東京麻布十番の時代のものである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「「輪廻三鈔」には未だ「雲母集」の余波が輝き、「雀の卵」に於て漸くその圏外に逃れ、心は身の落つきを思ふ朝夕と相重つて、いよいよ「葛飾閑吟集」の寂心に閑かに住しようとした。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪廻三鈔　　　　　　　四十二首但、「眺むれば満月光に」の原作介入、重複。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は同じく同じ神の声を同じ母胎の中で聴き、同じ血の鼓動を聴きつつ、輪廻転生の絶大苦悶から一時に一切の因縁を忘れて了つたのである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀歓かたみの輪廻は猶も堪へめ、泥土に似る身ぞ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪廻転生　　　　　　　――運命と鼻の表現（一）　その人の個性及び、その個性がその人の修養と経験とで研き上げられた人格とが、鼻の表現の変化の根柢を作っている事は、今まで研究して参りましたところに依って最早充分に了解の事と信ぜられます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔面中央の一肉団……本来不動、無表現の鼻柱はかくしてその人の個性、性格、人格を表明すると共に、父母未生以前の因果、弥勒の出世以後の因縁までも同時に眼の前に結び止めて、輪廻転生のあらたかさをさながらに拝ませているのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又不可思議をそのまま神として崇拝する万有神教は、輪廻転生の説と木乃伊とを生みました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……お気に入らぬと知りながら、未練な私が輪廻ゆえ、そい臥しは叶わずとも、お傍に居たいと辛抱して、これまで居たのがお身の仇……」とこっちから後を続けてこましたろかという気持で、階下へ降りた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢雄が羽太鋭治のその本や、国木田独歩の「正直者」、モーパッサンの「女の一生」、森田草平の「輪廻」などを、修一から読んでみろと貸して貰つたのは、三年生の時だつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し以ふに、群生昏焼舂磨の獄を立て、輪廻報応の科を具う。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その水莽草を食って死んだ者の鬼を水莽鬼というのであるが、言い伝えによると、この鬼は輪廻を得て来世に生れてくることができないので、その草を食って死ぬる者のあるのを待っていて自分の代りにし、それによって生れ代るといわれている。",
              "citation": {
                "source": "水莽草",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱な風景猫のやうに憂鬱な景色であるさびしい風船はまつすぐに昇つてゆきりんねるを着た人物がちらちらと居るではないか。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
