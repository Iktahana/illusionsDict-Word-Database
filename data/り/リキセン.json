    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hard fighting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "而して当面の敵たる何福は兵多くして力戦し、徐輝祖は堅実にして隙無く、平安は驍勇にして奇を出す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条早雲が、横合からとび出して行って、茶々丸を殺して伊豆をとったやり方などよりは、よっぽど、理窟があるが、結局陶晴賢との勢力戦であったのであろう。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて朝鮮の武将史儒はこの役に死し、祖承訓は残兵を連れて遼陽に還ったが、明の朝廷へは、我軍大いに力戦して居た際に、朝鮮兵の一部隊が敵へ投降した為に戦利あらず退いた、とごまかして報告した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤半之丞、武田七郎左衛門等数名の士が決死の力戦の後、竹束に重昌を乗せて営に帰るを得た。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の力戦振りは、「御手がら、げんぺい以来｜有間敷と申すとりざたにて御座候。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の力戦で、糺は既に身に深手を負っていた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か五人で斬込んだのであるから、その力戦振りも思ひやられる。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田稔麿は、脇差をとつて力戦し、裏庭で沖田総司と、一騎討ちになつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽天主義か　知的動員の倦怠　　▼漢口陥落を転機として、愈々国民的総力戦に移る。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等の周囲に迫つて来る死の諸相に対して極力戦はう。",
              "citation": {
                "source": "運命と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしかしっとりと秋の宵が迫って、行く手は彼は誰れ時の夕闇でしたが、しかしその宵闇の中にたばしる剣光を縫いながら、必死とあの宿の若者の力戦奮闘している姿が見えました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは主力戦艦の主砲よりはるかに長さは短いが、それでも砲身の全長は五メートル近くもあった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕に覚の柔道で、とびこんでくるやつを腰車にかけてなげとばし、つづいて拳固をつきだす奴の手を逆にとって背負いなげにと、阿修羅のように力戦奮闘した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の特徴は、わかり切ったことでありますが、武力戦にあるのです。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ精神総動員だ、総力戦だなどと騒いでいる間は最終戦争は来ない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民が総て統制的に訓練せられ、全部公役に服し、更に奉公の精神に満ち、真に水も洩らさぬ挙国一体の有様となった時武力戦に任ずる軍人は自他共に許す真の適任者であり、義務と言う消極的な考えから義勇と言う更に積極的であり自発的である高度のものとなるべきである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この徹底せる決戦戦争に於ては武力戦が瞬間的に万事を決定するであろう。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが戦争がすすむにつれ若い有識人を戦争に対する非協力な精神状態から極力戦争へ動員するために、また残酷な学徒動員のシステムを青春のヒロイズムにすりかえるために大学新聞は次第に官報的統制におかれた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてひとたび戦争が起れば、否応なく第三次世界大戦に突入する可能性が多く、原子力戦になる危懼が大きい。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日の力戦のためにはそれはあまりに虚弱である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とはいえご領主を相手にして、このわずかの人数をもって、いかに力戦いたしましても、勝つべき理由ござりませぬ！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の棋力は私とほぼ同程度だか、棋風は捉えどころがなく、こちらが強く出れば力戦を辞しないし、ふうわりと押せばさらりと受ける。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "無上の力戦緊張が一瞬にして生れる。",
              "citation": {
                "source": "相撲の放送",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、解剖学まで応用し、科学の粋をつくした力戦苦闘なのである。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家総力戦の真のすがたが、国民一人一人の眼にはつきりわかる時が近づきつゝあります。",
              "citation": {
                "source": "国防と文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中は軍需会社の親玉でも文士の先生でも、それはあなた、総力戦、ハイ総力戦、日本的、ハイ日本的、そんなこともやりましたけど、根はチャラッポコで、軍人さんの言ふことなんぞマにうけてゐる者は先づゐませんや。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は銃丸の中をくぐりぬけながら、力戦している警官隊の方へ進んでいった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "総力戦の意味は、軍事力と並行して国家活動のあらゆる分野、国民生活の全領域を、かかる「立派な勝利」の獲得に向つて、整備動員することであり、そのためには、これに応ずる国内の秩序と組織とが当然必要とされるのである。",
              "citation": {
                "source": "演劇と政治",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
