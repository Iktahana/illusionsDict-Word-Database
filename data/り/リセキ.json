[
  {
    "uuid": "b866e37b-4da4-5ce0-b715-be177c80b7a6",
    "entry": "離籍",
    "reading": {
      "primary": "りせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
