    "definitions": [
      {
        "index": 1,
        "gloss": "moonlit night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この夜は月｜冴えて風清く、野も林も白紗につつまれしようにて、何ともいいがたき良夜であった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今夜六月の良夜なりとはいへ、遠いい物音が、心地よく風に送られて来るとはいへ、なにがなし悲しい思ひであるのは、消えたばかしの鉄橋の響音、大河の、その鉄橋の上方に、空はぼんやりと石盤色であるのです。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ちつゞく惡鬼ばらひ、屋を壓する黒雲をぬぐつて、景氣なほしに「明月」も、しかし沙汰過ぎるから、せめて「良夜」とでも題して、小篇を、と思ふうちに……四五人のお客があつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夜　唐の玄宗、南の方に狩す。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、放たれたる女は、蜀道の良夜にあり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夜１月の夜のよう枯れし白樺なる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠数工の夜良夜よい花は空気をおくる。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夜鮮麗なは良夜の一二等星。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "居士が外来物を方便にする一例として篁村氏の「良夜」を引きたるが如きは、尤も我心を得ず。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その良夜の前の二、三時間を慌ただしい旅の心が騒めきやまぬ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はお前と宿縁があったから、お前を召んだ、良夜易闌、可即帰寝」　小吏不敢辞、遂侍仙妃枕席。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のやうな良夜なら、月の世界にもゆけさうに思へた。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如きの良夜は得易からず。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫摩黄金の良夜は、寂寞としてまた幽に奇しき畏の満ちわたる海と空との原の上。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫摩黄金の良夜は、寂寞としてまた幽に、奇しき畏の滿ちわたる海と空との原の上。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ月は美しいな、あのしんとした中空を夏八月の良夜に乘つきつて。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この良夜を如何んですナア」　と山県はしみ／″＼感じたやうに言つた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一間と離れた後の草叢には、鈴虫やら、松虫やらが、この良夜に、言ひ知らず楽しげなる好音を奏でてゐる。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほみ淵醉の良夜に、日子に婚ひてし日の初め、嚴のむしろを禁められて、花とし生ひつ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月明の良夜、慇懃に接す。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来珍らしい良夜であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百五十七　わたくしは蘭軒の事蹟を叙して此年文政七年の秋に至り、八月十五日の夜、蘭軒が江戸に於て無月に遭ひ、菅茶山が神辺に於て良夜に会したことを言つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山は良夜には会したけれども、歓を成すことを得なかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは仲秋三五の月が、玲瓏たる光を地上に投げ薄尾花の花の蔭で、降るように虫の鳴きしきる、一年に一度の良夜であったが、長い間の物忌から、すっかり欝気した純八は、その籠もった気を晴らそうものと、一人ブラリと家を出て、山手の方へ歩いて行った。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須原驛に着きしは、夜の九時頃なりしが、山中の荒驛は早くも更けて、冷露聲なく玉兎靜かに轉ずるの良夜も更に人の賞するものなく、旅亭は既に戸を閉ぢたるもの多かりき。",
              "citation": {
                "source": "秋の岐蘇路",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎ起きて『あかでしも朝寝しつ』と言ひ／＼、衣整なつて『おん口占に酬いまつらむ、笑ひなしたまひそ』とて、『良夜更易盡、朝暾已上※、願如梁上燕、棲處自成雙。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顧みもせず島野は、己ほどのものが、へん、愚民にお言葉を遣わさりょうや！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかと美しい女子など引き合わせたら、また何を言わりょうやら。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
