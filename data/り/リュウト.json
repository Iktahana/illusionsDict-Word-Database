    "definitions": [
      {
        "index": 1,
        "gloss": "smartly (esp. dressed)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道志山脈、関東山脈の山々の衣紋は、隆として折目を正した。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ草鹿砥宣隆という人が『古言別音抄』というものを書きました。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路の砂はすつかり流れてしまつて、小石が隆隆として突起してゐる。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の喫煙場で、隆と友人とが山の話をしていたが、ここにも病人があるらしく、若い女が流しの方で、しきりに氷をかいていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "其家には三人の子供があって、長女を政子、長男を政重、次男を政隆と云っていた。",
              "citation": {
                "source": "室の中を歩く石",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷王※と李景隆と、金川門を守る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は名を近藤重隆と謂う陸軍の尉官なり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　会釈したのは、乗竹侯爵の次男坊の、春隆という三十前後の青年だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、春隆という男に、もし取得というものがあれば、いんぎんなエティケットがわずかにそれであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだろうね」　昨夜首ったけ侯爵の春隆とてっきりだった――それが陽子の心境を変えてしまったのだと、京吉の眼は言葉のように針を含んでいた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、そんなに沢山に出来た能の曲目は、能の興隆と共に次第に減少して来た。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真田三代記と云うが、この幸隆と幸村の子の大助を加えて、四代記にしてもいい位である。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐より伝来の文化と、仏教の興隆とにより、美術工芸は非常なる発達を遂げ、単なる唐の模倣でない、新らしい芸術を産んでゐるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年からは、豊隆と自分とがひと月代わりに書くことになった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへが、これならば十分と思ふ服装で、隆として推出すんだね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうは、義隆という、ごついファーストネイムをもっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ宜しく」　キャプテン深谷氏の友人黒塚と云うのは、見たところまだ四十を五つと越していない、かっぷくのいい隆としたアメリカ型の紳士で、夫人の実弟洋吉と云う方は、黒塚氏に較べて体も小さく年も若く色の白い快活そうな青年だ。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで南朝が正統とか大覺寺の興隆とかいふことを別としても、私共の考へる所では、ともかくさういふ機運が動き、さういふ機運に相當する龜山、後宇多、後醍醐三代の天皇、或は北朝の花園院の如き名君がだん／″＼世の中に出られたので、自然公家の中にもさういふ人が出たのだと思ひます。",
              "citation": {
                "source": "日本文化の獨立",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "左翼の歴史が何故そのように急な興隆と急な退潮とを余儀なくされているかということについて、詳細にここで触れる必要のないことであろうと思うが、これ等の重大な歴史の相貌は悉く、日本がヨーロッパよりおくれて、而も独自な事情のもとに近代社会として発展して来たという特別な条件に原因をおいている。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そそくさと御仕度をなすって、黒七子の御羽織は剣菱の五つ紋、それに茶苧の御袴で、隆として御出掛になりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想界にも文学界にもいろいろのイデオロギイやイズムの目覚ましい興隆と絶えざる変遷があったが、その波に漾いながら独身時代の庸三の青壮年期も、別にぱっとしたこともなくて終りを告げ、二十五年の結婚生活にも大詰が来て、黄昏の色が早くも身辺に迫って来た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かつての自然主義隆隆とまったく同様、ちょうど三年にして衰退しはじめたのであります。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このシェーラーによるならば、ドイツの文學史は三百年目の興隆と三百年目の衰微との間を往復してをり、かくして紀元六〇〇年、一二〇〇年、一八〇〇年の三つの最高頂を經驗したとされる。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は通称を玄隆といって、百八十石六人扶持の表医者である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで最も身軽な矢川文一郎と、乳飲子を抱いた妻という累を有するに過ぎぬ浅越玄隆とをば先に立たせて、渋江一家が跡に残った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅越は名を隆と更めて、あるいは東京府の吏となり、あるいは本所区役所の書記となり、あるいは本所銀行の事務員となりなどした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅之助は後筑前守｜斉隆と云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやに、りゅうとしてるじゃないか。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の疎開していた町から、汽車で三、四時間、或る港町の駅に降りると、小川新太郎君は、りゅうとした背広服姿で、迎えに来ていた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ねずみ捕りは、思わず、はり金をりゅうりゅうと鳴らすくらい、おこってしまいました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
