[
  {
    "uuid": "75fcff9a-ce84-56ee-8536-90dfca5feee3",
    "entry": "両日",
    "reading": {
      "primary": "りょうじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
