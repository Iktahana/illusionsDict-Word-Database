      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lucky (auspicious) day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "改良日本語版を使った『ＴＨＥ　ＣＯＭＰＬＥＴＥ　ＯＺＵ』の制作が一段落付いた一九九四（平成六）年の春、祝田さんは仲間たちに「見せたいものがある」と声をかけました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "余道につかふることをえざれ、天を拝することをえざれ、鬼神をまつることをえざれ、吉良日をみることをえざれ。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "われよく汝等の顏をみれども、一だにしれるはなし、されど汝等の心に適ひわが爲すをうる事あらば、良日の下に生れし靈よ　五八―六〇汝等いへ、さらば我は、かゝる導者にしたがひて世より世にわが求めゆく平和を指してこれをなすべし。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてこの縁談の仲にはいってくれた人が伊那の谷から見えて、吉辰良日のことにつき前もって相談のあったおりに、青山の家としては来たる九月のうちを選んだのもそのためであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて仲人のもとまでと思いながら、かねて吉辰良日として申し合わせのあった日に当たる九月二十二日が来ても、彼にはその手紙が書けない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なんでもこの付近は、昔大工業の発展した大阪という都市があったんだそうな』　とエスペラント語に似た響きで『改良日本人』が教えてくれても、その時の人々にはそれはまったく不可解のことであろう。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧子は、「もし又あんなことになったら、私たちの生活は今度こそどうなるのかしらと思って……」　野良日にやけて、雀斑が見えるようになった顔を沈痛にふせた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
