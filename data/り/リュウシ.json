[
  {
    "uuid": "8e8245b7-86f4-59cd-a466-509026f40bbe",
    "entry": "粒子",
    "reading": {
      "primary": "りゅうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
