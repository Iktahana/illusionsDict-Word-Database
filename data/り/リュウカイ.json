    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cancelling a meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "挙り起ち遂に流会す。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたくしたちは極力これを妨害して流会させなければなりませんの。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒ぎの中から揺れて来る言葉の波は漸次に会議の流会を報らせて来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくその流会の原因は定員不足を理由としていることまで、寄り集った人波の呟きからだんだんと判って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "参木は、極力会議を流会させることを宣言していた芳秋蘭の笑顔を感じた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四〇　海港の罷市は特別会議が流会したのにも拘らず、ますます深刻に進んでいった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一躍一流会社の支店長級になり済したもの、庶民から一遍に新設官庁の役人に立身したもの、浪人から一足飛びに重役室の主人公となった者、新聞社や雑誌社の尤もな処へ目出たくおさまった者が〔多く？",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は此部屋で十日会――小郡同人の集まり――の最初の句会を開催する予定だつたのに、集まつたのは樹明さん、冬村さんだけで（永平さんはどうしたのだらう）、そして清丸さんの来訪などで、とう／＼句会の方は流会となつてしまつた、それもよからうではないか。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯俣のおやじさんは登歩渓流会のことを覚えていて、思い出話に花が咲いた。",
              "citation": {
                "source": "槍ガ岳",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "態※二流会社を志望する僕達は決して優秀でないから、擽ったいような心持で顔を見合せた。",
              "citation": {
                "source": "恩師",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二流会社では屈指だと言っていました。",
              "citation": {
                "source": "恩師",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今辰野君というのが定りかけています」「盛んにおやりですな」「何しろ一流会社中の一流で、秀才が雲と群っていますから、娘を持つ親は何うしてもこゝへ目をつけますよ。",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、僕は一流会社に勤めること十七年、先ずもって順調組だ。",
              "citation": {
                "source": "四十不惑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこの頃はいろんなインチキ会社が出来てね、とんだ会社員でくみ立てられた会社が、一流会社のようにひとをだましているらしいようです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎のつもりは躍進日本の一流会社の社員たちは印度の有色人種なぞを物の数にも入れていないぞ！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "集マラヌタメ、流会。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十八日――「丸金」ニテ、小頭組合評議員会ヲナシタルモ、二人シカ来ズ、流会。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "一流会社の支店長は二流会社の重役に当る。",
              "citation": {
                "source": "小問題大問題",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし在学中｜悉皆調子を下していたものだから、一流会社の採用試験を受けるような成績でなかった。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出世して一流会社の重役になっていた。",
              "citation": {
                "source": "ロマンスと縁談",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「○○紡績さ」「一流会社じゃないか？",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「○○紡績さ」「はゝあ」「一流会社だよ」「はあ」「実は妻の親父があすこに勤めているものだから、この間会った時、君に頼まれていたことを思い出して話したら、一人ぐらいは何うにでもなるから見込のある男なら寄越してくれと言うんだ」「先生」　と堀尾君はモジ／＼した。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半官銀行の頭取か一流会社の重役以下では納得してくれないらしい。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下さんは古い法学士で、鬢髪既に霜を置いているのに、二流会社の一課長に過ぎない。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い法学士で二流会社の課長は食い足らない。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、秀吉との会見は、信雄の発病という理由で流会となった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
