[
  {
    "uuid": "2589db67-77c0-58db-bf2a-e07a358810a0",
    "entry": "領事",
    "reading": {
      "primary": "りょうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
