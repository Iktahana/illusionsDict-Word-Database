    },
    "definitions": [
      {
        "index": 1,
        "gloss": "consul",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今朝はすべてが領事館旗のもとに従順で、私は錫と広場と天鼓のほかのなんにも知らない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大神宮のすぐ下にソビエト領事館がある。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "領事館御用の洗濯屋さんだからかと思ったが、電車通りを歩いていると、露文字の看板は外にも二つ見付かった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガロンはロシア人共産党員とともに上海に入ると、直に大馬路の一隅で露支共産会合が開かれ、赤衛軍の決死隊が組織され、党員徽章が配付されると労農領事館には青天白日旗とソビエット・ロシアの聯邦旗が交錯して掲げられた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京路を彼女はアメリカ総領事館書記、ローランド・グリーンと腕を組んであるいていたが、いつのまにか一品香ホテルに消えたと云うものがある。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてＮ国領事のバロン何某と中年のスカンジナビア婦人が二人と駆けつけて来た。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで毎日こうして次の論文の原稿を書いていたのかと思って、その一枚を取り上げてなんの気なしにながめていたら、Ｎ教授がそれに気づくと急いでやって来て自分の手からひったくるようにそれを取り上げてしまった、そうしてボーイを呼んでその原稿いっさいを紙包みにしてひもで縛らせ、それを領事に手渡しした。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "領事のほうからは、本国の家族から事後の処置に関する返電の来るまで遺骸をどこかに保管してもらいたいという話があって、結局Ｍ教授の計らいでＭ大学の解剖学教室でそれを預かることになった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手術の際にＯ教授が、露出された遺骸の胸に手のひらをあてて Noch warm ! と言って一同をふり向いたとき、領事といっしょにここまでついて来ていた婦人の一人の口からかすかなしかし非常に驚いたような嘆声がもれた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからひと月もたって、Ｂ教授の形見だと言ってＮ国領事から自分の所へ送って来たのは大きな鋳銅製の虎の置き物であった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の選ばれたものが、領事館へ陳情に出かけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "領事館は金持ばかりをかばった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、捕まった支那人のボーイと、それを使っていた外国人の主人とが、切っても切れない連絡があった確証が上がっても、外国人は、自分の国の領事館で裁判を受けるだけだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国人が、治外法権、領事裁判の撤廃を絶叫するのは、こんなところから原因していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇　領事館と支那官憲の疑問の眼が竹三郎の身辺に光っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また、たアくさん、領事館から来ているよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲は、厳重に領事館警察署員等に依って取りまかれていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違いのない筆で、領事館の裏書までしてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は、十日をすぎて、まだ、領事館警察の留置場から出てきなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだい、あの親爺はヘロ中で領事館に叩ッこまれとるし、婆さんをひとつものにしちゃどうだい？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二五　竹三郎は、領事館警察の留置場から、Ｓ病院に出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹三郎は、領事館の留置場で、ヘロインがきれてしまった肉体を、我慢が出来るだけ我慢をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎が這入って行くと、領事館からついてきた、帽子にエビ茶の鉢巻のついた若い巡査は、二人が、ちょっと顔を見合して室外に出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れがどんなにのた打ちまわっとったって、領事館の奴はへへら笑っていやがるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のような、みずから求めて世間に義理を欠いて孤独な生活を送りながら、それでいて悟りきれずに苦しんでいるあわれな人間にとっては、ケーベルさんのような人が、どこかの領事館の一室にこもったきりで読書と思索にふけっているという考えだけでもどんなに大きな慰藉であったかしれないと思う。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本國を出でゝから二｜年間、旅から旅へと遍歴して歩く身は、折々日本の公使館や領事館で、本國の珍らしき事件を耳にする外は、日本の新聞などを見る事は極めて稀であるから、私は實に懷かしく感じた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ猪野の詐欺横領事件は、大審院まで持ち込まれ、審理中であるらしく、猪野はいつも憂鬱そうに、奥の八畳に閉じ籠もり、酒ばかり呑んでいた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は斜めに、丘の上にある昔の韓国時代の仏蘭西領事館の赤い建物の上に傾いていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で為朝は一人、いつまでもつかまらずに、近江の田舎にかくれていましたが、戦の時にうけたひじの矢きずがはれて、ひどく痛み出したものですから、ある時近所の温泉に入って矢きずのりょうじをしていました。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話によると、東京では、家もないし、揉みりょうじを頼む人もあまりないので、これから、長野の温泉場をまわってみると云うことだった。",
              "citation": {
                "source": "おにおん倶樂部",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
