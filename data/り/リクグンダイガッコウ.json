        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "聯隊勤務に就かせ給ひ、普魯士国陸軍大学校に入らせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "普魯士国陸軍大学校の業を卒へさせ給ひ、四月十二日伯林を発せさせ給ひ、七月二日紀尾井町の第に帰り入らせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "士官学校の教官をして、陸軍大学校の入学準備をしていたのだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの姉さんは、田中という騎兵大尉の、陸軍大学校の学生のところに嫁いていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田は当時陸軍大学校の学生で、この飯倉の邸内の小さな家に住んでいた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍大学校の出身ならば一通りの戦術論や戦史に関する原稿は書けるだろうし、多少文章が今日の文化常識に副わなくても素人の知らぬことが書かれる以上一応読物にはなるかも知れない。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
