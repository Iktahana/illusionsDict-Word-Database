        "index": 1,
        "gloss": "ribbon or lapel badge worn in place of a medal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
