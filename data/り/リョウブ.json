      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese clethra",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "命令法５・２東京日日（夕）　文典といへば、どんな学生でもが虫下しの薬のやうに厭がる学科である。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれをどんな風にいひかへたなら、命令法になるかためしてみますから。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを命令法にいひ替ると……」　未来の将軍は腹一ぱいの声でわめいた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの法律の規定は概ね皆な因果法の規定となっておって、命令法の体裁をなしているものは殆んどない。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やすらへ」は「やすらふ」の命令法であつて、ぐづ／＼する事である。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "命令法の練習であったとは情けなし。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "山門寺門の天台側からこの抗議があって見ると、仮令法皇の思召でもそれを押し切る訳には行かなかった。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナアルさんは、しどろもどろになり、自動詞と他動詞を間違えたり、不定法の現在と命令法の複数を間違えたりする。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、個々の法規のなかには、普通の国語知識を持っていさえすればその法的意味を正しく理解し得るものもあるけれども、それはむしろ稀な場合であって、法令法規の大部分は解釈を予定して書かれており、解釈を通して初めて法が何であるかを知り得るようにできている。",
              "citation": {
                "source": "法学とは何か",
                "author": "――特に入門者のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ山窩の伝令法、瞬く間に山塞まで、非常の知らせが達するだろう。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにそこは既に風雪の激しい山頂若しくは夫に近い所であるから、椈や楢や七竈までが令法や万作などと同じように灌木状をなして曲りくねっている中へ、米躑躅や石楠などが割り込み、甚しい場所では更に黒檜や米栂や偃松をさえ交えている。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初は下生えの少ない椈の大森林の中を登るので至って暢気であったが、千三百米位から喬木が減じて次第に藪が甚しくなり、令法や石楠や、犬黄楊などの密叢が最も人を苦しめる。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其瘤までは令法、犬黄楊、楢、米躑躅、七竈の類が邪魔をするけれども、通行は割合に楽である。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処からシデや令法（方言、牛の糞）や槭などの茂った山の横を搦みながら少し行くと、雨樋を竪てたような潜り戸の狭間が待ち構えていた。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎ら、今日の我が国の現状を見るに、すべて政令法度は、天皇陛下の聖明なるお考えから出るのではなく、また庶民の公議によるものでもない。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎等、方今、我が皇国の現状を熟察するに、凡そ政令法度、上天皇陛下の聖旨に出づるにあらず、独り要務の官吏数人の臆断、専ら決するところにあり。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから姉川、さかもとの合戦がござりまして、いちどは扱いになりましたけれども、たちまち和議もやぶれてしまいまして、織田ぜいのためにじり／＼と御りょうぶんを削られてゆきました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて信長公はわずかのあいだに数箇国をきりなびけられ、こと／″＼くわがりょうぶんにくわえられまして、しょうしへの御ほうび、こうにんのおしおきなど、それ／″＼御さたあそばされ、九がつ九日にはもはや岐阜のおしろにおいて菊の節句をおいわいあそばされました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひでよし公の方では、この雪のあいだに柴田がたの大名しゅうを御せいばつなさるおぼしめしとみえ、年があらたまりますとふたゝびたいぐんをもって勢州へ御しんぱつなされまして滝川左近｜将監どのゝ御りょうぶんを切り潰され、しきりにかっせんのさいちゅうと申すしらせがござりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば三万石のりょうぶんをさしあげて一生｜御扶持申しましょうと仰っしゃるのでござりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
