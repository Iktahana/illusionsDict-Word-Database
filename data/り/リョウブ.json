[
  {
    "uuid": "a34ea37b-17ea-5dcd-9a26-fa62d548b7d4",
    "entry": "令法",
    "reading": {
      "primary": "りょうぶ",
      "alternatives": [
        "リョウブ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
