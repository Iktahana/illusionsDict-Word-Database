    "definitions": [
      {
        "index": 1,
        "gloss": "feeling of solidity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
