  {
    "uuid": "32013591-fced-5e2b-9e3f-9add01eeddb6",
    "entry": "陵墓",
    "reading": {
      "primary": "りょうぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imperial tomb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其ノ罪正ニ大帝ノ陵墓ヲ發クノ大逆政策ヲ改メズシテ支那ノ排日ヲ怒リ米國ノ排日ニ憂ヘ尚且ツ茫々然トシテ天佑ヲ夢ム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ここに都していた遼（契丹）代の陵墓で、周囲には古木がおいしげって、野草のあいだには石馬や石羊の横たわっているのが見いだされる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "安南王の陵墓附近の、林野巡視の駐在所まで、一人で出掛けて行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陵墓附近は原生林が昏く続き、カッチヤ松や、ナギが亭々と原生林のなかに混生してゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝ、安南の陵墓のあつた処だね？",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東漢時代の石彫に見えて居る馬車や、六朝時代の陵墓から發掘された馬車の模型と、十二三年前に、私が支那内地旅行の時乘用した馬車と略同一である。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "荀子が陵墓發掘のことを論じて、雖此也。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆恩殿の後に土を円形に盛つた宝頂が即ち清の太宗の霊柩を収めた陵墓である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中に「神楽駄場」の平地があり、霊地を象徴する環状石群があり、遠き昔から「いらずの山」としてもつたいづけられてゐた神陵所在地は、近年或る淫祠建立のため蹂躪され、その土饅頭式陵墓の大半を破壊されてしまつた。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "無智な敬神観念が、陵墓の何たるやを理解せず原形を破壊する位、むしろ当然であつたかも知れぬ。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後、十一月になつてから、近親の陵墓にも初穂が進められ、此と前後して新嘗祭りがとり行はれる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "陵墓への荷前使も、生きてゐられる尊親に朝覲行幸の礼を致されるのとおなじ意味の誓ひであつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えてふた月、十一月中旬はじめて、当今主上近親の陵墓に、荷前使を遣し、初穂を捧げられる。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "死者に奉る魂の事は、年末の荷前使が、宮廷尊族の近親の陵墓へたてられたことから見ても、明らかである。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この荷前は、東人が捧げた、生蕃の国々の威霊であつたのを、天子から更に、まづ陵墓に進められたことゝ解する外はない。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、つぎは鎮め葬つた上、陵墓の前で諷誦すべきものである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此初荷を更に宮廷から、伊勢や、陵墓へ進められる使者をのざき使ひといふ。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして現存の宣命は、伊勢神宮及び陵墓に告げる場合の固定したものゝ外は、常に同一の詞章を用ゐたことはなかつた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲人の中、建築に交渉の多い者のあつたことは、すさのをの命の出雲八重垣の歌、大国主のたぎしの小浜の火｜燧りの呪詞、播磨風土記の出雲墓屋の条、引いては出雲人で河内に移住し、土師氏の祖先となつた野見宿禰の陵墓に関する伝承等が示してゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓屋や陵墓の築造は、昔は、建築事業になつてゐた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、天子様のお血筋や、外戚の陵墓にも奉る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "約言すると、地方から、宮廷へ奉る処の稲の初穂を、九月に入つて、伊勢へ奉るのを神嘗といひ、其他の神々又は、大きな社に奉るのを相嘗と言ひ、陵墓に奉るのを荷前と言ふのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築として何の奇もなく巧もなく、而かも人に甚深の感動を與ふる處が、その崇高偉大なる所以であり、陵墓建築として洵に理想に近いものである」と云つて居られるは、實に私の言はうとする所を道破せられて、一語の之に加ふ可きものがない。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和平野にはすでにあれだけの大陵墓を築造し、あれだけの副葬品を埋蔵し、史部なる記録係の官吏もあり、使者をシナ南朝に遣わして技師を招聘したという応神天皇の御代においても、山一つ南にはいまだなんら平地の文化に触れることなく、太古のままの山人生活をなしていた人達が住んでいたのであった。",
              "citation": {
                "source": "日本における史前時代の歴史研究について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "守戸は同じく陵墓の番人でも、賤民であった陵戸とは違って、もと立派な良民です。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して陵墓の数は次第に増して、墓守の需要はますます多くなって来る。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで持統天皇の時に、陵墓の付近の良民を徴発して、三年交替にして陵戸の代理をさせた。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに中世陵墓の制も紊れて、守戸の扶持も行き届かぬ。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口はだんだん増して来て、生活に困難を生じて来るという事になっては、彼らは自然慣れた職業からして、陵墓以外一般世間の墓番をさしてもらう。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "内遠翁は紀州の夙部落の実際を調査して、夙の名のあるもの十の中で、一つは皮多、二つは付近に陵墓があるが、他の七つは全く陵墓に関係がない。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
