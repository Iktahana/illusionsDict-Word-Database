  {
    "uuid": "90ec3201-2477-57e0-a40c-0646262b6df4",
    "entry": "二",
    "reading": {
      "primary": "リャン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
