    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fluent (in a language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、女は急に調子づいて、流暢な英語で云ひ返した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵胃の工合の悪いときであるらしいが、そういう夢の中ではきまって非常に流暢にドイツ語がしゃべれるのが不思議である。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は語学も余程進んでいたのだし、又実際豚の舌は柔らかで素質も充分あったのでごく流暢な人間語で、しずかに校長に挨拶した。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術部長のウィーゼ博士は物静かで真摯ないかにも北欧人らしい好紳士で流暢なドイツ語を話した。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤコフ・イリイッチはそうしたままで暫く黙って居たが、内部からの或る力の圧迫にでも促された様に、急に「うん、そうだ」と独言を云って、又其の奇怪な流暢な口辞を振い始めた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水には落下の性を姿に現したプリムノという仙女と、流暢の性を現したカンリロエという仙女と、清浄を現したアカステという仙女と、飛沫を現したプレキサウレという仙女とが巣付いている。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから落ち着いて流暢な英語で反駁演説をはじめたのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言は、明晰に、口｜吃しつつも流暢沈着であった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて昼間「そろばん屋」から買うて来た（――といっては嘘になる、実は見知らぬ女からその本代を恵まれた）シーグフリードの「アメリカとは何ぞや」を読み出したが、冷静を欠いた頭では、流暢な山吹教授の訳文もすらすらと読み通せなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、「規矩男さんは、なかなかしっかりしていらっしゃいますね」と云って、あまり早く問題を提議したような流暢でない気持がした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流暢で構梁の慥かな肩の頂面に、つんもり扇形の肉が首の附根の背後へ上り、そこから青白く微紅を帯びた頸が擡げられた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、すこししゃがれた声で、流暢にきいた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "憾むらくは、通篇儒生の口吻多くして、説話は硬固勃率、談笑に流暢尖新のところ少きのみ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ビイルを一口啜つてかう云つた老人のドイツ語は、期待した程流暢ではなかつた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人　　　　　　　一　その翌日、神戸行きの急行列車が、函根の隧道を出切る時分、食堂の中に椅子を占めて、卓子は別であるが、一｜人外国の客と、流暢に独逸語を交えて、自在に談話しつつある青年の旅客があった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "流暢に出た大阪弁に弾みつけられてどんどん駆け出し、勢よく飛び込んでみると、おやッ！",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ何の物音もなく眠つた街に、住む人は因循で、ただ柔順しく僅に Gonshan（良家の娘、方言）のあの情の深さうな、そして流暢な軟かみのある語韻の九州には珍しいほど京都風なのに阿蘭陀訛の熔け込んだ夕暮のささやきばかりがなつかしい。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "流暢さの代りに、絶対に人に疑を抱かせぬ重厚さを備え、諧謔の代りに、含蓄に富む譬喩を有つその弁は、何人といえども逆らうことの出来ぬものだ。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流暢に出た大阪弁に弾みづけられてどん／＼駆け出し、勢よく飛び込んでみると、おやッ！",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめん下さい、先生」　と、彼は流暢な英語で挨拶しました。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで『源氏物語』を見てとてもこういう流暢なる文は書けないと思い、マコーレーの文を見てとてもこれを学ぶことはできぬと考え、山陽の文を見てとてもこういうものは書けないと思い、ドウしても私は文学者になることはできないといって失望する人がある。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にあなたがたの心情をありのままに書いてごらんなさい、それが流暢なる立派な文学であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おゝ、ジロウ――お前のことは予々お前の兄から……」　フロラは流暢な自国の言葉で、洗練された愛嬌を振りまきながら腕を差し出した。",
              "citation": {
                "source": "ガール・シヤイ挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体この書は文句｜麁野、下筆また流暢ならず、とても及ぶべくもないが、古今名人大一座で話し合う所を筆記した体に造った点が、馬琴の『昔語質屋庫』にやや似て居る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳文も流暢で、非常によく出来てゐる。",
              "citation": {
                "source": "レイモンドの『農民』",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "水蔭と二人で、いかにも親しい友達であるかのやうに――他で聞いては、鳥渡わからぬやうな符徴の入つた流暢な話し振、それが何んなに私の耳に羨しく響いたか知れなかつた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときＭ大尉はつかつかと進みよって、りゅうちょうなフランス語で大声に申しました。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
