[
  {
    "uuid": "e08c2115-ed7f-5bd1-ada5-d02381b67936",
    "entry": "流暢",
    "reading": {
      "primary": "りゅうちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
