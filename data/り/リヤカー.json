    "definitions": [
      {
        "index": 1,
        "gloss": "light two-wheeled trailer (towed by bicycle, pulled by hand, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この町では、いまも昔と変らず、毎朝、さかなやがリヤカーにさかなを一ぱい積んで、イカにサバだぢやあ、アンカウにアオバだぢやあ、スズキにホツケだぢやあ、と怒つてゐるやうな大声で叫んで、売り歩いてゐるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曳いてゐるリヤカーには、さまざまのさかなが一ぱい積まれてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日から君枝は、病院へ便利屋の電話が掛ると、いそいそと出掛け、リヤカーをつけて配達にまわった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠より根こじあがなひ、リヤカーに山ほども積みもて來さしつ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠より根こじあがなひ、リヤカーに山ほども積みもて来さしつ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日から君枝は、病院へ便利屋の電話が掛ると、いそいそと出掛け、リヤカーをつけて配達に廻った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "休むわけには行かず、夜おそく新聞を畳んで、郵便局までリヤカーにのせて持って行くのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "道すがら雪は容赦なく靴のやぶれから彼の足にしみていたが、泥濘の中をリヤカーで病人を運んで来る百姓の姿も――更に悲惨な日の前触のように、彼の心を衝くのだった。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのビルの一室が開けてもらえるかどうかはっきりしなかったが、彼の全財産を積んで一台のリヤカーはもうその建物の前に停っていた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋釜を満載したリヤカーや、老母を載せた乳母車が、雑沓のなかを掻きわけて行く。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上を生存者のリヤカーがいくつも威勢よく通っていた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヤカー一台に荷を纏め彼はボストンバツグ一つで中野を脱出することができた。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのビルの一室が開けてもらへるかどうかはつきりしなかつたが、彼の全家財を積んだ一台のリヤカーはもうその建物の前に停まつてゐた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上を生存者のリヤカーがいくつも威勢よく通つてゐた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、僕はあるとき、その傴僂男が汗みどろでリヤカーを牽いてゐる姿を路上で見てハツとした。",
              "citation": {
                "source": "火の子供",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れた青草を積み、農具の光ったリヤカーを引いて戻って来た久左衛門の長男の嫁は、川の流の傍で私に丁寧なお辞儀をした。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは堂島の橋の手前で、朝日の前あたりだったが、私が歩いていると、前を大きな箱を積んだリヤカーが走り脱けた。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端、電車の前部に突きあたり、箱ごと眼の前でリヤカーがぶっ倒れた。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗みどろになつて人の挽いて来るリヤカーがあるといつた調子で、かういふ方面に全くの素人である自分の如き者にとつては、『名状すべからざる』光景といふべきものであつた。",
              "citation": {
                "source": "三年",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室となると部屋中の者総がかりで、或者は布団をかつぎ、或者は食器を入れた笊を抱へて、病人を載せたリヤカーを囲んでぞろぞろと病室までを異様な行列を続けて行く。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "診察のあつたあくる日、成瀬もまたリヤカーに載せられて五号へ牽いて行かれた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヤカーの人となつた刹那、彼はふと手押車で手術室へ運んで行かれた喉頭癩の男を思ひ出し、その男は今はもう元気に毎日｜咽喉に取りつけた管のついた金具の掃除をしてゐるさうであるが、手足をばたばたと藻掻いた様子が成瀬の心から離れ難いのであつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はリヤカーの中で跼み身をちぢめてぼうつと熱に浮かされた頭に車の響きが激しく伝はつて来るのを覚えながら、遂々自分も重病室の一員となつたかと無量の感慨が溢れた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつと眼を閉ぢてゐると、彼はふとリヤカーに載せられて送られて来た時の印象が蘇つて来て、何故ともなく非常な孤独を覚え、このまま自分は死んで了ふんではあるまいかと淡い不安が心を流れるのであつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯を終ると彼女はリヤカーに乗せられて、雨の中を隔離病室へ転室して行つた。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体は白木の箱に入れられ、それを載せたリヤカーを引きながら、焼場まで奇怪な行列が続いて行く。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の毛の一本もない男、口の歪んだ女、どす黒く脹れ上つて顔・手、松葉杖をついた老人、義足の少年、そんな風な怪しげな連中が群がり、中央にリヤカーを挾んで列をなして畑の中を通つて行く様はちよつと地上の風景とは思はれない。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室することが定ると、収容病室から舎へ移つた時のやうに、同室の人達が、蒲団、食器その他をもつて、入室者を中央に挾み、或はリヤカーに乗せて送つて行く。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石を運ぶのには、分譲地の一軒に住んでる大工職のひとが、リヤカーと労力とを提供してくれました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
