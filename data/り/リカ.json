      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "underneath a Japanese plum tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「我李下の冠のいましめを思はず、瓜田に沓をいれたればこそ」「道のさまたげいと多からんに心せでは叶はぬ事よと思ひ定むる時ぞ、かしこう心定りて口惜しき事なく、悲しきことなく、くやむことなく恋しきことなく、只｜本善の善にかへりて、一意に大切なるは親兄弟さては家の為なり。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちが顔のいい上にあんなにはねッかえりで、瓜田李下の嫌疑なんぞにかまわないところへ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く李下に冠を整し瓜田に履を納れずとは何か。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "李下の冠、瓜田の沓。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、フェライラは、ある日、李下で冠を脱ぐ以上のことをやってしまった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都は嘗つて小生自身二年間ゐて、詩人にとつては有難い土地だと思つてゐるので、京都あたりからもつと面白いものが出てもよかりさうなものだと、かねがね思つてゐたが、仲々出なかつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔なべてはしけく　よそほひて〕宮沢賢治なべてはしけく　　よそほひて暁惑ふ　　　　　　改札をならび出づると　　ふりかへる人なきホーム　　　陸の橋歳に一夜の　　　　旅了へしをとめうなゐの　　ひとむれに黒きけむりを　　　そら高く職場は待てり　　　春の雨",
              "citation": {
                "source": "〔なべてはしけく　よそほひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長がもし人望のよい人である場合は、文部省によつて、アツサリ放校が取消されたにしても、何らか校長の顔を立てるためには生徒の方に臨時の損が振りかけられたに相違ありません。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "外もあんまり涼しくはなかつた、家の中よりか涼しいくらゐであつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと鍋屋横丁の裏辺りから東京高等学校の辺りにかけてといふものは、いやな東京の郊外中でもわけてもいやな所であり、硝子障子から外をみると、枯草の野ッ原の中で子供が三つ凧を揚げてゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "』」――「嘗て私は、橋の上を通りかゝつたとき、橋の上では人間が、みんなニヒリスチックになるものだと考へた、思つた。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは暗くなる時刻が来る少し前あたりから人に会ふやうな機会になつてゐたことが不運みたいなもんで、それ故何もかも神秘なやうなものでもある。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりかまだ歩いてゐた方がマシである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自分に友人のないことは、この偏屈と我がままのためであつた、折角親しくなりかけても、それですぐ不和になつてしまふ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま斧鉞を加へられたと思ふ個所も、決して原作の詩情を失はないばかりか、却つて原作よりも善くなつて居る。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あれには十年たっぷりかかりまして、と殊勝らしく伏眼でいったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一文にとりかかるため、私は、三夜、熟考した筈である。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりかまえて、一日一日を、せめて悔いなく送りたまえ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま教ったばかりのフランスの叙情詩とは打って変ったかかる無学な文句に、勝手なふしをつけて繰りかえし繰りかえし口ずさみながら、れいの甘酒屋を訪れたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なないばかりか、少し太った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
