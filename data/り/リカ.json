[
  {
    "uuid": "3d74ba0e-896a-595f-a05e-ddd5f06bbbdc",
    "entry": "理科",
    "reading": {
      "primary": "りか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
