    },
    "definitions": [
      {
        "index": 1,
        "gloss": "science (natural sciences and related fields, incl. mathematics, engineering, medicine, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やはり弘前高等學校の理科に在籍してゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理科大学の二年生で西片町に家を持っていたその頃の日記の一節を「牛頓日記」と名づけて出したことがある。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも二年生のとき牛頓祭という理科大学学生年中行事の幹事をさせられたので、それが頭にあったためかもしれない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校の理科の時間にＴＫ先生という先生が坩堝の底に入れた塩酸カリの粉に赤燐をちょっぴり振りかけたのを鞭の先でちょっとつつくとぱっと発火するという実験をやって見せてくれたことを思い出す。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理科の教科書ならばとにかく多少でも文学的な作品を児童に読ませるのに、それほど分析的に煩雑な註解を加えるのは却って児童のために不利益ではないかと思うというようなことを書き送ったような気がする。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに限ったことではないが、いわゆる理科教育が妙な型にはいって分りやすいことをわざわざ分りにくく、面白いことをわざわざ鹿爪らしく教えているのではないかという気がする。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこのレンズの大きさがどれ位あるかまた〔〕その中のさまざまの星についてはもう時間ですからこの次の理科の時間にお話します。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日大学の専門の学生でさえ講義ばかり当てにして自分から進んで研究しようという気風が乏しく知識が皮相的に流れやすいのは、小学校以来の理科教授がただ与えられた知識を覚えればよいというように教えこまれている結果であろう。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまた理科教育上極めて悪いことである。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正七年十月『理科教育』）",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにしてすべての戸棚や引出しの仕切りをことごとく破ってしまうのが、物理科学の究極の目的である。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ反対に私は学校で教える理科は今日やっているよりずっと実用的に出来ると思う。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時理科大学物理学科の聴講生となって長岡博士その他の物理学に関する講義に出席した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正七年十二月『理科教育』）",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌などで時々小学校の理科の教案と称するものを見ることがある。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし理科教育に従事される方々になんらかの参考になれば仕合せある。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三年十一月『理科教育』）",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の眞晝近く、地上のすべての事物は、人も、樹木も、家屋も、電柱も、また砂にまぎれる小蟻さへも、息を途絶えさすやうな劇しい暑さに疲れ果てて、ぢつと聲をひそめて立つてゐるやうに思はれるその眞晝近く、私は理科大學研究室の窓際の机に向つて、一所懸命に蘭科植物の葉色素研究の爲めに顯微鏡を覗き込んでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通教育にも理科の課程がかなり豊富にあるようであるから、それがよく呑み込めていれば、それだけでも一通りはかなり役に立つべきはずであるが、実際それがそうでないのは、教える方と教わる方と両方に罪があるであろう。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理科の学問をしているのに、どうして自分でラジオ機械を修繕しないのかと聞かれることがある。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして算術帳国語帳理科帳とみんな書きつけました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコはもう大悦びでそれをにがにがならべて見ていましたがふと算術帳と理科帳と取りちがえて書いたのに気がつきました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこのレンズの大きさがどれ位あるかまたその中のさまざまの星についてはもう時間ですからこの次の理科の時間にお話します。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全な材料はなかなか急には得難いので、ここではまず最初の試みとして東京天文台編「理科年表」昭和五年版の「本邦のおもな火山」の表を採ることにする。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく理科の書物なぞにある、ビーカーの底をアルコール・ランプで熱したときの水の流れと同じようなものになるわけです。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "法科のベルナー君や理科のデフレッガア君などは目下郷里へ帰ってたいへん静かであります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇九年の夏帝都セントピータースバーグを見物した時には大学の理科の先生たちはたいてい休暇でどこかへ旅行していて留守であった。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば小学校の理科の教程といったようなものを見ても、その膳立てが立派であると同時に料理の種がすっかり限定されてしまって、生徒はそれだけを食って満足するが、他に食物のあることをいっさい忘却してしまう。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不用意に取って来た一草一木を机上に置いて一時間のあいだ無言で児童といっしょにひねくり回したり虫めがねで見たりするほうが場合によってははるかに有効な理科教育になるということもありはしないか。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこのレンズの大きさがどれくらいあるか、またその中のさまざまの星についてはもう時間ですから、この次の理科の時間にお話します。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
