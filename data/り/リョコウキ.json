    "definitions": [
      {
        "index": 1,
        "gloss": "journal of one's travels",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
