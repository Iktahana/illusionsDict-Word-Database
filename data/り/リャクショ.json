        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆる『御本書』または『御本典』すなわち『教行信証』の行巻の終わり、信巻の前に付せられた『正信念仏偈』、あるいはいわゆる『略文類』または『略書』すなわち『浄土文類聚鈔』の中にある『念仏正信偈』は浄土史観を述べたものである。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって本典および略書の両偈がまず弥陀および釈迦について述べ、ついで七高僧について述べているのは当然である。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物語は既に以前に、九郎右衛門に代って此｜作者が、大略書き綴った筈である。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの作詩の動機に就いては「有明詩集」自註に大略書いておいたのを見てもらひたい。",
              "citation": {
                "source": "「有明集」前後",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
