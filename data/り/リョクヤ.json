        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし自分の眼底にはかの地の山岳、河流、渓谷、緑野、森林ことごとく鮮明に残っていて、わが故郷の風物よりも幾倍の色彩を放っている。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "底は一面の白砂に水紋落ちて綾をなし、両岸は緑野低く春草煙り、森林遠くこれを囲みたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭ヶ岡の樺太神社から瞰下した豊原の夜景はまるで緑野の中の正しい灯の碁盤目であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "至るところの緑野にポプラや楊の並み木がある。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣根ただ一重の内側の緑野は、自分らとは生涯なんの因縁もない別の世界のような気がする。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊七千｜駱駝三千という如き大群の家畜を養い得んには広き緑野を要するのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヨブの外にも彼に匹敵する、または彼に近き豪農が住んでいたことも当然推定せらるるが故に、かかる緑野の充分ある地はデュマの外にはないのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――かくて、われまた緑野の花は見じ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉突台のような緑野の緩斜面だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥後平野の広大な緑野が広がり、その向こうには青い峰々がぐるりと輪になって取り囲んで、地平線の光をバックにして光り輝いている。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "道夫は又同時に横網町の朝川善庵、薬研堀の萩原｜緑野、引舟通の大橋｜訥庵にも従遊した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上に立つて緑野の中へ涯知らず白く烟つて行く下流を見渡した時、※ルサイユ宮の運河などは児戯だと思つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦跡を弔ふと共に、よく晴れた五月の空のもとで、高粱が芽を出したばかりの広い緑野を展望するのは快いことであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "路に沿ふ楊柳の間から、緑野の前方に、金州の城壁と、其上にある可愛いい城楼とが竜宮の図のやうに望まれ、路には種種の形をした支那の荷車が交錯し、その中を支那馬車に乗つて行く呑気さは、異国情味の面白さであつたが、唯だ白く立つ砂ぼこりには困つた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏には高粱の為めに展望を妨げられるのであるが、私達は高粱が三四寸伸びただけの緑野の涯も無く霞んでゐるのを車窓に眺めながら、四人で歌を詠んでゐた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和はなほ合ひがたきかくれ水か、精魂さらずば直に緑野のべ、命の甘き泉のしぶきがもと露浸む華の護符を拔きえましや。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともそこにはかわいた、煩鎖な概念的理窟や、腐儒的御用的講話や、すべて生の緑野から遊離した死骸のようなものはない。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "村路を東にぬけると、左に小高くせまる山毛欅の林の、うら葉はやや秋づいた下蔭に、エリカの花はまだ紅の花を敷きつめていた、花にはコケモモの紅い果や、カンパヌラの紫が混じっている、私達はその木蔭に寝ころんで、樅の間に瞰下ろされる、ウンテルゼーエンの緑野を眺めた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当山修験、上州緑野郡安中宿天照寺配下。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　沙漠の開発　ボルダー・ダムの建設によって、もう一つ得られた天恵は、沙漠を緑野に化したことである。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいったように、このダムによって、南カリホルニア州にはアメリカ第二の工業中心地が生れ、またイムピリアル平原の沙漠を緑野に変えることによって、アメリカの食生活の改善にまで及んだのである。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの、例えば農地の開発を例にとってみるに、前にいったイムピリアル平原の開発が即ちそれであるが、灌漑水さえ十分にあれば、この沙漠は緑野と化すことが出来るということが既に実証されていたので、このダムの予算が通ったのである。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思って私の魂は遠くバビロンやアッシリヤの古代の伝説の世界にさ迷ったり、コナンドイルや涙香の探偵小説を想像したり、光線の熾烈な熱帯地方の焦土と緑野を恋い慕ったり、腕白な少年時代のエクセントリックな悪戯に憧れたりした。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれば、宋朝治下の塗炭の民土に、一｜颯の清風と、一望の緑野を展じるものと、望みをかけ得られないこともないのだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、寄手の陣頭より、おうと答えて、劉玄徳、左右に関羽、張飛をしたがえて、白馬を緑野の中央へすすめて来た。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
