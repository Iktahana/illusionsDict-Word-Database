[
  {
    "uuid": "5c4ea6dc-fb09-5db5-85cb-7f2b1047f11f",
    "entry": "良案",
    "reading": {
      "primary": "りょうあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
