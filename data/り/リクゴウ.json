        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "皆不折が書いたので水彩の方は富士の六合目で磊々たる赭土塊を踏んで向うへ行く人物もある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ「天地の境」五、六合目の等高線、森林を境として、山を輪切りにしたところの御中道を彷徨する私は、路の出入に随って、天に上り、地を下る、その間を、鳥と、虫と、石楠花が、永久｜安棲の楽土としている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　乱雑の美　五、六合間の等高線をゆく、御中道の大沢近くくると、にわかに婉曲してひた下りに下る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お中道めぐりの時は、ここから御殿場の三合目の小舎に出て下山したが、これより先、大宮口から茨木君と長男を連れて来たときは、この大宮口の五合目の室から六合七合と登った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また富士山の「御中道めぐり」と称して、山腹の五、六合目の間を一匝する道がある。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六合目――宝永の新火口壁（いわゆる宝永山）まで来ると、さすがに高嶺の冬だと思われる冷たさが手足の爪先まで沁みて来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六合五勺にして、頬は皮膚病患者のように黄色になった、弟はと見れば、唇は茄子のように、うす紫になっている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焼酎でも結構結構」と、焼酎五、六合に胡瓜の漬物を出して貰い、まだ一缶残っておった牛肉の缶詰を切って、上戸は焼酎をグビリグビリ、下戸は仕方がないので、牛肉ムシャムシャ、胡瓜パクパク。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜必ずビールを五六本、酒を五六合、チャンポンにのんだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の行乞所得米一升六合　銭四十一銭途上一杯の酒、それこそまさに甘露！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭　四十三銭今日の所得　　　　　　　　　　行程七里　　　　　　米　一升六合此度の敬治居訪問はほんとうによかつた、敬治君にもよりよく触れたし、奥さんのよいところよくないところも解つた、敬坊万歳、どなたも幸福であれ。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得　　米　六合　　　銭　九銭　　　外に句、十三。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得銭五十七銭、米三升六合。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所得（銭四十七銭、米一升六合）行程八里。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所得、銭五十三銭と米一升六合。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今日の所得は、銭七十四銭と米六合（？",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日、帝、楊、葉、程の三人と共に、呉江を出で、舟に上りて京口に至り、六合を過ぎ、陸路｜襄陽に至り、廖平が家に至りたもうに、其後を訊う者ありければ、遂に意を決して雲南に入りたもう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊留満喜三郎　それわが神でいゆすは天地六合の唯一神、宇宙万象の能造の主、天地空寂のうちに万象を造り、かるが故に日月星宿光を放つて、明歴々として東湧西没の時を違へず、地には千木万草あつて、飛鳥落葉の期を誤たず。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４六合を家と広く、布けよ平和、天皇の大陸軍、道あり、東亜我あり、国防の一線ここに、満蒙、生生の秋ぞいたる、決然、敢て、敢て当らむ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑又塩土老翁に聞きしに曰く、東に美地有り、青山｜四周、……余謂ふに、彼地は必ず当に以て天業を恢弘て天下に光宅るに足りぬべし、蓋し六合の中心か。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然して後に六合を兼ねて以て都を開き、八紘を掩ひて宇と為むこと、亦｜可からずや。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女が書いてくれる手紙を私は実に多くの立派な学者先生の文学を『六合雑誌』などに拝見するよりも喜んで見まする。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから、一級酒（六合）の配給を貰いに行きます。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斐己大人のは一合入、槇園君のは二合入、裸男のは六合入、一行の醉を買ふには不足なし。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど七十二になる彼の父はそこにかかるとさすがに息切れがしたとみえて、六合目ほどで足をとどめて後をふり返った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠に着いた時には既に七八寸の深さとなっていたが其処の茶屋で飲んだ五六合の酒に元気を出して留めらるるのを断りながら終にその日、天城山の北の麓に在る湯が島温泉まで辿り着いたのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠直卿は、五、六合立ち合っているうちに、相手の右近が、急所というべき胸の辺へ、幾度も隙を作るのを見た。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は監理部へ貰いに行って、米は一人について一日分が六合、ほかに罐詰などの副食物をくれるのですが、時には生きた鷄や生の野菜をくれることがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日から米も切符制、一日一合六勺（外米一合、内地米六合）では麦と混じて倍加しても私の胃袋を満たすには足らない、二食にするか、一食はうどんにでもするか、砂糖の切符制には平気の私もこれには少々困るのである。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
