        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西鶴についてはなお色々述べたいこともあるが、ここではただ表題に関係のあると思われる事項の略述に止めた。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）史話　史書や伝記に載った虎に関する話はすこぶる夥しいから今ただ手当り次第に略述する事とせり。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の持つてゐる思想の一通りを茲に略述して筆を擱くことにする。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ジュボアの書等より採って略述する。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "結語　以上に略述したところによつて、私の試みはほゞ読者にわかつたらうと思ふ。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "已に意志の統覚作用における地位を略述した所で、今度は他の観念的結合、即ち聯想および融合との関係を述べよう。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九月十八日）　　　　　　　三の一　故｜啄木氏ははたらけどはたらけどなおわが生活楽にならざりじっと手を見ると歌ったが、今日の文明国にかくのごとき一生を終わる者のいかに多きかは、以上数回にわたって私のすでに略述したところである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七）結語　大師入唐の事蹟は略述べ盡したから、最早この講演を終らうと思ふ。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今を去る二十八年の昔、金尾文淵堂主の依頼によって、源氏物語を略述した。",
              "citation": {
                "source": "『新新訳源氏物語』あとがき",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今ここで、恐らく旅の經驗のない讀者のために一つスケッチを試み、この莫大な數に上る、そして重要な役柄の階級の人について、概略述べて置いても無下に邪魔扱ひはされないであらう。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上で大体装綴様式を略述したことになるが、各々その工程形態によって、性質があるから、装案者はそれを味識して配慮することが必要である。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はフェノロサが試みたる最も専門的なる研究を略述してこの画家の評論を終るべし。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の様に紀州人がその辺のいきさつを知っていなければならない植物のうち三種を挙げてこれを略述して見た。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は雪華研究の歴史を大略述べたのであるが、かくて六世紀に亙る長期間を経たのち、われわれに最も親しい彼のウイルソン・エー・ベントレーが現れるのである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先、菊池大麓博士が英文で和算の算法を説いた数篇の論文があり、また藤沢利喜太郎博士が巴里で開かれた万国数学会議に出席して、日本の数学のことを略述されたものがあって、この藤沢博士の論文は短篇ではあるが、かの国でははなはだ有名なものになって居る。",
              "citation": {
                "source": "数学史の研究に就きて",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十五年の秋、東京で汎太平洋学術会議の開かれたとき、学術研究会議では『日本科学総覧』と題する英文の一書を編纂して、諸外国から来会した人々に分与したが、私は同会議の会員ではないけれども、特に同会議の依頼によりて和漢数学史の一班を略述してこれを寄せたのであった。",
              "citation": {
                "source": "数学史の研究に就きて",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上、総論を略述し終わりたれば、これより、二、三の種類を挙げて説明を試みんと欲す。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも催眠術は、その詳解に至りては、一、二言のよく尽くすところにあらざれば、ただここに、その術のよく心部よりの療法に利用すべきゆえんを略述すべし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五四段　宗教の真相　一（運命）　以上、すでに知識の方面より起こる原因を大略述べ終わりたれば、これより、運命に迷うより起こるという方を説きたいと思う。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一端は、余が「医学部門」心理的治療法、および別著『失念術講義』中に略述したれば、よろしく本編につきて見るべし。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ここに述べたことには、それぞれ根拠があるが、今はそういう根拠の上に立つこの建国史の過程を略述したのみであって、一々その根拠を示すことはさしひかえた。",
              "citation": {
                "source": "建国の事情と万世一系の思想",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一冊に纏める関係上なるべく簡単に各窯の歴史、品目、特色等を略述するに止めた。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殉死の発生と殺老及び棄老　殉死のさかんに行われた時代にあっては、それは必ずしも変態の葬礼とは言えぬけれども、それかと言うて常態とも想われぬので略述する。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この經驗によつて、水なしの消防法をも心得て置くべきものといふことを覺つたが、實際には水を使用しては却つて能くない場合もあるので、著者の專門外ではあるけれども、聞き噛つたことを略述して見ることにする。",
              "citation": {
                "source": "地震の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上略述した如く、日本家屋が木造を以て出發し、木造を以て發達したのは、國土に特産する豊富なる木材のためであつて、地震の爲ではない。",
              "citation": {
                "source": "日本建築の發達と地震",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　心の次に石　精神的の方面を大略述べた後に、その物質的方面の象を少しく指摘することはむだではないだろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "（第三巻第一章、以下三の一のように略述）　要するに、モンテーニュは年がら年じゅうふざけているわけではないが、どんな問題に対しても常に心のゆとりを失わないのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
