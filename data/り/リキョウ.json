        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "departure from the capital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、バルザックとドストエフスキーが流行しだしたという言葉をきいてその頃離京したのだが、いまでは、この世界第一流の作家もかえりみる者がすくなくなっているだろう。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の離京が人々の役に立つなら、そうするに越したことはない。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクが今日にわかにキミのあとを追うようにして訪問したのはキミの離京の名残りを惜しむためではなくて、キミのメグリアワセがあまりフシギだから、大竜出版社そのものに何かイワクがあるのじゃないかと見届けてみたくなったせいだ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の農村生活に不馴れな妻は、その度ごとに不如意がちな私たちの離京生活をなげくのであった。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　長平の離京は一週間ほどのびた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ明日は離京という晩、長平がおそく宿へもどると、茶室に青木が待っていた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "長らく有りがとうございました」　長平が離京するとき、ルミ子が送ってきた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が離京したあと、北槻中尉から聞いたのだろうか。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸軍の巡検から許都に帰ってきた郭嘉は相府に出て、初めて玄徳の離京と、大軍を借りうけて行った事実を知り、「もってのほか！",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そのことも、それがしが離京の際に、司馬仲達がくれぐれも警戒せよといっていました」「なに。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれぐれ、その直後にはすばやく離京するようにと、憲房は念を押した。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "にもかかわらず、彼は師直へ、無断離京の準備を命じた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草寺の天井の絵の天人が、蓮華の盥で、肌脱ぎの化粧をしながら、「こウ雲助どう、こんたア、きょう下界へでさっしゃるなら、京橋の仙女香を、とって来ておくんなんし、これサ乙女や、なによウふざけるのだ、きりきりきょうでえをだしておかねえか。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "滞在は一週間の予定で、その三日目の午後、やはりきょうのように陰っている日でございました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女はわざと疲れた風を見せないようにして、先に立って大師の表門をくぐると、前にもいう通りきょうは九月の縁日にあたるので、江戸や近在の参詣人が群集して、門内の石だたみの道には参下向の袖と珠数とが摺れ合うほどであった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりきょうと同じ所に立って、凍える手に鉛筆を運ぶ事もできず、黙ったまま立って見ていたのだったが、その時の山は地面から静々と盛り上がって、雪雲に閉ざされた空を確かとつかんでいるように見えた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四本のしごきはみなからっぽのぬけがらで、お蘭弁天がまたどうしたことか、きのう急に浅草の並木町とやらの家へ宿下がりを願い出して、それっきりきょうも姿を見せんというんですよ」「なにッ、そうか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもはつまりきょうの日本のこういう現実を掴んで私どもが自身の運命を托してそのために努力している日本の民主化がどういう状態におかれているかということをいまこの瞬間に通じる自分の問題として知らなければならないと思うのです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民と権力との抗争と現実がこんにちにおいてもそうであるとおり、毎日、いろいろな形に細部を変えながら、しかしきのうよりきょうへ、そして明日へと根づよく断続されてゆく、そのリアリスティックな人民の幸福への闘争の精神が「乳房」の基調となっている。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やっぱりきょう来られないので、余りひどいと多賀子来た由。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか、その上の子が、「きょうは、たいそうがあって、走りきょうそうで一ばんになりました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、というよりきょうの明方大層冷えましたね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりきょうにちゃんときょうを生きているのですもの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日だけは、うんとのびるつもりです、つまりきょう一日は。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりきょうは金曜よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其許は吉岡方の名目人で、つまりきょうの果し合いの総大将だからの、確乎していなければいかんぞ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "元よりきょうのことを父の耳へ伝えようなどとは、聞いているうちから思いもしないことではあった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとやはりきょうのことは、虫も知らせていなかったとみえるな」「知ろうはずはない。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もとよりきょうの招きというのも、決してただの饗応であろうはずはない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
