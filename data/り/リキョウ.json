[
  {
    "uuid": "f618e341-8904-5d76-a655-6b2f78d60c99",
    "entry": "離京",
    "reading": {
      "primary": "りきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
