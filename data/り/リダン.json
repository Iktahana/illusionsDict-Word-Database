[
  {
    "uuid": "b623f3b8-7eb9-579e-988c-4809feabda96",
    "entry": "離断",
    "reading": {
      "primary": "りだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dissection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして私の眼の下では彼らがやはりだんまりで、しかも実に余念なく組打ちをしている。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなやつも出て来たぞ」　向こうに魚の骨の形をした灰いろのおかしなきのこが、とぼけたように光りながら、枝がついたり手が出たりだんだん地面からのびあがってきます。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民二「はあ、全ぐその通りだんす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなやつも出て来たぞ」　向ふに魚の骨の形をした灰いろのをかしなきのこが、とぼけたやうに光りながら、枝がついたり手が出たりだんだん地面からのびあがつてきます。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい、雪さ豊年の兆だちゅう、旱は魚の当りだんべい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一は変態的に真佐子をいじめつけた幼年時代の哀しい甘い追憶にばかりだんだん自分をかたよらせて行った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、ちいさい男の子のひとりが、すずの兵隊をつかんで、いきなりだんろのなかへなげこみました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "この俺を、一体、何処まで追払うつもりだんべ？",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『勇敢にせんか、敵前ぢやぞ』　水は膝頭よりだんだん深くなつていつた、途端に雛太は白い脛を飜しぺたりと坐り、わつと泣き出した。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日来ていた愛子の足は二日おきになり三日おきになりだんだん遠ざかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりだんながおどかすから、あわてるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつりだんなになっているときゃしゃくにさわるだんなだが、こういうことになるとにっこりだんなになるんだから、うれしいんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひねりだんごじゃあるめえし、まごまごしていりゃ夜がふけるじゃねえか」「あんまり人を小バカにしなさんな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってきて、それとなく千萩の様子を見ますると、このとおりだんだんと年ごろになってはいるし、四年まえとはうって変わって、どことのう――」「美しくなっていたゆえ、また未練が出てきたというのじゃな」「お恥ずかしゅうござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしゃまた、あんまりだんなが人騒がせなことをきまじめな顔でおっしゃいましたからね、ほんとうに松平のお殿さまをお連れ申そうと思いましたぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつり右門はあごのだんな、伝六だんなはおしゃべりだんなと、近ごろ軽口歌がはやっているくれえのものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これからお前達が一番頼りだんだからな……。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でも去年あたりだんべ。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼と秋蘭との間に群がる群衆の幅から無数の牙を感じると、次第にその団塊の中に流れた共通の体温から、ひとりだんだんはじき出されていく自分を見た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭というものは、馬鹿になり出すと、つまり、馬鹿な方へばかりだんだん頭が良くなり出す。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを平静な感情として、ホラ、ここで笑いがはじまりだんだんこんなに高まっている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、反絵のとり残された媚の微笑は、ひとりだんだんと淋しい影の中へ消えていった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾何や物理や英語、それだけでもいまでは異国人のように差異ができた、こうして自分が豆腐屋になりだんだんこの人達とちがった世界へ墜落してゆくのだと思った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりだんだんせり上つた席に雌雄の河童が三四百匹、いづれもプログラムを手にしながら、一心に耳を澄ませてゐるのです。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりだんだん以前よりも、猥褻になって行くのだね。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりだんだんせり上がった席に雌雄の河童が三四百匹、いずれもプログラムを手にしながら、一心に耳を澄ませているのです。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった結婚法がやはりだんだんと見えている。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきりだんだんあんなことはなくなったねえ」「ええ、あのころは、あなたが先の連合と私との事についてよくいろんなことをほじって聞いた、前の事を気味悪がり悪がり聞いた」「ウム。",
              "citation": {
                "source": "雪の日",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はつまさきよりだんだん上の方に目をあげる。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
