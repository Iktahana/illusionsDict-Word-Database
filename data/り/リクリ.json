        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "拙堂も観た五色岩こそまた光彩陸離として衆人の目を奪うものであろうか。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙堂も観た五色岩こそはまた光彩陸離として衆人の眼を奪ふものであらうか。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "対聯比照に富み、光彩陸離たる形容の文辞を畳用して、燦爛たる一家の詩風を作りぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "對聯比照に富み、光彩陸離たる形容の文辭を疊用して、燦爛たる一家の詩風を作りぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドレ・ジイドは「ワルテルの手記」によって後者の庶民的生活力には結びつかず、象徴派のマラルメやアンリ・ド・レニエなどと相識り、爾後四五年間はその温室の中にあって、間接に『法螺貝』、『半人獣』などという雑誌編輯に当り、グループの「最も光彩陸離たる聖職者の一人」となった。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "光彩陸離たるやたらに奇麗なものだ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が終りまで遂にたんのう出来なかった原因の一つは、脚本そのものが余り光彩陸離たるものでなかったことと、二つには、演出する俳優の心の態度が、ぴったりと自分の胸に響いて来なかったことである。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　けれども、ユーゴオを先頭とするこの時代の光彩陸離たるロマンチシズムの作家たちにもう一歩近づき、仔細に眺めると、そこには微妙な形でバルザックにも関係する或る矛盾が発見される。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またイギリスの最も傑出した作家の一人、サッカレーの作品はその傑作「虚栄の市」の中で、光彩陸離と、なり上り結婚のために友情も信義もけちらかして我利をたくらむやり手な美しい女性を描いた。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学に入学した折、古ぼけた制服を着た一人の生徒の、胸のポケットの革の鉛筆｜した、赤や青や紫やの色とり／″＼の鉛筆と、それ等の鉛筆の冠つた光彩陸離たるニッケルのカップとが、私の眼を眩惑させたのであつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲を冠り鎧を着、薙刀を小脇に掻い込んでいるその風采には不思議はないが、鎧の上に羽織っている血紅色の経帷子が日光を受けて燦然と輝き四辺にあたかも虹のような陸離たる光彩を描き出したのは――庄三郎にとっては驚異であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶の勝れた布教があって、陸離たる光彩を放つものである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて太陽は光芒一箭、雲間を破ってその陸離たる光彩を燦然と輝かすのである。",
              "citation": {
                "source": "画室の言葉",
                "author": "藤島武二",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯「蛙」を「河童」とせん乎、更に光彩陸離たるべし。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ「蛙」を「河童」とせんか、さらに光彩陸離たるべし。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう訳で敬太郎の頭に映る観音の境内には、歴史的に妖嬌陸離たる色彩が、十八間の本堂を包んで、小供の時から常に陽炎っていたのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉辺に坐り若者たちに囲まれたときのあの陸離たる光彩は、もはやそこには有り得ない。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は元来農村といふ我々の都会生活とはかけ離れた生活形式によつて歪曲された人間性が、長篇といふ形式をかりて陸離たる光彩を放ちながら描破されはしないかと考へてゐたのであつた。",
              "citation": {
                "source": "長篇小説時評",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、この小説の作中人物は、晋の印象を通じてのみ語られてゐる限り、人に迫る深さを持つことができないのだが、いつたん晋の世界を出外れた部分へくるとはじめて陸離たる光彩を放つ。",
              "citation": {
                "source": "長篇小説時評",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬糞紙のらつぱは、更に大きくして光彩陸離たる姿と、清やかに鋭い声を発する舶来の拡声器を得た訣なのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にまたクレモン・ガアデンスの煙火戲の夜、崩れ落ちる五彩陸離たる火光を、いみじくも繋ぎとめた「黒と金とのノクタアン」を見よ。",
              "citation": {
                "source": "仙人掌と花火の鑑賞",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の病中に、空漠なる余の頭に陸離の光彩を抛げ込んでくれたジェームス教授も余の知らない間にいつか死んでいた。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生独得の植物学的漫談は、それだけで光彩陸離たるもんですから、助手なんか邪魔つけです。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると君方の演説は人世の紙屑で上手な細工がしてあって、光彩陸離としていても、555それは秋になって枯葉を吹きまくる湿った風のように気持の悪いものだ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "処でこの評論集は異彩陸離たるものがある。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜明け前」で学ぶべきは、仰云るように、作者の根気、努力、であるが、こちらの作者のスケールと現実洞察の、彼なりの鋭さ、リアリティーは実に光彩陸離たるものがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "消燈したって心の中はときによっては光彩陸離の有様です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く陸離たる麗やかさ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにどうしてその美しさはいつもまざまざと描き出されて、うすれるどころか印象の中で一きわ光彩陸離となってゆくのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、私は、下手なのである、やりくりが上手でないのであらう。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
