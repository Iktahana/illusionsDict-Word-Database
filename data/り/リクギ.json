      {
        "index": 1,
        "gloss": "six forms of the Shi Jing (genre: folk song, festal song, hymn; style: narrative, explicit comparison, implicit comparison)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
