        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ウマヤノ　マエノ　ヒザシガ　ヒニ　ヒニ　アタタカク　ナツテ　クロイ　土カラ　白イ　ユゲガ　ノボリハヂメテ　ヰマス。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　ヒバリハ　スガタガ　ミエナク　ナルホド　タカク　ノボツタ　トキ　ウツクシイ　コヱデ　ウタヒハジメマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナタハ　コレカラ　ドチラヘ　イクノデスカ」ト　シンセツナ　トシヨリハ　ワカイ　ヲトコニ　タヅネマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "キイテ　ヰタ　トシヨリハ　フカイ　タメイキヲ　ツイテ、「センサウハ　モウ　タクサンデス。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテ　チヤウサンハ　ウチニ　カヘルト、サツソク、ロバニ　ヒカセル　クルマヲ　ツクリハジメマシタ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　フタリハ　イツテ　シマヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コモリハ　ナミキミチヲ　トホツテ、コウエンノ　ハウヘ　イキマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コモリハ　コウエンヘ　クルト、ベンチニ　コシカケテ　コモリウタヲ　ウタヒマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ネンネン　ヨヲヲヲ　ネンネン　ヨウ」　シカシ、アカンボウヨリ　サキニ、コモリノ　ハウガ　ウツラ　ウツラ　ネムリハジメマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　トキ、コモリハ　フウセンノ　イトヲ　ハナシテ　シマヒマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカイ　フウセンダマハ　ソラノ　ハウヘ　ノボリハジメマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "的言イアテルヨリハ、ワガ思念開陳ノ体系、筋ミチ立チテ在リ、アラワナル矛盾モナシ、一応ノ首肯ニ価スレバ、我事オワレリ、白扇サットヒライテ、スネノ蚊、追イ払ウ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の看守はさみしげに座り、ユヅリハの葉柄の赤きが暮れんとして、閉さぬくぐりの間よりかなたの街の薄ら明をさしのぞき……さしのぞく……",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "静寂な闇の中に、やがてハリハリと杉の枯れ葉の燃える音がした。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルリハコベは雨近付ば必ず花を閉ぢ、午後二時頃定つて花萎むから、英國の古諺に、其徳聞き盡し難く、述べ盡す可らずと云ひ、貧者の晴雨計と俗稱さる。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから原稿の手直しを経て、雑誌の記事や紙の本を作ってもらい、ＣＤ―ＲＯＭの制作を進めるうちに、精神的なリハビリテーションを進めていたのでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "却テ戰後ニ於ケル利權設定等ノ禍因ヲ播キ、印度其者ヨリハ何等ノ報謝ヲ求メザル天道宣布ノ本義ニ汚點ヲ印シ易キハ豫メ深ク戒ムベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒダノナマリハオバエナ、マタクルワイナ、ソレカラナンジャナ、ムテンクテンニオリャコワイ、ウソカイナ、ウソジャアロ、サリトハウタテイナ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字トシテモ現今ノヒラガナヨリハ変態ガナノホウガ美シク、変態ガナヨリハ上代ガナノホウガ美シイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スナワチ形カライエバ草書ト少シモカワリハナイノデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少ナクトモカナヅカイノ問題ヨリハハルカニ単純デアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらすらと読める文章を書こうとして、土台をがっちり打ちこむことをおるすにし、その文章の上でさえ、大衆のかたまった力、熱、メリハリを再現することに失敗している。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リハーサルに相当する回路別の実験があり、演奏が実際の製作に相当する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生で並三ラジオに挑んだときはリハーサルからの参加だったが、テレビカメラでは編曲の基本設計にも踏み込んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "集積度が高まるにつれて回路のより広い範囲がチップに収まれば収まるほど、リハーサルと演奏に相当する創造性をほとんど問われない作業にしか関与できなくなるように思えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "）実はねえ、リハーチェフっていう商人のところでゴルカをやったのさ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃と、むし暑さ、氷を沢山呑むと、髪の毛が抜けると云うけれど、氷を飲まない由ちゃんも、冷蔵庫から氷の塊を盗んで来ては、一人でハリハリ噛んでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気がハリハリと硝子のやうでいゝ気持ちでした。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
