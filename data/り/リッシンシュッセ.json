    "definitions": [
      {
        "index": 1,
        "gloss": "success in life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "話し振りから、低級な立身出世を夢みていることがすぐ分った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬骨折って鷹に取らるるか……腕も知恵もないザマで立身出世ばっかりしたがる上役の下に付いとっちゃあ堪らんのう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、兄とか弟とかの立身出世のために自分を身売りまでする姉や妹があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村越の御子息が、目のあたり立身出世は格別じゃ、が、就中、豪いのはこの働きじゃ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒下駄で顔を殴られ、その駒下駄を錦の袋に収め、朝夕うやうやしく礼拝して立身出世したとかいう講談を寄席で聞いて、実にばかばかしく、笑ってしまったことがあったけれど、あれとあんまり違わない。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家家の屋根を越えて、青空に高くひるがへる魚の像は、子供の將來に於ける立身出世と、富貴と健康と、名譽と榮達と、とりわけ男らしい勇氣を表象して祝福されてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る多くの人々は、立身出世のために学問をし、他の或る篤志な人々は、社会民衆の利福のために、学術を役立てようと思って学問する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かいい事があるかと、いつまでも宴席に愚図愚図とどまっているような決断の乏しい男では、立身出世の望みが全くないね。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは如何に才学が有って、善良な人であっても、世間を危気無しには渡って行かれなかったろうと思われるから、まして官界の立身出世などは、東西｜相距る三十里だったであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたさまの御立身出世、もし、ご家内さま、お子さまがおありなら、一生ご無事息災、末々お家繁昌の運をお授けいたします。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿ニ似テ非ナル猿面冠者ハオノガ立身出世ノタメニハ、主人ヨリ猿々ト呼ビ捨テラレルモ、ヘイヘイト追従笑ヒナド泛ベタルハ、即チ羞恥ヲ知ラザル者ト言フガ如シ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六歳の時、丹造は広島をあとにして、立身出世の夢を宿毎に重ねて、大阪の土を踏んだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がこの健康道場にはいったのは、戦争がすんで急に命が惜しくなって、これから丈夫なからだになり、何とかして一つ立身出世、なんて事のためでは勿論ないし、また、早く病気をなおしてお父さんに安心させたい、お母さんを喜ばせたいなどという涙ぐましいような殊勝な孝心からでも無かったのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立身出世をする人物は子供の時分から粗衣粗食に甘んじて常に楽しく励む者である、といふ風なことをいつも祖母から教へられてゐた。",
              "citation": {
                "source": "鞭撻",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その頃の――恐らくは今でも――惣ての人の親は、家に資産があると否とを問わず一家の運命希望を我が子の立身出世に繋いでるから、滞りなく無事に学校を卒業してドコへか就職してくれなければ安心もし満足もしなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜太郎氏なる人物は、わたしは面識はなかつたが、噂に聞くところに依ると立派なる立身出世の人らしく、尊敬に価した。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「立身出世を望まれるなら、浮世へ出なければいけませんなあ」にわかにクックッと笑い出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か立身出世の秘訣でもございますか」　といって、いわゆる「成功の秘訣」なるものを尋ねたのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別に立身出世の秘訣とてはないのじゃ。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外には立身出世の秘訣はないのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、仏教でいう人は、決して立身出世を目的としているような人ではないのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でもありましょうが、武家が馬術を学ぶのは自分の嗜みにすることで、師範の家は格別、普通の者は馬術がよく出来るからといって立身出世することは出来ません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼母殿尊霊も、そなたが復讐などに大事な半生を費されるよりも、文明の学問に身を入れて立身出世なされる方が、どれほどお喜びになるか分からないと、拙者は存ずるが……」　新一郎の言葉は、いかにも肺腑より出るようであった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ何だッて愛想が尽きらア」「だけれども本田さんは学問は出来ないようだワ」「フム学問々々とお言いだけれども、立身出世すればこそ学問だ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自分の生れた年から数へて、恰ど七つ目に当つた干支を絵にかいて、いつも壁に懸けて置く時は、立身出世疑ひないといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや世故にたけたといわれる年頃では、そういう階級の狭い生活が多くの女の心に偏見と形式と家常茶飯への没頭、良人の世間並な立身出世に対する関心をだけを一杯にしていたであろう。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸へ老後の安楽を求め、立身出世の道を求めて来たとすれば彼は失敗した。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとこの話一　奥州の昔話に、竈の火焚き男、あるいは単に竈男と呼ばれて、ある訳合いから長者の家に下男となって住みこんだ男が、ついにはその家の愛娘に見染められて、立身出世するというすじの話がある。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたわけでその若侍はこの長者の聟君となって立身出世するというのである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
