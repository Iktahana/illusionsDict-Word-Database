[
  {
    "uuid": "e411e2b9-1f5e-5c20-a8c9-f1512354f7ab",
    "entry": "流産",
    "reading": {
      "primary": "りゅうざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
