        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ニュージーランドの株で、配当が四分五厘、額面は二五〇〇ポンドなのですが、わたくしは利回りにしか手を付けられません。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィンディバンクさんはその利回りからいつも四分の一引き出して、そのまま母に渡しておりまして、わたくし自身は、自分がタイプ打ちで稼いだ分でちゃんとうまくやってゆけますから。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板から降る白墨の粉のような、暗い冷たい霧の粒が、そこら一面踊りまわり、あたりが俄にシインとして、陰気に陰気になりました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、おとなの居留民達は、出兵請求の決議にかけずりまわり、一ツ一ツ印を集め、懇願書を出して、折角やってきて貰ったなつかしい兵士が、自分達のちっぽけな家とはかけ離れた、工場や銀行の守備に赴くのを、はたして、ペテンにひっかゝったように、憤ろしく、意外に感じなかっただろうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板から降る白墨の粉のような、暗い冷たい霧の粒が、そこら一面踊りまわり、あたりがにわかにシインとして、陰気に陰気になりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は駈けずりまわりながらも妹の方を見ることを忘れはしませんでした。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来塩原という処、金持共が贅沢に夏の暑さを避けに来る土地ゆえ、街路には至る処ハイカラ男女共が手を連ねてノサ張りまわりつつあり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひょうしに、ヒキガエルとウミヘビは下にころがり落ちて、あたりをはいずりまわりました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまも、みんなの仲間にはいって、くるくる踊りまわりました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、宮中のお役人の半分もの人たちが、いっしょになってかけずりまわりました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは、きれいなおもちゃを持って、踊りまわりました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようすが、あんまりしあわせそうなものですから、氷のかけらまでがうれしくなって、ぐるぐる踊りまわりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっぽけな黒い小人が、ずきんに鬼火をつけて、広間の中を踊りまわりました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ふたりは、広間にいる小人や鬼火たちといっしょに、ぐるぐる踊りまわりました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまは、あいかわらずブンブンうなりながら、踊りまわりました。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "やばんで、らんぼうな兵隊たちの前で、王さまは、はだかのまま、踊りまわりました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにもＷ君が、私の家の玄関にお酒を一升こっそり置いて行ったのを、その朝はじめて発見して、Ｗ君の好意が、たまらぬほどに身にしみて、その辺を裸足で走りまわりたいほどに、苦痛であった。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚たちは血眼になって走りまわりました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして蘭法附木で袂に火を放って走りまわりましたならば、そこここから火事になりましょう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレンはお寺の角のところを、ぐるぐる踊りまわりました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいらしい、豆粒のような小鬼どもは、ずきんに鬼火をつけて、広間のなかをおどりまわりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひいさまは、それはまるで、つばめが追われて、身をひるがえして逃げるときのような身がるさでおどりまわりました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもたちは、ほんのちょっとのあいだ、だまって立っていましたが、――たちまち、わあっというさわぎになって、木のまわりをおどりまわりながら、クリスマスのおくりものを、ひとつ、ひとつ、さらっていきました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもたちは、もぎ取ったりっぱなおもちゃを、てんでんにもって、おどりまわりました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れるというよりむしろ飛ぶように、だんだんに波の真ん中へより、それからまたその恐ろしい内側の縁のところへだんだん近づきながら、たぶん一時間も、ぐるぐると走りまわりました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗幕がかけられた階段教室のなかを、スクリーンの光だけをたよりに、頭をさげて、はいずりまわり、ようやく見つけた令子は、慶一の話をきいても、べつにおどろくでもなく、あわてるでもなく、じれったくなるほど冷静だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで女中はなおなお狂人のようになって床の上にころがりまわりましたが、しまいには金銀の糸がすっかり二人の女中に巻き付いて人間の糸巻きのようになって、只うんうんうなりながら床の上を転びまわるばかりでした」「お前はそれを見ていたのか」「エエ。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣とも人間ともわからない姿と声で躍ったり、跳ねたり、転がりまわり、匐いまわり、笑いまわり、泣きまわってお出でになりました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言いながら、室の中をあちこち躍りまわりました。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああうれしい」　こう言って俊夫君はまたもや室の中を走りまわりました。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
