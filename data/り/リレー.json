        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはガリレー以来、力学が始まってこのかただれも考えつかなかったほどわかりきった事であったのである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "競技は各区が単位になつて十数区で行はれるが、その中に「三代リレー」といふのがある。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはお爺さん、お父さん、息子、といふリレーである。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "役場と産業組合と国民学校の対抗リレーで、スタートには村長と、組合長と、校長とが並んだ。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄なひリレーは十四区から五人づゝの選手が出て、一メートルづゝ縄を綯つて、一定の長さに達した時、石を載せた箱を引つ張つて張力を試験して見た。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、優勝区には、増産奨励の酒が一升づつ出ることになつて村長の机の上に六本並んでゐるのだから、他の賞品になら寛容の美徳を現はす連中も、この縄綯ひリレーだけは、勝敗が明確でないといふことにした。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアインシュタインは古い昔のガリレーをほじくって相対性原理を掘りだし、ブローイーは塵に埋もれたハミルトンにはたきと磨きをかけて波動力学を作りあげた。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレーはその執拗な旋毛曲りのために縄目の苦しみを受けなければならなかった。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレーの空気寒暖計は発明後間もなく棄てられたが、今日の標準はまた昔のガス寒暖計に逆戻りした。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の系統は一朝一夕に発達したものではなく、ガリレー以来｜漸を追うて発達して来たもので、種々な観念もだんだんに変遷し拡張されて来たものである。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレーの時代の人には彼の力学はよほど見やすくないものだったでしょう。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピサの傾塔やガリレーの振子よりも彼を喜ばせたものはその浸礼堂の円塔の不思議な反響の現象であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで無終無限の道程をたどり行く旅人として見た時にプトレミーもコペルニクスもガリレーもニュートンも今のアインシュタインも結局はただ同じ旅人の異なる時の姿として目に映る。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし彼らがその驚くべき直観の力を具有してしかしてガリレー以後に生まれ、ファラデーの時代に生まれたと仮定したらどうであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレー、トリツェリ、ヴィヴィアニ、オットー・フォン・ゲーリケ、フック、ボイルなどといったような人がはなはだ粗末な今から見れば子供のおもちゃのような道具を使って、それで生きた天然と格闘して、しかして驚くべき重大な画期的実験を矢継ぎばやに行なったのがそもそもの始まりである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレー、ゲーリケ以後今日まで同様なことがずっと続いて跡を絶たない。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、仕事をする元気もなく机の周囲に青褪めた豪傑面を陳列して、アフリアフリと死にかかった川魚みたいな欠伸をリレーしいしい涙ぐんでいる光景は、さながらに飢饉年の村会をそのままである。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前にある友人とガリレーやブルノやデカルトの話をした。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレーはその二人の途中に立って悩んでいたのであろう。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞しいサモア青年達のリレーによって、叢林中の新しい道を、山巓に向って運ばれるのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは先日新聞社の催しで数名の知名の文士を北半日本のリレー飛行に搭乗させた、そのときの感想を話し合わさせるという趣向なのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上述のガリレー、ニュートンの発見に関する逸話はその実信ずるに足らぬ俗説であるが、しかしこれらの発見をするためにはまた非凡な準備素養を要した事は言うまでもない。",
              "citation": {
                "source": "知と疑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、垣根の下の、用水の水を、リレー式にバケツで運んで、二、三分のあいだに消しとめて下さった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は青年の体内から永遠に歌ひ継げ我等の歌をもつて夜から暁へのリレー死ぬものから――生きるものへバトンを手渡せだまるな、饒舌をもつて敵を圧倒せよ、牡丹のやうに美しく咲いて美しく散れいゝ加減、政治上の敗北にのたうち廻ることをインテリゲンチャに贈呈しろ過去は過去のみ何ものにも非ざるぞ――。",
              "citation": {
                "source": "小熊秀雄全集-5",
                "author": "詩集（４）小熊秀雄詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人リレー第一の手紙　山下智恵子様　みもとに　　ミナト・バスにて　　友成トミ子より　お手紙ありがとうよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐るべき色魔の殺人リレー」って言う標題でね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやつり人形のようなもの、甲冑武士のようなもの、進んでは電波操縦によるリレー式のもの、それから人造肉をかぶせてだいぶん人体らしくなってきたものなど約七百種のものが陳列されてあった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日本評論』の匿名リレー評論をよむと、日本の思想界を次の時代にひきいてゆく力量をもった綜合的思想家としては如是閑氏を措いて他にないように云われている。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら小屋まで一番早く帽子を運ぶには十一人でリレーのように継ぎながら運ぼうではないかと佐佐がいい出すと、それは一番名案だということになっていよいよ十一人が三間ほどの間隔に分れて月の中に立ち停ると、私は最後に病人の所へ水を運ぶ番となって帽子の廻って来るのを待っていた。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが十七世紀の法王庁はこの真理を語ったかどでガリレオ・ガリレーを重罪に問うた。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
