    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rich",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "英国人のオージルヴィ君や、ルーマニアのギリッチ君などとよく教室入口の廊下で立話をした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邸宅はもとノリッチ僧正（Bishops of Norwich）の宮殿であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき私はリッチモンドのスリークォーターでした。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でかボブ・ファーガソン、歴代でもリッチモンド一のスリークォーターだ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この出来事はヴァージニア州のリッチモンドの付近で起ったのである。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他各国大学又は図書館協会或は学会等、及びクワーリッチ、ヒールセマン等英仏独蘭の稀覯書肆から出版した各種の稀覯書目録（欧羅巴の稀覯書肆の特別刊行の書目は細密なる分類を施こし且往々解題を加え或はファクシミルを挿入する故書史学者の参考として最も珍重すべきものである。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他各国大学又は図書館協会或は学会等、及びクワーリッチ、ヒールセマン等英仏独蘭の稀覯書肆から出版した各種の稀覯書目録欧羅巴の稀覯書肆の特別刊行の書目は細密なる分類を施こし且往々解題を加え或はファクシミルを挿入する故書史学者の参考として最も珍重すべきものである。",
              "citation": {
                "source": "灰燼十万巻",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "リッチー教授は言う。",
              "citation": {
                "source": "唯物史觀と文學",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァレンタイン九七六二番が釈放されてから一週間後のこと、見事な金庫破りがインディアナ州リッチモンドであった。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミハイル・※シーリッチ『操縦士の空想』の中にある高緯度地帯の描写と現実の間に、何か類似点がありましたか？",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェラ・ザスリッチのような歴史的な業績をもつ婦人もある。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年、健康を害したツルゲーネフは「処女地」以後のロシアの解放運動の流れに対する関心からはすっかり離れ、懐疑的な「散文詩」「クララ・ミリッチ」などを書いた。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーヤ・マリッチはペテルブルグで教育を勉強していた。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベル研究所のデニス・リッチーという研究者によって、一九七二年から七三年にかけてＵＮＩＸを書くために開発されたＣは、本来の用途に加えて、さまざまなプログラムの開発にも広く使われる可能性を持っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちに東京大学大型計算機センターの石田晴久によって翻訳される、デニス・リッチーとブライアン・カーニハンの『プログラミング言語Ｃ』という本が存在していることを知り、日本橋を探し回った挙げ句見つけられずに、結局アメリカから取り寄せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにデリッチがその説を発表した後ち未だ僅に三年を経ざる内に、その予期に違わず、この法典の全部を発見し、且つそのハムムラビ法典なりとの予言も的中したのは、実に感歎すべき事実である。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "デリッチは、シャマシュはマルヅックの神性の一面であるから、この文に依って日の神が法を授けたという事を否認することは出来ぬと言うておる。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "オースチン夫人サラーは、一七九三年、英国ノリッチ(Norwich)州の名家ティロー家に生れた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "オースチン夫人サラーは、一七九三年、英国ノリッチ（Norwich）州の名家ティロー家に生れた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその補佐として、地質化学の担任たるトーマス・アンチセルに年俸八千ドル、地理測量のエー・ジー・ワルフィルドに六千ドル、書記兼医師スチュワード・エルドリッチを四千ドルであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンソン博士はそれを憤慨して、ゴート人の蛮行だと非難したが、そのくせ、婦人尊敬の癖を持っていた博士はリッチフィールドで牧師夫人と会食した時にはその共犯者に対して一言も非難の言葉を浴びせなかった。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでゲーテが、久方ぶりで街で愛人ベアトリッチェに行きあったような恰好であった。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "グードリッチの英国史といったような本を、一節ぐらいずつ読んで、それからそれを机の上へ伏せて、口の内で今読んだ通りを暗誦するのである。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物ずきの方、当方、娘四歳　ミセスリッチェ　だがこれ等は月給いくら位貰うのであろうか？",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十五日（日）晴　リッチモンドへ行った。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、第一のロシヤ譯はバクーニンの手になり、一八六三年頃、ジェネバなるヘルチェンの雜誌『コロコロ』の發行所から出版され、第二は女丈夫ウエラ・サスリッチの手になり（２）、一八八二年、同じくジェネバで出版された。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）ウエラ・サスリッチ云々はエンゲルスの間違ひで、實はプレハーノフによつてロシヤ文に飜譯されたのである。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方にハリッチ市が見えてきた。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
