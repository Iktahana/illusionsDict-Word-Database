    "definitions": [
      {
        "index": 1,
        "gloss": "way (of doing things)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
