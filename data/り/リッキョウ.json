    "definitions": [
      {
        "index": 1,
        "gloss": "bridge (over a road or railway)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昭和九年二月著者我が心また新しく泣かんとす冬日暮れぬ思ひ起せや岩に牡蠣漂泊者の歌日は斷崖の上に登り憂ひは陸橋の下を低く歩めり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朗吟調小曲――詩篇小解漂泊者の歌（序詩）　　斷崖に沿うて、陸橋の下を歩み行く人。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸橋を渡るとそこらの家の表札は日暮里となっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊売りや鯉売りが暗い火を点している省線の陸橋を通り、反射燈の強い光のなかを黙々と坂を下りてゆく。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸橋陸橋を渡つて行かう黒くうづまく下水のやうにもつれる軌道の高架をふんではるかな落日の部落へ出よう。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして故郷の家をのがれ、ひとり都會の陸橋を渡つて行くとき、涙がゆゑ知らず流れてきた。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸橋を渡る　憂鬱に沈みながら、ひとり寂しく陸橋を渡つて行く。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切を憎惡し、粉碎し、叛逆し、嘲笑し、斬奸し、敵愾する、この一個の黒い影をマントにつつんで、ひとり寂しく陸橋を渡つて行く。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョホール海峡の陸橋を渡って、見えていた市の中を通って、なおしばらく水辺に沿って行った処で若い紳士は車を停め、土地の名所である回教の礼拝堂を見せた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗足池方面へ向ふ途次の陸橋からは、南に富士が仰がれた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜の砂庭に吹き散り、陸橋の下には傷つきし犬瞳を凝らす。",
              "citation": {
                "source": "庭園の雨",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年十一月、渋柿）　　　　　　　＊　田端の停車場から出て、線路を横ぎる陸橋のほうへと下りて行く坂道がある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸橋を渡つて、杉垣にはさまれた屋敷通りに来た時であつた。",
              "citation": {
                "source": "階段",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとうとう、当時より三年前の或る秋の夜――恰度その夜は冷い時雨がソボソボと降っておりましたがな――Ｈ駅の近くの陸橋の下で、気の狂った四十女の肉体を轢潰してしまった時から、「オサ泉」の主張で彼等の間に、ひとつの風変りな自慰が取上げられたんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この駅のホンの一丁程向うの陸橋の下です。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度朝の事で、冷え冷えとした陸橋の上にも、露に濡れた線路の上にも、もう附近の弥次馬達が、夥しい黒山を作っていました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の狂った母は裸足のままで家を飛び出して、とうとう陸橋の下で汽車にひかれて死んでしまったのです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　車は広小路から坂本の方へ出て行き、狭苦しい町の中の雑踏へ来てから、陸橋の袂で駐まったが、その家はいつ来ても庸三は気分がよかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルドオから聖セバスチャンを経てＭＡＤＲＩＤへ辿り着いたジョウジ・タニイ――それは陸橋に月が懸って、住宅の根元の雑草にＢＯ・ＢＯと驢馬の鳴く晩だった――が、ドン・ホルヘに転身してこのマドリイの宿ときめたのが、商業街の心臓モンテイロ街のいま居る家だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夕方だった――それはきっと陸橋に月が懸って、住宅の根の雑草にＢＯ・ＢＯと驢馬の鳴く宵だったに相違ない――ちょうどその時、マドリッドのヴィクトリア座は、イダルゴを主役とする「ヴェルサイユの王子」を出し物に大入りをとっていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場のひけ時で人通りの激しい夕暮の長い陸橋の上で電燈が燦きはじめた。",
              "citation": {
                "source": "東京へ近づく一時間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "動坂の上にたって今日東の方を眺めると、坦々たる田端への大通りの彼方にいかにも近代都市らしい大陸橋が見え、右手には道灌山の茂みの前に大成中学校の建物が見える。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
