[
  {
    "uuid": "a2519c1d-a7b9-5fee-ac0c-a905ba3fec26",
    "entry": "良能",
    "reading": {
      "primary": "りょうのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
