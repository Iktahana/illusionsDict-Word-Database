      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "both banks (of a river)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汽車はサクラメントの大河に沿うて走る、川の底には、堅い凝灰岩などが露出しているが、シャスタを距ること、五十｜哩位のところから、熔岩が、両岸に段丘を作っている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾川は底まで澄みきつて、両岸の紅葉を映してゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸の崩壊箇所が向かい合っているのもやはり意味があるらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "進むに従つて両岸の景色が何となく荒涼に峻険になつて来るのが感ぜられた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "進むに従って両岸の景色が何となく荒涼に峻険になって来るのが感ぜられた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃林の在るところは、大体川砂の両岸に溢れた軽い地層である。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の広さも両岸の崖、ところどころの洲の青草。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある河の橋畔に出ると大きなビルディングが両岸に聳え立って、そのあるものには窓という窓に明るい光が映っている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つの橋をモルダウ河に渡して両岸に跨がっているプラハの都府で、幾百年かの旧慣に縛られている貴族の家に、千八百七十五年十二月の九日に生れたということです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "靄に透けてわずかに見える両岸が唯一の頼みだった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートサイドでレモンの皮のはいった塩水で嗽をしてスエズ運河の両岸の夜景に挟まれて身の丈を長くした妾は天晴れ一人前の女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上下｜少の間は両岸とも材木問屋多ければ、筏の岸に繋がれぬ日もなし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりは河水東西に流れて両岸の地もまた幽寂空疎なれば、三秋月を賞するのところとして最も可なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸の山は或時は右が遠ざかったり左が遠ざかったり、また或時は右が迫って来たり左が迫って来たり、時に両方が迫って来て、一水｜遥に遠く巨巌の下に白泡を立てて沸り流れたりした。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは水が両岸に激して発するのでもなく、また浅瀬のような音でもない。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸の人家低く高く、山に拠り水に臨むその数｜数百戸。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "底は一面の白砂に水紋落ちて綾をなし、両岸は緑野低く春草煙り、森林遠くこれを囲みたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の両岸に錯雑した建物のコンクリートの面に夕日の当たった部分は実にあたたかいよい色をしているし、日陰の部分はコバルトから紫まであらゆる段階の色彩の変化を見せている。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸、橋、よその船等、舞台の空幕のように注意の外に持ち去られる。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水飴色のうららかな春の日の中に両岸の桜は、貝殻細工のように、公園の両側に掻き付いて、漂白の白さで咲いている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、水はなるべく流す方がいいといって洪水の勢いを、そのままにして、滔々満々浸すに任せて置いたら、両岸の人家まで迷惑して害となります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には、水を排かせるなり、両岸を高く築き固めるなりして害を除きます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はまっ青に淵になったり硝子板をしいたように凍ったりつららが何本も何本もじゅずのようになってかかったりそして両岸からは赤と黄いろのまゆみの実が花が咲いたようにのぞいたりした。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片品の水せばまりて峡をなしている処、奔流｜碧潭、両岸の絶壁いずれも凡ならず。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車、利根川の鉄橋に差し掛かれば、雨はますます激しく、ただ見る、河水は氾濫して両岸湖水のごとく、濁流｜滔々田畑を荒し回り、今にも押流されそうな人家も数軒見える。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "河中に岩石｜突兀として橋を架ける便宜が無いのと、水勢が極めて急激で橋台を突き崩して了うのとで、少しく広い山河には一種の籠を懸けて、旅人は其の両岸に通ずる大綱を手繰りながら、畚に吊られて宙を渡って行く。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの両岸は、美しい景色でした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ボートの中に立ちあがって、美しい緑の両岸を、なん時間もながめていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸には、必ず柳がならんで居ります。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
