[
  {
    "uuid": "5f4bb546-a91b-5c9f-b686-b31957973cd0",
    "entry": "両岸",
    "reading": {
      "primary": "りょうがん",
      "alternatives": [
        "りょうぎし"
      ],
      "is_heteronym": false
    },
    "grammar": {
