        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また専六の手本は平井東堂が書いたが、これも五百が臨書だけは手を把って書かせた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の読書筆札の事は既に記したが、やや長ずるに及んでは、五百が近衛予楽院の手本を授けて臨書せしめたそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏軒は未だ曾て臨書したことがなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "劫を経た吉之丞の希世の動きが律動的に行かなかつたために、眼目の臨書・伝授のくだりが、かき乱された。",
              "citation": {
                "source": "手習鑑評判記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間の所在なさに、書きなぐつた往来文や、法帖の臨書などが、いまだに木津の家の蔵には残つてゐる。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな理由のもとに私は良寛風を慎んではいるが、それでも時に良寛様の晩年作を目前にする場合、ついその魅力に引きつけられ、臨書して見たい気持になる。",
              "citation": {
                "source": "良寛様の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一度でも臨書すると、当座はなんとなく良寛風の書にかぶれてゆくものである。",
              "citation": {
                "source": "良寛様の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "博物館の第一室では、いきなりあの楽毅論の臨書にふれ、光明皇后その人をじかに見た気がしたのである。",
              "citation": {
                "source": "正倉院展を観る",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほかにもいろいろの渡世がありんしょう。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、いつまでもこの通りでいなんしたら、遅かれ速かれ、やっぱり一間住居に決まりんしょうが……」「一間住居は蹴破っても出る」と、男の眼には反抗の強い光りがひらめいた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵からまたみなさん気の揉める方がお出来でありんしょう。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんなら、下総にいらっしゃる筈、嘘でありんしょう」「嘘なもんか？",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処ぞのお馴染へ上げる文でありんしょう。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "津山進治郎は世間でいうりんしょくからそうなのではなくて、彼のやりかたには、万事万端、何か一つのことを激しく思いこんでいて、わきめもふらずそれを追いこむことに没頭している人間の、はたにとん着ない馬力とでもいうようなものがあるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
