    "definitions": [
      {
        "index": 1,
        "gloss": "interest (on a loan, deposit etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "思ひがけなくも卑しい利息のことなどを云つたのを、堪らなく恥かしく思つた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息をなしとすればその人の財産には一銭の増減もありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日暮しの生活知識の奥に、永遠に利息が産み出せる定期預金のような知識を積みたい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年も二百年もの前に貸した金の利息を、そんなハイカラななりをして、毎日ついてあるいてとるということは、けしからん。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出した祝儀に、利息を取るよりけちな男だ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の財産の銀行利息だけでマキアベリイ撮影所を経営して行くことが出来るのです。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝の兄弟より利息を取べからず。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）家賃、それから諸支払い、借銭利息、船橋の家に在る女房どうして居るか、ははは、オドチャには一銭もなし、いや、小使銭三十九銭、机の上にございます。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗をしたのだか何をしたのだか知らないが、黄金を沢山持って武者修行、悪く云えば漂浪して来た伊勢新九郎は、金貸をして利息を取りながら親分肌を見せては段々と自分の処へ出入する士どもを手なずけて終に伊豆相模に根を下し、それから次第に膨脹したのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼッテルベルグ老人はもと株式仲買人で、今は財産の利息で暮してゐる氣樂な體だつたが、その收入が幾分減つたので、寒くて不自由でも少し暮しを詰めようといふ譯で、今年の冬はストックホルムからわざわざ寒氣の嚴しい島の別莊へ移り込んだ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚してからは、その利息が化粧料、小遣となろうというんだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「村長さんは叱言が酒の肴だ」「どうせ利息をつけて返す金だものを、あゝ人にへえこらさせずともよかりそうなものだ」村人の間にこんな蔭口があった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息でも呉れと言うのか』信徒一『こまかいことは知らんが、何でもややこしい難題やそうな。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めはこの古い家柄を衷心から尊敬するスコッチの大蔵大臣の肝煎りで手堅い公債ばかり買い入れ、その利息で楽々生活費が支弁出来た。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息ってものがあるわけよ」　明子が傍から加奈江をけしかけたけれど、加奈江は二度と叩く勇気がなかった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百円借りて、三十日借りの利息天引きで、六十円しかはいらず、日が暮れると、自転車で来て、その日の売り上げをさらって行った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "借りた金は、利息に利息を生み、土地は小作料を持って行った。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は原利息のために務に金を貸していたが、手許がくるしくなったので、壮い男の入智で山岡の宅地を奪って外へ売ろうとしているのであった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も卒かに金なくてかなはぬ時、餘所にてそを借り給はば、二割三割などいひて、夥しき利息を取られ給ふべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息は申し受けずして、いくばくにても御用だて侍らん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息はいくら高くてもかまわないってんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "また土木事業ばかりでなく、その他の事業でももしわれわれが精神を籠めてするときは、われわれの事業は、ちょうど金に利息がつき、利息に利息が加わってきて、だんだん多くなってくるように、一つの事業がだんだん大きくなって、終りには非常なる事業となります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫んだが、利息の言ひわけを済すと慌てゝ逃げて行つた。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や僕はあの利息の重味のために、精魂を枯らしてゐる。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉　　はじめやりそくなつてマツチをすてたわね。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし借りそくなったので、すぐ返した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "事がうまくいって、知らん顔をしているのは、心持ちがいいが、やりそくなって黙っているのは不愉快でたまらない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番容易に死ぬことが出来て、やりそくないのない縊死をとげるまで、臆病と自分でもいうほど、死の手段を選んでいたのだ。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそ、やりそくないのないように支度をして、三斎屋敷へ、本職の方で改めて乗り込むくらいな気組がなけりゃあいけないんだ――今夜は、あの三斎隠居とかいういけ好かない奴をどうしても味方に抱かなきゃあ駄目だけれど――　お初が、自分にいい聴かせているうちに、すでに、もう目あての場所に近づいていた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、法印は、いくらか力無げに、「おらあ、酒を呑みゃあ、きッと、やりそくなう――いや、もう、大した間違えをやらかしたんだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
