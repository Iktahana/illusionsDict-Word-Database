    "definitions": [
      {
        "index": 1,
        "gloss": "clinical (e.g. pathology, training, trial)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
