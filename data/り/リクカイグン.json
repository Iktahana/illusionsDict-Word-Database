        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近頃英国の某新聞で陸海軍人の待遇を論じたのについて某科学雑誌記者は次のような事を云っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸海軍の防備がいかに充分であっても肝心な戦争の最中に安政程度の大地震や今回の台風あるいはそれ以上のものが軍事に関する首脳の設備に大損害を与えたらいったいどういうことになるであろうか。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大本営陸海軍部発表。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国陸海軍は今八日未明西太平洋において米英軍と戦闘状態に入れり。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸海軍当局者が仮想敵国の襲来を予想して憂慮するのももっともな事である。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども今より十年後、二十年後、或は三十年後に至つても、米国の陸海軍は今日と同断なりと思はゞ、兵家の所謂油断は大敵なり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が邦は陸海軍の精鋭をもつて、宇内の強國を驚かして居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸海軍の精鋭は我が邦の大幸福であるが、之を愛惜するの工夫を缺いたならば寒心すべきものがある。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国は陸海軍の精鋭をもって世界の強国を驚かしている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸海軍の精鋭は我国の大幸福であるが、之を愛惜する工夫を欠いたならば寒心すべきものがある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観は仕事の感情を盛り上げてゆく、今度の陸海軍への報国的制作、海と山とに因んだ二十点などは、さうした感情状態でできあがつた作品である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観は一枚二万五千円、二十枚合計五十万円を陸海軍へ献金するための制作であつたが、かうした大観の政治性と、芸術家としての大観の芸術性とを一応分離して考へてみたい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "國内ノ無産階級ガ組織的結合ヲナシテ力ノ解決ヲ準備シ又ハ流血ニ訴ヘテ不正義ナル現状ヲ打破スルコトガ彼等ニ主張セラルルナラバ、國際的無産者タル日本ガ力ノ組織的結合タル陸海軍ヲ充實シ、更ニ戰爭開始ニ訴ヘテ國際的劃定線ノ不正義ヲ匡スコト亦無條件ニ是認セラルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは日本海を向こうへ越えた国境附近で、御国のために生命を投げだして働いている、わが陸海軍将兵のために敬意を表していたのかと思ったんだが、そうじゃなかったのかね」「ええ、敬礼は太陽にしていたんです。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに日比谷の陸海軍の合同軍楽隊の演奏がもう始まるころだから、もうここを出なくちゃならない。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のように陸海軍などが存在しているあいだは、最後の決戦戦争にはならないのです。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "行勝師は一昨年帰って来てそれを陸海軍に納めたのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国の国防的状態はドイツと同一ではなく、ただちにドイツの如くなり得ない点はあるであろうが、極力合理的に空軍の建設を目標として着々事を進むると同時に、航空が陸海軍に分属している間も一層密接なる陸海空軍の協同が要望せられる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸海軍の真の航空全兵力を戦争の状態に応じ一分の隙もなく統一的に運用し、陸海軍に分属していても空軍の占める利益をも充分発揮し得る如く全部の努力が払われねばならない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空総司令官を任命（成し得れば宮殿下）し、これに防空に任ずる陸海軍部隊および地方官憲、民間団体等を総て統一指揮せしめる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第七条、天皇は帝国議会を招集し、其開会、閉会及び衆議院の解散を命ず」更に進んで「第十一条、天皇は陸海軍を統御す」「第十三条、天皇は戦を宣し和を媾じ及諸般の条約を締結す」「第十四条、天皇は戒厳を宣告す」という諸条項を読んでも我等は「立憲」が全く似而非立憲政体であることを知ることが出来る。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこういう資格のある軍事評論家を、今日の陸海軍の将校の内に求めるならば、そこには数限りのない「戦争ジャーナリスト」の予備軍を発見することが出来よう。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も粗末な観念としての「戦争ジャーナリスト」の内、手近かにあるものは、陸海軍省記者クラブ式なジャーナリストである。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そののち、侵略戦争がすすむにつれて『輝ク』は、陸海軍に協力して「輝ク部隊」というものに編成された。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は人の上に立つ人、――立法官、判事、陸海軍の將校、――或は成功した著述家、或は教師、或はどこか遠くの國に於て日本のための代表者となつた事を聞きます。",
              "citation": {
                "source": "明治三十四年東京帝國大學文學部卒業生に",
                "author": "小泉八雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家団体と赤色陸海軍作家連盟とがその師匠役の組織的形態を示してくれることを我々は希望している。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究委員会は、赤色陸海軍に対する組織的な作家の接触と赤色陸海軍内の文学研究会指導を決議した。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤色陸海軍作家連盟からはポドソートスキーが挨拶した。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
