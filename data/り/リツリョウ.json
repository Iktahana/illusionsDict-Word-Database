        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔律令を定められた時は支那の制度を參考にせられた。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江令であり、文武天皇の御代に出来た大宝律令の根本を成すものである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家を弟に継がせ、自らは国学の復古を以て任とし、国史、律令、古文、古歌および諸家の記伝に至るまで渉猟した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔先生が「故を温ねる」と言われるのは、必ずしも前代の故実や形式を教えられるのでは無いけれども、故を温ねて新を知り、古聖先王の世を治め民人を教育した根本の憲章律令、すなわち形式を温ねて、そしてその中に在る精神意義の、百千年を経て尚新しいものを知ることあれば、以って人の師とするに足る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ急々如律令というのろいことばのかしら文字さ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "急々如律令（悪魔払いの呪文）、もう寸刻の容赦はありません。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから改正律令に依りますと、親を毆いた者は懲役十年、それが爲めに親に一寸でも傷をつけたものは終身懲役であつて、餘程輕くなつたけれども、尚ほ仲々重いのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、彼が貧しい人々や所謂不浄な人々と共に食卓に就いて、手を洗わずにパンを割いて食べたことは、食事の前に手を洗うという律令を破るものであって、この点で、彼は直接に祭司や教師の階級と衝突した。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲に於て彼は、律令や誡命などの解釈を飛び越えて、じかに神の許へ行った。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に見らるる新らしさとか革新さとかいうものは、律令や誡命などの夥しい旧解釈を乗り越して、じかに神の許へ赴いたことにある。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、古来の律令を折衷し、新に無窮の大典を撰定すべき事。",
              "citation": {
                "source": "船中八策",
                "author": "坂本竜馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "急々如律令は添え言葉、たいして意味はないらしい……さてこれで字義は解った。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急急如律令、もう寸刻の容赦もない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "牡丹燈記",
                "note": "青空文庫"
              }
            },
            {
              "text": "文武の代に律令を撰定したのも、此司の人々であつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "律令の外にも、宣命・寿詞の新作は、此よごとつくりのつかさの為事であつたらしい。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "審美の学を作りて、是を以て詩界の律令と為さんとするに在り。",
              "citation": {
                "source": "詩人論",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宝、養老の律令がでた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方志を書くに、紀傳體に志を書くこと、掌故といふもの即ち律令典例などの如きものを書くこと、それから文藝に關することを書くこと、この三つの體裁を備へて、さうして地方志が一般史の材料になるやうに著述をして置くといふことの必要を主張した。",
              "citation": {
                "source": "章學誠の史學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、道家と道書、即ち老莊と道教の本との區別、法家と刑法、即ち申韓と律令との區別をしない誤りを説き、又醫術に於ても、漢書藝文志では色々分類をし、解剖學や生理學や内科外科の處方もある。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "手製のもので、裏面には急々如律令と書くのだそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、古来ノ律令を折衷シ、新ニ無窮ノ大典ヲ撰定スベキ事。",
              "citation": {
                "source": "船中八策",
                "author": "慶応三年六月十五日",
                "note": "青空文庫"
              }
            },
            {
              "text": "律令も兵制も改定された。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "律令の改定はすでにこのころから準備せられていた。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやはや、急々如律令……山谷を漕ぎだすと、いきなり、ドッと横ッ吹きの大土砂降り。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、えらいことになりました」　急々如律令といったていで椅子に掛けて、ぐったりと首を投げ出している。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の律令制定でも、明治の法典編纂でも全く外国のものに依拠して、それがうまく運用されているのもまた同じである。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の論者の論拠とするところは、大宝の律令をもって唐の律令に対照し、その全部が彼の模倣でなく、所々にわが国情に適するごとき修正を加えているという点を力説するにあるのであるが、これははなはだ強くない論であるので、全然彼を模倣してはおらぬと言うだけでは、輸入分子を主としておらぬという証明にはならぬ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　１）　Id. c. ix. p. 343.　２）　Id. c. v. p. 221.　情欲の統御に関するかかる厳格な教義の外に、なお他の事情が、おそらく、結婚を奨励する律令が十分にその効果を挙げることを、妨げているのであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "権藤氏によると、元来風俗は恒例へ、恒例は礼儀へ、礼儀は制度律令へ、進化漸化するのであるが、こうした道徳的成俗は自然を以て本としなければならぬ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
