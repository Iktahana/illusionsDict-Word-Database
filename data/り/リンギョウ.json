[
  {
    "uuid": "6b0e68d1-c838-5c9e-a6d3-0cdc7bf3ec64",
    "entry": "林業",
    "reading": {
      "primary": "りんぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forestry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして改良また改善、牧畜、林業、漁業の日に日に盛大におもむく事を。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜産について、また林業について――造林、保護、調査。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、立派な西洋建ての北海道物産陳列所があつて、その附屬として、北海道林業會出品の寄せ木家屋が建つてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の飛魚と、甘藷と、甘蔗、それに林業くらゐが、この島の財政である。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――茂木技師は、仏印の林業調査に軍から派遣される事になり、同じ農林省で働いてゐるタイピストを募つて、それぞれの部署に一人づつのタイピストを置いて来る事になつてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加野は富岡と同じ東京高農の出で、先輩の富岡と安永教授の引きで仏印へ森林業の研究に赴任して来たのである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年となく此の地にとどまつて、印度支那産物誌や、植物誌を書いた仏蘭西人のクレボーや、シュバリヱの著述は、富岡にとつては仲々得がたいものであり、仏印の林業を知る上には、この書物は、此の上ない不朽の名著であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡にはとくに眼をかけてくれて、よく、仏印の林業に就いての説明を事こまかに教へてくれたものであつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドの裏側には、林業に関する本が二十冊ばかり積んであつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は或る新聞社で出してゐる農業雑誌に、南方の林業の思ひ出と云つたものを、此の数日ぽつぽつ書き出してゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林業の思ひ出をつゞる前に、富岡は、きまぐれな気持ちから、南の果物の思ひ出といつた三十枚ばかりの文章を、その農業雑誌に送つておいた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子が昏々と眠りかけて来たので、そのまゝ机に向ひ、富岡は林業と植物に就いての、仏印の思ひ出の原稿に向つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは主として、南方の林業に就いてのノスタルヂイを綴る心算であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイゴンの農林研究所に行つた時に、植物園に近いルウソウ街の、林業部長の部屋で、鰹節大の立派な伽羅の木を見せられた事があつたが、仏蘭西語では、ボア・ド・エーグルと云ふのだと、部長のモーラン氏に教へられた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日、五六枚位の仕事の速度では、南方の林業も仲々金に変る日は来ない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、もう二つばかり仕事があつたが、一つは、和歌山の高池町にある林業試験場へ、技師として勤める口であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、高池町の林業試験場へ行くよりも、南の果ての孤島である、屋久島の営林署へ行きたかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高池町の林業試験場が、気がむかなければ、同じ、和歌山の伊都郡九度山町の、高野営林署にも、君の行くポストはあると、その友人は勧めてくれた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の主要な財源は、五月の飛魚と、甘藷と、甘蔗と、林業である。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林業試験所のある、トラングボムで一寸降りて、そこで、富岡と加野は、それぞれの用事を済ませて、また、自動車は、もの淋しい鉛色のうねうねとした官道を、すくんすくんと音をたてて走つて行く。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　信吉が働いていた××林業株式会社というのも、たちはそれだった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、××林業株式会社現場行人夫募集の広告を見たとき、自転車屋が潰れてあぶくれていた信吉は、気が動いた。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄部屋や蟹工船の話をきいている信吉には、××林業の現場とはどんなところか、不安でないこともなかった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫募集広告には、日魯林業株式会社直営現場となっていた。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "××林業が現場を開いた年から毎年出稼ぎに来ているという源が、或る日バラックで腹掛のドンブリから受けとって来た金を出しながら、「畜生、なめてやがんな。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、××林業の現場はソヴェトの領土にあるおかげで、労働条件が内地よりズットましだった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんだから、××林業にとっちゃ日本人夫なんぞ一人や二人どうしようとこわくねえ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "××林業の日本人足のバラックだけが、わざと痺らされて何にも知らずボーとしてるが、つい山の外じゃ、もっと、もっと何か素晴らしいことがあるに違えねんだ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ、××林業の現場引あげが目の前に迫ると、若い信吉の心は苦しくなった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　信吉はとうとう、明日××林業株式会社事務所出張所へ総集合という前の晩、谷間の六号番屋をズラかった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
