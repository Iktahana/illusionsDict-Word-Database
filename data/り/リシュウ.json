    "definitions": [
      {
        "index": 1,
        "gloss": "officialism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "揃いも揃って気骨稜々たる不遇の高材逸足の集合であって、大隈侯等の維新の当時の築地の梁山泊知らず、吏臭紛々たる明治の官界史にあっては恐らく当時の官報局ぐらい自由の空気の横流していたはけだし類を絶しているだろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥田は東京市の名市長として最後の光栄を柩に飾ったが、本来官僚の寵児で、礼儀三千威儀三百の官人｜気質の権化であったから、豪放｜洒脱な官界の逸人高橋自恃庵が作った放縦自由な空気は忽ち一掃されて吏臭紛々たる官場と化してしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、主人楯凡児氏は、およそ官吏臭といふものから抜けきつた、軽妙洒脱な半面があつて、この隣組の育ての親と云つてもよく、彼の出るところ、話の纏まらぬためしはないといふほど、不思議な説得力をもつてゐる。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら、いきなりしゅうしゅうと両方の目から火をふきました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
