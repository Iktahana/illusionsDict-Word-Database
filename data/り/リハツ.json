    "definitions": [
      {
        "index": 1,
        "gloss": "haircut",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔の江戸時代の日本人は、理髪店で浮世話や将棋をしながら、殆んど丸一日を暮して居た。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な紅白の棒の看板を立てた理髪店がある。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "｛３｝米国国旗や理髪店の看板が縞模様でありながら何らの「いき」をももっていないのは、他にも理由があろうが、主として色彩が派手であることに起因している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "形状上では理髪店の看板とほとんど違わないが、色彩の効果によって「いき」な印象を与える。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、私がパリで散髪をしていると理髪師が私に向ってデ・ジャポネー（日本人）は騎兵は要らぬそうですねといった。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「床屋」が何ゆえに理髪師であるか不思議である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレイの理髪師は tukang chukor また tukang gunting である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店の軒先には、紅白の丸い棒が突き出してあり、ペンキの看板に Barbershop と書いてあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはいつもの理髪店が、客の来ない椅子を並べて、白昼の往来を眺めているし、さびれた町の左側には、売れない時計屋が欠伸をして、いつものように戸を閉めている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀が呉松路通インタナショナル理髪館で変装して上海の共同租界から各国兵の監視をくぐってオランダ船で逃れた当日は、彼は失業工人の一団を率いて特別戒厳令のなかに潜伏していた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は海岸通りの女理髪店で、彼女に断髪するように勧めてみました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂や写真部はもちろん、理髪店、ツーリスト・ビュロー、何でもある。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のれんをあげて理髪技士、　　白き衣をつくろひつ、弟子の鋏をとりあぐる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　鏡の中の俳優Ｉ氏　某百貨店の理髪部へはいって、立ち並ぶ鏡の前の回転椅子に収まった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向側の鏡が、九枚も上手に継いであって、店が丁度二倍の広さに見えるやうになって居り、糸杉やこめ栂の植木鉢がぞろっとならび、親方はもちろん理髪アーティストで、外にもアーティストが六人もゐるんですからね、殊に技術の点になると、実に念入りなもんでした。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪所の裏が百姓｜家で、牛のうなる声が往来まで聞こえる、酒屋の隣家が納豆売の老爺の住家で、毎朝早く納豆納豆と嗄声で呼んで都のほうへ向かって出かける。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流より石級の方を望めば理髪所の燈火赤く四囲の闇を隈どり、そが前を少女の群れゆきつ返りつして守唄の節合わするが聞こゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は何処までも理髪師らしくない、おぼこな態度で客あしらひをした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ上の壁に大きながくがかかって、そこにそのうちの四人の名前が理髪アーティストとして立派にならび、二人は助手として書かれていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも水の音に暮れてしまったので、電灯の下で夕飯をすませて、散歩がてら理髪店へゆく。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大仁理髪組合の掲示をみると、理髪料十二銭、またその傍に附記して「ただし角刈とハイカラは二銭増しの事」とある。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店を出ると、もう八時をすぎていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋には朝日理髪店と書かれてあり、これはめったに書きのがせなかった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりはつかれて、ぶらぶらと歩きはじめた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末には不景気と云ふ言葉の意味は、固よりはつきりは判つて居なかつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」曹長「マルトン原のかなしみのなかひかりはつちにうずもれぬああみめぐみのあめを下しわれらがつみをゆるしたまえ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――しかし……」　と、新内語りはつづけた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜物靜物のこころは怒りそのうはべは哀しむこの器物の白き瞳にうつる窓ぎはのみどりはつめたし。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな単純な手で収まりはつきますまい。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかっていることその一、ひとりの男が道ばたに立ち、夫妻の諍いを見ていたこと――日よけが上がり、部屋の明かりはついていたからだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
