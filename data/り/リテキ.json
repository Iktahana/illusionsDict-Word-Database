    "definitions": [
      {
        "index": 1,
        "gloss": "benefitting the enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今度は風が強く、全く利敵風であった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、かくのごとしといえども、忘恩無情の挙にあらず、城中の私闘を鎮め、利敵の徒を追い、征後の禍根を除きたるまでなり。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子もそれを見に降りてきたのだ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」清三が帰ると園子は二階から走り下りてきて食卓を拡げた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　大西も、栗本も、腰に弾丸がはまった初田も週番上等兵につれられておりてきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、しかし、中隊が麓へ到着するまでに登って、様子を見て、おりてきなければならなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋車をとめると、福隆火柴の小山がおりてきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しにこんなところまで、おりてきたんだい。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、克巳はさっぱりおりてきませんでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳は二階からおりてきました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜僕は梅田先生の処から借りてきてから読みはじめたけれどおもしろうて止められない。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を聞きつけてミシミシと二階を下りてきて「ヤア」と現われたのが、一別以来三年会わなんだ桂正作である。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ園の奴まだいたかな」　そう西山は大きな声で独語しながら、けたたましい音をたてて階子段を昇るけはいがしたが、またころがり落ちるように二階から降りてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅の方で、西山が図書館から借りてきたカアライルの仏蘭西革命史をめくっていた園が、ふと顔を上げて、まじまじと西山の方を見続けていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから人見さんが急いで降りてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて咳をしるべに純次が小道を下りてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで降りてきたまえ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ、飲みすぎ食べすぎのたたりてきめん、身心がだるい、熱い溢れる湯にはいりたくなり湯田へ行かうかとも思つたが止めにして戻る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに、女中といっしょに、あの小さな男の子がおりてきて、さがしはじめました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いましているお話は、その歌からかりてきたものなのです。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、今だって、心の中では、ずうっと、だいてあげているのに」　そのとき、大きな、黒いカラスが、目の前の道の上に、おりてきました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジュリーが右手をひっぱりますと、マタンはひっぱられるままに、おりてきました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの妹のアキコがね、とっても、うた時計がすきでね、死ぬまえに、もう一ぺんあれをきかしてくれって、ないてぐずったのでね、薬屋のおじさんとこから借りてきて、きかしてやったよ」「……死んじゃったのかい？",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでね、命日に、ぼくがまた薬屋からうた時計を借りてきて、やぶの中で鳴らして、アキコにきかしてやったよ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまわりさんの芝田さんは、なにか事件でも起こったかと、電燈の下であわてて黒いズボンをはき、サーベルを腰につるしながら下りてきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねはお寺でかりてきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とへんじがきこえて、正観が、ごそごそ鐘楼からおりてきました。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜お良は真蒼な顔で坂本の部屋から降りてきたので、どうしたのかときくと、坂本さんに怪談を聴かされたという。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
