    "definitions": [
      {
        "index": 1,
        "gloss": "implementation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "唯一ト声、釣りせんとて通るものなりと答へしのみにて、咎めらるゝ事も無く済みけるが、此のあたりの地をば吾が家にて有ちし往時もありければ、一ト言にても糺されしことの胸わろきにつけて、よし無き感を起しゝも烏滸がまし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一声、釣りせんとて通るものなりと答へしのみにて、咎めらるゝ事も無く済みけるが、此のあたりの地をば吾が家にて有ちし往時もありければ、一言にても糺されしことの胸わろきにつけて、よし無き感を起しゝも烏滸がまし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪へ行ったらしっかりせんと田舎者やと笑われるぞと、兄らしくいましめてくれた文吉の言葉を想出したのだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "都を出る時、遠く西方に旅する友と約するあり、東海道の某地を卜して相会見せんとす、期する日は明後、彼は西より来り、我は東よりせん、相見る時、情｜奈何。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪へ行ったらしっかりせんと田舎者やと笑われるぞと兄らしくいましめてくれた文吉の言葉を想出したのだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊はやはりせんの男の子にあいました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、そんな馬鹿なこと、絶対にござりせん。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、決して、わざとそんな口を利くわけではなかつたのだが、しつかりせんかツ！",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州の新町にて汽車を下り、藤岡より鬼石にかかり、渡良瀬川を渡りて秩父に入るの一路もまた小径にあらざれど、東京よりせんにはあまりに迂遠かるべし。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸より甲斐に至らんに武蔵よりせんには、荒川に沿いて上ると玉川に沿いて上るとの二路あり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はほとんどこおどりせんばかりに嬉しく感じた。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「びっくりせんでもいい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくりせんでもいいよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで値がまだ餘りせんうちに、もつと高くなること必定と云ふ時に賣るのはきまつて、わづかしか預けとらん小者の米だ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆうぐれしずかに　　　　いのりせんとて、世のわずらいより　　　　しばしのがる――」　讃美歌の声が奥座敷の二階から聞えて来る。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず、書斎に立て籠って懐中から例の手帳を出したが、何分｜夕景ではっきりせん。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれならよかろう」　納棺後、祐之助は、中学五年の長男に向って、「さて、これからが小一郎君のしっかりせんならん時だよ、父さんは偉い人だったが、その跡をさらに立派に立てるのが君の責任だ。",
              "citation": {
                "source": "墓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では」と、かの女は尋常な顏になつて、「人を棄てたりせんでもええぢやないか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊りせんかい、撲ん殴るぞ！",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お遇ひするが早いか、とにかく此宿屋を出ようではありせんか、こゝへ來たら「角大」と云ふ啄木の唄に出て來る女のひとの營むでゐる宿屋がありますと云つて、自動車を頼むでこられた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝかくばかりせんもなき二十五の女心の迷ひかな。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手紙も、日本へは四十日余りせんと届かんかと思うと、心細いね。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きっぱりせんが、マア一俵がとこじゃろ」「…………」　祖父さんは、やがて伏目になり、艶のない貧相な白髯を片手でしごいて、咳払いをした。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の要求すべきことなぞを知らず、違った世界を見たがったり、自分の生活を慰め、忘れようとしたりせんがため、全然無関係な書物を読もうとする傾向は次第に強くなって来ている現在である。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「町人へ嫁入りせんか」　と、いう言葉は、調所が、本当に、親切からいったものだとは、思えた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父やお母とは気持がしっくりせんしな。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野呂さんも女好きですからなあ、しつかりせんとおみつつあんとられてしまひまつせ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
