        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "農林学校を出た者よりも。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子を農林学校へやる学資とするためだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは内地の農林学校の助手だよ、だから標本を集めに来たんだい。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翰林学士の劉三吾、御歎はさることながら、既に皇孫のましませば何事か候うべき、儲君と仰せ出されんには、四海心を繋け奉らんに、然のみは御過憂あるべからず、と白したりければ、実にもと点頭かせられて、其歳の九月、立てゝ皇太孫と定められたるが、即ち後に建文の帝と申す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的方面の筆者は、いづれも当代一流の大家で、早大工科学長の山本忠興博士、上原林学博士を初め、かうしたものを書かうと云ふ素志を持つて居られたと云ふから刮目して見るべきであらう。",
              "citation": {
                "source": "小学生全集に就て（再び）",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三津子さんのお連合いは林学士で、ある地方の小林区署長を勤めていらっしゃるのでございます。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろの森へはいって、何かの仕事をしていた三津子さんのお連合い――前にも申した林学士の関井さんでございます――がやがて帰って来ました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡役所、税務署の若い役人や山林学校の先生や林野管理局の若手連が倶楽部のようにして集まるので常時も其｜家は賑かであった。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多式貯蓄法、林学博士本多静六。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林学博士と云えば、農学の一部で、それは自然科学の分野に属す学問上の博士ということであろう。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人が、林学について語らずに、貯蓄法について語っていることを、吾もひともみっともない妙なことと感じない感覚というものは、日本のどういう文化・科学性を語っているのだろうかと思った。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林学専門なら山がよく鑑定されるわけだろう。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の農科大学を出、今は鳥取の農林学校に在り。",
              "citation": {
                "source": "学校友だち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "西川は今は鳥取の農林学校か何かの教授をしている。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは北海道の旭川に帰り、林学博士松下真孝氏と結婚されているのですが、私の詩集も、このひとの友情がなかったら出版されていなかったのでしょう。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西のナンシー山林学校を出た人物である。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に吾輩が、如何に片腹痛かったかは、吾輩の親友若林学部長が知っている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝これを嘉賞し、故｜翰林学士、芳九｜連の遺子｜黛女を賜う。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから四五尺の長さにメッキリと書き詰めた漢文の上を形式ばかり眼を通して、その結末にある、大倭朝天平宝字三｜年癸亥五｜月於西海火国末羅潟法麻殺几駅大唐翰林学士芳九連二｜女芬　識　という文字を二三度繰り返して読んで、いくらか気を落付けてから、もとの通りに巻き返して箱の横に置いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の事は若林学部長に委託してありますから」云々と云い棄てて、呵然大笑しつつ扉を押し開き、どこへか立ち去ったとの事で、総長室の隣室で聞いていた事務員連は皆、同教授の発狂を疑いつつ顔を見合わせつつ震え上ったという。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して右に就いては若林学部長その他関係者一同口を緘して一語をも洩らさず、前記の大惨事と共に極力秘密裡に葬り去ろうとした模様であるが、本社の機敏なる調査に依って、かく真相が曝露したものである。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農林学校｜出身の、地主の悴の欣之介は毎日朝早くから日の暮れるまで、作男の庄吉を相手に彼の整頓した農園の中で余念なく労働した。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "農林学校の先生だとかをしてゐられると聞きましたが」「もう河原町へは当分帰る気はないんですかね。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の景色でよかったのは、渓流と天然の密林、それも何年か昔の話で、大抵の森林は、もうすっかりマッチの軸木と焚きつけに変ったから、今では林学や地理科で取りあつかうより、歴史の領分になってしまった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒場出の壮年の林学士。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は斗満の上流ニオトマムに林学士の天幕を訪う日である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林林学士を統領として、属員人夫アイヌ約二十人、此春以来｜此処を本陣として、北見界かけ官有｜針葉樹林の調査をやって居るのである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水際の雑木林に入ると、「あゝ誰れか盗伐をやったな」と林学士が云う。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林学士は斯く云うた、北見、釧路、十勝に跨る針葉樹の処女林には、アイヌを連れた技師技手すら、踏み迷うて途方に暮るゝことがある、其様な時には峰を攀じ、峰に秀ずる蝦夷松椴松の百尺もある梢に猿の如く攀じ上り、展望して方向をきめるのです、と。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾手は林学士が部下の塩田君、鹿児島の壮士。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
