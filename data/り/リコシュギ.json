        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所謂利己主義者ではないのであらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛情ばかりで智慧の判断の伴わない慈悲は往々にしてまた利己主義の慈悲になります。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角、自分は善良な慈悲心でして居るつもりのことが、利己主義の慈悲心になっては残念です。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう気がついたのは、主人であったか、読者たる私であったか忘れましたが、とにかく利己主義な慈悲の例証にこの話は役立つものです。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり自己満足、利己主義の慈悲とはこういうことなのです。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　女の方も女の権利とか位置とかを楯にして案外｜浅薄な利己主義な、お芝居気を満足させるための気障なのも往々にして見受けます。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな位友情のない、利己主義な、趣味のわからない人物は居ないだらう。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他国を属国とし、他国を征服すれば得をすると考える利己主義者があるから起って来るのだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その利己主義が誰れであるか、それは考えていない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この甲型の人の目から見ると乙型の人間は消極的｜退嬰的な利己主義者に見える。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角、自分は善良な慈悲心でしているつもりのことが、利己主義の慈悲心になっては残念です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう気がついたのは、主人であったか、読者たる私であったか忘れましたが、とにかく利己主義な慈悲の例証にこの話は役立つものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっても利己主義や、憎みはやはり人情の本能ですから、なかなか全部たちどころに捨て切れるものではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四七課　利己主義　利己主義ということは、人間の生きて行く上において是非必要なことでありますが、それを余り強調拡大させると、隣人はもちろん、社会にまで迷惑を及ぼします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正当に利己主義を使うことが日本ではまだ実行されていないようにさえ思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように、自分の明日の仕事に少しも差支えのないことで客人達を喜ばせ、客人達もその利己主義を許容し、主人夫妻をして明日のために充分眠らしめ、そこで自分も安心して自分達の愉快を尽すというところに、本当の利己主義の妙味があると思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事には程が必要ですが、それは、お互いにお互いの利己主義を認め合い、お互いのためを思い合って、お互いの利己主義を出来るだけ調和して発揮させて行くことが、博愛主義にも通ずる利口な利己主義の使い方だと思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが結婚して、やうやく男子に対する自覚が出来、初めて男といふものが解つた時、私の感じたのは、男子といふものは事業慾が強くて、一般に利己主義なものだと思ひました。",
              "citation": {
                "source": "男心とはかうしたもの",
                "author": "女のえらさと違う偉さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一段階に於いて感じた男子の利己主義も、それをつぐなつて余りあるだけの男の偉さを、第二段に於いて感ずるやうになつたのです。",
              "citation": {
                "source": "男心とはかうしたもの",
                "author": "女のえらさと違う偉さ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
