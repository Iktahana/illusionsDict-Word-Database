    "definitions": [
      {
        "index": 1,
        "gloss": "pangs of conscience",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
