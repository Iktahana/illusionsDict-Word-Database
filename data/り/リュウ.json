[
  {
    "uuid": "ed07d703-94f0-5475-8f8f-09acb8df93a4",
    "entry": "流",
    "reading": {
      "primary": "りゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
