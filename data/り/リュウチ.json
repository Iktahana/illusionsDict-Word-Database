    "definitions": [
      {
        "index": 1,
        "gloss": "detention (usu. during investigation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
