[
  {
    "uuid": "4546e2b1-0e02-5b7c-a7d6-3bbece4ab956",
    "entry": "良否",
    "reading": {
      "primary": "りょうひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
