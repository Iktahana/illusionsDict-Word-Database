        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「臨死むとする時、長歎息して曰く、伝へ聞く仮合の身滅び易く、泡沫の命｜駐め難し。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜美人臨死可儀容一　黒田官兵衛は健在なり。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまいぞ、うまいぞ、鈴蘭なんかまるでパリパリだ」　風が来たので鈴蘭は、葉や花を互いにぶっつけて、しゃりんしゃりんと鳴りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども実をとられた鈴蘭は、もう前のようにしゃりんしゃりんと葉を鳴らしませんでした。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は五年めごとにしか咲きませんが、そのときにも、ただ一りんしか咲かないのです。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつさいりんしんかとて柴をかつぎて、※さん被りにしたる村里の女房、娘の、朝疾く町に出づる状は、京の花賣の風情なるべし。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほかにもいろいろの渡世がありんしょう。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さん、さっきはお世話でありんした」　立兵庫に結った頭を少しゆるがせて、型ばかり会釈した彼女は鷹揚ににっこり笑った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか積もりんしたね」　座敷の櫺子窓をあけて外を眺めていた綾鶴が、中の間の方へ向いて声をかけた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、いつまでもこの通りでいなんしたら、遅かれ速かれ、やっぱり一間住居に決まりんしょうが……」「一間住居は蹴破っても出る」と、男の眼には反抗の強い光りがひらめいた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、いつか仲の町の草市で摺れちがった時の刀というのは、やっぱりこれでありんしたかえ」「むむ、そうだ。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵からまたみなさん気の揉める方がお出来でありんしょう。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんなら、下総にいらっしゃる筈、嘘でありんしょう」「嘘なもんか？",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってざますよ」「なに、知っている※　どこのものじゃ」「江戸町の角菱楼にいなました薄雪さんざますよ」「その者は、特に達磨がすきじゃったか」「大好きも大好きも、どうしてあんなひょうげたものが好きやら、髪飾り帯下じゅばんの模様まで、身につけるほどの品物はみんな達磨の模様でありんした」「さようか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯も三膳ずつに極めているの」　おひろは痩せた小さい体の割りには、声がりんりんして深みがあった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの弁護士団は、「本件の如き憲法や新刑訴の趣旨を蹂りんしているのではないかと被告がすでに思っているような事件においては」「法令が適正に運用されているかどうかを注意し、いやしくも非道、不正を発見したときにはこれが是正につとめなければならない。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つるつるしゃん、つてしゃんりんしゃん、それお腰、やりなおし、そら御手」　腰を上手に折れば、五本の指がすきまだらけになり、目付を上手にすれば、口がぽかんとあく。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処ぞのお馴染へ上げる文でありんしょう。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっとした文次、往来の上下を睨めまわすと、屋敷町の片側通りだ、御府内といえ、一つ二つ横町へそれたばかりなのにもうこの静けさ、庫裡のように寂寞としたなかに、八つ下がりの陽ざしがやけにかんかん照り返って、どの家からともなく、美しい主をしのばせぶりに、ころりんしゃん、かすかに琴の音がもれている――。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラ　そういえば、ぬしみとう、けったいななりをしておったが、確かもっと赤うて花びらも小そうありんした。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて二ばんに仮面をあてゝ鈿女に扮たる者一人、箒のさきに紙に女てゆかた也色ある細帯をなし群行、里言にこれをごうりんしやうといふ、こは降臨象なるべし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "津山進治郎は世間でいうりんしょくからそうなのではなくて、彼のやりかたには、万事万端、何か一つのことを激しく思いこんでいて、わきめもふらずそれを追いこむことに没頭している人間の、はたにとん着ない馬力とでもいうようなものがあるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御湯殿上記に「四月二十五日はてれん、けふりんしいたされて、むろまちとのへ申され侯」とあるのがその証拠である。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
