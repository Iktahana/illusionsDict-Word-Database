    "definitions": [
      {
        "index": 1,
        "gloss": "faculty of science and engineering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
