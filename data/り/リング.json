        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "老人株ではカナル線の発見者ゴールトシュタインや、ワールブルヒなどがおり、若手ではゲールケ、プリングスハイム、ポールなどもいた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて禿頭の大坊主で、いつも大きな葉巻を銜えて呑気そうに反りかえって黙っていたのはプリングスハイムであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人はジューリングと一緒に気球で成層圏の根元に近づき一時失神しながらも無事に着陸したという経験をもっていて、搭乗気球としての最高のレコードの保持者であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七二〇年頃ターリング（Terling）に新しく住家を求め、その後 Terling Place の荘園を買った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この最初の研究実験はターリングの邸宅の古いグランドピアノの上で行われたのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行後ターリングに帰って秋と冬を送った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七三年の秋に新しきレーリー卿となった彼はトフツの邸から父祖の荘園ターリングに移った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一八七四年から一八七九年までは平穏にターリングの邸で暮していた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その試験問題の討究のために試験官仲間をターリングに招待したが、そのためにソリスベリー卿とディスレリーとの和解の饗宴という歴史的のシーンに出席する機会を逸した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里ターリングに引上げてから、自分の研究室の準備にかかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターリングでやろうと計画していた研究の一つは、主要なガス元素の比重を精密に測定してブラウト方則を験しようというのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家族を挙げてターリングの邸内に移り、死ぬまでここでレーリーの片腕となって働いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の集会に列席する以外は大抵ターリングに居て書信で用を足した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄弟のバルフォーア、当時のアイルランド政務総監がターリングへ遊びに来た時は護衛の警官が十二人もついて来たりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターリングにおける日常生活を紹介する。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターリングの家の来訪者名簿には、内外の一流の学者の名前の外に英国一流政治家の名前も見える。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇五年に新しい助手 J. C. Enock を得たが、この人は一九〇八年にターリングを去った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦中ターリングは軍隊の駐屯所となった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしターリングの設備では実行が出来ないのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬式はターリングで行われた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓はターリング・プレースの花園に隣った寺の墓地の静かな片隅にある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨かれた車窓に、西紅葉の横顔がスプリングのついた船舶に乗船する女のように輝いていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、近頃盛に探偵小説を愛讀する自分だが、小説の上ではスリリングな殺人事件も現實に近所に起つてみると甚だ以て有り難くない。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルテンスの『ストリングマスタリー』より拙訳）　スペシアリストのほんとうの意義、その心得を説き尽くしたものと思う。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　ラインハルト・ゲエリング――「海戦」（海戦の中の第五の水兵は叛乱の志を持っている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ゲエリングは、反戦的ではありながら、本当に書こうとしていることは、人類全体の上に蔽いかゝっている運命の力との関係であるようだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではレニングラードからランゲル島へかけベーリング海近くまでも飛行機を飛ばし空中写真測量で北シベリアいったいの地図を作る事になっている。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の探険隊員の講演の際壁にかけられた粗末な北氷洋の海図の上を赤い線で示された航路の触手がするすると東に延びて、それがベーリング海峡を越えて横浜まで届くのを見た。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから壺の口縁の所のやや細かい形のモデリングが始まるのであったが、そうそういつまでも見ている暇がなかったから、そこまでで残念ながら割愛して帰って来たのであった。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは氷河鼠を食ひにベーリング地方へ行きたいのだが、どこらがいちばんいいだらう。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            }
          ]
        }
