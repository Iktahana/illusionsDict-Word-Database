        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "城ヶ島の雨雨はふるふる、城ヶ島の磯に、利休鼠の雨がふる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "色ならば、利休鼠か、水あさぎ、黄は薄くとも温かければ、卵いろとも人のいふ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから雪白のだぶだぶとしたズボン、利休鼠のお椀帽。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "右舷寄りのテエブルには、音楽会の晩、私に利休鼠の頭巾を貸してくれた、小さな小さな商人風の、若山牧水に似た顔のお爺さんと、その連れの須田町のある旅館の主人だという、これも江戸っ子式の快活な中爺さんと、例によって酒が賑やかだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
