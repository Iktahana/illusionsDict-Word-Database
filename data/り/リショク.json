    "definitions": [
      {
        "index": 1,
        "gloss": "money-making",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これ丈の資金があるが、何とか利殖の方法があるまいかつて君に相談したんでせう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」＊＊　「俗物」という観念は、世間的にしばしば趣味の低い人や、金銭の利殖に熱心な人を指している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また銭屋五兵衛や紀文の如く、生涯金銭の利殖を求めていて、しかも詩人的にロマンチックな人物もいる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西啓蒙期の詩人ウォルテルの如きも、非常に実利的で利殖に抜け目のない人物でありながら、しかも当時一流の人間的情熱家だった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛍雪はその後、漢和の辞典なぞ作ったものが当り、利殖の才もあってだんだん富裕になった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利殖の道にたくみだつたとは戲談にも云へんにしろ、世間普通の地主と變つた地主でもなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの位利殖のことには敏い人間が、どうも不思議でならないんです。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は利殖の勘定や、株式の掛引を知らない代りに、雪嶺博士と同じやうに哲学を考へる事を知つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンは彼を以て、星を眺めながら溝に落ちた人生の観照者として紹介しているが、もっと忠実な歴史家であるアリストテレスは彼を卓越した実業家乃至利殖家として紹介している。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の句をつけませんか」「そうね……」「何がいいでしょう……あ、こんなのはどうでしょう」　網野さんが云わない先から自分の考えのおかしさにふき出し、袂で顔を抑えながら笑い笑い、「利殖の本も買ふ気になれり」と下の句をつけた。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利殖の本も買ふ気になれり？",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皮と身と離るゝ体我もてば利殖の本も買ふ気になれり」　うまかったな、網野さんはなかなかうまい、と百花園のお成座敷の椽でお茶を飲みつつ更に先夜の笑いを新にしたのだが、その時網野さんのユーモアということが、作品にもつづいて私の頭に浮んで来た。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皮と身と離るゝ体我持てば利殖の本も買ふ気になれり」　思わず――その体の持主が私共だということ、それに利殖の本を結びつけた機智の面白さ――笑ってしまう滑稽さがあるが、このユーモアには何処やら淋しさがこもっているようではないか。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入の幾割かを皆が積立てて、その適当な運用、利殖によって、組合員の老後や病時の安定が保障され得るとしたら、恐く彼女はあれ程生存の不安に追立てられは仕なかったでしょう。",
              "citation": {
                "source": "ひしがれた女性と語る",
                "author": "――近頃思った事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都老妓｜中西君尾は、その晩年こそ、貰いあつめた黄金を、円き塊にして床に安置したような、利殖倹約な京都女にすぎないように見えたが、維新前の国事艱難なおりには、憂国の志士を助けて、義侠を知られたものである。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉本屋も小金を要領よく利殖してめっきり大きくなってきた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場ではお上さんが、一本のキング・オブ・キングスを清水で七本に利殖しているのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場ではお上さんが、一本のキング、オヴ、キングを清水で七本に利殖している。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "指導者側のそれらの婦人たちの中の或人たちが、経済的労働を私たち婦人に奨励されるのを見ると、その目的が利殖の外に出でず、その方法が振売商人の暴利を狙う不正手段と大差のないものであるのに呆れます。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も財産を作るには利殖の方法もあるし、比えば定期市場に手を出すような方法もあるから、一概には云えないが、三度の火事は疑えば疑えない事はない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金、金、金……利殖よりほか楽しみのないもののようにいわれた彼女が、女優生活の十年に残しえた三万円を捨ててかえり見ず、縊れ死んでしまって、そういう人たちに唖然とさせたのは痛快なことではないか。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "益満の企ても、国許の方々の企ても、調所の利殖しておいた金子があればこそじゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れだけの金を銀行に預けて置けば、年五朱として何程の利殖になる。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの金を銀行に預けて置けば、年五朱として何程の利殖になる。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "持山　　ふん、利殖としては悪くないね。",
              "citation": {
                "source": "雅俗貧困譜",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "利殖の投資以外のことに五万円ひきだすとすれば大胆すぎることであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七二　狭義の資本と利殖、すなわち動産資本と動産用役。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に労働と並べて土地、資本を置くべきではなくして、地用（rente）すなわち土地の用役と、利殖（profit）すなわち資本の用役とを置かねばならぬ。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に第三種の資本として動産資本（capitaux mobiliers）または狭義の資本があり、それらの資本が与える収入は動産収入（revenus mobiliers）または動産用役（services mobiliers）と称せられ、また利殖（profits）とも呼ばれる。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
