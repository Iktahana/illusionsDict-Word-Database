    },
    "definitions": [
      {
        "index": 1,
        "gloss": "list",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "之に反して、貧しき境遇にあるもの、生れながらによきキリストの血を受けて長く苦労せる人人の心には、自然とやさしい人情の種が蒔かれて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストを知らないのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の人もまた、マリヤ様、エス様が、たいへんありがたいおかたであるという事は、教会の雰囲気に依って知らされ、小さい時からお祈りをする習慣だけは得ていながらも、かならずしも聖書にあらわれたキリストの悲願を知ってはいないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｍ・マリイという人は、ヨーロッパの一流の思想家の由であるが、その「キリスト伝」には、こと新しい発見も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この程度の「キリスト伝」が、外国の知識人たちに尊敬を以て読まれているんなら、一般の聖書知識の水準も、たかが知れていると思った。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教えてくれたのは、欧米の人たちであるが、今では、別段彼等から教えてもらう必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神学」としての歴史的地理的な研究は、まだまだ日本は、外国に及ばないようであるが、キリスト精神への理解は、素早いのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教の問題に限らず、このごろの日本人は、だんだん意気込んで来て、外国人の思想を、たいした事はないようだと、ひそひそ囁き交すようになったのは、たいへん進歩である。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は単なる冷酷漢で、それゆゑ却て平和の中ではやさしい人とみえる、或時は自分をディアボリストかなと思つたりして満足してみる、かのお仁好しと天才との中間にある、得態の知れない輩なのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "富永は、彼が希望したやうに、サムボリストとして詩を書いて死んだ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう書き、又さう思ふとも強めたものゝ、私のセンチメンタリストであることは依然として変りなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　さうした、所詮世上のニヒリストには最も馬鹿気たと見えるだらう生活を――私自身もこだはつた生活だと今では思つてゐる――してゐた私は、今態々落第して、それをキツカケに京都の某中学に転校してゐて、「その頃の生活」の環境といふものと離れてゐる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分をセンチメンタリストと粧ふことがあるかも知れないが、それは彼と人々との齟齬を埋合はせる彼の自然の術なのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の文豪である大トルストイが、救世軍的人道主義者として擔がれたり、通俗モラルのセンチメンタリストとして、女學生の涙劇的ヒロイズムの對象であつたりしたことを考へると、今から考へて全く馬鹿馬鹿しく滑稽である。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、山岸は、「人間キリスト記」を書いた。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕口を言はず、駄洒落を飛ばさないから、Ｋ君をユーモリストだと誰も思はないけれど、挨拶をさせたり、序文を書かせたりしたら、Ｋ君のものは天下一品だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的太宰治　ヨーロツパの近代人が書いた「キリスト傳」を二、三册讀んでみて、あまり感服できなかつた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外國の人もまた、マリヤ樣、エス樣が、たいへんありがたいおかたであるといふ事は、教會の雰圍氣に依つて知らされ、小さい時からお祈りをする習慣だけは得てゐながらも、かならずしも聖書にあらはれたキリストの悲願を知つてはゐないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｍ・マリイといふ人は、ヨーロツパの一流の思想家の由であるが、その「キリスト傳」には、こと新しい發見も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この程度の「キリスト傳」が、外國の知識人たちに尊敬を以て讀まれてゐるんなら、一般の聖書知識の水準も、たかが知れてゐると思つた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教へてくれたのは、歐米の人たちであるが、今では、別段彼等から教へてもらふ必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神學」としての歴史的地理的な研究は、まだまだ日本は、外國に及ばないやうであるが、キリスト精神への理解は、素早いのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教の問題に限らず、このごろ日本人は、だんだん意氣込んで來て、外國人の思想を、たいした事はないやうだと、ひそひそ囁き交すやうになつたのは、たいへんな進歩である。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖をおりかかると下から大学生が二三人、黄色い声でアリストートルがどうしたとかいうような事を議論しながら上って来る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして視覚に関してはアリストテレスが『形而上学』の巻頭にいっている言葉がここにも妥当する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誅戮」「討伐」「征伐」「征討」などと、武張ったどこかの国のジャーナリストなら書きたい所であろう。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の中にガスがたまるからとか、また「生命の呼吸の大部分を分有するから」とか、あるいはまた「食わない方が胃のためによく、安眠が出来るから」とか書いているかと思うと、またアリストテレスの書物を引用して、「豆は生殖器に似ているから、あるいはまた地獄の門のように、ひとりでつがい目が離れて開くから」ともある。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
