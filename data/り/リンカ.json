[
  {
    "uuid": "82e2480f-6f9a-518e-8f1e-f579642329dc",
    "entry": "隣家",
    "reading": {
      "primary": "りんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
