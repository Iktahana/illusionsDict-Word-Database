      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "neighbouring house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――窓の外一間の所には隣家相接して建ち在ることゝす。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我を厭ふ隣家寒夜に鍋を鳴らす　霜に更ける冬の夜、遅く更けた燈火の下で書き物などしているのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁｜一重の隣家で、夜通し鍋など洗っている音がしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我れを厭ふ」というので、平常隣家と仲の良くないことが解り、日常生活の背景がくっきりと浮き出している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを故意に漂母と言ったのは、一つはユーモラスのためであるが、一つは暗にその長屋住いで、蕪村が平常世話になってる、隣家の女房を意味するのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ霰が降って来たので、隣家の鍋にガラガラ鳴って当るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れを厭ふ隣家寒夜に鍋を鳴らす葱買ひて枯木の中を帰りけり易水に根深流るる寒さかな古寺やほうろく棄つる藪の中月天心貧しき町を通りけり　此等の俳句に現はれる、抒情味の本質は何だらうか。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば冬の寒夜に、隣家で鳴らす炊飯の鍋の音。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日経て後の夕方、荒物屋の座敷には隣家の誰れ彼れが大勢集まって酒を酌んでいた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、隣家の仕合せに對して乾盃を擧げるといふやうな博愛心に似たものを持つてゐるのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと片方は暗い二條通に接してゐる街角になつてゐるので、暗いのは當然であつたが、その隣家が寺町通りにある家にも拘らず暗かつたのが瞭然しない。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコはポール商会のまえで車がとまったとき、カリタに隣家のとざされた商店の買収のことを話していた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐敷に坐つたまゝ爲る事もなく茫然と外を眺めて居たが、ちらと僕の眼を遮つて直ぐ又隣家の軒先で隱れてしまつた者がある。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は頭を上げてちょっと見上げたが、其儘すぐ一軒｜置た隣家の二階に目を注いだ。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の二階というのは、見た処、極く軒の低い家で、下の屋根と上の屋根との間に、一間の中窓が窮屈そうに挾まっている、其窓先に軒がさも鬱陶しく垂れて、陰気な影を窓の障子に映じている。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三分もすると急に飛び上がって一文字に投げるように隣家の屋根をすれすれに越して見えなくなってしまった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の、観音開きの戸口からは、馬貫之の細君が、歯がすえるヴァイオリンのような歌を唄うのがひびいてきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鼠色の南兵に、出口をふさがれ、壁を破って隣家へ逃げ、支那服を借りて、通りかゝった洋車のあと押しをして、苦力に化けてのがれてきた男があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源作の嚊の、おきのは、隣家へ風呂を貰いに行ったり、念仏に参ったりすると、「お前とこの、子供は、まあ、中学校へやるんじゃないかいな。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家を外から伺うと、人声一つせず、ひっそりと静まりかえっていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくたつと、弟を背負って隣家へ遊びに行っていた祖母が帰ってきて、「まあ、京よ、風邪でも引いたんかいや。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと片方は暗い二条通に接している街角になっているので、暗いのは当然であったが、その隣家が寺町通にある家にもかかわらず暗かったのが瞭然しない。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の近くまで来ると、隣家の人が峻の顔を見た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳屋は浅間な住居、上框を背後にして、見通の四畳半の片端に、隣家で帳合をする番頭と同一あたりの、柱に凭れ、袖をば胸のあたりで引き合わせて、浴衣の袂を折返して、寝床の上に坐った膝に掻巻を懸けて居る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家に同年輩の娘子供はずいぶんないでもなかったのにこれらとはとにかく遊ばなかった。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月や太陽が三十メートルさきの隣家の屋根にのっかっている品物であったらそれはたしかに盆大である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喋舌らせようとする方が無理じゃ」「そこで今度は方角を変えて、近所｜隣家や出入りの者の噂から探りを入れてみると、あの斬られた娘のお熊と言うのは、実を言うと先妻の子で、今の母親とは継しい間柄じゃげな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪所の裏が百姓｜家で、牛のうなる声が往来まで聞こえる、酒屋の隣家が納豆売の老爺の住家で、毎朝早く納豆納豆と嗄声で呼んで都のほうへ向かって出かける。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュセッポの家で時ならぬ嵐が起って隣家の耳を※てさせる事も珍しくない。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが第三楽章の十二句になると、どうもだいぶ気が軽くなり行儀がくずれてはれた足を縁へ投げ出したり物ごとにだだくさになったり隣家とけんかをしたり雪舟の自慢をしたりあばたの小僧をいやがらせたり、どうもとかくスケルツォの気分が漂って来る場合が多いようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
