        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "◎リヒテンシュタインに木曜日に行ったら、五シル入場券をとると云ったのでかえって来た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヒテンシュタインの門前で自動車を降りると、加藤さんが山高帽をかぶって絵具箱を下げた半白のずんぐりした男と話して居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ Wien から十五分ばかりのところにリヒテンシュタインの居城があった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十四日　小雨　火　リヒテンシュタインを又見に行く。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヒテンシュタイン美術館でルーベンスの「毛皮をまとえる女」を見ただけでも、伸子としては忘られない感銘だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンのリヒテンシュタイン伯の画廊で見た毛皮外套の若い女の裸体は今も目にのこっています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
