  {
    "uuid": "9742793b-b51f-5484-9c9b-8069e3ea9e59",
    "entry": "りょ",
    "reading": {
      "primary": "りょ",
      "alternatives": [
        "り"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "understood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "跳ねて破れず、爪｜割いて掻き※らりょうか――愛。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら見い、叱らりょう。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はきりょうがわるいから、愛嬌だけでもよくなさい。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きりょうが良いの、しとやかだのと、聞いて居られないくらいに見え透いたお世辞をおっしゃって、まるで私が、先生の目上の者か何かみたいに馬鹿叮嚀な扱いをなさるのでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにお前さんのからだは大地の底に居たときから慢性りょくでい病にかかって大分軟化してますからね、どうも恢復の見込がありません。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにお前さんのからだは大地の底に居たときから慢性りょくでい病にかかって大分｜軟化してますからね、どうも恢復の見込がありません。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂はここで三度の食事をするではないか、これをいやいやながら食う自分は彼の竹馬の友といわりょうかと、そう思うと僕は思わず涙を呑んだのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "下は物置で、土間からすぐ梯子段が付いている、八畳一間ぎり、食事は運んで上げましょというのを、それには及ばないと、母屋に食べに行く、大概はみんなと一同に膳を並べて食うので、何を食べささりょうと頓着しない。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりと画いていると、実景があまりよくッて僕の手がいかにもまずいので、画いていながらまたもや変な気になって何というまずサだろう、これが画といわりょうかおれはとてもだめなのかしらん、と思うと画くのがいやになってもうよそうかもうよそうかと思いながらやっていた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか一度はあの頑固｜爺をへこましてくりょうと猪古才なことを考えていた。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいたしますからごえんりょなくおおせつけてくださいまし」と申し上げました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……近い処が、西河岸にござらっしゃる、ね、あの、目の前であったろうずりゃ、お地蔵様はどうお扱いなさりょうかと、つくづく思っていましたよ、はい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて国手の事を俺｜嗅ぎつけて知っとったで、お孝を威しつけてくりょうとな、前の夜さり、懐中に秘いておったですれども、顔を見ると、だらけて、はや、腑が抜けて、そのまんま、蒲団の下へ突込んで置いた、白鞘の短刀が転がって出たですが。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……邪魔だらば、縁の下へ突込まりょうで。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　（彼が言のままに、手、足、胴｜腹を打返して藁人形を翳し見る）血も滴りょう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……神職　御神、かけまくもかしこき、あやしき御神、このまま生命を召さりょうままよ、遊ばされました事すべて、正しき道でござりましょうか――榛貞臣、平に、平に。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顧みもせず島野は、己ほどのものが、へん、愚民にお言葉を遣わさりょうや！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一思いに捻り潰してくりょう。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金どんどうしてくりょうな。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あこがれ慕う心には、冥土の関を据えたとて、夜のあくるのも待たりょうか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人じみたと思わりょうが、決してそうでない。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と更に拝んで、「手足に五寸釘を打たりょうとても、かくまでの苦悩はございますまいぞ、お情じゃ、禁厭うて遣わされ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の身としてあらりょうか。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう姿が隠さりょう、光った天窓と、顱巻の茜色が月夜に消えるか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪が長けりゃ女じゃ、と合点して、さかりのついた犬同然、珠を頂いた御恩なぞも、新屋の姉えに、藪の前で、牡丹餅半分分けてもろうた了簡じゃで、のう、食物も下されば、お情も下さりょうぐらいに思うて、こびりついたでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋谷悪左衛門取次を致す、」　と高らかに云って、穏和に、「お逢い下さりょうか、いかが、」　と云った。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それだ、と門口で断らりょう、と亭主はその段含ませたそうな気の可い顔色。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた、見たいなら障子を開けやす……そのかわり、敵打たりょうと思うてな。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "待て、見えない両眼で、汝が身の程を明く見るよう、療治を一つしてくりょう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
