    "definitions": [
      {
        "index": 1,
        "gloss": "bass range (in Japanese music)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今年私ハ、小サイタライノオ風呂ニ二三日ゴトニ入リマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前日、新宿の百貨店へ行って結納のおきまりの品々一式を買い求め、帰りに本屋へ立寄って礼法全書を覗いて、結納の礼式、口上などを調べて、さて、当日は袴をはき、紋附羽織と白｜足袋は風呂敷に包んで持って家を出た。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はわけのわからぬ言葉を発して、携帯の風呂敷包を下駄箱の上に置き、素早くほどいて紋附羽織を取出し、着て来た黒い羽織と着換えたところまでは、まずまず大過なかったのであるが、それからが、いけなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮分別の深い結納のお使者は、ひどく酔いました、これは、ひどく酔いました、と言いながら、紋附羽織と白足袋をまた風呂敷に包んで持って、どうやら無事に、会津藩士の邸宅から脱れ出ることが出来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば語呂がよいだけの韻文なぞといふものがある。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く云へば語呂合せだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で語呂合せの大家が語呂の一寸拙い芸術の大家に云ふのだ、「君は語感をおろそかにする」なぞ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士の影に潛んで顏も上げず、蹲踞つて、風呂敷の包物を膝にかかへた儘、胸悸して居るのが不圖目を見張つて、壯侠の顏を偸視る、途端、その亦鋭い視線と出合つて、俯向と急に顏色を變へた。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな厭な時候に、ただ一つ嬉しいのは、心ゆくばかり降る雨の夕を、風呂に行く事である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦はいつもこの雨のふるのにお風呂ですかと聞くが、自分は雨が降るから出掛けるのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿から風呂屋までは一町に足らぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の女の顔は不思議な美しさに輝いて、涼しい眼の中に燃ゆるような光は自分の胸を射るかと思ったが、やがて縁側に手をついて、宜しくば風呂を御召しあそばせと云った時はもう平生のお房であった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてせっかく風呂に入って軽くなった心を腐らしてしまうのであった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降ると風呂に行く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事がすんでそこらを片付けるうち風呂がわいたから父上から順々にいってからだを清める。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂から出て奥の間へ行くと一同の着替えがそろえてある。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日影が縁へ半分ほど差しこんで顔がほて／＼するのは風呂に入ったせいであろう。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと二、三日風呂にも行かず夜更まで机へすがったきりでコツコツ何か書いたり読んだりする。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこういう時はちょっと風呂にでもはいって来ると全く生まれ変わったように常態に復する。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、せんだつて私のところから借りて行つたシメノンの探偵小説を風呂敷から出して、「うまいですね。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という寛濶な衣であろう、それをまた……おそらく、谷初まって以来であろう、燃えるような、紫の風呂敷に包ませて、出かける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰に括ってある紫の風呂敷が、揺れると、強烈な色彩の波動が、流水の震動と一つになって、寂しい谷が、ぱっとなる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう時刻だから、紫の風呂敷を開ける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の人が、セント・ジョルジ・ギルドの人たちのように、糸車を挽いて、木綿を手織って衣ているかどうかを知らないが、風呂の水も、雑用の水も、熔岩の下から湧く渓河から汲み上げて、富士の高根の雪解の水と雨水との恩恵の下に、等分に生きていることを思うと、富士の裾野の水々しさに、一倍の意義があると思われる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯場には吹き曝しであるにしても風呂が湧いていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂は晩酌と同じ程、彼等へ魅力を持っていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、見えたにしても、もう皆登り切って、風呂に急いでいる筈であった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪具箱へスケッチ板を一枚入れて、其れと座蒲團代りの古い布切れとを風呂敷で包み隱したのを抱へて市内電車で巣鴨迄行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雜木林の出つ鼻の落葉の上に風呂敷をしいて坐り込んで向ひの丘を寫し始めた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "跳ねて破れず、爪｜割いて掻き※らりょうか――愛。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
