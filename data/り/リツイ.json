    "definitions": [
      {
        "index": 1,
        "gloss": "standing position (working, sex, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
