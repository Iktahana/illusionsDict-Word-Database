      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on-the-spot investigation or inspection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちっとの間御辛抱なさい」　臨検の医博士はいまはじめてかく謂えり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は特に奮発して晩酌三合（いつもは二合）、いゝ気持で寝てゐるところを揺り起された、臨検だといふ、お役目御苦労、問はれるまゝに日本禅宗史を一席辯じて、おまはりさんと宿の人々を感心させた（と自惚れる）。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの帰ったときには、あたかも警察から係官が出張して臨検の最中でした。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察署長と地方裁判所の若い検事が書記を伴って、現場を臨検に来たのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら、彼はまだこういう現場へは臨検に来るべきでなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、裁判所の都合と、彼の好奇心と、事件がそれほど重大視すべき性質のものでなかったのとの、この三つの偶然が彼をここに臨検させたに過ぎないのであった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後に日光に着けば、判検事の臨検はもう済みて、磯貝の死体はその旅館に運ばれていたり。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、臨検の巡査にでも、咎められたら、何と返事をしたらいゝだろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると九分九厘まではあの家の中にその手紙はのこっているに相違ないし、家の中にのこっている以上は、おそかれ早かれ臨検の警官に見つかるにきまっている。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "お察しのとおり、死体をひきずってゆく時、畳の上へ血のあとがついたものですから、家へひきかえして雑巾をとって来て、すっかり血をふきとったつもりだったのですが、臨検の警官に発見されたのは天罰です。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨検の警官からの電話で、君の手袋の片一方が発見されたことが明瞭になっているのだ」　今村は、頭から尻へ、串でつきとおされたような気がした。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく臨検の一行が帰り、証人として浅野社長も召喚されて、予審廷が開かれたことは言うまでもないが、その内容は今のと大同小異だからここで発表する必要はなかろう。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨検の医師は、頭部を兇器で打たれて、そのために心臓麻痺を起して倒れたのだと言っているようだが、これは時間にすれば殆んど同時であるが、原因結果の順序は逆になっている。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ用事があって事務所へ来た社長が小使の屍体を発見して警視庁へしらせ、臨検の警官が、今村が運悪くその場へ落していった手袋を発見して、彼を有力な嫌疑者とにらんだのだ。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇　最後の対質訊問　臨検の検事は、以上の各容疑者を、最後に対質訊問したが、その訊問の要点は次のようなものであった。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なるべくおとなしくやろうぜ、君はどうも乱暴すぎるよ、いつかの臨検の時も……」「そんな古いことはよせ、とにかくはいってみよう」　まだ戸締まりがしてないと見えて、木戸はちょっと押すと以前のようにすぐ開きました。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査が現場へ到着してからは、下田は巡査と協力して、世にも珍しい氷った死人を見たさに、そばへ近づいてくる群集を制止して、本署からの警官の臨検をまっていた。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になつて、漸く長野から判事、検事、などが、警察官と一緒に遺つて来て臨検したが、その溺死した田池がいかにも狭く小さいので、いかに酔つたからとて、こんな所で独りで溺れるといふ訳は無い。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村荘六が事務所に備えつけていた最新式の短波通信機も当局の臨検にあい、もちろんのこと押収の議題にのぼったけれど、当時彼は既にもう某方面の仕事を命ぜられていたので、その方に必要なる道具であるとして幸いにも押収を免れた。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、臨検の巡査にでも、咎められたら、何と返事をしたらいゝだらう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原へ行く、しかもその朝行われた心中の臨検に行くというのですから、僕は場所に対する興味と、事件に対する興味とで、二重に興奮していたわけです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が臨検した主な目的は、相手の男を尋問して、無理心中ではなかったか、また、たとえ合意の心中であったにしろ、男の方に自殺｜幇助の事実がなかったかを確かめるためだったのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨検中は、私人が二階へ上るのを、一切禁じてあったのですが、もうすべてが終ったので、家人の上るのを許したのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音堂裏は、昔の不夜城の入口で、今僅かに玉ころがしや空気銃、夏向きには鮒釣りなどで、職人肌の兄貴連を引きつけて居るが、弦歌のひゞきぱたりと絶えて二三の曖昧宿に、臨検におびえながら出入りする白い首が闇にうごめくだけではたゞもう淋しさの上塗りをするだけである。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして考えてゆくにつれて、はじめて死体を臨検した時のことを思い出したのです。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れたけれど月があるので、バスで蘇葉居へいそぐ、折よく在宅、しばらく話したが、何となく身心が落ちつかないので、バスでまた駅まで引返し安宿に泊つた、歩いて飲んで寝た、夜中に臨検があつた。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十二日　十三日十二日の未明、臨検があっただけ。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "平時は中下屋敷附近に火災の起るごとに、火事｜装束を着けて馬に騎り、足軽数十人を随えて臨検した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
