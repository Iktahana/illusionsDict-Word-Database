[
  {
    "uuid": "a53ad72e-5257-52b6-b5ce-ba519749381f",
    "entry": "臨検",
    "reading": {
      "primary": "りんけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
