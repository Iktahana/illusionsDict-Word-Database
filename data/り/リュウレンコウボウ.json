    "definitions": [
      {
        "index": 1,
        "gloss": "spending all one's time in idle amusement away from home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
