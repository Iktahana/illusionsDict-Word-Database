[
  {
    "uuid": "d4471869-5d56-5ddf-b0df-391eede51b25",
    "entry": "俚言",
    "reading": {
      "primary": "りげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
