    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dialect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冠の「イソ」というのは俚言集覧には「額より頭上をおおう所を言う」とあるが、シンハリース語の isa は頭である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……学円　ははは、俚言にも、婦人に対して、貴女はいつ死ぬとは問うても可い。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし古言がやがて雅言で、今言がやがて俚言だとは私は感じない。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるを彼は俚言もて歌ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の音にぞ驚かれぬる、の誇張より、土用なかばに秋風ぞ吹くの正直な俚言がそのころどれだけ私には身にひゞいて聞えて來るであらう。",
              "citation": {
                "source": "樹木とその葉",
                "author": "夏を愛する言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って俚言土俗に関して他所風の雑らぬ古伝を受くるに最も恰好の人物だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーンの『ゼ・イヤー・ブック』一八六四年版一二六頁に、豕能く風を見るてふ俚言を載す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからダヴッドの牝豕ほどずぶ酔いてふ俚言が起ったと。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「押すなや、せぐなや、神楽場じゃないぞ」　こういう俚言が備後にはある。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俚言の無頓著は此事を指すに宜しきが如くである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、言海でも、辞林でも、言泉でも、稍古いところで雅言集覧、俚言集覧、倭訓栞あたりでも「口づけ」を接吻の義には取つてはゐない。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同類相集まる」といふ俚言を引いて、さうした事実を認めてゐる。",
              "citation": {
                "source": "社会的分業論",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫を殺せば七代祟ると俚言があるけれど、その猫を食べれば十代も、二十代も祟るかも知れません。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "『俚言集覧』に上総では嶺をヒヨという、タケガヒヨという高山がある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『俚言集覧』には甲州の笹子峠に矢立杉という名木あり、七｜抱半云々と見えている。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『俚言集覧』に志摩｜磯部村に矢立の茶屋あり、俚俗に日本の家の建て始めという。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は和名類聚鈔・新撰字鏡の類より、下は東雅・和訓栞・雅言集覽・俚言集覽等に至るまで、皆其時代に應じて撰述せられ、後の見るものをして略遺憾なからしむ。",
              "citation": {
                "source": "『辭林』緒言",
                "author": "金澤庄三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水を此国の俚言に水揚といふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁これを見ればまづ二三｜羽こゝにをりて己まづ求食、さて糞をのこして喰ある処の目とす、俚言にこれを雁の代見立といふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国の俚言にすべて物の凍るを、○ざい○しみる○いてなどいふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "北越雪譜初編巻之中　終北越雪譜初編　巻之下越後塩沢　　　鈴木牧之　　編撰江戸　　　　　京山人百樹　刪定○　渋海川さかべつたう　我国の俚言に蝶をべつたうといふ、渋海川のほとりにてはさかべつたうといふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜家峯の谷になりたる所を俚言にだぎといふ、だぎは春解するやねの雪のしたゝりみなこゝにつたふゆゑ、つらゝは簷よりも大也、下にさはりなき所は二丈もさがる事あり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「安蘇に無姓なし」という俚言の行われたのも、仕事ぎらいの無性者を指したのではなくて、家々の由緒や系図をほこる謂であった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイジ　　　　　　　　備前邑久郡サイジンコ　　　　　　美作｜苫田郡サジッポ　　　　　　　備中川上郡サシッポ　　　　　　　同　小田・浅口郡サジッポウ（イタドリ）出雲仁多郡『俚言集覧』の増補に、伊勢でも虎杖をサシッポというとあるが、それはいずれの村であり、また今も存するか否かを知らぬ。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体に色が灰白なので老人に見立てたものと、長くつやつやとしているので少年に擬した名と二通りあり、なお『本草啓蒙』や、『増補｜俚言集覧』によれば舞を舞う人の姿にたとえたものも元は多かった。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にとっての一つの啓示は、近年活字になった安原貞室の『かたこと』という京附近の俚言を集めた書に、穂を拾うてミョウにまゐらするというあの頃の諺が出ている。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分では何もしようとしないので、昨日小太郎がパパに連れられて、国境平の奥の方に放牧の牛を見に行ったのを機会に今日の午後までに、宿題の一つである（夏休みの一日）という綴方を作っておくように、指切りげんまんまでして約束した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "平三は十歳頃までは時々寝小便を外すことがあつたが、「寝小便げんざい、はりげんざい。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、すっかりげんきをとりかえしました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは、みち子ちゃんは、今よりげんきになっているでしょう。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
