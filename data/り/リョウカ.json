    "definitions": [
      {
        "index": 1,
        "gloss": "water chestnut flower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "那古に遊び、船形に遊び、洲崎に遊び、鷹ノ島に遊び、沖ノ島に遊び、手ぐり網の船をさへ放ちて、菱花灣上、到る處に我が遊蹤を印しけるが、取りわけて一つ我眼にとまれるものあり。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池野菊、八木錠一、鈴木菱花の徒と來ると一滴も口にすることが出來ないのだ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "跳ねて破れず、爪｜割いて掻き※らりょうか――愛。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂はここで三度の食事をするではないか、これをいやいやながら食う自分は彼の竹馬の友といわりょうかと、そう思うと僕は思わず涙を呑んだのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりと画いていると、実景があまりよくッて僕の手がいかにもまずいので、画いていながらまたもや変な気になって何というまずサだろう、これが画といわりょうかおれはとてもだめなのかしらん、と思うと画くのがいやになってもうよそうかもうよそうかと思いながらやっていた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……近い処が、西河岸にござらっしゃる、ね、あの、目の前であったろうずりゃ、お地蔵様はどうお扱いなさりょうかと、つくづく思っていましたよ、はい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あこがれ慕う心には、冥土の関を据えたとて、夜のあくるのも待たりょうか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の身としてあらりょうか。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋谷悪左衛門取次を致す、」　と高らかに云って、穏和に、「お逢い下さりょうか、いかが、」　と云った。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも当時、新しいお学問の力をもってお導き下さりょうか。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏造って魂入れずと言うこともあるからなあ』信徒一『そりゃわいどもより、御先祖孝行のお上人さまの方がどのくらいそれを望んで居らりょうか知れん。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、三十円使いこんだ顔が何で会わさりょうかと思った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、聞かさいで、おかりょうか。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬がどうして人に金の皿を餽るものか、犬が人に遣った物の代金を我が受けらりょうか、いかに貧すれば鈍するとて上帝に誓うて爪の端も汝よりは受けられぬ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "白粉嫌いの殿様が面倒な女房などを滅多に持たりょうかい。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高武蔵守の娘、高三河守の妹を、氏も系図もない若侍にむざむざと呉れてやらりょうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たとえばここへ敵が寄せかけたという時、病気じゃとて安閑と寝そべっていらりょうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幾百人、幾千人、とても数え尽くさりょうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧　さりとて、これが見ていらりょうか。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえで　それじゃと言うて不意のいくさに、姉様はなんとなさりょうか。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけても暮れても硫黄の煙りを噴くという怖ろしい鬼界ケ島、そのような処へお前をやらりょうか。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お師匠さまも昼夜の祈祷に、やがて精も根も尽き果てらりょうかと案じらるるほどじゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけても暮れても硫黄の煙りを噴くという怖ろしい鬼界ヶ島、そのような処へお前をやらりょうか。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ穴のむじなどもが安受け合いを、真にうけて帰らりょうか。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時お七はわろびれずに、いいえ、吉三さんに逢いたいばかりに、火をつけたらもし逢わりょうかと思うて、つけたのでございます、と言い放して心の中で泣いて居たに違いない。",
              "citation": {
                "source": "恋",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
