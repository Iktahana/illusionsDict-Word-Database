  {
    "uuid": "dc6a2055-ead8-521f-8d13-c09f2d479975",
    "entry": "立憲",
    "reading": {
      "primary": "りっけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
