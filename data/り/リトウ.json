      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secession from a political party",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
