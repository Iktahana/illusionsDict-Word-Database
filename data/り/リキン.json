[
  {
    "uuid": "63948a20-b23f-52c1-95c7-df124da8b2c2",
    "entry": "利金",
    "reading": {
      "primary": "りきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
