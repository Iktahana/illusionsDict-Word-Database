[
  {
    "uuid": "33421068-1d52-56f8-a55e-95a37a6d3b86",
    "entry": "略す",
    "reading": {
      "primary": "りゃくす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
