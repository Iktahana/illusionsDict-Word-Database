    "definitions": [
      {
        "index": 1,
        "gloss": "sumo wrestler",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土俵には、ライトを強くあててゐるらしく、力士の裸體は、赤土色に見えます。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "照國といふ力士は、上品な人柄のやうであります。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の五ツ島とかいふ力士の人柄には、あまり感心しませんでした。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五番を見ただけですから、自信を以ては言へませんけれど、力士の取組に、「武技」といふよりは、「藝技」のはうを、多く感じました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば敵手の身体の何処を捕えて何処に力を加えるが有効かという四十八手の裏表には数学者のひねり出した力学上の原理が籠っている、力士は知らず識らずこの原理を応用しているのだ。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に四十八手を分析したら槓杆の原理のみならずあらゆる力学上の原理の応用が見つかるに相違ない、例えば体量の少ない力士が大きい敵手にぶつかる場合には速度の大小でどれだけの効果があるかという事あるいは敵の運動量を利用して強敵を倒す事など物好きな学者の研究によって明らかになりそうな事である。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰府訪でし人帰りきての話に、かの女乞食に肖たるが襤褸着し、力士に伴いて鳥居のわきに袖乞いするを見しという。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばか、と言はれて、その二倍三倍の大聲發して、ばか、と叫び返せば、その大聲の力士あがりの勝ちになるのである。",
              "citation": {
                "source": "春夫と旅行できなかつた話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルネラは昔の力士の大砲を思い出させるような偉大な体躯となんとなく鈍重な表情の持ち主であり、ベーアはこれに比べると小さいが、鋼鉄のような弾性と剛性を備えた肉体全体に精悍で隼のような気魄のひらめきが見える。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか昔日の力士｜逆鉾を思い出させるものがある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方より、神官代理｜鹿見宅膳、小力士、小烏風呂助と、前後に村のもの五人ばかり、烏帽子、素袍、雑式、仕丁の扮装にて、一頭の真黒き大牛を率いて出づ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の手綱は、小力士これを取る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（力士に）な、天下の力士は侠客じゃ、男立と見受けました。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "力士｜真先に、一同ばらりと立懸る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土俵の真中で四つに組んで動かない力士は、外観上｜至極平和さうに見える。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝｜大に怒って力士に命じ、大銅缸を以て之を覆わしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも押す方にも押される方にも、力士と力士との双方に云うに云われぬ気味合が有るから、寒気も甚かったし天気も悪かったろうが、福島近傍の大森から、政宗領のはずれ、叛乱地の境近くに至るまでに十日もかかって居る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "力士が常人に卓絶した體力を得るに至るのも、決して先天的の約束ばかりで然るを得るのでは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "能く心を以て氣を率ゐ、氣を以て血を率ゐ、血を以て身を率ゐる男が、即ち卓絶した力士になるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様が黒人の力士を養って、退屈な時のなぐさみものにしているような図と甚だ似ていた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の主人の権八はもと三の井と云う力士で、一度は紀州家の抱えとなっていた大関角力であったが、其の比は故郷へ隠退して附近の壮佼に角力の手ほどきをしてやっていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その流れ物の中にも仰向きになって両足を水の中にした死骸があって、それは力士のようにぶくぶくと膨れあがっていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横綱はじめ力士一同人力車で挨拶まわりをすることになったが、横綱ひとり大き過ぎて合乗用の俥にも乗れず、といって俥なしの挨拶まわりも淋しいと考えた挙句、横綱の腰に太い紐をまわし、その紐を人力車二台にひかせて、横綱自身よいしょよいしょと練り歩いて、恰好をつけ、大阪じゅうを驚かせた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "取巻は河原崎座の作者岩井紫玉、同座附茶屋の主人武田屋馬平、品川の幇間富本｜登名太夫、同熨斗太夫、桜川善二坊、その他俳諧師｜牧乙芽、力士｜勢藤吾等であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（101）尋いで伊太利本土に力士一揆が起つた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "Padua の武藝指南所で遊戲に供する力士を奴隷の中から養成してゐたのが一揆の源になつて、智略ある Spartakus を首領に戴いたのである。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏、角力の巡業があり、横綱はじめ力士一同人力車で挨拶まわりをしたが、横綱ひとり大き過ぎて合乗用の俥にも乗れず、といって俥なしの挨拶まわりも淋しいと考えた挙句、横綱の腰に太い紐をまわし、その紐を人力車二台でひいて、よいしょよいしょとひき廻して練り歩き、大阪じゅうを驚かせた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き花かくてたづねて、日も知らず、また、夜も知らず、国あまた巡りありきしそのかみのわれや、わかうど。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは曾て怪しき媼フルヰアとさまよひありきし山を望みき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
