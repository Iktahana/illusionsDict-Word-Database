[
  {
    "uuid": "cb10e0ea-b783-5be4-8f8f-cfc74a399eff",
    "entry": "両院",
    "reading": {
      "primary": "りょういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
