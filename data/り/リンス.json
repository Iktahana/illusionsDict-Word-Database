    "definitions": [
      {
        "index": 1,
        "gloss": "(hair) conditioner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
