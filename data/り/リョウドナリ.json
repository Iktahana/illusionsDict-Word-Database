    "definitions": [
      {
        "index": 1,
        "gloss": "both sides (on the left and right)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
