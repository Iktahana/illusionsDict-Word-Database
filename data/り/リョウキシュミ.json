    "definitions": [
      {
        "index": 1,
        "gloss": "fascination with the bizarre",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
