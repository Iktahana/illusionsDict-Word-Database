[
  {
    "uuid": "97121ec9-df45-5026-8380-a15a396b252d",
    "entry": "糧食",
    "reading": {
      "primary": "りょうしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
