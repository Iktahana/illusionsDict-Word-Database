          "standard": [],
          "literary": [
            {
              "text": "が、それはとにかく――（上人の手紙は取意の事）東京の小県へこの来書の趣は、婦人が受辱、胎蔵の玻璃を粉砕して、汚血を猟色の墳墓に、たたき返したと思われぬでもない。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗三郎――耽奇の猟色に溺れた江島屋宗三郎は、翌る朝庭の池の中から、溺死体になって発見されました。",
              "citation": {
                "source": "猟色の果",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
