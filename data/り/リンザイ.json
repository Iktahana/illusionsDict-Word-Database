        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わからん奴には、ぶん殴ったって、こんりんざい判りっこないんだから。",
              "citation": {
                "source": "「晩年」に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんりんざい、だめだね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうここへはこんりんざいこないと正九郎は思った。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこんりんざい、だんななんぞに幽霊屋敷や化け物話を聞かせるこっちゃねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀家から何か苦情があるかもしれねえが、こんりんざい渡しちゃならねえぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかの理由でもしこのさいその石が不機嫌なときには途中で止まって、こんりんざい動かぬようになる。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一度結婚したが最後――ほんとにこれが最後――こんりんざい離婚は出来ない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩なぞはもうこんりんざい書くまい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これもだいじょうぶのこんりんざいです」「じゃ、とにかく、東のほうへいってようすをさぐろう」「親分、運転手の野郎はどうしましょう」　それは四本指の声である。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブタになったりしたら、まったく、」とアリスは真顔、「こんりんざいかまってあげなくてよ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうこんりんざいこんなとこには来なくってよ！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやだと言ったって、もう、こんりんざい、抜け出しては来れない。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、エリザベスはエリザベスで、こんりんざい、既往を忘れるものではなかった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、こんりんざい、蛾なんかを部屋に入れてやる気はない。",
              "citation": {
                "source": "非情な男",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同時に、その過去とはこんりんざい対面したくない気分で生きているのだ。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこんな腹をした男は、こんりんざい笞刑吏にはなれっこない、まったくなれっこありませんや」「こういう腹の笞刑吏だっていますよ」と、ちょうどバンドをゆるめていたウィレムが言い張った。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜十　こんりんざい、俺の方で悪い事はしたおぼえ無えです。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰った当座の父は「煙草だけはどうも廃められないが、酒だけは、これがいい機会だから、こんりんざい、もう廃める」と断言して、母を感激させ、母はうれし涙をながさぬばかり、その事をぼくらにまで何度も告げてよろこんでいたが、それが結局、つかの間だったわけである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんりんざいこの家を野呂だけに所有させてやるものか。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば誰それは――その、思想堅固な公民で国家有用の材といわれる誰それは、こんりんざい金なんか貸さんということが、前もってよくわかっている。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの、受け入れるものか、こんりんざい受け入れやしない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはこんりんざいできません！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとであの鎖を引きちぎろうとしたって、もうこんりんざいだめだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼自身も、わたしの傍を離れることなど、こんりんざい、承知しなかったに相違ない。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことはこんりんざいしませんよ！",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんりんざい、おばあさん家へは行くまいとするかのように、肩をゆすって一歩すさった。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そしてゲーテの方でもそのことを以後こんりんざい忘れはしなかった（39）。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしいな」「ご冗談を」「なにッ」「こんりんざい、当館はお譲りできません。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
