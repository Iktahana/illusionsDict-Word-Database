[
  {
    "uuid": "a4a3074b-b92c-5f96-8b93-17c0207c2965",
    "entry": "立秋",
    "reading": {
      "primary": "りっしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first day of autumn (approx. August 8)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八月八日、立秋と、暦を見るまでもなく、ああ、もう秋だな、と私は感ずるのである。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年八月　　立秋憂愁のこれや野の国、柑子だつ灰色のすゑ夕汽車の遠音もしづみ、信号柱のちさき燈淡々とみどりにうるむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年　立秋白秋古代新頌水上水上は思ふべきかな。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙も何もなくなつてゐて、初の一枚には立秋の句があつたのを記憶してゐる。",
              "citation": {
                "source": "俳句と云ふもの",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦の上では、きょうが立秋というのであるが、三日ほど降りつづいて晴れた後は、さらにカンカン天気が毎日つづいて、日向へ出たらば焦げてしまいそうな暑さである。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "立秋からもう十日も経っているのに、相変らず暑い。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "立秋柳河のたつたひとつの公園に秋が來た。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は立春立夏の間を限り、夏は立夏立秋の間を限り、秋は立秋立冬の間を限り、冬は立冬立春の間を限る。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日　晴、立秋。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝たら餅柳すずしくお地蔵さまのあたま撫でては八月九日　晴、立秋。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "立秋気分十分、旅をおもふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は立秋だつた、吹く風が秋をさゝやいてゐる、私も旅に出かけよう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日　曇―時々微雨、立秋。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "立秋、雲のない大空から涼しい風がふきおろす。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際に当りて春夏秋冬の限界については何らの規定する所なければ余は依然として立春立夏立秋立冬を以て四季の限界とする説に従ひ居るなり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "立秋（八月八日頃）後半月位は暑気強くして秋の感起らず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に東京の気候を以ていはんには立春も立夏も立秋も立冬も十五日宛繰り下げてかへつて善きかと思はるるなり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "立秋の頃に至って、遂に懿宗に上奏して、玄機を斬に処した。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宿福川駅、此日立秋。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "題の下に「此立秋前一夕」と註してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "録音集豊島与志雄　八月の中旬、立秋後、朝夕の微風にかすかな凉味が乗り初める頃、夜の明け方に、よく雨が降る。",
              "citation": {
                "source": "録音集",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「大阪毎日新聞」昭和五月）　　　新秋雑想　立秋という日が過ぎて、どれだけ私のパレットの色数に変化を来したか、それはまだはっきりとは現れない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、われわれ骨人はその立秋の変化にあたりて下痢を催し、骨人は断然百パーセントの骨へ近づく。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用で鰻を食べたかと思う間もなく立秋である。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「大阪朝日新聞」昭和五年七月）　　　立秋奈良風景　奈良、大和路風景は私にとっては古い馴染である。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く立秋を過ぎるとはっきりと目にこそ見えないが、雲の様子が狂い出し、空気は日々清透の度を加え、颱風が動き出す。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが立秋の時になりますと、この月からは牢獄の手入れをして、責め道具の修理もし、訴訟事件の受付を始める、そして秋の末、即ち舊暦の九月、十月にもなれば追々秋の末になりますから、裁判の處理はどしどし片付け、總て刑罰はこの秋に於いて執行する、殊に死罪の處刑は秋に行ふと云ふことが述べてあります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧水氏の「立秋雑記」は心持よくよまれた。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
