[
  {
    "uuid": "ea6e229b-2e32-588a-81af-dd8be52c9b58",
    "entry": "領する",
    "reading": {
      "primary": "りょうする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊"
      ],
