    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to own",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんな将校が占領するんだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら少ないとてケージは、やっぱし一ツ分占領するんだぞ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは私の足音が遠離ればまたわけの分らぬ陰濕な會話で靜寂を領するやうに思はれた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ全くわが五官の領する世界にはいないのだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "常にジャムを領するをもって、自家の光彩を発揮する紳士は、この名馬夕立に対して恐入らざるを得ないので、「おや、千破矢様、どうして貴方、」と渋面を造って頭を下げる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと言へば航海中船の動搖を感ずる事が比較的に少ない爲で、此室を占領する爲には虎鬚の獨逸人や、羅馬風の鼻の高い佛蘭西人等に隨分競爭者が澤山あつたが、幸にもネープルス市中で「富貴なる日本人。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と盛名隆々たる濱島武文の特別なる盡力があつたので、吾等は遂に此最上の船室を占領する事になつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時正四位下左近衛少将に任官し、十八万石を領するに至った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "江州日野五千石ばかりから取上って、今は日本｜無双の大国たる出羽奥州、藤原の秀衡や清原武衡の故地に踏みしかって、四十二万石の大禄を領するに至った氏郷がただ凝然と黙々として居る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷は此時も功が有ったので、前後勲功少からずとて七郡を加増せられ、百万石を領するに至った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に州を領するの間滅亡する者其数｜幾許なるを知らず、況んや存命の黎庶は、尽く将門の為に虜獲せらるゝ也。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」伏して昭穆を案ずるに、将門は已に栢原帝王五代之孫なり、たとひ永く半国を領するとも、豈非運と謂はんや。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ全く吾が五官の領する世界には居無いのだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北マラアストランド二十四番街、宏壯な五階建てのアパアトメント・ハウス、その三階の八室全部を領するシイドウ男爵家、程なくソオルが、そこの玄關に案内を乞ふと、暫くして戻つて來た若い小間使は、男爵が書齋で面會する旨を傳へた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳に人間生活の状態を観よ、蠢々※々として、何のおもしろみもなく、何のをかしみもなきに似たれど、其実は、個々特種の快楽を有し、人々異様の慰藉を領するなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鍵の手に當る四疊半が――家の代が代つた時までそこにゐた客を二階へ追ひやつて――義雄の占領するところとなつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふも醉つてゐれば、こちらも丁度醉ひが出てゐるところで、互ひに知り合ひの仲とて、入りまじつて、兩方の臺を占領することになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨り者のところへ若い女――それを平氣で承知するやうなら、渠自身にも占領することが出來ないものでもなからうと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八　部落民だ、部落民に相違ないと云ふ考へが、どうしたものか、お鳥に對する義雄の心を占領するやうになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、社会に活動しようとする男子の心を十分に占領するだけの手段または奮発（僕はこれを真に生きた愛情という）がないではないか？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の島の人間共が死絶えた（それはもう殆ど確定的な事實なのだ）後は、この影のやうな・砂の亡靈のやうな小蟹共が、此の島を領するのであらうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島の人間どもが死絶えた（それはもうほとんど確定的な事実なのだ）後は、この影のような・砂の亡霊のような小蟹どもが、この島を領するのであろうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一｜見栄が他のものとは全く御覧の通り違いますから……近頃ではどなた様も消費経済とかいう思召で却ってこのようなのが、エヘヘヘヘヘ」　とか何とか思い切って踏ん込めば、最後の「ネーアナタ」と「止むを得ぬ」とを同時に占領する事が出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、二枚落を指す場合、六五歩と下手が角道を通すか通さないかは、山崎合戦で、天王山を占領するか否か位の大事な手である。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元は、信長の為に一敗地にまみれたとは云え三大国を領するに至った丈にどこか統領の才ある武将であったが、子の氏真に至っては全く暗愚であると云ってよい。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本軍の先鋒青木大尉は、率先して進み、第一塁を陥れて勇躍更に坂を上るが、薩軍の弾丸は雨の様に降りそそぎ、午後の三時になっても占領する事が出来ないので退却した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "官軍にとって結局は失敗であったにしろ、今日まで十数日の間、兵火を浴せて猶陥ちなかったここを、この日の一撃でとにかく一度は占領する事の出来たのは、大成功であった。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十日、官軍いよいよ最後の総攻撃を決したが、連日の激戦にも拘らず、おしまいは案外容易に占領する事が出来た。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き手の知名度や人気を背景にして、大量に売れるものが書店の目に付く場所を占領する一方で、じっくりと売れていった優れた本が品切れのまま放置される。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから殉死者遺族が許されて焼香する、同時に御紋附｜上下、同｜時服を拝領する。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
