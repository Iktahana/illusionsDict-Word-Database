    "definitions": [
      {
        "index": 1,
        "gloss": "two guilty parties tried and punished together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
