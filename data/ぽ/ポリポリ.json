        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蟹田から青森まで、小さい蒸気船の屋根の上に、みすぼらしい服装で仰向に寝ころがり、小雨が降って来て濡れてもじっとしていて、蟹田の土産の蟹の脚をポリポリかじりながら、暗鬱な低い空を見上げていた時の、淋しさなどは忘れ難い。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美津子は虱を湧かしていてポリポリ頭をかいていたが、その手が吃驚するほど白かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁丹を口に入れて、ポリポリ噛みながら、化粧して、それから、ベッドへ行くだろう。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の踵がポリポリポリと砕けて脱け落ちそうな苦しみの中に、息も絶え絶えになって喘いだ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆は冷えてしまったお茶を啜り、ポリポリと煎餅を噛り出した。",
              "citation": {
                "source": "奇蹟",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして口淋しくなると、自分でポリポリ摘んで食べては、お庄に田舎の嫁の話などをして聞かせた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か小さな、その癖おそろしく素敏っこい昆虫めが、とても我慢が出来ないほどチクチクと彼の躯を螫すものだから、手を一杯にひろげて彼は螫された箇所をポリポリ掻きむしりながら、思わず、『えい、畜生ども、ノズドゥリョフの野郎と一緒に鬼にでも食われてしまやがれ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎豆をポリポリ噛って待っているところへ、顔色を変えて嬶さんが戻って来た。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、自分の部屋に這入るや否や、鞄を肩からおろして、叔母のくれる煎餅をポリポリと噛りながら、今か今かと祖母の呼んでくれるのを待つばかりであった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は沈黙ってポリポリ大根の塩漬を噛んでいたけれど、台所の方でも侘しそうに、コツコツ葱を刻み出しているようだった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の美しい機関士も、ビスケットをポリポリかみながら一寸覗いて通る。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上に腕を突出してポリポリと掻いているもの。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何だかポリポリ喰べている。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして膝の上に置いた小い鑵の中に手を入れてはポリポリ喰べている。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬骨の出た男は身体を引込めると、ドスンと腰をかけたが、独言のように、「ちょっ、とうとう鯛飯を買い損ねた」　と云って隣の老人を見たが、居睡りをしているので、彼は荒々しく南京豆の鑵に手を入れてポリポリ始めた。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと、折角わしが特使に立った甲斐がないというものだ」　金博士は、後向きに椅子に腰をかけて、西瓜の種をポリポリ齧っている。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで催眠薬を酒の肴にポリポリかじるという手を思いついたのはアッパレであるが、これは、どうしても田中でないと、できない。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを朝に五枚夕べに五枚、日に十枚ずつよオく睨んでからポリポリとたべる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポリポリポリポリとかじりながら願をかけると、よろずかなわぬものはないぞ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "関ヶ原の時、戦闘開始するや、秀秋の裏切りがハッキリするまで形勢全く彼に非で、金吾の奴にはかられたか、と蒼ざめて爪をポリポリかみつづけていたという。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庭さきのうららかな日光に眼をほそめて、あーアッ、と大きな欠伸とともに、白地に葵の地紋のある綸子の寝巻の袖を、二の腕までまくって、ポリポリ掻いた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　石田氏は褞袍の懐手を、大裟袈にうしろへまわし、動物園の猿のようにポリポリ背中を掻きながら、ものをいうたびに波のように揺れるぽってりとした賢夫人の口もとを、貧相な上眼づかいでジロジロとながめていたが、いうことがなくなったとみえて、詰まらなそうな顔で、むっつりと黙りこんでしまった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――スミは片手を廻して背をポリポリ掻いてゐる。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手を伸して肱をポリポリ掻き、眼を醒す）まだかえ、父う？",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　けゞんな顏をする手代達に迎へられて、「大師樣の歸り、ちよいと覗いて見ただけさ」　平次は事もなげですが、大師樣をだしに使ふのは擽つたいのか、八五郎はテレ隱しにポリポリ小鬢を掻いて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            }
          ]
        }
