    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese sword (usu. single-edged and curved)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、心で日本刀の味を知れ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三越に大概な物はあるが、日本刀とピストルがない」と何かの機会にたいへん興奮してＰ君が言った事がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　一本刀土俵入り　日本の時代ものの映画でおもしろいと思うものにはめったに出会わない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近ごろ見た「一本刀土俵入り」だけはたしかに退屈せず気持よく見られた。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本刀をきたえる気持ちで文を草している。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、今日こそやっちゃるぞ」　松次はこう云って急いで己の家へ帰り、床に置いてあった日本刀を持ちだして来て、かってを知った田村の二階へつかつかとあがってゆき、刀を抜くなり琢次と思われる者の首を斬り落した。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、刀剣｜鍛冶も、唐伝来の技術を多少受けたかも知れないが、早くも世界独得の日本刀を造り始めた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、部屋の隅には黒鞘の長身の日本刀が立てかけてあった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は不意に日本刀を抜いて、裁縫していた己の女房を殺して、それから店へ出て主人を殺し、そして、己もその刃に斃れたものであった。",
              "citation": {
                "source": "指環",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "放ねると同時に背の方にまわして持っていた日本刀を執った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床には刀架があって、広巳が記念の軍刀と日本刀が架けてあった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳は日本刀を引掴んで執り、すらりと脱きながら岡本の方を揮り向いた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に輝いて見える伊豆の山の白雲の蔭の海の色は山の根だけ日本刀の峰などに見る青みを宿し、片側の廣い部分にはさら／＼として細かな波を立て始めてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "或る日の晝餐",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その磨き澄ました日本刀のような寒風が揺するのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子はふと、父が若い時に何かに激昂すると、直ぐ日本刀を抜いて、ビュウビュウと、部屋の中で振り廻すのが癖だったと、亡き母から聞いたことを思い出した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして社會主義者と名乘つている不良青年組や、何ぞ言えば日本刀を振り廻すような連中のあることを吾々は耳にしている。",
              "citation": {
                "source": "中西氏に答う",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本刀のニオイ」の他に、注射針の感覚や麻酔薬のニオイにも打たれるであろう。",
              "citation": {
                "source": "『心理試験』を読む",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの人もみな洋服を着ていましたが、腰に白｜木綿の上帯を締めて、長い日本刀を携えているのがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）仮りに沖縄人に扇子の代りに日本刀を与え、朱子学の代りに陽明学を教えたとしたら、どうであったろう。",
              "citation": {
                "source": "進化論より見たる沖縄の廃藩置県",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは日本刀の切味を、うんと見せてやりますよ」　川上機関大尉は、早くもリット少将の悪企を察し、汽船ブルー・チャイナ号出帆の約二十分後、二人は夜の闇を利用してひそかに海中にすべりこみ、この大危難から免れたのである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵状を知らねば、斬りこみようもないではないか」　と、川上機関大尉は持っていた日本刀の柄を叩いた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日本刀は、大尉が一振、杉田が一振もっていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところで日本刀を手に入れたのは、不思議というほかはないが、実はこれにも神明の加護があったのである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は飛行島に潜入したときに近づきになった比島の志士カナモナ氏が数本の日本刀を持っているのを見て、無理にねだって、二本を譲りうけたものであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小暗い下甲板　川上機関大尉は、半裸体に、日本刀を背中に斜に負い、組立鉄骨をのぼっていった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本刀じゃないか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の眼は、ときどきちらりと足許に転がっている日本刀の方へうごいていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は下甲板の格闘で、強力無双の敵下士官のため、すでに手籠にあおうとしたが、幸いにも伸ばした右手が、甲板に転がっている日本刀にかかったので、苦もなく強敵を斃すことができ、そのまま血刀をひっさげて、リット少将を襲ったのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下の生命は、いま私の掌中にあるのですぞ」　といって、川上機関大尉は、血に染んだ日本刀を前に廻してきっと身構えた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、四条京阪の前まで来て、ゴーストップを待っていると、ぽんとうしろから肩を敲かれた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
