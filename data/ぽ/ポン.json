[
  {
    "uuid": "b28588b5-04b3-53d1-bb29-9850fda5374e",
    "entry": "ポン",
    "reading": {
      "primary": "ポン",
      "alternatives": [
        "ぽん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とこう言い切るとあなたのほうじゃ、すぐもうこっちをポンチにしているのだからな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなわんよ」「それは、君だって僕だってはじめからポンチなのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチにするのでもなければ、ポンチになるのでもない」「私は在る。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "云つてみれば、ポンプに於てバルヴは非常に大切だ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でその柄が折れてゐたら、ポンプは汲めぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもその證據は、子供たちの悦ぶ映畫が、常に忍術使ひの出るチヤンバラ劇と、奇々怪々の夢に充ちた漫畫映畫と、ポンチ的諧謔のチヤツプリンとに限られてゐる。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチ絵のクラインバーンにはきっと豚や家鶏が鉄路の上に遊んでいるように描いてある、その通りである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木魚の音のポン／＼たるを後に聞き朴歯の木履カラつかせて出で立つ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また降り出さぬ間と急いで谷中へ帰れば木魚の音またポン／＼／＼。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗惡のポンチ畫には、笑ひたくても笑へないが、小川芋錢の山水に噴き出すことがあるのと、同斷である。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡兎はポンと跳んで、すれずれに立つてゐる二本の白樺の間を摺り抜けた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば（ヒツ）（ポン）（ヒユ）（ポ）（スコ）（メ）（ノス）（モイ）（オ）（リユム）（ピ）（オス）（エ）（ガ）（ゲン）（ウ）（ラン）。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気の導体ですっかり包んだ中へは外からの電気作用が及ばぬというのは定則で、ある学者はこれを証するために自身で金網の中へはいり外から恐ろしい強い電気の火花をポンポン飛ばしたが中に居た先生には何の事もなかったという事である。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月七日『東京朝日新聞』）空中飛行の将来　フランスから英国まで海を超えて飛行する事の出来たものには一千ポンドの賞金を与えると申し出した人がある。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上流の方から、南のイギリス海岸のまん中で、みんなの一生けん命｜掘り取っているのを見ますと、こんどはそこは英国でなく、イタリヤのポンペイの火山灰の中のように思われるのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的のものでもゴルフの外に庭球野球｜蹴球籠球排球などがあり、今は流行らぬクリケット、クロケーから、室内用にはピンポン、ビリアードそれから例のコリントゲームまである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味で私は本当の漫画と低級なポンチあるいはくすぐり画とを区別したい。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者の実例は場末の玩具屋の店頭で見られる安絵本のポンチなどがそれである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パ行音は語頭には用いられない（パット、ポッポト、ポンポンのような擬声語は別である）。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず自分で五〇〇ポンド、当時の名誉総長デヴォンシャヤー公が五〇〇ポンド出した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の寄附を合計して一五〇〇ポンドを得た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の仕切りにはテプラーポンプや附属のマノメーターなどを置いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は営業上の事で警察へ呼ばれたが、出頭しなかったので五ポンドの罰金を取られた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチの漫画を見せたり、また Engineering 誌の器械の図を見せたり、また「ロンドンを見せてやる」と称して子供に股覗きをさせ、股の間から出した腕をつかまえて、ひっくら返す遊戯をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土を食う分量はもとより一定せぬが、オットマック土人は一日に半ポンドも食うという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その基本金の現額は十一万八千余ポンドで、そのうち四万ポンドは某富豪が金婚式の際に寄附したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
