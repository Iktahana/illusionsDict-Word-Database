[
  {
    "uuid": "c90aef22-219f-50ad-bc26-bc9a5d9003e5",
    "entry": "ポーン",
    "reading": {
      "primary": "ポーン",
      "alternatives": [
        "ぽーん",
        "ぽおん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a boing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フリアゲテ　ヰタ　イシコロヲ、ポーント　ムカウノ　キニ　ナゲツケテ、マタ　コヒツジヲ　フトコロニ　イレ、スイタ　オナカヲ　オサヘナガラ　一ツノ　ムラヘ　ヤツテ　キマシタ。",
              "citation": {
                "source": "ヌスビトト　コヒツヂ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どさくさまぎれで地に落ちて砂にまみれた食いかけの百匁がきを、久助君はポーンと川の中へけとばした。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と法衣の破目を潜らす如く、懐から抜いて、ポーンと投出す。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーン、ポーンとつぼを伏せる音がきこえるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ポーン、ポーンと隣のへやから、松長の子分たちのもてあそんでいるさえたつぼ音が聞こえました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてつぼを伏せるのかい」　ごろりと腹ばいになると、あざやかな手つきで、ガラガラポーンと伏せました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　聞き流しながら名人は、無心にガラガラポーンと伏せて、さえたそのつぼ音を無心に聞き入りながら、心気の澄んだその無心の中から何か思いつこうとでもするかのように、しきりともてあそびつづけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーンと伏せてあけると、コロコロところがって、ピョコンと賽が起き上がるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――はしなくも聞こえたのは、ガラガラポーンという伏せつぼの音ならで、悲鳴に近い女の叫びです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、上の方でポーンと云うんだ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中心を失って、スーッと横に傾くと、地響をたてて地上に仆れ、ポーンと粉々にこわれてしまった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝の上にのっていた将棋盤も、ポーンと宙にはねあがった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもうすっかり怯えてしまって、とうとう横手の窓をポーンと明けると、鏡を手文庫ごと窓外に放りだした。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ポーンと五十銭玉を一つ助手の手に抛りこんで、僕は車を捨てた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に、焼け落ちた棟木かなんかのために、手首だけが切断せされて、火の廻りの遅いところへポーンと飛んだということも考えられる。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスミの枕をポーンと蹴飛ばしてやりたくなって、ツカツカと傍へ寄ったが、途端にこれは卑怯だなと気がついて、辛うじて思い停った。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーン、と乾いた音がすると、ここからもその花火の煙りが眺められるのである。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原などで、ポーン、ポーンと、青い玉や赤い玉の出るお粗末な花火を上げるのも好きだし、門の凉台であげる線香花火も可愛いと思ふが、兩國の川開きだけは立派な上にも豪壯なのが好い。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこまりました」　女将は嬌笑しいしいイソイソとコック部屋へ引上げると間もなくポーンと瓦斯焜炉へ火の這入る音がした。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何回目かに、通りの方から玉島の家のある薄暗い横丁に這入って来た時に、友木の足にポーンと当ったものがあった。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『そんならやつてしまへ』と云つて、ポーンと毀してしまう。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんならやってしまえ」といって、ポーンと毀してしまう。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ追つて来たおくまは岩に片足をかけて狙を定めて引きがねを引くとズドーンとこだまして筒をはなれた弾丸は旅人の髪をかすつて向うの岩角にポーンと当りました。",
              "citation": {
                "source": "鰍沢雪の夜噺（小室山の御封、玉子酒、熊の膏薬）",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪之丞は、鉄扇を、ポーンと闇に投げて、その場に膝を突いた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……引っこ抜いてポーンと肩を撲ると、一人がゴロッと転がってしまい、もう一度ポーンと頭を撲るともう一人がゴロッと転がってしまい、もう一度ビーンと横面を張ると、三人目のお客さんがひっくり返ってしまった。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「と、ムラムラと変な奴が出て、斬ってかかったんでございますよ」「うむ、うむ、うむ、侍がね」「と、スポーンと斬ったんで。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
