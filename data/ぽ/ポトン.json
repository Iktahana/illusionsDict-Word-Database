        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブン蛙とベン蛙がくるりと外の方を向いて逃げようとしましたが、カン蛙がピタリと両方共とりついてしまひましたので二疋のふんばった足がぷるぷるっとけいれんし、そのつぎにはたうとう「ポトン、バチャン。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブン蛙とベン蛙がくるりと外の方を向いて逃げようとしましたが、カン蛙がピタリと両方共とりついてしまいましたので二疋のふんばった足がぷるぷるっとけいれんし、そのつぎにはとうとう「ポトン、バチャン。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、間もなく床の上にポトンと肉片の落ちる音がした。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村は、こう考えると、静かに椅子から立ち上って卓子の灰皿へ長くなった白い葉巻の灰をポトンと落した。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして親蠅がとりついている蜂蜜の上に、生長液をポトンと垂らした。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると娘の云ったとおり、机の上にポトンと蠅の死骸が一匹、落ちてきた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが空に通じたものと見え、上からなにか黒いものがポトンと落ちてきた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき皆のお経の声がひとしお耳許でグワッと波打って高まってきて、ポトンと絶えた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井からは鐘乳石のようなものが氷柱のように垂れ下り、その端からポトンポトンと水が滴っている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あすか山、毛虫になって嫌われる」という川柳があるが、池のマスもいやがるだろうと思ったが、試みにその針でからだを隠して、池へポトンと落としてみると、ガバーッと飛びついて釣れた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この感じ、餅に似ていますね」「そうですな」　医師はポトンポトンと背をたたいて答えた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、釣鐘をとかすから、見ててごらん」と鉱山の小父さんがいわれたので、じっとその方を見あげていると、大きな釣鐘をひっかけた起重機が、グーッと転炉の上まで動いて来て、まっ赤な焔をはいているその口の中へ、釣鐘をポトンとおとしこんだ。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かびくさい、ひやっとした土のにおいがして、上から、ポトン、ポトンと、つめたいしずくが、ふたりの首すじへたれてくるのです。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "メラメラ……と一｜花の紅蓮は、彼の手からポトンと地へ落ち、薄い一ひらの灰と化していた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
