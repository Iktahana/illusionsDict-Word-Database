        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして人が訪ねて來ると、時々その笛をポーポーと鳴らしながら、「こいつを吹いとると、人生の寂しさを忘れるわえ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オッペケペー、オッペケペッポーポー。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の森では、夜になると梟がポーポーと鳴いた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯のポーポーと云う声よりももっと低い様な調子で話しながらしげしげ四方を見廻した。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーポー湯気がたって、美味そうな匂いがする。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽笛がポーポーと鳴った。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟々、轢轆、プープー、ポーポー。",
              "citation": {
                "source": "聚樂廻り",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島県石川郡には、虎杖をテテポーポーという例があると報ぜられる。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "北秋田の扇田あたりから、鹿角郡にかけてはポーポーといっていた。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県北部などの、烏をポーポーと喚んでいる地方では、その藁製の飾り物をポッポカラといっている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
