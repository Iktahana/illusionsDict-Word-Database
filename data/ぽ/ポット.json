  {
    "uuid": "9abbd6a2-dca5-5a71-98d9-a26ecec551bf",
    "entry": "ぽっと",
    "reading": {
      "primary": "ぽっと",
      "alternatives": [
        "ポッと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slightly (blushing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後からも前からもぎりぎりに生活の現実に詰め寄られている、その間をぽっと外ずして気分を転換したい。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ったかと思うとぽっとあたりが青ぐらくなりました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇術が何とか座にかかっているのを見にゆこうかと言っていたのを、峻がぽっと出てしまったので騒いでいたのである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い稲田が一時にぽっと霞んだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかなラクシャンの第二子がすぐ釣り込まれてあわて出し顔いろをぽっとほてらせながら「おい兄貴、一｜吠えしようか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹の子供らもぽっぽっぽっとつづけて五六｜粒泡を吐きました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかなラクシャンの第二子がすぐ釣り込まれてあわて出し顔いろをぽっとほてらせながら「おい兄貴、一吠えしようか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの草穂のかげに小さな小さなつめくさの花が、青白くさびしそうにぽっと咲いていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）署長はぽっと夢のやうに考へた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がマントをフゥとやって通ったら火がぽっぽっと青くうごいてね、とうとう消えてしまったよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当を言ったら、僕なんかあなたに怒られたら生きているかいもないんですからね」「あらあら、そんなこと」軽便鉄道の木でつくったシグナレスは、まるで困ったというように肩をすぼめましたが、実はその少しうつむいた顔は、うれしさにぽっと白光を出していました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青い上着の園丁は独乙唐檜の茂みをくぐって消えて行き、それからぽっと陽も消えました。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の向こうの青い林のこっちにかすかな黄金いろがぽっと虹のようにのぼるのが見えました。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……処々巌蒼く、ぽっと薄紅く草が染まる。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄墨、鬱金、またその浅葱と言ったような、どの桜も、皆ぽっとりとして曇って、暗い紫を帯びていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後について、長襦袢するすると、伊達巻ばかりに羽織という、しどけない寝乱れ姿で、しかも湯上りの化粧の香が、月に脈うって、ぽっと霧へ移る。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの静な、ひとがらな、おっとりした、顔も下ぶくれで、一重瞼の、すっと涼しいのが、ぽっと湯に染まって、眉の優しい、容子のいい女で、色はただ雪をあざむく。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は思わずぽっとなった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の裾のぽっと明るいところは、菜の花畠であって、それにつづいて手前のほうに百坪ほどの空地が見える。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると青扇は、酔いですこし赤らんだ眼のほとりをいっそうぽっと赤くして、苦しそうに笑いだした。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんも僕と同じ様に、うれしく、ぽっとしてしまったのかしら。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、気持よく、ぽっと酔う。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして顔を挙げ、笑いをこらえているように、下唇を噛んで、ぽっと湯上りくらいに赤らんでいる顔を仰向けて、乱れた髪を掻きあげ、それから、急にまじめになって私のほうにまっすぐに向き直り、「安心してけせ。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト長火鉢のさしの向いに、結綿と円髷が、ぽっと映って、火箸が、よろよろとして、鉄瓶がぽっかり大きい。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ軒端を伝って、ちょろちょろ、まるで鼠のように、青白い焔が走って、のこぎりの歯の形で、三角の小さい焔が一列に並んでぽっと、ガス燈が灯るように軒端に灯って、それから、ふっと消える。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ杉野君は、東中野のアパートから上野の美術学校に通っていたのであるが、その同じアパートに私も住んでいて、廊下で顔を合わせる時があると、杉野君は、顔をぽっと赤くして、笑とも泣きべそともつかぬへんな表情を浮かべ、必ず小さい咳ばらいを一つするのである。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
