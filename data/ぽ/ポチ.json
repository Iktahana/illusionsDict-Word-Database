  {
    "uuid": "905258e7-28d1-57bf-9e7a-f2dbb63a0428",
    "entry": "ポチ",
    "reading": {
      "primary": "ポチ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lackey",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "壁の隅には昼の蛾がポチポチゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎのランナーは、みんな年が若かつたので、元気にまかせて、担いでゐるのが肥えの筈であることを忘れて、ポチャポチャやりながら駆け出し疾走し始めた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐よりも、ずっと背が高いのにせんだんの気の小さいポチポチ花。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチカレオへ赤い貨車が動く。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしかたなく、この犬を、ポチなどと呼んでいるのであるが、半年もともに住んでいながら、いまだに私は、このポチを、一家のものとは思えない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のそんな親切なもてなしも、内実は、犬に対する愛情からではなく、犬に対する先天的な憎悪と恐怖から発した老獪な駈け引きにすぎないのであるが、けれども私のおかげで、このポチは、毛並もととのい、どうやら一人まえの男の犬に成長することを得たのではないか。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ他人のふりをしようと早足に歩いてみても、ポチは私の傍を離れず、私の顔を振り仰ぎ振り仰ぎ、あとになり、さきになり、からみつくようにしてついてくるのだから、どうしたって二人は他人のようには見えまい。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチは足も短く、若年でありながら、喧嘩は相当強いようである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "前足でころころポチをおもちゃにして、本気につきあってくれなかったのでポチも命が助かった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチは、それからは眼に見えて、喧嘩を避けるようになった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はポチを愛してはいない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬同士の組打ちで終るべきものなら、まだしも、もし敵の犬が血迷って、ポチの主人の私に飛びかかってくるようなことがあったら、どうする。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、機会あるごとにポチに言い聞かせた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、おまえを好いてはいないんだ」　少し、ポチにもわかるらしいのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私の繰り返し繰り返し言った忠告が効を奏したのか、あるいは、かのシェパアドとの一戦にぶざまな惨敗を喫したせいか、ポチは、卑屈なほど柔弱な態度をとりはじめた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私といっしょに路を歩いて、他の犬がポチに吠えかけると、ポチは、「ああ、いやだ、いやだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの顔色ばかり伺っていやがる」「あなたが、あまり、へんにかまうからですよ」家内は、はじめからポチに無関心であった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯物など汚されたときはぶつぶつ言うが、あとはけろりとして、ポチポチと呼んで、めしを食わせたりなどしている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチは、もちろん、捨ててゆかれることになっていたのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「連れていったって、いいのに」家内は、やはりポチをあまり問題にしていない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "わからんかね」「でも、ちょっとポチが見えなくなると、ポチはどこへ行ったろう、どこへ行ったろう、と大騒ぎじゃないの」「いなくなると、いっそう薄気味が悪いからさ、僕に隠れて、ひそかに同志を糾合しているのかもわからない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、ポチを捨てたのではない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
