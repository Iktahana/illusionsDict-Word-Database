    "definitions": [
      {
        "index": 1,
        "gloss": "juice pressed from a bitter orange",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
