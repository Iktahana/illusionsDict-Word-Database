        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "草からは、もう雫の音がポタリポタリと聞えてきます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その杉には鳶色の実がなり立派な緑の枝さきからはすきとほったつめたい雨のしづくがポタリポタリと垂れました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして林は虔十の居た時の通り雨が降ってはすき徹る冷たい雫をみじかい草にポタリポタリと落しお日さまが輝いては新らしい奇麗な空気をさはやかにはき出すのでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草からは、もう雫の音がポタリポタリと聞えて来ます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草からは、もうしずくの音がポタリポタリと聞こえて来ます。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その杉には鳶色の実がなり立派な緑の枝さきからはすきとおったつめたい雨のしずくがポタリポタリと垂れました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして林は虔十の居た時の通り雨が降ってはすき徹る冷たい雫をみじかい草にポタリポタリと落しお日さまが輝いては新らしい奇麗な空気をさわやかにはき出すのでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半三郎様……」「ハイ……」「しっかりなされませ」〔以下原稿用紙で二枚分欠落〕　青くなったまま両手を突いて聞いていた半三郎は、そう言ううちにポタリと一雫、涙を両手の間に落した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやしのなかにふるきりの、　つぶはだんだん大きくなり、　いまはしずくがポタリ」　霧がツイツイツイツイ降ってきて、あちこちの木からポタリッポタリッと雫の音がきこえてきました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に何か吾輩の食指の中央にポタリと落ちた冷たいものがある。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また鼻から出たにしたところで、鼻先から一尺四、五寸も前へ突出した食指の上へ、豆粒程の大さだけポタリと落ちる道理はないのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻莨に点じて三分の一を吸うと、半三分の一を瞑目して黙想して過して、はっと心着いたように、火先を斜に目の前へ、ト翳しながら、熟と灰になるまで凝視めて、慌てて、ふッふッと吹落して、後を詰らなそうにポタリと棄てる……すぐその額を敲く。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、ろうが『ポタリ、ポタリ』と落ちるので、だれもすわる人がなかったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾を……妾をつけまわしていらしたんでしょう……」　ズバリとそう言ううちに彼女の大きな眼から珠のような涙がポタリポタリと落ちた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところがはずみに掛って振った拍子に、その芋虫をポタリと籠の目へ、落したから可笑い。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と姉さんがとけて流れて合うのじゃわいなと、きき入りながら、睫毛を長くうつむいて、ほろりとした時、こっらも思わず、つい、ほろり……いえさ、この面だからポタリと出ました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、熱いものがグッと押上げて来、あわてて手をやるひまもなく、大粒の涙が一つポタリと垂れた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが眼にも止まらない早さだったのでビックリして見ている中に、父のモジャモジャ頭の中から真赤な滴りがポタリポタリと糸を引いて畳の上に落ちて流れ拡がり初めた。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
