    "definitions": [
      {
        "index": 1,
        "gloss": "pole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ポール・カリグに手解されてゐたトレズニカ独り、良心を以てコルビエールを読んでゐたのである。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人株ではカナル線の発見者ゴールトシュタインや、ワールブルヒなどがおり、若手ではゲールケ、プリングスハイム、ポールなどもいた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　ポール・モーランの「カタロオニュの夜」の中に現われるルメジオスですか。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・ヴァレリーの『ユーパリノスあるいは建築家』のうちで、メガラ生れの建築家ユーパリノスは次のようにいっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・ヴァレリイは同韻の二つの言葉を双児の交わす微笑に譬えている。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから電車のポールの尖端から出る気味の悪い火花も、日本アルプスを照らす崇厳な稲妻の曾孫くらいのものに過ぎない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の窓から狂風に吹き飛ぶ雲を眺めながら考えるともなく二十年前に見たベルリンのメトロポール座のレビューを想い出していた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルダーショットからロンドンまで一時間二十四マイルの速度で飛行し、聖ポールの寺院を一まわりして今度は風に逆らって進んだが、あまり風が強かったから水晶宮の辺で地上に下った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間近い城東電車のポールが電力線にスパークする光なのだが、小初は眺めているうちに――そうさ、自分に関係のない歓楽ならさっさと一｜閃きに滅びてしまうがいい、と思った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へん、シンガポールから迎えのこぬうちにくたばっちまえ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」仏国ポール商会代理店　太田ミサコ　日比谷街　36と、記された花模様の名刺を太い手首に丸めこむと、かの女は豚のように空中に跳ねた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　イズモ町の太田ミサコ経営のポール流行品店では、早朝から商品窓のマネキンに黒山のような人だかりがしていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポール商会を太田ミサコの夫が事務服をつけて急がしそうに右往左往した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコはポール商会のまえで車がとまったとき、カリタに隣家のとざされた商店の買収のことを話していた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女の顔が廃艦のような色にかわると、ポール商会に金属的な悲鳴が聞こえた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミサコが堅固な意志をとりかえすと、ふたたびポール商会は、事務と秩序と美にたいする感覚をとりかえして、使傭人たちが忙しそうに饒舌り、お世辞と商才が火華のように顧客を魅了した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾があの土地を買収したのも、妾はこの土地にポール商会のビルデングを建てるつもりなのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール流行品商会の二階の美容室では、太田ミサコが弟子にからだ中に花粉をはたかせていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争を書いた最もいゝものは、「セバストポール」だ。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セバストポール」に書かれた戦争は、「戦争と平和」にかゝれた戦争よりも、真実味の程度に於て、純粋で、はるかにしのいでいる。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイのような古今無双の天才でも、自分が実際行ったセバストポールと、想像と調査が書いた「戦争と平和」に於ける戦争とには、段がついている。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セバストポール」には、本当にその場に行き合わしたものでなければ出せないものがある。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "士官の立場から物を見て書いたのでも、トルストイの「セバストポール」は、はるかに、清新に、戦争と状景が躍動して、恐ろしく深く印象に刻みつけられる。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、以上見て来たところのものを西欧の近代の戦争文学と比較するならば、トルストイの「セバストポール」や「戦争と平和」は勿論、ガルシンの「四日間」「兵卒イワノフの手記」「卑怯者」でも、またアンドレエフの「血笑記」でも、モウパッサンのへんぺんたる短篇の戦争を扱ったものでも、やはり遙かに上にある。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイは見習士官としてセバストポールの戦争に参加したが、ガルシンも露土戦争に参加した。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字軍や一九一四年の欧洲大戦のごときは世界人類の歴史の橋の袂であり、ポール・セザンヌと名づけられた一人の田舎爺は世界の美術史の上の橋の袂である。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンガポールやコロンボの暑さは、たしかに暑いには相違ないが、その暑さはいわば板についた暑さで、自然の風物も人間の生活もその暑さにぴったり調和しているので、暑さが美化され純化されている。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑な線で、発車するまでの間を、車掌がその辺の子供と巫山戯ていたり、ポールの向きを変えるのに子供達が引張らせてもらったりなどしている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
