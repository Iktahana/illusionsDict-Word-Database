        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その小さなちゃぶ台には、コーラやオレンジジュースの缶、ポテトチップスやポップコーンの袋がのっていて、あちこちから頻繁に手が伸ばされている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志の書置きに目を走らせるやいなや、ポップコーンをぶちまけるように、ワラは、ありとあらゆる単語を、ひとまとめにして慶一に投げつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑茶の葉にパフド・ライスとポップコーンとを加えて入れたお茶だ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二本目のやつに出てくるナタリー・ウッドは、わりあいにいい体をしていたし、サル・ミネオが画面にあらわれたなら売店までポップコーンを買いにいこうと考えていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、結局、ポップコーンどころではなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
