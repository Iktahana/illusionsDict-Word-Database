    "definitions": [
      {
        "index": 1,
        "gloss": "with a pat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "牡兎はポンと跳んで、すれずれに立つてゐる二本の白樺の間を摺り抜けた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の番頭から掏り取った紙入れを取り出し、中味を抜き取り、空の紙入れをポンと投げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ということを言いたげに呉は、安楽椅子に、ポンと落ちこんでチューインガムをしがんでいる深沢をチラと見て、にたにたと笑った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと煙管を払いて、（何、遠慮をしねえで浴びるほどやんなせえ、生命が危くなりゃ、薬を遣らあ、そのために私がついてるんだぜ、なあ姉さん。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と片手で小膝をポンと敲き、「飲みながらが可い、召飯りながら聴聞をなさい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高信さんが、銀貨を若干、先棒の掌へポンと握らせると、にこりと額をうつむけた処を、「いくら貰うたかい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その首を口にふくんで適当な圧力で吹くと底のガラスの薄板がポンという音を立ててその曲率を反転する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、元気を出せよ」　そうして竜の小さな肩を扇子でポンと叩いた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたな方の一等から九等までは、あしたおれがスポンと切って、こわいとこへ連れてってやるぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大三もしばらくは困って立ってゐましたが、やがてポンと手を叩いて云ひました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして狸はポンポコポンポンとはらつづみをうちました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと見送った猪口兵衛は何思うたか片膝をポンと打ちながら口吟んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　磯は黙って煙草をふかしていたが、煙管をポンと強く打いて、膳を引寄せ手盛で飯を食い初めた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵家の家従がパッとマグネシウムをたいてポンと写真を取ると、すぐに機関車がスクリーンにとび出してエンジンの音楽の始まるところの呼吸などはちょっと理屈なしにおもしろい。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は通らず、雨傘も威勢よくポンと轆轤を開いたのでは、羽目へ当って幅ったいので、湯の帰りにも半開、春雨｜捌きの玉川｜翳。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一度口へ出して、ピシリと遣られる、二度とは面は向けられまい、お鹿も今夜ぎりと思うと何となく胸が迫って卓子台の上が暗かった……」　お孝はポンと楊枝をくべた、すうッと帯を揺って焦れったそうに、「ちょいと、まあ、待って頂戴よ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト木彫のあの、和蘭陀靴は、スポンと裏を見せて引顛返る。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "函に載せると、ポンと飛出しさうであるから遠慮した。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と壁の中に、爽な少い聲して、潛り門がキイと開くと、蝶のやうに飜然と出て、ポンと卷莨の灰を落す。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたな方の一等から九等までは、あしたおれがスポンと切つて、こはいとこへ連れてつてやるぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『よし、さあでは引きあげ、おい誰でもおれたちがこの車を出ないうちに一寸でも動いたやつは胸にスポンと穴をあけるから、さう思へ』　その連中はぢりぢりとあと退りして出て行きました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして桃いろの封筒へ入れて、岩手｜郡西根山、山男｜殿と上書きをして、三｜銭の切手をはって、スポンと郵便函へ投げ込みました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち空で白いけむりが起り、ポンポンと音が下って来それから青い柳のけむりが垂れ、その間を燕の形の黒いものが、ぐるぐる縫って進みました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は私の問を終まで言はせず、ポンと禿頭を叩いて、『オヽ、濱島さん※　よく存じて居ますよ、雇人が一千｜人もあつて、支店の數も十の指――ホー、其お宅ですか、それは斯う行つて、あゝ行つて。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、私がキツパリと答へると、彼はポンと膝を叩いて『やあ、奇妙々々。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』大佐はポンと掌を叩いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　　　第十七回　冐險鐵車自動の器械――斬頭刄形の鉞――ポンと小胸を叩いた――威張れません――君が代の國歌――いざ、帝國の萬歳を唱へませう『其處が、奇々妙々の發明だよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とポンと小胸を叩いて『此樣な工夫をやるのだもの、此武村新八だつてあんまり馬鹿にはなりますまい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と武村兵曹は口をむくつかせたが、忽ちポンと掌を叩いて『おゝ、それも左樣だ、私の考通りにも行かないな、之から糧食を積入れたり、飮料水の用意をしたりして居ると、矢張出發は明朝になるわい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と態と元氣よく、犬の首輪をポンと叩いて『これ、稻妻、しつかりやれよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
