    },
    "definitions": [
      {
        "index": 1,
        "gloss": "porch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かの女は、潜り門に近い洋館のポーチに片肘を凭せて、そのままむす子にかかわる問題を反芻する切ない楽しみに浸り込んだ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレンのポーチとか、ロザリのアーチとか。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "優等生型の身辺事情には、いろいろ順序が立っているでしょうからねえ」「からかわれる張り合いもないような事なんです」　規矩男の家は松林を両袖にして、まるで芝居の書割のように、真中の道を突き当った正面にポーチが見え、蔦に覆われた古い洋館である。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一つの琺瑯質の壁に蔦の蔓が張り付いている三階建の、多少住み古した跡はあるが、間に合せ建ではないそのポーチに小さく貸間ありと紙札が貼ってあった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーチから奥へ抜けている少し勾配のある通路の突き当りに水も覗いていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五段の石段を上ると玉石を敷き詰めた広場があり、蘇鉄の植込を前に控えてポーチの玄関という洋館でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻｜暖簾を狭く垂らして、二階に若い男女の笑い声の聞えるお好み焼屋や、粋なそばやと見えながら洋風の窓やポーチを取付けてあるので看板を調べてみると、それは茶房。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は赤瓦の洋館で、ポーチの上には郁子の棚が日陰を作つてゐた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れに沿うた裏口のポーチも板張りの平面で、それに二、三段の無造作な周辺、水ぎわの緑の草、盛りの紅葵、あるいは向日葵、様々の夏草の花壇、柳の根といった風である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ポーチの脇に、兄妹の緑と赤との愛らしい自転車が置いてあった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "金雀児の生垣に挟まれた表現派風の可愛いポーチには、奇妙に大きなカイゼル髭を生した一人の警官が物々しく頑張っていたが、大月が名刺を示して夫人から依頼されている旨を知らせると、急に態度を柔げ、大月の早速の問に対して、岸田直介の急死はこの先の断崖から真逆様に突墜された他殺である事。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーチで靴をぬいで、カーテンをあけてみると、みさをはベッドの上に仰向けに寝ていました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ長｜襦袢をひっかけたまま、細紐もむすばずに扉をあけてくれて、私がポーチで靴をぬいでいるまに、すぐベッドへひきかえして、裸のままでベッドの中へもぐりこんでしまいました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "車がホテルのポーチに着くと、二人はほとんどすれすれに並んでホールへはいっていった。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀灰色の猫の児は今日も私のポーチで居睡っているだろう。",
              "citation": {
                "source": "追慕",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーチに、棕梠の植木鉢が並べてある。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸に近づきながらチチコフは、入口のポーチの上に他ならぬ主人の姿を見つけた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蓋馬車がポーチに近づくにつれて彼の眼はだんだん嬉しそうになり、相好が次第に崩れて行った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "時おり彼はポーチの上から庭や池を眺めながら、ひとつ地下道をつくって家から真直ぐに行かれるようにしたらいいとか、池の上に石橋を架けて、その両側に屋台店をひらき、そこへ商人を坐らせて、百姓に入用な細々した雑貨でも売らせるようにしたら素敵だなどと言ったりする。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、一同がもうポーチへ出た時、マニーロフが言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニーロフは長いことポーチに突っ立ったまま、だんだん遠ざかってゆく半蓋馬車を見送っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーチへまた一人、前のよりは少し若いけれど、大変よく似た女があらわれた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女主人は、さっき灯りを持ってポーチへ出てきた女の方を向いて言ったが、その女は早くもそこへ羽根蒲団を運びこんで、両脇をパタパタ敲きながら、部屋じゅうに濛々と和毛をたちあがらせていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう女主人は二人がポーチへ出た時に言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女地主は、ポーチの近くに立っていた十一ぐらいの女の子に向って声をかけた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い木の階段を這うようにして、広いポーチへ上ると、出会頭にギーッと扉が開いて、絞染更紗の着物をきた、肥った婆さんが顔を出すなり、『こちらへ、どうぞ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この間に三台の馬車はもうノズドゥリョフ家のポーチの前へ横づけになった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "セリファンは合図のあり次第、馬車をポーチへ寄せようと待ち構えているらしい。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーチへ馬車を乗りつけながら、チチコフは、殆んど同時にちらと二つの顔が窓から覗いたのに気がついた――頭巾帽をかぶった、胡瓜のように細長い女の顔と、モルダヴィヤ南瓜のようにずんぐりした男の顔とだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
