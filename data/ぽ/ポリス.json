    },
    "definitions": [
      {
        "index": 1,
        "gloss": "police",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば「メトロポリス」に現われる器械などは幼稚で愚鈍で、無意味というよりは不愉快である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い映画では「メトロポリス」に現われた機械のばからしさなどが代表的である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その像を刻める塔、埃及なるヂオスポリスに立てり、日出日沒ごとに鳴るといひ傳ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰はコンスタンチノポリスにさへ降りしなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "近き年の破裂の時も、我等拿破里人は傘さして行きしが、均しく灰降るといふも、拿破里に降るとコンスタンチノポリスに降るとは殊なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはダンドロのコンスタンチノポリス征服とマルクス寺の銅馬とを題として即興の詩を歌ひ、會員證を授與けられたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二百三年コンスタンチノポリスを征服す。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもの思いは、彼のほんの些細な動作にまでしみわたり、――彼のふざけている時にも現われ、――ペーセポリス18の神殿のぐるりの蛇腹にあるにやにや笑っている仮面の眼からのたくり出ている毒蛇のように――彼の快活さの閃きにさえも織り込まれているのだった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸映画「メトロポリス」には、ブリギッテ・ヘルム扮するところの可憐なるロボットが製造せられるが、こんな美しいロボットは実在しない。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの映画が、東京の邦楽座に出たとき、築地小劇場の連中が、「メトロポリス」の実演をやった。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午ごろに、メトロポリスという大きなホテルの入口で、写真を撮って貰っているとき、そこへまたひょっこりジイドが現れた。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしギリシヤのポリス的世界の時代においては、未だ真の個人的自覚というものはなかった。",
              "citation": {
                "source": "デカルト哲学について",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるばるも帰り来しものかな――やがて亜細亜のメトロポリスへ、汽車は走り込むのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、じっさい十五世紀の眼抜きの場所はこうであったに相違ないと思われるほど、クエイントな商店街の形式をそなえているんだから、十五世紀のメトロポリス！",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "白系移民の本屋「ペトロポリス」が、よろこんで直ぐ出版した。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからインデアナ州へ流れ込んで、インデアナポリスでガンネスと言う男と結婚し、ここにベル・ガンネス夫人と名乗ることになった訳だが、漸てホッシュという情夫が出来て、一夜、このホッシュと共謀の上、熟睡中の良人ガンネスを斧で一撃の下に殺し、暫らくホッシュと何ごともなく同棲生活が続いている。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番兵の前からポリスというものがあって、これが邏卒となり、巡邏となり、巡査となったので、初めはポリスって原語で呼んでいた訳ですな。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポリスが出来るまでは、江戸中は無警察のようでした。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩人の心にはアクロポリスやゴルゴタの外にアラビアの薔薇さへ花をひらいてゐた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では、テア・フォン・ハルボウ女史のメトロポリスなぞが、そうである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "オストロゴートの王テオダトゥスの爲にユスティニアヌスと和を謀らんとてコンスタンティノポリスに赴き、かしこに死す、その間彼は皇帝に説きて異端者を罰せしめきと傳へらる一九―二一〔信ずる所〕キリストにおける神人の兩性〔一切の矛盾〕肯定眞なれば否定僞りに、否定眞なれば肯定僞りなり。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の三一を否定せる三世紀の異端者（アフリカのペンタポリスに生る）〔アルリオ〕アリウス。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラクーザにもネアポリスの丘の上に大きな円形劇場が遺っているが、タオルミーナにも町の北東の高台（海抜二一三米）に見事な円形劇場が遺っている。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東は海で、西は山で、その山の、すぐ目の前にはタオルミーナの古い町がバナナの果実のように断崖の上にかたまり合って、古代の城壁で囲まれ、その一番高い所（三九六米）にアクロポリスと呼ばれた城砦があり、その後の高い所（六三四米）にモラの城砦があり、更にその後にモンテ・ヴェネレの奇峰（八六四米）が聳えている。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三角岳メトロポリス　それ以来、Ｘ号の乱行は、まったく見られなくなった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは、三角岳のメトロポリスです。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この三角岳メトロポリスには、われわれ木のほかに、昆虫、鳥、小さい獣、石などにも、人間と同じように考えたり、お話をうけたまわったり、ご返事できる者が、たくさんいるのですよ」「ふしぎだ。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、もっともっとこの三角岳メトロポリスをべんりな世界にしたいと思って、さらにいろいろと研究と工夫を進めているのだった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいおかしいとは思っていたのですが、何しろこのあたりは、メトロポリスとかいう化物地帯で、木が物をいいだしたり、石や机がひとりで動きだしたり、あまり気味がよくないので、警官もこわがって、やって来るのを二の足ふんでいたんです。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
