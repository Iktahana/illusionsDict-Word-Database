        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夏目先生が帰ってからすぐに筆をとってこの端書をかき、そうして、おそらくすぐに令妹律子さんに渡してポストに入れさせたのではないかとも想像される。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、實家のポストには投入しかねた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私自身も郵便を投函する必要のあるとき自動車の運転手に「郵便函があったら留めてくれ」といおうか「ポストがあったらストップしてくれ」といおうか、どっちがよくわかるだろうかと咄嗟に迷うことがある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ辻の赤いポストも美しく、煙草屋の店にいる娘さえも、杏のように明るくて可憐であった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものように、四ツ辻にポストが立って、煙草屋には胃病の娘が坐っている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも町の南はずれにあるポストが、反対の入口である北に見えた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の愛情、赤いポストにするまで。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋にかえるとアダは体操を開始してポスト孔から大洋に向って胸の悪気流を吐き出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏ教授はしかし「これはよくあるポストモルテムの現象ですよ」と言い捨てて、平気でそろそろ手術に取りかかった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに赤いポストが見える。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、この道をまっすぐに歩いていって、三つ目のポストのところでキスしよう」　女は、からだを固くした。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストにマッチの火を投げ入れて、ポストの中の郵便物を燃やして喜んでいた男があった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日、毎日、あちこちのポストの中の郵便物を焼いて歩いた。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十四日　ペンで細字で考え考え書いてしまったのを懐にして表のポストに入れに出た。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木橋の、埃りは終日、沈黙し、ポストは終日｜赫々と、風車を付けた乳母車、いつも街上に停つてゐた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日で云えば、この木魚は郵便ポストのようなもので、誰もいない時は此のポストへ結び文を押し込んで置いて、なにかの打ち合わせをする約束になっていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその木魚のポストを誰が明けるか判らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "改作・からりと晴れたる法衣で出かける　　　追加二句　みんな寝てしまつてゐるポストのかげがはつきり　見おくるかげは見えない松むし鈴むし（樹明君に）　八月十五日晴、宿酔ほがらかである、昨夜、最後の一片まで賞味した鮒のあらひのうまさがまだ残つてゐる！",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物と見せかけたのは、郵便ポスト――だったじゃありませんか。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にははっとするほど自分を腑効なく感じ、いっそ満洲へでも飛び出してみようかと考えることもあったが、あの辺にも同窓の偉いのが重要ポストに納まっていたりして、何をするにも方嚮が解らず、自信を持てず、いざとなると才能の乏しさに怯けるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして横の暗がりに在る赤いポストの上に手をかけた。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、そのポストに手をかけた瞬間であった。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのポストの生冷たさが熱鉄のように彼の掌に感ぜられると同時に、彼は或る素晴らしいヒントを得たのであった。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それと一緒に、今の今まで、あたたかい親切な人間とばかり見えていた叔父が、急に鉄のポストみたいに冷たい態度にかわって、傲然と私を睨み下しているのに気が付いて、又もビックリさせられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストノ　ウエニ　トマツテ　ヰタ　スズメガ、「アレハ　ワタシノ　カゲダワ」ト　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クツ　クツ　クツ」ト　ポストハ　ワラヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソウレ　ゴラン、オマエサンノ　カゲデ　ナイ　シヨウコニ、オマエサンガ　トンデモ、アノ　カゲハ　ウゴカナイデハ　ナイカ」ト　ポストハ　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
