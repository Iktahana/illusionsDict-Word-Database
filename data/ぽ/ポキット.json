          "literary": [
            {
              "text": "そのとき、ポキッと脚を折ったのです。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストは、アシかなにかのように、まんなかから、ポキッと折れてしまいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、大きいりっぱな木が、メリメリポキッと、恐ろしい音をたてて、地べたにたおれるんですからね。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその日、一陣の狂風が吹いて、中軍の牙旗がポキッと折れた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
