        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "壁の隅には昼の蛾がポチポチゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐よりも、ずっと背が高いのにせんだんの気の小さいポチポチ花。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯物など汚されたときはぶつぶつ言うが、あとはけろりとして、ポチポチと呼んで、めしを食わせたりなどしている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このナイフがわるいのだ」　と子供は言ってナイフを磨いでコシコシ削りましたが、やっぱりポチポチと黒いシンが折れます。",
              "citation": {
                "source": "鉛筆のシン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察のそばの道に沿った汚ない溝には白い小さい花がポチポチ咲いて、さびた水に夢見るような赤いねむの花がかすかにうつった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝起きて行つて薦を取り去り、明るい若草色の芽が、一せいに地上にポチポチ頭をもたげて來てゐるのを見た時には、駿介は思はず歡喜の聲を發した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々上の桟敷で茶をこぼす、それが板の隙間から漏りて下に寝て居る人の頭の辺へポチポチと落ちて来る、下の人が大きな声で、何かこぼれますよ、と怒ったようにいう、上の人が、アアそうですか失敬失敬、などという。",
              "citation": {
                "source": "病",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻広島へ着く頃になると、雨がポチポチ降りだした。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の罪も無い、ただお金をポチポチ溜めて、お神さんを養生させるだけが楽しみといったような仏性のお爺さんが、怨みも何も無い、思いがけない人間から、思いがけない非道い殺され方をしたんだからね。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞして気を鎮めたいものだと思って欲しくもない枝豆をポチポチ食べながら今度の病気の原因を話し合ったりした。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると右の手先からポチポチ血がしたたって、雪の上に散ってゆく、私は今まで、頸に巻いていた手拭――高野君が物好きに、わざわざ小包で伯林まで贈ってよこした、幸四郎の手拭を破って、取り敢えず繃帯をしてやったが、血を拭くと肉が破れて骨が白く表われている。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雨は降っていないと心得て表に出ると、ポチポチと落ちている事がある。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、あなたもポチポチの組ですか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨吉は男つ振りは好いけれど、あつしとポチポチで、まるつ切りの徳利だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上あの邊は渫つたばかりで自棄に深いから危ふく溺れかけたところを――」「お話中だがネ、八、あつしとポチポチといふのは、泳ぎの出來ないことがポチポチなのか、それとも、男つ振りの好いところがポチポチなのか、それをはつきりさせねえと、お調がつかねえ」「あれ、負けて置いて下さいよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土が雨に流されて、幾条も縞の出来た所には蹴返されて泥まびれになった木の切株と、ふやけた片方の草履がころがり、地上から三四尺隔っている死人の裾から落ちる雫で、下にはポチポチと丸い小さい穴が沢山出来ている。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他にこまかいものが少々あるがそれは五百円ばかりで片がつき、十分ポチポチやってゆく自信がおありの由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はサッカレの「虚栄の市」をポチポチよんで第四巻までの終り。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際問題としては、目下の吾々の生活は銀行相手の赤字生活ですから、今年の末頃にはポチポチ仕事が出来ないと、閉口です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチポチと短い文章を書き、詩のような物も書き、それがやがて一冊の本にでもなるだけの収穫があれば、こんな時期も私は怠惰ではなかったと云うものでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも筆舌的なものと、文学的なものと、どっちにもポチポチつきですが、旧い文学の領内では全く背中一重なのが実際ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い石垣には、苔の花がポチポチ見え、土塀のうえの梢は黄昏れかけていて、邸のうちから燈火がもれている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも其処此処と、ポチポチ灯りの影は見えるが、近づいて見ると、それは皆、木挽や石工の寝小屋だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "町通りにポチポチ灯の色が見え初めた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
