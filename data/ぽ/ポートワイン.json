        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遊覧客や病人の眼に触れ過ぎて甘ったるいポートワインのようになってしまった海ではない。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートワインとか、白酒とか、甘味のある酒でなければ飲めなかった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へべれけに酔っぱらった大そう年をとり過ぎた踊子が、私の傍へ来て、ポートワインをねだるので、振舞ってやると、やがて彼女は、ダンス位出来なくては可哀相だから、教えてやると云って、私の両手を掴んで立ち上がるのであった。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶匙に砂糖一ぱい、ポートワイン三分の一。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下もやがて四十で、弁護士になることは内心諦めているらしく、彼の売る一本二銭の焼鳥は、ねぎ八分で、もつが二分、酒、ポートワイン、泡盛、ウイスキーなどどこの屋台よりも薄かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下もやがて四十で、弁護士になることは内心諦めているらしく、彼の売る一本二銭の焼鳥は、ねぎが八分で、もつが二分、酒、ポートワイン、泡盛、ウイスキーなどどこの屋台よりも薄かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くからいわゆるポートワインの輸出港として知られている。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、馬酔木さんを訪ねてポートワインをよばれる、それから彼女を訪ねる、今夜は珍らしく御気嫌がよろしい、裏でしよんぼり新聞を読んでゐると、地震だ、かなりひどかつたが、地震では関東大震災の卒業生だから驚かない、それがいゝ事かわるい事かは第二の問題として。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　常子は枕元にあつたポートワインをグラス二ツにつぎ、白井の飲むのを見て、自分も一口、そして敷蒲団の下から懐紙を出して口の端をふく。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪くなった毎年何千樽ものりんご酒が田舎から偽物のポートワインに変換するために運んで来られる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリティッシュ・ポートを作るには―――「…イギリスのブドー酒または良質のリンゴ酒を４ガロン、レッド・ビート・ルート（赤カブ）のジュースを２クォート、ブランディを２クォート、ロッグウッドを４オンス、砕いたラタニア根（ポートワインの着色料）の半ポンドを用意する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして匿名の実業家が鳥井さん自身であること、その鳥井さんは、赤玉ポートワインやサントリーの主人であることなどを、初めて知った。",
              "citation": {
                "source": "鳥井さんのことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポートワインをやりたまえ。",
              "citation": {
                "source": "共産主義者の犯罪",
                "author": "THE CRIME OF THE COMMUNIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートワインについての意見はいつそう嘆かわしいものでさえありました。",
              "citation": {
                "source": "共産主義者の犯罪",
                "author": "THE CRIME OF THE COMMUNIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの婦人は、高尚ぶつてはいたが、ごく親切だつたので、どこでも見られるごく古風な大伯母さんのような態度で、お客さまに小さなグラスのポートワインと一切れの種入れケーキを出してきて、ブラウンが逃げ出すひまのないうちに、道徳や行儀作法の一般的堕落についてさんざんお説教を聞かせたのであつた。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートワインを飲みたまえ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋には暖かい火が燃えており、ポートワインもあり、メアリが病気の子供のために送った物だ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "マークがポートワインと、凝ったサンドイッチを小皿に持って来て、ビートリスに勧めた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルデラが銀製の葉巻箱を差し出し、ポートワインも近くにあると、言葉を継いだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家から出て自活します」　父のバンストンが悠々とポートワインを飲んだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功するかもしれないし失敗するかもしれませんが、完敗してお父様の助けが必要になったら実家に戻り、エイビスがまだ求婚していれば、妻になります」　父がポートワインを手酌でつぎ、にやり。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃棄物をポートワインのように置いたら熟して、因果に苦しんでいる。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
