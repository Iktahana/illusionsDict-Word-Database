        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あらゆる火花のエネルギーを吐き尽くした火球は、もろく力なくポトリと落ちる、そしてこの火花のソナタの一曲が終わるのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹男の手に熱い涙がポトリポトリ落ちて来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポトリとその膝へ涙が落ちて来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今ポトリポトリと膝の上へ落ちて来る涙を見ていると、鈴子の瞼には、もう鶴雄の顔しか泛んで来なかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の奥がじーんと熱くなり、そして、かつての落語家の頬をポトリと伝う涙は、この子の母親になる筈の自分の妻と、そしてこの子のきょうだいになる筈の自分の子を、明日はどこへ探しに行けば良いのかという頼り無さだった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏頭、鶏頭、　記憶に悲哀は再燃する、切迫｜詰つた俺の感覚が四ん匍ひになつて剃刀を拾ひかける、ハツと霊魂が後から呼び返すと意久地もなくパタリと身体が平べつたくなる、苦しい涙がポトリポトリと額を抑えた手の甲に零れる……　轡虫が啼く……唐突に座り直して、ぐいと右の指を二三本白粉の瓶に突つ込む。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨滴の如く、ポトリ／＼落ちて来るリズム。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同水道端の水道の水滴がポトリ／＼落ちて、残置灯の鈍い光に照らされているのが、にわかに夜の更けた感じだ。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の第一段を下るとき、溜っていた涙が私の眼から、ポトリとこぼれた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ですけど……それはそれとして、大阪へお出でになったらキットおたよりを下さいましね……どうぞ……ね」　そう言ってアイ子さんはタッタ一しずく涙をポトリと落されました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　ポトリとも何とも音はしなかった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故もっと大きい滾れ孔を作って置いて、筒の外から、こう耳を近づけると、ポトリポトリと上部洞から、下部洞へ水の落ちてゆく音がよく聞えるように作らなかったのであるか。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、まさしく、ポトリと音がして、赤羽主任の掌上には、一滴の血潮が、円点を描いた。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、濡れしをれた衣服の裾がべつたり脚に纒つて歩きにくさうであり、長く伸びた頭髮からポトリ／＼と雫の滴る圭一郎のみじめな姿を見た千登世の眼には、夜目にも熱い涙の玉が煌めいた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポトリ／＼とバケツに落ちる栓のゆるんだ水道の水音に誘はれて、彼は郷里の家の裏山から引いた筧の水を懷しく思ひ出した。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白く並んだ肋骨を、鬼火のように波打たして、おびえ切ったウツロ眼から泪をポトリポトリと落しはじめた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして涙を拭いて火鉢の赤火を見るともなく見てゐますとその灰の中に先生の涙がポトリポトリ続けさまに落ちてゐます。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだポトリ　ポトリ　雨のしずくがトタン屋根にしたたっているが、前の瓦屋根越に見えるよその排気筒はしずかにゆるやかにまわって、蠅が　巻き上げた簾のところで　かたまってとびまわっている。",
              "citation": {
                "source": "無題（十）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小指の尖で、中身をポンと落しメリメリと外箱を壊して裏をひっくりかえすと、弦吾はポケットから薬壜を出し、真黄な液体をポトリポトリとその上にたらした。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり色のこいマントの上、赤い帽子の上とそしてやわらかで赤い長靴の上をポトリポトリとしめして行きます。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清めたまえ」　神仏に気勢をかけて力の限り屋根裏の煤を払うと、ポトリと上から落ちてきたものがありました。",
              "citation": {
                "source": "屋根裏の犯人",
                "author": "――『鼠の文づかい』より――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
