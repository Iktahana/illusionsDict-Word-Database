    "definitions": [
      {
        "index": 1,
        "gloss": "pointer (dog breed)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから氣むづかしげな樣子をした、栗毛のポインタアは、金色の脚のついた圓卓子の端にその背中をこすりつけながら、漆塗りの臺の上のセエヴル製の茶碗をがたがた顫はせてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、七年ほど前からポインター種の犬を飼っている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく洋行して世界で有名な犬を能く御承知で、「ポインター」や「セツター」は勿論日本人の余り知らない「シトリーパー」や「ラーチヤー」種の猟犬をお飼ひになつたが、爾ういふ犬社会に通じた方が矢張日本種は中々好いと仰しやつて俺を頭に都合三疋｜御扶持を給はつてゐる。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの行衛知れずになった犬というはポインターとブルテリヤの醜い処を搗交ぜたような下等雑種であって、『平凡』にある通りに誰の目にも余り見っとも好くない厭な犬であった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬も、ポインターか、セッターか形のいい猟犬だ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "積分すべき曲線を紙に手書きし、これを装置にかけてポインターで線をなぞっていくと、複雑な計算を要する処理結果が得られた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きとなったが最後、ポインターだのプードルだのという犬を飼って、五百ルーブルでも千ルーブルでも気前よく投げ出す人がありますが、その代り犬も上物でなけあね。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で、ポインタア種の、栗色をしたとてもすごいのがいて、子供たちはみんなこれをチョコといってこわがっていました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペットはポインターの雜種で、茶色の大きい犬だった。",
              "citation": {
                "source": "美しい犬",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、どこからか迷い込んで来たポインター雑種の赤犬を一匹、台所のタタキの上に繋いで、バタを塗ったジレットの古刃を三枚ほど喰わせて、悶死させているのであった。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には英国種のポインタアの年をとってよぼよぼしているのがいた。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年生の手塚という医者の子が鹿毛のポインターをしっかりとおさえていた、するとそれと向きあって三年の細井という学生は大きな赤毛のブルドッグの首環をつかんでいた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみ、ぼくのカナリアが子をかえしたからあげようね」「いらないよ」「じゃね、きみは犬を好きだろう、ぼくのポインターをあげようね」「ぼくの家にもポインターがいるよ」「そうだね」　手塚はひどく当惑してだまったが、もうこらえきれずにいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポインタア種の白い犬ですが……この間、私が近所の森の中にパイプを落してきたのを啣へて來てくれてから、急に仲好しになりました。",
              "citation": {
                "source": "匈奴の森など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "春子女史は、薄もので拵えた真黒の被布に、下にはやはり黒っぽい単衣の縞もの銘仙を着た小柄の人物で、すこし青白い面長の顔には、黒い縁の大きな眼鏡をかけて、ちょっとみたところ年齢のころは二十五六の、まずポインター種の猟犬が化けたような上品な婦人だった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポインタアの雑種は、房一の往診にはどこへでもついて来た。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村入して間もなく、ある夜｜先家主の大工がポインタァ種の小犬を一疋抱いて来た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいポインタァ種の黒犬で、家の人が見廻りして来いと云えば、直ぐ立って家の周囲を巡視し、夜中警報でもある時は吾体を雨戸にぶちつけて家の人に知らす程怜悧の犬であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年から押入婿のデカと云う大きなポインタァ種の犬も居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此辺には牝犬が少ないので、春秋の交尾期になると、猫程しかないピンを目がけて、来るわ／＼、白君、斑君、黒君、虎君、ポインタァ君、スパニール君、美君、醜君……婿八人どころの騒ぎではない。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　あるとき、私のところへ犬屋がやってきて、「先生は犬の通だそうですから伺いますが、柴犬やもしくは小型の日本犬はポインターなぞよりも優秀な猟犬だそうですが本当ですか」「それは訓練次第でそうなるかも知れないね」「いえ、生まれつきですよ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様にポインターやセッターを猟犬本来の訓練をやめてレース用の訓練に力をそそいでレース犬に仕立てたところで、全然犬種ダラクで、向上とは申されぬ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にしたがっているのは、老いぼれたポインター犬と、尊敬すべきバンタムだった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートバイに乗る、テニスをやる、このごろは猟犬に凝って、ポインターやセッターを飼って毎日｜蚤を取ってやっているんだよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "燕尾服の自殺　――ブルゴオニュの葡萄祭り――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポインターのかわりですね。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポインターのまじりだね。",
              "citation": {
                "source": "野菊の花",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち犬をセッター、ポインター、テリヤー、グレーハウンド等に分けて、これらの名称を用いればまたセッターをすべて同じ物、ポインターをすべて同じ物と思う傾きが生ずるゆえ、事実を模型化するという点は前にひとしい。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所太平町に住んでいる時分、下手な鉄砲をやっていたので、ポインターの猟犬を飼っていたが、これも子犬からもらってきて、自分で「持ってこい」から教えた。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
