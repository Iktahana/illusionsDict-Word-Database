        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ポアンカレのいわゆるゲオメーター型の学者と思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンポアンから　ゆらゆらと風船でも飛ばしたい麗かさだ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャルソンの客あしらいに多少の薄情さはあっても、それがいつも芝居の舞台のように陽気に客を吹き流して行くロン・ポアンの店が、妙に春に似合う。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアッソニエの大通はもう五色の光の槍襖を八方から突出していた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアッソニエの通りだけが彼女に許された猟区だった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの場合を総括するに、いずれもかつてポアンカレーの述べしごとく「原因の微分的変化が結果の有限変化を生ずる場合」に当るを見る。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレーは「方則は不変なりや」という奇問を発している。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ複雑な変化の微小な事、またポアンカレーの謂うごとく複雑さが十分複雑であるために「偶然の方則」が行われ、多くの場合には簡単な平均的の云い表わしを抽象的に考える事が出来るのであろう。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレーの言葉を借りて云わば、前者は源因の微分的変化に対して結果の変化がまた微分的である場合に当り、後者は源因の微分的差違が結果に有限の差を生ずる場合である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知る限りではただアンリー・ポアンカレーがその晩年のエッセー（７）において論じたものである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレ著「科学者と詩人」の訳本を見ていたら、「学者は普通に、徐々にしか真理を征服しないものであります。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その三原山行きの糧食としてＮ先生が青木堂で買って持って行ったバン・フーテンのココア、それからプチ・ポアの罐詰やコーンド・ビーフのことを思い出したので、やっとそれが明治四十二年すなわち自分の外国留学よりは以前のことであって帰朝後ではなかったことがわかった。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレが大統領時代には毎週火曜日に全閣員と昼食をこの店で摂るのが例だった。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真なるもののみが愛すべきものである、とポアンカレが言っている。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾よく流れを逆に上り切って桃色と白のカフェ・ローポアンで一休み。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼びそめぬ、ラヂオのニュース、フラン落ち、巴里暴動す、ポアンカレーまた世に出でむ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼びそめぬ、ラヂオのニユース、フラン落ち、巴里暴動す、ポアンカレーまた世に出でむ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "コスモポリタンとかレビュー・オヴ・レビュースとかさういふ雑誌を見せられて世界の出来事を話され、又パリのサロンの写真帳をひろげて、アムプレショニズムやポアンティリズムの講釈を聞かされた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "否々、わが「アムボンポアン」の「カステロ、デ、ロヲオ」の如くならんは、堪へがたかるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アムボンポアン」は肥胖、「ベルラ、ナポリ」は美しき拿破里といふ程の事なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういへば、反対者は、有名なポアンカレのパラドツクスを思ひ浮べるかも知れない。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレが太陽と地球との運動について言つてゐることもそれと同様である。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "即はち、ポアンカレの主張は、決して真理の任意性をゆるすものではなくて、真理の唯一なることは十分にみとめてその表現の規準を便利といふことにおいたのである。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに関して興味をもつ人はデンマーク人クローマン（Kroman）、米人スタロ（Stallo）並びに有名な仏国数学者ポアンカレ（〔Poincare'〕）の著書を見ればこの問題に関する総括的批判的の研究を見い出すであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏国の数学者ポアンカレーのごときも自然科学の立脚地に立って形而上学に接近して来たとのことであります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、天罰とか神罰とか言われるのであるが、ポアンカレーの言うように、偶然というものは、実は原因を見つけることの出来ぬ程複雑な「必然」と見做すのが至当であって、怪談や因果｜噺の中にあらわれる偶然を、私はむしろ、この「複雑な必然」として解釈したいと思うのである。",
              "citation": {
                "source": "血の盃",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアンリ・ポアンカレのものなどにそういうものを感ずるのである。",
              "citation": {
                "source": "フランス哲学についての感想",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレが射影幾何学は直線を予想し直線は計量に基くが故に射影幾何学も量的であるというが（〔Dernie`res Pense'es, p. 58〕）、元来射影幾何学に於てはこのような計量に基く直線はない。",
              "citation": {
                "source": "物理的空間の成立まで",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
