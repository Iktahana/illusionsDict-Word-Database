    "definitions": [
      {
        "index": 1,
        "gloss": "pose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして「粗野で逞しいポーズ」と、そのポーズの背後に潜んでゐる「優しくいぢらしいセンチメント」とは、彼のあらゆる小説と詩文学とに本質してゐるものなのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装はスイスから取り寄せた品で、羽をはさんだ帽をかぶり、ピッケルを手にして考えているようなポーズをしたものであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手を柱に凭せ体を少し捻って嬌態を見せ、片手を拡げた袖の下に入れて、写真を撮るときのようなポーズを作った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも文明国の、そして自由な新時代の女性としての公平なポーズ（姿態）だと思いました。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歪んだポーズである。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞しい忍耐を以て、この歪んだポーズに堪え、根気よく真に魅力ある理想を探って行き度い。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井氏の「二科同人群像」には単なる似顔の集成でなく、各メンバーの排置のみならずそのポーズや服装によって各自の個性を表現しようという苦心の痕が覗われる。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "額に翳した右の手先と、左の腰盤に当てた左の手首の釣合いが、いつも天候を気にしている職業人のみがする男型のポーズを小初にとらせた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから妾のポーズをお作りになって、製作台にお立ちになったロダンさんは人格の変った方のように、妾には感じられるのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その瞬間に、妾はそれが昨日妾が気を失ったときの肉体のポーズであることに気が付きました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーズも何も無く、ただ、ぼんやり立っていますね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真をとってくれる人も多くなって、右むけ、はい、左むけ、はい、ちょっと笑って、はい、という工合いにその人たちの命令のままにポーズを作ったのです。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑い合っている写真と、それからもう一枚は、私が浮浪児たちの前にしゃがんで、ひとりの浮浪児の足をつかんでいる甚だ妙なポーズの写真であった。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの一つ一つのシーンは多くの場合に静的であり活人画でありポーズである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はこの老人が此夜に限らず時々得意とも慨嘆ともつかない気分の表象としてする仕方話のポーズを茲に紹介する。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のポーズ　落日の最後の明りが築港の海に消えてしまうと、やがて大阪に夜が来た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "草は壺に投げ入れたままで、そのままで何ともいえないポーズを表現する。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘は心から喜ばしそうに、そのピンを橙色の胸にさして、ちょっとポーズをしてみせながら明るい蓮葉な声で笑った。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての猛獸の習性として、胃の中の餌物が完全に消化するまで、おそらく彼はそのポーズで永遠に眠りつづけて居るのだらう。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての猛獣の習性として、胃の中の餌物が完全に消化するまで、おそらく彼はそのポーズで永遠に眠りつづけて居るのだらう。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこういう生活図面の設計の中に配置する点景人物として、図面に調和するポーズを若き妻に求めた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは、他人に向って一種のポーズをつくり、文学だの美術だのを談って居る氏よりも、どれほど無邪気で懐しく、人間的な憂愁や寂寞のニュアンスを氏から分泌しているかも知れないのだ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "座板へ置いて無意識にポーズを取る左の支え手から素直に擡げている首へかけて音律的の線が立ち騰っては消え、また立ち騰っているように感じられる。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くに寄せる浪のうねりは琅※の練りもののように、悠揚と伸び上って来ては、そこで青葉の丘のようなポーズをしばらく取り、容易には崩れない。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままでの孤独は、謂わば相対孤独とでもいうようなもので、相手を意識し過ぎて、その反撥のあまりにポーズせざるを得なくなったような孤独だったが、きょうの思いは違うのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はわたしが彼等を裏切るようなことを告げてもたゞ「それもよかろう」「まあ、やるがよい」という大様なポーズを取るだけになっている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが子供のときから躾けというものによって自分を殺し切り、人の思惑や人の好みを察して酌取ることにだけ発達させられて来たわたしの心というものが何でこのポーズを見破らずには置こうぞ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
