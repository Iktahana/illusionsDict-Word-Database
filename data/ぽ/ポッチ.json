        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただひとりぽっちが寂しかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八、九なのが二つ三つ年上の編物を覗き込みながら、　――あんた、まだそれっぽっち。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴のはちゃんと注文で、自分の好みの注文で、しつぽのはじだけぽっちょり黒く染めて呉れと云ふのです。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはいつも一人ぽっちで、何か考え考えあるいていたから、おおかたウッカリして避け損ったのだろう。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「井戸辺に出ていたのを、女中が屋後に干物に往ったぽっちりの間に盗られたのだとサ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の家を立てるべき弟は日露戦争で戦死したために彼女はほんとうの一人ぽっちであったので、他家に嫁した姉の女の子を養女にしてその世話をしているという事であった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もお知りのたんだ一人の息子を二十九年になもし、台湾で死なしてから、一人ぽっちになりましたけに、世話をしとる若い衆がどれも我が子同様に思われてな、すまんことじゃけれどなもし。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朋輩がさそってもいさめても、まだ帰らないのだとだだをこねてとうとうひとりぽっちになってしまいました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と抜出ていた簪を、反らした掌で、スッと留めて、「そうね……姉さんの御志で、お雛様の栄螺と蛤を、一石橋から流すと云うのに一人ぽっち。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これっぽっちか」　お加代はぺっと唾を吐いた途端に、「あ、これは豹吉の癖だったっけ」　と、にわかに豹吉のことを想い出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヒンブルのお加代ともあろうものが……」　と、そんな自分がいじらしいと思う前に、まず腹が立って、だから、一層いらいらした声で、「あんた、これっぽっちしか持ってないの？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの老嬢はいつもひとりぽっちで、窓の中がわで立ち働いていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "お人形は今夜一晩じゅう、おもての木の上に、ひとりぽっちですわっていなければならないのでしょうか？",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この小さな女の子が好きになりましたので、こんな広い世の中を、ひとりぽっちで、どこへ行くの、と、ききました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「ひとりぽっちで」という言葉は、ゲルダにもよくわかりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が火の気はぽっちり。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞおかまいなく、お引き取りを、と言うまでもなし……ついと尻を見せて、すたすたと廊下を行くのを、継児のような目つきで見ながら、抱き込むばかりに蓋を取ると、なるほど、二ぜんもり込みだけに汁がぽっちり、饂飩は白く乾いていた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽっちり三臠、五臠よりは附けないのに、葱と一所に打ち覆けて、鍋からもりこぼれるような湯気を、天井へ立てたは嬉しい。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを――三光坂上の葭簀張を出た――この老人はうら枯を摘んだ籠をただ一人で手に提げつつ、曠野の路を辿るがごとく、烏瓜のぽっちりと赤いのを、蝙蝠傘に搦めて支いて、青い鳶を目的に、扇で日を避け、日和下駄を踏んで、大廻りに、まずその寂しい町へ入って来たのであった。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅町の弦光の借屋の膳の上には、芋がらの汁と、葡萄豆ぽっちり、牛鍋には糸菎蒻ばかりが、火だけは盛だから炎天の蚯蚓のようだ、焦げて残っている、と云った処で、真珠を食ったあとだから、気が驕って、そんなものには、構っておられん。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよ／＼わたくしの身のまわりに殻が厚くなったせいでしょうか、それともいざとなったら世の中に一人ぽっちと覚悟がきまって来たせいでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、とぼ／＼と踏み入って行く、奥底の知れない闇と青田の泥のにおい、あ――あ、ほんとに女の独りぽっちというのは、こんなひどい気持のものでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」するとかの女はそういうわたしの顔を怪訝に見上げながらわたしの襟を揺り「どうしてこれっぽっちの事で、そんな大げさなことを言うの。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私が都に一人ぽっち残ってさぞ寂しかろうと同情する。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "独りぽっちで隅の方から眼ばかり光らせて居る。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "京吉につきまとっていたのは、女の意地からとはいうものの、一つにはやはり女にとっては一人ぽっちになるのが一番辛いからであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一人ぽっちで夜の町をさまようという寂しさの中へ、わざと自分を虐めて行く女心は、もはやただならず狂気めいていたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの家の主人は、毎日々々、お金を使いたいだけ使って、その日その日を楽しく遊ぶよりほかには、何にもすることがないのに、私ときたら、朝から晩まで、せっせと汗を流して働いても、やっと、まずいパンを少しぽっちしか、買うことができないんだ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこまったよ、もう家の中には、少しぽっちの綿よりほかには何にもないんだよ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」清子「兄が南方で戦死して、あたし一人ぽっちになったでしょう、それでもって私のこと心配して、あなたは天涯孤独だからといって、慰めたり励ましたりして下さるんだけど……。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
