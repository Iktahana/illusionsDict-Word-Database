          "literary": [
            {
              "text": "漁師のポンポン船は二年前からナジミなのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポンポン船でも定期船とそう違わぬ速力で大島へ行くことができる。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうポンポン船に乗って、釜石湾から外洋に突出している御崎半島の白浜という部落へ出かけた。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンポン船は陸に横づけにはならない。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、正月の松の内に、五、六人の友人と一隻のポンポン船で遠征し、寒さでみんなカゼを引いてしまった。",
              "citation": {
                "source": "ゲテ魚好き",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
