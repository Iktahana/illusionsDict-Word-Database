[
  {
    "uuid": "f073a5b4-154e-58bc-97ea-53fbd4e9b62c",
    "entry": "ぽっぽ",
    "reading": {
      "primary": "ぽっぽ",
      "alternatives": [
        "ポッポ"
      ],
      "is_heteronym": false
    },
    "grammar": {
