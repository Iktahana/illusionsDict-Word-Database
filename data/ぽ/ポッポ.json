      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "puffing (smoke or steam)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "キックキックトントンキックキックトントン　凍み雪しんこ、堅雪かんこ、　　　　　野原のまんじゅうはぽっぽっぽ　酔ってひょろひょろ太右衛門が　　　　　去年、三十八たべた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントン、キックキック、トントン、　凍み雪しんこ、堅雪かんこ、　　　　　野原のおそばはぽっぽっぽ、　酔ってひょろひょろ清作が　　　　　去年十三ばい喰べた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹の子供らもぽっぽっぽっとつづけて五六｜粒泡を吐きました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がマントをフゥとやって通ったら火がぽっぽっと青くうごいてね、とうとう消えてしまったよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントンキックキックトントン　　凍み雪しんこ、堅雪かんこ、　　　　　　野原のまんぢゅうはぽっぽっぽ　　酔ってひょろひょろ太右衛門が　　　　　　去年、三十八たべた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントン、キックキック、トントン、　　凍み雪しんこ、堅雪かんこ、　　　　　　野原のおそばはぽっぽっぽ、　　酔ってひょろひょろ清作が　　　　　　去年十三ばい喰べた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のうえには荷物船やぽっぽ蒸汽が忙しそうに往来し、そこにも暮らしい感じがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「三郎さん、でもね、ちょっと上手だって言いますよ、ぽう、ぽっぽ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽう、ぽっぽ――あの三人は町へ遊びに出掛ける処なんです。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかり誘をかけますとね、ぽう、ぽっぽ――お社｜近まで参りましょう。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽう、ぽっぽ――あれ、ね、娘は髪のもつれを撫つけております、頸の白うございますこと。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽう、ぽっぽ――髷の鬢を撫でつけますよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ぽう、ぽっぽ――可哀相ですけど。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎さんを突いたのは――帰途は杖にして縋ろうと思って、ぽう、ぽっぽ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまた、真岡、アイヌ語のモウカ「美しい波の上」という美しい語義を持った樺太西海岸での第一の市街から、南へ南へ、終点本斗を指して出た、や、それは今出たばかりの煙の、むくり、むくり、むくり、ぽっ、ぽっぽっである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤めがなくて、ぽっぽにたんまりおこづけえがあって、べっぴん片手に船遊山、チャカホイ、チャカホイ、チャカチャカチャ――と、いけませんかね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いてふすまを開けますと、ランプの心が多く出て居て、ぽっぽっと黒煙が立ち上って、室内が煙で暗くなっています。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "面長の、しかも膨らみのある顔で、調子も“鳩ぽっぽ”と綽名されていたような含み声であったが、和事師をしては当代第一人と称されて、かの団菊左の三名優に次ぐべき地位を占めていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、見世物のほうにいってみようよ」「兄ちゃん、あれがおもしろそうよ」　と、ミドリがゆびさしたのは、たくさんの見世物のなかにまじって、「ぽっぽ座」と、そめだした赤や青の旗をたてた小屋です。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「富さんの家で何かどたんばたんという音が聞えたから、どうしたのかと思って駆けつけてみると、富さんは湯あがりの頭からぽっぽっ煙を立てて、その叔父さんという人の胸倉を掴んで、ひどい権幕で何か掛け合いを付けているんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は机に片肱をもたせかけて、熱でぽっぽとほてる頭を押えていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにその日は暑かったので、私は、鏡のなかの私からぽっぽと湯気が立っているのを見た。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩ぽっぽ鳩ぽっぽと云う唄が出来るかも知れない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
