    "definitions": [
      {
        "index": 1,
        "gloss": "dropping (of tears, dew, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "といった時には、その赭い頬に涙の玉が稲葉をすべる露のようにポロリと滾転し下っていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポロリと、白い布の上に落ちてきたものを見ると、かられた、黒い、じぶんのかみの毛でした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その顔にポロリと一筋涙を伝わせると、「かんにんどっせ」　くるりと背中を向けると、いきなり部屋を出て行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の割りに老けた若先生の近眼らしい眼から涙がポロリと落ちた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポロリと白い布の上に落ちて来たものを見ると、刈られた、黒い、じぶんの髪の毛でした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いあいだいたんだむしばがポロリとぬけたような気持ちだ。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても変物、此男木作りかと譏る者は肉団奴才、御釈迦様が女房｜捨て山籠せられしは、耆婆も匕を投た癩病、接吻の唇ポロリと落しに愛想尽してならんなど疑う儕輩なるべし、あゝら尊し、尊し、銀の猫捨た所が西行なりと喜んで誉むる輩是も却て雪のふる日の寒いのに気が付ぬ詮義ならん。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、死ぬ前の晩、八重子はか細い声で木崎を蚊帳の中に呼び入れて、「短い縁だったわね」　ポロリと涙を落して、木崎の頭髪を撫でていたが、急にはげしく燃えた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とその埃りっぽい薄膜の耳がポロリと落ちる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポロリポロリと涙がながれる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、きのふ、ペンは指先からポロリと落ちてしまつたのだつた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六競馬の呼障碍は三頭立てで障碍初出走のザザが大した事がないとすれば、ミスエメラルドは故障後の脚力に全く見るべきものなく、アケタケの本命で動かないような気がしていると、そのアケタケが一周ならずしてポロリと落馬して、ミスエメラルドが足にまかせて逃げてしまった。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　七郎丸の眼から球のやうな涙がポロリと滾れ落ちた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雪二郎にすゝめられた私は、歯ぎしりをして拗らうとかゝつたが、忽ち指先が痺れてポロリとしてしまつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "白刃をポロリと地上に墜すと体を絞り手拭のようにねじって、両手を代り代りに伸ばしては虚空をつかむと見えたが、やがて、ズドーンと地上に転落した。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポロリと小指が一本取れた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくそこから母指がポロリと脱げるに相違ない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神にこびりついていたたくさんの殻がポロリとはげ落ち、外気に触れたみずみずしい表面が律動を始める。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は重ねて『でも妾には人形の顏に見える』余『然うですな、これが眉毛で、これの下に眼があると好いのですが』と言ひつゝ、小揚子でツヽくと、土が、ポロリと落ちて、兩眼が開いた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "權現臺の懷古",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でも……それがタッタ一匹の犬から起った事なのですから……スッ……スッ……」　令嬢の眼からポロリポロリと光る水玉が辷り落ち初めた。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ない」「これぐらい冷やかしゃ沢山だ……」　老伯爵はポロリポロリと涙を流し始めた。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙を一しずくポロリと膝の上に落した。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロスコーさんは、あれから直ぐに自殺してしまったんだからね」　博士の言葉が終らないうちに東作老人が、口に啣えてスパスパ美味そうに吸っていた煙草をポロリと膝の間へ落した。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、三人が跳び退いた機みに、それがカサコソと鳴って、おまけになお薄気味悪いことには、肋骨の端が一、二本ポロリと欠け落ちて、それも灰のようにひしゃ潰れてしまうのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀が年老いて来ると、舌に牙のような角質が生えるそうだが、それを他の生物の皮膚に突き刺し、血液の中に浸して置くと、その角質が忽ち、ポロリと欠け落ちてしまう――と云うのだがね。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に行っても二こと目には「芸人の子」が出かけていじめられて居てもたれ一人味方になって呉れる人もない中でまっさおなかおをして唇をかんでポロリポロリと涙をこぼして居るのを意地悪の子供達はまわりにたかってヤンヤとはやして居る事がたびたびあった。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
