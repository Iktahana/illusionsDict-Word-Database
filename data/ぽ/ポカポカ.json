        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三｜疋はぽかぽか流れて行くやまなしのあとを追ひました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆をあげた舟、発動汽船、ボート、櫓で漕ぐ舟、それらのものが春のぽかぽかする陽光をあびて上ったり下ったりした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに干してある蒲団からはぽかぽかと暖かい陽炎が立っているようであった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春先などのぽかぽか暖かい日には、前日雨でもふって土のしめっているところへ日光が当たって、そこから白い湯げが立つことがよくあります。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだが、ぽかぽかして来やしませんか。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽかぽかして来たようだ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男たちはよろこんで手をたたき、さっきから顔色を変えて、しんとして居た女やこどもらは、にわかにはしゃぎだして、子供らはうれしまぎれに喧嘩をしたり、女たちはその子をぽかぽか撲ったりしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中は秋とは申しながらさすがに日がぽかぽかとうららかで黄金色の光が赤いかわらや黄になった木の葉を照らしてあたたかなものですから、燕は王子のおおせのままにあちこちと飛び回って御用をたしていました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからもう熊はなめとこ山で赤い舌をべろべろ吐いて谷をわたったり熊の子供らがすもうをとっておしまいぽかぽか撲りあったりしていることはたしかだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてへ出て見ると日光は実に暖かくぽかぽか飴色に照ってゐた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中ではお茶がひっくり返って、アルコールが青くぽかぽか燃えていました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男たちはよろこんで手をたゝき、さつきから顔色を変へて、しんとして居た女やこどもらは、にわかにはしやぎだして、子供らはうれしまぎれに喧嘩をしたり、女たちはその子をぽかぽか撲つたりしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と果しもなく野原のごとく広い中に、塚を崩した空洞と思う、穴がぽかぽかと大く窪んで蜂の巣を拡げたような、その穴の中へ、すぽん、と一個ずつ飛込んで、ト貝鮹と云うものめく……頭だけ出して、ケラケラと笑って失せた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の雲があつちやこつちにぽかぽか浮いてゐるばかりでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側にぽかぽかと日のあたる、風のない昼には、そこへゐざり出て、自分の目で雲華寺の門を見はつてゐました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたつき前の、あの日、忘れもせぬ、朝は凍えるように寒かったが、ひる少しまえから陽がさして、ぽかぽか暖くなって先王は、お庭に、お出ましなさったが、その時だ、その時。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽかぽかあたたかいので、そのうちにいねむりをはじめました。",
              "citation": {
                "source": "飴だま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……晩に雪が来ようなどとは思いも着かねえ、小春日和といった、ぽかぽかした好い天気。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……満山のもみじの中に、もくりと一つ、道も白く乾いて、枯草がぽかぽかする。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この燈籠寺に対して、辻町糸七の外套の袖から半間な面を出した昼間の提灯は、松風に颯と誘われて、いま二葉三葉散りかかる、折からの緋葉も灯れず、ぽかぽかと暖い磴の小草の日だまりに、あだ白けて、のびれば欠伸、縮むと、嚔をしそうで可笑しい。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこう下を向いて来かかったが、目の前をちょろちょろと小蛇が一条、彼岸｜過だったに、ぽかぽか暖かったせいか、植木屋の生垣の下から道を横に切って畠の草の中へ入った。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽかぽかぺんぺんうらうらうらと変なひとり言も呟いた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜想い出すと、急にぽかぽかぺんぺんうらうらうら。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三口目を飲んでしまふ頃には、もう体ぢゆうがぽかぽかして来て、雨に濡れた絆纏から湯気が立ちさうな気がする。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで聞いてみると、玄関の騒ぎが終わった後に女中が部屋へ帰ってすわっているうちに妙に背筋の所がぽかぽか暖かになって来たそうである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
