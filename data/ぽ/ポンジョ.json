    "definitions": [
      {
        "index": 1,
        "gloss": "Japan Women's University (abbr)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
