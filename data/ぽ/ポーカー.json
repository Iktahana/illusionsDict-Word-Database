        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女将のアレキサンドラは片隅で亭主の白系露人とポーカーを七枚のカードを並列してやっていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは英介氏のむかし馴染みの女友だちがたずねてやってきて、英介氏を郊外の酒場へさそったり、彼女たちのアパルトマンでポーカーを一晩中やったり、英介氏にタキシードを着せてテッフィン（レストラン）に連れだしたりしたからだ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は、もう無かつたので、私達は焚火の傍らで、おそくまでポーカーの手合せに耽つた。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからポーカーにも負けてやらんならん。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもには、カードテーブルでポーカーをする、という考え方はなじまない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーカーはつねにポピュラーな暇つぶしだったが、自室のベッドか、応接セットのテーブルでやるものと、相場は決まっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母の訃を受けて帰国した私の父は、毎日退屈をかこつて、二年三年生の私ばかりを相手に鉄砲打に出かけたり、ポーカーを教へたりして、何となく成人の友達扱ひであつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーカーに似て居る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このタイユフェールの坊やは剣が強くて、また、ポーカーのフォーカードを手に持っているかのようにいつも自信満々のやつなんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネてから、中野英治にポーカーを誘はれたが、すっぽかして、お勝へ行き、ビール二杯、ヨーロッパおでんいろ／＼食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時、非凡閣加藤・中野英治とポーカーの約束。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパンへ入ると田中三郎等に逢ひ、旬報の二階で二十一から相場、ポーカーと進歩して行く話から明日はぜひ一戦やらうと約す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村・堀・田中・高橋と久々のポーカー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の顔ぶれではポーカーになる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャック・田村・高橋・三郎といふ好メムバーでポーカー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりポーカーは面白い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三ぶちゃんとポーカーをやったり、おとなしく遊んで一時半頃床につく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は一つ、ポーカーに加はってやらう、嚢中いくらもないんだが、大丈夫の自信あり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日のポーカーしなきゃよかった、後悔。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "次のやや小さな台には四人の男たちが少額をかけてポーカーをしている。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のやり方はポーカーのフラッシュだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
