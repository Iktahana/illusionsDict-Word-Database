        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「パン、ポラリスであります。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしい、パン、ポラリスを詳述せよ。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パン、ポラリス、南極探険の帰途、ヤツプ島沖にて死亡、遺骸は水葬せらる。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめくさの花の　咲く晩にポランの広場の　夏まつりポランの広場の　夏のまつり酒を呑まずに　　水を呑むそんなやつらが　でかけて来るとポランの広場も　朝になるポランの広場も　白ぱっくれる。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」フ〔ァ〕ゼロ（泣き出しさうになりなが〔ら〕演壇にのぼり、唱ふ）「つめくさの花の　かほる夜は　ポランの広場の　夏まつり　ポランの広場の　夏のまつり　酒くせのわるい　山猫が　黄いろのシャツで出かけてくると　ポランの広場に　雨がふる　ポランの広場に　雨が落ちる」山猫博士（憤然として）「何だ失敬な。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）山猫博士（起きあがる）「あゝ、こゝは地獄かね、おや、ポランの広場へ逆戻りか。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、山猫の云ひぐさではないが、ポランの広場の夏まつりポランの広場の夏まつり　とかうだ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ポラーノの広場？",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だったろうねえ、ポラーノの広場。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポラーノの広場へ行けば何があるって云うの？",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三千八百六十六、五千まで数えればいいんだから、ポラーノの広場はもうじきそこらな筈なんだけれども。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原ぜんたいに誰か魔術でもかけているか、そうでなければ昔からの云い伝え通り、ひるには何もない野原のまんなかに不思議に楽しいポラーノの広場ができるのか、わたくしは却ってひるの間役所で標本に札をつけたり書類を所長のところへ持って行ったりしていたことが、別の世界のことのように思われてきました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こんなに方角がわからないとすれば、やっぱり昔の伝説のようにあかしの番号を読んで行かなければならないんだが、ぜんたい、いくらまで数えて行けばポラーノの広場に着くって？",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちもポラーノの広場へ行きてえのか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでもポラーノの広場はあるかい。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるにはあるけれどもお前らのたずねているような、這いつくばって花の数を数えて行くような、そんなポラーノの広場はねえよ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じいさん、ポラーノの広場の方角を教えてくれたら、おいらあ、じいさんに悪魔の歌をうたってきかせるぜ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろはいつでも酔っているんだ、きっとあいつらがポラーノの広場を知ってるぜ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはきっと五六日のうちにポラーノの広場をさがすから。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはポラーノの広場というのはこういう場所をそのまま云うのだ、馬車別当だのミーロだのまだ夢からさめないんだと思いながら云いました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ、ポラーノの広場まで習いに行かなくてもいいや。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、ポラーノの広場　それからちょうど五日目の火曜日の夕方でした。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜ならもう間違いなくポラーノの広場へ行ける。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
