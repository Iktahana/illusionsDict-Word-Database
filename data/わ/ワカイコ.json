[
  {
    "uuid": "3dbde287-4979-5224-9c09-e7c68823b9a2",
    "entry": "若い子",
    "reading": {
      "primary": "わかいこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
