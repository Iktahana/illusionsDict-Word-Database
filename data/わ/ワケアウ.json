        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "九本の一升瓶をずらりと一列に並べて、よくよく分量を見較べ、同じ高さずつ分け合うのである。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、仲好く分け合うのだ。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋と家賃を分け合うなら、私など打ってつけの男ではないか。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "分け合えば分け合うほど、我々は多くを得るでしょう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり活きておりましたら、何彼につけて頼みにもなり、嬉しいことも楽しいことも、分け合うことが出来ますのに。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が豊饒のまっただなかに暮し、万人が自然の恩恵を平等に分け合う社会状態においては、かかる感情は必ずや消失してしまうであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "質屋の内情を知り、友達と最後の六ペンスを分け合うようになる頃には、ずっと優しい、いい女になるよ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治はもとより、われわれ文化人も働きかけて、もっと広い全土にお互いに文化を作用し合って幸福を分け合う、それがきょうの文化の日に思うことである。",
              "citation": {
                "source": "文化の日",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、わが物は何なりと、欲しくば、仲よく分け合うて持ち去るがよい」「…………」　忽ち、すすり泣きが流れた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れの諸子にも、仲よく分け合う。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時「感激」がどんなにはげしくても、そして、その「感激」をわけあう男の人たちが数人集ったにしろ、仕事そのもののじみな本質は必ず経済問題にぶつからずにはすまない。",
              "citation": {
                "source": "その人の四年間",
                "author": "――婦人民主クラブの生い立ちと櫛田ふきさん――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは、ひとと睦じくすることの魅力をしみじみと感じ、互いに喜びをわけあうようになり、親しく寄りあうのだ。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、そんな二人の少年｜乞食のような姿でわずかな食事をわけあうぼくと山口とに、まるで人目をしのぶ泥棒ネズミのような、ある隠微な、みすぼらしい友情がつながっているのをかんじる。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
