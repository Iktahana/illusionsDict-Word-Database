    "definitions": [
      {
        "index": 1,
        "gloss": "youthful indiscretion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
