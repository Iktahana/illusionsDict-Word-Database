[
  {
    "uuid": "31fa3884-ea76-5cb9-9dca-01ed2a3ffe79",
    "entry": "若い",
    "reading": {
      "primary": "わかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
