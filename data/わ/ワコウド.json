        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁日あるきの若人たち、愼まずばあるべからず、と唐の伯父御が申さるゝ。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、青春の感激だとか、若人の誇りだとかいう言葉は、聞いて寒気がして来て、とても、あの、ハイスクール・スピリットとかいうものには、ついて行けなかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年生の兵太郎君がせんとうで、ほかの者は、そのあとに二列にならび、げんきよく、「世紀の若人」の歌をうたってゆきました。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ、すべては血に燃え、肉慾に狂ふ、放逸な若人達の織りなした一つの悲劇だつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりによく筋肉が締り過ぎたが故に厳しい縄目のあとのように憂愁の隈さえ見える、あの青白く逞しいミケラアンゼロの若きダビデの像に似た肩と胸と腕を持つ若人に食べて貰いたいものです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すればわたくしはその若人の体内のヴィタミンのようにでもなってその人の生涯に生きて行くであろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹角みちのくの谷の若人、牧の子は若葉衣の夜心に、赤葉の芽ぐみ物｜燻ゆる五月の丘の柏木立をたもとほり、落ちゆく月を背に負ひて、東白の空のほのめき――天の扉の真白き礎ゆ湧く水のいとすがすがし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちのくの牧の若人露ふみてもとほり心角吹けば、吹き、また吹けば、渓川の石津瀬はしる水音もあはれ、いのちの小鼓の鳴の遠音とひびき寄す。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、いのちの高丘に誰ぞ角吹かば、我も亦この世の埓をとびこえて、野ゆき、川ゆき、森をゆき、かの山越えて、海越えて、行かましものと、みちのくの谷の若人、いやさらに角吹き吹きて、静心なし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の愛人の美沢は、早く父を亡くして母親育ちであるだけに、お洒落な細かい動作が、身体にしみついていて、いかにも美青年らしく見えたが、この青年はいかにも健康な、スポーツででも鍛えたらしい若人という感じがした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "若人等は尖りたる帽の上に、聖母の像を印したる紐のひら／＼としたるを付けたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ついに、警察によって刺激された若人どもは、立派な『無産階級軍の前衛隊』となり、なお加えらるる試煉によって、牢獄も、絞首台も、恐るるに足らずという、固い信念の中に、生きるようになったんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌ひませう△春はよし、うた人ならでも碧空を仰いだ若人は何で歌はずに居られやう。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤獨の皿に盛られた黒光りする血精に招かれて、若人の血は沸ぎる、沸ぎる。",
              "citation": {
                "source": "杉よ！　眼の男よ！",
                "author": "富岡誠",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸想と詩歌とさかづきとを、いづれは劣らぬ若人への天つ御饗とは誰かいふや。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目にも玉をあざむく二人の若人の腕ののびるところ、鬼をもひしぎそうな大男の浪人姿がつぎつぎとたおれて、うしろからバラバラと、裏崩れ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに倒れをりまする男が御親戚のマーキューシオーどのを殺害しましたるをロミオと申す若人が討取ってござります。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の太陽は、健康な若人のやうに晴やかに笑つてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯気嫌の親父は、洋盃を打ち振つて、蛍の団へ行かうとする若人達の為に！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり激しくいうなら、若人の方が老人よりもその土地に対して早く老人になるのである。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎となるやへり行く古柱　圓覺寺は木立晝暗うして登りては又登る山の上谷の陰草屋藁屋の趣も尊げなるに坐禪觀法に心を澄ます若人こそ殊勝なれ。",
              "citation": {
                "source": "鎌倉一見の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "若人はたすきりりしくあやどりて踊り屋台を引けば上にはまだうら若き里のおとめの舞いつ踊りつ扇などひらめかす手の黒きは日頃田草を取り稲を刈るわざの名残にやといとおしく覚ゆ。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枕に惟然泣く夜の長さかな　翁は腹痛みて終夜眠り給はざりしとて暁に余を呼び醒まし若人をゆり起したる夜長かな　　　鳴雪など戯れ給ふ。",
              "citation": {
                "source": "日光の紅葉",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "新体制という声は、若人よ立て、という響をおこしたけれど、このことは実際生活の中でどんな形であらわされているだろうか。",
              "citation": {
                "source": "女の行進",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の若人たちと手を輪につなげ、日本をふくむ世界の若い人々は、男も女も、野蛮な力で生命と人生がふみにじられることに対しては徹底的に抗議している。",
              "citation": {
                "source": "小さい婦人たちの発言について",
                "author": "――『わたしたちも歌える』まえがき――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にこの息子さんの面ざしはお父さんの俤を湛えているけれども、この若人も、きのうはやっぱり地下室に蜒々と連らなった人の列に立ちまじって、先ず制服の警官にすっかり身体検査されたのかしらと面白く思った。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ封建の気分がのこっている日本は、若人に対してほんとの人間愛に不足している。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "板倉氏のものを讀めば、いかにも悦び勇んで山行する若人の氣分が漂うてゐるのを感ずる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
