        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スーパーの特売日には、人がわんさか押し寄せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭には毎年、わんさかと桜の花が咲き乱れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちがわんさか集まって、公園で遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ノートブック型マシンがわんさか売れて、デジタルおやじの腕っぷしは鍛えられる一方である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここまで単純化すれば、一九九一年にわんさか登場してきた新しい提案の類は、みんなこの線でまとまってしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあはん、私は口が下手で、よういわんさかい、あんたから、おいでやしたら、ようお礼いうてえやちゅうて。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の共同墓地での踊りが放縦極まる筆致で描かれており、もう一つ、他のもの以上にそのコンセプトが私にショックを与えたのがあった――何処とも知れぬ地下納骨所の中に何十体もの獣どもがわんさか集まっていた。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は今までこんな異常生物をわんさか見たことがありますか」　ハロルドの指差す方向から、奇妙な海洋生物が一匹ずつ二人の所へ這い出してきた。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
