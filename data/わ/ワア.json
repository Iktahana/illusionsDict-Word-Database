        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――あゝあれは春の草なのよ、間違へてたわあたし………。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わあ、どうも、いかん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻かれた奴あ、ギュッと巻き締められて、息の根を止められちまわあな。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "新築の市役所の前に青年団と見える一隊が整列して、誰かが訓示でもしているらしかったが、やがて一同わあっと歓声を揚げてトラックに乗込み風のごとくどこかへ行ってしまった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文展へ行つて見ろ、島村觀山とか寺岡廣業とか、あゝいふのはみんな大家だぜ、こんなのとはちがわあ」「あれでも何處かへ持つて行きあ、三十圓や五十圓にやあなるんだよ」などといふのも聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の町通りにわあわあいう声がして、それが店の先で纏ると、四郎が入って来た。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○わたくし達は、外でお友達と一緒の時は「ノシちゃえ」なぞと随分、男のような言葉も使ってわあわあ騒ぐ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると耳に手をあてゝ、わああと云ひながら片足でぴょんぴょん跳んでゐた小さな子供らは、ジョバンニが面白くてかけるのだと思ってわあいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、わあわあ叫んで、吉郎をはねこえたり、水に入ったりして、上流の青い粘土の根に上ってしまった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、また隅々からわあっという歓声とも怒号とも分らぬ声が聞こえた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おわあ、こんばんは』『おわあ、こんばんは』『おぎやあ、おぎやあ、おぎやあ』『おわああ、ここの家の主人は病気です』貝つめたきもの生れ、その歯はみづにながれ、その手はみづにながれ、潮さし行方もしらにながるるものを、浅瀬をふみてわが呼ばへば、貝は遠音にこたふ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯らしの吹くたそがれ時などに背中へ小さなふろしき包みなど背負ってとぼとぼ野道を歩いている姿を見ると、ひどく感傷的になってわあっと泣き出したいような気持ちになったものである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この騒ぎにおどろいて帰って来た時には、長屋の者が唯わあわあ云っているばかりで、ほかには誰もいませんでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はむしろに座って、「わあああああああああ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが不思議なことは、「わああああんああああ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よごせ慶助わあい。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わあい、慶助、木ペン返せじゃ。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると耳に手をあてて、わああと云いながら片足でぴょんぴょん跳んでいた小さな子供らは、ジョバンニが面白くてかけるのだと思ってわあいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わあ」豚はあんまり口惜しさや、悲しさが一時にこみあげて、もうあらんかぎり泣きだした。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫の袈裟をかけて、七堂伽藍に住んだところで何ほどのこともあるまい、活仏様じゃというて、わあわあ拝まれれば人いきれで胸が悪くなるばかりか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、遠くに、行々子が鳴きしきつて、こゝに蛙がすだく――其の間を、わあーとつないで、屋根も門も見えないで、あの、遅桜の山のうらあたり、学校の生徒の、一斉に読本の音読を合はす声。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
