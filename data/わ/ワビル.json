[
  {
    "uuid": "3462d033-da64-5286-bb06-9166de05a19b",
    "entry": "侘びる",
    "reading": {
      "primary": "わびる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be worried",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一電は一電よりも急を告げて、帰朝を待侘びる友人知己はその都度々々に胸を躍らした。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "都から来た人たちの中、何時までこの山陰に春を起き臥すことかと侘びる者が殖えて行つた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "都から来た人たちの中、何時までこの山陰に、春を起き臥すことか、と侘びる者が殖えて行った。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉は東京の方の空を眺めて、種々な友達から来る音信を待ち侘びる人と成った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "六面の体、形よく整い、その内左右各二面には、緑、桃、黄、紫の色に綾なす山水が描かれ、前後各一面には濃き赤を以て葉状の模様を描く、その形美しく色美しく筆美しく、今や楽しく快く机上の務めを果そうとて吾々を待ち侘びる風情が見える。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜から、真剣に良人の帰京を待ち侘びるゆき子は、思っただけでも慄っとした。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟の出発を待侘びるものは田山白雲一人ではなく、士農工商が一人二人と渡頭へ集まってひっかかる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "田山白雲は焦ったがりながら、渡頭に近い高さ三メートルばかりの小丘の上で、遠眼鏡を眼窩の上から離さず、マドロスの逃げ込んだ追波の本流の方をしきりに注視していましたが、そのうちに、向う岸の渡頭に集まって舟を待侘びる士農工商の群れが、急に動揺をはじめたような模様が見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とどうやらこっちを見ながらわびるように誘うようになまめかしく呟いた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏のわびるやうな瞳とぶつかつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそくなりまして、と小声でわびる。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んで、そして何處かで、びつくりして自分に泣いてわびる無情な主人がみてやりたいと思ひました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と旅人はわびるように言い、灰色の包みを解いて、年の頃五歳ほどの美しい少女を外に出す。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "着く所に着いてから思い存分の手当をするからしばらく我慢してくれと心の中にわびるように言いながら、君は若い漁夫を卒倒したまま胴の間の片すみに抱きよせて、すぐ自分の仕事にかかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしだって定子をみごとに捨てて見せますからね」と心の中で頭を下げつつ幾度もわびるように繰り返していた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は祈るようなわびるような心でしみじみと貞世を見入った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院内の交際などで病人たちが慰め合ってる気風もとよ子に次第にわかりはじめ、時折りは長兄の見舞を待ちわびる気持も、周囲の空気のなかに紛らかされていた。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ敏子は、過去の罪はあくまで自分でわびるが、将来は決して左様な事はしない、否、将来ばかりではない、結婚後だって無論そんな事はない。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様も外人が下馬して脱帽しわびることなら許してつかわせといわれた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "後朝をわびるどころではない。",
              "citation": {
                "source": "鶏鳴と神楽と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「単身彼地に帰還致すべく、彼地には小生を待ちわびる女性も有り、彼女と結婚の上、大陸に根を下す覚悟に有之候。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ父の遺稿に、わが子（長男）を見て先考を思ひ不孝をわびるといふやうな老後の詩があり、親父にそんな気持があつたかね、これは詩の常套の世界にすぎないのだらうと冷やかしたくなるのだが、然し、父の伝記を読むと、長男にだけはひどく心を労してゐたことが諸家によつて語られてゐる。",
              "citation": {
                "source": "石の思ひ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宿の水差しのフタをオモチャに遊んでいてこわしたので女中にわびると、女中が言下に「ハア、先日水差しの下の方をこわしたお客さまがありましてね、ちょうどよろしゅうございます」　と言った。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによつて可憐な女の高潔な魂にわびるがいい！",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者達の一団に気転のきいた一人がゐたらここで一言わびるだけで万事無難に終つたのだが、鈍重な気候や自然はさういふ気転と仇敵の間柄ではぜひもない。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ父の遺稿に、わが子（長男）を見て先考を思い不孝をわびるというような老後の詩があり、親父にそんな気持があったかね、これは詩の常套の世界にすぎないのだろうと冷やかしたくなるのだが、然し、父の伝記を読むと、長男にだけはひどく心を労していたことが諸家によって語られている。",
              "citation": {
                "source": "石の思い",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちとあうまでの一年は、長く思われるが、待ちわびるそのあいだに、たがいに仕事につとめ、日々をむだにしないようにとお告げ下さい。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "死の直前まで悩みつづけた、荒っぽい野性のまんまの教え子たちには、鉛筆の走り書きで、「よい子になるように……」と遺書をのこし、学校と村人たちに対しては、自分のいたらなさをわびる書をのこして……。",
              "citation": {
                "source": "石をしょわずに",
                "author": "――わかい女教師の自殺",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは梵鐘の聲さへ二三年前から聞き得なくなつた事を、ふと思返して、一年は一年より更に烈しく、わたくしは蝉と蟋蟀の庭に鳴くのを待ちわびるやうになつた。",
              "citation": {
                "source": "蟲の聲",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何故に待ちわびるやうになつたか、其理由をこゝに言ひたいと思つたからである。",
              "citation": {
                "source": "蟲の聲",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
