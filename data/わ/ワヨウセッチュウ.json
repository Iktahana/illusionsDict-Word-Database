    "definitions": [
      {
        "index": 1,
        "gloss": "blending of Japanese and Western styles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
