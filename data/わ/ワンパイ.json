        "examples": {
          "standard": [
            {
              "text": "麻雀で、王牌はドラ表示牌や嶺上牌がある場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "王牌を開くと、どんな牌が出てくるかいつもドキドキする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は王牌からまさかの牌をツモり、逆転勝利した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが妖女め、又もや王牌入の二二一をならべをつた！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌々思案もせずに、祖父は王牌の髭面に素早く切札を叩きつけた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、どうだらう、持牌は切札の｜Ａ牌に王牌に兵牌で、彼が前に打つたのは六ではなくて后牌だつたのだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
