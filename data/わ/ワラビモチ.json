        "examples": {
          "standard": [
            {
              "text": "夏の暑い日には、冷たいわらび餅が最高のご褒美だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "きな粉と黒蜜をたっぷりかけたわらび餅は、まさに日本の味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は初めてわらび餅を食べた時、そのもちもちとした食感に驚いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "町々へは早やはつ夏の訪れを知らせるように遠く能勢から蹲躅売りが来、なぜか、この頃になると、しがらきやわらび餅とて葛餅を小さくしたような餅菓子の類を粋な手拭で顔を包んだ若い衆が屋台を引っ叩って売りにきた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　○わらびもち　○黒牛と赤紐　○猿沢の池を見下す柳茶屋五月十二日（火曜）　東大寺、龍松寺、筒井氏に案内されて三月堂、不空羂索を見る、その調和の破れて居る点についていろいろ研究。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
