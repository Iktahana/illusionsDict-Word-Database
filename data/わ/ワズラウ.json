[
  {
    "uuid": "a79a303a-290e-5c84-a06b-4ba72eaf23ff",
    "entry": "患う",
    "reading": {
      "primary": "わずらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
