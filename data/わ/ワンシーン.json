          "standard": [
            {
              "text": "映画のワンシーンが、鮮明に記憶に残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はその劇の感動的なワンシーンを演じきった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カメラマンは、決定的瞬間を捉えるため、ワンシーンを何度も撮り直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "六時からまだ四カットあったのを岡田敬も気をきかしてワンカットワンシーンといふスピードでやって呉れたので七時にアガり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンシーンワンカット、三分何秒流しっ放しで、丸山定夫とのやりとりを一カット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
