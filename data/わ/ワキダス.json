    "definitions": [
      {
        "index": 1,
        "gloss": "to gush out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此處の湯元から湧き出す湯の量は中々豐富らしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本魂を腐蝕する毒素の代りにそれを現代に活かす霊液でも、捜せばこの智恵の泉の底から湧き出すかもしれない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Bullock 恋にやつれたエレクトラの広告板から湧き出すオオケストラ、しかも彼女の才能は日比谷街にもまして複雑なのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "言へば言ふほど枝葉が茂つて、路が岐れて谷が深く、野が広く、山が高く成つて、雲が湧き出す、霞がかゝる、果は焦込んで、空を打つて、『皆、これだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水の湧き出す処などを、うまく見付けて掘ると沢蟹の小さいのを、一升も二升も捕ることさへあつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "和国橋の袂に一本しょんぼりと立っている柳が顫えるように弱く靡いて、秋の寒さはその痩せ衰えた影から湧き出すように思われた。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなだらしのないマネをする奴がいるから困る」と坑夫へ向って、「いったい、何処で拾ったんだ」「水呑場の直ぐ横に、置き忘れたように転っていました」　水呑場――とは云っても、自然に湧き出す地下水を水甕に受けているに過ぎなかった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで滝の水のように白かった筈なのが、今は濃い緑色の光沢のある房々とした髪毛になって、振り動かす度に云うに云われぬ美しい芳香が湧き出すのであった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かれに誘われて、深田君は庭に出ると、明かるい月は霜をふらしたような白い影を地に敷いて、四つ目垣に押っかぶさっている萩や芒の裾から、いろいろの虫の声が湧き出すようにきこえた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で暮した一年の生活、それがいつでも一番先に湧き出すような力でかれに蘇って来た。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その後手に縛られた両手を見ました時、腸を切り苛むような憤と共に、涙が、――腹の底から湧き出すような涙が、潸々として流れ出ました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒石油だけが湧き出す油田というのを見た。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油が湧き出すぐらいであるから、地盤がわるく、有害瓦斯の洩れるような場所が沢山ある。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きるために働きながら、却ってその働きによって現実には死に追いやられようとする男女の苦痛と反抗が、詩となって迸り、小説となって湧き出す。",
              "citation": {
                "source": "見落されている急所",
                "author": "――文学と生活との関係にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして膿の湧き出す腫物そのものを直して、清潔な人間らしい艷のある皮膚にしたいと希うのである。",
              "citation": {
                "source": "人間の道義",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを見出した時、私は自分の裡から湧き出す期待をもって読んだ。",
              "citation": {
                "source": "是は現実的な感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔中から一面に湯気が湧き出すような気がして……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく湧き出す熱い涙で何もかも見えなくなったまま、呼吸を喘ませた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その炭車の左右十六個の車輪の一つ一つには、軌条から湧き出す無数の火花が、赤い蛇のように撚じれ、波打ちつつ巻付いていた。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……といったような途方もない、在り得べからざる邪悪な疑いが、腸の底から湧き出す胴震いと一所に高まって来た。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくもくと湧き出す血が、海藻のような帯を引き、ちらりと緑色に髪の毛のようなものが見えたかと思うと、屍体は、激しいうねりを立てて水底に沈んでゆく。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、自己以外にそういうものがあるとしても、それをまったく、「自分のもの」とし、自分の中から湧き出すものとしてから、舞台を踏むという覚悟と矜りとがなければならないと思います。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは、地球上のいずれかの低気圧に作用されて起る風とは別に、胆吹自身が持っている呼吸が、夜のある期間には風となってあの通り湧き出すのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奥まった岩窟の間から湧き出す清水だから、こんなに生温いはずはありようはない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はその榛の樹のそばの井戸の所在を老人に訊いてみるが、老人はもう五十年もこの島にゐて、まだ井戸の水が湧き出すのを見ない。",
              "citation": {
                "source": "鷹の井戸",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愉しいもの裕かなもの、涼しいものが一瞬間でも湧き出す井戸が、その「鷹の井戸」が、どこかにあるのかしら？",
              "citation": {
                "source": "鷹の井戸",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっち側の岩間から湧き出す湯を水車仕掛のポンプで汲み上げて、樋で導くようになっている。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の雪解の地下水がその西麓のここに四十何ヵ所も湧き出すのを利用して、十万平方メートルの県営養鱒場ができている。",
              "citation": {
                "source": "滝しぶき",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　地震の前に湖底又は海底から地下水が、また特殊の場合には石油が、湧き出すことも、もちろんあり得ることである。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉は無限にわきだすし、鉱物質はかたまりつづけるし、毎日毎日高くなるので、何年か後には、世界にくらべ物のない名物となるだろう。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
