      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "axillary bud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その間を二人は葉煙草の脇芽を摘むことにした。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャフェのテラスに並んでうそ寒く肩をしぼめながら誂えたコーヒの色は一きわきめこまかに濃く色が沈んで、唇に当るグラスの親しみも余計しみじみと感ぜられる。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出て、まっすぐに上諏訪へ行き、わきめも振らずあの宿へ駈け込み、そうして、いきせき切って、あのひと、いますか、あのひと、いますか、と騒ぎたてる、そんな形になるのが、いやなので、わざと上諏訪から一つさきの下諏訪まで、切符を買った。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいさんに見られた柱は、まるで木のように堅くなって、足をしゃちほこばらせて、わきめもふらず進んで行き、その変なじいさんは、もう恭一のすぐ前までやってきました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢいさんに見られた柱は、まるで木のやうに堅くなつて、足をしやちほこばらせて、わきめもふらず進んで行き、その変なぢいさんは、もう恭一のすぐ前までやつてきました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は新しい幸福にむかつて進んでいく人のやうに、わきめもふらないですぎていきました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、場所柄もわきめえねえつて酷く叱られたつていふね。",
              "citation": {
                "source": "野の哄笑",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方において、科学者や技術者たちは、その大半が工場につめて、わきめもふらずに、地球脱出用のロケットを製造することに、一生けんめいであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺まではわきめもふらずに上って来たが、ここで歩みをゆるやかにしたものですから、呼吸もやや平調になったのでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、敏ちゃんは、学校から帰りに、この犬が、やはりなにかくわえて、わきめもふらずに原っぱをかけて、あちらのすぎ林の中へゆくのを見ました。",
              "citation": {
                "source": "母犬",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びたシルクハットを頭にのせた、ずんぐりとした小がらの男で、ひどく、しんけんな顔つきで、わきめもふらず酒場にはいってくると、つかつかととおりぬけて、おくの客部屋のほうへ歩いていった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "津山進治郎は世間でいうりんしょくからそうなのではなくて、彼のやりかたには、万事万端、何か一つのことを激しく思いこんでいて、わきめもふらずそれを追いこむことに没頭している人間の、はたにとん着ない馬力とでもいうようなものがあるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまんなかのところを、白手袋はめてバイブルをもった人たちが、行儀よく、わきめもふらないで登ったり下りたりしているの。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生のずれたところへ力瘤を入れて、わきめもふらない女の哀れな憎々しさ。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリイ男爵は一羽のあきれるほどきれいな「燕」を、紐飾りのついた胸へ、かなり堅く抱き寄せたなり、顔を相手の顔に近づけて、わきめも振らずに、相手の眼を見つめていた。",
              "citation": {
                "source": "ある幸福",
                "author": "EIN GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "（島田へゆく前）思索のたのしさ、対象により深く深くとはいり込んでゆくたのしさで、体をふりながらわきめもふらず進んでゆくようなところがなく、何だか息が短くて癪にさわっていた。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしは、又わきめをふらず、一意専心に、このセザンヌ風プラス明日という文章をかきたいわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、彼はわきめもふらずに、町の昼の雑沓をその中心から遠退いた。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、人は一心になると怖ろしいもので、道庵先生に於てすら、今日は朝の迎え酒だけで、それからはわきめもふらず本草学に熱中している。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレー（灰色）のせびろをきて、同じ色のソフトをかぶって、まっすぐ前をむいて、わきめもふらず、あるいてくるのですが、そのようすがなんだか、へんでした。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老人さえつけて行けば、魔法博士の秘密がわかると、わきめもふらず、尾行をつづけるのでした。",
              "citation": {
                "source": "虎の牙",
