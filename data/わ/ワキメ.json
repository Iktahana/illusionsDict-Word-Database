        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう晩には綿入羽織をすっぽり頭からかぶって、その下から口笛と共に白い蒸気を吹出しながら、なるべく脇目をしないようにして家路を急いだものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳代の青年期に蜃気楼のような希望の幻影を追いながら脇目もふらずに芸能の修得に勉めて来た人々の群が、三十前後に実世界の闘技場の埒内へ追い込まれ、そこで銘々のとるべきコースや位置が割り当てられる。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は脇目もふらずにゆっくり楽屋口の方へ歩いて行く。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全に裸体で豊満な肉体をもった黒髪の女が腕を組んだまま腰を振り振り舞台の上手から下手へ一直線に脇目もふらず通り抜けるというものすごい一景もあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな人は脇目にはこの簑虫と変ったところはなかったかもしれない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上り下りの電車がホームに到着するごとに、たくさんの人が電車の戸口から吐き出され、どやどや改札口にやって来て、一様に怒っているような顔をして、パスを出したり、切符を手渡したり、それから、そそくさと脇目も振らず歩いて、私の坐っているベンチの前を通り駅前の広場に出て、そうして思い思いの方向に散って行く。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で彼は日曜のいい天気なるにもかかわらず何の本か、脇目もふらないで読んでいるので、僕はそのそばに行って、「何を読んでいるのだ」といいながら見ると、洋綴の厚い本である。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂは脇目もふらずに無表情な頤を波の上につき出して進んで行った。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "真綿は繭を曹達でくたくた煮て緒を撈り、水に晒して蛹を取り棄てたものを、板に熨して拡げるのだったが、彼女は唄一つ歌わず青春の甘い夢もなく、脇目もふらず働いているうちに、野山に幾度かの春が来たり秋がおとずれて、やがて二十三にもなった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇目にもはっきりとそれが判った。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時間のあいだ我々は脇目もふらずに掘った。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "前垂懸で繻子の帯、唐桟の半纏を着た平生の服装で、引詰めた銀杏返、年紀も老けて見え、頬も痩せて見えたが、もの淋しそうに入って脇目も触らず、あたりの人には目も懸けないで、二階へ澄して上ろうとするのを、円輔が瞶めて、ちっと当ての違ったという形で、変に生真面目に、「お帰んなさい。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さらどのような事があろうと脇目を振る気はないんですから」　お千代はわけもなくおとよのために泣いて、真からおとよに同情してしまった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は脇目も触らずに、どん／＼と歩いた。",
              "citation": {
                "source": "「尾花」を読みて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は脇目も觸らなかつた。",
              "citation": {
                "source": "悔",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ脇目には、壜型の凹凸にやゝ線の細い陰影がうかゞはれる程度の未成品で誰の肖像であるか判別もつかなかつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋めいた微風が吹きはじめた頃で、たゞの散歩なら至極快い美しい眺めの田園風景なのだが、小樽は脇目も触れずに、上着を脱いでも汗は滲ませながら郵便脚夫のやうに忠実に進んで行つた。",
              "citation": {
                "source": "黄昏の堤",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のやうな境涯にある學生はひとへに守舊の道を行けばいいので、脇目をふるべきではないとおのれに言ひ聽かせた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつもこゝの世界には不似合な平然たる顏つきをし、運動の時にはもう長い間、何囘も歩き慣れた道のやうに、さつさと脇目もふらずかの花園の間の細道を歩くのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕には目的地を定めて脇目もふらず歩くなんて云ふことは出來ない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつもここの世界には不似合いな平然たる顔つきをし、運動の時にはもう長い間、何回も歩き慣れた道のように、さっさと脇目もふらずかの花園の間の細道を歩くのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十「どうなすったね」　脇目もふらずに、一日仕事にばかり坐っている沈みがちなその女は、惘れたような顔をして、お島が少し落着きかけて来たとき、言出した。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし岸本はもっと広い自由な世界をめがけて脇目もふらずに急ごうとした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは、毎日脇目もふらずに宿へ帰ってゆくことが、二十五年もつづけて来た習慣だったのに。",
              "citation": {
                "source": "孤独",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日もまたいらっしゃいな、おいしいものを用意しときますから」「ありがとう、参ります」　脇目もふらず彼は去った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫の用が濟んで、もう暑さを感ずる日當りのよい黒光りの縁側へ出ると、野路を歩く時には、脇目もふらずに、見ないやう／＼と勉めて來た小學校の後姿が、淺間しい姿になつて、其の鯨のやうな細い眼に映つた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャフェのテラスに並んでうそ寒く肩をしぼめながら誂えたコーヒの色は一きわきめこまかに濃く色が沈んで、唇に当るグラスの親しみも余計しみじみと感ぜられる。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出て、まっすぐに上諏訪へ行き、わきめも振らずあの宿へ駈け込み、そうして、いきせき切って、あのひと、いますか、あのひと、いますか、と騒ぎたてる、そんな形になるのが、いやなので、わざと上諏訪から一つさきの下諏訪まで、切符を買った。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいさんに見られた柱は、まるで木のように堅くなって、足をしゃちほこばらせて、わきめもふらず進んで行き、その変なじいさんは、もう恭一のすぐ前までやってきました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢいさんに見られた柱は、まるで木のやうに堅くなつて、足をしやちほこばらせて、わきめもふらず進んで行き、その変なぢいさんは、もう恭一のすぐ前までやつてきました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
