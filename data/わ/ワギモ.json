  {
    "uuid": "d3064db4-c3fd-533f-8c39-a97e738e5d99",
    "entry": "吾妹",
    "reading": {
      "primary": "わぎも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
