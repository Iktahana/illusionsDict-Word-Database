[
  {
    "uuid": "94d0443c-ddca-5c79-bdf2-40da3e599e0b",
    "entry": "和食",
    "reading": {
      "primary": "わしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕暮になって、一行が水神の八百松へ晩餐をとりに入ろうとすると、みち子は、柚木をじろりと眺めて「あたし、和食のごはんたくさん、一人で家に帰る」と云い出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは和食の鯛の眼肉の羮にでも当る料理なのであろうか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで朝飯が済んだのかと思っていると、今度は改めて和食の膳が運ばれて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そのあとは急に良き醤油に山椒の芽の匂う鯛の兜焼が食べたくなり、洋間の中に青竹の欄干の小座敷がしつらえてある和食の料理店へ河岸を替えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝が和食なのはめずらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一月八日）木の実おちてゐる拾ふべしあとになりさきになりおへんろさんのたれかれ（野食）秋あたたかく蠅も蚊もあつまつて短日暮れかかる笈のおもさよ脚のいたさも海は空は日本晴秋もをはりの蠅となりはひあるく仲がよくないぢいさんばあさん夜が長く　十一月九日　曇――雨、行程三里、和食松原、恵比須屋。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食を急激に和食に変える辛さを母は想ったものか、彼女から矢代にそう訊ねたとき、朝だけはパンにしたかったいつもの癖が出て、うっかりパンと答えてしまったが、今の彼にはこういうことも自己批判めいた種となって、一途に烈しく和色に偏してゆこうとする自分の保守さ加減も、まだ徹底出来ぬのだと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはゆる洋服、洋食、洋館のこれほど普及した今日に於てさへ、一方、和服は決して廃せられず、和食はむしろ常食であり、畳障子の家屋は住みよきものとされてゐます。",
              "citation": {
                "source": "日本文化の特質",
                "author": "――力としての文化　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ところが、一人分だけ、和食のお膳が出てるの。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "真壁は仏蘭西風の簡単な朝食、さとは和食である。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「土地を見にいらつしつた方は、食事のお代はいただかないことになつてゐます」「僕は、たゞ遊びに来たんだから金は払ふよ」「和食の定食が三十銭、パン牛乳なら二十五銭です」「ふむ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちでも早く出来る方をくれ」　和食の膳がすぐに運ばれた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳には洋食部と和食部（といってもすき焼専門だが、）と、それから他に旅館とがあって女給仲居が凡そ五十人もいた。",
              "citation": {
                "source": "女給",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め登恵子は洋食部の方へ志願したのであるが、今都合が悪いから一ヵ月和食の方で働いてから廻すという約束で、取りあえずお座敷女中を働くことになった。",
              "citation": {
                "source": "女給",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停の数で三つ先に、和食の店があるの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "和食の店の匂いが、冷えた空気のなかに強くあった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある門前町でみやげ物店、和食の店、そして甘いものの店を営む家の、離婚歴のある次女が今度の相手だった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "和食の店の支配人になった西野について、美代子と三枝子は語り合って笑った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋食だと思ってたのに和食でがっかり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時、食堂へ、和食を試みる、いくらかまし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食は和食といふ奴を部屋へとる、ひどい飯で驚いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つひに一睡も出来ず、食堂で和食の朝飯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食、うまいフランスめしのあと、和食がよろし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時頃、食堂で和食を食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "和食し、道子と五目ならべ、ピョン／＼で遊ぶ、家庭円満。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
