        "examples": {
          "standard": [
            {
              "text": "旅行の計画を立てる際、JRの割引切符を上手に利用すると旅費が抑えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓口で学生証を見せて、学割の割引切符を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターネットで事前予約すると、新幹線の割引切符が手に入る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五日間通用の出來る割引切符を利用せむとする也。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日より、小金井花見の割引切符を賣る由、張出してありければ、買はむとするに、雨の爲に、延ばしたりといふ。",
              "citation": {
                "source": "春の郊外",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "割引切符を買う時は無論制帽の方が都合がいいが、汽車に乗り込んでしまうと必要はない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ソヴェトの勤労者はめいめいの属す職業組合を通じて各劇場の割引切符を貰う）。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
