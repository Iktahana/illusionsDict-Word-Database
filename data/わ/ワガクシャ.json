    "definitions": [
      {
        "index": 1,
        "gloss": "scholar of (ancient) Japanese literature and culture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
