[
  {
    "uuid": "b7390026-1aa8-550f-acbd-ddd6a3d94ecc",
    "entry": "詫び",
    "reading": {
      "primary": "わび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "apology",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は田舎の程度の低い学校を出たばかりで、充分の高等教育を受けなかったので、常に自分の無学を悲しみ、良人に対して満足な奉仕ができないことを嘆き詫びた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時ヘルンから万葉集の歌を質問され、答えることができなかったので、泣いてその無学を詫び、良人に不実の罪の許しを乞うた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『エ、おい何とか言はねえか、物を言はねえかよ、唐變朴』『………………』『蹈んだら、蹈んだと言ひねえな、確かに私が、蹈みましたと詫びりや、すむ事ツた。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちへ帰って早速母に詫びたけれど母は平日の事が胸にあるから、「何も十枚ばかりの蓆が惜しいではないけれど、一体私の言いつけを疎かに聞いているから起ったことだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでお母さんの悪かったことをよく詫びてくれ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は如何様にもあなたにお詫びを致します。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにお詫びをするのが何より民子の供養になるのです」　僕はただもう胸一ぱいで何も言うことが出来ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですからお詫びを申す様な訣……」　僕は皆さんにそんなにお詫びを云われる訣はないという。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子のお父さんはお詫びを言わしてくれという。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考えるほどあの児が可哀相で可哀相で居ても起っても居られない……せめてあなたに来て頂いて、皆が悪かったことを十分あなたにお詫びをし、またあれの墓にも香花をあなたの手から手向けて頂いたら、少しは家中の心持も休まるかと思いまして……今日のことをなんぼう待ちましたろ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生はどんな場合に於ても、決して人に詫びはしない。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自分自身にも詫びはしない。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、僕の失禮をお詫びします。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六驚いて居る五郎蔵を投げ飛ばし、　その首筋掴んで、Ｔ「帰ったら大吉に　申して置け」　一同が斬り付けんとするのを一喝して置いて、　五郎蔵に、Ｔ「日下部典六が怖くて　よう来ぬのなら　怖う厶いますと　両手をついて　詫びに来い！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「怖いのなら　怖う厶いますと　双手をついて　詫びて行け」　「エッ」と典六不思議そうな顔。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、Ｔ「さすれば　命だけは助けてやる」　と云われて典六「さては半次」と立ち上らんとするが、　大吉に刀突き付けられ、　仕方なく両手をついて詫びる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家諸氏や編輯者にお詫びをしなければならない。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隣近所にお化粧のアラを拾うやつもなくてさばさばしたろう」　これが唯一の、娘も共に零落させた父の詫びの表明でもあり、心やりの言葉でもあった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さういふ姿をお眼に掛ける失禮をお詫びしながら、暫くアストオル吸入器を用ゐた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度おまきも詫びた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか気になるので、五月の末に無沙汰の詫びながら手紙を出すと、すぐその返事が来て、来月は氷川様のお祭りで強飯でも炊くから遊びに来てくれとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを考えると、わたくしは何だか師匠を見殺しにしたようで、明けても暮れても気が咎めてなりませんから、毎月その詫びながら墓参りには欠かさずに来るようにしています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は畳に額をうずめて、恐れかしこんでわが子の罪を幾重にも詫びた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端氏に對してはその作品を汚したことを幾重にもお詫びしたい。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ、貴兄に機会があればお詫びするとして取敢えず原稿を御返却いたします。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァレリイの言葉、――善をなす場合には、いつも詫びながらしなければいけない。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、父は学校のおつとめの帰りに、岩見先生のお家へ、お礼とお詫びにあがったようでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこそ私は、いつか叔父さんに教えられたように、私の見た事、感じた事をありのままに書いて神様にお詫びしたいとも思うのですが、私には、その勇気がありません。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供らが叫んでばらばら走って来て童子に詫びたり慰めたりいたしました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の片側は翳り、片側は日射しをうけて、あつたかいけざやかにもわびしい秋の午前です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
