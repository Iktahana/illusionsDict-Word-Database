    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese-made thing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
