        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "英語では何というかと思って和英辞書を開けてみたが虫の一種とあるばかりで要領を得なかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘボン先生といえば、何人もすぐに名優｜田之助の足を聯想し、岸田の精※水を聯想し、和英字書を聯想するが、私もこの字書に就ては一種の思い出がある。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その店頭の雑書の中に積まれていたのは、例のヘボン先生の和英字書であった。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ではこれ以上の和英字書も数種刊行されているが、その当時の我々は先ずヘボン先生の著作に縋るより他はない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の書物を読むには英和の字書で済むが、英語の会話を学ぶには和英の字書がなくてはならぬ。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "就てはヘボン先生の和英字書を買ってもらいたい。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分だつてさつき彼は、Yadokari〔寄居虫〕n. the Hermit Crab と、和製英語見たいな言葉を和英字引で引いたのである。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は、二階で、和英字引を引いたり、Hermit といふ名詞をワザと英文の字引で引いて、“one who retires from society and lives in solitude or in the desert.”などと口吟んだり、また「やどかり――蟹の類。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（和英兩文にて）『大森介墟古物編』は、實にそれである。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学初歩　　　　価一分一朱義塾読本文典　　価一分和英辞書　　　　価三両二歩地理書　　　　┌一部に付窮理書　　　　┤弐両より歴史　　　　　└四両まで　右にて初学より一年半の間は不自由なし。",
              "citation": {
                "source": "慶応義塾新議",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに中西へより、和英とフレーズの辞書を買って来る。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三省堂で、コンサイズ和英二冊買って光子さん夫婦に送る。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六は安政四年、「和英對譯商用便覽」を出版してゐること。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "また三谷氏の「詳傳」も、「本木翁が入牢説云々は「蘭話通辯」を印刷出版したることと、蘭書に因りて「和英對譯辭書」を著述せんとする企あることを密告せるものあること、翁が開國論者たることの世に聞えたる等に起因せりといふ」と書いてゐる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政三年に「和蘭文典文章篇」、同三年に「和英對譯商用便覽」、同五年に「物理の本」である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "また前記三著のうち「和英對譯商用便覽」も一册現存して、安政元年にイギリス船へも開港した長崎の商取引のため、若しくは蘭語から英語にうつりつつあつた時代に魁けたものだといはれる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌造この時期の心中を、私らはわづかの記録や遺作によつて想像するよりないが、「和英對譯商用便覽」が一枚板の木彫で、わづかに和製洋文字のノンブルを附けたに過ぎないものであつたのをみれば、ときには大きな絶望に襲はれることもあつたかと思ふ。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "和英の辞書をひいても、勘に相当する適当な言葉は見当らない。",
              "citation": {
                "source": "勘",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると一同が、ドクトル・ペーンは和英相通じて医者相当の名であるとの評が起こった。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "海事用語の訳は中内清文氏の和英西仏葡語海洋総合辞典（http://www.oceandictionary.jp/index.html）を参考にしました。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯箱、和英、英和と漢和の字書。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和英』　『世界経済年報』ヴァルガ※『日本経済批判』ヴァルガ※『日本経済年報』第二輯※『軍備増税・公債』　ダニロフ『軍備と国民経済』　『世界経済年報』？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和英の辞典はコンサイズよりもすこし大きくて目のつかれないひきいいのが林町にあったから、それと同じのを入れましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和英はどの道買うわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和英はただ単語ばっかり並べたのはつまるまいと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "林町で備えている井上の和英の大型のがよいと思っていたら絶版の由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『第八路軍従軍記』と井上の和英中辞典もお送りしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和英、たけのぶのは大きすぎ、井上のは例えば「イタヅラ」という字をローマ字でひくとすぐ「徒に」の「いたづら」が出て来る、ほかのは悪戯（いたづら）が第一に出る、そういうちがい（日本語感のうちの漢文的要素）がありますが、文例ではやはり井上の方がよく選び出して居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和英どうでしょう、一寸ほかに名案が浮びませんが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪ビルから電車で三省堂へゆき、そこで和英コンサイズを二冊買って、速達に出せるように包んで貰い、松田という人の和露も見ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
