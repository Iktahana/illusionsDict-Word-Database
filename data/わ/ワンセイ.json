      {
        "index": 1,
        "gloss": "Japanese born in Taiwan during Japanese rule",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
