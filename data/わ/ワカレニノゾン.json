        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "別れに臨んで李陵は友のために宴を張った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、わたしはお別れに臨んで、悪魔の杖によって隠されたる原因をはっきりと申し上げておきたく存じます。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れに臨んで、彼はこう祝福してくれた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子供たちをかような尊い戦いのために、今日只今から社会に送り出す私の心持……お別れに臨んで……」　校長先生のお話がここまで参りました時に、満場から湧き起った拍手のたまらない渦巻き……それから暫くの間続いたススリ泣きと溜息……。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は別れに臨んで君の送られたその児の終焉記を行李の底に収めて帰った。",
              "citation": {
                "source": "我が子の死",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お別れに臨んで一言忠告を許して貰いたい。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れに臨んで今まで私が文典の講義をしたお礼として主僧から十タンガーその他の人々も感心な巡礼のラマであるといって若干の金をくれて敬意を表せられたです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れに臨んでひとえにこの事を願うという意味で般若心経三巻を読みました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れに臨んで彼はスペイン人をトゥンベスの町へ招待したが、ピサロも彼に鉄の斧を贈った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その別れに臨んで、彼は香苗に向って、「こんど帰って来たら」という一語を残した。",
              "citation": {
                "source": "城中の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れに臨んでも、もはや云うべきことはなかった。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈※、別れに臨んでは、口約束だけでは心もとないとあって、三郎｜進は、（何か、御息女のおしるしを戴きたいが）　と、自分の意志のかたい所を見せて、こう希望を述べると、（御もっともな仰せ。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その別れに臨んで天人がいうには、もし私に逢いとうなったら、あめ牛千疋を土に埋め、その上にブナ（南瓜）の種を播き、その蔓を伝うて昇って来なさいという。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻のたなばたひめが別れに臨んで、月に三度は逢いましょうと言ったのを、聞きそこなって三年に三度とやと答えたので、それから七月七日にしか逢えなくなったという点は、すなわちまた天稚彦の草紙と同じであった。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
