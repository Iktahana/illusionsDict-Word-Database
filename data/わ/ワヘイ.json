[
  {
    "uuid": "e9280224-554f-55d4-964b-c2847031dcf0",
    "entry": "和平",
    "reading": {
      "primary": "わへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "peace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "現代の中國の若い智識人に讀ませて、日本にわれらの理解者ありの感懷を抱かしめ、百發の彈丸以上に日支全面和平に效力あらしめんとの意圖を存してゐます。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもすぐに和平をして、学校ゴツコや何かをするのでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、「和平建国」というロマンチシズムには、やっぱり胸が躍ります。",
              "citation": {
                "source": "三月三十日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、白蘭の和平調停を、英仏｜婉曲に拒否す。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年徳川殿と和平の時、貰う筈であったが、真田がわがままを云って貰えなかった。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西和睦　和平が成立した時、真田は、後藤又兵衛とともに、関東よりの停戦交渉は、全くの謀略なることを力説し、秀頼公の御許容あるべからずと言ったのだが、例によって、大野、渡辺等の容るる所とならなかったわけである。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "欺くて表面的には和平成り、此の年を以て応仁の乱は終ったことになって居る。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無賠償、無割譲」といふ道義的和平条件を正面に立てて、東亜諸民族の恒久平和の楽土を建設するために戦つてゐるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツとしては軍事的成功を活用し、米国大統領の無併合、無賠償の主義を基礎として断固和平すべきであった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "政略関係は総て和平を欲していたのにルーデンドルフは欧州大戦はクラウゼウィッツの「理念の戦争」であり連合国は同盟国を殲滅せざれば止まないのだから、この戦争に於ける統帥は絶対に政治の掣肘を受くべきにあらずとして政戦略の不一致を増大し、「こうなった以上は最後まで」と頑張って遂にあの惨敗となったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部をワルソー方向に進めてロシヤの垂涎の地である同地方に露軍を牽制し、東普に集めた主力軍をもってこの敵の側背を衝き、一挙に敵全軍を覆滅して和平を強制する方針であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は出来るし、生活の不安はないし、允男の成績はいいし、一家は和平に満ちていた。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　タケシが警察学校を去って三日後、一九七三（昭和四十八）年一月二十七日、アメリカ・南ベトナム、北ベトナム・南ベトナム臨時革命政府は、パリでベトナム和平協定と議定書に調印した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう言へば、今日は和平新宅の俊子の七日やが、七日目／＼に死ぬな。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心持が偶※夏の夕暮の涼風に反映したものであつて、同時にそれは又万国和平の心でもある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正六年十一月に、段祺瑞内閣から南方征伐の大權を委任されて湖南へ出陣して居つた、總司令官の王汝賢や副司令官の范國璋らが連署して、弭兵和平の通電を發して、段内閣の瓦解の原因を作つた。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "新支那中央政府の要人たる傳式説氏や趙正平氏などを中心とする文芸科学社関係のグループや、中華日報や新申報への関係の人々を除いては、たとえ和平派に心を寄せ東亜新秩序建設に志ある人々でさえ、表面上灰色的態度を取らざるを得ず、日本人と会談することなどは甚だしく警戒する。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の和平を希ひたる孫中山の名も知らん。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に依りて、和平給ふ。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人騒がせな博士の失踪は、精神｜錯乱の結果でもなく、況んや海を越えて和平勧告に行ったものでもなかった。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋津洲・磯城島と倭、みな大和平原における大きな村の名であった。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "多助は袴羽織でお花は縫模様の振袖と大和錦の帯を締め、髪は文金の高髷にふさ／＼と結いまして、少し白粉も濃く粧けまして、和平夫婦が三々九度の盃を手に取上げる折から、表の方から半合羽を著て、今河岸の船から上って来たという様子で這入ってまいりましたのは、炭の荷主で、飛駒村の吉田八右衞門でございます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日華事変中から太平洋戦争中にかけて、重慶政府へ、大小さまざまの幾筋かの和平の糸がくり出された。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国征伐の時、秀吉と如水の一存で浮田と和平停戦した。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在でも雷岳の上に立てば、三山をこめた大和平野を一望のもとに眼界に入れることが出来る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の指導者はこゝに想ひ至らねば、永遠の和平など議する資格はない。",
              "citation": {
                "source": "春日雑記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "和平申し入れが討議されているものと思われる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに和平のために努力しているのに、力およばず、両者はだんだん離れて行き、そしてますます態度は硬化し、前よりもずっと正面衝突の危険が感じられてくるのだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛利家の幸運も、天下の和平も、挙げてこの中にあり、ですな」　隆景は温厚、然し明敏果断な政治家だから官兵衛の説くところは真実だと思つた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "房枝は、窓ぎわへいって、カーテンをそっとあけて、下を見おろした。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
