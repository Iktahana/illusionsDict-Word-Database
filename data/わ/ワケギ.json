        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（昭和十七年夏）風船あられ　飯蛸、鯖、魴※、白魚、さより、蛤、赤貝、栄螺、分葱、京葱、鶯餅、草餅、茶飯、木の芽――と、かたへのものゝ記には三月のあぢがこんな具合に列ねてある。",
              "citation": {
                "source": "下町歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "■　分葱――くせえなあ！",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく帰って来ました」――フィリップは言う――「帰ってきたので、家へ入れたんです」　彼は、分葱しか食いたくない時は、自分で病気だということがわかるのである。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "分葱――くせえなあ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わびしかるべき茎だちの浸しもの、わけぎのぬたも蒔絵の中。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｗ老人から、ちしや苗とわけぎの球根を分けて貰うて植ゑる、安心々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬味のわけぎを小さく刻んで、山盛り皿に入れて出しておいて、戸口に椅子を持ち出し、だしの煮こぼれるまで、由は此椅子に呆んやりかけてゐるのです。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉おろし、さらし葱、わけぎの薬味。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "酢ミソに辛子をつけて、わけぎを細かく切った薬味をつけて置いて行く。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
