[
  {
    "uuid": "16b0e934-a1a5-5cea-85eb-61f209dba8b5",
    "entry": "若作り",
    "reading": {
      "primary": "わかづくり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞",
