    "definitions": [
      {
        "index": 1,
        "gloss": "young Japanese amberjack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
