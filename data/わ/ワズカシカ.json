    "definitions": [
      {
        "index": 1,
        "gloss": "(nothing) but a little",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我々の時代には、かかる不屈不撓、かかるはげしい熱狂を抱いてゐる藝術家は僅かしか居りません。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（それとて私にはほんの僅かしか要りませぬ。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僅かしかありゃしねえでがすよ、顔を知っとる奴なら、三百人もありますべえか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっても、極く僅かしかない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　木代が、六十円ほどはいったが、年末節季の払いをすると、あと僅かしか残らなかった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝶ちゃんは、僕を大酒飲みのように言うがあれだけ飲んで、事実、飲んだ気はほんの僅かしかないのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七才八才の時には、努力しても僅かしか挙げることの出来なかった重石も、成長し身体が大きくなれば、簡単に之を挙げられるものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年だか一昨年だか朝日新聞に、現代家屋の図面が毎日々々載つた事があるが、書斎を特に設けた家は僅かしか無い。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、僅かしか残っていない歯の中から、またその目ぼしい一本が、抜け落ちるように、兄がいなくなる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年に代って、彼女の僅かしか残っていぬかも知れぬ良心を恥かしめてやる必要があるのだ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べてこれを蹂躙らうといふ輩のみじめさといつたら――彼等の生活はちやうど巨大胃のやうに、どんな物でも手當り次第に荒こなしをするだけで、自分の生命に吸ひとる分量といつたら、ほんの僅かしかない。",
              "citation": {
                "source": "飛鳥寺",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたものか、いつの年も咲き盛った花の割合に、実のとまりが極く少く、とまった果実もそれが熟れる頃になると、妙に虫がついて、収穫として畑よりあがるものは、ほんの僅かしかなかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、僅かしか残つてゐない歯の中から、またその目ぼしい一本が、抜け落ちるやうに、兄がゐなくなる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年に代つて、彼女の僅かしか残つてゐぬかも知れぬ良心を恥かしめてやる必要があるのだ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は二人ともよく知つてゐましたが、岩野氏は生前すでに一家を成してゐた人だけに、交際も広く友人知己も多かつたのに比べて、平尾氏のはうは、どちらかといふと人間が陰気で、引つ込み思案で、おまけに名前も売り出さないうちに亡くなつたので、今では知つてゐる人も僅かしか残つてゐません。",
              "citation": {
                "source": "恋妻であり敵であつた",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "城崎から香住までは里數にしても僅かしかない。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "應擧の作品についても、私は今日まで僅かしか知る機會を持たなかつたが、來て見て動かされた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草もなくなつた、石油も乏しい、木炭も僅かしか残つてゐない、其中庵非常時風景、いや、むしろ、平常時風景！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の女学校教育は特別なものであったから、共学がはじまってまだほんの僅かしかたたない今日、女子学生が男の学生に比較してあとにいるという事情にも無理もないところがあります。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "より少い、より僅かしか儲けなかった人に課せられる税は、率は少くても利潤の大半を引攫うものであろうが、それに対しては猶予はないのである。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本の妻が残して置いて行った着物は、あらかたは生家の方へ返し、形見として郷里の姉へも分け、根岸の嫂にも姪にも分け、山の方にある知人へも分け、生前園子が懇意にしたような人達のところへは大抵分けて配ってしまって、岸本の手許には僅かしか残らないように成った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二五年、党は「同伴者」の反プロレタリア的・反革命的要素が「現在では極く僅かしかない」と認め、前述の忍耐づよいテーゼを出したのだ。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤い木」の場合にピリニャークがとった態度は果して彼の「極く僅かしかない反革命的、反プロレタリア的要素」を示しているだろうか。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ほんとにどういう理由で、世界の文学はあらゆる時代を通じて傑れた婦人作家というものを僅かしか持っていないのだろうか？",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、一葉の時代はまだ日本にジャーナリズムが僅かしか発達していませんでした。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため婦人の民主的な文学というものは婦人自身の中には非常に僅かしか芽生えないで、そのあとは進歩的な男の人達が文化全体の問題として問題にしました。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人と、僅かしか入って居ない金入れのちょろまかしとは、愛にとって実に意外な連想であった。",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄の衣物を賣つたのは下宿の拂ひになつてしまふし、病院から拂ひもどして呉れる分も僅かしかない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出發の時に俄かにおほ雪となつたのがいけなかつたのだが、青森に來ると地上が僅かしか白くなつてなかつたし、ここぢやアまだのやうだ、ね。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現在我邦の政府で映画教育の価値がほんのわずかしか認められていないとしたら、何時になったら立派な教育映画が出来るようになるか全く見込が立たない有様である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
