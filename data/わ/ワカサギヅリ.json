        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ウインタースポーツとしてスキー、スケートが婦人にできて、氷上のワカサギ釣りが女の子にできないわけがないと思う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷上のワカサギ釣りの道糸も、一厘半の本テングスをおはぐろ染めにしたのが、今でもある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒中氷上のワカサギ釣りもサシを使うが、これはとくに紅ザシといって食紅でサシを染めて使う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬のしびれるような氷の上のワカサギ釣りに、芸者にウイスキーを持たせて連れて行った。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、親戚の高校生の女の子にも、スケートのついでにワカサギ釣りを教えたが、ぼくよりいつもよけいに釣ってしまう。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
