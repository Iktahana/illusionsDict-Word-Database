[
  {
    "uuid": "15d66107-d62f-560d-9f40-f0058a9ad151",
    "entry": "渡殿",
    "reading": {
      "primary": "わたどの",
      "alternatives": [
        "わたりどの"
      ],
      "is_heteronym": true
    },
    "grammar": {
