          "literary": [
            {
              "text": "溺れる者は藁をも掴む。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁をも掴むというくらいだから真正面に向っては抱き付かれて同伴にされる。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "溺れるものは藁をも掴む。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この肉身を原子病治療法発見の貴重な資料に使うのであるから、でたらめな実験をめくら滅法やってみるのではない、おぼれる者はわらをもつかむというあわて方で、迷信だろうとインチキ薬だろうと手当たり次第飲んでみるのでもない。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長い指で何かを握ろうとする様は、溺れる者わらをもつかむ風情だった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
