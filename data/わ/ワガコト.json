    "definitions": [
      {
        "index": 1,
        "gloss": "personal affair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筆を生命の我が事業は凡てこの一脚を土台にして建設せらる。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたや又、我がなつかしき白村に翡翠白鯨我が事を語りてあらむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、やさしくもう一度訊かれて、圭子はついに、我が事のように頬を染めて、「お恥かしいんですけれど、ただ今｜酒場に出ております。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女に同情を持つ村の人々は我が事のやうにほつとした。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間の一小中学の言うに足らぬ私の結社であっても、それを我が事として関わりを持ち、愛を寄せるときには、たましいを打ち込む対象となり、喜びとなり、嘆きとなり、後になって限りなくなつかしい追憶となるのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が事、人の事と言わず、くだらない物が讃めてあったり、面白い物がけなしてあったりするのを見て、不公平を感ずるのである。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と我が事の様に嬉しさうに、莞爾しながら言つた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、奥間百歳が巡査を志願してると云ふ事が知れ渡ると、部落の人々は誰も彼も我が事のやうに喜んで、心から彼の合格を祈った。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "功立ち名顯るゝに隨ひ、いつしか自ら愛する心起り、恐懼｜戒愼の意弛み、驕矜の氣漸く長じ、其成し得たる事業を負み、苟も我が事を仕遂んとてまづき仕事に陷いり、終に敗るゝものにて、皆な自ら招く也。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同姓、右門とは我が事なるぞ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばちはてきめん、我が事も、人の背後に笑ふぞと、知らぬが花の模様もの、着た夫人の集会も、あながち長屋の女房達に、譲らぬが世の習ひなるべし。",
              "citation": {
                "source": "移民学園",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は我が事はや半ばなりぬと喜ぶ隙にも、方様はさすがお心咎めてや。",
              "citation": {
                "source": "葛のうら葉",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハ……番頭さんもお糸さんを、別品やというて誉めてる癖に、我が事は棚へ上げとかはるさかいをかしいわい。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が事となつては、さう悠長な量見も出ず。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平次、『千里の虎』を擧げた相だが、大層な手柄だ」　吟味與力笹野新三郎は、我が事のやうに喜んで待つて居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平次、『千里の虎』を挙げたそうだが、大層な手柄だ」　吟味与力笹野新三郎は、我が事のように喜んで待っていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「味が良うなったな」　将昭が目を丸くしてそうつぶやいたので、健一は我が事のように誇らしく思った。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、彼は結局のところ何も返答しませんでしたし、おそらくほんとうはまったく何も知らなかったのでしょうし、彼は私を逮捕して、それで我が事終れりという顔つきでした。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一面には、ヤッペとド・エスコバアルの位置に我が身を置いて、二人が感じているはずの、心をむしばむような感情を、おれは我が事のごとく胸中に味わわざるを得なかった。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が事に精一杯で、たぶんビンセント卿に伝えてない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が事で精一杯、神経が参っているけど、後悔する気もない。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰もが我が事のように思うだろう。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫礼は初め味方の手ちがいかと狼狽したのであったが、さはなくて蜀兵自身が火を放ったものと知ると、しまったと叫んで、「孔明はすでに看破しているぞ、我が事破る」　と、躍り上がって無念がった。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "きわだってすぐれたる作品を書き、わがことおわれりと、晴耕雨読、その日その日を生きておる佳い作家もある。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」夫人の嶮しい顔色に、女中はわがことのように顫えていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと新寺の開運地蔵としてお祭り申しあげるよう、特にあの六体を分けてやったものでござりますゆえ、そのお施主たちがわがことのように、あちらの寺へお力添えなさるはあたりまえでもござりまするし、別してねたむところなぞないはずでござりまするが、これこそほんとうに天魔に魅入られたというのに相違ござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "後学のため、ちっとだんなのつめのあかでももらって煎じて飲みな」　いつも変わらぬ右門のゆかしい一面をここにおいても見せましたので、すっかり伝六がわがことのように大みえをきりながら、さっそく命令どおり近くの自身番へ手錠を取りに駆けだそうとすると、まことに人は意気のものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぞりとひとなであごをなでりゃ、このとおりぱんぱんと眼がつくんだからね、景気よくぶっ飛ばすようにちょっくらと駕籠をめっけてめえりますから、お待ちなせえよ」　わがことのようにおどり上がって駆けだそうとしたとき、「お願いでござります！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に江戸も御繁昌かな」「はっ、近年はまた殊のほかの御繁昌にて、それもみな上様の御代御泰平のみしるし、恐れながら土州めも、わがことのように喜ばしゅう存じあげておりまする儀にござります。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はまだあれほどにはなっていず、目も鼻も正しい形をしていると思うのは、わがことであって身勝手な思いなしによるものなのであろうと気恥ずかしいような思いをしながら茫と外をながめつつ寝ていた。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
