        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "多分｜鰐の事だろうが、その説明がかなり面白いものである。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百分の一近辺のものは猩々、鹿、猫など、それから下って百分の一より千分の一の間にあるのが麒麟、象、羚羊、獅子、袋鼠、鷲、白鳥、雉、鼠、蛙、鯉など、なお一層下って千分の一より一万分の一の間には海馬、鯨、鰐、海鰻、章魚などがひかえている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて川に飛び込む鰐は、その飛び込む前に安息している川岸の石原と茂みによって一段の腥気を添える。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の先祖は爬虫だそうであるが、なるほどどこか鰐などの水中を泳ぐ姿に似たところがあるようである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐と虎とのけんかも変わっている。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐が虎をねじっているのか、虎が鰐をねじっているのか見たところではどっちだかわからない。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あのぐるりぐるりと腹を返して引っくり返る無気味さは、やはり、虎よりも鰐の属性にふさわしく思われるものである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇と鰐との闘争も珍しい見ものであるが、なにぶんにも水の飛沫がはげしくて一度見せられたくらいでは詳細な闘争方法が識別できにくいのが残念である。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の夕刊に青森県｜大鰐の婚礼の奇風を紹介した写真があって、それに紋付き羽織｜袴の男装をした婦人が酒樽に付き添って嫁入り行列の先頭に立っている珍妙な姿が写っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……エジプトの王様は代々、自分の妻を一晩｜毎に取換えて、飽きた女を火焙りにして太陽神に捧げたり、又は生きたままナイル河の水神様の鰐に喰わせたりするのを無上の栄華として楽しんでいた。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根裏より燻製の猿、鰐の子などが古血のように固まって垂れて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の向うは、鰐の泳ぐ、可恐い大河よ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船のある事……帆柱に卷着いた赤い雲は、夕日の餘波で、鰐の口へ血の晩御飯を注込むんだわね。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟と視て、「まあ……」　離すと、可いことに、あたり近所の、我朝の※樣を仰向に抱込んで、引くりかへりさうで危いから、不氣味らしくも手からは落さず……「島か、光か、拂を掛けて――お待ちよ、否、然う／＼……矢張これは、此の話の中で、鰐に片足食切られたと云ふ土人か。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　――港で待つよ――　と、恁う申すのではござりませぬか、と言ひも未だ果てなかつたに、島の毒蛇の呼吸を消して、椰子の峰、鰐の流、蕃蛇剌馬の黄色な月も晴れ渡る、世にも朗かな涼しい聲して、　――港で待つよ――　と、羽を靡かして、其の緋鸚鵡が、高らかに歌つたんです。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう晩かつたから、材木の森に谺する鰐口の響きもなく、露地の奧から笛の音も聞えず、社頭にたゞ一つ紅の大提灯の霧に沈んで消殘つたのが、……強ひて擬へるのではない、さながら一抹の丹頂に似て、四邊皆水。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「紙入に入つて居ます、小さいのが蝦蟇口……」　と此の分だけは、鰐皮の大分膨んだのを、自分の晝夜帶から抽出して、袱紗包みと一所に信玄袋に差添へて、「大丈夫、往復の分と、中二日、何處かで一杯飮めるだけ。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「（源三郎）……かくて竜宮に至りて宮中を見れば、その高さ三十丈の玉塔に、かの玉をこめ置、香花を備え、守護神は八竜｜並居たり、その外悪魚｜鰐の口、遁れがたしや我命、さすが恩愛の故郷のかたぞ恋しき、あの浪のあなたにぞ……」　その時、漲る心の張に、島田の元結ふッつと切れ、肩に崩るる緑の黒髪。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを登り尽した丘の上に、大きい薬師堂は東に向って立っていて、紅白の長い紐を垂れた鰐口が懸っている。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方に行った頃、武田麟太郎が鰐に食われて死んだという噂がひろがった。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田麟太郎が鰐を食ったのなら判るが、鰐に食われるようなそんな武麟さんかねと笑った。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐が一匹おったんや……」　と、話し出した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先づしめたもんだ、鰐の口の方でお逃げなすツたといふ奴よ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "不圖カン／＼鰐口の鳴る音が耳に入る。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ………」とお房は些と首を傾げ、箒を持つ手を止めて、「鰐口の音ですわ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "また待乳山で鰐口が鳴ツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは誰でも、人から非難せられたり、怒られたりしていい気持がするものでは無いかも知れませんが、自分は怒っている人間の顔に、獅子よりも鰐よりも竜よりも、もっとおそろしい動物の本性を見るのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこには気味の悪い海月や鮹や、恐しいあんかうや、鰐ざめなんかひそんでゐるだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」きっとそうだと思いながらも、そうあらわに質問して、これはいかんと狼狽した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
