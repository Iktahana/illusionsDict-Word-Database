          "literary": [
            {
              "text": "和光同塵とは申せども、神境、佛地である。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外翁は、所謂、讃めて言ふと、和光同塵と申すのでせうか。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房もあり子供もあり、葷酒はいうに及ばず肉食も勝手にやるようになった今日では、禅僧について居た古来の聯想や歴史を全く棄てて、当世風になるのが、所謂る和光同塵の精神かも知れぬ。",
              "citation": {
                "source": "僧堂教育論",
                "author": "――禅僧の友人に与う――",
                "note": "青空文庫"
              }
            }
          ]
        }
