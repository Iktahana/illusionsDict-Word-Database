[
  {
    "uuid": "8b9e88de-42b4-5c67-a74e-bbae7a63fc9d",
    "entry": "輪っぱ",
    "reading": {
      "primary": "わっぱ",
      "alternatives": [
        "ワッパ"
      ],
      "is_heteronym": false
    },
    "grammar": {
