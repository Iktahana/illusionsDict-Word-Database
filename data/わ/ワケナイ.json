        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがその危なっかしい血統が、龍太郎の誕生によってヤット繋ぎ止められたと思う間もなく、龍代自身の肉体に、早くもその忌まわしい遺伝病の前兆が、あらわれ初めたことがわかりましたので、まことに申訳無いが貴方に……つまり私にですね……情ない姿をお見せしないうちにお別れする決心をしました。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実は、今、金がまるつきり無いんで、……もう半歳以上たまつてゐるんで実に申訳無いと思つてゐるんだけど……それに荒物の借りも相当溜つてゐるしね。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな場合にも、このｅとyeとを同じ文字で書いたことは、東京語における語頭のガ行音と語頭以外の鼻音のガ行音とを文字に書きわけないのによっても理解することが出来る。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金ですむ事なら、わけないけれども、女たちが、それだけで引下るようにも思えない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎はじつに申しわけないと思って、足の痛いのも忘れてしょんぼり肩をすぼめて立ったのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首をシュッポオンと切ってしまう位、実にわけないはなしだ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、ちょっと離れとりますが、歩いてもわけないですよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがいい、あんた何も堂島さんにこんな目にあうわけないでしょう」　磯子が、そう訊いたとき、磯子自身ですら悪いことを訊いたものだと思うほど加奈江も明子も不快なお互いを探り合うような顔付きで眼を光らした。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肥るわけないじゃないの」　汽笛が高らかに響き渡った。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで、古なじみの義務を放棄するわけないではないか。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「例の男に目星を付けたら証拠はわけない。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、そうやすやすと連盟員になんてなれるわけないってね。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、機に起つと、「わけないぞに、一緒に行こうかに。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長の藤田さんはお留守だったので、受附の娘さんに紙包を差し出し、「昨夜は、申しわけない事を致しました。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけ部屋があまってんだから、ダメだなんて、いうわけないだろ」５ラジオをつけて、グルッとダイアルを回すたちまちダンスのはじまりだ〈ダンス、ダンス、ダンス〉ビーチボーイズ　ＫＷＴＳの「開局」は、六月二十日に決まった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがいうわけないじゃんか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、あんなところから、見えるわけないだろ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことが、百科事典に出てるわけないだろ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "タバコや酒はないだろうな」「あるわけないでしょ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出したばっかなのに、またすぐＬＰが出るわけない」　服部がこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが去年よりドラムがヘタになったことだって、ちゃんと知ってる」「会議で、そんな話がでるわけないじゃん！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ、おそろしく剣呑な奴で、教師のひとりやふたり、気に入らなければ、叩き出すのはわけない、なんていうんですからね」　高志がクスクス笑いながら、いくらなんでも、ふたりいっぺんはムリだ、とつぶやいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、いくらおまえでも、そんなに細いわけないけどな」　憤然として、慶一はパンツのヒモを内側にたくしこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "心当たりはないのか」「あるわけないですよ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ云つてしまつては加藤君との約束を破ることになつて申しわけないんだが、村瀬さんのその蒼ざめた真剣な顔を見ては黙つてゐるわけにはゆかない――ねえ、村瀬さん、貴方の病気を治したがつて、皆なで工夫したんですよ。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この許可されないシナリオの中に、どうやら私の書いたものもまじつているらしいので、これは何とも申しわけない話だと思つている。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ジェンナーは、いつまでもぐずぐずしていては、恩師ハンター先生に対してももうしわけないと思い、二十九｜歳のときいよいよ種痘の研究にとりかかりました。",
              "citation": {
                "source": "ジェンナー伝",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまた巫女を頼むと、それは前の娘が音頭をとり先綱をとって曳いたらわけないとのこと、そうするとたちまちやすやすと石は軽く動き出して山上に曳き上げられ、いまの所に来座せしものだという。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "血をわけない子供に、こうした自然の愛情の湧くものかどうかの判断が、子を産んだ経験のない自分には、つきかねるように思えた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "決断のとき「いくらいいもの作ったといったって、セールスルートがなきゃ売れるわけないだろう」　マイクロソフトのベーシックを積み、市場に出回っているパーソナルコンピューターを大きく上回る性能を持つと、ＰＣ―８００１の素晴らしさを謳う渡辺に、大内は切り返した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
