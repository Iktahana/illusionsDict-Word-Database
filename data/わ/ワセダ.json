    "definitions": [
      {
        "index": 1,
        "gloss": "field of early-blooming (or ripening) rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明治四十一年一月の「早稲田文学」に現れた、花袋の代表作の一つであろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙で包んだ花鉢をだいじにぶら下げて車にも乗らず早稲田まで持って行った。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、代表的な学校、（帝大、早稲田、慶応、目白女子大学、東京女子医専など）をえらび、毎月連載したいと思います。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば君が住まわれた渋谷の道玄坂の近傍、目黒の行人坂、また君と僕と散歩したことの多い早稲田の鬼子母神あたりの町、新宿、白金……　また武蔵野の味を知るにはその野から富士山、秩父山脈｜国府台等を眺めた考えのみでなく、またその中央に包まれている首府東京をふり顧った考えで眺めねばならぬ。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西片町にしばらくいて、それから早稲田南町へ移られても自分は相変わらず頻繁に先生を訪問した。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか早稲田の応接間で先生と話をしていたら廊下のほうから粗末な服装をした変な男が酔っぱらったふうでうそうそはいって来て先生の前へすわりこんだと思うと、いきなり大声で何かしら失礼な口調でののしり始めた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨終には間に合わず、わざわざ飛んで来てくれたＫ君の最後のしらせに、人力にゆられて早稲田まで行った。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう同門下の人たちと先生没後の今日、時おり何かの機会で顔を合わせるごとに感じる名状し難いなつかしさの奥には、千駄木や早稲田の先生の家における、昔の愉快な集会の記憶が背景となって隠れているであろう。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円山｜曰く『どこで修業するつもりだ』、『Ｗ専門学校に行って矢部さんの講義を聞こうとおもう』、『札幌から紹介状でも貰ってきたか』、『来ん』、『じゃ俺が書くからこれから行ってみろ』……辞儀を一つする……貰いものの下駄をはく……歩く（ここは長し）……早稲田という所は田圃の多いところだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　早稲田文学、文章世界、帝国文学、新小説。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう早稲田には穂が出てゐる。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏さんは、所謂「早稲田界隈」をきらいだと言っていらしたのを、私は聞いている。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、私は、井伏さんと一緒に、（何の用事だったか、いま正確には思い出せないが、とにかく、何かの用事があったのだ）所謂早稲田界隈に出かけたことがあったけれども、その時の下宿屋街を歩いている井伏さんの姿には、金魚鉢から池に放たれた金魚の如き面影があった。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、早稲田界隈の下宿生活には縁が薄かった。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を長く伸ばして、脊広、或いは着流し、およそ学生らしくない人たちばかりであったが、それでも皆、早稲田の文科生であったらしい。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稲田界隈の親分を思いがけなく迎えて、当然、呑むべきだと思っているらしい気配なのだ。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏さんと早稲田界隈。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　早稲田界隈の下宿街は、井伏さんに一生つきまとい、井伏さんは阿佐ヶ谷方面へお逃げになっても、やっぱり追いかけて行くだろう。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三巻の後記に於て、私は井伏さんと早稲田界隈との因果関係に触れたが、その早稲田界隈に優るとも劣らぬ程のそれこそ「宿命的」と言ってもいいくらいの、縁が、井伏さんの文学と「旅」とにつながっていると言いたい気持にさえなるのである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都府立京都第一中学校を昨年卒業し、来年、三高文丙か、早稲田か、大阪薬専かへ行くつもりです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁護士の試験をうけるために早稲田の講義録をとっているという木下は、道で年頃の女に会うときまって尻振りダンスをやった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ずっと以前にも、そうだ、明治三十八、九年の早稲田時代にも、私たちは下宿から下宿へ引越車の後を蹤いてゆく時にも、ニッケル製のランプを片手に捧げて、とぼりとぼりと歩いたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、また、「医専、慶応、早稲田ァ、二高、日本歯科、青年団、写真班、鹿児島ァ起きろ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "回顧すれば七歳のむかし、我が早稲田にありし頃、我を迷はせし一幻境ありけり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早稲田文学」の史劇論其の第一なり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「読売」の高田半峰氏発起して歴史脚本を募れるは、「早稲田」の史劇論に続て、劇詩界の高潮を報ずる者なれ。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理な事をさせてはならないというので、傍から勧めて早稲田に入れることにした。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう生まれ合わせだと皆はいうけれど、そうばかりは思われない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして腕をぶる／＼振わせだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうちっと長生きをしていりゃ、そのうちにはおれが仕方を考えて思い知らせてやろうものを、ふしあわせだか、しあわせだか、二人ともなくなって、残ったのはおまえばかり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
