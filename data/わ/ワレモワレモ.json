    "definitions": [
      {
        "index": 1,
        "gloss": "vying with one another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病男病女が我も我もと詰め懸ける。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば一｜皿の菓子、一｜盞の珈琲に、一円、二円と擲ちて、なおも冥加に余るとなし、我も我もと、入交り、立替る、随喜の輩数うるに勝うべからず。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒は我も我もと先を争うて明い処へ飛び出して来た。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お薬師様でお通夜していたものが殺された、神様も頼みにならん」　薬師堂の参詣に来ていた者がこう云って我も我もと逃げ帰ったので、それからは何人一人参詣するものもなくなり、それがために薬師町は衰微してしまった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流の士は愛卿のことを聞いて、我も我もと身のまわりを飾って狎れなずもうとしたが、※学無識の徒は、とても自分達の相手になってくれる女でないと思って、今更ながら己れの愚しさを悟るという有様であった。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると舟の上にいる旅人が争うて我も我もと肉をなげてくれた。",
              "citation": {
                "source": "竹青",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると我も我も、と十人ほどの声があがる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣たちが我も我もと随行を望んだ。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう大官や名家の折紙が附いたので益々人気を湧かして、浅草の西洋覗眼鏡を見ないものは文明開化人でないようにいわれ、我も我もと毎日見物の山をなして椿岳は一挙に三千円から儲けたそうだ。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は諏訪町、駒形方面から、一方は門跡から犇々と火の手が攻めかけて来るのだが、その間は横丁の角々は元より到る処荷物の山で、我も我もと持ち運んだ物が堆高くなっている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは官軍が彰義隊から分捕った糧米を、その見物の連中に分配しますと、我も我もと押し迫り、そのゴタゴタ中に一俵二俵と担いで行く……大勢のことで、誰がどうしたのか、五十俵百俵はたちまち消えてなくなる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "上野戦争当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし誰かが刈り出すと、にはかに氣忙しくなつて、我も我もと驅り立てられるやうに先を急ぎ後れまいとする、そのやうなのが百姓の心理だと駿介は聞かされたことがある。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで餘り山へは出かけなかつたものも我も我もと出かけるやうになるだらう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぶさりたいといふものが我も我もと出て來て、また一もめもめたあとで愈々出發となつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手桶薬缶抔を提げたる人だち我も我もと押し掛くる事故我ら如き弱虫は餓鬼道の競争に負けてただ後ごみするのみなれば何時飯を得べくとも見えざるにぞ思ひかねて甲板の右舷より大廻りして他の口に行けばここも同じ事なり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "是においてか新聞記者は四方より集まりて我も我もと従軍を希望して已まず。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことをやり出すと他の児童の邪魔になって教室で我も我もと質問するようになっては規律がなくなるから、そういう一風変った児童は特別な学校を造って教えたならばよかろうという説もありましたが、果してそう出来るなら面白い。",
              "citation": {
                "source": "教育家の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも二十歳前後の娘さんとみえますが、なかに一人、豊かに肥えた肩をむきだした洋装の、だぼ沙魚みたいなお嬢さんが、リイダア格で、「サインして下さいよう」とサイン帳をつきだすと、あとは我も我もと、キャアキャア手帳をつきつけます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると我も我もと三人五人続いて上陸する。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我も我もと天幕を出て隊長の周囲へ集まった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給千円、食事づきで雇ひたいと申しでると全員にわかに殺気立つて我も我もと申出るのを押しとゞめ一室をかりて一人づゝ口答試問を行ふ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸市中の見物は、我も我もと押しかけて来ましたけれど、大尽の妾宅の門まで来て見ると、急に二の足を踏んでしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために、いったん二の足を踏みかけた見物が、みすみす目玉の飛び出るほど高い場代を払って門の中へ入り込むと、人気というものはおかしなもので、ついには我も我もと先を争って切符を買うような景気になって、門内へなだれ込みます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が王子稲荷の踊りへ出かけるという話を聞くと、べつだん誘いをかけたわけでもないが、化物屋敷に居合わせた御家人崩れの連中が、我も我もとお伴を志願することになった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子は喜び勇んで我も我もと慰藉料を請求したいにきまっているが、女の子は払ってくれないね。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "のれんを誇った料理の老舗も、「ふぐは扱いません」などとはいっておられず、我も我もとふぐ料理の看板を上げつつあるのが、きょうこのごろの料理屋風景である。",
              "citation": {
                "source": "河豚は毒魚か",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上憶良の言い草ではないが、白銀と黄金と珠とを人間第一の宝として尊重せられた奈良の御代において、陸奥から黄金が発見されたと聞いては、我も我もとその宝の山に分け入りたくなる。",
              "citation": {
                "source": "炭焼長者譚",
                "author": "系図の仮托と民族の改良",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、やがて夜になると、そうした塵の大群は、われもわれもと大空に匐い上って、都の光明を雲の上まで高く高く吸い上げて、夜もすがらの大火事を幻想させる一方に、愚かしい山々や森林の形を地平線上に浮き出させて、力ない、疲れ切った農民の眠りを見守らせているのだ。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかまろう、つかまろう」　こうして、みんなが、われもわれもと、すがりつくのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを構わずに夫婦はやがてその見世物小屋の前に来て、お金を払って中に這入りますと、あとからついて来た黒山のように沢山の人間も、夫婦の珍らしい姿が見たさにわれもわれもとお金を払って中に這入りましたので、大きな見世物小屋が一パイになりました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
