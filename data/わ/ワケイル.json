    "definitions": [
      {
        "index": 1,
        "gloss": "to make one's way into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金鉱を発掘する人は、親や妻子より遠く、山中に分け入るのだ。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が門川で下りて、更に人力車に乘りかへ、湯ヶ｜原の溪谷に向つた時は、さながら雲深く分け入る思があつた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに中央線の汽車で甲州から信州へ分け入る際、沿道の民家の建築様式あるいは単にその屋根の形だけに注意してみても、私の言うことが何を意味するかがおぼろげにわかるであろうと思う。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くこと数里、深山幽谷深かく分け入ると、谿川の流れ巌に激しく、奔流矢を射るごとき淵に出た。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は又、曾て読んだ八犬伝の中で、犬飼現八が庚申山に分け入るの一段を思い出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾路の山へ分け入ると、折々に不思議を見る。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにやら道をまちがへてゐたが、――それがかへつてよかつた――山また山、青葉に青葉、分け入るといつた感じだつた、蛙声、水声、虫声、鳥声、そして栗の花、萱の花、茨の花、十薬の花、うつぎの花、――しづかな、しめやかな道だつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "大田への道は山にそうてまがり水にそうてまがる、分け入る気分があつてよい、心もかろく身もかろく歩いた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅の前を流れている濁った堀川に沿うて半町ぐらい上ると川は左に折れて旧城のすその茂みに分け入る。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のわきに少し分け入ると、ここだけは特別に樫や楢がこんもりと黒く茂っている。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火縄銃を執つて分け入る時凡そ如何なる野獣でも適当の距離に於て彼の目に入つて其筒先に斃れないものはなかつた。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつかお前の方まで分け入るぞよと輝き渡る藤原郷の奧山を望んで思つたものであつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつかお前の方まで分け入るぞよと輝き渡る藤原郷の奥山を望んで思ったものであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵から抜け出たようなといったその美男のところに、なぞの山へ分け入る秘密の間道があるに相違ないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方が初めて平定した時、四方を巡回して南山の深いところへ分け入ると、日もようやく暮れかかって来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、薪を伐るために、妻と妹をつれて山の中へ分け入ると、奴僕はだしぬけに二人に言った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けてから神坐のあたりを調べると、なま血のあとが点々として正門の外までしたたっているので、李はその跡をたずねて、山を南に五里ほども分け入ると、そこに一つの大きい穴があって、血のあとはその穴の入口まで続いていました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊この一切の無益なる世の煩累を振りすてゝ、もの恐ろしく汚れたる都の憂あとにして、終に分け入る森蔭の清しき宿求めえなば、光も澄める湖の静けき岸にわれは悟らむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊この一切の無益なる世の煩累を振りすてゝ、もの恐ろしく汚れたる都の憂あとにして、終に分け入る森陰の清しき宿求めえなば、光も澄める湖の靜けき岸にわれは悟らむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪から汽車で、一時間半ばかり乘つてゆくうちに、はや私達はかなりの山間に分け入る思ひをした。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く分け入るうちに古めかしく物錆びた一宇の堂の前へ出た。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽州米沢の典薬｜勝成裕が、御隠居｜上杉鷹山侯（治憲）の内意を受けて、一行十五人、深山幽谷に薬草を採りに分け入るという、その時代としては珍らしい計画が立てられた。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代はむかし幕府の将軍夫人が硯水を京都から取りよせる話を読んで、贅沢のたしなみ過ぎたるものと思っていたのも、事実いま東野の話で、日常の苦心の細やかさもそこまで深く分け入るものかと感服をあらたにした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五月十二日、鎌倉を立ちて甲斐の国へ分け入る。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　塩尻から五千石通りの近道を、松本の城下にはいって、机竜之助と、お雪ちゃんと、久助の一行は、わざと松本の城下へは泊らずに、城下から少し離れた浅間の湯に泊り、そこで一時の旅の疲れを休め、馬をやとい、食糧を用意して、島々谷の道を分け入ることになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に銀山女魚といわれる魚で、鱗が白銀色に光って美しいのであり、濁り川は、鬼の押し出し所に湧きでるが、密林が深く夏場は分け入るのに困難だ。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもちろん岩窟の老人も私が森林へ分け入ることを非常に嫌っているらしかった。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道行く旅人、野に分け入る百姓｜等は相｜戒めて、決して琵琶池の辺りに近かないという。",
              "citation": {
                "source": "森の妖姫",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔だつたら、一旦かうと思ひ込んだらどんなに路のない所でもガムシヤラに突進したものが、今では自信がなくなつて、様子の知れない所へ分け入ると怖気がついて、ひとりでに足がすくんでしまふ。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またバスではいったん海へでて別の谷川沿いにまた山中深くわけいるのだから歩く方が時間的にも早いぐらい。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
