    "definitions": [
      {
        "index": 1,
        "gloss": "side (of the torso)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
