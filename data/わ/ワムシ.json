        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "・土の虫のちぎられたまゝ土にもぐる　月にむいて誰をまつとなくくつわむし　ふけてあぶらむしがはふだけ・住みついて煤のおちるにも（改作）　十月十六日夜あけのしぐれはさびしくわびしく身にしみた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "よわむしな私は芝居がこわくて、大きらいだったのに連れていっては失敗していた。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の音にも、まつむし、鈴虫、くつわむし、それぞれ趣きがあってよい。",
              "citation": {
                "source": "音の世界に生きる",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ健坊よわむしだね、百合ちゃんはこわくないよ、ホラ、何でもないじゃないか！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃあ　おんなみたいに　よわむしか？",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「死ぬの、おしいもん」「よわむしじゃなあ」「そう、よわむし」　そのときのことを思いだすと、今もむしゃくしゃしてきた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よわむしだなあ。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまだって、そんなよわむしは、たすけてくれやしない。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
