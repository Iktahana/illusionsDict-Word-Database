        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蜻蛉の形をしたこの島山の胴のまん中に、岩と岩との幅広い断れ目の溝があって、そのあわいから、わたくしは生い立たせられつつあるのを見出したのでした」　西の海を越えて、うねって来た二つの大きな山の脈系、それは島山の胴の裂け目を界にして南北に分けられる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから宅へ帰っても、しかられるのがこわいから、この事は両親にもだれにも話さないでいた。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬に復讐されるのが、こわいから、しかたなくそっとしておいてやっているのだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく食欲を満足したあとでアイスやコーヒーを味わいかけていい心持ちになっている時分に、これが始まるのである。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっちゃくて、かわいかったそうだ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、噴火でどんな場合が一ばんこわいかね。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプの、てごわいかたきが出て来たわい、と思った。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が因業な親爺や思たら、わいかテあの時ただの俥ひくもんかいな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにわたくしはこんなにかよわいからだではございますが、ついぞ病気をいたしたことはございませんから、島へ行ってから、どんなつらい仕事をしたって、からだを痛めるようなことはあるまいと存じます。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママこわいから厭さ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いうなじが透きとおるようにきれいで、それが自分にはただかわいかった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんちゃんとんちゃん」という声も、いつものごとくにかわいかった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしこわいから我慢しようかと思っていたんだけれど、お松さんと一しょなら、矢っ張行った方が好いわ。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ひとりではこわいから、そんなら一しょに行ってよ。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮様が来ていらっしゃるのでしょう」　と言ったので、起きて来て、「少納言、直衣着た方どちら、宮様なの」　こう言いながら乳母のそばへ寄って来た声がかわいかった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいかった小女王を思い出して、源氏は独り笑みをしながら又寝をした。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたも書いてごらんなさい」　と源氏が言うと、「まだよくは書けませんの」　見上げながら言う女王の顔が無邪気でかわいかったから、源氏は微笑をして言った。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二条の院へ帰って源氏の見た、半分だけ大人のような姿の若紫がかわいかった。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれも同じ型の人はないものですが、その人は才女らしい、りっぱなというような点は欠けていたが、上品でかわいかった」　などと源氏が言うと、「でも、明石の波にくらべるほどにはどうだか」　と夫人は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだにふだんからかよわいからだの女房は苦労の重荷に圧しつぶされて、その明くる年の春に気病みのようなふうで脆く死んでしまった。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その殿様というのはエラソウで、なかなか傲然と構えたお方で、お目通りが出来るどころではなく、御門をお通りになる度ごとに徳蔵おじが「こわいから隠れていろ」といい／＼しましたから、僕は急いで、木の蔭やなんかへかくれるんです。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、そなたのようにかわいかったでありましょうな」「はい、みなさまが源空寺の豆兄弟、豆兄弟とおっしゃいまして、ときどきないしょに、くりのきんとんなぞをくださりました」「ほほう、くりのきんとんをとな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれはちゃちな野郎だろうが、念のために首実検しようかい」　おどろきもせず、たれのあわいからのぞいてみると、これが早い、――年のころは三十七、八、町人づくり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "主水之介は打ち笑みながらふりかえると、襖のあわいから血走った目をのぞかせて、いざとなったら躍り出そうと身構えていた京弥へ静かに命じました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こうなりゃお多根のかたさまがどんなにいじらしくて、すなおで、かわいかろうとも、おれの目にゃ如夜叉なんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだとて、またあんないれずみをしたんです」「かわいかったから、ただもうかわいかったからでござんす」「なに！",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう、ただもうかわいかったからなのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、あれはいちいちやることがかわいかったね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
