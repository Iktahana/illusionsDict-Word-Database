    "definitions": [
      {
        "index": 1,
        "gloss": "bowl-shaped",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
