        "index": 1,
        "gloss": "impossible to do (although wants to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あなた一人でなく、現にわたくしも見たのですから、心の迷いとか、眼のせいだとかいう訳にはいきません。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでコローボチカは、『そんな死んだものを売る訳にはいきません』って、如何にも尤もな答えをしたんですよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺を幕府の細作とも知らず、俺の詭計に引っかかるとは思えば気の毒な連中ではある」　惻隠の情とでもいうのでしょうか、こういう感情が湧くと一緒に自己｜譴責の心持も、起こらない訳にはいきませんでした。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょろ松は、へこたれて、「うけあうという訳にはいきませんが、まあ、ひとつやってごらんなさいまし」「まあ、じゃ、いやだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "パトラッシュは、荷車のそばに倒れて、そのまま死んでしまいたいと思いましたが、少年が生きてパトラッシュを必要とする間は、弱音を吐いて降参する訳にはいきませんでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんなせまいところでは、そういうわけにはいきません。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、起きあがるわけにはいきません。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ですけど、うちの息子は、アリの塚へやるわけにはいきません。",
              "citation": {
                "source": "幸福な一家",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、アンネ・リスベットの子供は、そういうわけにはいきませんでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんなせまいところではさういふわけにはいきません。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、かうなつては、ぢつとしてゐるわけにはいきません。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんなせまいところではそういうわけにはいきません。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人ののどがちょうどしんたのむねあたりで乾かぬわけにはいきません。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、すゞちやんは、まだたうぶんは、そつとねかせておかなければならないので、ぽつぽのところへつれていくわけにはいきませんでした。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも兵たいですから、涙なんぞを見せるわけにはいきません。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ケリムは、最初六ぴきはたしかにゐると言つた手まへ上、そのまゝ引つこんでしまふわけにはいきません。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるっきりなしというわけにはいきませんわ」「知れたことさ。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に髪が白いというだけのことで、それが山岸に祟っている怪しい女であるなどと一途に決めるわけにはいきません。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからしばらくの間は鉄砲も持たずに、馬を連れて歩くってわけにはいきませんよ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはこれから手袋編みだけで食べていかねばならないんですから、引っ越すわけにはいきません。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが晴れるまで、元と同じというわけにはいきません。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、いやでもたましいはかえってこないわけにはいきません。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二のお話　　　男の子と女の子　たくさんの家がたてこんで、おおぜい人がすんでいる大きな町では、たれでも、庭にするだけの、あき地をもつわけにはいきませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても日帰りというわけにはいきませんので、先方に二晩泊まって、火曜日の朝帰って来るということでしたが、修学旅行以外にはめったに外泊したことのないわたくしですから、ともかくも両親に相談した上で御返事をすることにして、その日は継子さんと別れました。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒ですが、むろん助けるわけにはいきません。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういうわけにはいきませんね。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、僕を信用して下さったついでに、もう一歩すすめて、ほんの少しでも事情をお話し下さるわけにはいきませんか？",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれにしても、あのホテルにいるわけにはいきませんねえ。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら親友の間柄でも、その秘密を無理にさぐり出すわけにはいきませんから、わたくしも唯黙って聴いているよりほかはありませんでした。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらで無関係と認める人間を立ち会わせるわけにはいきません。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
