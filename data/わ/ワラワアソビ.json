        "examples": {
          "standard": [
            {
              "text": "広場で童遊びに興じる子供たちの声が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は、日が暮れるまで童遊びをして過ごしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大人が見れば単純な童遊びでも、子供にとっては真剣な世界だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これは又、べろ／＼の鉤とも称せられて、童遊びとしての分布も可なり広い。",
              "citation": {
                "source": "鷹狩りと操り芝居と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、童遊びのまゝごと・おつかさんごとなどいふ形を生み出した、元の姿として見るべきであらう。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
