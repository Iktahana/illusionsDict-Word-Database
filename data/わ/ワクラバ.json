[
  {
    "uuid": "226e3efe-ff34-5b5a-ae98-909d52906f37",
    "entry": "病葉",
    "reading": {
      "primary": "わくらば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "blighted leaves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼れの乘つて來た船は霧の大河の水底に沈んだ一枚の病葉に過ぎない。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや黄なる風景白き猫枝にかがやき、ゆりの木の病葉黄なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い葉や既に枯れかかつた病葉は一溜もなく八方に飛び散り、木は根から大揺れに揺れる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の音も時節に連れて哀れに聞える、淋しい……ソラ風が吹通る、一重桜は戦栗をして病葉を震い落し、芝生の上に散布いた落葉は魂の有る如くに立上りて、友葉を追って舞い歩き、フトまた云合せたように一斉にパラパラと伏ッてしまう。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "病葉がサラサラと降って来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白楊の中には、枝が引き裂けたまま、幹からすっかり離れもせずに、病葉と一緒にだらりと下へ垂れさがっているものもあった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がここに書こうとする小伝の主｜一葉女史も、病葉が、霜の傷みに得堪ぬように散った、世に惜まれる女である。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "剪裁されたばかりの青枝を跨ぎ、寛ぎの出て来る小丘を降りてからもう病葉の散る橡の樹の下へ出ると「新アジヤ」という東野の演題がまた矢代に泛んで来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "向かい合った三人の空間を、病葉が揺れながら一葉二葉落ちた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処からともなく流れ来る微風に、常緑樹の病葉や落葉樹の紅葉は、何等の努力もなく如何にも自然に、梢から地上へと舞い落ちる。",
              "citation": {
                "source": "秋の気魄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "病葉が風に散るのだろう、肩の上へ落ちて来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十九日（月曜）　昨夜句あり　○白猫の足裏に散る萩の花　○竹の露しとど檐打つ夜半もあり　○はためくや遠稲妻に虫の声　今日　○鎌切の恋のかたみか雄の翹　○桜並木｜病葉の下犬二匹　○赤松の根に露草は咲きやらず九月二十二日（木曜）　アルキペンコの作品が面白かったものの一つです。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、狂花（腹立上戸）、病葉（眠り上戸）、酒悲（泣き上戸）、観場害馬（理屈上戸）などもやってくる。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きはらふ河風に桜の病葉がはら／＼散る。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きはらう河風に桜の病葉がはらはら散る。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら人なき家の如く堅くも表口の障子を閉めてしまった土弓場の軒端には折々時ならぬ病葉の一片二片と閃き落ちるのが殊更に哀深く、葭簀を立掛けた水茶屋の床几には徒に磨込んだ真鍮の茶釜にばかり梢を漏る初秋の薄日のきらきらと反射するのがいい知れず物淋しく見えた。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "色づいた病葉が微風にあおられ体の上へ落ちて来たりした。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝葉が揺れ、病葉が舞い落ち、焚火が靡き、草が翻り、そうして姥の白髪と白衣とが、白い※のように閃いた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお焚火はトロトロと燃え、土釜からは湯気が薄白く立ち、風に煽られて病葉が、ひっきりなしに、散って来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっきりなしに病葉が散った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から部屋の中へ差し出されている楓の、血のように紅い病葉が、吹き込んで来た風に揺れたばかりであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色づいた楓の病葉が、泉水の中へ散ったらしい。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病葉が彼方にも此方にもはらはらと散ている。",
              "citation": {
                "source": "捕われ人",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと空しく、もつと汚れた生活を送りながら、而もその空しさと穢さとを意識し拔いてゐながら、猶病葉が秋の梢に縋り付くやうに、此生活に對する未練を斷絶し得ぬ俺の心弱さと俺の決定心の乏しさとを何と云はう。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と音がするのは庭の柿の病葉が散りかかるのであろう。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い桜の幹が黒ずんだ色のなかから、銀のような光りを秋の日に射返して、梢を離れる病葉は風なき折々行人の肩にかかる。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その振りがようやく収ったと思う頃、颯と音がして、病葉はぽたりと落ちた。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の病葉が一枚、ひらひらと舞ひ落ちて、ぼつりとそこに浮ぶ。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時ならぬ花見の催しに、あたり近所が急に春めいてきて、病葉の落ちかかる晩秋の桜の枝に花が咲いたようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわくらばのてすさびにすゞろにゑへるひとごゝろかすかにもれしともしびにはなのすがたはてりしとか。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
