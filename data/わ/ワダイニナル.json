    "definitions": [
      {
        "index": 1,
        "gloss": "to be in the news",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらにＡＭＤは一九九一年秋のコムデックスでマイクロコンピューターの電源電圧を落とす新しい提案を行うという話だったので、「これは話題になるぞ」とオレは踏んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらぬ事までも二人は競争して人の話題になることも多いのである。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は屋敷と新聞を分け合って読んでいても共通の話題になると意見がいつも一致して進んでいく。",
              "citation": {
                "source": "機械",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が旅をしても、この頃、世間の所謂低山ばかりを歩いて居るのは、一つはさうしたやるせないものから身をかはさうと言ふ気があるに違ひない國木田氏の書き物に執した人々の間には、「忘れ得ぬ人々」と言ふ短篇が、よく話題になる。",
              "citation": {
                "source": "山の音を聴きながら",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして話が落付いてきて、まじめな話題になると、島村も相当に口を利いた。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパートのオカミサンなどというものはアパート内の物品が右から左へ動くだけの変化にも鋭敏で、砂袋がふえていれば、すぐ話題になる性質のものなのである。",
              "citation": {
                "source": "推理小説について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "時によつて、これらの文章が、青年諸君の間で話題になることも望ましい。",
              "citation": {
                "source": "『敗戦の倫理』編者のことば",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉町ではこうした記事が大いに話題になるから、その方面に敏腕なのがそろっているものだ。",
              "citation": {
                "source": "能面の秘密",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロベエル・コンシャアルの印象が話題になる。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　日本人の自尊心と云へば、既に早くから世界の話題になるほど「手のつけられない代物」であつた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても志野は、実に立派な陶器であるがために、立派な話題になるのである。",
              "citation": {
                "source": "志野焼の価値",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんが話題になる場合はわけても心苦しくなつてくる。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、あらゆる人間が人の話題になるような奇妙な身の上をしているのですな」「なるほど」　まったく、人生はそんなものかも知れない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身にしても、梶せつ子と関係をもつに至った一夜の出来事などは、人の絶好な話題になるものであろう。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一時暴風雨の事が話題になる。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈火会が集ると、今にこれが話題になる。",
              "citation": {
                "source": "吉川さんの声と眼",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "気狂いなら失踪しても云いわけはたちますが、しかし、世間の話題になるのは困りますからね。",
              "citation": {
                "source": "和製椿姫",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "交友録黒坂達三君のこと　和辻哲郎君と私との共通話題になる播州人が一人ある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に注意されてしかるべき点は、類似宗教中、最もインチキな部類にぞくすると見なされて、社会で兎や角話題になるものの大部分が、何等かの神道に関係の深いものだということだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等よく話題になるのも、話してゐて嬉しさうに見えるのも、あなたのことなのですよ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが読まれて話題になる頃には、何時だって大体もうその状態はぬけているのに。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「迚もいいわよ、可哀そうなのよ」という話題になるのに。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、こんなテーマはテーマの本質をとらえているものの間で話題になるべき種類のことではありませんから、私は黙っていたわけでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてラウベルの会話は、音楽以外の話題になると面白かった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽論が席の話題になる――頃を見計らって、また道庵が、今度は山陽をホメ出すこと。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくみんなと飲んでるときなどウルトラマンだとか仮面ライダーだとかいった昔の子供向け番組のことが話題になると、自分が誰よりも熱心にしゃべる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶世か何うか、奥田君のところへ行って妹に訊けば分るし、尚お好い話題になる。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆丈夫ですが、田舎の高等学校へ行っている次男がこの頃｜痔を患っています」　なぞと矢張り子煩悩と見えて、息子さん達が屡※話題になる。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話題になるついでに、ぼくはラジオの代金を現金で払った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "国許では、知られている刀で、物干竿という名があるくらいです」　無口だと思いのほか、自分のすきな話題になると、美少年は問わないことまで語りだした。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
