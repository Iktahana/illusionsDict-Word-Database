        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女　あたしが此の間片附けて帰つてから、まだ三日ばかしにきやならないんだけれど、まあまた散らかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（書き始める）女　まあ奇麗な字を書くわねえ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ペンを擱いて向き直る）女　恰度よかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからはかうして部屋に籠つて煖炉のそばにゐるのが一等好いわね、あなたは幸福だわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも小説家の前でそんなこといふと嗤はれるわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の肥つた女達は、私のや私の前の男のネクタイを見ながら、「まあ勉強しますわねえ、八十銭であんな物まで附けるのですものねえ……ええェ」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、「ああ好いですわねえ」とその一人が云つた、「先代萩の序幕……あの舟はしつかり出来てますわねえ、かかりますでせうねえ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川だわねえ、お母さん。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんも呆れたらしく、私の部屋を拭き掃除しながら、お客さん、馴れたら惡くなつたわね、としんから不機嫌さうに呟いた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう、道理でお腹の出来てる顔付だわね。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなになんでも延長したり質の問題にして考へたりしてたら御飯も食ふ時間がなくなりますよ」「さうかしら……」「女としては物分りの好い方だし、昨日の昼迄ならさうだわねと位に言つて呉れたんだらうにな……」と彼はさう思つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "百数十年も昔に作った蕪村の詩が、明治の新体詩より遥かに芸術的に高級で、かつ西欧詩に近くハイカラであったということは、日本の文化史上における一皮肉と言わねばならない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内は、その新聞を讀んで、「でも、よかつたわねえ。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、木魚を頬ぺたに吊してゐるやうにも見えるわね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに若い女の聲でしたわね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、みなさん、何とかして逢はせてあげたいものだわねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どつちも、どつちだわね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武士は食わねど高楊子」主義で突っぱった当時の青年文士は、いいかげんシビレを切らしても、原稿料の催促はしたくなかった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花として美しく開くものは、つぼみとしてまず麗わしく装わねばならなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みて「高根の雪」なる美しい語が、我が日本の古くからの歌に散見するのも、我が山岳国には欠かれない存在であると云わねばならない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドブンとも云わねえや。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "叶わねえなあ、こんな手合にかかっちゃ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔付きにも似合わねえ野郎だ！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遁げろ」って何故云わねえんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "削って、出汁にして、食われて失くなってしまわねばならない、なんて法はない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い奴を腹ん中へ入れといて、上下から焙りゃこそ、あの位に酔っ払えるんじゃねえか」「うまくやってやがらあ、奴あ、明日は俺達より十倍も元気にならあ」「何でも構わねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見張りで聞いて来らあ」「いや、構わねえ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この説が一般に採用されるかどうかという事はなお他日を待たねばならぬが、とにかく天体の運動に関して光明を与うる一大発見と云わねばなるまい。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず今日乗客船の速いので一時間二十五｜浬くらい、かなりに速いと云わねばならぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
