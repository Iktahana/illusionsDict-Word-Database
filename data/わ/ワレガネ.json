        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アッ、これだナ」　と怪人が喜びの声をあげたとき、不意に天井の方から破れ鐘のような声が鳴り響いた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はにやにや笑つて答へないが、若者の一人が眞面目くさつて考へこみ、多少ためらつた末に「そりや、ごつつおうの方がええ」と答へ、「わしかてその方がええ」ともう一人の若者がそれに相槌を打つのを聞くと、その男は怒つたやうな破れ鐘のやうな聲を出して怒鳴るのであつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はにやにや笑って答えないが、若者の一人が真面目くさって考えこみ、多少ためらった末に「そりゃ、ごっつぉうの方がええ」と答え、「わしかてその方がええ」ともう一人の若者がそれに相槌を打つのを聞くと、その男は怒ったような破れ鐘のような声を出して怒鳴るのであった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それらを見直す前に、その蟋蟀が戸板のような羽根を擦り合わせ、鼓膜のしびれるような、破れ鐘のようなチンチロリンをはじめたのである。",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つ払ふと大はしやぎで、ふだんは蚊のなくやうな細い声しかでないくせに、こんなチッポケな痩身のどこからでると思ふやうな破れ鐘の声で応援団のやうに熱狂乱舞して合ひの手に胴間声にメッキのやうなツヤをかぶせて御婦人を讃美礼讃したり口説いたりする。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ皆、ちょっと静かにせんかッ」　大江山課長が破れ鐘のような声で呶鳴った。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っ払うと大はしゃぎで、ふだんは蚊のなくような細い声しかでないくせに、こんなチッポケな痩身のどこからでると思うような破れ鐘の声で応援団のように熱狂乱舞して合いの手に胴間声にメッキのようなツヤをかぶせて御婦人を讃美礼讃したり口説いたりする。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れ鐘のやうな声だつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、破れ鐘のやうな大音声でかうと問ふた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上の席に突ッ立上った大河内参事官閣下が、破れ鐘の様な大声で呶鳴った。",
              "citation": {
                "source": "監獄部屋",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い丸太ン棒のような物で背をガンと打ちのめしたなら、破れ鐘のような音をして前の竜バミ谷へけし飛んで行くに相違あるまい。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その時早しその時おそし、聴衆のなかに忽ち破れ鐘のやうな哄笑が起つて、ぬつと前へせせりだした一名の壮漢がある。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　破れ鐘のような声。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとの草むらから沸き起こった破れ鐘のような笑い声がかたわらの左膳を振りむかせた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　折れよとばかり手をたたいて、破れ鐘のような声で叫んだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず顔から髯が生えているのか髯の中に顔が同居しているのか分らない赤つらを反り返して、日盛りに破れ鐘をつくような声を出して「うめろうめろ、熱い熱い」と叫ぶ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼はランランとして鼻高く、色あくまで赤く、八面六｜臂、声破れ鐘の如くウォーッと、アハハ、いや全くだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとでも手を抜きそうにしようものなら、破れ鐘のような声で、恐縮させる。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、破れ鐘のような大音声でこう問うた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとは知らず康おじさんは破れ鐘のような声を出して喋りつづけた。",
              "citation": {
                "source": "薬",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は破れ鐘のような声を出した。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤大臣の演説が終ると、たちまちその足もとから破れ鐘のような声が起った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れ鐘のような大声で、「諸君ちょっと待ちたまえ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　破れ鐘のような声だった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、錯乱した破れ鐘のようなピカ一の声がとどろいた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホラ、こんなすばらしい武器が」　ゴリラが破れ鐘の様な声で云った。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふいに、破れ鐘ごえでこう叫んだのを見ると、雲つくような大男が三人、大小｜打ッこみ、侍すがた、へべれけに酔って熟柿のような息をはき、晃々たる大刀をぬきはらい、花や女子の踊りにまじって、ブンブンふりまわしているのだからたまらぬ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹でも逃げ隠れなどすると、引きずり出して首を捻じ切るぞ」　と、破れ鐘のような声でこうご託宣をくだしたのである。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺れ返る船の舳に立って角鍔の一刀を引ッ抱えた生不動は、破れ鐘のような声を、伝馬の中に向って叩きつけた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」矢庭に勝治は、われがねの如き大声を発した。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
