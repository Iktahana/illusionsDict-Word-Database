          "literary": [
            {
              "text": "それを手伝おうとしたけれど、私には和裁がよく出来なかったし、母も教えてくれなかった。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母に、翻訳の代償として、と言えばおかしいが、和裁を教えて貰うように願った。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "照代の家には、お多賀さんというばあやがいて、家事万端をやっており、その姪にあたる喜久ちゃんという少女もいて、洋裁と和裁との稽古をし、ゆくゆくはその道で立つつもりらしい。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仕立物の小さな看板を出して、お母さんは和裁の針仕事、姉さんは洋裁のミシン。",
              "citation": {
                "source": "小さき花にも",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "農園刑務所だからね、囚人たちでつくっているんだ」「あなたなんか和裁工でも、じゃがいもぐらいは、たっぷりあがれたの？",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二くち三くちで、もう終りさ」　重吉は網走で、独居囚の労役として、和裁工であった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてそんなこと知っていらっしゃるの」「和裁工だったんだぜ。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはこうしておくの」　その日の日づけをかいて、和裁工石田重吉記念作品と、つぎきれの上に書きつけた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永々厄介な小僧をお世話様でしたのうと兄が挨拶したあと、ぺこんと頭を下げ、「ほんの心じゃけ、受けてつかわさい」　と、白い紙包を差し出して、こそこそ出て行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "永々厄介な小僧を世話でしたのうと兄が挨拶したあと、ぺこんと頭を下げ、「ほんの心じゃけ、受けてつかわさい」と、白い紙包を差し出して、何ごともなかった顔で、こそこそ出て行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一人で生活するの、楽しみなような、恐ろしく空虚で、その空虚さに堪えず、何とかなってしまいそうなこわさいろいろあり。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
