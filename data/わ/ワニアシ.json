        "examples": {
          "standard": [
            {
              "text": "彼は長年のデスクワークで、わに足になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "わに足の子供に、親が歩き方を指導している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの選手はわに足だが、素晴らしいサッカーの才能を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "校長は肱枕をして足を縮めて鼾をかいているし、大島さんは仰向けに胸を露わに足をのばしているし、清三は赤い顔をして頭を畳につけていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不浄の家にいられるか」　と、やにわに足蹴にする。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　真赤になったお艶が叫ぶようにいった時、忠相のそばを離れてとんで来た黒犬が、何か感ちがいして、やにわに足もとで吠えたてたのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
