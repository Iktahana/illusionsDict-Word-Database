    "definitions": [
      {
        "index": 1,
        "gloss": "to discern (e.g. right from wrong)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
