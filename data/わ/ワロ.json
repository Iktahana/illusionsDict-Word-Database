  {
    "uuid": "ff65a951-9e2e-5711-ac3e-ad10f87e1bae",
    "entry": "和露",
    "reading": {
      "primary": "わろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
