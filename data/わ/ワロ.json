      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japan and Russia",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひいて御覧」　そう云われるといちごんもなくて和露の字引をひいて、伸子はその字を見つけ出した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "和露は近日中に出かけてしらべましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪ビルから電車で三省堂へゆき、そこで和英コンサイズを二冊買って、速達に出せるように包んで貰い、松田という人の和露も見ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この和露は殆ど只一冊の信用出来るものだそうで、専門家も八杉氏のロワとこれとを並用している由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和露は買いましょうか？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代ちやんひどく不快でもなつたのかい福や薬を飲まして呉れないか何うした大変顔色がわろくなつて来たおばさん鳥渡と良之助が声に驚かされて次の間に祈念をこらせし母も水初穂取りに流し元へ立ちしお福も狼狽敷枕元にあつまればお千代閉ぢたる目を開らき。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずわろき事もまじらではえあらず。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高取は、一番最後に、巻脚絆を巻き直して、靴を引きずり、整列に加わろうとしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわろは金山掘りのわろだな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、僕は一向まわろうとも思わなかったが、ひとりでからだがまわって仕方なかったよ。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その説を承たまわろう、是非願いたい！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりそのころ近所の年上の青年に仏語を教わろうとしたことがある。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後私の生活がいかように変わろうとも、私は結局在来の支配階級者の所産であるに相違ないことは、黒人種がいくら石鹸で洗い立てられても、黒人種たるを失わないのと同様であるだろう。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三階級にのみおもに役立っていた教養の所産を、第四階級が採用しようとも破棄しおわろうともそれは第四階級の任意である。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非教わろうと思てるんですけど。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって、ちょっとでもさわろうものなら、すぐに指先をぱんとたたかれるのですから。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "）しかしこの現状の内奥には、早くもまた時代を逆に呼ばわろうとする、次の反動が準備され、漸く詩壇の意識に登りかけている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中が進んで、古いしょうばいがいらなくなれば、男らしく、すっぱりそのしょうばいは棄てて、世の中のためになる新しいしょうばいにかわろうじゃないか。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一ト声、釣りせんとて通るものなりと答へしのみにて、咎めらるゝ事も無く済みけるが、此のあたりの地をば吾が家にて有ちし往時もありければ、一ト言にても糺されしことの胸わろきにつけて、よし無き感を起しゝも烏滸がまし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一声、釣りせんとて通るものなりと答へしのみにて、咎めらるゝ事も無く済みけるが、此のあたりの地をば吾が家にて有ちし往時もありければ、一言にても糺されしことの胸わろきにつけて、よし無き感を起しゝも烏滸がまし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に笑われるのがいやさに、彼は誰にも教わろうとはしなかった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代　ほんまに気味わろいことぢやのう。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気味わろいことぢやわいな。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり疲れ切って寝床に横わる京子を頻りにいたわろうとするお民を、加奈子は無理に引きさがらしたあと、京子の開け放して出た窓の戸をしめて、また京子の枕元に一人坐った。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂田をいたわろうとする筆がかえってこれでもかこれでもかと坂田を苛めぬく結果となってしまったというのも、実は自虐の意地悪さであった。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出て戦に加わろうという子供じみた誘惑に勝たねばならぬ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは追つめられたものが、しまいにはみずから進んで動き出すものに変わろうとしてきた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちび猫は三毛を自分の親とでも思いちがえたものか、なつかしそうにちょこちょこ近寄って行って、小さな片方の前足をあげて三毛にさわろうとする。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある日、休みが終わろうというときのことだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　医師は潔く、「承わろう。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
