        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十年来むし込んでおいた和本を取り出してみたら全部が虫のコロニーとなって無数のトンネルが三次元的に貫通していた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭和対訳の二冊物で、大きい厚い和本である。",
              "citation": {
                "source": "サフラン",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大和本草』に四国に狐なしというが『続沙石集』に四国で狐に取り付かれた話を載す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大和本草』に津軽に果然の自生ありと出づるがどうもあり得べからざる事で、『また仙猴、その鼻孔天に向う、雨ふる時は長い尾で鼻孔を塞ぐ、群行するに、老者は前に、少者は後にす。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大和本草』には猫は死ぬ時極めて醜い由で、隠れて人には見せぬとあるが余は幾度も見た。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大和本草』十六にこれ羊の別種で牛と形と相類せずと弁じ居る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大和本草』附録下に、野猪の脂は、婦人をして乳多からしめ、疥癬を治す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝原益軒は、猫は至って不仁の獣なるも他の猫の孤児を乳養するは天性の一長と称讃したが（『大和本草』一六）、『後周書』に、陸逞｜京兆尹たりし時都界の豕数子を生み、旬を経て死す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ一物の内、その形体処々功能多き事鼠に逾えたる物なしと賞賛した（『大和本草』一六）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から襖を開けて、押入に首を突込んだまま、そこに山のように積重ねてある書物を、あれかこれかと捜していたらしい、脚本作者のＷは、そのなかから八冊ばかりの大型の和本を取出すと、「これだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大学前の、あの和本屋にあるのですよ、新斎諧と云うのでしょう」　と、その男は云った。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは十二三冊の小さな黄表紙の唐本で、明治四十年｜比、私は一度浅草の和本屋で手に入れたが、下宿をうろついている間に無くしたので、この四五年欲しいと思っていた。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本屋の数で二三軒行った処に、和本を売っている処があって、そこには時どき珍らしい本が出るので、まずそこへ往って見たが、べつに買いたいと思うような本も見当らないので、神保町の電車の交叉点の方へと、道草を喫いながら歩いていた。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは貧しい中から苦心して蒐めたもので、兄から貰った小使で買った其角の五元集、支考の俳諧十論などの古い和本も入れてある。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は従来｜衣魚と言ふ虫は決して和本や唐本以外に食はぬものと信じてゐた。",
              "citation": {
                "source": "変遷その他",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "和本では小川町の松山堂も古い。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和本は虫が食ひはしませんか？",
              "citation": {
                "source": "漱石山房の冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして香具師と和本屋と古道具屋と狐まんじゅう、どびん焼、くらま煮屋が昔そのままの顔で並んでいた。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただただ、雑色と雑形の一種異様な混淆であって、あるいは、盆景的に矯絶な形をした木の根細工のようでもあり、その――一面に細かい亀裂の入った羊皮紙色の皮膚を見ると、和本の剥がれた表紙を、見るような気もするのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯前、和本箱を見、西行の伝記、栄花物語、その他を見出す。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ美の世界性であって、人類の親和本能がこれを行わしめるのである。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和本の渋引や雲母引の表紙も同断であらう。",
              "citation": {
                "source": "装幀について",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和本草には、昔から日本には箱根山から東北には鯰がいないといってある。",
              "citation": {
                "source": "鯰",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると籠屋は煙管を措き、茶を一杯ぐっと傾けて、さて、表座敷の神棚から一冊の手垢に汚れた和本を下ろして来て、無雑作にたずねはじめた。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから、この記述では和本仕立の装綴については之を省いて触れることをしない。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆和本で、それぞれの書名が小口に綺麗に書かれたのが積重ねてあって、表紙の色はそれぞれ違いましたが、どれも皆無地でした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の三方は天井まで棚を造って、和本がぎっしり積上げてあるのを、尊い物のように仰いだ覚えがあります。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く中世をのがれよというのが、あの本居先生なぞの教えたことじゃなかったですか……」　酒の酔いが回るにつれて、正香は日ごろ愛誦する杜詩でも読んで見たいと言い出し、半蔵がそこへ取り出して来た幾冊かの和本の集注を手に取って見た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤掛なにがしという日蓮宗の信者で、頭のはげた隠居さんが一そろい九冊ばかりの、あい色の表紙のついた、こころもち小形の和本を奥の戸だなからさがしだしてきて、それをわたしに売ってくれました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は活字本当世新刊和洋の書籍雑著を主として和本唐本を置かず、他は和本唐本を主となし活版本は僅に古書の翻刻物を売買す。",
              "citation": {
                "source": "古本評判記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
