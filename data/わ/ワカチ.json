        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むかし水戸義公は日本諸寺社の古文書を写させ、水災を虞れて一所に置かず、諸所に分かち置かれしという。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "村中近年までこの火を分かち、式事に用いたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに句読点の処理や数字の表記、漢字の使い方、和文の中に欧文を交ぜ書きする際はどうすれば読みやすくなるかといったさまざまな点に関して、本作りに携わる人たちは工夫を重ね、成果を分かち合ってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その分かちがたいはずの絆が、あっけなくゆるみ始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここまでこられて良かったね」と、小さな温もりを分かち合うために。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど印刷術は、紙でできた冊子という構造物と分かちがたく結び付いていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "点字は、分かち書きされる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解力の高い人間に比べれば、点訳ソフトの分かち書きでは、誤りや解釈のずれが生じやすい。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただただ大地を両断して、海と陸とに分かち、白波と漁船とが景色を彩なし、円大な空が上をおおうてるばかりである。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "分福とはどういうことであるかというと、自分の得たところの福を他人に分かち与えることをいうのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幾分かを他人に分かち与えて自分と共にその美を味わう幸せを得させるのは分福である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜福の工夫を為し得る場合とそうでない場合とに関わりなく、すべて自分の享受し得た幸福の幾分かを割いて之を他人に分かち与え、他人をして自分と同様の幸福を、少しにもせよ享受できるようにするのを分福というのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜福とは自分の福を取り尽さず用い尽さないことをいい、分福とは自分の福を他人に分かち与えることを言うので、二者は実に相異なりまた互いに表裏をなしているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瓶の佳酒が有ると仮定する、之を自分一人で飲み尽せば酔いを得るに足り、他人と共に之を飲めば自他共に酔いを得るに足りないという場合に際して、自分一人で之を飲み尽して、同座又は同寓の人に分かち与えないのは、福を専にするのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瓶の酒、我を酔わすに足りなくとも人とその味わいを分かち、器半分の肉、我が満足には不足だが人にその切り分けを薦める、このような分福の行動は、実に人が餓犬でなく貪狼でないところを表わすのであって、単に福を得る道として論じるべき一箇条と云うよりは、人としての高貴な情の発動というべきである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその一瓶の酒を分かち与えられ、器半分の肉を分かち与えられた人は、之によって非常に甘美な感情を惹起されるのであって、その感情の衝動された結果として生じる影響は決して些細なものではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の名将の伝記を繙いたならば、士卒に福を分かち、恵を贈るのに、昔の名将等がどんなに臨機の処置を取ったかが窺われるが、之に反して愚将弱卒等は常に分福の工夫に欠けたケチな行為を為すものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業者としては店員や使用人や関係者や取引者に対して、常に自分の福分を分かち与える覚悟と行為とを持つ時は、自然とこれ等の人々はその主人の為に福運の来ることを望むものであるから、人望の帰するところ天意これに傾く道理で、その人は必ず福運の到来を受けるようになるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天道は復すことを好む」というが実にその通りで、我より福を分かち与えれば、人もまた我に福を分かち与えるものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤清正や福嶋正則や前田利家や蒲生氏郷や、或いは始めから臣下であり或いは中途から旗下に属した者にも、惜気なく福を分かち恵を施したのは秀吉の一大美点であって、一勇者にも何十万石を与えられたのであった。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし便宜上から器と非器とを分かち身と心とを分かって、呼称を便利にしているのが自然の勢いなのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お分かちいたしましょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "禍福を分かち、苦楽を共にするというのがそれです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島上陸　望遠鏡をとって眺めると、水天いずれとも分かちがたい彼方の空に、一本の煙がすっとたちのぼっている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　明治の哲学、広くいえば明治の思想の潮流を回顧してみると、少なくとも三つの段階に分かちてこれを考えることが便利のように思う。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "序論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四方八方手を分かち、追手を出しましてござります」「俺からもすぐに追手を出そう」「は、なにとぞよろしいように」「国の掟だから止むを得ない」「は、なにとぞよろしいように」「俺は愚痴を云う人間ではない」暗然として信玄は云った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能と良心と、わかちがたき一つの心をふたつにわかたんとする大人の心のうらさびしさよ、力をこめて引きはなされた二つの影は、糸のやうにもつれあひつつ、ほのぐらき明窓のあたりをさまようた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡、その地をわかちて、五大州となす。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は夕闇がこめて、煙の臭いとも土の臭いともわかちがたき香りが淀んでいる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われもし生きて天下を取らんには、その恩賞として日本の半分をわかち取らすぞと、諸人の聞く前でたしかに誓うた。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
