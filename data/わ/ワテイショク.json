        "examples": {
          "standard": [
            {
              "text": "ランチタイムに、焼き魚と小鉢、味噌汁がついた和定食を注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この和定食は、季節の食材が使われていて、彩りも豊かで健康的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅館で出された豪華な和定食で、一日の始まりを優雅に過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "食堂は感じが悪いから止めようと思ったが、コーヒーがのみたいので、行くと、サービス女が又々感じ悪く、坂本のとった和定食に梅干の種が入ってゐたので、つひに怒り、女給頭をどなる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
