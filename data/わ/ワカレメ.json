        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし一たん見まいと決心したからには意地が出て振り向くのが愧かしく、また振り向くと向かないのとで僕の美術家たり得るや否やの分かれ目のような気がして来た。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は赤い方をまっしぐらに走っているし、ある者は青い方をおもむろに進んで行くし、またある者は二つの道に両股をかけて欲張った歩き方をしているし、さらにある者は一つの道の分かれ目に立って、凝然として行く手を見守っている。",
              "citation": {
                "source": "二つの道",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランか、スリーアウト、チェンジかの分かれ目だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも言うことだが、そこが主観と客観の分かれ目で、明瞭な主観に立っていないものに深い作は望めない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その機に臨んで、不要な気遣いをするかしないか、それこそ戦の勝ち負けの分かれ目、一国存亡興廃の分かれ目と知るがよい。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄道の分かれ目における星座の日時を与えた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道誉にとっても、ここは生涯の分かれ目か」　彼が、いよいよと察知したのは、つい二日前である。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちを取るか、腕の分かれめ、てがらのわかれめ、いいや、道のとり方によっちゃ、知恵の浅い深いがおのずとわかることになるんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然泣き出したりしたのは私の態度に冷たい義理のわかれめを感じてのことであらう。",
              "citation": {
                "source": "青春の天刑病者達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやめの数は二人の男の通う同じ日取りの同じ数をかぞえていて、株のわかれめに莢ほどの蕾の用意を見せ、緑は葉並を走ってすくすく伸び上っていた。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて多くの人間が生活のどんなポイントでそれてゆくものか、そのポイントに自分が立ってみなければ分らない、人間の高貴さは観念でもわかるが、弱さは生活のなかをくぐって自分とひととを見なければ分らず、そんなあれこれが生活を知っているかいないかのわかれめとなるのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この支線とのわかれめのポイントのところに、三人の犯人のうちで、いちばんすばやいやつが、待ちかまえています。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関車がレールのわかれめを、とおりすぎました。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、一号車二号車、その二号車の車が、レールのわかれめを、とおりすぎたしゅんかんに、ぼくは、パッとポイントをたおします。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三号車が、わかれめをとおりすぎたしゅんかんに、ぼくはまた、ポイントをパッともとにもどします。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犯人を、かりに、ノロちゃんとしますと、ノロちゃんは、支線のわかれめと製材会社との間にある森の中に、待っているのです。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここぞ、若君にとって、武運のわかれめ、忍剣どのもおぬかりあるなよ」「いうまでもない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "色と欲、生涯のわかれめだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国土の興亡のわかれめだ。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯の運を賭けた機微なわかれめといってよい。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
