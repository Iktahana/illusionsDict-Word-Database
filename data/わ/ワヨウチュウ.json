        "examples": {
          "standard": [
            {
              "text": "レストランのメニューには、和洋中の様々な料理が揃っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家族旅行では、皆が好きなものを食べられるように和洋中のバイキングを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "百貨店のデリバリーサービスでは、和洋中の有名店の味が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その代り安くてたっぷり、腹っぷさげはどこでも間に合う便利の世の中、和洋中入交りのごった返し、舌一枚では味わいかねるも無理でない。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
