      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to laugh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんなそう言って笑うがいい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより僕は無学にして文献に暗く、考証等に笑うべき蒙失があるかも知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏畑の竹藪の中の小径から我家と往来が出来て、垣の向うから熟柿が覗けばこちらから烏瓜が笑う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をしかめながら父上も笑えば皆々笑う。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の水楼に坐して此方を見る老人のあればきっと中風よとはよき見立てと竹村はやせば皆々笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の大名それの君、すれちがいし船の早さに驚いてあれは何船と問い給えば御附きの人々かしこまりて、あれはちがい船なればかく早くこそと御答え申せば、さらばそのちがい船を造れと仰せられし勿体なさと父上の話に皆々またどっと笑う間に船は新田堤にかかる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりようやく薄暗く工夫体の男｜甲走りたる声張り上げて歌い出せば商人の娘堪えかねてキヽと笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "透見の女性達の眼には、その光景が、何かひどく悪い事でもしている現場を見届けでもしたように、とにかく笑うべく賤しむべきこととして取扱われているらしかった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎は舌打ちをしたと云う風であったが此方を見て高く笑うた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し社会が進歩すると私のこの案を笑う人がなくなるかもしれないような気がする。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のボーイが cabin からいかがわしい写真を出して来て見せびらかしながら会食室へはいったと思うと、盛んに笑う声が洩れて来た。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑うときは峯の雪を日に輝して東海一帯の天地を朗なものにした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくらの空に朗々と失することの楽しさ」　またころころと笑う声は、珠うち鳴らしつつ距り行くが如く、霞を貫きおお空の宙にまであとをひいていつとしもなく聞えなくなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「お金入れの口を開けてみて、お金が一文も無いときは何だか可笑くって可笑くって、あはあは笑うのよ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の人が笑うのに釣込まれたせいもあるがやはり可笑しくなって笑ったのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをほめる人があれば笑う人があり怒る人があり嘆く人がある。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この迷信を笑う西鶴の態度は翻って色々の暴露記事となるのは当然の成行きであろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の笑うのは ilai でこれは日本に近い。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ha_sita〕 は笑うべき事で「はしたない」に通じる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "(Skt.)garh は非難するほうだが軽蔑して笑うほうにもなりうるのである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもかすかに笑う其目つきが忘れられなくなつかしかった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は狐鼠狐鼠と僕の所へ這入ってきて、小声で、私は内に居るのが一番面白いわと云ってニッコリ笑う。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしいのが一つあった筈だ」　稲刈連は出てしまって別に笑うものもなかったけれど、民子はあわてて菅笠を脱いで、顔を赤くしたらしかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対にまた、心の自由を得ない人間の憐むべく笑うべくまた悲しむべき現象を記録したものが非常に沢山に収集されていて、それがまたこの随筆集中の最も面白い部分をなしているのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男の変った所説の一例を挙げると、自分が風邪を引いて熱を出したりしたとき「アンマリ御馳走を喰べ過ぎるんじゃあないですか」と云ってはにやにや笑うのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛さん蛙の子は矢っ張り蛙だな」　「蛙の子は蛙か、うめえ事を云やァがる」　源兵衛、淋しく笑う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年の話をすると鬼が笑うって言うじゃねえか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静が、　「兄さん、意地悪ねえ」　「お前が、あんまり綺麗になってるもんだから、すっかり見違えて居たんだよ」　「知らない」　石松笑う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御冗談を」と笑う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
