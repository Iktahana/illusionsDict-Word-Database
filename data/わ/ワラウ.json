[
  {
    "uuid": "6cc5b32c-2a82-58e6-8d2a-9265598d0c8c",
    "entry": "笑う",
    "reading": {
      "primary": "わらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
