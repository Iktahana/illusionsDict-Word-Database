        "examples": {
          "standard": [
            {
              "text": "長い間会っていない友人の顔を、少しずつ忘れかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "忙しい日々の中で、大切な約束を忘れかけていたことに気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の歌を口ずさんでいたら、途中で歌詞を忘れかけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "暗いことを忘れかけると思ひ出させられ思ひ出させられしてさんざん生殺しの目にあはされました。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、たいした事じゃないがね、たまには、高円寺のほうへも遊びに来てくれっていう御伝言さ」　忘れかけると、怪鳥が羽ばたいてやって来て、記憶の傷口をその嘴で突き破ります。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼がいつも一心になって、女給仕の透視に立会ったり、始終彼女に透視を強いたりしてるのは、そして時には、そのために授業時間まで忘れかけることがあるのは、皆に知られてる事実ではあったが、それは指輪の一件を弁義することにはならなかった。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は室の中をぐるぐる歩き廻りながら、我を忘れかけることが多かった。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の美くしさをあんまりわすれかけると大変な事になって仕舞う。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
