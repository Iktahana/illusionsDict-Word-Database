    "definitions": [
      {
        "index": 1,
        "gloss": "skeleton shrimp (Caprella mutica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "われから惑乱している姿は、たえて無い。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本曹洞禅の開祖道元禅師が支那の天童山に修業しておられたとき、師僧の如浄禅師が、「参禅は身心脱落なり」（禅の修業の目的は精神肉体の捉われから解き放たれることだとの意）と言われた言葉を聞いて、さとられたのを、たった一度の大悟と言って、よく例に引いて来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "些と彼方へもお顔をと言われるにも、気がさして、われからすすむともなく廊下を押されて、怪談の席へ連った。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、友人の不名誉の病い慰めようと、一途に、それのみ思いつめ、われからすすんで病気になった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころされる日を待ち切れず、われからすすんで命を断とうと企てた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちの我れわれから観ると、単に奇怪な伝説としか思われませんが、わたしの祖父などは昔の人間ですから、井戸の家の血統が今なお連綿としているのは、自害したおっ母さんのお蔭だといって、その命日には欠かさずに墓参りをしています。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、われから誘うように、準之助氏を見上げた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "行かでもの處へまで、われから強ひて出かけて行つて烈しい失望や甲斐なき苦勞を味ふ事が少なくない。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれから取上げやがって、ああして荒して置けあどうだと云うんだ。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意地をわれわれから取り除けてしまったならば、われわれは腰抜け武士になってしまう。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は返事を書きにくく思召したのであるが、「われわれから御｜挨拶をいたしますのは失礼でございますから」　と女房たちがお責めするので、灰色の紙の薫香のにおいを染ませた艶なのへ、目だたぬような書き方にして、消えがてにふるぞ悲しきかきくらしわが身それとも思ほえぬ世に　とお書きになった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "心中してわれから命を縮めた者は、同じ浄閑寺の土に埋められながらも、手足を縛って荒菰に巻かれて、犬猫にも劣った辱かしめを受けるのである。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "与五郎　しいてとやこう申されたら、それがしも刀の手前、われから姉妹の縁切って、そなたを連れ帰ろうと存じたるに、玉虫殿のこころも早う解けて、われも満足。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝＝先づわれから愛せよ＝＝この語の意味は、誰でも知つてゐるだらうけれども、これを本当に経験するといふことは難かしいことだからね』『さうですかな』智と空　智と空とから生れ出して来る自己創造――。",
              "citation": {
                "source": "不思議な鳥",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "われから迷う身の行衛、　知っているのは世の中に、　赤い鸚鵡の他にない。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と僕は、大層に慌てふためいて、つまりその、それだけのいわれから坊主となり、帽子を飛ばしてカンカンと秋の陽にたゝかれてゐる青い頭を擲つたといふわけだ。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の我れわれから考えますと、どうもそれは主人と野水の幻覚らしく思われるのですが、一概にそうとも断定のできないのは、ここにまた一つの事件があるのです。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリス　其樣なことを被言るのは、われから我面を讒訴するのぢゃ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はウラルを越えてシベリアへ入って来たとき、幾千里となくつづいた原野を見ると、過ぎて来たヨーロッパの智的文化が、ロマンチックな儚い城に見えてならなかったが、人間努力の結果を、無にする物の見方は、われわれからは抜けぬと見える。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚のように急所のなくなるのを本懐とする風習は、常にわれわれから遠ざかろうとしない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでと、第一になぜ私が文学好きなぞになったかという問題だが、それには先ずロシア語を学んだいわれから話さねばならぬ。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが必然であるのみならず、その違って居る処が今日のわれわれから見ても面白いと思うのである。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女｜寄祈の力の偉大であったことはとうてい今日のわれわれからは想像のほかであります。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "われから作っている女らしさの故に女の本心を失っている女たちという逆説も今日の現実では一つの事実に触れ得るのである。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "真偽の境がわれからぼやつくところにスリルがかくされていると見ているのである。",
              "citation": {
                "source": "仮装の妙味",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい六月の若葉の下を、その青い美しさに照りはえる自分をわれからめでて歩く人々は、それぞれにいちどしかない自分の一生を、どういう主題で貫こうとしているだろうか。",
              "citation": {
                "source": "人生のテーマ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧田の牛は、この地蔵たちの前を通りぬけ、井戸からすこし先の竹垣のこわれから、よくみることが出来るのだった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの日々で、「みじめな朝鮮人」を見下げる習慣をもたされてきた一部の人々は、いまは日本も敗けてしまったのだからと、軍国主義権力の崩壊を、それによってこわされた自分たちの生活と同じ一つもののように思いこんで、われから隷属に屈していることはないだろうか。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自然さに、その自然さの時代的な主張にわれから靠れて、本質においての受け身なところや、又愛とひとくちに云い表わしているその愛の質を見わける力はまだ十分になかったのではなかろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
