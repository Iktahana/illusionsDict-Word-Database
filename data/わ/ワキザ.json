    "definitions": [
      {
        "index": 1,
        "gloss": "downstage left (in noh), where the secondary actor is often seated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
