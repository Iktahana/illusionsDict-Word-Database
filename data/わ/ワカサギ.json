    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese pond smelt (Hypomesus nipponensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、いまは公魚の季節だ。",
              "citation": {
                "source": "釣った魚の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の山中湖や、上州の榛名湖では氷の上でこの公魚が釣れる。",
              "citation": {
                "source": "釣った魚の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "公魚は、焼くと肉に渋味が出て結構でないように思う。",
              "citation": {
                "source": "釣った魚の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが榛名湖の公魚は、丈は長い上にまるまる肥っていて、どうした関係か渋味が少ない。",
              "citation": {
                "source": "榛名湖の公魚釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名富士、相馬山、ヤセオネ、天神峠に囲まれた、広いなだらかな火口原の野の末に、描いたような枯れ林を水際に映した美しい榛名湖で、公魚を釣る気分はまことに愉快である。",
              "citation": {
                "source": "榛名湖の公魚釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで想い出すのは公魚である。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "公魚は氷魚と同じにこれから冬に入って季節となるが、東京市民の口に入るものは、多く土浦の霞ヶ浦産である。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗にチカキという青森県や北海道方面からの乾公魚は一層渋味が強くて惣菜にもならぬほどである。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いうわけで霞ヶ浦産でも、東京付近の中川、江戸川、荒川などで釣れた公魚を上等の食味を盛っているとは思わなかった。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、昨年の初冬から釣れはじめた榛名湖の公魚を食べてみて、なるほど公魚とはおいしい魚であるということが分かったのである。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお底石が細かい火山の噴出物で四時外輪山から湧水を注ぎ込み、餌の藻蝦が豊富であるから他の不純物を口にしないので公魚の味が上等になったのではなかろうか。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い氷に一尺四方くらいの穴をあけ、尻に蓆を敷き、傍らに石油缶を切った火鉢を置いて冬の朝、紫光の公魚を手にする興味はまことに深い。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近知ったことであるが、榛名湖で釣れる公魚は本場の霞ヶ浦でとれるものよりも、骨が柔らかである。",
              "citation": {
                "source": "水と骨",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷上の公魚釣りも、趣が深い。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣りあげて氷上に放つと、忽ち棒のように凍った公魚は、細かい鱗の底から、紫色に光る艶を放って、鮮麗な小魚である。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから線路は千曲に沿ふて、公魚の穴釣の松原湖駅まで。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節がおくれては居るが、公魚の穴釣りをする。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中湖は深いので秋の公魚釣りはなく、氷が張りつめてからの穴釣だけである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ公魚をスキー場霧ヶ峯近く蓼の海で釣つた二月もあつた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐに公魚と直感した。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "川へ上るのは産卵のために相違ないし、そんな早春に産卵する魚は公魚以外にはない筈だからであつた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して穴釣りで公魚が釣れたのである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られずに年魚である公魚は何代もかゝつてあんな小湖であれ程繁殖したのであつたらう。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月中旬から三月中旬迄、この小湖は氷が張りつめて居るが、三年前水を乾して以来公魚は駄目になつた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖へ注ぐ川へ、春情稍動くを感じて、やまべを釣りに行くと、二三十尾のやまべと十尾内外の公魚がかゝる。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "上川の支流では湖水の氷解け以来、公魚の人工授精卵を諏訪湖漁業会が真剣になつてやつて居る。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏の小料理屋に、諏訪湖公魚とビラの出て居るのを見た。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しあれは一月下旬であつたから、穴釣の出来ぬ諏訪のものではないが、とにかく諏訪湖公魚と銘をうたれると、自分がほめられて居るやうでうれしかつた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月　諏訪湖上、公魚船釣。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞し去る合間もなく、食卓がととのえられて、梅干にお茶、味噌椀からワカサギに海苔と、気持よい朝食でありました。",
              "citation": {
                "source": "沼のほとり",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
