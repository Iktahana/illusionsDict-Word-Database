        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それなのに君は小説家志願でいつになったらお銭がとれるようになるかわかんないでしょう。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとかよは、「うわあ、兄な、木ペン取てわかんないな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはわかんないかもしれないが、そいつはドレッバー長老の息子で、ぼくはジョーゼフ・スタンガスン。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちのどちらを、あんたや娘さんが選ぶかはわかんないけれど。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きなノイズが入らないようにはできるけど、あんまりスムースには聴こえないからね」「気にすんなって、どうせ、みんな眠ってるから、わかんないさ」　高志は、六小節しかないイントロを、テープ編集で四倍にしろと要求している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿みたいなジジイどもが、いろいろ、わけのわかんないこといってんのも、気に入らないしさ」　しゃべっていいときと、いけないときがある、ということすら知らない、行儀の悪い明治のジジイどもだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえだけってことはないだろ」「わかんない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わかんない」「おまえさ、おれがいなかったら、どうした？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかんないよ、日本の会社はメチャクチャだから」「ヤードバーズの〈オーヴァー・アンダー・サイドウェイズ・ダウン〉だの、スタンデルズの〈ダーティー・ウォーター〉だの、騒々しい曲ばっかじゃねえか」　三日後に、ワラがアメリカへ帰る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わかんないよ、あんなの」　佐藤が、片桐の指を見つめたままこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもさ、わかんないことがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中身を見て、わかんないような奴は、どっちを食ったって、おなじじゃねえか」　広岡は、うるせえ野郎だな、ちょっときいただけじゃねえか、とぶつぶついいながら、パラフィン紙の上に中身を三分の一ほどのせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よかったら、あなたのバンドのドラムの子も」「ウーン、わかんないよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かな、なんて、煮えきらないこといってないで、イエスっていえよ」「だって、わかんないんだよ、仕事がどうなるか」「仕事なんて、ほかにいくらでもある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、さきから天地がひっくり返ったような気がしていて、そんなことをされたって、何のことだかわかんないわ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――言葉がわかんないんじゃないの？",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故だかわかんないんですけど」「……ケ……怪しからん。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮ではソンナ話、聞いたこともないんですから、ドウしたらいいのかわかんないんですもの。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の云う事は……モット確りした事を云っとくれよ」「だって将来の事なんかわかんないんですもの……貴方みたいに正直に、何もかも真に受けて、青くなったり、赤くなったり……」「オイオイオイ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ブル新、盛に『コップ』をデマっているらしいよ」「ほか、無事かしら」「わかんない。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき乙女は、額からとび抜けそうに長い眉をつり上げ、二人とも小柄ながら、乙女よりは三四寸上にある勉の顔を見上げて、「――わかんない！",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに三人が三人で、いろんなことを……妾達にはとても、わかんないようなことを考えたり、したりしてるんだわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、わかんない、ママ。",
              "citation": {
                "source": "母の日",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどワケがわかんないのだから、一寸も面白うない。",
              "citation": {
                "source": "小説",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○さんは悠然として、「わかんない人ね、両方の眼の真中にあるのよ。",
              "citation": {
                "source": "ハナとタマシヒ",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみがそのことわかんないのは、あたしのせい。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
