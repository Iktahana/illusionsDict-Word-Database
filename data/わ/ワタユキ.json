        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "町へ入るまでに日もとつぷりと暮果てますと、「爺さイのウ婆さイのウ、　綿雪小雪が降るわいのウ、　雨戸も小窓もしめさつし。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へ入るまでに日もとっぷりと暮果てますと、「爺さイのウ婆さイのウ、　綿雪小雪が降るわいのウ、　雨炉も小窓もしめさっし。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子窓越しにチラチラ光る綿雪を見遣りながら……。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻燈のにほひわが友よ、わが過ぎし少年の友よ、汝は知るや、なつかしき幻燈の夜を、ほの青きほの青き雪の夜景を、――水車しづかにすべり、霏々として綿雪のふる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ暮れたばかりなのに、綿雪が深々と降りこめて、夜更けのやうに静かだ。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目ですわ、苦しむばかしですものウ‥‥」　小豆色の女の肩に、綿雪が柳の葉のやうに降りかゝつてゐる。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女達は、お粒の変にからんだ高話をきいてゐたが、恰度、直子がふつさりとした髪の毛に綿雪をつけたまゝ這入つて来たので、そのまゝまた雀をどりの唄をつゞけるのであつた。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直子は沈黙つたまゝ壁鏡に向かひ、ハンカチで頭髪の綿雪を拭きながら、背を射てゐるお粒の眼を痛く心に感じた。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの時福太郎の頭の上から、夥しい石の粉が、黒い綿雪のようにダンダラ模様に重なり合って、フワリフワリと降り始めたからであった。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな綿雪がふってきて、石をしきつめた道路や、馬の背や、辻馬車の馭者の帽子を白くそめた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "やわらかな綿雪が、赤犬の背中や頭にいっぱいふりつもった。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹雪とか、綿雪とかいうのは、この雪片の名前である。",
              "citation": {
                "source": "自然の恵み",
                "author": "――少国民のための新しい雪の話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ちわれわれによって牡丹雪あるいは綿雪と呼ばれているものである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹雪あるいは綿雪と呼ばれているものは、割合に温暖の地に降ることは人の知るところであって、その大きさは、時には直径十五｜糎にも及ぶものがあることが記録されている。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経質に手につかんでいた書類が綿雪のようにバラバラとあたりの床にちらばつた。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野は「主婦之友」の何十枚かを書いたので、気持がいゝからつきあへと言ひ、銀座へ出ると雪――綿雪。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
