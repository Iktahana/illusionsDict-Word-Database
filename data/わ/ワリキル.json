        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "10を2で割ると、きれいに割り切れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この数字は3で割り切れるはずだが、計算が合わない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "割り切れる数と割り切れない数を見分けるのは、算数の基本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
