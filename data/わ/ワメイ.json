    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese name (esp. for a plant or animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "和名鈔には「顱　和名加之良乃加波長　脳蓋也」とあるそうで「カハラ」は頭の事である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「大蛇」というような場合に『古事記』では「遠呂智」と書いてあり『和名抄』では「乎呂知」と書いてある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間花屋で買うとき、試しに和名を訊ねて見たら、「わたしどもでは唇草といってますね、どうせ出鱈目でしょうが、花の形がよく似てるものですから」　と、店の若者はいった。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし舟は曳舟には限らぬので、『和名鈔』には釈名の「艇小而深者曰の字をたかせに当ててある。",
              "citation": {
                "source": "高瀬舟縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って和名漢名なども無さそうだ。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで調度やなんぞは手近にある和名抄にある名を使つた。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし舟は曳舟には限らぬので、和名鈔には釋名の「艇小而深者曰の字をたかせに當ててある。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中古の頃この宮居のいと栄えさせたまいしより大宮郷というここの称えも出で来りしなるべく、古くは中村郷といいしとおぼしく、『和名抄』に見えたるそのとなえ今も大宮の内の小名に残れりという。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『和名抄』に蛇和名倍美、蝮和名波美とあれば蛇類の最も古い総称がミで、宣長の説にツチは尊称だそうだから、ミヅチは蛇の主の義ちょうど支那で蟒を王蛇と呼ぶ（『爾雅』）と同例だろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『和名抄』に蟒蛇、和名｜夜万加々知、『古事記』に赤加賀智とは酸漿なりとあれば、山に棲んで眼光強い蛇を山酸漿といったのであろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に蟒に充てるウワバミは小野蘭山これを『和名抄』の夜万加々智とす。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和名抄』に仁之木倍美と訓んだ蛇嶺南に生ず、大なるは五、六丈、囲り四、五尺、小なるも三、四丈を下らず〉とあるが、『エンサイクロペジア・ブリタンニカ』十一版に南米熱地産なるアナコンダに次いで諸蛇の最大なるものとあり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は特に留意せなんだが、ほどなく老人死した後考うるに、駱和名川原毛黒い髦の白馬だというから、不毛に当らず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬属の最後に列なるが驢で、耳が長い故、和名ウサギウマといい、『清異録』に長耳公てふ異名を出す。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから思い付いてリンネウスが飛馬竜（ペガスス・ドラコニス）と命名したまま今も通用する小魚、和名はウミテング、その形怪異で牛若丸の対手としていつも負けている烏天狗や応竜の日本画に似、英語で海竜という。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "海馬、和名はタツノオトシゴまた竜の駒、蛟の子など呼び、その頭馬に酷だ似、左右の眼カメレオン同前別々に動く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に海馬は上記諸名のほか竜宮の駒（また竜の駒、『尤の草紙』に迅き物雷神の乗るという竜の駒）、馬王海ウマ等の和名あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草啓蒙』に猴の和名を挙げてコノミドリ、ヨブコトリ、イソノタチハキ、イソノタモトマイ、コガノミコ、タカノミコ、タカ、マシラ、マシコ、マシ、スズミノコ、サルと十二まで列ねた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの例から見ると、摩頭羅なる語の本義は何ともあれ、国としても人としても仏典に出るところ猴に縁あれば、猴の和名マシラはこれから出たのかと思わる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和漢三才図会』にいわく、〈『和名抄』、猴以て一物と為す、それ訛り伝えて、猿字を用いて総名と為す、と書いた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "概説　鶏、和名カケ、またクダカケ、これは百済鶏の略でもと百済より渡った故の名か。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第４図『和名類聚鈔』に、〈を以て繋ぐ〉とあり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに和漢とも後には老いたる豕も本は子であったから猪、イノコと唱えたので、家に畜う家猪に対して、野生の猪を野猪また山猪、和名クサイイキ、俗称イノシシという。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "氈和名カモ、褥呉音ニク、氈にも褥にもなったので、羚羊をニクともカモシシまたカモシカというといえば、マミの毛皮も氈の用に立てたのでカモシシといったものか。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "石竹はもと瞿麦と別たず、日本でも撫子、又は常夏は撫子属の諸種の総称だつたが、後には花びらの歯が細く裂けたを瞿麦、和名ナデシコ又、常夏、細く裂けぬを石竹と日本で定めた。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "和名の、頭文字のＨをとつたのださうだ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウトウトこんな事を考えていたが、気がついてみると垣の外ではさっきの子供等がまだ大きな声で歌ったりわめいたりしている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬つころの悪魔の杓子野郎が、と彼女はわめいた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はベッドから起き上りざま大声でわめいた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スラビナがわめいている、三人の外国人の腕の中で、アフガニスタンの山脈のような胴体をつねられて悲しみは赤く腫れあがってしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
