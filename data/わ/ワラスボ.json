        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あるいは藁苞のような恰好をした白鳥が湿り気のない水に浮んでいたり、睡蓮の茎ともあろうものが蓮のように無遠慮に長く水上に聳えている事もある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんがおずおずと一銭の藁苞を出しかけると、吉公は、「それは嫌だ。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづく下枝の節の処へ、構わない、足が重るまでも一所に踏掛けて、人形の首を、藁苞にさして、打交えた形に、両方から覗いて、咽喉に嵌めて、同時に踏はずして、ぶらんこに釣下ろうという謀反でしてなあ。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れつき頭の悪い記者は、念のため今一度買った八百屋に行ってきいて見たら、「今までの藁苞に這入っているのでは、そのままお膳に乗っけられませぬ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い晩、私は子供達と、穴の中の藁苞に貯えてある銀杏の實を出して、爐の縁で燒いて食べた。",
              "citation": {
                "source": "梁上の足",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "切米とは、扶持米を數囘に分けてか、又は金錢に取り替へて渡すことをいふので、手形の書替とは、切米券を、請取にしてもらふことで、請取手形が渡ると、受取人の名を紙に書いて割竹に挾み、大倉役所の藁苞に※込んでくるのである。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は窃っと藁苞の中から脇差を出して腰に差し、慄える足元を踏〆めて此の家の表に立ちましたのは、丁度日の暮掛りまする時。",
              "citation": {
                "source": "敵討札所の霊験",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けた屋根裏からつりさげた藁苞に、焼いた小魚の串がさしてある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けた屋根裏からつりさげた藁苞に、燒いた小魚の串がさしてある。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも芝居なぞで玉子の藁苞を見ると、それを提げて田圃道を○○町へ辿る小学生を思い浮べる。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やッ、いよいよ本ものになりやがった」　こんがらもこの有様を見ると、馬の背につけておいた藁苞の道中差を押ッ取り、いきなり駈け寄って鐘巻自斎の横合から、「野郎、覚悟をしろ！",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋と火を借りれば……」　泥の藁苞を下げて、御膳所の口を覗いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を泥田へ入れたらしく、真っ黒にして何か藁苞に容れて持っている。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旁※、一度は訪れようと考えていた矢先、ちょうどよい、ここへは苦情の来ぬように俺が禁厭をして来てやる』　青貝柄だの、樫だの、朱柄だのの槍が十本程、一束にして藁苞に巻いて荷の中に立てかけてあった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に行われているのは餅を一種の藁苞に入れて、屋敷まわりの一定の樹の枝に引掛けて置き、それから大きな声で烏を喚ぶのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "餅を包んだ藁苞を蔵って置いて、田植の日の苗束に用いる風習があったらしいのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩手県では一般にこれをシットギと謂い、風の神送りの日に作って藁苞に入れて供え、または山の神祭の際に、田の畔に立てる駒形の札に塗りつけた。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁苞の馬に藁苞の餅を背負わせて、道祖神の前まで牽いて行って置いて来る。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち粢を藁苞に包んで、高い木の梢に引掛けておき、烏が来て持って行くことを念ずるのである。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、助九郎が戯れ半分に訊くと、「きょうは芋は持って来なかったけど、これをお通さんに持って来た」　と、丑之助は、手に提げていた藁苞を上げて見せた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが持って来てくれた気持は受けておきますから」「じゃあ、逃がしちまえ」　丑之助は、晴々といって、藁苞の腹を破った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りだしたのは藁苞である、グイとしごいて、苞からむきだされたのは、蝋色鞘の滑らかな大小。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
