          "standard": [],
          "literary": [
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度ごとに、ヘルンはまた『ごめん、ごめん』などと言って笑いふざけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "観衆と共に、げらげら笑い、観衆と共に泣くのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、笑いながら眠っていたわ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お笑いになっては、いけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、お笑いになって下さい。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にはねえ」私の顔をちらと見てから、口角に少し笑いを含めて、「ひとの見さかいができねえんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場は躊躇せず、その報いられなかった世界的な名手がことさらに平気を装うて薄笑いしながらビイルを舐めているテエブルのすぐ隣りのテエブルに、つかつか歩み寄っていって坐った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようという、なんの意味もない決心を笑いながら固めて、二人、浅草へ呑みに出かけることになったのであるが、その夜、私はいっそく飛びに馬場へ離れがたない親狎の念を抱くにいたった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだからこそ、こんなふうになんでもない口調で語れるのであるが、当時は、笑い話どころではなく、私は死のうと思っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいぶかしく思いながらその後姿をそれとなく見送り縁台に腰をおろすと、馬場はにやにやうす笑いして言いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のスケッチをいちまい二十円くらいで、何枚でも買って呉れるというひとがあるのです」にやにやひとりで笑いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やるなら一緒にやってもいい」「あなたは一体、何しにここへ来たのだろう」「さあ、――風に吹かれて」「言って置くけれども、御託宣と、警句と、冗談と、それから、そのにやにや笑いだけはよしにしましょう」「それじゃ、君に聞くが、君はなんだって僕を呼んだのだ」「おめえはいつでも呼べば必ず来るのかね？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が笑いながら言ったら、「やあ、このたびは御苦労。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お父さん、」と上の姉さんも笑いながら、「そりゃ当り前よ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにまた笑い出して、「うちのモオニングを貸してあげましょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ会って名刺を貰ってその名前をよんだときに思わず顔中が笑い出しそうになって困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も教授が厳粛な顔をしてこの人の名を呼びかける度に笑いたくなって困ったのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宅の女中が近所の小母さん達二、三人と垣根から隣を透見しながら、何かひそひそ話しては忍び笑いに笑いこけているので、自分も好奇心に駆られてちょっと覗いてみると、隣の裏庭には椅子を持出してそれに楠さんが腰をかけている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然向うの曲り角から愉快な子供の笑い声が起って周囲の粛殺を破った。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎まれ児世に蔓ると云う諺の裏を云えば、身体が丈夫で、智恵があって、金があって、世間を闊歩するために生れたような人は、友情の籠った林檎をかじって笑いながら泣くような事のあるのを知らずにしまうかも知れない。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳許で嘲笑いされたり、私語かれるような気がする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て鬼だ」「船長ってえ鬼だったよ」「大笑いさすなよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人鵜照君の年賀状観の変遷史をここに御紹介して読者の御参考あるいはお笑い草に資するのである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実を確かめないで学者が机上の議論を戦わして大笑いになる例はディッケンスの『ピクウィック・ペーパー』にもあったと思うが、現実の科学者の世界にもしばしばある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばこんな笑い話があった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったいそんなに拾って、どうしようと言うのだ」と聞くと、おもしろそうに笑いながら、「だって拾うのがおもしろいじゃありませんか」と言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警視長官は笑いながら先手を打って唄うたいの反則事件の調書を見せようとした。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警視長官は面白くもない昔の唄を町の唄うたいが義務で唄う表情を想像して笑いたくなったが我慢して穏かに断った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなもも一度わらいました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
