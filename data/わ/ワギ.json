  {
    "uuid": "2fcb95b4-17a3-5a50-a9a6-fb0391beb22c",
    "entry": "和議",
    "reading": {
      "primary": "わぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
