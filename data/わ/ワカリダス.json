        "examples": {
          "standard": [
            {
              "text": "何度も練習を重ねるうちに、だんだんとピアノを弾く楽しさが分かりだした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "最初は苦手だった上司の良さが、一緒に仕事をするうちに少しずつ分かりだしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "物語の伏線が回収され始め、事件の全体像がようやく分かりだしたところだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "他人の名を詐称している事実を告白しないかぎり、冤罪をいいとく方法はないわけだが、調べが捗れば、自然わかりだすのだと思い、徹底的に取調べられることを期待して、知らない、そんなことはないの一本槍で突っぱった。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年かの後、複雑な裏の事情が自然にわかりだすまで、それらの機微を明確に把握できるものはひとりもあるまいということだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
