    "definitions": [
      {
        "index": 1,
        "gloss": "young person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それといふのが世態で何しろ神経生存だけになつてゐて、まづまあ金ピカ流儀を覚えて「嗤はれないやうに嗤はれないやうに」か、又一方「我等は若きプロレタリアだツ」になるほか差当つて帰趨を知らないからである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私が、私の言語における「詩」といふ定義を換へるならば、彼は疑ひもなく詩人――しかも最も若き時代の詩人――であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの若き芸術家たちが世界に呼びかけた機関雑誌。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の日に感じたものは、春の若き悩みであったところの「恋を恋する」思いであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにそこには若き日本の若い人の情緒がある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗き空へと消えゆきぬ　　わが若き日の夢は希望は。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪はあまりに深く　　その月はあまりに清く、あはれわが若き日を燃えし希望の　　今ははや暗き空へと消え行きぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたるは、いのちを自然に還して、その肥田から若きものの芽を芽出たしめるという。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は判っててよ」　女は、この類いで、この若き獣神が生きとし生けるものの醜悪の底の味いを愛惜し、嘗め潜って来たであろうことを察して、悪寒のある身慄いをした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木は自分ながら壮躯と思われる身体に、麻布のブルーズを着て、頭を鏝で縮らし、椅子に斜に倚って、煙草を燻ゆらしている自分の姿を、柱かけの鏡の中に見て、前とは別人のように思い、また若き発明家に相応わしいものに自分ながら思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルダス・ハクスレーの短篇『若きアルキメデス』には百姓の子のギドーが木片の燃えさしで鋪道の石の上に図形を描いてこの定理の証明をやっている場面が出て来るのである。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の婦人のまだうら若きと見ゆるが靴の上に草鞋をはき、一人は橋の上に立ち、一人は岩に腰うちかけて絵など写すめり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三紀層、白堊紀、石炭紀、Silurea 紀と地球創成の跡を究めて、遂に太古の暗黒時代に這入つた時、若き研究家であつた彼が、人生の大きな不安に捉はれて、深い懷疑に沈んだ時を私は想像した。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老えるも若きも、病めるも健やかなるも。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて若き夫婦の幸しき月日は夢よりも淡く過ぎたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "年若き教師の、詩読む心にて記憶のページ翻えしつつある間に、翁が上にはさらに悲しきこと起こりつ、すでにこの世の人ならざりしなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き乞食はその鈍き目を顔とともにあげて、石なんどを見るように源叔父が眼を見たり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時若き男二人もの語りつつ城下の方より来しが、燈持ちて門に立てる翁を見て、源叔父よ今宵の寒さはいかにという。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや行き過ぎて若者の一人、いつもながら源叔父の今宵の様はいかに、若き女あの顔を見なばそのまま気絶やせんと囁けば相手は、明朝あの松が枝に翁の足のさがれるを見出さんもしれずという、二人は身の毛のよだつを覚えて振向けば翁が門にはもはや燈火見えざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老夫婦は声も節も昔のごとしと賛め、年若き四人は噂に違わざりけりと聴きほれぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州よ我子よと呼びつつ走りゆくほどに顔のなかばを朱に染めし女｜乞食いずこよりか現われて紀州は我子なりといいしが見るうちに年若き眼に変わりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助を中にして三つの墓並び、冬の夜は霙降ることもあれど、都なる年若き教師は源叔父今もなお一人｜淋しく磯辺に暮し妻子の事思いて泣きつつありとひとえに哀れがりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "県出身の若き将校らの悲壮な戦死を描いた平凡な石版画の写真でも中学生のわれわれの柔らかい頭を刺激し興奮させるには充分であった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく今日のいわゆるファイティング・スピリットの旺盛な勇士であって、今日なら一部の人士の尊敬の的になったであろうに、惜しいことに少し時代が早過ぎたために、若きウェルテルやルディン達にはひどく毛嫌いされたようであった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、これは諷刺に非ず、格言に非ず、一篇のかなしき物語にすぎず、されど、わが若き二十代の讀者よ、諸君はこの物語讀了ののち、この國いまだ頑迷にして、よき通事ひとり、好學の白石ひとりなきことを覺悟せざるべからず。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き時｜活計疎く、西南の不夜城に居びたりのいきつき酒して耳に近き逐ひ出しの鐘を恨み、明けて白む雲をさへうるさやと遣戸さゝせ、窓塞がせ、蝋燭を列べさせて、世上の昼を夜にして遊ぶも、金銀につかへぬ身のすることならば、人のかまふべくも無し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇的映画などは一日一日に古くなっても、ニュース映画は日に日に新たに、永久に若き生命を保つであろうと思われる。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国展の会場をざっとひと回りして帰りに、もう一ぺんこの「秋庭」の絵の前に立って「若き日の追憶」に暇請いをした。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイデルベルヒの学生歌」（俗名、若きハイデルベルヒ）でも窓下の学生のセレネードは別として、露台のビア・ガルテンでおおぜいの大学生の合唱があって、おなじみのエルゴ・ヴィヴァームスの歌とザラマンダ・ライベンの騒音がラインの谷を越えて向こうの丘にこだまする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われより若き素直の友に、この世のまことの悪を教えむものと、坐り直したときには、すでに、神の眼、ぴかと光りて御左手なるタイムウオッチ、そろそろ沈下の刻限を告げて、「ああ、また、また、五年は水の底、ふたたびお眼にかかれますかどうか。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
