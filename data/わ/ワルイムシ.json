    "definitions": [
      {
        "index": 1,
        "gloss": "undesirable lover (boyfriend, girlfriend)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
