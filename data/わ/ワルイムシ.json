        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悪い虫のつかんうちにお祖父やんのこれと見込んだ男と結婚しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い虫のつかんうちに、お祖父やんのこれと見込んだ男と結婚しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓼酢で松魚だ、身が買えなけりゃ塩で揉んで蓼だけ噛れ、と悪い虫めら。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みてゐるうちに、私は、こんな気味の悪い虫を、到底姉になぞ飲ませられるものかと思つた。",
              "citation": {
                "source": "イボタの虫",
                "author": "中戸川吉二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが実に危険なので、もしや二日も三日も溜まっていた水だと鉛毒は勿論、悪い虫も必ず発生しているに違いない。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどつばめは、その翌日から、きんまくわの悪い虫だけは、一ぴきもとつてやりませんでした。",
              "citation": {
                "source": "きんまくわ",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イナゴといふ虫は、お米のできる稲をあらす悪い虫ですが、それは煎つて食べるとおいしいので、近くの町へ売れるのでした。",
              "citation": {
                "source": "栗ひろひ週間",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしは、むやみにだつて、悪い虫なら殺した方がいいんだと思ひます。",
              "citation": {
                "source": "原つぱの子供会",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、悪い虫なら、いくら殺したつてよいといふ意見です。",
              "citation": {
                "source": "原つぱの子供会",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、いつか顕微鏡で見た『てんたう虫』ですね、あれは悪い虫を喰つてくれるよい虫です。",
              "citation": {
                "source": "原つぱの子供会",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛虫もバイキンと同じやうなもので、人間に少しも益になることをしない、悪い虫です。",
              "citation": {
                "source": "原つぱの子供会",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "好子さんの云はれたやうに、わたしも悪い虫なら、むやみにだつて……いいえ、一匹も残らないやうに殺してしまつた方がいいんだと思ひます。",
              "citation": {
                "source": "原つぱの子供会",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな悪い虫ぢやなくて、とつてもいい虫虫様だよ。",
              "citation": {
                "source": "母子ホームの子供たち",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い虫だが、とつてしまへばよいのだから、他の病気よりは性質はいゝと云ふことになる。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年このころになると、悪い虫がつくのでありましたから、今年は、どうか満足に実を結ばせたいと思いました。",
              "citation": {
                "source": "牛女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからとなく、たくさんのこうもりが飛んできて、毎晩のようにりんご畑の上を飛びまわって、悪い虫をみんな食べたのであります。",
              "citation": {
                "source": "牛女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、りんごには、おかげで悪い虫がつかずによく実りました。",
              "citation": {
                "source": "牛女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「先生、うちの娘っこに、このごろ悪い虫がつきやしてナ、どうも心配でならねえのですが――」　泰軒先生のあとから、長屋の連中が行列のようについて、ワイワイいって作爺さんの家へ送りこむんです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、もっと性の悪い虫なんで。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あんたも、そうはじめから悪い虫ときめてしまわんで、よくその虫を見ることだな。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間知らずの、子供のような人でな、あれに悪い虫がついたならば、いかな雑賀屋の大財産も、一たまりもないであろう。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑賀屋のおせい様に、とうとうその悪い虫がついたのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私がお前達に話した事を急いで繰り返せば、それがどんな悪い虫でも離れた処から、吾々に害をしたり、毒を放たりする虫はゐない。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その松の嫩枝を咬み、新芽を食つて木の育つのを妨げる悪い虫が繁殖しないやうに殺してしまふ為めにはさうするより仕方がない。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菊には去年の秋から、落合の徳松という、悪い虫が付いていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "玉の輿の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "手頃の貸家があるなら世話して下さいよ、家賃なんかに糸目は付けないから――といったような具合にな」「それくらいのことを言ったんじゃ、腹の虫が納まりませんよ」「たいそう機嫌の悪い虫だね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人娘のお仙を、同じ商売仲間の末広町の八百峰の跡取り息子に嫁にやるについて、俺の力が借りたいと言うのだよ」「悪い虫でも付いているんでしょう、どうせ当節の娘だ」「そんな話じゃねえ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へッ、へッ、笑わせるぜ、見得を切ったって驚くこちとらじゃねえ、御領内に湧いた悪い虫だ、お見知り置いて貰おうか」　熊の皮の胴服の方は、山刀にうねりをくれて、人をなめ切ったようにせせら笑って居ります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "大名の倅",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか気味の悪い虫が這ってでもいる様なの。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「気をつけろよ」「…………」「其方はまだ知らんようだが、悪い虫がついておる」「……悪い虫が？",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
