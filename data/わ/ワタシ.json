[
  {
    "uuid": "9a0f159f-fa6e-56f7-b6c5-046ee422a574",
    "entry": "私",
    "reading": {
      "primary": "わたし",
      "alternatives": [
        "ワタシ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
