          "standard": [
            {
              "text": "コンピューターの割り込みコントローラは、複数の周辺機器からの要求を効率的に処理する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "OSの設計では、割り込みコントローラとの連携が重要な要素となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高性能な組み込みシステムでは、割り込みコントローラがリアルタイム処理の鍵を握る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この機能の制御用に、ＰＣはインテルが製品化していた８２５９Ａと名付けられた割り込みコントローラーを使っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
