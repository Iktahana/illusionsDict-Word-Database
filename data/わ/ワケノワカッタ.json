        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも冷静で、訳の分かった意見をくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その長老は、人生経験豊かで、訳の分かった話をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと訳の分かった、現実的な計画を立てよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "角灯に火をつけて、我々一同は、こんなことよりはもっとわけのわかった事がらにふさわしいような熱心さをもって仕事にとりかかった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの新吉はどうなったかはわかりませんが、世の中には鍛冶屋のおやじや曲馬団の団長のようなわからずやの意地わるの人間がいるかわりに、この動物園のおじいさんのようなわけのわかった親切な人もたくさんいます。",
              "citation": {
                "source": "曲馬団の「トッテンカン」",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははははは」　なんというわけのわかった、奥ゆかしいお侍だろう！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
