    "definitions": [
      {
        "index": 1,
        "gloss": "to apologize sincerely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眼上のものに心から詫び入る姿のように。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と手を支いて、誰にか詫び入る、そのいじらしさ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師にまた打たれて詫び入ると徐かに這って行けという。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐れ入りまする――かかる痴かしきすがたを御覧に入れまして――」　と、詫び入るように言うと、「まず、立ちなさい。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　浪路は、詫び入る甚太郎の言葉が、耳にはいらぬように、「いかに、おな子の身は弱いというたとて、どこまでもどこまでも一家、一門のために、牲に生き、牲に死ぬほかはないと言やるのか？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしから云や、まあ頭をさげて、かうかう娘が申します、まことに不都合な次第だが、反対する元気もないので、と、あの婆さんに、詫び入る一手だ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "詫び入るのを無理に引っ張って椽側の前まで連れて来た。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かへつてこちらが気の毒なほどに詫び入るその律気さに、あの本はさう云ふ運命だつたのだらう。",
              "citation": {
                "source": "堀辰雄のこと",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに申し訳ありません、お許し下さい』そして畳に頭をこすりつけて詫び入るのでした。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して悪気でしたことではございません」　幸吉は板敷の上に額を埋めて、泣かぬばかりに詫び入るのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "白紙の恐怖",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して惡氣でしたことでは御座いません」　幸吉は板敷の上に額を埋めて、泣かぬばかりに詫び入るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "白紙の恐怖",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かおふくみあっての事か」　すると半兵衛重治は、すこし膝を退げて、詫び入る体で静かに諭した。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私はすぐに詫び入る態度に出ることなく、君の気持だけは然しありがたく貰って置くよ、と初めのように静かに話しかけることが出来た。",
              "citation": {
                "source": "指導物語",
                "author": "或る国鉄機関士の述懐",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも若い教官からなにがなくとも珍らしいお客にお茶ぐらいいれようじゃないか、と促され、すっかり忘れていました、と詫び入るように微笑んで立ちあがった彼は、矢張りいつもの佐川二等兵であった。",
              "citation": {
                "source": "指導物語",
                "author": "或る国鉄機関士の述懐",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞どの、このとおり手をつかえ……弁円が初めて、おん身の足もとにこう手をつかえて、詫び入るのだ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お疑い申した罪は、ご勘弁ねがいたい」　詫び入るので、権之助も間が悪くなって、「おれも良くなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなお、諄々と、「べつに、どういう心算でもなく、お堂の中に、女子の泣き声が聞えたので、不審に思って、覗いてみただけでござります」　と、言い訳して、平蜘蛛のように、詫び入るだけだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう二度とは、身に過ぎた願いはいたしません）　と、彦兵衛が、身をちぢめて、詫び入ると、（いや、ほんとに、刀のひとつもさしてみたいと、志を立てるなら、ひとの為になるような功を積むがよい。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慚愧にうたれて、詫び入ることばも見つからなかった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さっきからただ、詫び入るばかりだった老人とともに、「わたくしたちは、もと開封東京の者でございますが、重い税にくるしめられて、商売もなりたたず、この渭州へ流離うてまいりました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――奉行の賀は、まだあとから少し遅れてまいりますと、三拝九拝、階の下で、詫び入るばかり。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それにひきかえて、半兵衛ごときは」　と、また病躯を責めて、詫び入るらしい気ぶりを抑えて、秀吉は彼のことばを不意に奪った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――済まない）　ただそう思って、胸の中で詫び入るほかはない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　怒りにふるえ、猛りに猛って、周瑜の耳は、詫び入る諸将のことばなど、まるで受けつけなかった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
