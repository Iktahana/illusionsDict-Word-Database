        "examples": {
          "standard": [
            {
              "text": "地方の道の駅では、様々なわら細工がお土産として売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は昔、美しいわら細工を作るのが得意だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、わら細工体験でオリジナルのリースを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その半分、裸のかしわが、クックッと逃げる情景　支那の老婆が日向ぼっこして、麦わら細工を縫み乍ら兵隊の行軍を見ている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "川崎の宿で駕籠をかえて、大森へさしかかった時に、お峰は近所の子供へ土産をやるのだといって名物の麦わら細工などを買った。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "町屋から蒲田へさしかかって、梅屋敷の前を通り過ぎたが、あまり風流気のない二人はそのまま素通りにして、大森に行き着くと、名物の麦わら細工を売る店のあいだに、休み茶屋を兼ねた小料理屋を見つけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
