[
  {
    "uuid": "4a5d61f4-b566-5c95-a952-dac9766dc6c2",
    "entry": "輪になる",
    "reading": {
      "primary": "わになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
