    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indivisible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向うものが運命なら運命のぎりぎりの根元のところへ、向うものが事情なら、これ以上割り切れない種子のところに詰め寄って、掛値なしの一騎打の勝負をしよう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは割り切れないかもしれない。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雇傭関係は自発的にも法的にも次第に合理化されつつあり、末梢的には割り切れないものが残っていながら、幾分光りが差して来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり小菊に芸者屋を出さす相談であったが、彼女も最初に首をひねり、盗人に追い銭の感じがして、ぴったり来ない感じだったが、しかしその割り切れないところは何かの惑かしがあり、好いことがそこから生まれて来るように思えた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、この白樺の幹の蔭に、雀を狙う黒い猫みたいに全身緊張させて構えている男の心境も、所詮は、初老の甘ったるい割り切れない「恋情」と、身中の虫、芸術家としての「虚栄」との葛藤である、と私には考えられるのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも得体の判らない家の生活に混っていると、いつまで経っても割り切れない奇数の出続ける数字を扱っているようなもどかしさから不安の気持に襲われました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私に割り切れないものがあの社を去るに当って一つあった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そんな野心がふと恋心めいた情熱に変っているのだから、所謂男の心は公式では割り切れない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　私は割り切れない不思議な出来事の数々を考え考え暗闇の中を二三町ほど手捜りに歩いて行った。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、その色彩の原素性は、彼がフランス的であるといふ意味でシャガアル風な民俗的などうにも割り切れない人間的な色彩上の原素性、原始性ではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこがどうとハッキリわかっているわけではないけれど、近頃の生活は何だか身体のなかに、割り切れない残りかすが日一日と溜まってくるようで仕方がないわ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが合理的な考へで割り切れない、合理的な考へを追ひ詰めたその一歩先の所から湧いて來るやうなものが豫感だ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　指揮単位が個人になるとの判断は、今日までの大勢、即ち大隊→中隊→小隊→分隊と分解して来た過程から推察して次は個人となるだろうというので、考えには無理がないようであるが、次に来たるべき戦闘方法に対する判断がつかないため、私としても質問者と同様、具体的に考えると何となく割り切れないものがある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "割り切れない、割り切らうとあせらない心境逍遙。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "□人生は割り切れないだらうが、割り切れるやうな場合もないではない、深い体験で算盤玉を弾く時。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "割り切れない人生、どうやらかうやら、へゞれけ人生からほろゑひ人生へ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝人事件判決が下つた、被告全部無罪、私たちには事件の真相はつかめないけれど、割り切れないものがあるらしい、その割り切れないものは現社会の癌だらう！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "未明起床、残つたゞけを飲む、身辺整理、私には私では割り切れないものがある！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそうなるべきだと思いながら、庸三の心には今なお割り切れないものがあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが之は文芸現象を理性によって割り切れないということではない。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "米穀通帳なり金融通帳なり見せて貰つて控へておけば大丈夫でせう」　僕はまだ割り切れないものがあつたが、その足でアパートの部屋を訪れた。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「資本関係のない二つの企業から給料を受け取っていては、双方の利益が衝突したときに割り切れないだろう」との認識を、彼らは共有していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の力では、とうてい割り切れない問題を、あの方だけは、御自身でやり遂げようとなさっているのではないでしょうか。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの行手に横たわる不安と、意地を屈したことに対する割り切れない気持にもかかわらず、私はこの恵まれた現在を愉しまずにはいられなかった。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあどうぞ」　帆村にすすめられて、亀之介は割り切れない気持で、室へ再び足を踏み入れた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行者としては、むしろ、割り切れないものにぶっ突かった方が興味がある。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧進帳を出したのは、興行師らから、断わりきれない頼みだったんだ。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "概ね雲水などというものは、至極わりきれない精神や、肉体を袈裟につゝんで諸方をハイカイするにすぎないようなものであるが、ソノ子の場合はそのような不明快なものではない。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、みんなしてこの平さんをチヤホヤした上に、店の女中を初め、見知らぬお客までが、その当り運にあやかりたいというわけで、一杯いただきたがるものだから、平さんは断わりきれないで、つい、うかうかと呑んでいるうちに、腹のしまりがつかなくなりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は内面的には強い人であったようだが、人から頼まれれば断わりきれないところがあった。",
              "citation": {
                "source": "十五年",
                "author": "山本実彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
