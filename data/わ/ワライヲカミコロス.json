        "examples": {
          "standard": [
            {
              "text": "厳粛な雰囲気の中、彼は必死に笑いを噛み殺していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生のユニークな発言に、生徒たちは笑いを噛み殺すのに必死だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真面目な顔をして笑いを噛み殺している彼の姿を見て、さらに笑ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "苦が笑いを噛み殺すためであつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホ、ホ」　お半は少し蓮っ葉に言って、笑いを噛み殺すのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村吉右衛門は、あの通りの人柄だから、六代目みたいに大っぴらに笑わぬ代り、まことに苦り切った顔で、笑いを噛み殺すのに骨を折っている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして給仕頭や小間使や大勢の女中たち、しまいには笑い声に惹かれて料理人や門番までが、恐る恐る広間の入り口近くへ覗きに来て、妻や私の気を兼ねながらいかに渋面作って笑いを噛み殺すのに骨を折ったことであろうか！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
