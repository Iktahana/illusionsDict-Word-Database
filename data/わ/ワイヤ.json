        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "横手の外人別荘から、小さい金髪の男の子が、ワイヤー・ヘヤードを連れて、どこどこまでもかけて行った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてマリーが二十二歳になるまで過ぎていったが、そのとき彼女のすばらしい美貌が、パレ・ロワイヤールの地階に店を持っていて、その付近に巣くっているごろつき投機師どもをお得意にしているある香水商の眼にとまった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三年半ばかり以前（６）、この同じマリー・ロジェエがパレ・ロワイヤールのル・ブラン氏の香水店から姿を消して、今回のとたいへんよく似た騒ぎを起したことがある。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜のこと、我々はパレ・ロワイヤール付近の、長い、きたない街をぶらぶら歩いていた。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈錘と、ワイヤとは投げられた石のように飛んで行く。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大工、なぜすみへ行く、そのワイヤを抜くんだ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吊り下がっているワイヤーが、その垂直線の囲りを、ゆるく円を描いて揺れていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一直線に張っていたワイヤーだけが、時々ブランコのように動いた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイヤ・ロープが、誰か下で振っているように揺れていて、ボクンボクンと鈍い不気味な音は其処からしていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイヤーを巻いている歯車の工合で、グイと片方のワイヤーだけが跛にのびる。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井を縦断している二条のレールをワイヤー・プレーをギリ／＼と吊したグレーンが、皆の働いている頭のすぐ上を物凄い音を立てゝ渡って行った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鋳物場で型上げしたばかりの、機関車の車輌の三倍もある大きな奴で、ワイヤー受けの溝をほるために、横｜穿孔機に据えつけるためだった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ボール盤の側に、四五人の職工とパンパン帽をかぶった職長が集って、ワイヤー・プレーを跛に吊したグレーンがガラ／＼と寄ってくるのを見ていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンがとまると、ワイヤー・プレーは余勢でゆるく揺れた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイヤー・プレーは底を二つの滑車にのせ、穿孔機の腕にその軸と翼を締めつけて、固定された。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あの大きなワイヤー・プレーはたった一つの音もたてずに、グイと手前にのめってくる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "船腹の半ばまで下った時、ワイヤ・ロウプの一本が軋んで動かなくなった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっそりとやせ、ワイヤーフレームの眼鏡をかけたゲイツは、青年というよりも少年といった方が似つかわしい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "針金に情報を書き込むワイヤーメモリーを用い、記憶させた検査のためのプログラムをデコーダーを使って読み出すＩＣテスターの頭脳の開発にあたった後藤は、意識しないうちにコンピューターの基礎技術を身につけていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての機能を回路に作り付けてしまうワイヤードロジックに代え、シンプルなＣＰＵとプログラムの組み合わせで機能を組み立てるという発想をより徹底させれば、はじめから一つにまとまったマイクロコンピューターを使うというアイディアが当然浮上してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラントの各所のデータを集めて表示、分析するシステムを、これまで横河電気はワイヤードロジックで作っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸べの森の一角に見えるカフェー・パビヨンロワイヤルの天蓋の上には、一面の紅霧が棚曳き渡り、湖は森の地平から盛り上った張力を見せ灯火に光っている。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "パビヨンロワイヤルの桃色の明りが見えて来ると、島に繁った花の樹が水の上から次第に白く朧ろに浮いて来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中のパピヨン・ロワイヤルだけは常の日と変らなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロワイヤルを出てからすぐ裏の森の中へ二人は這入っていった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイヤとチエンで、どんなに緊り縛り付けといたって、一旦辷り出したとなれあ、人間の力で止める事が出来ない。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠見でホルバインの、「マーガレット・ワイヤット（ヘンリー八世の伝記者、タマス・ワイヤット卿の妹）の像」に似ていると思われたクリヴォフ夫人の顔が、近づいてみると、まるで種痘痕のような醜い雀斑だったからである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス大革命時代に流行した「アンクロワイヤーブル」(その名からして『本当とは思はれぬ』と云ふ意味だ。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
