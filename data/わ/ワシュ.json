[
  {
    "uuid": "a76735c4-bb2f-5474-b554-5d315774733e",
    "entry": "和酒",
    "reading": {
      "primary": "わしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "traditional Japanese alcohol (primarily sake, but also shōchū and fruit wine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は常々私の和酒好みを嫌つて、せめてカクテールの調合位ゐには興味を持つて呉れ、そして、いろ／＼な酒罎を本棚にでも並べて、殺風景な部屋の飾りにでもしてお呉れ――などゝ云つてゐたのである。",
              "citation": {
                "source": "ファティアの花鬘",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに事を仕損じて誰に迷惑がかかったというでもなし、この女の罪はわたくしに免じてどうか御勘弁を願わしゅう存じます」　女がしきりに頼むので、半七は無下に跳ねけ付けることも出来なくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なまけて、何もしゅくさらんとて、工場から飯を食わしゅてやっとるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――そのお言葉を聞くにつけ、いよいよあなたがおいたわしゅう存じます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五人の侍女に目遣す）平にお聞取りを願わしゅう。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お察しなされて下さりませ』（法師五六人、親鸞聖人の木像を担ぎ出して来る）阿闍梨『親鸞どのもいたわしゅう思召されていらるるだろう。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花に嵐の比喩も古めかしい事ながら、さて只今と相成りましては痛わしゅうて、情のうて涙がこぼれまする事ばかり……。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいたわしゅうござりますれど、もうおわかれ申しまする。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわしゅう教えてくだされぬか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂部が奥へゆくと、今まで時々物狂わしゅう呶鳴り散らしていた師直の声が急に鎮まった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ程の恋を――二十年来｜偲びに偲んだこれ程の想を、この世で一言も打ち明けいで、何時の世誰にか語るべきと、思うに付けても、物狂わしゅうなるまでに、心が擾れ申して、かくの有様じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れながら、これには三人の人の命がこもっておりまするゆえ、末長くご秘蔵願わしゅうござりますと、ご用人さまにお取り次ぎお願いしてな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "上さまご祈願所を汚しましたる不敬の数々、なにとぞお許し願わしゅう存じます」「なんのなんの、そのごあいさつでは痛み入りまする。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしきようにお計らい願わしゅう存じます」　僅かにそれだけを書いた書置なのです。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見のがし願わしゅうござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女魔と申すものはとかく美しきもの、御寵愛はさることながら、それゆえにお上ほどの御明君が、正邪のお目違い遊ばされたとあっては由々しき大事、只々御明察のほど願わしゅうござります……」　一にも明君、二にも明君、只明君々々と明君ずくめで押し通しました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて腰本治右の企らみましたるつくりごと、御賢察願わしゅうござります」「でも治右は、その方がささに酔いしれて、紋にたわむれかけたと申しおるぞ」「以ってのほかの讒言、みなこの早乙女主水之介を罪ならぬ罪に陥し入れようとの企らみからでござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は二なき御明君、御明察願わしゅうござります」「いずれにしても不埓者じゃ、不、不埓者めがッ」「恐れ入ってござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじきじきのお裁き願わしゅうござります」「………」「恐れながら御賢慮のほど、いかがにござります」「憎い。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸旗本早乙女主水之介、松平の御前にお目通り願わしゅう存じまするが、いかがにござりましょう」「なになに、旗本とな――」　声をきいて、源七郎君お自ら磊落そうにふり向くと、流れに垂れた釣竿をあやつりあやしつつ、じいッと退屈男をやや暫し見守っていたが、伯楽よく千里の馬を知るとはまさにこれです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども、わたくしが捜査に従うということは、なるべく厳秘に願わしゅうござります」「そうか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "力を貸す段ではないが、余に何をせよというのじゃ」「下手人はこのごろ新しく浪人になった者でござりましょうとも、浪人とことが決まりますれば、御前の、あの――あとはご賢察願わしゅう存じます」「おお！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人者と決まりますれば、御前の、あの――あとはご賢察願わしゅう存じます、といった御前のあの、というその「あの」なる「あの」はなんであるか？",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせわしゅうもございましょうが、お通りすがりの節は、ちとお立ち寄りを。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
