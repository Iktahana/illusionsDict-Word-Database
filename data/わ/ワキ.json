[
  {
    "uuid": "e6a7d4b2-c530-52aa-ba66-3433fcc64be9",
    "entry": "脇",
    "reading": {
      "primary": "わき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "armpit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぎょっとして振りむくと、馬場の右脇にコバルト色の学生服を着た背のきわめてひくい若い男がひっそり立っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四丁目で電車を下りると皿の包を脇の下へ抱えてみたが工合が悪い。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹燈籠とかの活人形はその脇にあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左脇の家に人｜数多集い、念仏の声洋々たるは何の弔いか。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い冠木門の両開き戸をあけるとすぐ玄関で案内を乞うと右脇にある台所で何かしていた老母らしきが出て来た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右脇には句集など取散らして原稿紙に何か書きかけていた様子である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さねかずらとはどんなものかしらず、蔦這いでる崖に清水したゝって線路脇の小溝に落つる音涼し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道の並木の松さすがに昔の名残を止むれども道脇の茶店いたずらにあれて鳥毛挟箱の行列見るに由なく、僅かに馬士歌の哀れを止むるのみなるも改まる御代に余命つなぎ得し白髪の媼が囲炉裏のそばに水洟すゝりながら孫｜玄孫への語り草なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう晩には綿入羽織をすっぽり頭からかぶって、その下から口笛と共に白い蒸気を吹出しながら、なるべく脇目をしないようにして家路を急いだものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃｜流行った鍔の広い中折帽を被って縞の着物、縞の羽織、それでゴム靴をはいて折カバンを小脇にかかえている、そうして非常にゆっくり落着いて歩いて来るのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、もう一つ、宅の門脇の長屋に住んでいた重兵衛さんの一家との交渉が自分の仮想的自叙伝中におけるかなり重要な位置を占めているようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰掛の一番後ろの片隅に寄りかかって入口の脇のガラス窓に肱をもたせ、外套の襟の中に埋るようになって茫然と往来を眺めながら、考えるともなくこの間中の出来事を思い出している。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」早く殺さないと肉が落ちると云うので要太郎が鳥の脇腹をつまむと首がぐたりとなった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「来たら脇腹をつまんでやらあ。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いことは横町の入口の両脇の角に「ユヤ」「床ヤ」と書いてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この袋町への入口の両脇に「ユヤ」「床屋」としてある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから下の方へ下がった道脇に「正門」とあるのはたぶん前田邸の正門の意味かと思われる。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突の脇へ子供を負った婆さんとおばさんとが欄干にもたれて立って、伝馬の船底から山を見ている顔が淋しそうな。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体が西を向いて行くのであるから、椎茸は車の右脇へ頭を出したり左へ出したり。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちている破片の量から見ると、どうもこの二本は両脇の二本よりだいぶ高かったらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳代の青年期に蜃気楼のような希望の幻影を追いながら脇目もふらずに芸能の修得に勉めて来た人々の群が、三十前後に実世界の闘技場の埒内へ追い込まれ、そこで銘々のとるべきコースや位置が割り当てられる。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その脇に沿うて略同じ勾配の道路をつけるから、自然に途中で道と河の高度差の最大な処が出来るのであらうかと思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れに沿うて二條のトロの鐵軌が敷いてあつて、二三町距てた電車通の神社の脇に通じて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の方へ下りる坂脇の稲荷の鳥居も、柱が立って桁が落ち砕けていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その脇に沿うてほぼ同じ勾配の道路をつけるから、自然に途中で道と河との高度差の最大な処が出来るのであろうかと思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は掌を裏返しに脇腹を焦れったそうに掻いた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、手頃に傷けてまだ息を残さしてある雄鹿を小脇に抱えていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い芸妓たちは、とうとう髪を振り乱して、両脇腹を押え喘いでいうのだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」達二は脇差しを抜いて身構えしました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
