[
  {
    "uuid": "fa53661e-7be0-5235-944f-a8cd0560f3e8",
    "entry": "我",
    "reading": {
      "primary": "われ",
      "alternatives": [
        "わ",
        "あれ",
        "あ",
        "わぬ",
        "わろ"
      ],
