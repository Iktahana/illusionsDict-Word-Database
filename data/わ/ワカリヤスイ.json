    "definitions": [
      {
        "index": 1,
        "gloss": "easy-to-understand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
