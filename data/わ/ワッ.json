    "definitions": [
      {
        "index": 1,
        "gloss": "boo! (sound used to scare someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
