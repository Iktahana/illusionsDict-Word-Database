[
  {
    "uuid": "ac6e77f1-c558-5fb6-a5fc-71e8c7ea3a25",
    "entry": "詫ぶ",
    "reading": {
      "primary": "わぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Nidan verb (upper class) with 'bu' ending (archaic)",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to apologize",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ほう、実雅の前で詫ぶるというか。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "我にも疾く往きね、揺返しと云ふこともあれば危し、疾く／＼とそゝのかせど、風いたう吹きて寒げなれば、悩める身の風に当りて悩まさりて死なむも、こゝにて押し潰されむも同じ命なり、動くことも懶ければ、此儘にてあらせてよと打詫ぶ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "構へて待たせし心ならねば……」ト、詫ぶるに鷲郎も深くは咎めず、やがて笑ひにまぎらしつつ、そのまま中に引入れて、共に夕餉も喰ひ果てぬ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧めて無理な勉強をさして、此様な事になってしまって、まことに済みません、と詫ぶる外に彼等は慰めの言を知らなかった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふより早し肩先てうと蹴倒し、詫ぶる詞は耳にもかけず、力に任せて打擲しつ、　お前のやうな不貞なものは、ちよつとも家に置く事は出来ぬ。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "済まなかつたと、詫ぶれば格別。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "せがれ奴をさし出して、お旅先を心なきお引留め、おゆるしを」　と、詫ぶるのであった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "不肖家時、清和の嫡流に生まるといへど、かなしいかな、徳なく才とぼしく、家祖の遺託に応ふるあたはずして、苦計むなしくやぶれ、かへつて、家統も危きを見、わづかに家名の絶えを支へんため、ここに一切を闇に附し、一身を屠腹して、子孫に詫ぶ。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「さればで……」　と、言い詫ぶる態で。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔たゞかたくなのみをわぶる〕宮沢賢治　　……たゞかたくなのみをわぶる　　　　なにをかひとにうらむべき……ましろきそらにはゞたきてましろきそらにたゆたひて百舌はいこひをおもふらし",
              "citation": {
                "source": "〔たゞかたくなのみをわぶる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔島わにあらき潮騒を〕宮沢賢治島わにあらき潮騒をうつつの森のなかに聴き羊歯の葉しげき下蔭に青き椿の実をとりぬ　　南の風のくるほしく　　波のいぶきを吹き来れば　　百千鳥　すだきわぶる三原の山に燃ゆる火のなかばは雲に鎖されぬ",
              "citation": {
                "source": "〔島わにあらき潮騒を〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "｣　　　　　　声またもわぶるがごとき。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　声またもわぶるがごとき。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重の雲遠くたゝへて、　　　西東はてをしらねば、白堊紀の古きわだつみ、　　　なほこゝにありわぶごとし。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　静に放すと、取られていた手がげっそり痩せて、着た服が広くなって、胸もぶわぶわと皺が見えるに、屹と目を※る肩に垂れて、渦いて、不思議や、己が身は白髪になった、時に燦然として身の内の宝玉は、四辺を照して、星のごとく輝いたのである。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに二時と忍ぶを得ず、涙を流して窮を訴へ、只管籠を出でむとわぶ、汝すら其通りぞ。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにわぶしの語句、「あした待たるる宝船。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "脊の高い瘠男の、おなじ毛糸の赤襯衣を着込んだのが、緋の法衣らしい、坊主袖の、ぶわぶわするのを上に絡って、脛を赤色の巻きゲエトル。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を静かに中へ引き込ませて、源氏の伴った惟光が妻戸をたたいて、しわぶきをすると、少納言が聞きつけて出て来た。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少し小さい字で、ねは見ねど哀れとぞ思ふ武蔵野の露分けわぶる草のゆかりを　とも書いてある。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あだに見し　夢かうつつかなよ竹の　おき伏しわぶる恋ぞくるしき　その声に兼好は思わず見返った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "起き臥しわぶる恋ぞくるしき――さすがにようぞ説き当てられた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あたえられた円座を占めて、権右衛門は直垂の袖をかき合わせると、師冬は軽いしわぶきを一つした。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島田髷や帯の乱れた後ろ姿が、嘲弄の言葉のように目を打つと、親佐は口びるをかみしめたが、足音だけはしとやかに階子段を上がって、いつもに似ず書斎の戸の前に立ち止まって、しわぶきを一つして、それから規則正しく間をおいて三度戸をノックした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内、夜陰の気はしんしんと引きしまって、しわぶきの音一ツない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "離り來て野邊におもへば露くさの花の色だにさはひとり求めわぶるなる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はその前を通ったとき、フトその一つの独房の中から低いしわぶきの声を耳にした。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の宴のあくる日で、ゆうべから酔いこけた賓客たちも日の高い頃にだんだん退散して、あるじの軽いしわぶきも遠い亭まできこえるほどに、広い別荘のうちもひっそりと静まっていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座はしわぶきの声もなくて、鳴き弱ったこおろぎが真垣の裾に悲しくむせんでいるのが微かに聞こえるばかりであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分は廊下に立って待っているんだが、出発に際しての彼の心配は全然｜杞憂に帰して、隊員は、しわぶきどころか呼吸を凝らしている。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
