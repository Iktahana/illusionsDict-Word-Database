          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "嘗て常陸の山に在って旅人から聞いた話の、八つの湖に女神の姿を待ち侘ぶ河神たちの姿も眼の前に見た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背戸續きの寮屋に、茅屋に侘ぶる風情とて、家の娘一人居たる午すぎよ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠栖の場所は行平が「藻塩垂れつつ侘ぶと答へよ」と歌って住んでいた所に近くて、海岸からはややはいったあたりで、きわめて寂しい山の中である。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "喃々と門を叩きて、今や開くると待侘ぶれども、内には寂然として聲なし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この内小金吾｜頻に侘ぶ。",
              "citation": {
                "source": "いがみの権太",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
