  {
    "uuid": "a629524f-fd23-5c97-8d1c-b84805fa33c8",
    "entry": "鷲",
    "reading": {
      "primary": "わし",
      "alternatives": [
        "ワシ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eagle (Accipitridae family)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは鷲にならうとして沒落したツァラトストラの人間悲劇にたとへられる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてレコードに吹き込んで呉れるかも知れない……ニツトー……ツバメか……鷲、さあ……」　私は何時の間にやらロマンチックな浮々しさになつてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と幸福との間に一羽の鷲が――不幸なこつた不幸な！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊橋も後になり、鷲津より舞坂にかゝる頃よりは道ようやく海岸に近づきて浜名の湖窓外に青く、右には遠州洋杳として天に連なる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上見ぬ鷲の翔らん天ぎわから地上へかけて雲の帳は相変らずかけ垂れていたが、深まり来るたそがれの色にあらがうように帳の色は明るく薄れ行きつつある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山寄りの道を行く方が山の岳神を探すに便利は多いようなものの、それ等の山は多く未開の山で、ちょっと人に訊いただけでも、山の主は、百足であるとか、猿であるとか、鷲であるとか、気の利いた山の神ではなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう一度、東から今のぼった天の川の向う岸の鷲の星に叫びました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鷲は大風に云いました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらのなかほどへ来て、よだかはまるで鷲が熊を襲うときするように、ぶるっとからだをゆすって毛をさかだてました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうぢき鷲の停車場だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か書類のようなものを鷲握みにして読みはじめたと思ったらすぐ終った。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百分の一近辺のものは猩々、鹿、猫など、それから下って百分の一より千分の一の間にあるのが麒麟、象、羚羊、獅子、袋鼠、鷲、白鳥、雉、鼠、蛙、鯉など、なお一層下って千分の一より一万分の一の間には海馬、鯨、鰐、海鰻、章魚などがひかえている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢にも、過去の一切を投げ出し、鷲のやうに空を飛んだ。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鷲や鷹のやうな視覺を持たない。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光、鷲の前の小鳩と云った形。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母の夫は、足駄をはいて、両手に一俵ずつ四斗俵を鷲掴みにさげて歩いたり、肩の上へ同時に三俵の米俵をのっけて、河にかけられた細い、ひわ／＼する板橋を渡ったりする力持ちだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうじき鷲の停車場だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あかいめだまの　さそり　ひろげた鷲の　　つばさ　あおいめだまの　小いぬ、　ひかりのへびの　とぐろ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川もそらの井戸も鷲の星や琴弾きの星やみんなはっきり見えます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けたたましき跫音して鷲掴に襟を掴むものあり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦稈帽を鷲掴みに持添へて、膝までの靴足袋に、革紐を堅くかゞつて、赤靴で、少々抜衣紋に背筋を膨らまして――別れとなればお互に、峠の岐路に悄乎と立つたのには――汽車から溢れて、風に吹かれて来た、木の葉のやうな旅人も、おのづから哀れを催し、挨拶を申すうちに、つい其誘はれて。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またガニミード神話の反映をガンダラのある彫刻に求めたある学者の考えでは、鷲がガルダに化けた事になっている。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗和尚とジュースの神の鷲との親族関係は前に述べたが、河童や海亀の親類である事は善庵随筆に載っている「写生図」と記事、また※庭雑録にある絵や記載を見ても明らかである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は荒鷲のようにたけりたけって、グラスをつかんだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれだけです』と煩わしそうに言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くから母に死なれ、父は頑固一徹の学者気質で、世俗のことには、とんと、うとく、私がいなくなれば、一家の切りまわしが、まるで駄目になることが、わかっていましたので、私も、それまでにいくらも話があったのでございますが、家を捨ててまで、よそへお嫁に行く気が起らなかったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はかるく狼狽の様子で、「くらべたりするもんじゃないよ」と言って笑ったが、すぐにけわしく眉をひそめ、「いや、ものごとはなんでも比較してはいけないんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原理を敷衍すれば、菓子は「くわし」と書かずして「かし」と書き、關東は「くわんとう」でなくして「かんとう」、蝶は「てふ」でなくして、「ちよー」と書くべき筈である。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって自ら筆を取り、あえて大胆にこの書をあらわし、著者の見たる「新しき蕪村」を紹介しようと思うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
