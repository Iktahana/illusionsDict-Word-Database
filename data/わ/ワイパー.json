          "literary": [
            {
              "text": "×艦隊ハ既ニハワイパール軍港ヲ出デテ、大挙西太平洋ニ向イタリ。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしワイパーは動かない。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイパーは正常に作動するよう直すべきだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイパーがガラスの表面で懸命に雨水を拭っている。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の外にあるその平凡な光景の空間を、大量の雨が横殴りに飛んでいき、ワイパーがガラスの上でそれをぬぐい続けた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイパーを止め、エンジンを停止させた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイパーがそれをぬぐい、ワイパーのブレードが届かないところでは、雨滴はガラスの表面に薄くひきのばされ、たいていの場合、その薄い水の膜は横に流れた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、ワイパーを作動させた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、ワイパーをとめた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイパーのスイッチをオンにした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
