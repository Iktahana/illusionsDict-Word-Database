        "examples": {
          "standard": [
            {
              "text": "今日の吸い物の椀種は、鯛の切り身と旬の京野菜だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "懐石料理では、季節感を大切にした美しい椀種が供される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は料亭で修行を積み、椀種選びの腕を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "白焼きの橙酢、から揚げ、ふらい、椀種、味噌田楽。",
              "citation": {
                "source": "榛名湖の公魚釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味が少ないから白焼きの橙酢、カラ揚げ、椀種、味噌田楽向きにこしらえてもおいしい。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥したくちこ、すなわち、このこは網の上に載せ、火に焙って、そのまま食ったり、椀種にしたりする。",
              "citation": {
                "source": "くちこ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
