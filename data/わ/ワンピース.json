    "definitions": [
      {
        "index": 1,
        "gloss": "dress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ワンピースを着せて変装の女給に……活動のサキソフォン吹きに……タキシードを着せて芝居のボックスに……どれもこれも憎いほどよく似合った。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボックスでは、一人のまるで女の様な綺麗な肌をした色の白い、ぼくと同年輩位の美少年が、セルの着物の袖から白い手をぬッと伸ばして房々とした髪の毛をかきあげながら、その店の、雀斑のあるかなり可愛いい顔をしたワンピースのドレスの少女とひそやかに語らいながら二人切りの時間を楽しんでいる様だった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく眼を定めてみると、それは平凡な白地のワンピースを着流した令嬢であった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末なワンピースを着て、少しお化粧して、こっそり家を出た。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造と並んで、赤いワンピースを着け黒い地の透いた帽子をかぶった十六七の少女が一人腰掛けていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々とコバルト色の無地のワンピースを着て、衿のボタン代りに丸紐をボウ（蝶結び）に結んでいると、上海帰りのルミが、「殺生やわ、ほんまに……」と、遅れて上って来て、ペラペラひとり喋った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十の娘が着るような花模様のワンピースを着ていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色の無地のワンピースが清楚に似合う垢ぬけた容姿は、いかにも占領軍の家族が撮りたくなるくらい、美しかったが、しかし足には切れた草履をはいていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パパ、ほんまか」　寿子はあわててヴァイオリンをピアノの上に置くと、隣の部屋へかけ込んで、汗だらけのシュミーズの上に、よれよれの、しかし花模様のついたワンピースを着た。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗色の夥しい渦巻毛を肩から胸まで波打たせて、黄色い裾の長いワンピース式の印度服を着ている。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思う間もなく背後の扉から飛出したらしい、黄色いワンピースを着たアダリーが私の前に重なり合って突立った。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その扉を開こうとすると、黄色のワンピース……アダリーが、イキナリ私の右腕に飛付いてシッカリと獅噛み付いた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手に握っていた八百五十円の札束をイキナリ、アダリーのワンピースの襟元に押込んだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……アッ……」　という小さな叫び声が私の枕元から聞えたので、ビックリして振り返ってみると、栗色の髪をグルグル巻にした黄色いワンピースの少女、眼の大きい、唇の赤い、鼻の高い、憂鬱な檳榔樹色の少女だ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに、ちゃんと着てしまっているのに――」クリーム色のピケで、型ばかりはひどくハイカラだが、お手製らしいワンピースを、大仰に手を展いて見せた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいな靴、きちんとした桃色ワンピースに、小さなリネンのエプロン。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば、若しも犯人が男で、そしてそんな野心を持っていたのだったならば、その男は、一見男に見えるビーチ・パンツやビーチ・コートを着るよりも、当然、逆に、一見して婦人と思われるワンピースか何かの婦人服を着なければならない筈だからね。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はそのひとり、花柄のプリントのワンピースを着た子の、頭のうしろでたばねた、長い、艶のある、豊かな髪の毛に見ほれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "花柄のワンピースを着て、白い帽子をかぶり、脚をきちんとそろえて、すっと伸ばして坐っているすがたは、いちだんと大人びて見えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、衿やボタンや縁どりだけが白い、無地のブルーのワンピースを着て、文学全集を三冊重ねたぐらいの、ストローのバッグをもっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンピースでなければいけないというなら、それでもかまわないが、なにかべつの色、たとえば、トレイニング・ウェアに合わせて、オレンジ色とかにしないと、つじつまが合わないではないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ彼が口説いてみようかと思っている近所の娘さんが臙脂色のワンピースを着て遊びにやってくる。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一匹は臙脂色のワンピースが旧態にかえった姿だった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ一枚のワンピースがほんとうに若い女性の生活をいたわり働く婦人の身だしなみをいたわって、そのように特別に染められた布地で作られているなら、どんなに若い人たちの心の楽しみがふえるでしょう。",
              "citation": {
                "source": "自覚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨になって直ぐ縮むような縮緬の服をつくるより、麻のワンピース、木綿の着物、雨が降っても大丈夫な長靴が欲しいし、そういう生活の役に立つ服装がすべての人に余り差別なく出来るようでありたいと思う。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "名のとおり日本服を改良して、洋装との間にしようとした改良服は、上を、つつ袖の口をひらひら飾りにし、うち合わせ襟で、スカートの部分とくっつけたワンピースだった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政子の方は、それでも支度が出来たのか、すつきりした、黄ろい麻のワンピースを着込んで立つたなり、フランネルで爪を磨いてゐる。",
              "citation": {
                "source": "愛する人達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏝焼けのした、まつかな髪を振り乱して、垢染みたポプリンのワンピースを何時も着てゐたが、大柄で肥つてゐたので、洋服なぞは皮膚の一部のやうに見えた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "りよは青い波模様の、着物地でつくつたワンピースに、これも綿入りの薄茶の背広の上着を着て、何となくおめかしをして留吉の手を引いてゐた。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "念入りに化粧をして、粗末な布地ではあつたが、白絹のワンピースを着て、朝の食堂に降りて行くと、牧田氏と、あの男が、網戸をあげた、広い窓辺でコオヒイを飲んでゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
