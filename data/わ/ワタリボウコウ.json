    "definitions": [
      {
        "index": 1,
        "gloss": "working as a servant for a series of masters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "元は山城屋と同村の遠縁に当る某家から出て、十五の年から二十年近くも、江戸の大名を二三ヶ所も渡り奉公に歩いて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれ達は渡り奉公の人間だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旗本屋敷の渡り奉公なんぞしている者はどうも悪い奴が多うござんすからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一季半季の渡り奉公というではなし、児飼いから馴染みの深い奉公人である。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り奉公の中小姓などが並大抵のことでその後釜に据われる訳のものではない。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから渡り奉公のやつこの生活を羨んで、旗本奴などゝ言ふ名を甘受してゐたのだ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから供人の縫殿介なる若党の骨がらもよく、いわゆる雑人ずれのした渡り奉公人とはちがって、子飼からの躾がみえる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
