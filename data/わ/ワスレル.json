    "definitions": [
      {
        "index": 1,
        "gloss": "to forget",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これで綺麗な着物と帯とを買えば、きっと佐野次郎のことを忘れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰げば尊しわが師の恩、という歌を忘れるな。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういふわけだか、その技師の罪名と運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういうわけだか、その技師の罪名と運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後交通は急劇に頻繁となり、人は竟に自然をだけ克服する力では、眩ぐるしき対人圏に於て誠実たり得ず、やがては我を忘れるに到つたのである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "客を迎へて客を忘れる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬老の心掛けを忘れるな！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういふわけだか、その技師の罪名と運命を忘れる事が出來ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸の叢の中には、それを着ものの紐につけると物を忘れることができるという萱草も生えていたが、翁はそれも摘まなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、全く見えなくなると、そのこともだんだん忘れるものです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして物質界を赤裸々のままで見る事を忘れる。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い訣とは思うが何分にも忘れることが出来ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が今忘れることが出来ないというのは、その民子と僕との関係である。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "物も言い得ないで、しょんぼりと悄れていた不憫な民さんの俤、どうして忘れることが出来よう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人が訪ねて來ると、時々その笛をポーポーと鳴らしながら、「こいつを吹いとると、人生の寂しさを忘れるわえ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉刀の柄に手を掛けて、Ｔ「舞台へ上る、その前に　親兄弟に遺言　して置く事、忘れるな！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋさんは彼の背後にある實社會の強い現實的な力を忘れることが出來ないやうに見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十幾本の鉤を凧糸につけて、その根を一本にまとめて、これを栗の木の幹に結び、これでよしと、四郎と二人が思わず星影寒き大空の一方を望んだ時の心持ちはいつまでも忘れる事ができません。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはよくそれを忘れる。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉元過ぎれば暑さを忘れるという。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし西洋で二年半暮して帰りに、シヤトルで日本郵船丹波丸に乗って久し振りに吸った敷島が恐ろしく紙臭くて、どうしてもこれが煙草とは思われなかった、その時の不思議な気持だけは忘れることが出来ない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらないようで実に不思議なアドヴェンチュアーとして忘れることが出来ないのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、いゝいゝ、忘れるもんか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、家へ来たある謹厳な客が、膝へあがって来た仔猫の耳を、話をしながら、しきりに抓っていた光景を忘れることができない。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一斉に声を合わせるトタンに、故郷も、妻子も、死も、時間も、慾も、未練も忘れるのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも思い込んだらどうしても忘れることのできない質で、やっぱりおまえと同一ように、自殺でもしたいというふうだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち巡査のことをちっとでも忘れると、それ今夜のように人の婚礼を見せびらかしたり、気の悪くなる談話をしたり、あらゆることをして苛めてやる」「あれ、伯父さん、もう私は、もう、ど、どうぞ堪忍してくださいまし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この簡単な言葉に迷わされて感覚というものの基礎的の意義効用を忘れるのはむしろ極端な人間中心主義でかえって自然を蔑視したものとも言われるのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方でまた自分の思ったような結果が出たときに、それが実は思ったとは別の原因のために生じた偶然の結果でありはしないかという可能性を吟味するというだいじな仕事を忘れる恐れがある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり道具を尊重し過ぎて本然の目的を忘れるのは有りがちな事であるから、これもよく考えてみなければならない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
