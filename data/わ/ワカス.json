    "definitions": [
      {
        "index": 1,
        "gloss": "to boil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は銀の鼎と言ふ……　組込の三｜脚に乗る錫の鑵に、結晶した酒精の詰まつたのが添つて、此は普通汽車中で湯を沸かす器である。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすゝぎ湯を沸かすさへ焚物が惜まれた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子の時は産み落とすまで母は働き、いざ陣痛が来たとなると、産婆を呼びに行く間もなく、泡を喰った父が湯を沸かすのも待たなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と小村さんが暗がりの中を探りながら先へ立って、「いきなり、風呂を沸かす宿屋が半道と来たんでは、一口飲ませる処とも聞きにくうございますよ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか水を汲んで来て、湯を沸かす支度などをしていた。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を燃やし湯を沸かす。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな夜ふけになぜ洗濯をするかというに、風呂の流し水は何かのわけで、洗い物がよく落ちる、それに新たに湯を沸かす手数と、薪の倹約とができるので、田舎のたまかな家ではよくやる事だ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜は飯汁の外に麦をえます、その跡で馬の物を煮る、馬の裾湯を沸かす。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この湯、もと地獄谷温泉と稱したりしが、温泉湧出せぬやうになり、この頃は、鑛物を水に溶かして沸かすやうにしたるが、それでも疝氣に効能あるとかにて、近郷より來り浴するものありと聞く。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "正吉は火を焚きつけて、湯を沸かす支度にかかる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたの朝も、兄さんの帰る前に火を焚きつけて、お湯を沸かすようにして置いて下さい。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉と言つても、沸かす湯は沸かす湯だけれど……』『それは面白いね。",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも手伝って火を焚いて、湯を沸かす、茶を淹れる。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、このごろは、余ひとりで出勤し、余ひとりで掃除もすれば、茶も沸かす。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『誰れも沸かす人がなくつて、独りでにこんなにお湯が出るの？",
              "citation": {
                "source": "子供と旅",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お妙は眼をふいて、湯を沸かす支度をする。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうここらを掃かねえのかね」「きのうは葬式で、茶を沸かすやら、火を起すやら、わし一人でなかなかここらの掃除までは手が廻らなかったからねえ」と、銀蔵は笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "この湯といふは居風呂にて沸かすものながらそれだに早や汲み尽せしと覚えて底を払ひたり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "身辺整理、必要な物以外は身辺に置かないのが私の持前だ、古い手紙やハガキを燃やして湯を沸かす！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "古雑誌を焚いて、湯を沸かすことは（時としては御飯を炊くこともある）、何だかわびしいものですね（さういふ経験を持つてゐる人も少くないだらう）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "古雑誌を燃やして飯を炊き茶を沸かす、わびしいと思はないでもないが、不平ではない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七輪に火も興りかけていたし、鉄瓶にも湯を沸かす仕掛けがしてあった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでお茶を沸かすと、それはおいしいんですよ」　中根夫婦がかわるがわる話しかける話声も何となく岸本の下宿を賑かにした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶は川水を汲んで来て石の竈に薬鑵掛けて沸かすので、食ひ尽した重箱などはやはりその川水できれいに洗ふてしまふ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの天狗の落とし子のような彼のおいたちがすでに仙人らしい飄逸味に富んでいるが、茶に沸かす川の水の清さを桶の中から味わい分けた物語のごとき、いやしくも文芸の道に一片の了解をいだく者の、会心の笑みを漏らさずには読み得ぬ一節ではあるまいか。",
              "citation": {
                "source": "茶の本",
                "author": "はしがき",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへさし昇って来る朝日に照り耀いた雪を冠ったまま、朧に静まる薄紫の枝枝の繊細さ、――矢代は顔を洗ってから一寸雪片を口に含んで菜を截り、火をストーブに焚きつけてそこで湯を沸かすのである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この知人と云うのも、その日暮しの貧乏人なのでございますが、絹の一疋もやったからでございましょう、湯を沸かすやら、粥を煮るやら、いろいろ経営してくれたそうでございます。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびとなく足をすくわれ、のめり、手を突きながらも、温度は手が凍えるまで下らなかったので、金剛杖や糸立を強くつかんで、大宮口の五合目へ、ほうほうの態でたどりつき、たき火でぬれた上衣を、かわかすのに暇取った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡っ引の人達の鑑定では、おそらくお角さんをかどわかす手段であったろうというのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこれ考えながらお座敷を掃いて、それから、お風呂をわかす。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
