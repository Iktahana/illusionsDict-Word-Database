[
  {
    "uuid": "acc968fb-875b-5cb8-be2a-3feb17ddf6a0",
    "entry": "私する",
    "reading": {
      "primary": "わたくしする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-する",
