          "literary": [
            {
              "text": "スワンプ〔低湿地〕がちょいちょいある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃日本橋通りにワンプライス・ショップという洋品店があり、また神田に中庸堂という書籍店があって、どちらも日曜を休みにしていた。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒なことに私の不安な予想が当って、中庸堂は破産し、ワンプライス・ショップは日曜休みを廃止してしまった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            }
