        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「うん、やっぱり子供らは入ってるねえ、しかし構わんさ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「偽札なんど有ったって、俺等は使わんさ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わんさんどうしたの？",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の柄ほども文句を謂わんさ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノートブック型マシンがわんさか売れて、デジタルおやじの腕っぷしは鍛えられる一方である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはバカバカしいかもしれないが、統一と言った約束事がわんさとある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここまで単純化すれば、一九九一年にわんさか登場してきた新しい提案の類は、みんなこの線でまとまってしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはまえと違って、いかさま、江戸のお盆人気をひとりで占めているらしく、わんさわんさの大入り繁盛です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今迄親方とか親爺とかと呼び慣れてゐた面々は、つい、王様といふのはあまり可笑しかつたり、忘れたりしてしまつて、「さつきわつしらがマストにのぼつてながめてゐると、あの美味さうなリンゴ酒の樽が、わんさと積み込まれましたぜ、親方！",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "するてえと、慾の皮のつっぱった連中がわんさわんさとおしかけて、十万円とふしぎな見世物の両方につられてどんどんはいる。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴公館には、その日朝暗いうちから人がわんさと押しかけて皆餞別の贈り物をしました。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野兎が、まるで地面も見えないほど、わんさといやあがるんだぜ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、幸か不幸かすぐ近くに村があったので、早速この騒ぎに百姓どもがわんさと集まって来た。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "物見だかい群集が毎日わんさと押しかけた。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでお祭り騒ぎで、馬車がわんさと押し寄せた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "議事堂には、毬栗頭の大公たちがわんさとゐたが、この連中は物の道理をよく辨まへてゐたから、おれが『皆の者よく承はれ、地球が月に乘つからうとしてゐるのぢや、月を救つてとらせようぞ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅府警察署から、さっそく停車場目がけてわんさと押し掛けて来る。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来君と旅行するのは御免だ」「なあに構わんさ」「君は構わなくってもこっちは大いに構うんだよ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕あ、おやじの死ぬとき一週間ばかり徹夜して看病した事があるが、あとでぼんやりして、大いに弱った事がある」「少しぐらい身体が疲れたって構わんさ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大通りを横断してバリケードのように同じようなレインコートを着、ソフトをひらひらさせ、赤い腕章を巻いた男がわんさと居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮ケンなんかにくっついてたらどもならんで――敵やぜ”カブト町の人のわんさいる中で大きい声を出してそう云ったガンモドキ。",
              "citation": {
                "source": "日記",
                "author": "一九五一年（昭和二十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあはん、私は口が下手で、よういわんさかい、あんたから、おいでやしたら、ようお礼いうてえやちゅうて。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "――うん、あれや、どうだつてかまわんさ、処が、今度こそは大丈夫だ。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにすぐその前にある帝展はどうか、その方はわんさと押しかけている。",
              "citation": {
                "source": "伝不習乎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランジュ　　なに、かまわんさ。",
              "citation": {
                "source": "序文",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か虚を衝かれたように慌てだしながら、ノメるような勢いで、「闘わんさきに勝負がわかるか、犠牲をおそれて戦争ができるか――」　彼は性急にマクしたてた。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で最もおほきく生長する木はくすの木が第一で、次ぎはすぎ、たいわんさわら、いてふ、しひ、まつといふ順になります。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            }
          ]
        }
