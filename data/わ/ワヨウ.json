[
  {
    "uuid": "15c62a5b-c196-5d65-9374-b572789bcc0a",
    "entry": "和洋",
    "reading": {
      "primary": "わよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
