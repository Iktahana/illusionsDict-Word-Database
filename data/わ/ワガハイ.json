        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを当の松岡は（これは譬噺で、事実談ではありません）レニンに呆れられているという事にも気づかず、「なんだ、レニンってのは、噂ほどにも無い男だ、我輩の眼光におされてしどろもどろではないか、意気地が無い！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かういふのが我輩の嗜好だ、かういふ流儀こそ我輩のものだ」なぞと彼は繰返してゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、時たま、我輩こそオリジナルな文人だぞ！",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸ふ巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩の足跡までこんなに深く入るといふのは実際少し恐れ入った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれだからと云って我輩のこの追跡には害にならない。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩はその地点を記録する。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿は我輩のやうに黒猫ではないから、まあ大した心配はあるまい。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸う巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩の足跡までこんなに深く入るというのは実際少し恐れ入った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山猫博士、「座っておいでになっても立っておいでになっても我輩は我輩ぢゃないか。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつが我輩を〔侮〕辱したから我輩はこいつへ決闘を申し込んだのだ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩警察のために棄置かん、直ちに貴公のその額へ、白墨で、輪を付けて、交番へ引張るでな、左様思え、はははは。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩あえて憚らず、こうやって手を握ったまま十字街頭を歩くんじゃ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "無礼なやつだ君は我輩を知らんか。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「坐っておいでになっても立っておいでになっても、我輩は我輩じゃないか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は我輩のために乾杯しようというんだな。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度は我輩うたって見せよう。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつが我輩、名誉ある県会議員を侮辱した。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから我輩はこいつへ決闘を申し込んだのだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして工合のわるいのをごまかすように、「ええと、我輩はこれで失敬する。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「黙れ、きさまは我輩に、七十二人待てつと云ふか。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幽霊の曰くです、我輩はクローヂヤスに殺された、クローヂヤスは、わが妃に恋慕し、――」　ハム。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妃を横取り、王位も共に得んとして、我輩の昼寝の折に、油断を見すまし忍び寄り、わが耳に注ぎ入れたる大毒薬、というわけなんですがね、念がいってるでしょう？",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは「ミスター・ニシは、わがはいの良き教師である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがはいは、最もできの悪い生徒である」というよりほかはない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがはいが、ただ今からダン艇長にかわって、この飛行艇の指揮をとることになった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがはいの、いうことをきかない者は、たちどころに射殺する。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶な命令「そこでわがはいは、本艇の航路をしめす。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいから、わがはいの、いうようにするんだ。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
