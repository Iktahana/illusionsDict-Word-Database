    "definitions": [
      {
        "index": 1,
        "gloss": "to boil up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黒板へ書いている数式が間違ったりすると学生が靴底でしゃりしゃりと床をこするので教場内に不思議な雑音が湧き上がる。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は裏庭を左にした壁のオルガンの前に腰かけて、指の先の鍵盤から湧き上がる快い楽音の波に包まれて、しばらくは何事も思わなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭のかがり火のようで、一面真っ赤に燃えるに至っては、目にしたものの雄大さに逃げる一行の心も癒され、力も湧き上がる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私がもとの停泊所へ戻ろうかということを言いだそうとしたそのとたん、艫の方を見ると、実に驚くべき速さでむくむくと湧き上がる、奇妙な銅色をした雲が、水平線をすっかり蔽っているのに気がついたのです。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "――がその霧のなかから天に向って湧き上がる大叫喚は、お話ししようとしたって、とてもできるものではありません。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅では万事無造作ですから」『どうも無造作すぎるな』とわたしは、思わず湧き上がる嫌悪の情をもって彼女のぶざまな様子をじろじろ眺めながら、心の中で考えた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬか生きるか娑婆か地獄かと云う際どい針線の上に立って身震いをするとき自然と横膈膜の底から湧き上がる至誠の声である。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし衰えた、歓声は盛り返す潮の岩に砕けたようにあたり一面に湧き上がる。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "直衣などを着るために向こうの室の御簾を引き上げて源氏がはいる時に、短い几帳を近くへ寄せて立てた人の袖口の見えたのを、女王であろうと思うと胸が湧き上がるような音をたてた。",
              "citation": {
                "source": "源氏物語",
                "author": "野分",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな侮辱までも忍ばねばならぬかというお気持ちばかりが湧き上がるのであるから何を言うこともおできにならない。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フール・オン・ザ・ヒル」の演奏を終えたあと、アンコールの声を充分待ちきることなくアルテアが次の演奏に移った点には不満が残ったが、耳を澄ませてラジオからの音を追う聴衆の視線の熱に、ドンピアはくすぐられるような喜びが湧き上がるのを抑えられなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして内から湧き上がる彼らのエネルギーは、硬直しがちな大組織を活性化させる鍵となると読んだ大内淳義の理。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアのうがった穴に生まれた湖は、内から湧き上がるソフトウエアへの飢えの圧力をはらみ、水面をかろうじて平らかに保ちながら膨れ上がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそくＭＩＴＳあてに注文を出した安田は、かつてラジオの世界で巻き起こった大衆運動が、マイクロコンピューターを核として再び湧き上がるのではないかと考えるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不潔な山が春から夏への季節には再びなみなみと湧き上がる水の底へ沈んでいきその上を蛙や赤腹が泳ぎ廻るのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が一歩踏み出すごとに、力強いルフランはまた新しく湧き上がるのであった。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの湧き上がる青葉に埋まっていた稲佐山は赤ちゃけた岩山と変わっているではないか？",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃然として新鮮なる興味が荒涼たる原子野に湧き上がる。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "室を埋むる湯煙は、埋めつくしたる後から、絶えず湧き上がる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい君樽麦酒の祝杯を一つ挙げようじゃないか」と青年は琥珀色の底から湧き上がる泡をぐいと飲む。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔らかい若葉の豊かな湧き上がるような感触は、――ただこの感触の一点だけは、――油絵の具をもって現わし難いところを現わし得ているように思われる。",
              "citation": {
                "source": "院展日本画所感",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は食事の仕度をして、お新さんは町役人やら、一緒に子供の見えなくなつた家へ知らせて歸ると、不思議なことに、六疊に寢て居た筈の信太郎は見えない」「フーム」　八五郎の話すのを聽き乍ら、お新は又ドツと湧き上がる新しい涙にひたつて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの命",
                "note": "青空文庫"
              }
            },
            {
              "text": "男勝りと言はれたお角も、二千兩を隱して町人道を立て通した佐太郎も、其頃になつてボツボツ集つて來た近所の人達や、遠い親類を相手に、新に湧き上がる悲しみに、泣いたり口説いたり、取止めのないことに紛れて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平次は身内に義憤の湧き上がる心持でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "猫の首環",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フ、フ、フ」　湧き上がるやうな笑ひ、女の頬には可愛らしい笑くぼが渦を卷きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "片瀬へ着いたのは大嵐の眞つ最中、忘れもしない二百十日の厄日の翌る日、陸から見ると江の島が泡の中へ湧き上がるやうな恐ろしい景色でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地獄から來た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は食事の仕度をして、お新さんは町役人やら、一緒に子供の見えなくなった家へ知らせて帰ると、不思議なことに、六畳に寝ていたはずの信太郎は見えない」「フーム」　八五郎の話すのを聴きながら、お新はまたドッと湧き上がる新しい涙にひたっております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "五つの命",
                "note": "青空文庫"
              }
            },
            {
              "text": "續いて菊次郎――日頃｜賢さうに取澄してゐるのが、膳を二三枚｜蹴飛すと、湧き上がるやうな怪奇な手振りで、ヒヨロリ、ヒヨロリと人の間を泳ぎ廻るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "笑ひ茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬兵衞の顏は姪の痛々しい死骸を前にしながらも、湧き上がる忿怒に燃えるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鍵の穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "片瀬へ着いたのは大嵐の真っ最中、忘れもしない二百十日の厄日の翌る日、陸から見ると江の島が泡の中へ湧き上がるような恐ろしい景色でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            }
          ]
        }
