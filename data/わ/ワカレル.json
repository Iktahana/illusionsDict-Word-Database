[
  {
    "uuid": "4a7070c3-c73e-56eb-bf42-7939d31900a4",
    "entry": "別れる",
    "reading": {
      "primary": "わかれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to part (usu. of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然し別れると云つてみろ、「負けて逃げちやひやがンの」とか、「勝手な奴だよ」とか云ふことになるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤解されたことを忍んで別れるより仕方もなくなると、忍んだ故にもう一段誤解されるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れる時その話のことで「明日かあさつては是非訪ねるから」と三田村自身云つたのだが未だに来ない。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が餘事にそれたが、最後に、別れる時、前言の一切を取り消すやうな反語の調子で、彼は印象強く次の言語を繰返した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸途に別れる時、室生は例のずばずばした調子で、私に向つて次のやうな皮肉を言つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車を降りて、別れる時に、「恋なら恋のやうに神剣にな、君はダラダラしてゐる……」　従兄が彼の肩に両手をかけて人道主義者のそのワザとらしい親切さで言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体から言つて、流行歌曲の種属は二つに別れる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこっちから訪ねる場合は、何時でも随意に別れることが出来るのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか自分と云うものが二人に別れる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけで左右に別れる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私は、この「捨て身」で階級闘争の中に入つてゐる、同志と別れることは、出来ないと考へた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松にはとても顔見合って別れることは出来ないところから、自分の気づかない間に逃げようとしたのだが、其機会を得られずに泊って終った。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸途に再度大船で別れる時には、もはや心から諸君に握手して禮をのべた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一つ彼女にとって未練であったのは自分の生みの父親に別れることだった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そんならどうでも別れるというのですか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし二人は別れることが出來なかつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは湊と別れるとき、湊がどこのアパートにいるか聞きもらしたのが残念だった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツノスケに別れると、ミサコはそのまま楽屋口から冷たい街路に出た。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして別れるとき私はチタ子に接吻したのですが、それについて彼女は、　――あなた、忘れてはいやだわ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラはクロフォードと別れるとともにレーン・クロフォードの売子でもなくなった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ戻らうといふと、それには及ばぬといふので、立話で用件を聞いて六本木の散髮屋の方へと別れる。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若ものたちは、送ってきた親や、同志たちと、営庭で別れる。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夏｜信州星野温泉から小瀬温泉まで散歩したとき途中で道の別れるところに一人若い男が休んでいたので、小瀬へはこちらでいいかと聞くと、それでは反対で白糸の滝へ行ってしまうという。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言えばすりこぎでとろろをすっているのなどを見ても、どうもやはり手首の運用で巧拙が別れるような気がする。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の顔も平生のとおりの母の顔、兄の顔も今年の夏別れる時に見たままの兄の顔。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三十四は驚くな、然し僕は此の頃何んだか青年と云ふ時代と別れる樣な氣がしてならないけれども」　井田は二十七歳である。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえと別れるのは俺たち全くつらいや。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもおまえのようなよい友だちと別れるのは悲しい」とおっしゃいました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし達には」　二人で死ぬか、別れるか。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一緒に死ぬか、別れるか」　多情な男と棲むことは、女の一生の苦しみであり、一人に愛を強要する女の為めにも男は悩み通さねばならないと兄は助言した。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
