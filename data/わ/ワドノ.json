          "literary": [
            {
              "text": "「なう／＼あれなる御僧、我殿御かへしてたべ、何処へつれて行く事ぞ、男返してたべなう、いや御僧とは空目かや」の一節。",
              "citation": {
                "source": "「歌念仏」を読みて",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛殿老女村岡、御蔵小舎人山科出雲、三条殿家来丹羽｜豊前、一条殿家来若松｜杢、久我殿家来春日｜讃岐、三条殿家来森寺｜困幡、一条殿家来入江｜雅楽、大覚寺｜門跡内｜六物空万、三条殿家来富田織部。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鼓判官知康の院宣を持して来れるに問ひて「わどのを鼓判官と云ふは、万の人に打たれたうたか、張られたうたか」と云ひたりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "源教、そはよき功徳ならん、古志郡のお菊がいうれいを見とゞけたりと人々にかたり玉へ、愚僧もわどのを証人として幽霊をかたりて教化のたよりにせん。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
