          "literary": [
            {
              "text": "六　私が「いでゆ」のドアをあけたとたんに、わっと笑い崩れる少女たちの声が聞えた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一同が高く笑い崩れるにしたがって、片方の牡蠣のように盲いた眼までを輝かして顔だけでめちゃめちゃに笑った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう信敬（神経）を起すな」「アハハハ、アハハハ」と、一同は笑い崩れる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた来ていたのですか」「ええ、お帰りになってから、考えたら何だか様子が変だったから、すぐ車で来て見たの、そうして昨夕の事を、みんな婆やから聞いてよ」と婆さんを見て笑い崩れる。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はキョトンとして女の笑い崩れる歯ぐきに見とれた。",
              "citation": {
                "source": "苦力頭の表情",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒鳴る本人すら訳の解らない啖呵を吐き出しながら、顔中を赤貝みたいにむき出して、笑い崩れるロシヤ人のテーブルを泳ぎ廻った。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子ハアドルの内田さんが、先に進みでて、「おおきに」と澄ましたお辞儀をしたので、あなた達は笑い崩れる。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手を拍つ）みな笑い崩れる。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同笑い崩れる中に、言いだした侍が起って、残りの十人ほどの帯刀を一しょに集めて、ひとかかえ奎堂の前へ置く。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "両人は申し合せたごとく「ハハハハハ」と笑い崩れる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うではまたひと際高く、笑い崩れる四人の苦しげな声が聞えた。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一勝一敗のつくたびに、どっちかが、杯をのみ乾し、その口惜しがりようを見て、みんなが笑い崩れるのだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
