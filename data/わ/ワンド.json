    "uuid": "2738ebff-783a-5143-9b05-c3215b506fac",
    "entry": "ワンド",
    "reading": {
      "primary": "ワンド",
      "alternatives": [
        "ウォンド"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "魔法使いはきらめくワンドを振って呪文を唱えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ハリーポッターの映画で、ワンドが持ち主を選ぶシーンが印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ケーキのデコレーションに、ワンド型のピックを使ったらかわいいだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "連隊を免ぜられ、次に任ぜられたのはバークシア連隊付で、かくしてマイワンドの激戦へ参加したのである。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイワンドで戦友が斬り殺されるのだって平然と見たのにな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの吐き気を催すような魔法使いは絵の具の中に地獄の業火を興し、絵筆は悪夢の菌糸を振りまくワンドだった。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
