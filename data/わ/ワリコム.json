[
  {
    "uuid": "d4b4f757-2140-5300-87dd-05bf679d6be8",
    "entry": "割り込む",
    "reading": {
      "primary": "わりこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
