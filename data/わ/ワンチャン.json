        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園で可愛いワンちゃんが駆け寄ってきて、しっぽを振ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は毎日、愛するワンちゃんを散歩に連れて行く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねぇ、ママ、あのワンちゃん、なんていう名前？」子供が指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
