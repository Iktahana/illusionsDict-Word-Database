    "definitions": [
      {
        "index": 1,
        "gloss": "(sound of) laughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
