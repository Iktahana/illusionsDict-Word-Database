        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐに取って返せば、忘れ物でもしたように思うであろう。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行夫は大事な忘れ物でもしたやうに、忙しく寢床から半身を起して、大きく開いた眼で闇の中を見※すだらう。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうだ、忘れ物もあるし後で寄るよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か忘れ物でもして来たかな。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か忘れ物でもしたんだらう位に思つたので、とめもしなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學校にゐた頃から脱字をしたり計數を間違つたり、忘れ物をする癖があつた人なのだらうか？",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ、忘れ物をして……。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで文次郎は迷惑な忘れ物をかかえて、暫くここに待合せていることにして、お峰親子の駕籠はまっすぐに江戸へ帰った。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "古の真人は、能く是非を超え善悪を超え、我を忘れ物を忘れ、不死不生の域に達しておったのじゃ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベディックトンは入口を、何か忘れ物をしたと云う口実にて通りたるに相違なく、しかして見張人を殺害し、手早く最大の金庫を開らきて、中の目ぼしきものを持ち去りたるに相違なきなり。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベディントンはなかに忘れ物をしたとの口実で進入し、警備員を殺害後速やかに大金庫を荒らし、そののち強奪品とともに逃亡したに相違ない。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにか、忘れ物でも……」「さあ、どうも大きな忘れ物をして来たらしい」と、半七はほほえんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京上りの汽車つきければ、たち立でて、汽車に乘りけるに、かの少女きたりて、忘れ物とて、さし出すを見れば、八鹽のいでゆにて我におくりたる團扇なり。",
              "citation": {
                "source": "八鹽のいでゆ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、恰も何か忘れ物を思ひ出した態を露骨に表す、といふ自分ながら妙な（と思つた）虚栄心で、「……」何やら首を動かして点頭くと、クルリと踵を回らせた。",
              "citation": {
                "source": "失題",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよつと忘れ物、ノートで。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忘れ物をしました。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁石の音をきいて、とんだ忘れ物をいま思い出したよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "封印に使った印形が無事息災かどうか、肝心なそいつをちっとも聞かなかったじゃねえか」「ちげえねえ、ちげえねえ」　名人にも似合わない大きな忘れ物でしたから、ほとんど一足飛びでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからどうも何かだいじな忘れ物をしているように思ったから、いっしょうけんめいああやって廊下を歩きながら考えていたんだが、よく考えてみりゃ、おら、おなかがへっているよ」　人を食ったことに空腹だといったものでしたから、出鼻をくじかれて、伝六が当然のごとくに鳴りだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "うず高く積みあげて引き退ろうとしたのを、「まだ忘れ物がある」　呼び止めたのは退屈男でした。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が何か忘れ物でもして途中から引き返してくるおそれは十分にあるし、途中で買物でもして、二十分やそこら費やしていることは女には普通にあることであるから。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口の方へ向かって帰ってゆく群衆とは逆の方向へ、何か忘れ物でも取りにゆくような、はっきりした目的意識をもって私は歩いて行った。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か忘れ物でもあるんですか。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、じつと両手を拱んで思案に暮れてゐたが、ふと忘れ物をしてゐるのに気が注いてにやりとした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れ物とは他でもない女房の事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の口添は粕漬や山の芋と違つて、画家の忘れ物を直ぐ思ひ出させる効果がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夥しい忘れ物のなかから、自分のを捜し出して、大喜びで中を検めて見た。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、ちょっと、と言って、私は飛鳥の如く奥の部屋に引返し、ぎょろりと凄くあたりを見廻し、矢庭にお膳の寒雀二羽を掴んでふところにねじ込み、それからゆっくり玄関へ出て行って、「わすれもの。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出られてはたまらない――彼の方が一目散に飛出すと、おばあさんが後から、「もしもし貴下、おわすれものですよ、なんておそそうな――」　そう言って着せてやったのは、毛皮のついた外套だった。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはわすれものをした人につける名で監督日記の或る処にちやんとそう云ふ欄がもうけてあつて、針一本の忘れ物でも厳重に其処につけられて罰せられるのでした。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
