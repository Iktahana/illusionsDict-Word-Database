    "definitions": [
      {
        "index": 1,
        "gloss": "memento (from a dead person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは彼女の忘れ形見の年頃の寫眞である。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は奥様のもう一人のほうの乳母の忘れ形見でございましたので、三位様がかわいがってくださいまして、お嬢様といっしょに育ててくださいましたものでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方には忘れ形見がなかったのですか」　なお明確に少女のだれであるかを知ろうとして源氏は言うのである。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの六条の御息所の生んだ前皇太子の忘れ形見の女王が斎宮に選定された。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりますればもう、千萩の素姓も申しましょうが、この女は、わたくしの父三庵が、書生のうちからかわいがられて、今のような医業を授けていただいたたいせつな先生の、お師匠さまの忘れ形見なのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは唯、平親王将門の忘れ形見という系図を持った若い美しい一人の尼僧が、陸奥の秋風に法衣の袖を吹かせながら、この坂の中程に立っていたと云うことを想像したい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉の東慶寺には、豊臣秀頼の忘れ形見という天秀尼の墓がある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は旦那の忘れ形見ともいうべきお新と共に、どうかしてもっと生甲斐のあることを探したいと心に思っていた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治はじめの自由民権が叫ばれて、婦人がどしどし男子と等しい教育をうけ、政治演説もし、男女平等をあたり前のことと考えた頃、日本では、木村曙「婦女の鑑」、若松賤子「忘れ形見」などの作品が現れた。",
              "citation": {
                "source": "明日咲く花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はだからその母親が死ぬと間もなく、お通夜の晩に、忘れ形見の太郎を引き寄せて、涙ながらに固い約束をしたものであった。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小奴は、先代三遊亭円遊の忘れ形見で、それ故の「芸」の血なのである。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊之助は四人の子をのこしたが、それらの忘れ形見がいずれも父親似である中にも、ことに二代目が色白で面長な俤をよく伝えていて、起居動作にまであの寛厚な長者の風のあった人をしのばせる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡き夫の忘れ形見に当たる少年を相手に、寂しい日を送るという一人の未亡人がそこに住む。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしい東京の忘れ形見として、いつまでも私は大切にとっておきたいと思っている。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『団栗』の主題は、若い奥さんがこの日、団栗を沢山拾う話と、五年後にその忘れ形見の「みつ坊」が、同じくこの植物園で団栗を拾う話とからなっている。",
              "citation": {
                "source": "『団栗』のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鏡花氏に逢って、僕が先ず聞いたのは、今井君夫妻の忘れ形見の身の上なのであった。",
              "citation": {
                "source": "友人一家の死",
                "author": "松崎天民",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　今井君の骨を抱いて、その忘れ形見達と共に、僕が美作山中の故郷へ帰ったのは、桜花に早い大正六年四月上旬の事であった。",
              "citation": {
                "source": "友人一家の死",
                "author": "松崎天民",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの忘れ形見を今まで会いもせずにいたとはなあ」　と、四の宮を愛撫しながら、涙を押えることが出来なかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の世の忘れ形見になろうぞ、もう幾月程じゃ、気分はどうじゃ、何せ、不自由な水の上の暮しでは、身二つになっても心配じゃのう」　などと仰せられていました。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の忘れ形見――多寡が娘一人を目的に、命がけの爭を續けて居る横井源太郎には、斯うなつては、最早悔も躊躇もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "百草園の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えて翌る八月の五日、亡くなつた三杯龍之助の甥、同苗宇三郎の屋敷から、龍之助の忘れ形見、お玉といふのが三杯家に乘込んで來るところを、道に擁して錢形の平次とその子分の八五郎が喰ひ止めました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二つの刺青",
                "note": "青空文庫"
              }
            },
            {
              "text": "「林右衞門の忘れ形見の娘が二人。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "妹の扱帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく言へば、板屋八十郎の姉の忘れ形見で、その姉が三年前に亡くなり、嫁入先も沒落して、娘の多世里だけが、板屋家に引取られて育てられて居るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "邪戀の償ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに紫琴女といふ宗祖樣は、上樣の御連枝だとか申すことで――いえ、思ひ切つて申上げませう、先年高崎に御預け中、御切腹遊ばされた、駿河大納言忠長樣の忘れ形見だと申しますが――」　八五郎も、それを傳へ聞いた平次も『そんな馬鹿なことが』と驚きましたが、「いろ／＼伺つて見ると、嘘とばかりは申されません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十八年前三七郎殿に、生れたばかりの女の赤ん坊を預けたのは、日本橋のさる大店の妾と申し上げた筈だが、まことは、大變な違ひで、それは先年鈴ヶ森で處刑になつた、大泥棒風雲源左衞門の忘れ形見であつたのぢや」「あツ」　誰やらが思はず驚きの聲を揚げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "苫三七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日藤兵衞に取つては、朋輩でもあり、競爭者でもあつた一色清五郎の忘れ形見、一時は酒と女に身を持ち崩しましたが、近頃はすつかり志を改めて、藝道熱心に精進し、今度は愈々師匠藤左衞門の許を離れて、覺束ない乍らも一家を興さうとしてゐる男でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に可愛らしいが、まだほんのねんねで、よく働きますが、――何んでも百壽園の先代の忘れ形見だと言ひますが、引取手がないので、今の百壽園に引取られて、奉公人並に働いてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の祕薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、新六郎樣は先代の忘れ形見、お銀さんは先代の御内儀の姪、二人は兄妹のやうに育つたんですもの」「――」「それが知れると、お銀さんは近所に住んでゐたタチの惡い浪人者と戀仲になつたと、ありもしない惡名をつけて追ひ出されました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日藤左衛門にとっては、朋輩でもあり、競争者でもあった一色清五郎の忘れ形見、一時は酒と女に身を持ち崩しましたが、近頃はすっかり志を改めて、芸道熱心に精進し、今度はいよいよ師匠藤左衛門の許を離れて、覚束ないながらも一家を興そうとしている男でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘奈々子は二十二、これは先妻の忘れ形見で、継母の由喜子とは姉妹としか見えません。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
