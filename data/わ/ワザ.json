[
  {
    "uuid": "b50f5923-7c25-580c-aba4-d5f21ac0a9b4",
    "entry": "技",
    "reading": {
      "primary": "わざ",
      "alternatives": [
        "ぎ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
