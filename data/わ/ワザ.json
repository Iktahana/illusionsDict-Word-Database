      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "technique",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "内容価値と技巧価値は対立してはゐませんよ。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題となるのは技巧だけです。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容は技巧以前のものです。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "技巧を考慮する男は吃度価値ある内容を持つてゐます。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはつまり様々の技法論が盛んで、分析的な気持が強かつたからであると思ふ。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくんば、詩はただ技だけのことになつて、それでは、人々の心にとゞくものとならない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には実以てどんな技術もなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォルムのない競技で以て、徒らに勝たうとばかりしてゐるやうなもので、仮令勝てたにしても、競技そのものを楽しむ気持はなく、勝つた時に熱病的に嬉しいだけで、十年の後に回想したらば、なんといふこともなかつたと、呆然としなければならない始末だらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へば平凡なこととなるけれど、あれやこれやの作品が、その読む人の人格といふ点で関連し合ひ、ひいては文学一般の了得が、その人なりに満足され、つまり、競技に勝つだけでなく、そのフォルムも自分にとつて決定的である筈のものが最後的に探索されねばならないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり我が国では、技術家も猶多分に政治家である場合に助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術堪能そのものが登用される場合は極めて稀であります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論外国にしろ、多少とも此の世の中は左様なものではありますが、高い程度の技術ではともかく、凡そ常識の既に認める範囲にある技術では、我が国程に台所情実は場を占めてないやうであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば芥川君は、私の古い詩について意見を述べ、表現技巧の缺點を指摘された。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小説の價値批判が、描寫（表現）の巧拙にかかるやうに、詩についても同じ描寫の效果性（即ち表現技巧）について求めた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自選詩集に採録されてる有明の詩は、彼の中での最も惡い作品であり、多くは修辭的の技巧に凝つて、リリツクの純眞性を喪失してゐるやうなものばかりである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "国技館の角力を見物して、まじめくさり、「何事も、芸の極致は同じであります。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな案配であるから、彼の天才を信じるも信じないも、彼の技倆を計るよすがさえない有様で、私が彼にひきつけられたわけは、他にあるのにちがいない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もまたヴァイオリンよりヴァイオリンケエスを気にする組ゆえ、馬場の精神や技倆より、彼の風姿や冗談に魅せられたのだというような気もする。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一芸に於いて秀抜の技倆を有すること。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、また大隅君にとっては、この五年振りで逢った東京の友人が、相変らず迂愚な、のほほん顔をしているのを見て、いたたままらぬ技癢でも感ずるのであろうか、さかんに私たちの生活態度をののしるのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写の技師が罪に問はれました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういふわけだか、その技師の罪名と運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が「純真」と銘打つてゐるものの姿を見ると、たいてい演技だ。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演技でなければ、阿呆である。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写技師が罪に問われました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にも、どういうわけだか、その技師の罪名と運命を忘れる事が出来ませんでした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言換れば叫びは無論生活で、その生活に近似せしめる習練――技の習得が芸術となるのだつた。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般生活はいざ知らず、由来芸術とは、芸術家自身の統一夥多がなさしめるわざではないか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即興詩の、聴手は喜ぶものであれど、歌ふ身になつてみれば心許ないわざであらう。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
