    "definitions": [
      {
        "index": 1,
        "gloss": "noisily",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小作人どもは、ワイワイ云ってるだけで、何とも手の下しようがなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の人が四五人ワイワイ言って居るが、聞いても分らない。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも長屋のお内儀二三人、ワイワイ話している。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガヤガヤ、ワイワイ口々に、Ｔ「横暴だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処彼処の弥次馬連ワイワイ、ワイワイ騒々しい事！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆ワイワイ言っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と前方に当って群集がワイワイ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くワイワイ騒いでる群集（五、六カット程で）カメラ近寄ってその人垣の中から悲鳴が聞える。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ると、今までワイワイと勢よく攻めのぼって来た兵隊は、皆一時にドンドン逃げ出してしまって、あとにはただ二人のお兄さん、アア王とサア王とだけが残りました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると成る程、今までに見たことのない奇妙な夫婦が、馬車の上に乗ってソロリソロリとやって来ますので、皆不思議がってワイワイ云い初めました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見世物みたような珍らしい夫婦が来た」　というので、ワイワイワイワイ押しかけて来て、夫婦は歩くことも出来ません。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だろう」「どうしたのだろう」「行って見ろ行って見ろ」「ワイワイワイワイ」　と集まって、往来一パイになってかけ出しました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするうちに見物人はみんなワイワイ騒ぎ出しました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房はそれを聞くと一ペンに血が上がって、医師が間に合わぬうちに歯を喰い締めて息を引き取った……というので文作の家の中には、村の女房達がワイワイと詰めかけている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなこと土間も桟敷も正面も、ワイワイがやがやと云う……縁日同然。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、それは老人だけの話で、若い者は、何年にも見たことのない人間の赤ん坊というものが珍しさに、ワイワイ騒ぎながら見物に来たと聞いている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近まわりの工場の連中がワイワイ取巻いて見ているうちに、お釜帽を冠った機械油だらけの職工が、板片の上に小石を二つ三つ並べて、腰元らしく尻を振り振り登場すると皆、一時にドッと笑い出したりした。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声に驚いて、外に逃出していた百姓連中がワイワイと駈集まって来るのを、銀之丞は和尚の屍体に片足かけたまま見下した。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、個人としての私が、恩に着ることはないし、まして私の妹である貴女が、眼に角を立てて、ワイワイ云うことではないわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い時から、お伽話と実際の差別がつかなかったり、人前に立ってワイワイもてはやされると、いよいよ有頂天になる性質は、たちまちその本領を発揮して、人に対する奉仕というようなものでなく、彼女自身がその空気の中に溶け込んで、浮れ出してしまうのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大勢の雇人が出て来て、妾の事をキチガイだキチガイだって、ワイワイ騒ぎ出したの。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が、それに伴れてワイワイとはしやぎたてたりした。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に映さしたり、少し許り神泉氏が水墨的な滲みを利かしたりするとワイワイ言ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            }
          ]
        }
