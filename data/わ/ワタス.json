[
  {
    "uuid": "75bd4858-278e-59c2-9dbf-e6ebeadeacd1",
    "entry": "渡す",
    "reading": {
      "primary": "わたす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
