[
  {
    "uuid": "1f0b5b65-50de-5d70-a0d2-cb638440dd5a",
    "entry": "別れ",
    "reading": {
      "primary": "わかれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
