          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "バレーボールの試合で、相手のスパイクがワンタッチでアウトになり、得点につながった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "審判は、ボールがブロックにワンタッチしたと判断し、インプレーを続行させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "惜しい、ボールはワンタッチもなく直接アウトになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
