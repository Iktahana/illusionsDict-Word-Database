        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このコーヒーメーカーは、ボタンをワンタッチするだけで美味しいコーヒーが淹れられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンアプリのワンタッチ操作で、すぐにタクシーを呼ぶことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいパソコンは、ワンタッチでスリープモードから復帰するので便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "touch (of the ball before it lands out of bounds; in volleyball)",
