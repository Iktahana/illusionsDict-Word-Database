        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつか新聞で、かれの自戦記を読んだが、あの文章は、忘れがたい。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が見たらなんでもないこの貧しい記録も自分にとってはあらゆる忘れがたい貴重な経験の総目次になるように思われる。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく、イタリアの美しい自然を背景として美少年アントーニオと歌姫アヌンチアータとの悲恋を描いた『即興詩人』のごときは忘れがたい作品の一つであるといえよう。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "たあいない風景ではあったが、けれども、私には忘れがたい。",
              "citation": {
                "source": "I can speak",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森に於ける四年間は、その故に、私にとつて忘れがたい期間であつたとも言へるであらう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女の仁丹のにおいのする口臭を、永久に忘れがたいだろうと思った。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「発心」の数首「機縁」の数首は然し忘れがたいものである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミメオグラフとして販売されていた印刷機を開発したトーマス・エジソンに会えたことは、新治郎にとって生涯、忘れがたい思い出となりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨めしかった点でも、恋しかった点でも源氏には忘れがたい人であったから、なおおりおりは空蝉の心を動かそうとする手紙を書いた。",
              "citation": {
                "source": "源氏物語",
                "author": "関屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煙の中に立つて眞向ひに聳えた槍嶽穗高嶽を初め、飛騨信州路の山脈、または甲州から遠く越中加賀あたりへかけての諸々の大きな山岳を眺め渡した氣持もまた忘れがたいものである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "火山をめぐる温泉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山には格別秀れたところもないが、少年時代の遊び場所として、私にとっては忘れがたい土地なのだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ最初の記憶はウオタアヒアシンスの花の仄かに咲いた瀦水の傍をぶらつきながら、從姉とその背に負はれてゐた私と、つい見惚れて一緒に陷つた――その生命の瀬戸際に飄然と現はれて救ひ上げて呉れた眞黒な坊さんが不思議にも幼兒にある忘れがたい印象を殘した。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になると、毎年それをくり返していたので、私に取っては忘れがたい少年時代の思い出の一つとなっているが、この頃では秋になっても東京の空を渡る雁の影も稀になった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小滝のある間は――その美しい姿と艶なる声とのする間は、友人が離散し去っても、幼いころの追憶が薄くなっても、熊谷の町はまだかれのためになつかしい町、恋しい町、忘れがたい町であったが、今はそれさえ他郷の人となってしまった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民運動に最初に関係した年の秋、向う岸の村を訪はうと、舟でわたつた、河口に近いところの北上川の大きなうねりと、そのあたりの風光も亦忘れがたい。",
              "citation": {
                "source": "忘れえぬ風景",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵も描き、文章に達し、音楽も愛し、しかも音楽（セロ）の演奏ぶりなどにはなかなか近親者に忘れがたい好感を与えるユーモアがあふれていたようである。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂丘の上からは海も望まれるかと、鷄二が一人で砂の道を踏んで行つた後姿も忘れがたい。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田君は草市の翌朝に通つて見て、まだ草の香りがそこに殘つてゐた時のことを忘れがたいといつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞臺の上に動く能役者の足どりとその白い足袋の感じが、水中に動く魚に譬へてあつたやうだが、あの美しい形容も忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て七年の月日を小諸の山の上に送つたことのあるわたしが、東京への往き還りに、あの上州の山々を汽車の窓から望んだことも忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少年は十歳ばかりの年頃に一生忘れがたいやうな力餅を味はつたのであらう。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がそんな小さなものを見つけた深い印象は忘れがたいほどのものであつたと見え、どうかして養ひたいとの念から、困難な旅の中にもその事に心を碎き、國にまで伴なひ歸つたといふことである。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉も忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻想を伴ふもの必ずしも文藝の革新にのみ限らないやうな氣がして、あの言葉も忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公論誌上でわたしの發表しはじめた序の章はいくらかでも同君の無聊を慰めたかして、例の鉛筆で次の一詩を葉書にかいて寄せられたことも忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはその碑文の譯を見たこともあるが、今だにあれは忘れがたい言葉としてわたしの胸に殘つてゐる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年に一度の黒パンは何でもないことのやうだが、民族の長い歴史にかけてそれを記念するところに教授が心の奧もしのばれて、あの話は忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに一つの道に精しい人達はおもしろいところへ眼をつけるものだと思つて、あの笹の葉の話は妙に忘れがたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしにとって終生わすれがたいあの最初の晩のように、そこには全員が、一人も欠けずにそろっていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーストン喜劇の前に、ハム、チビという妙な髯をはやした大男と小男のコンビの喜劇新馬鹿大将という英国の喜劇俳優もわすれがたい想い出である。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
