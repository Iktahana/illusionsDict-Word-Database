[
  {
    "uuid": "228a7589-6fe6-5740-91d8-01538ac21ace",
    "entry": "分かりにくい",
    "reading": {
      "primary": "わかりにくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
