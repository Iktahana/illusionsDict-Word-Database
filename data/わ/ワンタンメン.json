        "examples": {
          "standard": [
            {
              "text": "飲んだ後には、あっさりとした醤油味のワンタン麺が無性に食べたくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このお店のワンタン麺は、ツルツルの皮とジューシーな餡が絶妙だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は迷わず、得意のワンタン麺を大盛りで注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "銀座裏の飲食店街にある中華料理芳々亭の隅のテーブルにただ一人、今しもワンタンメンを食べ終ったのは西江葉子であった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて、来々軒のチャーシュウ・ワンタンメンというのを食って、ああ、何たる美味だ！",
              "citation": {
                "source": "浅草を食べる",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "来々軒のワンタンメンと、大阪屋のシチュウとトースト、紅茶とカステラ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
