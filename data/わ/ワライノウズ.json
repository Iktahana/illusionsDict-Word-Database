        "examples": {
          "standard": [
            {
              "text": "彼のジョークで会場は一気に笑いの渦に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テレビ番組のコメディアンが、見事な話術で笑いの渦を巻き起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちの発表会は、親たちの温かい拍手と笑いの渦に包まれて幕を閉じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これに対して伯円師の八重垣姫、画像に向った後ろ姿は水の垂れそうな美しさ、但し首筋の太さは牛のよう、チョボにつれて向き直った顔は塗りも塗ったり造作も判らぬくらい、その上名代の鼻ッピー、それで台詞は持前の塩辛声、申し分なき珍妙さに満場どよめいて笑いの渦巻。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
