        "examples": {
          "standard": [
            {
              "text": "おとぎ話に出てくるような、ここはまさに雪のワンダーランドだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、おもちゃのワンダーランドで目を輝かせながら遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の想像力は豊かで、いつも頭の中には自分だけのワンダーランドが広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ワンダーランドのアリスの冒険の一場面を想い出した。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「不思議の国に落ちこんだ気分」「八年ぶりの日本も、そうとうにワンダーランドよ」「そうだろうね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌『ワンダーランド』とそのあとの『宝島』をめぐる作業、そして僕自身の雑誌ライターとしてあるいは翻訳者としての仕事が山のようにあった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の僕は、『ワンダーランド』そしてその続きの『宝島』で、『ロンサム・カウボーイ』というタイトルのもとに、文章を連載していた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
