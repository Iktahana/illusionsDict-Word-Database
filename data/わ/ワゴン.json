    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wagon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "慶一も、ワラも、山崎も、こうした大荷物を、非常口につけたステイションワゴンから、部室に運ぶのを手伝わされた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里に本社のあるワゴンリイのくるまだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の前は広々としていて、白い自働電話があり、自働電話の前には、前大詩人の奥さんであったひとがワゴンと云う小さなカフェーを開いている。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の仕事が片づくと、さて、一週間を送るべき、モスコー行きの硬床ワゴンに落ち着きました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論隣室のピエルミ君の上のワゴンに寝るんでせうが、来るとすぐ私の部屋にはいつて来て、ヤポンスキーと呼びかけて来るのです。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちのワゴンのボーイの一人は羆。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "インツーリスト奴、ワゴンリーにのせやがった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その沙塵をあげて、カヴァード・ワゴンの列が、幾万という黄金探索者を西へ西へと運ぶ。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "買って来たピッツアとロウソクの明かり　僕のビートルの前を走っていたマーキュリーのステーション・ワゴンは、ハレイワの町のなかで右折した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーキュリーのワゴンが前方の視界から消えて、僕は気づいた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろから僕が見ていたあのワゴンの光景は、ハワイにおけるクリスマスの光景なのだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かならずしも使い勝手が良いとは言えないステーション・ワゴンの荷物室をいっぱいにふさいで、棚が何段も作ってあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い色の泥水のような絵具で、一〇〇マイル・カー、とウインド・シールドに大書したセダンやステーション・ワゴンが十台ほど、中古車売り場の奥の片隅にならんでいた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに充分にストーリーを蓄積させているセダンやステーション・ワゴンは、一〇〇マイル・カーとしてさらにストーリーを獲得していくのだろうか。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海岸の名物のひとつである、クレイジー・ジョーのランチ・ワゴンの車体に書いてあるメニューを、僕は完全に記憶していた時期があった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことの延長として、クレイジー・ジョーズ・ランチ・ワゴンのメニュー車体も、僕は記憶していた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョーのワゴンで買うことが出来たのは次のとおりだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人から借りた、ポンティアック・カタリーナのステーション・ワゴンだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このステーション・ワゴンは、彼の奥さんがスーパー・マーケットへ買い物にいくときに使うものだそうだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンティアックのステーション・ワゴンまで歩いてきて、その平凡な車体をぼくは佳子に示した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「エドワードの奥さんは、このステーション・ワゴンを、金曜日ごとの買い物に使っているんだそうだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーケットに隣接して、エイヴィスやバジェットのオフィスがあるのを確認して、ぼくはステーション・ワゴンをマーケットの駐車場に入れた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャロリンから借りて乗っていたポンティアック・カタリーナのステーション・ワゴンを、スーパー・マーケットの駐車場に停めたまま忘れて来た。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこの瞬間まで、そのステーション・ワゴンのことは、ぼくの頭のなかから完全に消えていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "佳子を空港で迎えて町へいき、レンタカーの事務所でトラックを借り、そのままステーション・ワゴンのことは完全に忘れてしまったことを、ぼくはキャロリンに説明した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのクライスラーのさらにうしろから来るのは、佐々木誠の、四輪駆動のワゴンだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このワゴンには、佐々木だけが乗っていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転席の両方の窓ガラスをいっぱいに降ろして、中尾晴彦はひとりでステーション・ワゴンを運転していた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はステーション・ワゴンの速度を落とした。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまえを徐行してとおりかかる晴彦のステーション・ワゴンを、ブースのなかから制服を着た中年の女性が見た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
