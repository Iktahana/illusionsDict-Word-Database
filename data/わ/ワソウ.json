    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若い丸髷の下町式マダムが弁慶縞の上っぱりで、和装令嬢式近代娘を相手に、あでやかにつややかに活躍している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "和装の若い婦人たちが小さい叫び声をあげて所々に跼み竦むのは。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一概に風を咎め立ても出来ないし、また近年では和装にも丸綴ぢの腰布を下に着け、なほ重々の用意もあつて本当には何でもないのだが、しかし女の身として斯る場合には必ずシヨツクを受ける。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ福沢翁の著わした「世界国づくし」という和装木版刷りの書物があった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は和装で吾妻下駄をからから桟橋に打ち鳴らしながら、まるで二三日の旅に親類へでも行くような安易さだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁間には、鳥羽僧正の漫画を仕立てた長い和装の額が五枚｜程かけ連ねてあります。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお見廻わすと、和装洋装の娘連れだけで入って来て「あとで屹度アイスクリームを喰べましょうよ」と約束してから、本食のコースに取りかゝる一卓があります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乗組員が皆死んでしまったのは、どういうわけですかね」　ケノフスキーが何かいいだそうとするのをドレゴは抑えて、「せっかく丈夫な船が出来たにしろ、乗組員がその場で全部死んでしまうんでは、買い手がつかないですからなあ」「いや、あれは当時乗組員用の衝撃緩和装置が間に合わなかったせいだよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから艦体の外部に張りめぐらされた網状の電界中和装置は、怪人集団の城塞から発射した嵐のような原子弾をよく捕捉し、中和して無害とならしめた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "趣味　まず衣服であるが、全部和装ばかりで数もごくわずかしかない。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋風なる者は束髪長裾、俗にこれを嬢と呼び、和装なる者は雲髻寛袖、俗にこれを姫といふ。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近移ったばかりの信濃町の雪枝の家の少し手前で、タキシイを乗り棄て、白いレイスの衿飾りのある黒いサテンの洋服を着た葉子は、和装の時ほど顔も姿も栄えないので、何か寒々した感じだったが、気分も沈みがちであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はダンサアらしい三人ばかりの娘達と、四十がらみの洋装と、それより少し若い和装の淑女と長椅子にかけてゐる反対の側の椅子にかけて、二組出てゐる踊りを見てゐたが、ステップはみな正しいもので、踊り方も本格であつた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がきるのでは、現在の自己の環境のために和装一方です。",
              "citation": {
                "source": "「洋装か和装か」への回答",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その令嬢は和装で女優かと見える派手好みであった。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋装、和装、頬紅、口紅、引眉毛取り取りにニタニタ、ヘラヘラと笑い傾けながら、荘厳を極めたロココ式の応接間に押し並んだところは、どう見ても妖怪だ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると、思い切って早起して、いつもの通りに凝った和装の身支度を済ました女優呉羽嬢は、直ぐに轟家の顧問弁護士、桜間法学士を呼付けた。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」検事には鎮子の黒ずくめの和装が、ぐいと迫ったように感ぜられた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、開閉器の直下に当る床の上に、和装の津多子以外にはない、羽織紐の環が一つ落ちていたからだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にとって、洋装は和装より簡単であろう。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌につけるものから順次に比較しても明かだし、和装の半襟や帯とその付属品一切の繁雑さを考えても明かである。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の方は洋髪に結った年の頃二十三、四歳の丸顔の和装をした美人だった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて三十がらみの和装の女が道化師のやうな剽軽な身振りをしながら木村重吉の席の方へやつてきた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒井は軽快な洋装に、韮山風の陣笠をかぶって、洋鞍に乗り、田山は和装、例の大刀を横たえた姿が、例によって奇妙な取合せであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "行燈に圓朝の句を題した見返しある和装本が初版で、左側の序文は「研究」の中でも屡々いった春のやおぼろのそれである。",
              "citation": {
                "source": "小説　圓朝　あとがき",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、天井そのものも二元性を表わそうとすることが多い。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に牀自身も二元性を表わそうとする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "田口は看護長の返事を待ちながら、傷病者がうまく橇に身を合わそうとがた／＼やっているのを見ていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん食うに食われない理屈はない、家賃、米代以下お新の学校費まで計算して、なるほど二十五円で間に合わそうと思えば間に合うのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山崎の声のひゞきには、それを現わそうとしているところがあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
