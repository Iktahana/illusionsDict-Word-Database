[
  {
    "uuid": "6485b28d-6794-55d3-94fc-1390d3bb5a62",
    "entry": "罠",
    "reading": {
      "primary": "わな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
