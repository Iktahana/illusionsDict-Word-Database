        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一人の生徒はスイミングワルツの口笛を吹きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すでに、かの女は栗鼠の毛皮をつけた女を囮りにして、「――いいわ、こんどのワルツの曲のとき、あんた、あのレデーに申込むのよ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "咏嘆的な音楽が奏でられ、スカートの長いフランス女とアバッシュなマルセーユ男でワルツを始めました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子におかれたザシカのクンセイのような扮装をして女達がワルツを踊っていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルツ、タレルキンの心臓、ニコロの青蛇のような首抱いて、私は踊る。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の生徒はスヰミングワルツの口笛を吹きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八人のようではありましたが、たしかにもうほんもののオーケストラが愉快そうなワルツをやりはじめました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月馬鹿ってのはね――あんただって、チャールストンとワルツの違い位は知っているんだから、教えといて上げるわ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんもののナイチンゲールは、自分かってにうたいますし、いっぽう、つくりものの鳥は、ワルツしかうたわないのですから。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ワルツはどんなふうにはいっているか、そして、どんなふうに動くか、そしてまた、どの曲のあとに、どの曲がつづいてくるか、ということなども、明らかにすることができるのでございます」「わたくしも、そう思います」と、みんなは、口々に言いました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを振りまわせば、世の中に知られている曲という曲、ワルツでも、ギャロップでも、ポルカでも、どんな曲でも、鳴らすことができるのでした。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を洗って着物を着代えているとどこからともなく古風で派手なワルツが凪いだ空気へ沖の浪のなごりのように、うねりを伝えて来る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝になる時と、日が暮れる時に、美しいワルツが聴えて来ました。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯行は男爵の姪御のモニカ・シユワルツ孃によつて三十分ほど前に發見されたんでありますが、裏側の部屋にも同樣な手口で殺害された死體がございます。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　立ち上つた巡査部長は間もなく十三歳の可憐なモニカ・シユワルツとボオイの制服を着た若者を連れて引き返して來た。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に音楽、薔薇のワルツ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォスゲンやシュワルツワルドを遠くに見て、ライン地方の低地を過ぎて行くのである。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ほんもののさよなきどりは、かってに、じぶんのふしでうたって行きましたし、さいく物のことりは、ワルツのふしでやったからでした。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかをあけて、どうワルツがいれてあるか、それがうたいすすんで、歌がつぎからつぎへとうつって行きますぐあいを、人民ども、だれのあたまにもはいるように、しめしてみせることが、できるのでございます――。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他のものでは、フォン・ウェーベル（３）の最後のワルツのあの奔放な旋律を奇妙に変えて複雑にしたものが、痛ましく心に残っている。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一弾のアウトラインを、ジョン・シュワルツという『ニューズ・ウィーク』の記者が一九九二年四月六日号の記事の中で書いている（「THE NEXT REVOLUTION」）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワルツになつたら、僕も仲間に入つても好いよ。",
              "citation": {
                "source": "ランプの便り",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルツは、たしか、あれ一枚しかなかつたな？",
              "citation": {
                "source": "ランプの便り",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其処で、昔習い覚えた危い足取で古臭いワルツを踊り始めた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川は、ショパンのワルツを聴きながら、スッカリ憂欝になってしまった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ふので、滝本は、オーバ・ゼ・ウエイヴ・ワルツなどを、調子高く吹奏した。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂も音も夕空に、とうとうたらり、とうたらり、ワルツの舞の哀れさよ、疲れ倦みたる眩暈よ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "痍に悩める胸もどき、ヴィオロン楽の清掻や、ワルツの舞の哀れさよ、疲れ倦みたる眩暈よ、神輿の台をさながらの雲悲みて艶だちぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
