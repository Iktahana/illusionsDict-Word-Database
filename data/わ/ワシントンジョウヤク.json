        "examples": {
          "standard": [
            {
              "text": "ワシントン条約により、象牙の国際取引が厳しく規制されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "絶滅の危機に瀕した動物を守るため、ワシントン条約は重要な役割を果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この規制は、ワシントン条約の附属書に記載されている動植物に適用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いずれもワシントン条約の即時廃棄を断行せよということで立ち現われたのである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本国民精神が如何にワシントン条約廃棄そのものであるかを、読者は注意すべきだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが文芸におけるこの国民精神が、国防精神やワシントン条約廃棄精神にまで具体化（？",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
