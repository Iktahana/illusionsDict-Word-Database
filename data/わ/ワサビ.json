        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あんなところが登れようかね」と、岩壁の白い薙を指しながら、話の緒を引き出したところが、あすこは嘉門次が、つい去年、山葵取りに入りこんで、始めて登ったところで、未だ誰もその外に、入ったものはないと言うので、私はふと聞き耳を立てた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ駅の俥を雇って町中を曳かれて行くと、ほのぼの明けの靄の中から大きな山葵漬の看板や鯛のでんぶの看板がのそっと額の上に現われて来る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」な味とは、味覚の上に、例えば「きのめ」や柚の嗅覚や、山椒や山葵の触覚のようなものの加わった、刺戟の強い、複雑なものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉松の林中には蝉時雨が降り、道端には草藤、ほたるぶくろ、ぎぼし、がんぴなどが咲き乱れ、草苺やぐみに似た赤いものが実っている、沢へ下りると細流にウォータークレスのようなものが密生し、柵囲いの中には山葵が作ってある。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはまた朝早くから四里も五里も山の中の山葵沢へ出掛けて行く。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山葵や椎茸にはどんな水や空気や光線が必要か彼らよりよく知っているものはないのだ。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊のいない夏は山葵のつかない鯛の刺身のようなものかもしれない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷畑から採って来た鮮かな山葵の束が縁につけてあるのがくんくん匂う。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶碗の三葉は生煮えらしいから、そつと片寄せて、山葵を活きもののやうに可恐がるのだから、われながらお座がさめる。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手づまみの大皿の鮨は、鐵砲が銃口を揃へ、めざす敵の、山葵のきいた鮪いのはとくの昔討取られて、遠慮をした海鰻の甘いのが飴のやうに少々とろけて、蛤がはがれて居る。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其を趣味に隨順せずして、茄子に清冽の水を與へ、山葵に硫黄を與へるやうな事をすれば、二者の氣は各異つた事で、各※異つた作用をなすが、本具の約束に應ずる事なら何も隨順したが宜い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大東館の直きこっちの大きな山葵の看板を見ましたか、郵便局は。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だししたぢに、慈姑、生麩、松露など取合はせ、魚鳥をうどんの粉にまぶして煮込み、山葵を吸口にしたるもの。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さま、この牡蠣のフライと山葵漬はおあがりになりませんね。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薄暮の反射に、柔軟かにして悩ましき汝が衾は銀の潤沢に光れど、冷やかなる鉄の寝台の上、据ゑられし木造の函は、汝が身を入れたる小さき牢獄は山葵色の曇にうち歎く。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひよつくりこつくり顫へてゆく……ピアノに合せた足どりの、ふらふらと両手を振つて、あかしやの禿げた並木をくぐりぬけ、三角｜形の街燈の鉄の支｜柱によろけかかつて腰をつき、そそくさと、そそくさと、内隠から山葵色の罎を取り出し、こくこくと仰向いて、苦さうな口のあたりに持てゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間は広く、店｜全幅の薬種屋式の硝子戸棚には曇つた山葵色の紙が張つてあつて、其中ほどの柱に阿蘭陀渡の古い掛時計が、まだ正確に、その扉の絵の、眼の青い、そして胸の白い女の横顔のうへに、チクタクと秒刻の優しい歩みを続けてゐた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、これは宜い、後をすぐ浸けておくれ、すこし時間があって、ね、船に乗るところだからね」「どちらへいらっしゃいます」「台湾へ帰るところだよ」「おや、台湾へ、それは大変でございますのね」「あ、あ、ちょと途が遠くってね」　謙作は魚軒に添えた割箸を裂いて、ツマの山葵を醤油の中へ入れた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三州奇談に、人あり、加賀の医王山に分入りて、黄金の山葵を拾いたりというに類す。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れのこっちの縁に生えた山葵の芽を一疋の姫蟹が摘み持ち、注意して流れの底を渡りあっちの岸へ上り終えたところを、例の礫を飛ばして強く中てたので半死となり遁れ得ず、爾時岩間より他の姫蟹一疋出で来り、件の負傷蟹を両手で挟み運び行く。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは山葵沢であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天城山の山葵という名をば久しく聞いていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその山葵沢なるものをも絵葉書などではたびたび見ていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小石原いちめんに真緑の山葵が植えつけられているのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "茂りならんで居る山葵の大きさも殆んどみな相均しい。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ア、彼処を御覧なさい、あんなに大きい山葵沢が」　と呼ばれて見た渓向うのそれは、道で見て来たものより遥かに見ごとなものであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二里あまりも登った頃、やがて我等三人はいま渓向うの山葵沢つづきに眺めて来たと同じい落葉樹林のなかへ歩み入った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は初めは其処まで登って、炭焼小屋か山葵沢の小屋を探して一晩野宿しようかという相談が起ったのであったが、まだなかなか寒かろうというので見合せることにしたのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その凸点だけを残したほかは、全部樹海や、大裾野の緩斜地で、すりおろしのわさびの、水々しい緑にひたっている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わさび田ここになさんとて、　　枯草原にこしおろし、たばこを吸へばこの泉、　　　　たゞごろごろと鳴り申す。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
