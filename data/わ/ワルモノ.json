[
  {
    "uuid": "8ddbac0d-2a4c-510c-81d8-b65e178a956c",
    "entry": "悪者",
    "reading": {
      "primary": "わるもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
