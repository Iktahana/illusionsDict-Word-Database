    "definitions": [
      {
        "index": 1,
        "gloss": "to burst into laughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "するとドイツ語の分らない人でも皆釣り込まれて笑い出す。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「子供が生れるんだって」　「まァ赤ちゃんが」　二人、笑い出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家｜呆れて相手の顔を見おり、さてついに己れも笑い出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄球をころがしているお客も、見物している人達も、番をしている商人も一処になって時々笑い出す。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう仕事をしている画家と、非常にデリケートな物理の実験をやって敏感なねじをいじってはめがねをのぞいている学者と全く兄弟分のような気がしておもしろくなって来た、そしてどういうわけか急におかしくなって笑い出すとＴ君もいっしょに笑い出してしまった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はよろこんで笑い出す。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる笑うべき事がない時に笑い出すのは医者に診てもらう場合に限らなかった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳文の意味がどうしてもわからない場合に、それを一ぺん原語に直訳して考えてみるとなるほどと合点が行って思わず笑い出すことがある。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで泣き沈んでいた女が気が狂ったのでなく静かに笑い出すときがそれであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おつやは内を指さして囁けば、重兵衛は笑い出す。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その中にお婆さんが、唐突にゲラゲラ腹をかかえて笑い出すと、その菰をつい剥がしたの。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、おかしくなって、笑い出す子もありました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "額こッつりで小児は泣き出す、負けた方は笑い出す、涎と何んかと一緒でござろう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これにはみんなが笑い出すと、「ようし、やれ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、髑髏が笑い出すと共に、お杉も家をぬけ出した。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る者は又、にやにや笑い出す。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は何故笑われるのか判らないらしく、それでも此方の笑に調子を合わせてニヤニヤ笑い出すのであった。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも他の者と一緒に笑うのではなく、誰も笑わない時にいきなり大声で笑い出すのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とシャーロック・ホームズは笑い出す。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし困惑していることがありありと感じられ、警部も眉をつり上げ、アレク・カニンガムときたら笑い出す始末。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まちがったことじゃ」　などと言うのを聞いてたまらず笑い出す人があると、「鳴りが高い、おやめなさい。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "）中二　（高田と共に笑い出す。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "李はそのうしろ姿を見て、大きく笑い出す。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村の笑い出すのを見た二人は無性におかしくなってもう一度新しく笑いこけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは丑の刻参りの藁人形よ」　こんな事をどうかした拍子に面と向かって木村にいって、木村が怪訝な顔でその意味をくみかねているのを見ると、葉子は自分にもわけのわからない涙を目にいっぱいためながらヒステリカルに笑い出すような事もあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　カンテラの光の届かない部屋の一隅から、急にカラ／＼と頓狂に笑い出す声を聴くと、元気のある度胸の据った喜太郎｜迄が、ハッと色を変えた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "落馬のときのことなど心配すると、今の人はおかしがって笑い出すかも知れないが、むかし池大雅は、旅行のとき、宿場宿場でよく馬に乗ることがある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、さも愉快そうにげらげらと笑い出すかも知れない。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう列べたら、大抵の園芸家は大きな声で笑い出すであろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、かの女は蓮の花がひらくように、僕のこころの迷彩のなかでわらいだす。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
