        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雪溶の日は犀川橋を渡るのも怖かつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯や何に世渡る家五軒　木枯しの吹く冬の山麓に、孤独に寄り合ってる五軒の家。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何に世渡る」という言葉の中に、句の主題している情感がよく現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にまた蕪村は、冬の蕭条たる木枯の中で、孤独に寄り合う村落を見て木枯や何に世渡る家五軒　と、霜枯れた風致の中に、同じ人生の暖かさ懐かしさを、沁々いとしんで咏むのであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ　穹窿に煤煙ながれ工場區街の屋根屋根より悲しき汽笛は響き渡る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨り橋を渡るも灼きつく如く迫り心みな非力の怒に狂はんとす。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠音に渡るかほととぎすの。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に一本大きな赤椿があって、鵯の渡る頃は、落ち散る花を笹の枝に貫いて戦遊びの陣屋を飾った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬田の長橋渡る人稀に、蘆荻いたずらに風に戦ぐを見る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井川の水｜涸れ／＼にして蛇籠に草離々たる、越すに越されざりし「朝貌日記」何とかの段は更なり、雲助とかの肩によって渡る御侍、磧に錫杖立てて歌よむ行脚など廻り燈籠のように眼前に浮ぶ心地せらる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい思想や学説でも、それが多少広く世間に行き渡るころにはもう「流行」はしない事になる。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規は世の中をうまく渡って行く芸術家や学者に対する反感を抱くと同時に、また自分に親しい芸術家や学者が世の中をうまく渡る事が出来なくて不遇に苦しんでいるのを歯痒く思っていたかのように私には感ぜられる。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸橋を渡るとそこらの家の表札は日暮里となっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは、青竹の狹い縁を滑らぬやうに、用心しながらそつと渡る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この谷は、しばらくは、一方は截っ立った崖で、一方は森の下道である、そして板橋一つで、向う岸へ往ったり、こっちへ来たりするので、橋が多い、その板橋を渡る時には、いつも冷たい風が、上流の方から吹いて来る、それは雪を含んで来るのでなければ、氷のように冷たい水のおもてを吹いて来るからであろう。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を渡る頃は又雨になつて河風に傘を取られさうであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また仁明天皇の御代に僧｜真済が唐に渡る航海中に船が難破し、やっと筏に駕して漂流二十三日、同乗者三十余人ことごとく餓死し真済と弟子の真然とたった二人だけ助かったという記事がある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を渡る頃はまた雨になって河風に傘を取られそうであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかな斎の衣は、鶴の羽づくろいしながら泉を渡るに似て爽かにも厳かである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海路は相模国三浦半島から、今の東京湾頭を横断して房総半島の湊へ渡るのが船筋だった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔一寸待って、今｜渡るようにしますから。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶなく渡る、二人がわたる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年も、もう空に、透き徹った秋の粉が一面散り渡るようになりました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホウ、そら、やれ、むかし　達谷の　悪路王、まっくらぁくらの二里の洞、渡るは　夢と　黒夜神、首は刻まれ　朱桶に埋もれ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国へ渡るとなんだか急に呑気になった、巡査を見ても牛乳屋を見ても誰を見ても一様に呑気な顔をしていた。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁がね　朝月夜のかげ空に残りて、見し夢の余波もまだ現なきやうなるに、雨戸あけさして打ながむれば、さと吹く風｜竹の葉の露を払ひて、そゞろ寒けく身にしみ渡る折しも、落くるやうに雁がねの聞えたる、孤つなるは猶さら、連ねし姿もあはれなり。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日下　「クサハ」河を渡船で渡る。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に僕野戦病院入り、いつかニュース映画で兵隊が褌一ツで川を渡るのがありましたね。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、雁の渡るのを見る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の唸る中を、凍てついた路を渡る下駄の冴えかえった音が響いて来た。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
