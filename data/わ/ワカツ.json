    "definitions": [
      {
        "index": 1,
        "gloss": "to divide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――死ぬつてことが分かつてゐたのだわ？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふかあすかは知らぬが、自分はもうこの椅子から立ち上がらずにしまふのが分かつてゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "己には前から分かつてゐた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "身分のある人びとには、語られてゐることがすつかり分かつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランゲナウ人は誰にも訊ねなかつたが、將軍が分かつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう云つてゐるのが、その右手で分かつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は、人に道を譲り、人と利福を分かつという事が美徳の一つに数えられた。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に呂昇の壺坂を感心したのが本當に感心す可き所にしたのか、將た今また攝津の藝術にやや窮屈な壓迫を感じたのが予の耳の罪であるのかも分かつ事が出來ぬ。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは分かつてゐます。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袂を分かつはただ一瞬の苦艱なりと思いしは迷いなりけり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでもここにかうして立つてはゐられないといふこと丈は、八にも分かつてゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し先に立つて行つた四角な顔の太つた男は、年も四十｜恰好で、大佐か中佐かだらうといふこと丈は分かつた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め手に取つたときから、何かぢやらぢやらいふものが這入つてゐて重いといふこと丈は分かつてゐた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近かな話が、術語の如きものでも自分だけで分かつてゐるやうな飛んでも無いものを使用してる場合が非常に多かつた。",
              "citation": {
                "source": "知己の第一人",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "部分々々を讀んでゐると十分に分かつてゐるけれども、全體として見ると、此の長い議論から何が頭に殘つたかと顧みて一寸分かりにくいやうな感じを抱いた。",
              "citation": {
                "source": "知己の第一人",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角地中海の波に全く沈没してゐるわけでもないことが分かつたからですね。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午前三分間だと云ふ時、丘陵の上に見えてゐた妙な物が、小男で、多分｜他所者だらうと云ふことが分かつた。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄きがその一｜言で、何をわたくしに申したのだといふことが、わたくしには直ぐに分かつたからでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、それが分かつてゐたものでございますから、余り気味の悪さに、わたくしは目を瞑りました。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう大抵分かつた筈だと思ひますのに、兄きはどうしたのだか首を振つて、わたくしに同意しない様子で、やはり一しよう懸命に檣の根の鐶に噛り付いてゐます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "君には全く僕が誰の事を思つてゐたと云ふのが分かつたのかい。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで君が敷石の事を考へてゐると云ふことが分かつたのだね。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの君子風のグレシア人は空想で説を立てたのだが、近世コスモゴニイの研究が出来てから、天体の発展が分かつて来て、エピクロスの説いた事が事実的に証明せられたと云つたね。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕の推測の当つたのが分かつた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令ばフランス人の云ふにはあれは、多分スパニア人であつただらう、若し自分にスパニア語が分かつたら、何を言つたか、一言や二言は分かつたに違ひないと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして見るとこゝに非常に軽捷な然も大胆な奴がゐて、あの棒からあの窓枠に飛び付かうとすれば、飛び付かれると云ふことが、己には分かつた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マルタ航海会社と云ふのはどうして分かつたのだね。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜと云ふにそれだけの事が分かつてゐると思ふと、その男がこゝまで出向いて来るのに来易いのだ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしや動物の為業だと分かつたところで、己が現場を知つてゐると云ふことを証明するのがむづかしからう。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源には二人の蘭人とは誰と誰であるかゞわかつて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
