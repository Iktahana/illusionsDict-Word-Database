          "literary": [
            {
              "text": "しのんで、しのんで、つつましくやってさえ行けば、渡る世間に鬼はない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しのんで、しのんで、つつましくやつてさへ行けば、渡る世間に鬼はない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡る世間に鬼はないと云うけれど、わたしはこゝからホールに通よつて行つた。",
              "citation": {
                "source": "淪落",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡る世間に鬼はない、鬼でさえ頼めば人を食わぬ。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡る世間に鬼はない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡る世間に鬼はないと云うから、同情は正しき所、高き所、物の理窟のよく分かる所に聚まると早合点して、この年月を今度こそ、今度こそ、と経験の足らぬ吾身に、待ち受けたのは生涯の誤りである。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡る世間に鬼はないという諺は豪い。",
              "citation": {
                "source": "ロマンスと縁談",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んな人間がいるだろうと思って多少不安でやって来たが、渡る世間に鬼はない。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、半瓦の弥次兵衛は、自分の世話している婆の味方というので、肝胆を照らし合うところがあり、婆は婆でまた、多くの後ろ楯に囲まれて、「渡る世間に鬼はないというが――ほんに小次郎殿といい、半瓦の身内の衆といい、わしのような老いさらぼうた者を、ようして賜もる志……何というてよいやら。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
