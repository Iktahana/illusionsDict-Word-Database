        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三晩つづけてここで雲呑を食べるのである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるじは、雲呑の皮を巻きながら尋ねた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のふるさとを思いつつ釜から雲呑の実を掬っていた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コレ、チガイマス」　あるじから受け取った雲呑の黄色い鉢を覗いて、女の子が当惑そうに呟いた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲呑は十銭であるが、叉焼雲呑は二十銭なのである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は暫くもじもじしていたが、やがて、雲呑の小鉢を下へ置き、肘のなかの花束からおおきい蕾のついた草花を一本引き抜いて、差しだした。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……富岡町の支那屋で雲呑を喰ってると、そこへ電話がかかってきたんだ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那そば、雲呑の、うまいところなんか、彼女に、きけば、たちまち判る。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "安くてうまい、といふのが来々軒、こゝは昔――震災前ほどではなくなったが、やっぱり分厚なものを食はせる、焼売など、又中華丼・雲呑がよろしかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪屋が休みで、来々軒の雲呑ですます。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終って、来々軒の雲呑と中華丼を食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから伊東とハマムラで、シウマイ、中華丼に雲呑を平げて、ＶＡＮへ寄り、みつ豆とコーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高陞へ歩き、焼売と叉焼雲呑を食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャシュウワンタン。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ワンタンのように――は誰かの名文句を失敬したものである。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンタン売りの煤けたランプが、揺れながら壁の中を曲っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、腹が減ったが、その辺で、ワンタン屋の屋台でも見つけようじゃないか。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜の向うでワンタンを鉢にうつしていた白い割烹着にレースの布を捲いた娘がチラリと一瞥を送って「いらっしゃい」と声をかけた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も彼も握手をしましょう、ワンタンの屋台に首をつっこんで、まず支那酒をかたぶけて、私は味気ない男の旅愁を吐き捨てた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も彼も握手をしましょう、ワンタンの屋台に、首をつっこんで、まず支那酒をかたぶけて、私は味気ない男の接吻を吐き捨てた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は金を出して、ワンタンと酒を注文した。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせインチキの支那料理だろうと思って近寄ってみると豈計らんや、インチキでない証拠に、店の張出し窓の処にワンタン十銭、シウマイ十銭、チャアシュウ十銭、支那ソバ五十銭と書いた木札を立てて実物が陳列して在る。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小銭がつかえる者は「おやき」をやめて、ワンタン屋の屋台に入った。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンタンを一つ食べていきましょう」と新ちゃんがいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンタン屋のチャルメラに似たる音せしかば、ちょっと中を覗きて見しに、喇嘛僧二人、怪しげなる喇叭を吹奏しいたり。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "中華ソバ屋は、狭い地所に新築した小さな家で、出来る品物も数少く、ワンタン、ラーメン、チャシュウメン、それから時折シュウマイと、それぐらいに過ぎなかった。",
              "citation": {
                "source": "庶民生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏の飲食店街にある中華料理芳々亭の隅のテーブルにただ一人、今しもワンタンメンを食べ終ったのは西江葉子であった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "汁粉雑煮、ワンタン屋、汚水を流す溝や不完全な炊事場から蒸れ臭い不健全な臭気が、ほこりで白っぽくなった春の並木道に漂っていた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレー半島、クワンタン沖に、ときて、その次がちょっと出ない。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒目勝ちの小さな眼を瞠ってしばらく想い廻らしていたが、「媽、父はワンタンを売ったから、わたしも大きくなったらワンタンを売るよ。",
              "citation": {
                "source": "明日",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
