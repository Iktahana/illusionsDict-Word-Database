    "definitions": [
      {
        "index": 1,
        "gloss": "fornication",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いらねえよ、そんなもん」　和姦でさえやりそこなった慶一が、不機嫌な声でこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "啻に表向の縁組のみならず、古来士族中にて和姦の醜聞ありし者を尋るに、上下の士族｜各その等類中に限り、各等の男女が互に通じたる者ははなはだ稀なり。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ただし日本士族の風俗は最も美にして、和姦などの沙汰は極めて稀に聞くところなり。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神戸はどうしても謝罪状を書けと原稿のようなものを出しましたが、私は拒絶いたしまして、それとなく君と僕と定次郎と共に貞の所へ行って、強姦か和姦か聞けば分る事だから、聞きに行こうと、云いましたが、神戸はそれに応じて呉れなかったのであります。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑法已に和姦を寛宥して罰せずんば禮教又防範する能はざるに至らん。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに君は小説家志願でいつになったらお銭がとれるようになるかわかんないでしょう。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとかよは、「うわあ、兄な、木ペン取てわかんないな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い暗い蚕豆、影のふかい蚕豆、蚕豆が汝か、さういふ俺ちが蚕豆か、はや、訳がわかんねえ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れるだあに、いつまでりきれぬ蚕豆、蚕豆は三段歩、俺ちの畑で、俺ちが蒔いて、育てて、肥やしたのによ、何が鬱ぐことのあるべえ、寂しいか、切ねえか、訳はわかんねえだが、涙がながるる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十円もあったら、ふんとにどんだけ楽だかわかんねえのにさ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんより、医者さでも掛かるようになったら、なんぼ損だかわかんねえべちゃ、爺つあんはあ！",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはわかんないかもしれないが、そいつはドレッバー長老の息子で、ぼくはジョーゼフ・スタンガスン。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちのどちらを、あんたや娘さんが選ぶかはわかんないけれど。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "政さんはいよいよ興がって、「こりゃわかんねい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とよ黙っててはわかんね。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小作米は兎に角、作の悪かった原因がわかんねえようじゃどうも困るね。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おら、困つちやつた――何うして好いかわかんなくなつたゞ……』『ふむ――』　正木はかう点頭いて見せた。",
              "citation": {
                "source": "船路",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "けんど道がわかんねえで困ってると、しあわせよく水車番に会ったからすぐ知れました。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけのわかんねえやつさなんとでも言わせておけばいいだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きなノイズが入らないようにはできるけど、あんまりスムースには聴こえないからね」「気にすんなって、どうせ、みんな眠ってるから、わかんないさ」　高志は、六小節しかないイントロを、テープ編集で四倍にしろと要求している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿みたいなジジイどもが、いろいろ、わけのわかんないこといってんのも、気に入らないしさ」　しゃべっていいときと、いけないときがある、ということすら知らない、行儀の悪い明治のジジイどもだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえだけってことはないだろ」「わかんない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わかんない」「おまえさ、おれがいなかったら、どうした？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかんないよ、日本の会社はメチャクチャだから」「ヤードバーズの〈オーヴァー・アンダー・サイドウェイズ・ダウン〉だの、スタンデルズの〈ダーティー・ウォーター〉だの、騒々しい曲ばっかじゃねえか」　三日後に、ワラがアメリカへ帰る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わかんないよ、あんなの」　佐藤が、片桐の指を見つめたままこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもさ、わかんないことがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中身を見て、わかんないような奴は、どっちを食ったって、おなじじゃねえか」　広岡は、うるせえ野郎だな、ちょっときいただけじゃねえか、とぶつぶついいながら、パラフィン紙の上に中身を三分の一ほどのせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よかったら、あなたのバンドのドラムの子も」「ウーン、わかんないよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かな、なんて、煮えきらないこといってないで、イエスっていえよ」「だって、わかんないんだよ、仕事がどうなるか」「仕事なんて、ほかにいくらでもある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『なんともわかんねえぞよ。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
