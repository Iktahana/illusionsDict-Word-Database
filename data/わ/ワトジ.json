        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かくかくとした祖母の字も、和綴じでていねいに仕上げられた『蜉蝣』の、味わいの一つです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い人は論外だし、もう一人いる人も、円いような顔の老人で、すっかり背中を丸め、机の下でこまかい昔の和綴じの字書の頁をめくっている。",
              "citation": {
                "source": "図書館",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手元にある和綴じの小さな冊子に拠りながら、私自身の言葉で昔話を再現してみたい。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "字体も大きく、和綴じの本で、※絵もなかなか鮮明でしたからお手本には上々でした。",
              "citation": {
                "source": "あのころ",
                "author": "――幼ものがたり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "和綴じの六冊本で、馬琴の覚書きのやうなものであつたが、西鶴のことについての小伝記は、立つて読んでゐる私にも大変面白かつた。",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
