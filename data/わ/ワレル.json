    "definitions": [
      {
        "index": 1,
        "gloss": "to break",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは折々フットボールが飛んで来て窓硝子が割れるので、校長の考案したことであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "甍は伸びをし空は割れる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」不意に松本がびっくりして、割れるように叫んだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "担架にのせられたまゝ床の上に放っておかれた、大腿骨の折れた上等兵は、間歇的に割れるような鋭い号叫を発した。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、鈍感なセメント樽のような動物は割れるような呻きを発して、そこらにある水桶を倒して馳せ出た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　二週間ほどたって、或る日、健二が残飯桶をかついで丘の坂路を登っていると、彼の足音を聞きつけて、封印を附けられた宇一の小屋から二十匹ばかりが急に揃って、割れるような呻きを発して、騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸棚が倒れる轟音、硝子が割れる音、壁がどさる音。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は斯う考えて、まるであの梯形の、頭も割れるように思った。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスなどの円盤の中央をたたくと、それがある整数だけのほぼ同大の扇形に割れる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその氷の割れる音は科学を尊重するはずの日本へ少しも聞こえなかった。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北氷洋の氷の割れる音は近づく運命の秋を警告する桐の一葉の軒を打つ音のようにも思われるのである。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、左の下あごの犬歯の根だけ残っていたのが容易に抜けないので、がんじょうな器械を押し当ててぐいぐいねじられたときは顎骨がぎしぎし鳴って今にも割れるかと思うようで気持ちが悪かった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※６　劈開＝鉱物が一定の方向に割れる性質。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居も大概にせんと筋書が割れるが……」「さればと言うて臭いという証拠は何処にも在りゃせん」「アハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が割れるように痛むので寝たのだと聞いて磯は別に怒りもせず驚きもせず自分で燈を点け、薬罐が微温湯だから火鉢に炭を足し、水も汲みに行った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹は、忽ち何者をか見出したと見へ、割れるやうな聲で叫んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝雇人がパン／＼と電球の割れる物音に驚かされて眼がさめ、庭に出てみると、丁度二十個目の電球を投げつけようとしている豹一の姿が眼にはいった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ある晩も座敷から酔って帰った銀子が寝てから、磯貝が割れるほど戸を叩き、母が聞きかね飛び出して来て、銀子に戸を開けさせ上にあげたが、白々明けるころまでごたごたしていたので、彼女は磯貝の帰るのを待って、銀子に言うのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでも見物は熱狂し、割れるように喝采した。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それももう十五六年前と來ちやあ、忘れるのも無理はないよ……」彼は割れるやうなだみ聲で得意らしくかう云つて、ウ井スキイのグラスを取り上げた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの花火つくりの名人は、打ちあげられて、玉が空中でぽんと割れる、あの音に最も苦心を払った。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二という数は、六でも割れる、三でも割れる、四でも割れる、二でも割れる、実に神聖な数ですからね。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの実際の年月日時刻のうちで、六で割れる数は、十二月だけだった。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖を距てた宿の家族の居間で、「南が吹いて来たな、氷が割れるぞ」と呟く声が聞えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草盆はひっくりかえす、茶碗が転る、銚子は割れる、興奮のあまり刀を振りまわすこともあり、伊助の神経には堪えられぬことばかしであった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした八雲の心理は、我が子の魯鈍に幻滅を感じてる親が、他人から、その愛児の悪評を聞いて怒る心理と、よく似たものであったと思われる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作を語れ、と言われると、どうして私は、こんなに怒るのだろう。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の映画は、そんな敗者の心を目標にして作られているのではないかとさえ思われる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの魯迅先生が、いま生きていたら、何と言われるでしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は実にしばしば服装をかえて、私のまえに現われる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
