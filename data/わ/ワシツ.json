        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ和室は二階に一間しかなかつた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは八畳ほどの和室だった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫂が、和室がひとつどうしても欲しいつて作らせたんですつて……。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はキャッチボールのできるような広い和室へ通され、その片隅に炬燵をつくってもらって寝倒れていた。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳の洋室が中央にあって、四畳半の和室が両側についている。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩舎に付属した和室には、馬丁の福次郎が住んでいると聞いていましたから、そこの戸も引き開けてみました。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災前には客間が和室の八畳だったので、その違い棚に一杯にならんでいた。",
              "citation": {
                "source": "解説　趣味を通じての先生",
                "author": "額田六福",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、土居先生のみは、あやか夫人の憎悪にみちた指定によって、同じ階上に住むことを拒否され、階下の和室に一室を与えられることとなりました。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋はたたみをしいた和室になっている。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、奥へ……」　じゅうたんを敷いた洋間の奥に和室があるのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思った俺の口を封ずるようにロクが、「いつ来ても、この部屋は――結構ですね」　それなり俺たちは和室にあがって対座した。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときの和室のような、妖しい密室感のある、自己完結した和室。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度だけだがその和室を見ているから、描くのは記憶を再現して絵として整理すればそれでよかった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江利子さんがおっしゃってたわ」　加納に頼まれた挿絵の仕事でホテルの和室を訪ねたいきさつを、深町は説明した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ和室が空いているという。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣接して東側に和室があり、この和室が里里葉の寝室だった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の東側は、バルコニーから順に、八畳の和室、その押入れ、浴室と洗面、クロゼットのある主寝室、そしておなじくクロゼットのついた、ひとまわり小さい洋室だ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルコニーに面した広い和室、それから先生の部屋がふたつ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "和室に面した広いところは、隣の家の二階から見えます。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間と和室が左右に振り分けになっていて、階段の反対側の奥には洗面や浴室、そして息子さんのお部屋」　位置を指で示しながら、恵子はそのように復習した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷地の北側には、ふたつの和室の境目あたりに、金属プレハブの物置がひとつあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして生きながら焼かれる人々の叫喚の声が念仏や題目の声に和してこの世の地獄を現わしつつある間に、山の手では烏瓜の花が薄暮の垣根に咲き揃っていつもの蛾の群はいつものように忙わしく蜜をせせっているのであった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　記者は、なお、兵士たちを見まわしつゞけた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらすら道端へ出さっせての、（…………）　爺どのを呼留めて、これは罪人か――と問わしつけえよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの後家めが」　と按摩は又、そこいらを睨みまわしつつ、土の上で一膝進めた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がこれ程に深刻な魅惑力を発揮し得ようとは今までに一度も想像し得なかった程で、私は思わず心の中で……妖女……妖女……浴室の中の妖女……と叫んだほどに、烈しい熱情と、めまぐるしい艶美さとをあらわしつつ私の眼の前に蔽いかかって来たのであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小芳の心中、ともかくも、お蔦の頼み少ない風情は、お妙にも見て取られて、睫毛を幽に振わしつつ、「お医者には懸っているの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ……小路の奥の、森の覆った中から、葉をざわざわと鳴らすばかり、脊の高い、色の真白な、大柄な婦が、横町の湯の帰途と見える、……化粧道具と、手拭を絞ったのを手にして、陽気はこれだし、のぼせもした、……微酔もそのままで、ふらふらと花をみまわしつつ近づいた。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎らしい鼻の爺は、それはそれは空恐ろしいほど、私の心の内を見抜いていて、日に幾たびとなく枕許へ参っては、（女、罪のないことは私がよう知っている、じゃが、心に済まぬ事があろう、私を頼め、助けてやる、）と、つけつまわしつ謂うのだそうで。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして生きながら焼かれる人々の叫喚の声が念仏や題目の声に和してこの世の地獄を現わしつつある間に、山の手ではからすうりの花が薄暮の垣根に咲きそろっていつもの蛾の群れはいつものようにせわしく蜜をせせっているのであった。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
