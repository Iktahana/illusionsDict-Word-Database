        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "平気で、陽気で、藁束のやうにしむみりと、朝霧を煮釜に填めて、跳起きられればよい！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に崖の総六が背戸の畑に、茄子が生えたと申すので、はじめは誰もほんとうにはいたしませなんだが、立派に紫の花が咲いて、霜除に丹精した、御堂のような藁束の中に、早や小指ほどなが一体。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く中に、畝の蔭から、ひよいと出て立つた、藁束に竹の脚で、痩さらばへたものがある。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小径を、誰かの背負つた藁束が、すでに暮色の立ちこめた竹藪の暗みへ、ひつそりひつそりはひつてゆく。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯平の視力が再び恢復した時には火は既に天井の梁に積んだ藁束の、亂れて覗いて居る穗先を傳ひて昇つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は乾燥した藁束の周圍を舐つて、更に其焔が薄闇い家の内から遁れようとして屋根裏を偃うた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "舐つた火は更に此れを噛んでずた／＼に崩壞した藁束は其の火を保つた儘既に其の勢ひを沈めた落葉の上にばら／＼と亂れ落て其處に復た火勢が恢復された。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吾は藁束のようにカサカサに乾しからびて、動けなくなってしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがこの工場は明るいなあ」　四方の窓から朝の陽が、藁束のように投げ込まれている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌畳な支那の中年男が、酸漿のしぼんだようなものを何本となく藁束に刺したのを肩へ担いで、欠伸みたいに大きくゆっくり口を開けるたんびに、円い太い声が、心もち震えて長閑に吐き出されるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁束の屋根は濁流の中へ逆立ちした。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐつたりと、精も根も尽き果てて彼は自分の荒ら屋へ駈けこむなり、藁束のやうに地面へぶつ倒れてしまつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう言つて、煙管から煙草の燠を藁束のなかへはたき落すと共に、フウフウ吹きはじめた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カテリーナは驚愕のあまり、手を拍つとともに、藁束のやうに良人の屍の上へ倒れた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "また平生見かける相撲が――髪を藁束ねにした褌かつぎが相撲膏を貼っていたためかもしれない。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "物音らしいものは耳鳴りで聞えず、かすめ通る灯火の綾の間に見えたホームの荷造の藁束が、いよいよ身近なものの匂いを伝えて迫って来る。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみんかみん」　てお呼び声がどこからか聞えるように思ってフイッと眼を開いてみるてえと、コンクリート作りの馬｜小舎みてえに狭い藁束だらけの床の上へ投げ出されているのに気が付きました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樽柿をかじりながら子供等は藁束の間に遊んでいた。",
              "citation": {
                "source": "秋の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上へおっかぶさるように藁束が堆く積み重ねられてあった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、どうかすると、藁束に身を靠せかけたままいつか心持が重くなってついうとうと転寝の夢に入るような事さえもあった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "木炭の空俵や、藁束や、新聞紙などを、夥しく積み上げて、それに火をつけ、その火種をあちこちに投げ散らして、葦を焼いてるのだ。",
              "citation": {
                "source": "ものの影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置の前に、まだ片付けてない炭の空俵や藁束などがありまして、それに火が燃え移りましたのを、わたくしはただぼんやり眺めていたのでございます。",
              "citation": {
                "source": "花子の陳述",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五万何把の藁束分けて、隠れんぼどこかと探チてまわる。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "白昼の陽光が、新しい藁束のように、穴倉の中へ射し、穴倉の中は、新酒を充たした壺のように明るかったが、頭でも打ったのか、仰向けに仆れ、手足をバタバタ動かしながらも、立ち上がることの出来ない五郎蔵の姿が、負傷した螳螂かのように、その底に沈んで見えていた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁束の炬火で焔の工合いを調節し、それを脚の下や、耳の中に入れたりなどする。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一寸職工が手隙を見せると彼女は自ら藁束を取って入口へ挿入した。",
              "citation": {
                "source": "トンカトントンカッタカッタ",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩の八時から明け方の四時まで、灯火は油にひたした藁束であった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたのかと、彼女もつい腰をあげて戸口からこはごは中をのぞき込んだ時、藁束のやうなものが一面に敷いてある上へ、安里があふむけに寝そべつてゐる姿を見て驚いた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハツとしてその視線を追つて行くと藁束の上に無造作に置かれた、その藁細工の熊手に落ちて居るではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狼の牙",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁束の氣で人間を切りやがる」　平次も何となく暗い心持でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "迷子札",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
