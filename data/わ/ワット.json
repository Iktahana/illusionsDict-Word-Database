[
  {
    "uuid": "b873633d-d31e-56a2-9598-c6708f82184e",
    "entry": "ワット",
    "reading": {
      "primary": "ワット",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "watt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "普通の炭素ランプでは一燭光につき三・五ワットくらいの電力を要するのがこのランプではわずか一ワットで足りる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、カンボジヤ女、シソワットの居城、王宮付舞妓であった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラはかくして富裕な家庭でもとシソワット王宮舞踊場の踊子であった母の美しい愛撫によって育成された。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "プノンペンの街、タマリンドの街路樹、メコン河の流れ、シソワット王の城内、彼方には椰子の林があり、赫熱とした熱帯の強烈な太陽の直射と、熱風を避けた王城内でノラの母はシソワット王と廷臣の居並ぶ玉座のまえで、オーケストラと数十人の唄い手の歌声のなかで華麗な彼女はカンボジヤの踊りを舞うのだった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が君の目的だ」「工業で身を立つる決心だ」といって正作は微笑し、「僕は毎日この道を往復しながらいろいろ考がえたが、発明に越す大事業はないと思う」　ワットやステブンソンやヱヂソンは彼が理想の英雄である。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、彼は客のなきままに、自分で勝手なことを書いては消し、ワット、ステブンソン、などいう名を書いていると、八歳ばかりの男児を連れた衣装のよい婦人が前に立った。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワット」と児供が読んで、「母上、ワットとは何のこと？",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬古　　僕はワットーの精神でそのデカダンの美を見きわめてやる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その堰堤の高さ百八十尺、長さ一千尺コンクリート、貯水量十億立方尺、堰堤上流三里十二町、面積百七十一町、水量流域百二十三方里、発電機四台、励磁機二台、電力四万二千九百キロワット。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは古着を貧民に支給するのを狙いとして、ワット街教会堂の協力で作られた組織なのだが、その日の晩の八時にその組合の会合が行われるので、バークリ夫人は出席しようと夕飯を急いで済ませた。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしどもがワット街の教会から帰っていたのは、九時一五分前あたりです。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "だっておっかさんは、そんな立派な光る物なんぞ着てる人じゃなかったんだものを」というと、それはそれは急にお顔色が変ったこと、ワットお泣なさったそのお声の悲そうでしたこと。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし子は画筆の手を休めて、両手を伸ばして、首をあとへ引いて、ワットマンをなるべく遠くからながめていたが、しまいに、小さな声で、「もう駄目ね」と言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは〈ドライヴ・マイ・カー〉や、〈ホワット・ゴーズ・オン〉も好きだけど。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈黙を縫って、受話器のむこうから〈ホワット・ゴーズ・オン〉のハーモニーが流れてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、〈ホワット・ゴーズ・オン〉のジョンのハーモニーが聴こえたら、なんか、あの時代にむかって、ぶっ飛ばされたような気がした」「聴くんだったら、ＣＤを買え。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、二〇ワットの電燈の下に両方の壁が聳え立ち、窓は鎖され、扉には鍵がかけてある。",
              "citation": {
                "source": "玩具",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ、急ニワットナキ出シテシマッタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさらば、さらば葡萄祭、さらばよ花籠、橡の葉陰の舞踏の庭のワットオぶりの花籠よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語でいえばホワット（何か）とホワイ（なにゆえ）といってもよいでしょう。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから電灯を取りはずして勝手元に引きかえし、検べて見るとそれは、いつものとおりの艶消し瓦斯入りの、一〇〇ボルト六〇ワットの電球であった。",
              "citation": {
                "source": "鼻に基く殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟でドニェプル発電所が完成したという一事は決してただ数千万キロワット時の電力増加を意味するだけのものではない。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千万キロワット時の電力の増大、それに応じて工場が電化し、農村の電化とラジオ網が拡大するということは、ソヴェト同盟ではそれだけ早く真に自由な階級のない社会が来る、経済的基礎の昂揚を意味するものなのである。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
