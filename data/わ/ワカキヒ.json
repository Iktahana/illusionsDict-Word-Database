    "definitions": [
      {
        "index": 1,
        "gloss": "younger days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "げにそこには若き日本の若い人の情緒がある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗き空へと消えゆきぬ　　わが若き日の夢は希望は。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪はあまりに深く　　その月はあまりに清く、あはれわが若き日を燃えし希望の　　今ははや暗き空へと消え行きぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "国展の会場をざっとひと回りして帰りに、もう一ぺんこの「秋庭」の絵の前に立って「若き日の追憶」に暇請いをした。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで詩人が歌うように、若き日には物皆悲しく、生きることそれ自体が、既に耐えがたい苦悩なのである。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにゆゑの若さぞやこの身の影に咲きいづる時無草もうちふるへ若き日の嘆きは貝殼もてすくふよしもなし。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六回「青年よ、若き日のうちに享楽せよ！",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老い疲れたる帝国大学生、袖口ぼろぼろ、蚊の脛ほどに細長きズボン、鼠いろのスプリングを羽織って、不思議や、若き日のボオドレエルの肖像と瓜二つ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は加奈子の若き日の美貌の友だった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅三爺は、その若き日の過去を、幾年となく竜雄の家に雇われてきたのであった。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集作業について回る「暗黒面」を、パーソナルコンピューターで彼方に蹴飛ばしてしまうという若き日の夢が現実に変わりつつあると思うと、もういけなくなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳの未来は、こうしたＧＵＩの世界にこそ開けると確信した若き日の（今でも十分若いのだけれどね）吉本青年は、ＧＥＭの日本語化に邁進していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き日のわれわれが夢にも知らなかつた新しき苦悩に就いて深く語らひ、終ひには足どりも危ふくなつた変れる友をぶらさげて、月あかりの露路を運んでゐた時の彼の感慨は果して何んなものであつたか？",
              "citation": {
                "source": "浅原六朗抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまったく似合わしからぬ恋である、おそろしい罪であることはこれ以上であるかもしれぬが若き日の過失は、思慮の足らないためと神仏もお許しになったのであろう、今もまたその罪を犯してはならないと、源氏はみずから思われてきたことによって、年が行けば分別ができるものであるとも悟った。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の若き日の憧れは、未来の外交官たる直也の妻として、遠く海外の社交界に、日本婦人の華として、咲き出ることではなかったか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日はともに葦かびの若き日をこそ歌ひしか。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ泪にうるむ眼をとじて思考すること五分間……又となき若き日の思い出は……ああ、頼もしくもあり寂しくもある日は……時の運行！",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の若き日の憧れは、未来の外交官たる直也の妻として、遠く海外の社交界に、日本婦人の華として、咲き出ることではなかつたか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は、ともに葦かびの若き日をこそ歌ひしか。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから恋人は忽ち現れても忽ち此方を振り棄てゝ……あゝ、だが若き日に恋のないといふことは何たる悲惨な光景だらう……そんなことで彼は悶々と暑い日を書斎に寝そべつて打ち過した。",
              "citation": {
                "source": "渚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "花自らが生命の昂揚であり、燃焼でありますから、それが他の花から見て、若き日の徒費であらうと、少しも構はないのであります。",
              "citation": {
                "source": "桜の花",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここに一人の年若き日本紳士あり。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青春の息の痕」というのは、涙の痕が手紙に残ってるように、菩提樹に若き日にナイフで傷つけた痕がいつまでも残ってるように、青春の苦悩の溜息の痕を示すという意味である。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き日の露伴が、小石川の小さい池のある一葉の住居を訪ねて行ったことがあったのを。",
              "citation": {
                "source": "人生の風情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て自由民権の時代に大阪事件にかかわりをもった福田英子が『青鞜』の第二年目の或る号に感想を乞われて、老齢ながら「若き日の誇り」をもって、らいてう女史の識見は高いが、それは人生問題であって、婦人問題ではないと、その区別を明らかにしたのは正当であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴は若い俊子を、自分の若き日の思い出の中に生きている一葉と全く切りはなして眺め得ただろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ若き日の思出のみぞ花やげる。",
              "citation": {
                "source": "孔雀船",
                "author": "伊良子清白",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物流転　　35若き日の絵巻は早も閉じてしまった、命の春はいつのまにか暮れてしまった。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、若き日にとって、魅力多き賑わいである。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの世のわかきひとびとら白き手をつなぎ垣のかげにみなたのしげに語れり。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
