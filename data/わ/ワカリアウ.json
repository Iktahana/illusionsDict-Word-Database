        "examples": {
          "standard": [
            {
              "text": "育った環境が違っても、時間をかけて対話すればきっと分かり合えるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "長い間対立していた二つの国が、ようやく和解し、互いに分かり合う道を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "私たちは親友だから、言葉にしなくてもお互いの気持ちが分かり合える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり、人間はその根もとのところでは、みんなよくわかりあうのだということが、久助君にはわかったのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
