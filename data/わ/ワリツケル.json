        "examples": {
          "standard": [
            {
              "text": "イベントの参加者全員に記念品を割り付ける作業が意外と大変だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生は生徒たちに公平に課題を割り付けるように心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "システムは、各タスクに適切なリソースを自動的に割り付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "否と云ったならばただ一刀に、弦四郎の左の胴からかけて、胸まで割り付ける意気込みであった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを三十日に割り付けると、四銭ばかりだが――いくら田舎でも少し安過る様だな」と野々宮さんが計算を立てた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴を輪切るか真っ向を割り付けるか、伎倆の如何、躰形の如何、呼吸の緩急によって変化縦横！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
