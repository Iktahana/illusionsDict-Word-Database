        "examples": {
          "standard": [
            {
              "text": "トラックのタイヤには、坂道での安全確保のために、必ず輪留めをかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "整備士は、車体をリフトアップする前に、前後輪に輪留めを設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この工場の床には、フォークリフト用の輪留めが常備されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "女の耳のあたりには素晴らしく赤い薔薇の花が一輪留めてあった。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
