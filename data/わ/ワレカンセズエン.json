        "examples": {
          "standard": [
            {
              "text": "彼は友人たちの議論には我関せず焉と、静かに本を読んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世間の喧騒に我関せず焉と、仙人のように暮らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もはや彼の問題に我関せず焉、と私は決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "当時の青年層は大体に於て我関せず焉で、明星などその尤なるものであつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "近寄らんとする群衆にも我関せず焉の様子で草をひと把みひと把みと毟り取っては膝にうち当てて汚れを落とし、口に運んでいた。",
              "citation": {
                "source": "象を撃つ",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
