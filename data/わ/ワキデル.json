[
  {
    "uuid": "e7a6e3e6-612b-52ae-ba83-7a65a0db383a",
    "entry": "湧き出る",
    "reading": {
      "primary": "わきでる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
