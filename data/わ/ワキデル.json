      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to gush forth (e.g. water from a spring)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "谷間の泉から湧き出る水は、その周囲に凍てついて、氷の岩が出来ていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　六　鉱山監督局の技師には、危険な箇所や、支柱や柵をやってないところや、水が湧き出る部分は見せないようにつくろっているのだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古めかしさの底から湧き出るほんたうの新しさが感ぜられる。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人の僻見によつて、穢されない彼等の頭腦と感覺の中から、かつて發見されなかつたやうな幾多の思想や感情が湧き出るのに遭遇するだらう。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもこの山巓を少し降った叢の中には、どこかに岩間から湧き出る清泉があるとは、日中｜麓の村で耳にしたので、「オイ、その清泉の所在を知らぬか」と剛力に聴いてみたが、「一向知らねえだ」と澄ました顔をしている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等よりもより雑然たる諸相の中から、湧き出る、溢れ出る、転がり出る、飛び出る、それらの如く、蠢々として、哀々として、莞爾として、突兀として、二人三人五人の青年たちがむくりむくりと起き上って来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "許した証拠に、汽笛だけでも鳴らしてくれると……」　彼女は、そうして湧き出る涙を拭く力さえも失っていた。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉が振り返つて子供を見た時、湧き出るやうな微笑をおさへる事が出來なかつたのである。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉の心は常に淋しく冷たく、涙のやうな暖かいものの湧き出る所のないことを思つた。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の胸のあたりに湧き出る汗は、僅に曲折をなしつゝ幾筋かの流るゝ途を作つて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "深いわけは知らないながらも、お米もなんだか引き入れられるように心さびしくなって、さっきの恨みとはまた違った悲しみに、あたらしい涙がおのずと湧き出るのを押さえることができなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、被害の翌朝、世の中の犯罪者一般に対する憎悪が、初めて自分の心の中に湧き出るのを感じました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからそれへと、いくら思い出してみてもこれならばという自信の湧き出る美しい女性を探し当てることはできなかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛情が、腹のままに湧き出ることが出來るのである。",
              "citation": {
                "source": "書翰",
                "author": "大正十二、三年（推定）　横光君子宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただ湧き出る不愉快の爲めに、渠はかの女が縫ひ物を持つて來てしてゐるそのそばへ無言で寢ころんでゐると、そこへ雪の屋がいつもとは何だか違つた樣子でやつて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "人には、愛情が主權を握つて、幸福は人間に由らなければ受けられない刹那もあるが，健全な時は、人の心には、燦然たる星の夜空も、雲の樣に湧き出る愛や恐怖も、その有限的性質を失つてしまつて、僕等は完全圓美な靈界に這入つて居るのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宿は評判だけあつて、気安くて、深切で、安くて、よろしい、殊に、ぶく／＼湧き出る内湯は勿体ないほどよろしかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは水に乏しいけれど、すこしのぼれば、雑草の中からしみじみと湧き出る泉がある。",
              "citation": {
                "source": "『鉢の子』から『其中庵』まで",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の裡に何んとも言へぬ川島先生へ気の毒な情が湧き出るのを覚えた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "中腰になって両手を伸ばしつつ、私の言葉を遮り止めようとして狼狽している態度が、新しく新しく湧き出る私の涙越にユラユラと揺らめき泳いだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし本当に自己を知り、強固に自己のエスプリを持っているならば、目標に向って邁進すべく熱意は自ずから湧き出るということが考えられていいはずである。",
              "citation": {
                "source": "画室の言葉",
                "author": "藤島武二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、苦しいのは自分ばかりではないのだ、と思うと彼は光が湧き出るような感激を覚えた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒土の上に透き間もない苔は木立の間に形ばかり付いていた小道をも埋めて踏めばじとじとと音もなく水の湧き出る小暗い庭は、話に聞いたいろいろの恐ろしい物の住家のように思われ、自由に遊び廻る気にはなれないので縁近いところでつまらなくすくんでいた。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あまりに固くなり過ぎたからか、いつもは湧き出る空想が今度に限って湧いて来ない。",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共はこの沃地に湧き出る詩の霊泉を汲んで、もつと広く深い想像の世界へ踏込まねばならない。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代子が風のごとく自由に振舞うのは、先の見えないほど強い感情が一度に胸に湧き出るからである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "海のやうにわきでるわたしの寂寥をまきちらせ。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミッドウェー島は、ホノルル港から、約千カイリ、ハワイ諸島の西端の島で、島は、海面から、約十二メートルの高さであるが、すこしほれば清水がわきでるから、この島で、まず飲料水をつみこむことを考えた。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに晩秋の、こんなしぐれのふるうすら寒い日に、洗いざらしの単衣ものをきて、たびもはかずに、素足にピチャピチャと、すりへらした下駄をつっかけ、このからだのどこから、いったい、猛犬の五郎丸におどりかかろうとするような、あんな気力がわきでるものでしょうか？",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ヴェッテルン湖の近くの、メデヴィの平原に、鉱泉がわきでるようになります。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
