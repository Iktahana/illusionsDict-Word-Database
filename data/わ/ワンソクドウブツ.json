        "examples": {
          "standard": [
            {
              "text": "腕足動物（わんそくどうぶつ）は、二枚貝に似ているが、全く異なる系統の動物である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "化石として発見される腕足動物（わんそくどうぶつ）は、古生代の海の生態系を知る上で重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海底の岩に固着して生活する腕足動物（わんそくどうぶつ）の仲間は、世界中に生息している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "沈める都市の信じ難い廃墟を、遍在する豊かな海百合、腕足動物、珊瑚、魚族を見た。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
