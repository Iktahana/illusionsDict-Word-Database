[
  {
    "uuid": "b600552d-c791-5dbb-a8ae-4b03e239f9cb",
    "entry": "和子",
    "reading": {
      "primary": "わこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
