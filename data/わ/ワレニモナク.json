[
  {
    "uuid": "c214fd13-d9b7-53fc-95d1-08744a471f15",
    "entry": "我にもなく",
    "reading": {
      "primary": "われにもなく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
