[
  {
    "uuid": "e4780e64-bda1-52b6-9a7d-e15453ed5dcc",
    "entry": "悪い",
    "reading": {
      "primary": "わるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
