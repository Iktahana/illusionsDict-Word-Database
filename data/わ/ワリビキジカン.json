        "examples": {
          "standard": [
            {
              "text": "映画館では、レディースデーやファーストデーなど、様々な割引時間が設定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観光施設によっては、特定の時間帯に訪れると割引時間が適用されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ジムの早朝割引時間は、お得に運動したい人にとって魅力的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "乗物は二等より三等を愛し、活動写真は割引時間になってから見た。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十年にもなるだろうか、チェリーという煙草が十銭で買えた頃、テンセン（十銭）という言葉が流行して、十銭寿司、十銭ランチ、十銭マーケット、十銭博奕、十銭漫才、活動小屋も割引時間は十銭で、ニュース館も十銭均一、十銭で買え、十銭で食べ十銭で見られるものなら猫も杓子も飛びついたことがある。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に説明しておくが、この頃の電車には早朝の割引時間のほかに、急行時間というのが出来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
