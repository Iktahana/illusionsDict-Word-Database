    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese translation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東行西行雲悠々」といふ漢詩を、昔の或る人が和訳して「きさらぎ、やよひ、日のどか。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの和訳の詩には芸術としての価値がなく、且つ原詩のあたへる詩的感銘を、少しも表象的に伝へてゐない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が日本語によってこの種の表現をしようとすれば、いかにしても支那音の漢語を借り、和訳された漢文口調でする外はない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先頃まで流行して居たはやり唄が和訳されてもう町の童の唇に上っている。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼時余は、母に、論語を学び、二宮尊徳の修身を聴講し、ナシヨナル・りいどる巻の一に依つて英語を手ほどかれ、和訳すゐんとん万国史を講義された。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（和訳して――上京後の第二信）　余の親愛なるミセス・Ｆよ。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラ・マンチアのドン・キホーテがあるな、こいつは和訳だね、長いからな――。",
              "citation": {
                "source": "読書と生活",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と胸を叩いて、その方法にとりかかつて見たが、和訳した文章を眺めると、拷問にかけられても他人の前には提出も敵はぬ幼稚沁みたものに見え、私は腕をこまねいてとつおいつなる長太息を洩らさずには居られなかつた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品は朗読に価する韻文詩の由であるが、誰かの和訳文はないだらうか。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の和訳は『今昔物語』や『宇治拾遺』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし平安朝廷の食膳を記した『厨事類記』に猴喜んで食う故に猴桃とも名づくとあれば、邦名サルナシは支那名を和訳したのか。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "“My Dear Flora, H――”　私は、胸のうちでこれを修飾的に和訳して胸を顫はせた。",
              "citation": {
                "source": "悪筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最新式避姙法」の書物　マリーストーブとかブラングエンとかいう人々の著書の和訳、又は「性」という文字を標題に取入れた雑誌は、記者が街頭の書物屋で見ただけでも十種近くある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼時余は、母に、『論語』を学び、二宮尊徳の修身を聴講し、『ナショナル・りいどる』巻の一に依つて英語を手ほどかれ、『和訳すゐんとん万国史』を講義された。",
              "citation": {
                "source": "余話",
                "author": "秘められた箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も折々自分の喋舌ることを秘かに自分の胸に和訳して見ると、気狂ひにでもならなければ到底口にすることも適はぬ気障つぽさだと首をすくめたが、そんな反省などは喋舌つてゐる限りは何も残らなかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は未だ宿屋の番頭なども繰り込まぬ人気のない待合所のベンチに腰を降して「新進作家叢書」とか「ウエルテル文庫」などゝいふ小型の和訳本を読んだ。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も、恋人とも定らぬ相手とさへも、一旦和訳して見ると、恰で熱烈な恋愛者の言葉である通りの仰山な文字面が如何にも愉快であつた。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "朗らかな冗談を、そのまゝ和訳した態の真にうけて、倍増の悒鬱に覆はれては大変だ――と私は要心したが、生真面目になるばかりで、あはや昏倒でもしさうであつた。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたに親しみを感ずるうれしさに和訳のほうを読みました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯員の一人は、片手で髭を引っぱりながら熱心に露文和訳をしていた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百は漢訳和訳の洋説を読んで慊ぬので、とうとう保にスペルリングを教えてもらい、ほどなくウィルソンの読本に移り、一年ばかり立つうちに、パアレエの『万国史』、カッケンボスの『米国史』、ホオセット夫人の『経済論』等をぽつぽつ読むようになった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一月六十円の月俸を貰ひ、昼は英文和訳を教へ、夜はせつせと仕事をした。",
              "citation": {
                "source": "身のまはり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し這般の和訳艶情小説を一読過せんと欲するものは、請ふ、当代の照魔鏡たる検閲官諸氏の門を叩いて恭しくその蔵する所の発売禁止本を借用せよ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした錻力製の呼吸孔の事を医学用語ではカニウレと云うのだが、和訳したら金属製咽喉笛とでもなるのかな。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の署名のＪ・Ｍ・ＳをＪ・Ｉ・Ｃと置き換えて得ました暗号用のアルファベットを、更に、苦心して探りました××大使館用の暗号用アルファベットと置き換えて得ました英文の和訳がこれであります。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が支配している警視庁のまん中に立っていながら、廊下にスパイでも居るかのように、わざわざ入口の扉を開け放して来て、突立ったまま電文の和訳の残りを読み終ると、もう一度廊下の方をチラリと見ながら、私の顔に眼を移した。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月四日（火曜）　入学試験 Conversation と英文和訳と Dictation があった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒間には先生の言は道理だというものがあり、また、頑固で困るというものもあった、が結局先生に対してはなにもいわなくなった、英語の先生とはいうものの、この朝井先生は猛烈な国粋主義者であった、ある日生徒は英語の和訳を左から右へ横に書いた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニーから来る通信がいつでもなまぬるいので、カロラインは腹を立ててわやくを言いだした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（眼を光らし、姫を瞻めて）まだそのようなわやくをおっしゃる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
