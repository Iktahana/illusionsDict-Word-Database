        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旗手ワイズミュラア。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し城壁の間にはエエデル・ワイズの花なども相見え、如何にも寨外へ参りたるらしき心もちだけは致し候。",
              "citation": {
                "source": "雑信一束",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "カール・グロース、チーグラー、ワイズマン等によって支持されている。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は生活準備説ともいわるべきカール・グロース、チーグラー、ワイズマン等によって支持さるるものである。",
              "citation": {
                "source": "スポーツの美的要素",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターザンのワイズミュラーが全盛のころ、オリムピックの帰途だかに、日本へ来たことがあった。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の日本の国際レベルの選手は高石一人だが、彼は競泳界を引退するまで、一度もワイズミュラーに勝つことができなかった。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイズミュラーはプールのまん中までもぐっていって、顔をだしざま、水をふきあげて、ガガア！",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸上水上に限らず、短距離の速力はほぼ人間の限界近く達しており、ワイズミュラーの記録は今日でも大記録であるが、日本来朝の時には高石がいくらか接戦することができたから、当時に於ては競争相手のないアルネ・ボルグの方が驚異であった。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイズミュラーは今年二十七でしょう。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あの英吉利人も二十七でなくちゃならないんだ」　なるほど、ワイズミュラーによく似ている。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画に出てくるワイズミュラーのようにふやけた顔はしていないが、身体の釣り合いや、腕の長すぎるところなんか、たいへんよく似ている。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前の淑女たちを『リットル・ウィメン』などと呼んだ仕返しに、ワイズミュラー君のことを『ローリーさん』と呼ぶことにした。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイズ・ミュラーも見た。",
              "citation": {
                "source": "世に出るまで",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしワイズおよびムアが発表したこの見解も根拠は極めて薄弱である。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイズの訳書を研究したヘーザーはカタル性黄疸（＊＝ウイルス性肝炎）、淋病、たぶん結核の証拠を見つけ出している。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイズルは北シベリアの現地人のあいだにしばらく逗留していたときに彼の小屋に訪ねてくる若い女性がはしゃいでシラミを投げつけたことを話してくれた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とおなじくオリンピックのチャンピオン・スイマーであり、最高のターザン役者として知られていたジョニー・ワイズミュラが、デュークの次に泳いだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
