    },
    "definitions": [
      {
        "index": 1,
        "gloss": "peace and harmony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夏とはちがって人影も見えぬ和楽園の前に釣を垂れている中折帽の男がある。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "能く家を整えて、一家をして、より多くの和楽幸福を得しむると云うことは、人間の事業中に在って、最も至聖なるものである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りと雖も相互に於ける身分の貴賤、貧富の隔壁を超越仕り真に朋友としての交誼を親密ならしめ、しかも起居の礼を失わず談話の節を紊さず、質素を旨とし驕奢を排し、飲食もまた度に適して主客共に清雅の和楽を尽すものは、じつに茶道に如くはなかるべしと被存候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこんな心細い腕前で「主客共に清雅の和楽を尽さん」と計るのも極めて無鉄砲な話であると思った。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "失せにしものは此に見出され、求むるものは此に備はり、家｜兵燹に焼かるる憂なく、愛する夫を戦場に死せしめず、和楽の和雅音大空に棚引いたり。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平楽の並べ合いをする「男女同権」の意味からでなく、家庭和楽のすすめ合いをする「男女同義務」の上から見て――鼻の表現研究の行き方である恋愛至上主義、即ち文化生活向上の意味から見て、取り敢ず大白を挙げて慶賀すべき現象と考えられるのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが邦幸いに従来大字ごとに神社あり仏閣ありて人民の労働を慰め、信仰の念を高むると同時に、一挙して和楽慰安の所を与えつつ、また地震、火難等の折に臨んで避難の地を準備したるなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家和楽の庭には秋のあわれなどいうことは問題にならない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち趣味の同化から和楽しためでたいところで落ちになっているのであるが、この嚊大明神の、竈の下でも吹いてやがれ云々が非常に利いて、痛快でかつ適切でありはせぬか。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺は一体に勤人の住宅が多かつたので、何処の家でも裹ましげな和楽の声がしてゐるやうに思へた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に女子にとつては最も大切なる一家の家庭を司つて、その上に一家の和楽を失はぬやうにして行く事は、多くは母親の教育如何によりて善くも悪くもなるのである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今までの日本の習慣では、一家の和楽といふ事が甚だ乏しい。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして更に向島の七福神巡りをするものもあれば、近所の廻礼をすますものもある、けれど廻礼には大方二日以後の日を択び、元日はただ※笑の間に和楽して終るが多い。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "法諡を和楽院潤壌貞温大姉と云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "試演は歌舞伎座で催すのだが、沢山の人を集めた和楽オーケストラなので、広い場所でなくっては稽古が出来ない。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "廟は正殿と寝殿とに分れ、寝殿は後部に在つて、其処には夫婦二神の像が略服を著けて、一日の晏居に、云はば天地人間の司配を忘れて家庭の和楽に浸つてゐる形である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいてこの村は太平和楽になった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢きも智を忘れ、富みたるも財を忘れ、貧しき我等も労を忘れて、愛と美と涙の中に和楽する一味の人。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる国粋主義者も、軍楽隊を和楽化しようとは思はず、国歌の曲譜が三味線や尺八にのらないことを嘆じもしないし、銅像は東洋風の技法でなければならぬと誰も注文はしないのである。",
              "citation": {
                "source": "官立演劇映画学校の提唱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "声は勿論、声楽とか、和楽のいろいろな歌、長唄、義太夫、謡曲、そういうもので最も自然に直接鍛えられます。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しＡが、一日に二時間、家庭の為に、全部の自己と云うものを和楽のうちに投げ出す人であったら、私の家庭生活に対する愛は、些か傷も負わずに育てられるに違いない。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の時代思潮は何かといへば、つまり平和を愛し一身の安穏和楽をもとめるやうになつたといふことだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "万民が秀吉の偉業を謳歌するのは彼によつて安穏和楽を信ずるからで、然る時に、息つくまもなく海外遠征、壮丁は使丁にとられ、糧食は徴発、海辺の村々は船の製造、再び諸国は疲弊して、豊臣の名は万民怨嗟の的となる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思へば当今の天下統一万民和楽もひとへにあなたの武略のたまものです。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に先生が其趣味主張を一切胸に畳んで、所謂家庭の和楽の犠牲となって一個の好々翁として穏にヤスナヤ、ポリヤナに瞑目されたとして、先生は果してトルストイたり得たでしょう乎。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小春」とか「和楽」とかの画になりそう。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北は伴奏が和楽ばかりの上にひねったお客いわゆる笑わざるをもって大通とするお客が多かったから、南よりやや演りにくかったが、それとても楽天地や金竜館のお客に比べれば天地雲泥の相違だった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬のからっ風が玄関を吹きぬけ、遠くのドアをばたばたさせ、窓のあたりにひゅうひゅう鳴り、煙突から吹きおりてくるとき、奥まった心地よい部屋で、一家の和楽するさまを、落ちついて安心した心持ちで見ることができるほどありがたいことはないだろう。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは素人の料理であるけれども、一家の和楽、団欒がそれにかかわっているのだとすれば、精一杯の、まごころ料理になるのである。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に、奧州の平泉中尊寺へ詣でたかへりに、松島へ行く途中、海の底を見るやうな岩の根を拔ける道々、傍の小沼の蘆に、くわらくわいち、くわらくわいち、ぎやう、ぎやう、ぎやう、ちよツ、ちよツ、ちよツ……を初音に聞いた。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
