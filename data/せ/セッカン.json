[
  {
    "uuid": "323e7943-d7c1-5342-b544-e459e257977d",
    "entry": "石棺",
    "reading": {
      "primary": "せっかん",
      "alternatives": [
        "せきかん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sarcophagus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筆が洗練され、枯淡になっていても、やはりどこか昔の虚子の「三つのもの」や「石棺」時代の名残のようなものが紙面の底から浮上がって来るように私には感ぜられるのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死者を納れる石棺のおもてへ、淫らな戯れをしている人の姿や、牝羊と交合している牧羊神を彫りつけたりした希臘人の風習を。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには長方形の石棺が置かれてある。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの石棺は歴山大帝の遺骸を藏むといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その墓舎はそれから三年間開かれなかったが、三年目の終りに一つの石棺を入れるために開かれた。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "石棺の露出せる處に、里見廣次の墓と題する石塔を訪ひ、總寧寺の境内を過ぎ、右に兵營、左に練兵場を見て、國府臺を下り、市川の村はづれより市川橋を渡り、小岩驛より汽車に乘りて歸ることとしけるが、日なほ高ければ、小利根川の右岸を下ること凡そ十町、善養寺一名小岩不動に立寄りて、星下松を仰ぎ、影向松を撫す。",
              "citation": {
                "source": "川魚料理",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に露出せる石棺は別にて、上古の制也。",
              "citation": {
                "source": "國府臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘り出された一個の石棺が、かれらの前に置かれてある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な刀剣、曲玉管玉、石棺の中に充ちている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んだ石棺には、ペルシア模様の中に、ラテン語の碑文があり、水道の設備、浴場の排水路、暖炉の大きさから察すると、この都の文化は、その昔ギリシアやローマに劣らなかった繁栄を示したものにちがいない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖には信玄の石棺が沈められてゐるといふ傳説が一時傳つてゐた。",
              "citation": {
                "source": "霧の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は××に乗り組んだ後、エジプトの石棺に書いてあった「人生――戦闘」と云う言葉を思い出し、××の将校や下士卒は勿論、××そのものこそ言葉通りにエジプト人の格言を鋼鉄に組み上げていると思ったりした。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その中に幾つか石棺の姿が明滅して、明らかにこの一劃が、算哲の墓※に相違ないことが分った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査が終ると、三人は愴惶に石棺の蓋を閉じて、この圧し狂わさんばかりの、鬼気から遁れていった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内者に導かれて地下の墓洞へ下りて行くと、龕毎に学者政治家達の石棺が花｜環に飾られて蔵まつて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖の水の乾く時が来たら、死骸は石棺のまま現われなければならない。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然、文政年間に好奇の人間が現われて、信玄の石棺を引き上げようとした。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ灘兵衛、石棺はあったか？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石棺の在所は解らずとも、手懸りでもあってくれればよいが」　頼正は船首に突っ立ったままじっと水面を窺った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我石棺を引き上げると云うも、法性の冑を奪い返し、家宝にしたいに他ならぬ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苔蒸した石棺に腰をかけ」「苔蒸した石棺に腰をかけ？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生首をくわえた水狐族の巫女が、苔蒸した石棺に腰かけている！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石棺引き上げの第一日目はこうして失敗に終わったのである。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「湖水の石棺を引き上げようというあの乱暴な計画がどうやらお蔭で止めになったらしい。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は松火を振り立てながら、自分の考古癖に誘われて、石棺の方へ近寄って行った。",
              "citation": {
                "source": "木乃伊の耳飾",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んぞ知らんその耳飾は、博士が発見する前に、私が石棺の木乃伊の耳から、もぎ取って置いたものでございます。",
              "citation": {
                "source": "木乃伊の耳飾",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし石棺は鉄の蓋をもって、厳重に蔽われ鎧われていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こういう光景の中に、このような石棺があるのである。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶子と民弥とは満足に充ちた心――喜びと幸福と感謝とで、無言でしばらく石棺を見詰めた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はこの頃では殆んど毎日のように、私が痩せ衰えた姿の夢や、警察につかまって、そこで「せっかん」（母は拷問のことをそう云っていた）されている夢ばかり見て、眼を覚ますと云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
