[
  {
    "uuid": "594e6cc6-a3fb-5490-b12f-fb689e63acbc",
    "entry": "性的",
    "reading": {
      "primary": "せいてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
