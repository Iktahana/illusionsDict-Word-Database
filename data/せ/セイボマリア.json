    "definitions": [
      {
        "index": 1,
        "gloss": "Virgin Mary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
