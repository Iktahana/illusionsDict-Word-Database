        "examples": {
          "standard": [
            {
              "text": "彼の仕事はいつも拙速主義で、細部への配慮が足りない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトでは、拙速主義に陥らないよう、計画段階を重視する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "拙速主義で作られた資料は、後で修正に手間がかかることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いい意味での善良な国民、穏和な意味でのプロレタリアは、実際めいめいのまじめな仕事に真剣に従事している限り、拙速主義の疑わしい知識に飛びついて朝夕心を騒がせ気をいら立てる必要は毛頭ないのである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会はいつ開かれるのかまだ決定していないらしいが、内務省は拙速主義でその成案を得ることにするそうである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
