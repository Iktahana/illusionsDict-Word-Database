[
  {
    "uuid": "cb2172a4-4d3e-57e8-b3d3-730754c0fc1a",
    "entry": "選別",
    "reading": {
      "primary": "せんべつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
