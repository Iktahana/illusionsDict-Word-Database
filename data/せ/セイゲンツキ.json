        "examples": {
          "standard": [
            {
              "text": "彼は制限付きの自由を与えられ、特定の場所から出ることを禁じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "期間限定の制限付きライセンスを購入して、まずはツールの使い勝手を試してみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この奨学金は、特定の学部を志望する学生のみが対象という制限付きの公募だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これがほんの僅かでも聞えて来る限り、あらゆる幸福も名誉も制限付きの名誉・幸福でしかない。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点について釈然としない限り、俺にとって、あらゆる人間界の現象は制限付きの意味しか有たないのだから。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
