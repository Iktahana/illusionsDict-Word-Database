        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船長は、横柄に収まりかえっていられる筈の、船長室にはいなくて、サロンデッキにいた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を茫然して居るかツ※』と叫んだまゝ、私は身を飜して船長室の方へ走つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして船長室で船長に会って葡萄酒と珈琲と、見た事もない美味い果物を御馳走になった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼はもう一度｜罵ったあとに、船長室のドアを荒あらしく突きあけて甲板へ飛び出してしまった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし船長室はわたしの船室から少し離れているので、彼の言うことははっきりとは分からなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの女はちゃんとそこにいたよ」　彼は起ち上がってドアをあけ、のろのろと不確かな足取りで、船長室へ歩いて行った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今晩、かねて私の義務であったので、公正証書のために彼の動産表を作ろうと思って、船長室へはいってみると、すべての物は以前にはいった時と少しも変わっていなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして私たちは船長室に突進した。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして我々は船長室に突進したが、戸を押し開けたとき、なかから発砲音が聞こえてきた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間が船長室の隣にあり、我々はそこに集まって、長椅子に身を投げて、お互いに談笑した。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、船長室でしたくをしていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長が、そのダイアモンドのピンを、ネクタイに「優雅」にさそうとしている時に、純白の服を着けたボーイは船長室の扉をたたいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴さん、登別に行くんで、急いでるんだよ」「ところが、こっちはもっと急ぎの用事なんだ、ちょっと頼む」　ボーイは再び船長室の扉をたたいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "チーフは船長室のドーアの中へ消えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと相談をして来るから」と藤原へ言って、「どうぞ私の室まで」とメーツらに目くばせをして、彼は船長室へ又候はいって行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、船長室に密議を凝らしに行ったメーツらはサロンへ引っかえして来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランチから、会社員が船長室へはいって行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "検疫官は絵島丸の検疫事務をすっかり年とった次位の医官に任せてしまって、自分は船長室で船長、事務長、葉子を相手に、話に花を咲かせながらトランプをいじり通した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検疫官の官舎の白い壁も、そのほうに向かって走って行くモーター・ボートも見る見る遠ざかって小さな箱庭のようになった時、葉子は船長室でのきょうの思い出し笑いをしながら、手欄を離れて心あてに事務長を目で尋ねた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂは招かれて船長室に行き、そこで麦酒を御馳走になり、いろいろとめづらしい航海の話を聞き、船長と一緒に夜の海と空とを眺め、星座の位置などを指し、もとの船室には帰らずに、そのまゝひとりそこに眠つて了つたが、しかもつひにひとりではなしに、かの女が絶えずそこにやつて来てゐるのを感じた。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長室に無電係が周章ててかけ込んできた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は船長室から「糞壺」に帰ってくると、忽ち皆に、渦巻のように取巻かれてしまった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他愛のないものさ」監督は、船長室で、船長を相手にビールを飲んでいた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生二人、吃り、威張んな、芝浦、火夫三名、水夫三名が、「要求条項」と「誓約書」を持って、船長室に出掛けること、その時には表で示威運動をすることが決った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――船長室へ押しかけた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長室の窓が凄い音を立てて壊れた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長室にも無電室にもみつからないと、東屋氏は、船橋を降りて後甲板の士官室へ飛込んだ。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は船長室に近い舳の方の甲板の上に陣取つたが、一行の五六人のものの中には松江からの古川君、境からの渡邊君の外に、美保の野村君もまた一緒で、境から乘つた時と殆ど同じ顏觸れであつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽつかり島が、島も春風　島はいたゞきまで菜ばたけ麦ばたけ・ここが船長室で、シクラメンの赤いの白いの（三原丸）　四月十四日　坂下から清内路へ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「念のため、船長に報告したら何うでしょう」　となって、ストウン二等運転士が船長室のドアを叩く。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
