          "literary": [
            {
              "text": "ごくシンプル文が伸びただけのものや、あるいは普通ならピリオドで止めてしまうような文と文が、コンマやコロン・セミコロンといった句読点で一気につながれてゆく、というものです。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、セミコロン「;」もできるだけ残してあります。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし必要に応じてダッシュ「――」を追加しました（青空文庫形式版では全てのセミコロンを削除し、読点、句点、ダッシュに適宜置き換えました）。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
