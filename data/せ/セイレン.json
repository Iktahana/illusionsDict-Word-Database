[
  {
    "uuid": "c8955dbc-2270-56d7-93a9-ccc2d1753155",
    "entry": "清廉",
    "reading": {
      "primary": "せいれん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
