    "definitions": [
      {
        "index": 1,
        "gloss": "freedom to carry out political activities",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
