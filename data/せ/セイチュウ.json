[
  {
    "uuid": "b993b701-b17a-5cbe-9100-ac955352b307",
    "entry": "正中",
    "reading": {
      "primary": "せいちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
