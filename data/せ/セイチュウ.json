      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "middle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（一）正中偏平等方面を中心にして、差別方面を眺めた形であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）正中来次は平等方面のみを眺むる場合であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕空にむらむらと嶽の堂を流れて出た、一団の雲の正中に、颯と揺れたようにドンと一発、ドドド、ドンと波に響いた。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正中二年十月と言えば、後醍醐天皇が、藤原資朝、藤原俊基等の近臣と王政の復古を謀って、その謀の泄れたいわゆる正中の変の起った翌月のことであるが、その二十一日に、山城、近江の二箇国に強震があって、日吉八王子の神体が墜ち、竹生島が崩れた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、相手を素裸にして打倒した女が凱歌をあげ、情事に於ける正しき者と認められ、今迄厳正中立を保って見物していた衆人から祝福を受ける。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正中の変前に、日野俊基が山伏姿で湯治と称し、大和、河内に赴いたことは、『増鏡』や『太平記』に立派に記してあるが、恐らくこんな時、楠氏と朝廷とが結ばれたのかも知れない。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "正中元年その御計画は、北條氏の探知するところとなり、資朝、俊基の公卿を始め、土岐頼兼、多治見国長などの犠牲者を出したが、天皇は隠忍してその時機を待たせられて居たが、嘉暦元年北條氏の皇位継承に対する干渉露骨となるや、天皇の御決心いよ／＼深く、北條氏討伐の御計画は、正に一触即発の域に達した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（西鶴の武道傳來記六の二に、天正中伊豫の合戰に討死した人の幼女を護つて東都に立退た忠臣が七十餘歳になり、二八ばかりに成長した故主の娘は諸人の執心うたてく、表て向き夫婦同樣に暮し居た。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "八足の正中に一足あるをいうと記せるごとき、どうもわが邦にも交合に先だって一足が特に長くなり体を離れてなお蠕動する、いわゆる交接用の足（トクユチルス（第五図））が大いに発達活動して蛇に肖た蛸あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は日比谷公園を散歩しながら久し振でゆっくり話そう、ということに定めて、街鉄の電車で市区改正中の町々を通り過ぎた。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、この岸辺には　　　　　　　　　　一九一八―一九二三（大正中期）　日本の婦人の生活は、第一次欧州大戦終結を境として、各方面に大きい変化を生じた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治より大正中葉まで出現した殆どすべての作家は、大学出身者であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十四年という歴史の頁の上で、少からぬ日本の婦人作家群のうちの何人が、少くとも、明治末・大正中葉の、女も人間であるというつよい主張に立って、自身の文学を自覚し制作していたであろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今お側にゐた小僧は額の正中に大い目が一つしかありませんでした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の正中に一｜目を開いてゐる畸形は胎生学上に有りやうがない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平聖恵方の完本は、躋寿館に永正中の鈔本の覆写本があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかしさへ置きたれば、いよゝ狭きに、をさなきものねむたしとて、並みゐる正中に足踏み伸して臥す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔李朝物〕　所謂李朝物は大正中期以後今日まで異常な流行をみた。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、この一隊だけは政府党の警官たちをも監視し牽制する厳正中立の鉄甲である。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち後村上天皇崩御の正中二十三年よりずつと後のことである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "押鐘津多子――あの大正中期の大女優は、それ以外のどんな鎖の輪にも、姿を現わさないにもせよ、すでに事件最初の夜、古代時計室の鉄扉を内部から押し開いていて、ダンネベルグ事件に拭うべからざる影を印しているのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚また名所圖會は廣田村中條の蛭子社に就いて、「里人云、當社は古は頗る大社にして莊嚴なりしかども、天正中回祿にかかりてより今の如く僅の小社となれり。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざゆけ、牡羊四の足をもて蔽ひ跨がる臥床の中に、日の七度やすまざるまに　一三三―一三五ねんごろなるこの意見は、人の言よりも大いなる釘をもて汝の頭の正中に釘付けらるべし　一三六―一三八審判の進路支へられずば。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "我はうるはしきシレーナなり、耳を樂しましむるもの我に滿ちみつるによりて海の正中に水手等を迷はす　一九―二一我わが歌をもてウリッセをその漂泊の路より引けり、およそ我と親しみて後去る者少なし、心にたらはぬところなければ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の樹下に合掌する韋提希夫人あり、婢女一人之に侍立し、樹上に三色の雲かゝり、正中上方一線の霞の下に円日あり、下に海中島ある構図である。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の樹下に合掌する韋提希夫人あり、婢女一人之に侍立し、樹上に三色の雲かゝり、正中上方一線の霞の下に圓日あり、下に海中島ある構圖である。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の樹下に合掌する韋提希夫人あり、婢女一人之に侍立し、樹上に三色の雲かかり、正中上方一線の霞の下に円日あり、下に海中島ある構図である。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせいちゅうんだすが、この人が表向き和明ちゅう子の乳母になっておりますが、実は生みの親だンね、子爵家の縁故のもんで、子爵家の在亡に係る事だすし、現在の生みの子の一大事だすさかい、一生懸命だしてな、私もあれからこっち、あんな激しい気性の女子を見た事がおまへン。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
