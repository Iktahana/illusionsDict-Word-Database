        "examples": {
          "standard": [
            {
              "text": "成都では、伝統的な**川劇**の公演を観覧した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "**川劇**の変臉（へんめん）は、その技術の高さで有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "**川劇**の独特な音楽と踊りに、観客は魅了された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一番はずれの江川劇場は玉乗や手品の興行で人に知られていた。",
              "citation": {
                "source": "浅草むかしばなし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "江川劇場のロクロー中根の「笑ふ弥次喜多」を見て、みや古へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "潰れかゝってる江川劇場で僕の「美人島」の改訂したのをやってるから見に行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
