[
  {
    "uuid": "54856ca0-af3a-5740-b508-029bed9f6eee",
    "entry": "先導者",
    "reading": {
      "primary": "せんどうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし私は「社会の先導者」としての新聞のほんとうの使命を果たすためには、それはむしろやむを得ない当然の事ではないかと思っている。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に背中を見せて歩いていた、偶然の先導者はもう無事に玄関近くまで行っている頃、門と、玄関との中程で、左側のかなめ垣がとぎれている間から、お酌が二人手を引き合って、「こわかったわねえ」と、首を縮めて※き合いながら出て来た。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして国民の先導者らは文化に対する最も野蛮な暴行を犯した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一節に曰く野蛮の先導者暗黒時代の松明持孔子を祭りたる廟と今なほ二、三の考古家によりて愛読せらるる『論語』といふ古書における「子の曰く」を研究したる学校とのありし処は今の○○シヤボン屋のシヤボン庫のあたりなりといふ。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイノはいつもいい土地を發見する先導者であるが、それをよく開墾する努力をしないので、生存競爭上、いつも和人の爲めに追ツ拂はれて、そのあとを占領されてしまつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい女は多くの人々の行止まつた処より更に進んで新らしい道を先導者として行く。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "又辿らうとする先導者にも初めての道である。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ知られざる道の先導者は自己の歩むべき道としてはびこる刺ある茨を切り払つて進まねばならぬ。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も先導者は到底永遠に生き得べきものでない。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて追従者は先導者の力を認めて新らしき足跡を辿つて来る。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初めて先導者を讃美する。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し先導者に新らしかりし道、或は先導者の残せし足跡は開拓しつゝ歩み来し先導者にのみ新らしい道である。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて倒れたる先導者に代る先導者は更にまた悲痛に生きつゝ自己の新らしき道を開拓しつゝ歩いて行く。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしきてふ意義は独り少数の先導者にのみ専有せらるべき言葉である。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先導者は先づ確固たる自信である。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先導者は如何なる場合にも自分の仕事に他人の容喙を許さない。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "追従者はまた先導者の一切に対する批判者の資格を有しない。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "追従者は唯だ先導者に感謝しつゝその足跡をたどるより他はない。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は先導者の前進にならつてやうやくその足跡を辿つて進む事が出来るのみだ。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先導者は先づ何よりも自身の内部の充実を要する。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先導者は開拓しつゝ進む間には世俗的の所謂慰安などは些もない。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に幸福、慰安、同情を求むる人は先導者たる事は出来ない。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先導者たるべき人は確たる自己に活くる強き人でなくてはならぬ。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先導者としての新らしき女の道は畢竟苦しき努力の連続に他ならないのではあるまいか。",
              "citation": {
                "source": "新らしき女の道",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目的は我日本国中に於ける気品の泉源、智徳の模範たらんことを期し、之を実際にしては居家、処世、立国の本旨を明にして、之を口に言うのみに非ず、躬行実践、以て全社会の先導者たらんことを期する者なれば、今日この席の好機会に恰も遺言の如くにして之を諸君に嘱托するものなり。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでに先導者の立場になっていた阿賀妻が、終始先頭をきって進んでいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもときどき先導者の姿を見うしないそうな不安に駆られた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
