        "examples": {
          "standard": [
            {
              "text": "漢の武帝は、西域諸国を管轄するために西域都護府を設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "西域都護府の設置により、中国の影響力は中央アジアにまで及ぶようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "考古学調査によって、かつて西域都護府が置かれていたとされる城址が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かくて和帝はその翌年（西暦九一）に西域都護府を再興して、班超をその都護に任じた。",
              "citation": {
                "source": "東漢の班超",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに任尚は班超の忠告を無視して、餘りに嚴急な取締をなした故、忽ち部下の反抗を招き、續きて西域諸國も離叛いたし、折角班超の圖も、僅か五年の間に破壞せられ、西域都護府も閉鎖さるることとなつた。",
              "citation": {
                "source": "東漢の班超",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
