  {
    "uuid": "ac62b1ec-00c1-5d8c-8d2c-bdbd3c4af72b",
    "entry": "済美",
    "reading": {
      "primary": "せいび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "achieving virtue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○十一月、伊井蓉峰、水野好美らが済美団を起し、浅草公園の吾妻座にて開演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尽力と後援とによって成立したのが、済美団という一座で、伊井蓉峰がこの時初めて舞台の人となったのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "民の心をわが心として親しくその声を聞き、いや、この忠相じしんがすでに民のひとりなのじゃ……王道の済美はここに存すると、まあ忠相はつねから信じておるよ、はっははは、おっと！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上が中村座へ乗り込んで間のない明治二十四年十一月、こちらは浅草の吾妻座へ旗挙げした伊井蓉峰の済美会、よし町芸妓米八の千歳米坡と共に初めての男女合同劇、万事は依田学海翁の指導とあって、狂言も一番目に同翁の作「政党美談淑女操」。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
