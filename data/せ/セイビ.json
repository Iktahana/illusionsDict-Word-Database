[
  {
    "uuid": "393b2445-ac16-583c-84a0-668e8768f842",
    "entry": "整備",
    "reading": {
      "primary": "せいび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
