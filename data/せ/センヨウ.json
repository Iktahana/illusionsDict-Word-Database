    },
    "definitions": [
      {
        "index": 1,
        "gloss": "adenoid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――暫くして、「不可ませんようツ！",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「娘がこれぎり帰って来ませんようだったら、どうしましょう」と、彼女は二、三度も水をくぐったらしい銚子｜縮の袖で眼を拭いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "断念ろ」　と突きやる手に喰い附くばかり、「いけませんよう、いけませんよう。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お筆も紙もありませんよう。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の信用に拘わってはならぬとあって、役人体の者なぞは滅多に近寄らせんように取計ろうておったものじゃが……言語道断……」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "打俯したりし婦人は蒼白き顔をわずかに擡げて、「ええ、もう知りませんよう！",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際あんまりびっくりなさいませんように。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ、不可ませんよう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たものの話でござりますが、これを一目の時、震え上って、すぐに地震、と転倒いたしましたそうで、ここで誰も大地震の前触を、虚言とは思いませんようになりました。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　はい、内をお忘れなさいませんように、私は一生懸命に。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、可愛いお嬢さんが、決して決して河野なんかと御縁組なさいませんよう。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行進パレードに使うてんがい（王さませんようの大きな日がさ）が準備できました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、貴郎、そうしていらっしゃる処ではありません、早く真砂町へおいでなすって、先生が何なら奥様まで、あんな許へは御相談なさいませんように、お頼みなさらなくッちゃ不可ません。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、」　と思込んだ顔を擡げた、主税は瞼を引擦って、元気づいたような……調子ばかりで、一向取留の無い様子、しどろになって、「貴女は、貴女は御心配下さいませんように……先生、」　と更めて、両手を支いて、息を切って、「申訳がございません。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また逢違いになりませんように、それでは御飯を召食りかけた処を、失礼ですが、」「いや、もう済んだです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おつき申してはおります、月夜だし、足許に差支えはございませんようなものの、当館の紋の提灯は、ちょっと土地では幅が利きます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、身体もぞくぞくして、余り見ていたくもなかったそうだが、自分を見懸けて、はじめたものを、他に誰一人いるではなし、今更帰るわけにもなりませんような羽目になったとか言って、懐中の紙入に手を懸けながら、茫乎見ていたと申します。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都　唯今、仰せ聞けられ承りまする内に、条理は弁えず、僧都にも分らぬことのみではござりますが、ただ、黒潮の抜身で囲みました段は、別に忌わしい事ではござりませんように、老人にも、その合点参りましてござります。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして貴方は、美女ヶ原にお心覚えの草があって、其処までお越し遊ばすに、二日も三日もお懸りなさらねばなりませんような気がすると仰有いますが、何時か一度お上り遊ばした事がございますか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてこの生が人丈になって、私の姿が見えませんようになりますと、それを潜って出ます処が、もう花の原でございます。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがために、窶れた男は言渋って、「で、ございますから、どうぞ蝋燭はお点し下さいませんように。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもの事に、ものが逆になりませんよう、やっぱり美津から……」　とちょっと目を合せた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼も夜もどっちで夢を見るのか解りませんような心持で、始終ふらふら致しておりましたが、お薬も戴きましたけれども、復ってからどうという張合がありませんから、弱りますのは体ばかり、日が経ちますと起きてるのが大儀でなりませんので、どこが痛むというでもなく、寝てばかりおりましたのでございますよ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな容子で、一日々々、このごろでは目もあてられませんように弱りまして、ろくろく湯水も通しません。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫が参りましたようですが初手からあまり夫の此頃をよく御存じのような御様子をなるべくなさいませんように、追々お話をほぐして頂き度う御座います。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大津の方からこの頃は私を相手にせんようですから別に招もしません」「招んだって行くな。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、次郎さんがしっかりしたはるさかい、心強いわな」　蝶子はそう言ったあと、「――主人もこの頃はとんと真面目になってな、酒は飲まへんし、食物の道楽もせんようになったし、まあ、夜店の洋食焼きを毎晩食べたがるくらいなもんや」　柳吉のことを嬉しそうに言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといっしょに、一人の神さまは、女神のおうしろへまわって、「どうぞ、もうこれからうちへはおはいりくださいませんように」と申しあげて、そこへしめなわを張りわたしてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
