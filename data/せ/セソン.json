    },
    "definitions": [
      {
        "index": 1,
        "gloss": "World-Honored One (honorific name for Gautama Buddha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南無祇園精舎に在すわが師釈迦牟尼世尊よ！",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神将のＣ　――われ等の教主釈迦牟尼世尊は美しくまします。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊のお姿は見て居るだけで四六時中飽く事が無い。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目※連　――世尊の美しさは女とか男とかいうものの美しさではない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難の器械はそこらにざらにあるが、世尊の器械は専売特許だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊のおん肌は、張り切った生命の一枚板だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "師の世尊がお呼びであるぞ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）阿難　――世尊のみ弟子の中に在って神通第一と呼ばれたる目連どの。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く来るが宜い、世尊のお召だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）舎利弗　――世尊、御機嫌はよろしゅう御座いますか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）※曇弥　――世尊、衆生をお救いになる御心配のほかに、お心を悩ますことも御座りませぬか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺ということがもし出家に許されるのであったなら、ああ……わたくしは、只今すぐにこの恥辱より逃れることが出来ましょうに……恐れ多い申し分では御座いますが、わたくしは世尊が、人間に自殺をお禁じになった事をお恨みに存じます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――尊き世尊よ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧三　――平常世尊があまり阿難を甘くなさるので、増長してこんな事になる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分なら、世尊より証道の御允可の出るのも、久しい先では無いと云って居られました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し差し支えがなかったら、只今のあなたの言葉の内容に就いて、もう少しくわしく話して下さらぬか……実はかねがねあなたの心境の進みに就いて注意をするよう、わたしは世尊から命令を受けて居りました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊は聖なる花嫁であれと仰せられました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は切絵図を調べて、綺麗な比丘尼の家が、本世尊院の境内であったことを知った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊院は今旧境内の過半を失って、西の隅に片寄っている。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだ得ざるを得たりといいいまだ証せざるを証せりと言うのをさえ、世尊はこれを増上慢とて難ぜられた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊諸｜比丘に向いその因縁を説きたまわく、昔｜迦葉仏入滅せるを諸人火葬し、舎利を収め塔を立てた時、居士女極めて渇仰して明鏡を塔の相輪中に繋ぎ、願わくはこの功徳もて後身世々わがある所の室処光明照耀日光のごとく、身に随れて出ん事をと念じた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞿伽離見付けて諸比丘に向い、世尊｜毎も舎利弗は欲少なく足るを知ると讃むるが我らの手に入らぬこの珍物を蓄うるは世尊の言と違うと言った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿那律言う、姉妹よ我等はまさにこの悪業を作すべからず、世尊の制法もまた聴さざる所なりと。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊内心智を揮い、かの者死して非々想天に生まれ、八万四千大劫の後ここに堕落して飛狸身を受け、諸畜生を害しまた婬し、その報いで餓死して今度は地獄に生まるるはずと知ったとある。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥勒世尊、翅頭末城外の金剛荘厳道場竜華菩提樹下で成道する。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、弥勒世尊無量の人と耆闍崛山頂に登り、手ずから山峯を擘く。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊は、『われは人間なるが故に……』かう言つて、そこを高調してゐるが、この言葉には、実に立派な心理の縦断がその背景を成してゐることを私は思はずにはゐられない。",
              "citation": {
                "source": "心理の縦断と横断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて私は世尊が死に面して三七日間にこの法身を説いた形を殊に偉大であると思ふ。",
              "citation": {
                "source": "心理の縦断と横断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから思ふと、世尊が信にその根本を置いたのは、深い心理の縦断を痛感したためであるといふことがわかる。",
              "citation": {
                "source": "心理の縦断と横断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせそんなぢゃ永くは続かない。",
              "citation": {
                "source": "床屋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
