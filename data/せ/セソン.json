[
  {
    "uuid": "fd507f83-5f7f-5abe-a9ff-3518761160a7",
    "entry": "世尊",
    "reading": {
      "primary": "せそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
