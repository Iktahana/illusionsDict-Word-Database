        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "レーニンの居た室、もとの洗面室、そのウムイヴァリニクを掃拭する召使の居た室に夫婦で居た。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下へ出て、すぐ前の洗面室へはいつた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し隔った食堂にいた加十が何の物音も聞かず、皇帝が洗面室を踏み出す時に新しく葉巻を吸いつけられたことで、この間の事情を想像することが出来ます。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は記憶の中で、冬の朝五時にみんなの目をさまさせ、板石敷きの洗面室へ走らせる残酷なベルの響きを聞いた。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面室では生徒も教師もひとしく氷のように冷たい僅かな水で顔を洗ってから、まったく無言の行で服を着なければならなかった。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面室で髭を剃り、軽く歯を磨いた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きなのがあれば、あげますよ」　そんなことを喋りながら、母親は順子を洗面室へ案内した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間へ戻って書斎に入り、そこから洗面室、そして洗濯機などが置いてある作業部屋を、ふたりは見た。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面室の外に立ちどまったヒトミは、なかをミヨコに示した。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその店の洗面室で、歯をみがいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に出て間取りをひととおり見て歩き、洗面室に入って手を洗った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階にはご夫婦の寝室があるのですけれど、そこは使わずに、廊下や納戸そして洗面室や玄関でも撮影しました」「自分の日常の場に、若く美しい裸の女性がひとりいるという光景そのものが、新鮮だったのですね」「そうなのです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面室には化粧品が残っていたし、風呂には石鹸や桶がきちんと置いてあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと屋内に入り、廊下、洗面室、キチン、そして居間などでも水着の夏子を撮った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に入った彼は洗面室で顔と手を洗った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールからまっすぐ奥へ歩き、彼は洗面室に入った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のなかに入り、ヨシオは洗面室で顔と手を洗った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚き口は洗面室のフロアとおなじ高さにあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオは洗面室を出ていき、廊下を歩き玄関のホールをへて、居間に入った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオが出てしばらくしてから、直子も洗面室を出た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　正一君が、元気な声で答えましたので、おとうさんは、そのまま、寝室のいっぽうにあるドアをひらいて、洗面室へはいっていきました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ、はやく洗面室から帰ってこないのだろう？",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　正一君がふしぎに思っていますと、その洗面室の中で、どしんと、もののたおれるような音がして、「ううん。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんが、洗面室でたおれたのかしら。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面室は、寝室から出入りできるばかりで、ほかに出口はありません。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、さきほど洗面室へはいっていった笠原さんは、なにをしているのでしょう。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、笠原さんは、洗面室から出られない、わけがあったのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、洗面室のドアの中からのようです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがこの洗面室へはいったかと思うと、あいつが、うしろから組みついてきたのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
