    "definitions": [
      {
        "index": 1,
        "gloss": "infection through contact",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「接触感染するんだ、ワトソン――接触なんだ、近寄らなければ心配ない。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "主として秋に流行し夕暮れから明け方に罹り、接触感染はしない。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方はコッホと接触感染説者で他方はペッテンコーファーと局地主義者であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "接触感染主義者によると防禦の主な方法は、排泄物の消毒、患者の隔離、公的な交通の監視、良い飲料水の供給であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくその後に当面は優勢となった接触感染学説は疫病流行のすべての現象を説明するものではなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気は本性が接触感染性なので人々は簡単に罹患する。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の接触感染は皮膚のいろいろな場所で起きるが日常の接触で母親から子供に移ることもあった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラカストロの「接触感染」は彼の梅毒の詩から16年後の1546年に発行された。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「接触感染について」の第２の書に次のように書かれている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この接触感染は今でも盛んであるがその性質は最初に出現してから変化したように見えるからである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボイヤーは1751年にこの病気は接触感染ではないと宣言した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "接触感染は無く医師も個人も患者や死人から病気にならなかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者は時期的にも場所的にも広く分散していてシラミによる伝播や接触感染は除外され500人以上の患者の環境を注意深く研究しても全集団に共通な要因たとえばラット、ノミその他の病原体を媒介する動物や昆虫のどれも原因とみなすことはできなかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
