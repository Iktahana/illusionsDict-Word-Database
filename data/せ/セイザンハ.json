        "examples": {
          "standard": [
            {
              "text": "西山派の教義は、善人悪人を問わず念仏を唱えることで極楽往生ができるというものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "京都の光明寺は、浄土宗西山派の総本山として多くの信徒が参拝に訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "西山派の僧侶から、阿弥陀如来の慈悲についての法話を聞く機会を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いよいよ、運動会の日になりますと、村の人たちは、東山派と西山派とに分れて、手手に、旗を押し立てて、学校の運動場へのりこみました。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山派の、今雄さんびいきの人たちは、赤い旗を、西山派の、京一さん組の人たちは、白い旗を造りました。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
