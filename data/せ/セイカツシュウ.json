        "examples": {
          "standard": [
            {
              "text": "長期間空き家になっていたはずなのに、なぜかかすかな生活臭が残っていて不気味だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "換気不足のせいか、玄関を開けた瞬間に古い油と埃が混じったような生活臭が鼻をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この部屋、芳香剤の匂いと生活臭が混ざって、ちょっと変な感じがするね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
