[
  {
    "uuid": "fb288af3-e742-541a-a676-006ef3c92466",
    "entry": "競り上げる",
    "reading": {
      "primary": "せりあげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
