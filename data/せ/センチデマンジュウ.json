    "definitions": [
      {
        "index": 1,
        "gloss": "if you are hungry, where you eat doesn't matter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
