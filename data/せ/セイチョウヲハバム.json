    "definitions": [
      {
        "index": 1,
        "gloss": "to hinder the growth of (e.g. plants, someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
