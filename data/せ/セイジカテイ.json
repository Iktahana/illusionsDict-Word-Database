        "examples": {
          "standard": [
            {
              "text": "「政策が決定されるまでの不透明な政治過程を、もっと国民に分かりやすく公開すべきだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「民意がどのように反映されるのか、意思決定の政治過程を詳しく分析する必要がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼は自身の研究テーマとして、地方自治体における予算編成の政治過程を選んだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "民主政では理念としては、人民の主権や民意の絶対性ということが前提されてはいるが、現実の政治過程では、国民の自己支配とか自治ということを、文字通りに実現することは、技術的にも組織的にもほとんど不可能である。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
