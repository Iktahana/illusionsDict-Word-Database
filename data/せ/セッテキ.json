          "literary": [
            {
              "text": "答　小銃や大砲は直接敵を殺傷する兵器ではない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最終戦争に用いられる直接敵を撃滅する兵器が、みずからかくの如き遠距離に威力を発揮し得ない限り、将来ますます行動力の飛躍的発展を見るべき航空機によることが必要であり、空軍が決戦軍隊として最終戦争に活用されなければならない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどな兵馬が一緒に歩いているとも思えないほど接敵は密やかに行われていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "係りの役人たちもあせってきたのであろう。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもう、星をまちがえたのかなって、あせってきた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは齢不惑に近くなってきたので、あせってきたのかも知れない。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんたら、お若いのに、どうしたの」　そんなことを言われると、いよいよあせってきて、駄目である。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
