  {
    "uuid": "a74587e5-a3ec-5745-9e8c-8f46edbd2cbb",
    "entry": "選手権",
    "reading": {
      "primary": "せんしゅけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
