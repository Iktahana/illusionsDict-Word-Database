[
  {
    "uuid": "4067d226-947b-5ae5-b5d6-07fcd9f8c90c",
    "entry": "切言",
    "reading": {
      "primary": "せつげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
