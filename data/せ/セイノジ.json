          "literary": [
            {
              "text": "歪　不の字と正の字をくツつけて「ゆがむ」といふ字になる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正の字面は『易』の大畜の卦から出て居る。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月を直す二月の文字ふとし　　　　端当　二月になってからついうっかりして正月と書いた、その正の字を二と改めたために、二月という字が太くなったという風にも解せられる。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "但｜書損って消したというよりは、正の字を二に改めたのが太くなったという方が、事柄として纏っているであろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三人が、せいのじゅんにならんで、見物せきにむかっておじぎをしているのです。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
