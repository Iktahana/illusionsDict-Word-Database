        "examples": {
          "standard": [
            {
              "text": "複数形を表す接尾辞を付け忘れると、文法的に誤りと見なされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "動詞を名詞に変える接尾辞は、専門用語の形成において重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この接尾辞は、主に敬意や親愛の情を込める際に用いられます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「児ろ」の「ろ」は親しんでつけた接尾辞で、複数をあらわしてはいない。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞書といえば、当時の私は辞書をひいて語源を探ったり、接頭語や接尾辞の関係を明らかにすることに興味をもっていたから案外言語学への第一歩はこの時代にふみ出していたのかも知れない。",
              "citation": {
                "source": "図書館通い",
                "author": "――私の中学時代――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
