      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "correct",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最早予は人間として正則の進行を計る資格が無くなった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼病を得て処世上正則の進行を妨げらるるに及びては、愈私心的自己の希望を絶対に捨てねばならぬ事になった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに世には、正則なる律格や押韻やの形式をもっていながら、本質上に於て詩と称し得ないような文学がある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の文字は、確にだれがみても異存のない、文字通りの正則な韻文であるにかかわらず、本質上から詩と呼ぶことができないのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　「大体に於ける法則」ということは、10の中の８が正則で、２が変則であるという如き、数量の上の計算でない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに不思議なことは、古今すべての詩の約束が、この偶然の場合を法則とし、音楽に於ける韻律の形式を、そのまま正則に言語に移して、所謂「韻文」を成形していることである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば吾人の国語は、正則に韻律的であるほど退屈であり、却ってより不規則になり、より散文的になるほど変化に富み、音律上の効果を高めてくるから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は正則と変則とに別れて居て、正則の方は一般の普通学をやり、変則の方では英語を重にやった。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃変則の方には今度京都の文科大学の学長になった狩野だの、岡田良平なども居って、僕は正則の方に居たのだが、柳谷卯三郎、中川小十郎なども一緒だった。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "で大学予備門（今の高等学校）へ入るには変則の方だと英語を余計やって居たから容易に入れたけれど、正則の方では英語をやらなかったから卒業して後更に英語を勉強しなければ予備門へは入れなかったのである。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の中学というのは、今の完備した中学などとは全然異っていて、その制度も正則と、変則との二つに分れていたのである。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "正則というのは日本語｜許りで、普通学の総てを教授されたものであるが、その代り英語は更にやらなかった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、私は何れに居たかと云えば、此の正則の方であったから、英語は些しも習わなかったのである。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、親にも私が学校を退きたいという考が解ったのだろう、間もなく正則の方は退くことになったというわけである。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　既に中学が前いう如く、正則、変則の二科に分れて居り、正則の方を修めた者には更に語学の力がないから、予備門の試験に応じられない。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は正則の方を廃してから、暫く、約一年｜許りも麹町の二松学舎に通って、漢学許り専門に習っていたが、英語の必要――英語を修めなければ静止していられぬという必要が、日一日と迫って来た。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、義雄の心を頻りに競爭的に刺戟するのは、晝家大野正則の努力と成功とである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "元康の士｜筧正則等が之に乗じて進み、門を閉ざす暇を与えずに渡り合い、松平義忠の士、左右田正綱一番乗りをし、ついに火を放って焼くことが出来た。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この職充は平常士を好んで、嘗つて加藤清正、福島正則等、国を除かれ家を断たれた時、その浪士数十人を引取った程である。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石の福島正則みたいな向う見ずの大将も、一時、退却したくらいだ。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島正則の家や、加藤清正の家は、この法度に触れて断絶した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方が正則の授業よりは遥に面白かつたのみならず、実際有益でもあつたやうに思はれる。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は正則と云ふこと、正しいと云ふことを認めて置きたいのであります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "Tolerance と云ふことを使はれる場合は多くは何か正則なものが先きへ認めてある。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正則のものがなくて Tolerance と云ふことはありませぬ。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の弖爾乎波の許容になりましたときなどは、まだ元の語格を正則にしてある。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「得しむ」は正則である、「得せしむ」は許容すると云ふのでありますから、趣意は能く分つて居ります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の假名遣を正則にして發音的に新に作る假名遣を許容するなら宜しい。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
