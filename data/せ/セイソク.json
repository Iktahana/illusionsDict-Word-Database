[
  {
    "uuid": "fcf5b657-b308-50f1-8adb-26975dd7f1df",
    "entry": "正則",
    "reading": {
      "primary": "せいそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
