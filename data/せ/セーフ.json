        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "セーフチーバルヴが、慌てて呻り出した。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "……シイ――イイ……という音がどこからともなく聞こえるのは、セーフチーバルブの唇を洩るスチームの音であろう……それとも私の耳の底の鳴る音か……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝敗真に時の運とせば、吾人は、トルストイを有し、ゴルキイを有し、アレキセーフを有し、ウヰツテを有する戦敗国の文明に対して何等｜後へに瞠若たるの点なきや否や。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セーフティーバァルプ」（安全弁）という綽名がついていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーフチィヴァイヴァルヴが、吹きそうになって来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に合わぬと知ったので、最後の手段として円タクを割増金つきで急がせることにより、ようやく時刻ぎりぎりに滑りこんで、セーフと相成った。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くことにしてかえりに、大学前の本屋へよって、セーフリナ、アンナ・アフマトワ、ベラ・イムベル、マリエッタ・シャギニャーン。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、モヤ、本をよんでくれ、（セーフリナの伝と、唯物史観）自分編物をして、一方の方のスウェターの袖をあんだ。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、エリセーフへよって、ビクトリア・ゲンリホブナの見舞、夢の話をきいた。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーフリナの欧州旅行記あり。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃エリセーフの店までがらがらだ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稲田セーフになる。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当選すると、学校からセーフチーコンミチーという文字をきざんだ星形の徽章をくれる。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸のセーフチーコンミチーが物をいうのである。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も二十年前に、パリのサツマ会館の管理者としてのエリセーフ氏を知っていたので、今度の渡米には、久しぶりの邂逅を楽しみにしていた一人である。",
              "citation": {
                "source": "エリセーフ氏",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてエリセーフ氏を真っ先に訪ねた。",
              "citation": {
                "source": "エリセーフ氏",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリセーフ氏も非常に喜んで、有名なボストンの美術館を案内したり、オルコット夫人の家の近くにある料理店で、劒魚を御馳走してくれたり、大いに歓待してくれた。",
              "citation": {
                "source": "エリセーフ氏",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリセーフ氏は、東大の卒業論文に『芭蕉の研究』を書き、菊五郎について踊りも習ったことがあるという先生である。",
              "citation": {
                "source": "エリセーフ氏",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年エリセーフ君が、振袖を着、かつらをかぶった舞台姿の写真が、壁にかかっているのだから、フジヤマや日光の話をしたわけではない。",
              "citation": {
                "source": "エリセーフ氏",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしエリセーフ氏の真意は、『三四郎』時代の日本だけにあるのではなさそうであった。",
              "citation": {
                "source": "エリセーフ氏",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは現在ハーバート大学で、極東美術の主任教授をしている、エリセーフ氏の話である。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリセーフ氏は、生まれはロシア人であるが、若い時に日本へ来て、主な教育は東京で受けた人である。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も二十年前に、巴里でエリセーフ氏に大分厄介になったことがある。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の夏、ボストンで、二十年ぶりに、このエリセーフ氏に会った。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはエリセーフ氏が、東大の学生時代に、北海道へ旅行した時の話である。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の景色は広々としているといっても、シベリアを知っているエリセーフ氏には、そう珍しいことでもなかったであろう。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごとごととのろい北海道の三等車の中で、紺絣のエリセーフ君は、夢中になって、『三四郎』に読みふけっていた。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、「もしもし」とエリセーフ君に話しかけた。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリセーフ氏には、この言葉がよほど気に入ったものとみえて、三十年後の今日、この話をするエリセーフ氏の語調の中には、当時の日本をしのび、自分の青春をなつかしむ情が、脈々として流れていた。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
