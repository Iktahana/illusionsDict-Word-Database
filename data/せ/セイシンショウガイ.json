        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この社会的不安が肉体にあらわす精神障害を、一つの抑圧されたコムプレックスとしてフロイドは解明しようとした。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神障害、身体障害、人種／民族差別に関係する放送できない用語が含まれます。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神障害、身体障害、人種／民族差別に関係する放送できない用語があります。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神障害に関係する放送できない用語があります。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神障害、疾病、身体障害、人種／民族差別に関係する放送できない用語が含まれます。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体・精神障害に関係する放送できない用語が含まれます。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカは精神障害者の治療で他の国に遅れを取らなかった。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体・精神障害に関係する放送できない用語があります。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に彼はデモクリトスの精神障害を治した。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神障害の場合には、これに伴う不眠の治療に麻薬を使うと良くなることを知っていた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "デーモンが取り付くという同じ考えは精神障害者の非人間的な処理に導き、この点で教会の行為をムーア人（イスラム教徒）のより賢く人間的な行為と比べると教会は恥じなければならない。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に痙攣および精神障害は、顔の変形および病人の全個性の変化を伴い、変化した人の幻覚を生ずる。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "バビロン人によると心臓の魔術による精神障害。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教的儀式、迷信、習慣、呪文、は、特に助産婦の領域および子供の介護、およびさらに精神障害者の治療、の合理的な治療と関係して、変化しないで続いた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃一時重い抑鬱的精神障害に陥り、入院、治療を受ける。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は特に精神障害に注目していた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "病理解剖学的な説明はまだ不可能だったからであり実際のところ多くの精神障害について今日でも不可能である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "1793年にイタリアの医師キアルジは精神障害で死亡した62人の病理解剖の報告を含んでいる本をフィレンツェで発行した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一般に言って精神障害に罹っているあいだに死亡した患者の死体解剖では脳にほとんど変化は無く従って記載的な方法によって精神障害の症状学をある程度整頓することは遠い将来のことであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの領域における彼の貢献たぶん生涯における最も重要な成果は、精神障害者の不幸な運命を楽にしたことであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "大革命が始まったときに精神障害者にも自由がもたらされた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は個人的に国民公会に行き鎖を除くことを代議士に納得させその後で精神障害者は普通の病人と同じように見做され取り扱われるようになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴッホの生活記録を見ないでも自画像は精神障害の充分な証拠であろう（図35左）。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学で彼は精神障害児童の心理指導を勉強している。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
