        "examples": {
          "standard": [
            {
              "text": "望遠鏡の接眼鏡を交換して、月のクレーターをもっと詳しく観察しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "接眼鏡にまつげが触れると、視界がぼやけてしまうので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高性能な接眼鏡を使うと、星の色がより鮮やかに見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "接眼鏡は左手によって彼の目に当てられた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暇に、僕は何気なく、先刻から速水氏が覗きこんでいた器械の前に立ち、そこに出ている接眼鏡らしいものの上に眼を持っていった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
