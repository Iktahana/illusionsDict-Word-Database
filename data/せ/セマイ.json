[
  {
    "uuid": "ac51b323-b5a2-5acc-93f4-194dae7399ae",
    "entry": "狭い",
    "reading": {
      "primary": "せまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
