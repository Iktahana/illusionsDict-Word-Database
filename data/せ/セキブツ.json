    "definitions": [
      {
        "index": 1,
        "gloss": "stone Buddhist image",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
