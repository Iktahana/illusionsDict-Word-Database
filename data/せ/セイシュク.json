[
  {
    "uuid": "c5a80619-7946-5070-b26a-c03739aa86df",
    "entry": "静粛",
    "reading": {
      "primary": "せいしゅく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
