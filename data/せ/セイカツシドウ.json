        "examples": {
          "standard": [
            {
              "text": "放課後、生活指導の先生に呼び出され、茶髪にした理由について厳しく追及された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学校側は、SNSでのトラブルを防ぐために生徒への生活指導を徹底することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「生活指導って言われると、なんだか背筋が伸びる思いがするよ」と卒業生が笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二月十七日の『都』の夕刊には、国民生活指導部長の談話に対する学生層からの様々の抗議がのせられた。",
              "citation": {
                "source": "「健やかさ」とは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また文化部だけでなく生活指導部、青年部なども、さういふ役割を十分果し得るのぢやないか。",
              "citation": {
                "source": "既往文化と新文化",
                "author": "――某氏との談話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "翼賛会生活指導部と協力して、これは当文化部でも専門家を動員して既に研究に着手してゐるのです。",
              "citation": {
                "source": "文化の新体制",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人には、一般の塾生活指導者にありがちな自己｜陶酔ということが微塵もなかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
