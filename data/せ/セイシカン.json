          "literary": [
            {
              "text": "一種の生死観によつて、身命を潔く擲つことができ、悲みに堪へる訓練ができてゐる。",
              "citation": {
                "source": "風俗の非道徳性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、日本人の生死観がよく訣る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴先生の生死観が、何で鍛えられたかということだけが問題である。",
              "citation": {
                "source": "露伴先生と神仙道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも露伴の生死観は、『仙書参同契』中に詳しく述べられている丹道の極意に通じているような気がするからである。",
              "citation": {
                "source": "露伴先生と神仙道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
