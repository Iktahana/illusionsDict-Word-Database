          "literary": [
            {
              "text": "（時計を出して見ようとして、なくなっているのを発見）時計もセブンか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "セブンどころじゃないイレブンくらいだろう。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "セブンなんだけれど、ということである。",
              "citation": {
                "source": "まちがい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ラッキーセブンだ」「ぼくにラッキーはない、だめだ」「ばかいえ、きみはたしかに勝てるのに勝たずにいるんだ」「どうして？",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
