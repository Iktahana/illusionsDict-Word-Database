        "examples": {
          "standard": [
            {
              "text": "トランプの「セブンブリッジ」で、最後にダイヤのセブンを引いて逆転勝ちした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幸運の数字であるセブンが並んだスロットに、思わず歓声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画のクライマックスで、セブンの文字が書かれた謎の箱が届けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（時計を出して見ようとして、なくなっているのを発見）時計もセブンか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "セブンどころじゃないイレブンくらいだろう。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "セブンなんだけれど、ということである。",
              "citation": {
                "source": "まちがい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ラッキーセブンだ」「ぼくにラッキーはない、だめだ」「ばかいえ、きみはたしかに勝てるのに勝たずにいるんだ」「どうして？",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
