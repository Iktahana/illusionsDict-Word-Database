        "examples": {
          "standard": [
            {
              "text": "腕の良い整形外科医によって、火傷の痕がきれいに修復された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は信頼できる整形外科医を見つけるために、複数のカウンセリングを受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美容医療の分野では、経験豊富な整形外科医の需要が非常に高い。",
              "citation": {
                "source": "幻辭AI",
