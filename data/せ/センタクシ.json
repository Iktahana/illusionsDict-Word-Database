          "literary": [
            {
              "text": "河畔の緑草の上で、紅白のあらい竪縞を着た女のせんたくしているのも美しい色彩であった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ、けっこうなお聖母さまの日だ、おちいさいキリストさまの下着の、おせんたくして、ほしなすった日だ。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ、きょうは聖母さまの日だろう、聖母さまが幼子キリストさまの肌着をせんたくして、かわかそうという日だからね。",
              "citation": {
                "source": "ブレーメンの音楽師",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんたくしなくちゃ。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
