    },
    "definitions": [
      {
        "index": 1,
        "gloss": "selection and commentary (on literary texts or poems)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうして直ぐ毎月自分の出してゐる歌の雜誌の編輯、他の二三雜誌の新年號への原稿書き、溜りに溜つてゐる數種新聞投書歌の選評、さうした爲事にとりかゝらねばならなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "『赤い鳥』は子供たちからの作品を求め、鈴木が綴方を、北原白秋が詩を、山本鼎が絵を担当して選び、選評を添えて誌面で紹介していきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時の選評は今でも大事に仕舞つてあるけれど……それはＳ、Ｓ―だけのお蔭とも言へないかも知れないけれど、私のより外に取るのがないと言ふので、わざ／＼点を殖してくれたりしたことを、後で社の人に聞いて、何のくらゐ感謝したものだか。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして直ぐ毎月自分の出している歌の雑誌の編輯、他の二三雑誌の新年号への原稿書き、溜りに溜っている数種新聞投書歌の選評、そうした為事にとりかからねばならなかった。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "『文芸』の当選作「運・不運」（池田源尚氏）を読み、選評速記を熟読して、深くその感に打たれた。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『文芸』の選評の間で、生態描写のことがちょっとふれられているが、系譜的な作品というものと、過去へさかのぼった生態描写とは文学の質において異うという点が、深めて考えられていいと思った。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先だって冨山房百科文庫で森槐南の『唐詩選評釈』を買ってきて読み、昔を思い出して懐しかった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九月六日）百十八○けふ或る雑誌を見て居たらば、新刊書籍のうちに、鳴雪翁の選評にかかる俳句選といふものの抜萃が出て居つた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは奉納の行燈に立ち寄りて俗句に感ぜし事もあり、あるいは月並の巻を見て宗匠輩の選評を信仰せし事もあり。",
              "citation": {
                "source": "俳句の初歩",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川賞（第十八回）選評岸田國士「棉花記」、「和紙」、「伝染病院」、「淡墨」、「道」の五篇のうちから、私は「和紙」を推すことにした。",
              "citation": {
                "source": "芥川賞（第十八回）選評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川賞（第二十回）選評岸田國士　私の手許に送られて来た作品は、いづれもなかなか佳いものであつた。",
              "citation": {
                "source": "芥川賞（第二十回）選評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふわけで、今度だけは、責任をもつて選評を書く資格が私にはないのである。",
              "citation": {
                "source": "棄権",
                "author": "――芥川賞（第二十三回）選後評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "清潔な文章を買ふ――芥川賞（第二十一回）選評――岸田國士　最後に残つた候補作家七人のうちから一人を撰ぶことは困難であつた。",
              "citation": {
                "source": "清潔な文章を買ふ",
                "author": "――芥川賞（第二十一回）選評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日選評者一同を東仲通鳥屋末広に招飲す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "余も選評者中の一人なれば招れて徃く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "松莚子宅にて玄文社懸賞脚本の選評をなす。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "清末の鴻儒兪曲園が日本人の詩賦を選評した『東瀛詩選』にも、この事を賛して「東国人詩集毎集必有数序。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野浩二と青野の選評を見ても面白く、青野は鑑賞に沈湎し、宇野は文学の中から却って評論的であります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌の選評も一段落となって、皿に盛った食事が出た。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その老人の一人が私の家へ来て、和歌の選評をしてくれという。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に和歌の選評を頼みに来た人も、教養のある立派な人だった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
