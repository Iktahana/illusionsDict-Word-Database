[
  {
    "uuid": "eb98e610-b51a-5d8f-95aa-2d27a781eff5",
    "entry": "選評",
    "reading": {
      "primary": "せんぴょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
