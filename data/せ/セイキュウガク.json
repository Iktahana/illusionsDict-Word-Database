        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今月のクレジットカードの請求額が予想より高くて、慌てて明細を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "請求書に記載された請求額が間違っていたので、すぐに修正を依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工事費の請求額には、人件費だけでなく材料費も含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "常にコンピューター室にたむろしては、使用時間に対応したレンタル業者の請求額をうなぎ登りに増加させるウォズニアックは、すぐに学校側に目を付けられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が請求額を全部支払いました、ほらこれです。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も過ちは避けられないし、この手紙は請求額の四倍の値打があるんだから」　しばらくの間、その請求額にみんな仰天だ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
