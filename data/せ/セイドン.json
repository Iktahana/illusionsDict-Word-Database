    "definitions": [
      {
        "index": 1,
        "gloss": "fine weather and cloudy weather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
