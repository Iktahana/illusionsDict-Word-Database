[
  {
    "uuid": "947ab70f-6400-5b59-ab7c-1b164841aebe",
    "entry": "背にする",
    "reading": {
      "primary": "せにする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-サ変-する"
      ],
      "ctype": null,
