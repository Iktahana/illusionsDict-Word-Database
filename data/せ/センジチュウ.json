[
  {
    "uuid": "3243f925-9d29-57c0-9fa4-51762b482dc1",
    "entry": "戦時中",
    "reading": {
      "primary": "せんじちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
