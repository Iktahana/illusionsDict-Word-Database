[
  {
    "uuid": "f906c9dc-6915-5522-928b-41d0bf8fec7a",
    "entry": "石槨",
    "reading": {
      "primary": "せっかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
