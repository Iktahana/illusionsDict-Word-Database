          "literary": [
            {
              "text": "ずっとセクシー」　慶一は素早くドアをしめる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタジオアルタの巨大な金色のスクリーンにはレオタードを着た外人のモデルがジャズダンスをリズミカルに踊りながら自分のセクシーな肉体を誇示している。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識されてしまったら、セクシーな部分が強くなりすぎたりするでしょうね」「さて、そのふたりは、知りあってから一年間、愛しあってきた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにそうなのですけど、美代子のほうがはるかに良くて、私はいつもうらやましく思ってました」「たいへんきれいだとは、ものすごくセクシーだということですか」　日比谷は質問をはさんでみた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かで端正で、どんなときも絶対に崩れませんから、なおさらセクシーなのです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のセクシーさは目につきやすいものではなくて、秘めたものなのです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩はいかにセクシーか１　島村冬彦が伊東夏子を初めて写真に撮ったのは、彼が高校生になってひと月後、五月の最初の日曜日の午後だった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステージ上のローリング・ストーンズがいかに邪悪にみえようと反現実的であろうと、またセクシーであろうと、あたらしいものはなにも生まれてこないのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
