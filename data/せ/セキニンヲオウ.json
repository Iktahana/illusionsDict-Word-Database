[
  {
    "uuid": "054bac61-fadd-5532-a53d-f7563b40f795",
    "entry": "責任を負う",
    "reading": {
      "primary": "せきにんをおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
