    "definitions": [
      {
        "index": 1,
        "gloss": "former years",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なお「蕪村論」は、先年著者の個人雑誌『生理』に連載して、一部読者の好評を博したものであり、附録「芭蕉私見」は、他の雑誌に掲載したものに、多少別に筆を加えたものである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは先年亡くなった左右田喜一郎博士であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はめいめい先年の絶大な恩を受けたこと、及びこの度の戦勝の祝をくどくどしく申し述べた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは普通の積雲とは全くちがって、先年桜島大噴火の際の噴雲を写真で見るのと同じように典型的のいわゆるコーリフラワー状のものであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒ヶ岳は先年の噴火の時に浴びた灰と軽石で新しく化粧されて、触ったらまだ熱そうに見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安井氏の「風吹く湖畔」を見ると日本の夏に特有な妙に仇白く空虚なしかし強烈な白光を想い出させられるが、しかしそういう点ではむしろ先年の「海岸風景」の方から一層強い印象を受けたような気がした。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年ドイチュランド号が二十三浬一五の速力を得たに比較して少々劣るようであるが、これは途中で霧に逢うたためだとの事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに先年来は酸水素吹管で水晶の小片を熔かして細い棒とし、これを沢山に熔かし合せて管やフラスコを作る事が出来るようになった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年、靜岡に蒲原有明氏を訪ねた時、有明氏は茶の湯や生花の趣味を愛して居られ、且つ僕にかう語られた。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことになるのだつたら、先年伊豆に旅行した時の歸りに、是非沼津へ寄ればよかつたのである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年の、川崎造船所のストライキに対して、歩兵第三十九聯隊が出動した。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年友人Ｍ君が詳しく各樹の遅速を調べて記録したことがあって、その結果を見せてもらったことがある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年、犬養内閣が成立したとおなじ日に一羽のローラーカナリヤが迷い込んで来たのを捕えて飼っているうち、ある朝ちょっとの不注意で逃がしてしまった。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年｜塩原の山中を歩いていた時に、偶然にこの涼しさの成立条件を発見した。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年胃をわずらった時に医者から煙草を止めた方がいいと云われた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先年｜筑波山の北側の柿岡の盆地へ行った時にかの地には珍しくない「地鳴り」の現象を数回体験した。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象については先年わが国のある学術雑誌で気象学上から論じた人があって、その所説によると旋風の中では気圧がはなはだしく低下するために皮膚が裂けるのであろうと説明してあったように記憶するが、この説は物理学者には少しふに落ちない。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについてはどうか私が先年「思想」に出した「比較言語学における統計的研究法の可能性について」を参照されたい。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれであったか先年ドイツの雑誌で単晶の針金のすべり面の数が針金の弾性的高周波振動できまるという説を出したことがあったようであったが、これもあまりふに落ちない説であった。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平田理学士は、先年、某停車場の切符売り場の窓口に立ち寄る人の数に関する統計的調査に普通の統計理論を応用して、それが相当よく当てはまる事を確かめた。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばまた、銀座松屋の南入り口をはいるといつでも感じられるある不思議なにおいは、どういうものか先年アンナ・パヴロワの舞踊を見に行ったその一夕の帝劇の観客席の一隅に自分の追想を誘うのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれよりもこの人に感心したのは氏が先年Ｈ子夫人と同伴で洋行したときに、パリ在住の通信員によって某紙上に報ぜられたこの夫妻の行動に関する記事を読んだときである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年なくなったが、じみな人であった。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親友の黒田が先年まで下宿していた荒物屋の前を通った時、二階の欄干に青い汚れた毛布が干してあって、障子の少し開いた中に皺くちゃに吊した袴が見えていた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年水温を測る時の目じるしに、池の中のところどころに立てておいた竹ざおが雪の薄くつもった氷の上に頭を出している場合に、さおの北側へ妙な扇形の模様ができる事があった。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の芥川君には先年｜雑司が谷の墓地で見た時のような心弱さといったようなものは見えなかった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が先年、東京における冬季の日々の気圧を曲線にして見たときに著しい七日ぐらいの週期を見たことがある。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう大規模の大地震に比べると先年の関東地震などはむしろ局部的なものとも言える。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年｜小田原の浜べで大波の日にヘルムホルツの共鳴器を耳に当て波音の分析を試みたことがあったが、かなりピッチの高い共鳴器で聞くとチリチリチリといったように一秒間に十回二十回ぐらいの割合で断続する轢音が聞こえる、それがいくらかこの蝗群の羽音に似通っているのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか思うたが、取次いだ小使どんが、やや暫時あって引返して、お目に掛ろう言わるる、通れ、とあって、廊下伝い方角を教わって、そしてそれから歩行き出したがね、――私は先年この岐阜県下ですわ、飛騨のある山家｜辺僻に勤務した事があって、深い谷陰、高い崖に煙草の密造をする奴を検べに行ったのじゃね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
