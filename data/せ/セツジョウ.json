[
  {
    "uuid": "00bbcd20-0644-50f2-bcfe-68ac6de5e249",
    "entry": "切情",
    "reading": {
      "primary": "せつじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ardent love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしそこに母親である自分の愛も挟める余地のあるものでさえあったら……だが二人の様子を見ると、そういう母親の気苦労を知らない若い男女は、年老いた寡婦の唯一の慰めを察して、二人の切情をも時に多少は控えても、自分の存在を中間に挟めて呉れるであろうか。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしやわざくれ、作品のモチーフとなる切情に殉ぜんかなと）　からし菜、細根大根、花菜漬、こういった旬の青味のお漬物でご飯を勧められても、わたくしは、ほんの一口しか食べられなかった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそこに母親である自分の愛も挟める余地のあるものでさへあつたら……だが二人の様子を見ると、さういふ母親の気苦労を知らない若い男女は、年老いた寡婦の唯一の慰めを察して、二人の切情をも時に多少は控へても、自分の存在を中間に挟めて呉れるであらうか。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもわたしは敬虔と、切情と、涙と、訴えとだけで押し切った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先代の延寿は道楽といふ道楽を仕尽して、とどの果には舌切情死までしようとした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺を建てること、法事のことなどにつきての老師の意見は多少知って居るが、今度は国師号のことを附け加えて愚見を吐いたので、「予が現に報いんとする切情を知らぬ、この馬鹿奴」とでも思われて、沈黙を守られたかと、まあ今はそう考えて居る。",
              "citation": {
                "source": "釈宗演師を語る",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
