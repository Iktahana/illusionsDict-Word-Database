        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あとには先任将校が続いてのぼってくる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ柳下機の消息はないか」　と、頤紐をしっかりかけた水原艦長が、心配そうに先任将校をふりかえった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "直二と先任将校の乗っている艦上機は、予定通り、近所を航進中の、駆逐艦｜山風に救い上げられた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村君に児玉君もな」　望月大尉は、やはりこの班員で、先任将校であった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "発令所には、さっきまで司令塔にいた艦長と先任将校とが、いつの間にか儼然たる姿を現しています。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ向うは気がついていないようですね」　先任将校は双眼鏡から眼を離して、いいました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しっかりしろ、傷は浅い」と先任将校。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生意気な汽船だ」　先任将校が耐えかねたように、口の中で怒鳴りました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよ出あいますかな」　近づいた先任将校が嬉しそうにいいました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
