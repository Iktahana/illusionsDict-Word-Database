[
  {
    "uuid": "6c641b4a-e4f0-5422-8454-d9de3d9c0569",
    "entry": "遷化",
    "reading": {
      "primary": "せんげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
