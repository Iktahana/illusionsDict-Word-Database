[
  {
    "uuid": "c2a91e17-b96e-5621-94ca-9c36595e68a5",
    "entry": "生物",
    "reading": {
      "primary": "せいぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
