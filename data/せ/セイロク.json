    "definitions": [
      {
        "index": 1,
        "gloss": "western foot (of a mountain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
