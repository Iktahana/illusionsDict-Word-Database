          "standard": [
            {
              "text": "この検査では、知能の発達度合いと生活年齢を比較して発達の遅れを判定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は実年齢（生活年齢）よりもずっと落ち着いて見え、周囲から頼りにされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「生活年齢が同じでも、体力や精神力には大きな個人差があるものだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "数え年の十三歳（生活年齢は十二年と五カ月）で尋常四年生の彼は原級｜留置を二度も喰った落第坊主だった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
