    "definitions": [
      {
        "index": 1,
        "gloss": "vocal music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああいう歌でもちゃんとした声楽家の歌ったのならきっとおもしろいだろうと思われるが、普通のレコードのように妙な癖のあるませた子供の唱歌は私にはどうも聞き苦しい。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌姫はほんとうにすぐれた声楽家で、わたしはヨーロッパの大都会でこの人がほめそやされているのを見たことがあります。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優として舞台に立つこともかなえられず、持って生れた美声を頼りに志望した声楽家にもなることができないままに、いくどか絶望のどん底におちいった。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――リュシエンヌよ、私は或る声楽家を知っていた。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もこの声楽家は、許嫁との死別の悲しみに堪えずしてその後間もなく死んでしまったが、許嫁の妹は、世間の掟に従って、忌の果てには、心置きなく喪服を脱いだのであった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その僕が声楽家のあなたと道連れになるなんて……。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その人は京都に住んでいる声楽家だというだけで、まるで見当がつかなかった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……くわつとふりそそぐ日光、冷たい風、春と夏との二声楽、……緑と金……四十三年五月　　五月新しい烏竜茶と日光、渋味もつた紅さ、湧きたつ吐息……さうして見よ、牛乳にまみれた喫茶店の猫を、その猫が悩ましい白い毛をすりつける女の膝の弾力。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三年三月　　金と青との金と青との愁夜曲、春と夏との二声楽、わかい東京に江戸の唄、陰影と光のわがこころ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面から見れば音階音で以て声楽と合わせる伴奏楽器は舞台表現上極めて低級な役割りしかつとめ得ない……同時に能の楽器は現在の四種類以上に増加する必要は絶対にないという事が、能を見るたんびに直感される。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分より更に活溌な連れの男の胴衣にすがりついて、声楽ではその仲間の奮闘的の努力にも遙かにまさって、力のある肺の底から低音で牡牛の吼えるような声を出しながら。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以後、歌劇女優、女流声楽家等いう各種の職業婦人？",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今｜市俄古に住んでゐる、米国の首歌妓シユウマン・ハインク女史は、無論声楽家としても聞えてゐるが、それよりも子供のたんと有る音楽家として名が通つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀女８・８（夕）　女流声楽家三浦｜環と今は故人の千葉｜秀浦との関係は一頻り喧しい取沙汰になつたので、世間には今だにそれを覚えてゐる人も鮮くあるまい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流声楽家三浦環女史が倫敦に居る頃、女史の周囲には医者や、銀行員や、外交官や、大学の助教授やが油虫のやうに寄つて集つて、御機嫌取りに色々の進物を女史の足もとに持ち運んで来たものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリアは、はじめ声楽家になって、自分がこの世に生れて来たということの真価を発揮しようと思い立った。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽といっても第一位が声楽家たちであり、楽器の演奏家たちがそれにつづいているのであって、ヨーロッパの音楽史はあれほど幾多の卓抜なプリマドンナの名を記しながら、婦人の作曲家というものはほとんど一人もその頁のなかに止めていない。",
              "citation": {
                "source": "婦人の文化的な創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の才能が、一番歴史的に発揮されている音楽の領分においてさえ、その芸術貢献の道が、主として自然発生の女性という性の声楽の美と、その美にふさわしい一箇の喉笛にかかっているというのは、文化の問題として何を語っていることであろうか。",
              "citation": {
                "source": "婦人の文化的な創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、我々の前に、パリに住んでいる声楽家でありピアニストであり、作家ルイ・ヴィアルドオの妻であるヴィアルドオ夫人の存在が浮び上って来る。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽、特に女性がこれまで偉大な足跡をのこして来た声楽の場合では、その自然的な条件が文学的創作の場合と大分違う。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいソプラノの出る、または味のあるアルトの出るよい女性の喉を持ってさえおれば、声楽家として第一の必須条件は生理的に具わっている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が見出そうと欲したのは五年目に見るソヴェトに対するゴーリキイの失望と、偉大な声楽家シャリアピンが金の儲からぬロシアを捨てて、しかも古いロシアの嘆きの唱を歌いつつ稼いでいるように、ソヴェトを見限るであろうということであった。",
              "citation": {
                "source": "マクシム・ゴーリキイによって描かれた婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだっけかって、かあさん、あんなに伊太利声楽の隠れたる天才って書いてあったじゃあないの」「――ねえ、あなた――」　いねは、百代の方はいい加減にして良人に云った。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽気な声楽家のラオロはこんなに何も持っていないのだろうか。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇の面には、小山内薫時代からの山本安英などのほかに、原泉子をはじめ、数多い女優が現れ、声楽家関鑑子は、演出家小野宮吉と結婚して、次第に人間的深みを加えつつあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの手元にある最近の婦人録に、声楽家奥住龍子女史の略伝がこんなふうにのっている。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本音楽学院本科声楽部卒業。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い声の時は声楽にきく丸味と落つきがあってよかったが甲声が悪い。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
