[
  {
    "uuid": "57428e63-14c3-5172-bf26-9ef0aec35cf1",
    "entry": "専門外",
    "reading": {
      "primary": "せんもんがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
