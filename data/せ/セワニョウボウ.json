    "definitions": [
      {
        "index": 1,
        "gloss": "perfectly dedicated wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
