    "definitions": [
      {
        "index": 1,
        "gloss": "world-class",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これも世界に誇るべき名山だと思う。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のドイツで一番高いゴチックの寺塔のあるという外には格別世界に誇るべき何物をも有たないらしいこの市名は偶然にこの科学者の出現と結び付けられる事になった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にはもう世界に誇るものがなんにも無くなったけれど、でも、あたしのお母さんは、あたしのお母さんだけは。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "全世界に誇るべき東洋の文豪、魯迅先生の逝去せられたのは、昭和十一年の秋であるが、それに先立つこと約十年、先生四十六歳の昭和元年に、「藤野先生」という小品文を発表せられた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、それが、精鋭を世界に誇る日本の警察力に依ったのであっても、こんなに、みじめにならずにすんだであろう。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちは、構造や性能などがあらまし分かれば、あとは勇敢無比を世界に誇るわが海軍の爆撃機や軍艦でもって、とにかくぶっ潰せるものと思っていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは例の世界に誇る巨人爆撃機だな」　と、帆村は早くもそれと察した。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨人爆撃機なら、時速は五百キロで、航続距離は二万キロ、爆薬は二十｜噸積めるという世界に誇るべき優秀機だった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりＳ国が世界に誇る超重爆撃機をもって攻めてきたのだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともまず最初に団結の力を認め、これを実行に移したものが資本家であったということは日本映画界が世界に誇るに足る珍記録であり、チャップリンといえどもとうてい企図し得ないすばらしいギャグではないか。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの王冠――瑞典の国章はどこにでも見受ける――が陽にきらめいている水辺高層の楼閣――ストックホルムが世界に誇る新築の市役所である。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に誇る日本の古典文学といえば、それがたった一つしかないようにいつもとり出されている源氏物語にしろ、枕草子、栄華物語、その他総てこの時代の婦人たちの作品である。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林多喜二という立派な世界に誇るべき文学的才能を持った男を殺したのは日本の共産党の間違った文化に対する態度だと。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に誇る英国造船技術の精粋――排水量六万噸と言うから、実際、当時に於てはずば抜けていた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本民族には民族として、世界に誇るべき趣味と、「内なる美」を持っていた。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども世界に誇るべき二千年来の家族主義は土崩瓦解するを免れざるなり。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性に扮する能役者が白い足袋をはいて、静かだが音律的にこの掛橋を歩む工合を見て、私はいつも『なんといふ女性的香気のある歩み工合であらう、小股の内気な運び工合は実に天下一品だ……この歩み工合だけでも、芸術として世界に誇ることが出来る』と思はないことがない。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は固より、日本の芸術を以て、世界に誇るに足るものだとは信じてゐるが、世界の方では、まだちつともさうは考へてゐないのみならず、やうやく浮世絵が珍重されてゐるとはいへ、それも骨董価値を外にして、どれだけ、芸術品としての取扱を受けてゐるか。",
              "citation": {
                "source": "左団次一行",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時こそ、歌舞伎劇は、世界に誇るべき古典劇として、今日以上の芸術的地位が与へられるであらう。",
              "citation": {
                "source": "歌舞伎劇の将来",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は世界に誇る大型飛行機の生産国である。",
              "citation": {
                "source": "真珠",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に誇るべき舞台を創り上げた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリが世界に誇るものは、たしかにその伝統のなかにあるでせう。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれを実行する人があったとしたら、確かに世界に誇るに足る日本一のツバキ園を作る事が出来る訳です。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハナショウブは、まったく世界に誇るべき花であるがゆえに、どこか適当な地を選んで一大花ショウブ園を設計し、少なくも十万平方メートルぐらいある園を設けて、各種類を網羅するハナショウブを栽え、大いに西洋人をもビックリさすべきである。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に誇るべき文化日本の最優秀発明品なのである。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次欧洲大戦の時に、英国の政府で、英国が世界に誇る大物理学者たちを総動員して、国防科学の素人発明を審査させたことがある。",
              "citation": {
                "source": "千里眼その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国の如きも近く日清戦争の頃までは、国民の目的は唯｜軍に勝つと曰ふだけで有つたらしいが、今度露国と開戦するに就て、只日本が強いと云ふ事を世界に誇るのみに満足せず、之と同時に正しい国であると云ふて欲しい望が出て来た。",
              "citation": {
                "source": "文明の強売",
                "author": "大石誠之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "富裕なるロンドン市が世界に誇る、英国の暮し向よき中流層を拡大させつつ東端には一時的ならぬ貧を二代三代とかさねさせているうちに、この逆三角の顔を持ち七歳ですでに早老的声変りをした異様な小人間がおし出されて来たのである。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば、春田博士が長年の苦心研究によって発明した世界に誇る可きＣ・Ｃ・Ｄ潜水艦の秘密試運転が、横須賀において行われる当日であった。",
              "citation": {
                "source": "骸骨島の大冒険",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、彼等は兵士としては、世界に誇る可きものになる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
