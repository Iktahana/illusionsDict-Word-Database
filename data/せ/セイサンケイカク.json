        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう風に一年の生産計画を立て、それでいろいろやって行く。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念すべき一九一七年からソヴェト同盟は年々当面の生産計画とともに常に先へ先へ五ヵ年位ずつ一まとめにした生産拡大計画をもって進んで来た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画は毎年大体定められた生産計画によって生産されている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と白字で書いたプラカートが貼られ、一週間ずつの採炭高と生産計画とを対照した興味ある統計図がかかげられている。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが戦争中労力不足等の原因でだんだん減って、北海道庁の農業生産計画に現われた耕地面積の統計では、昭和二十年度には、約七十六万町歩になっている。",
              "citation": {
                "source": "琵琶湖の水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道庁の農業生産計画にあらわれた統計では、昭和十二年度が、一番農耕地が多かった年となっている。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして放任しておいても農業は進歩し、国の生産計画は立つものかどうか。",
              "citation": {
                "source": "垣内の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々に実行されて来ている生産計画が二八―二九年経済年度から一九三三年までの五年間に、特別五ヵ年計画として意義をもつのは、この五年間に生産各部門が、これまでの平均生産額を、倍から二倍以上に上昇させる計画であるという点であった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富農がソヴェトの穀物生産計画を擾乱している事実は、おととし、一九二八年の穀物危機とよばれた時期から、誰の目にもはっきりした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油と白くかかれている特殊な輸送船が川波の間をさかのぼってゆくのをみると伸子にしろソヴェトの生産計画の生きた姿を感じずにいないのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁民と農民との生産計画を比較すると、一方は土地を擁して安全である代りに、何等の意外な収益を予期することが出来なかった。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
