    "definitions": [
      {
        "index": 1,
        "gloss": "passionate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「臍の緒に泣く」という言葉は奇警であって、しかも幼時の懐かしい思い出や、父母の慈愛深い追懐やが、切々と心情から慟哭的に歌われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何で年よる」という言葉の響に、如何にも力なく投げ出してしまったような嘆息があり、老を悲しむ情が切々と迫っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しい事には歳が歳であったから見もし聞きもした場所も事実も、二昔も程遠き今日からふりかえって考えてみると夢のような取り止めも付かぬ切々が、かすかな記憶の糸につながれて、廻り燈籠のように出て来るばかりで。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――を考へ、愛慕の情眞に切々たるものがある。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前達」夫がその言葉に托した、切々たる愛情が感ぜられた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝子は、何十年か、何百年か以前、人間が意慾を何かによって押えられた時代に、人間の力が自然を創造する方面へ注がれた息づきが、この庭に切々感じられた。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はなお、自分の患って居ることを報告して切々情を愬えている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも汽車で、うとうとと寝た時には、清水だの、川だの、大な湖だの、何でも水の夢ばかり切々に見ましてね、繋ぎに目が覚める、と丁ど天龍川の上だったり、何処かの野原で、水が流れるように虫の鳴いてた事もありましたがね。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "切々内へ呼び出しちゃ、花骨牌でも撒きそうに思ってるんだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、お初にお目に懸りまする、いかがでごわりまするか、ますます御翻訳で、とさぞ食うに困って切々稼ぐだろう、と謂わないばかりな言を、けろりとして世辞に云って、衣兜から御殿持の煙草入、薄色の鉄の派手な塩瀬に、鉄扇かずらの浮織のある、近頃行わるる洋服持。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」酔っているようであったが、語調には切々たるものが在った。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」の切々、無言の愛情より発していること、知らなければいけない。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな人は一生復習許りして、辞書に成つて墓穴に這入るにや、など呑気な考へを以て居れば、手にしたものは皆何処かに失くしてしまへど、さりとて新らしい本を切々買ひ込むなどゝ云ふ余裕のある読書家にあらず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい切々たる哀情が私の胸をうつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の光を切々とすくう鰌すくいの端厳さはかつての鏡花散人も見たものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に恐ろしい沈黙と突き放されたやうな寂しさが切々と私の心を襲ふて来た、恐ろしい、どうにかして逃げ出したい――　チリツンチリツンとまた金の絃を弄ぶ響がする。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱虫……苦痛と凌辱との思ひ出が切々と蘇る。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の蝋燭が鼻の真向にしんみりと光り輝く、眼と眼とが凝とその底から吸ひ付くやうに差覗く……つくづくと陰影と霊魂と睨み会つたまま底の底から自愛と憐憫の心とが切々と滲み出る。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一入にまた痛ましきは切々として新なる流離の悲みである。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海人」の仕舞でも地謡（梅津朔造氏、山本毎氏）が切々と歌っているのに、翁は白い大きな足袋を静かに静かに運んでいた身体附が一種独特の柔か味を持っていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば嬉しさを表現する時には躍り上るような音階を通じて最高音に達し、悲しみをあらわす事には嫋々切々として、ためらいつつ最高音に達するように節づけたとする。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼女」の台辞だって、切々に覚えている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生、口数の少いだけに、こうなるとその切々とした述懐に、力が籠って来るのである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二音の繰返しが十度び位ゐも切々として繰返さるゝと、合の手見た樣に僅かに一度、もう一音を加へて三音に啼く。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いいえ、先生、貴下が、寐かして、）と切々にいったが、いつになく酔っちゃいるし、ついぞないことをいうんだから、婆さん、はッと気がついて大喜び。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪田譲治氏の作品から享ける切々たる哀感は常にわたしの胸に痛かつた。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辞切々人の心を動かさずば止まない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人をいかなる者として汝これを大にし、これを心に留め、朝ごとにこれを看そなわし、時わかずこれを試み給うや、いつまで汝われに眼を離さず我が津を咽む間も我を捨て置き給わざるや」とは彼の神に対する切々たる哀訴である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天を言うに当っては、もちろん道の本源に及ぶが、孔子の道は多く切々と「人」の上に就いて言われているのである、随って「物事」の上に之を認めようとするのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、身体中に残った精力を蒐めながら、やっと切々に云った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
