        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば東限溝・北限何太夫作・西限道の類である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アワラという地名はこの県などがたいてい西限であって、東は甲信から関東に及び、また北国にもわずかの例がある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
