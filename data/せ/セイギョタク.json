        "examples": {
          "standard": [
            {
              "text": "発電所の緊急時には、担当者が制御卓で迅速な操作を行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい監視システムの導入により、制御卓のインターフェースが大幅に改善された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "管制塔の制御卓には、常に複数のモニターと通信機器が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一つの部屋にラックを並べた形で収め、向かい合わせに制御卓を置き、カメラマンがマシン全体を写真に収められるようなものをオールセンは目指した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新しい照明の開発は進んでいるかね」あなたは容器の側で制御卓のキーを叩いている桃太郎に尋ねる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星時間で二年くらい先になると思います」桃太郎はそう言いながら制御卓を巧みに操作して、マジックハンドを動かしていた。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると制御卓の下から黄色い包装紙に包まれたハンバーガーが出てくる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
