[
  {
    "uuid": "f31cf0d8-d876-5fe7-b691-2fe334b8ffc2",
    "entry": "戦艦",
    "reading": {
      "primary": "せんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "battleship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "盛庸防ぐ能わず、戦艦皆燕の獲るところとなり、陥れらる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は凡ゆる軍艦の知識に精進してゐて、朝日、三笠、敷島、厳島その他主なる戦艦や巡洋艦の、排水量でも砲門の数でも、速力でも、艦長の名前でも暗記してゐた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中であいつに見つかりゃ、戦艦であろうと輸送船であろうと、ストップを喰うんだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は悲観調ならざるを得ない」委員連中「全く困る」「日本兵は乱暴だ」「気が変だ」長官「たった日本の体当り一機で、わが空母や戦艦や大型輸送船を一隻ずつ轟沈撃破せられてたまるものじゃない。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは主力戦艦の主砲よりはるかに長さは短いが、それでも砲身の全長は五メートル近くもあった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホ潜十三、ホ潜十三、……」　戦艦武蔵が呼んでいた相手がいよいよ現れたのだった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上組は巡洋艦隊で、南洋の辺に残っているのは主力艦隊だろうよ」「うむ、すると戦艦淡路、隠岐、佐渡、大島や、航空母艦の赤竜、紫竜、黄竜などというところがわれわれを待っているわけだね。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソ連が極東に三十師団を持って来れば我が軍も北満に三十師団を位置せしむべく、ソ連戦車三千台なら我も三千台、また米国が六万屯の戦艦を造るなら我もまたこれと同等の建艦を断行すべきである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、こんなこともあるよ、エイゼンシュテインが「戦艦ポチョムキン」を撮影した時、老いぼけた坊主が十字架もって出て来るんだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦艦オーロラーが、冬宮を砲撃した時の写真、軍事革命委員会の本部があった、スモーリヌイの大きな写真を見ると、われ知らず、喜びの叫びが口をついてあふれる。",
              "citation": {
                "source": "ロシアの過去を物語る革命博物館を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、一九一七年の「十月」に赤色海軍が演じた英雄的役割は、ソヴェト映画の傑作「戦艦ポチョムキン」に、永久的足跡をのこしている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千の将兵が蠅捕紙上の蠅みたいに、戦艦大和にへばりついたまま水底に沈んで死んだ愚かしい悲劇が、偉大な叙事詩の如く感動的に無批判に書かれたものが、数十万の人たちに愛読されている。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "中根香亭は「朝延大発軍艦北征、我艦要撃之于宮古、敗而還、於是五稜廓為本営、列戦艦於函館港、分遣諸隊於松前江差室蘭、以備敵」と記してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイテ戦は総敗北、海軍の大本山、戦艦大和も撃沈された風説が流れていた。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど科学の粋を尽した白い戦艦が一望のもとに並び下ったかと見える堂堂たる景観だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "白東会を雇って応戦準備を整えた地主達は、戦艦の様に落着き、小作人達の結成を眼下に視下した。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、両者の海軍力は、戦艦九対十四、装甲巡洋艦九対二の比率で、伊太利側が一倍半の優勢を持していたのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、右舷のはるかに、黒々と防波堤が見え、星のように燦めくタラント軍港の燈火――いまや、戦艦「レオナルド・ダ・ヴィンチ」は目睫の間に迫ったのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚艦の一つらしく、続いて現われた灯に、本艇は、戦艦レオナルド・ダ・ヴィンチの所在を知ったのであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、戦艦「レオナルド・ダ・ヴィンチ」は、タラント軍港の水面下に没し去っていったのであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君の知っている通り、戦艦『金剛』や『榛名』の装甲は八吋（二〇・三糎）だから、『最上』の方が強いわけである。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ戦艦よりも強い軽巡洋艦！",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "『最上』のデーゼル機関は武田博士が、それこそ骨をけずるような苦心をして造ったもので、ドイツが自慢する豆戦艦『ドイッチュランド』のデーゼル機関さえ、全然くらべものにならないのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦艦『長門』『陸奥』『日向』『伊勢』『山城』『扶桑』『榛名』『金剛』『霧島』。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦艦『八島』の第二世　碧海湾に波騒ぎ、どッと、もり上って来た渦巻は、みるみる「ごォ――ッ」と音を立てて真二つに割れた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ずっと昔の戦艦の名前だね。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争の時、旅順の沖で壮烈な、勇ましい最期をとげた、名誉ある大戦艦の名だ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月でも、一日でも、いや一時間でも十分でも、はやくはやく、この潜水戦艦を進水させなければならない。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の思念の底の一すじのせんかんたる渓流もまた、この言葉であったのだから。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんかんと泉声が聞えて、床をふむ足の裏が冷々とする。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
