        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "節電は街を暗くし、交通機関も無駄な旅を戒めています。",
              "citation": {
                "source": "明治懐顧",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "世耕情報、尺祭り、節電盗電、日本は目下、あげて道化芝居である。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは、節電のため、終電が早やかったのである。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも節電で消えていたが、ついたら、壮大なもんだろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "節電のための計画停電という奴だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "節電勵行で、折々、無事に電氣のついてゐる夜は有難い。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "賭場を出た時、一時を打ったんだぞ」「節電で何処の風呂屋も突拍子もない時間にやるのよ。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焼夷弾の消し方」「空の体当り」「ジャガ芋の作り方」「一機も生きて返すまじ」「節電と飛行機」不思議な情熱であった。",
              "citation": {
                "source": "白痴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "節電日とあって昼は電燈無し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉納氏の奥さん曰く、「節電々々で夜の暗いこと、まあ防空演習のお姉さんみたいですわ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日熱海俵別荘へ引越の筈だが、そっちから電話で温泉が節電のため時間制となったとのことで、大がっかり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂へと言ひたいが、節電のため昼すぎは湯が止ってる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十一日（水曜）　九時に起きる、今日は節電日で湯が出ないといふのでクサる、ヒゲを剃る元気もなし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
