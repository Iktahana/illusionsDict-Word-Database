    "definitions": [
      {
        "index": 1,
        "gloss": "glabrous sarcandra herb (Sarcandra glabra)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）前代未聞の定九郎いなせな定九郎男ッ振りの善い定九郎よ実に無類千両！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはもう三千両ほどをたくわえて、奥の唐櫃にしまい込んであったのを一切没収された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「六千両くらいなもんだろう。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百両ぐらいの価値は確かで御座いますがトテモ千両なんて踏めるシロモノじゃ御座んせん。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両箱の山を積んでもこの楽しみばっかりは、お譲りする訳に参りませんので……ヘエ……」　松倉十内は又しても余計な事を言ったために、非人風情に吹き巻くられた形になったので、スッカリ苦り切ってしまった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "というものは実は山王台で種々の空想を描いた時、もし千両も拾ったらなど、恥かしい事だが考がえたからで、それが事実となったらしいからである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤッ」さむらいはふところから白いたすきを取り出して、たちまち十字にたすきをかけ、ごわりと袴のもも立ちを取り、とんとんとんと土手の方へ走りましたが、ちょっとかがんで土手のかげから、千両ばこを一つ持って参りました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイ、ヤッとさむらいは千両｜函を又一つ持って参りました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両ばこはみなで十ほどそこに積まれました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の千両ばこの十やそこばこ、きっときっと持ち参るでござりましょう」「うむ。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六平は十の千両ばこをよろよろしょって、もうお月さまが照ってるやら、路がどう曲ってどう上ってるやら、まるで夢中で自分の家までやってまいりました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上に列記したるものを、はじめをはり取｜揃へむか、いくら安く積つて見ても……やつぱり少しも安からず、男子は裸百貫にて、女は着た処が、千両々々。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爽な心持に、道中の里程を書いた、名古屋扇も開くに及ばず、畳んだなり、肩をはずした振分けの小さな荷物の、白木綿の繋ぎめを、押遣って、「千両、」とがぶりと呑み、「ああ、旨い、これは結構。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金は十分、通い廊下に藤の花を咲しょうと、西洋窓に鸚鵡を飼おうと、見本は直き近い処にござりまして、思召通りじゃけれど、昔｜気質の堅い御仁、我等式百姓に、別荘づくりは相応わしからぬ、とついこのさきの立石在に、昔からの大庄屋が土台ごと売物に出しました、瓦ばかりも小千両、大黒柱が二抱え。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、千歳座にて「四千両小判梅葉」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "・日かげりげそりと年をとり・そこらに冬がのこつてゐる千両万両・地つきほがらかな春がうたひます・ゆふべはゆふべの鐘が鳴る山はおだやかで・鴉があるいてゐる萠えだした草　三月十一日晴、晴、朝酒はよいかな、よいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台地方には昔から、雀が多かつたのか、仙台笹とかいふ紋所には、雀が二羽図案化されてゐるし、また、芝居の先代萩には雀が千両役者以上の重要な役として登場するのは誰しもご存じの事と思ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には古雛を買ひ集めてみたり、時には筆矢立を漁り歩いたり、奇抜だつたのは昔の千両箱の蒐集であつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、お前も、花見がてらに上方へのぼって、島原へでも行って遊んで、千両二千両使ったって、へるような財産でなし、気に入った女でもあったら身請して、どこか景色のいい土地にしゃれた家でも建て、その女のひとと、しばらくままごと遊びなんかして見るのもいいじゃないか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浪人は大声を挙げて、「百両千両のかねではない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両の茶碗を叩きつけたところは些癇癪が強過ぎるか知らぬが、物に囚われる心を砕いたところは千両じゃ廉いくらいだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両の茶碗をも叩ッ壊した其政宗が壱尺七八寸の叩き壊し道具を腰にして居る、何を叩き壊すか知れたものでは無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ明日の富籤に当りてえナ、千両取れりゃあ気息がつけらあ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お望みとありゃ、千両束で足の埃を払いて通るぜ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "富籤が当って、一家狂喜している様を、あるじ、あさましがり、何ほどのこともないさ、たかが千両、どれ銭湯へでも行って、のんびりして来ようか、と言い澄まして、銭湯の、湯槽にひたって、ふと気がつくと、足袋をはいていた。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、いちばんまえの席は、ふとった肉屋のおやじが、ひとりでせんりょうしていましたが、それがまた最上の席でもあったでしょう。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして牢屋のほうでは、ふしぎにも、数かぎりない鳥や獣がやってきて、牢屋から森まで、すっかりせんりょうしてしまっています……。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら、こいつが、もう一ぴきのクマを追いだして、このおりをせんりょうしたのかもしれません。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
