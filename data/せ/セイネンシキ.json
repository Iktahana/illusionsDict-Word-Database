    "definitions": [
      {
        "index": 1,
        "gloss": "coming-of-age ceremony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
