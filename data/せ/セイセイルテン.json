    "definitions": [
      {
        "index": 1,
        "gloss": "all things being in flux through the endless circle of birth, death, and rebirth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）「人間の奴め」宇宙は生々流転する、――昨日の彼は明日の私だらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来痛切に自然の理法といふものを感じる、生々流転の相を観じる。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "生々流転、無限なる人間の永遠の未来に対して、我々の一生などは露の命であるにすぎず、その我々が絶対不変の制度だの永遠の幸福を云々し未来に対して約束するなどチョコザイ千万なナンセンスにすぎない。",
              "citation": {
                "source": "堕落論〔続堕落論〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "生々流転は人生の真相だから、恋人の殺された当日から生々流転。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡本かの子の、生々流転のことどもや、いい人でしょう、と紹介された私のこと。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいせいるてんという言葉もある。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
