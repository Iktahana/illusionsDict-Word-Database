[
  {
    "uuid": "3350ba74-c9a4-56db-b0bc-570b45daa41d",
    "entry": "西洋",
    "reading": {
      "primary": "せいよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
