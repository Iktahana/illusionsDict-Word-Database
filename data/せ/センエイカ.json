        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "写真のピントが甘く、もっと鮮鋭にしたかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その映像は、デジタル処理によって輪郭が先鋭化され、より鮮明になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "論争は先鋭化し、双方の主張はますます尖鋭になっていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
