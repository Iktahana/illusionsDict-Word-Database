  {
    "uuid": "d9781f5d-72e6-5c7b-bd64-0c05bc052333",
    "entry": "瘠地",
    "reading": {
      "primary": "せきち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "barren land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どこを風見の鷄が見てゐるのか冬の日のごろごろと※る瘠地の丘で　もろこしの葉が吹かれてゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを風見の鷄が見てゐるのか冬の日のごろごろと※る瘠地の丘で　もろこしの葉つぱが吹かれてゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "児どもでも老人のようには見えませんか、青いうちに皺の入った瘠地の杏のように。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の村は瘠地であつたので自然櫟林が造られたのである。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが櫟がずん／＼と瘠地に繁茂して行くやうに村には丈夫な子供が殖えて行く。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介には、瘠せて骨ばつた、さうしてその上を鞭打たれて赤裸かになつたやうな馬の尻と、甘土が薄く、すつかり養分を吸ひ取られて、カサカサになつてしまつたやうな瘠地の肌とが、この上ない相似性をもつて眼に見えて來るのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせきちゃんを送って行くのだから、影や道陸神を用心おしよ。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おせきちゃん、御覧よ。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おせきちゃんは月夜の晩には表へ出ないんだってね。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おせきちゃん、いますか。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせきちやんを送つて行くのだから、影や道陸神を用心おしよ。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おせきちやん、御覧よ。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おせきちやんは月夜の晩には表へ出ないんだつてね。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おせきちやん、居ますか。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてしらん、ぎしぎし、たちあおい、かわほね、のいばら、つきみそう、てっせん、かなめ、せきちくなどが咲き、裏の畑の桐の花は高く薫った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごこちがなくなっていても、生きているとおりの顔いろをしていて、ほおは、せきちく色をしていましたし、くちびるは、さんごをならべたようでした。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
