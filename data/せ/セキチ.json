[
  {
    "uuid": "48aecad9-2fda-516c-b4d1-53bfb19401f3",
    "entry": "尺地",
    "reading": {
      "primary": "せきち",
      "alternatives": [
        "しゃくち"
      ],
      "is_heteronym": false
    },
    "grammar": {
