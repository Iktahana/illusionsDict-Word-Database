        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いかなればまた愁ひ疲れてやさしく抱かれ接吻する者の家に歸らん。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座席に肩を寄りそひて接吻するみ手を借したまへや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このようにヨーロッパとアメリカとが虚空を距てて睦まじく接吻するようになったのは科学の力の最も詩的な表現である」と。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二人はすつかり仲好しになり、互に「兄弟」と呼んで抱擁し、髯面をつけて接吻さへする。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "醉つて見知らぬ男と友人になつたり、兄弟と呼んで接吻した醉漢は、朝になつて百度も唾を吐いて嗽ひをする。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "微妙な接吻がそののちに来る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは生れていつぺんでも娘たちに接吻したことはない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十分の敬意を以て、ゾフィイの手に接吻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして愛の限りを味わって幾度も幾度も接吻いたしましたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして敵兵に捕えられる時に、そっと牧師の妻の髪に接吻したのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――……接吻しますよ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達はラムブルデル・セントロの椰子の大通りで、狂気のように接吻しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が薄気味悪がって逃げ出そうとすると、急に妾を抱えて嫌がるのもきかないで妾に接吻しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "息詰まるような長い接吻を終えると、彼は絶望的な声を挙げて妾を突きとばしたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこにロダンの傑作、黄銅時代、ダナイト、美しき冑造り、接吻等に変って、バルザックの寝巻姿が私達の心に憂鬱な余生を送る心理学者のように映るのを見るのであった。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が息をきらしてマリに××りになると、彼女の額に接吻して言った。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のアンナ・ニコロと私、熱烈な接吻、果しがない。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………をつけたアンナの……、いそ／＼と私を迎えると※々として私の唇に接吻して、心にもない。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナ・ニコロ接吻したまま、　――ヨシユキ、ロマンチシズムとヒロイックなスラビナの時代はまだロシア人は香のいい肥料があったのです。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・ポンペアの低い嬉びに、世界各国の鶏の歌奏でるユダの主人、私はシャンパン、緑色の天井、進撃勇ましい、桃色の月、見上げて、十人のコウカサスの女に接吻する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナ・ニコロが私を引ずって矢鱈に接吻する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときによってジャズ・バンドがビビの音楽をやっているとき、死海の水に映って正気を失った士官に貴女が抱かれて、独逸仕込の接吻の洪水のなかで、彼奴がロメオとジュリエットの名台詞を彼がネロのようにそりかえって早口で喋舌るときは全く貴女を薄倖の踊子だとさえ思ったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚｜迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は彼の岩石のような胸に爆弾を装置しながら別離の接吻をした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして別れるとき私はチタ子に接吻したのですが、それについて彼女は、　――あなた、忘れてはいやだわ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、テエブルの上にあつたグラスの、琥珀色の酒をぐいと呑み干すと、いきなりまた男の首筋に白い手を卷きつけて、じやれつくやうに短い接吻をその唇に與へた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、縮こめた女の體をぐいと自分の胸に引き寄せて、二度目の接吻を交したかと思ふと、二人は身を搖す振つて一時に笑ひさざめいた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」博士たすけよ、と呼ばむとする時、何と、……頸寄り、頬重り、脚抱くと視るや、尾を閃めかして接吻をした。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、カレンは、おのをつかった役人の手にせっぷんすると、あれ野を横ぎって、そこを出ていきました．（さあ、わたしは十分、赤いくつのおかげで、苦しみを受けてしまったわ。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
