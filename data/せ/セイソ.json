[
  {
    "uuid": "d81e1169-5389-5a5b-bb22-a018f783f91f",
    "entry": "清楚",
    "reading": {
      "primary": "せいそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "neat and clean",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小門｜清楚、「春夏秋冬花不断」の掛額もさびたり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはや単純と静けき呟きと、とまれ、清楚のほかを希はず。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白に襞の多い着物と、頭の白い花の冠が非常によく似合い、私に持って来たクリスマス・プレゼントのチョコレートの箱の飾リボンの縁が、清楚にうつり合った色彩は、私に思わずつかつかと傍へ寄らしてしまったような、好もしい感じを与えました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は寂しい、君は正直で、清楚で、透明で、もつと細かにぴちぴち動く。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣い緑の牧場と、靄にかすんだ海峽の水と、黄ばんだポプラの林と、赤煉瓦の清楚な修道院の建物と――それ等が秋らしい靜かな色の調和を作つて快く私の瞳に沁み渡つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし部屋が割合に気持のいい部屋で、すべてが清楚な感じを与えた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場は、つい最近新築されたものらしく、よごれが無く、純白のタイルが張られて明るく、日光が充満していて、清楚の感じである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は遺産を近親の死から十五の年に得て清楚な暮しに一生涯事欠かない孤独な少女学究者なのです。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通りの挨拶終つて後、夫人は愛兒を麾くと、招かれて臆する色もなく私の膝許近く進み寄つた少年、年齡は八｜歳、名は日出雄と呼ぶ由、清楚とした水兵風の洋服姿で、髮の房々とした、色のくつきりと白い、口元は父君の凛々しきに似、眼元は母君の清しきを其儘に、見るから可憐の少年。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ半を口に啣へて、うつむいて見せた圖は、永洗の口繪の艷冶の態を眞似て、大に非なるものであつたが、これは期せずして年方の插繪の清楚であつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年紀は二十三、四、姿はしいて満開の花の色を洗いて、清楚たる葉桜の緑浅し。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて先斗町にからこという舞妓がいて、評判になったが、鈴子には往年のからこにはなかった清楚なういういしさがあった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇の中の椿の花の清楚な白さが、鈴子を想い出させたのであろうか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初々しく可憐な鈴子が、清楚な花のように匂うばかりにはにかんで、小郷の前に坐った時、小郷は、「ほう……」　と、眼を細めてしまった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合の花のように可憐で、清楚であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛々しいばかりに、清楚であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ十八になったばかしの、痛痛しいばかりに初々しい清楚な娘さんである。",
              "citation": {
                "source": "十八歳の花嫁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉や株のむくつけきに似もやらず、なんとその花の清楚なことよ、気高いかおりがあたりにただようて、私はしんとする。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼には真佐子のやや、ぬきえもんに着た襟の框になっている部分に愛蘭麻のレースの下重ねが清楚に覗かれ、それからテラコッタ型の完全な円筒形の頸のぼんの窪へ移る間に、むっくりと搗き立ての餅のような和みを帯びた一堆の肉の美しい小山が見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その全体からうける清楚とした感じは、とても後年の濃艶な扮装の夫人から想像することはむづかしい。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝室の壁の隠し棚に入れて置く夜壺、たとへこれがペルシヤ模様の清楚華麗な品であるにしても、この始末など、いくら内弟子でも桑子にはさせられない。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の清楚で有り得るか有り得えぬかも僅々の日數で徹底し得るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿も風采も鶴に似て、清楚と、端正を兼備えた。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは婀娜なり……それに似て、これは素研清楚なり、というのを不忍の池で。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色の無地のワンピースが清楚に似合う垢ぬけた容姿は、いかにも占領軍の家族が撮りたくなるくらい、美しかったが、しかし足には切れた草履をはいていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "清楚な女とダンスというものを、結びつけて考えたくないという偏見だ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鳥居の前で下りると、清楚な白い石畳の道を、また石の段を真っ直に、私たちは登って行った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白粉気がなく、癖のない潤沢な黒髪を、無造作に束ねているので、たいへん清楚な感じがした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "書いてみましょう、しかし「清楚」一本では映画にならないかも知れないと。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の中で、この夜、村始まって初めての殺人があるかも知れないという状態はせいそうだ。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
