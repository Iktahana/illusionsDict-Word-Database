        "examples": {
          "standard": [
            {
              "text": "「隣国の内政に対する政治干渉は、外交関係を悪化させる重大なリスクを伴う。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「学問の自由を守るためには、大学運営への政府の政治干渉を排除しなければならない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「メディアに対する不当な政治干渉がないか、常に監視の目を光らせている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば、坂野少将という人がいて、海軍は政治に干与しないと声明したが、夫が何よりもの政治干渉と解釈されるというようなわけだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
