[
  {
    "uuid": "92eb69b6-ebec-552c-aa13-770d8912a922",
    "entry": "責め道具",
    "reading": {
      "primary": "せめどうぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
