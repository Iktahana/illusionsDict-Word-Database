        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は佐藤春夫、室生犀星、北原白秋、千家元麿、高村光太郎、日夏耿之介、佐藤惣之助等の諸君の詩を、たいてい忠實に讀破してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろその比較ならば、却つて千家元麿などの方が適切だらう。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今の知つてゐる詩人で、千家元麿にこの同じ自然性を感じてゐる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く言つて、千家元麿は「生れたる子供」「生れたる自然人」だ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども君と千家とは、そのナイーヴさの特色に於て、非常にまた著るしくちがつたものが感じられる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "導かれた車室の中には、白鳥省吾、千家元麿、川路柳虹等の諸君が、いつもの親しい顏ぶりでそろつてゐた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の落葉のままが風雅なら、どんな田舎家にも千家茶道宗家の看板は掲けられましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに「一鉢千家飯」、涙ぐましくなる。",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一分のスキもない手紙など『手紙が仲々出来ない』といったりしたことを千家君は誤解したらしい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武野紹鴎とか千利休が出て法式を整へたので、千家表流・千家裏流・千家武者小路流などが出来、更に、石州流・有楽流・藪内流・遠州流などの流派が出来た。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼の詩風を他人がよく、千家元麿氏の流れをくんだ平明さを追ふものだといふ言葉をきくことがあるが、私はさうは思へない、千家氏からは不用意な素朴さの牽引力を感じるに反して、彼は細心な野性をもつてゐる、この点ではずつと象徴的である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年大河内子爵のお伴をして俗に柘植黙で通ってる千家の茶人と、同気相求める三人の変物｜揃いで東海道を膝栗毛の気散じな旅をした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、衛養療法や静座法を研究する意で千家の茶事を学ぶに等しい二葉亭の態度では禅に満足出来るはずがないのが当然で、結局禅には全く失望した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茶にも裏千家というものがあるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは小さい災いを免かれまい」　その翌日、東市から火事がおこって百千家を焼いたが、まずそれだけで消し止めた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟女眞といふのは、契丹の太祖阿保機時代に、女眞が寇をすることを恐れて、女眞の豪族數千家を分けて遼陽の南方に置いた。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "和江村では、その都度幾度か地方の神官を招いて、清祓式を行つてはみるが、一向｜効目が無くて狂人は殖えるばかりなので、寧そ大社教の管長様を迎へたらといふ事になつて、さてこそ千家管長の乗込みになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不昧公は千家へ往く途中で、急にその日は大徳寺に宝物の虫干がある事を思ひ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "千家ではまた宗左が欠伸ばかりし続けてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大社の主典島君に導かれてあちこちと見て※つた後、私達は千家邸で早い晝食の饗應を受けた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の時間が迫つたことを知らされて、私達はあわたゞしく千家邸を辭した。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "□一鉢千家飯（行乞心理）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一項附記して置きたいことがある、庵としての御馳走は何もなかつたが、雑草を見て貰つたこと、一鉢千家飯を食べて貰つたことは、私としてまことにうれしいことであつたのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃のことで月謝はわずか四、五十銭でしたが、四、五人寄れば多少纏まりますので、島田氏はよろこんでおりました（流義は千家でした）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "西町時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあるいは九月から千家元麿という人の「善の生命」という雑誌に「愛と知恵との言葉」という題で、短いものを、毎月組曲のようにしてしばらく書くかもしれません。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「福岡日日」の記者など流転の生活を続け、大正12年大阪で「風貌」を主宰、ブレイク、千家元麿の影響をうけた詩が認められた。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近行われた日本の新しい祭日を決める討論会においては、衆議院議員馬場秀雄、民主的な立場をもつ歴史家羽仁五郎と、シントーイストであって出雲大社東京分祠長千家尊宜等が登壇し、大衆の中に少くない数の学生が見られた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か処方せんけれあならんと思つたかした校長は、その五名を放校に、他の十五名を謹慎処分といふことにしました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しナフタリン臭くなっているかも知れませんけど、ね、」と私のほうに向き直って言って、「うちのひとには、もう、なんにも要らないのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五番を見ただけですから、自信を以ては言へませんけれど、力士の取組に、「武技」といふよりは、「藝技」のはうを、多く感じました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
