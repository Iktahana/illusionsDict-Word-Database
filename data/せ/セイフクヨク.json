    "definitions": [
      {
        "index": 1,
        "gloss": "the lust for conquest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この驚くべき征服欲は直径わずかに二三ミリメートルぐらいの細い茎を通じてどこまでもと空中に流れ出すのである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "征服欲などは、所詮、運命を知らざる間の出来心にすぎませんね。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "征服欲も友情も、恋も学問も。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『虞美人草』に至っては鮮やかな類型的描写によって、卑屈な利己主義や、征服欲の盛んな我欲や、正義の情熱や、厭世的なあきらめなどの心理を剔抉した。",
              "citation": {
                "source": "夏目先生の追憶",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "征服欲の満足と歓喜で野蛮になっている群集の相貌というものを、伸子はそのときはじめて見たのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クライスラーほどにも聴かせようとはせず、フーベルマンのような露骨な征服欲を見せることもしない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初聴いた時は、その達者さと、征服欲の旺盛さに驚いたものだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは香ばしい汗と獰猛な征服欲との闘いといってもいい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
