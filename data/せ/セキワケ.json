    "definitions": [
      {
        "index": 1,
        "gloss": "wrestler of the third highest rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
