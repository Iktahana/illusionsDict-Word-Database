[
  {
    "uuid": "0a6a9f39-d8fb-5e3e-8704-2e05321b58b7",
    "entry": "正否",
    "reading": {
      "primary": "せいひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
