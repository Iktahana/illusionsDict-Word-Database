          "literary": [
            {
              "text": "その小さな木造の建物を搖がす深い唸りは、オルガンの音ではなくて、製粉機の響きであつた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その製粉機会社の主人ってのが、仲仕上りで、金なんぞ一文だって只出すという奴じゃあないんです。",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コゼツのだんなは、粉袋や製粉機に取り囲まれてせっせと働いていましたが、心をいっそうかたくなにしてこうつぶやくのでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
