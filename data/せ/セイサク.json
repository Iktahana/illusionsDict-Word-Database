[
  {
    "uuid": "46d7c4a3-4a5f-5628-8e61-69090c00ff66",
    "entry": "制作",
    "reading": {
      "primary": "せいさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
