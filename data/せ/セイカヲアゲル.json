          "literary": [
            {
              "text": "ただしあくまで理想主義的なＴＲＯＮ的アプローチも、いわゆるインテリジェント・ビルのような限定的な空間では、成果を上げるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがアルテアが生まれて以来、パーソナルコンピューターの発展にとって欠かすことのできない条件として機能してきたオープンアーキテクチャーに背を向けたＰＳ／２は、ＩＢＭが期待したほどの成果を上げることができなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍医学校の全能力をあげて検査に当ったなら、いかなる医大の全能力も遠く足もとへ及ばない大成果を上げるに相違ありません。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
