    },
    "definitions": [
      {
        "index": 1,
        "gloss": "live birth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "断じて生産の形式のものではない。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるを現今様々なる新主義新主張の提唱者等は、生産の形式で芸術を展開しようといふ、徒な欲求を持する者ではあるまいか。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら芸術といふものは其処で休むためのものであつて、其処で生産しようといふやうなものではないからである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、マニラの生産品を積んで、三池へ向って、帰航の途についた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰爭の爲に出來たらしい小工場が到處に小規模な生産をやつて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子夫妻が父の祖神の翁に顔を合すとき、大体話は山の生産の模様、山民の生活の状況、それ等を統ねて行く岳神としての支配の有様、そのようなものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また広義の詩、すなわち文学的生産一般は「いき」の表情、身振を描写し得るほかに、意識現象としての「いき」を描写することができる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、詩、すなわち文学的生産にあっては、特に狭義の詩のうちに、リズムの性質において、「いき」の芸術形式を索め得ないことはない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の場合においては、球技を職業とする人は格別、普通にはとにかく不生産的の遊戯であり、日常生活の営みからの臨時転向である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の趣味としては、もつと空氣の明るく近代的で、工場や、煙突やが林立し、一方に生産的市場が活動しつつ、一方に赤瓦の洋風家屋などの散見する情趣、即ち大都會の郊外にみる近代的生活の空氣がすきなのだ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそんな大量生産の際に、一つびとつの死なぞはうまい具合に行きつこはない、が、そんなことはあまり大したことではないのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "大量生産さへすれば好い。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "有閑者がこの街を自分の調査機関のようにたえまなく往来して、記憶をタイプライターで刷りあげると、不生産的な、非社会的な報告書しかつくれないような愚な街であった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の連合委員会の事業振興の決議案にもかかわらず、閑散とした取引市場をとりまいて、日一日と失業者と、彼らの飢えが生産余剰と反比例して街の広場に堆積して行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "立野信之、細野孝二郎、中野重治、小林多喜二等によって幾つかは生産されている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これらの作家によって、現在までに生産された文学は、単に量のみを問題としても、我国人口の大部分を占める巨大な農民層に比して、決して多すぎるどころではない。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、自然主義文学運動は、ブルジョア生産関係の反映として、「在るがまゝに現実を描き出すこと」「科学的精神」「客観描写」「現実曝露」等、ブルジョアジーがその生産方法の上に利用した科学の芸術的反映として、ブルジョア社会建設のために動員され、そして発展したものである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義文学が、資本主義的生産関係を反映し、あるがまゝに現実を描こうと企図したのに対して、この写生派、余裕派、低徊派等は支配階級の中に根強く巣喰っている封建主義を多分に反映して逃避的唯美的傾向に走っていた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸には、搾取のない生産と、新しい社会主義社会の建設と、労働者が、自分たちのための労働を、行いうる地球上たった一つのプロレタリアートの国があった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人口の最大多数の生産的職業がまた植物の栽培に関しているという点で庭園的な要素をもっている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらは科学の産み出した生産物であって学そのものとは区別さるべきものであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう種類のものにはやはり必ず何かしら独創的な内察があり暗示があり、新しい見地と把握のしかたがあり、要するになんらかの「生産能」を包有しているある物がなければならないのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは成る程、君も僕もぜんぜん生産にあずかっていない人間だ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争のためにできたらしい小工場が至るところに小規模な生産をやっている。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど手ぬぐい浴衣もあればつづれ錦の丸帯もあると同様なわけであって、各種階級の購買者の需要を満足するようにそれぞれの生産者によって企図され製作されて出現し陳列されているに相違ない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
