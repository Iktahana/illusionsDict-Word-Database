[
  {
    "uuid": "c3cb8364-6afc-574d-adb1-bc528da08dc8",
    "entry": "生残",
    "reading": {
      "primary": "せいざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
