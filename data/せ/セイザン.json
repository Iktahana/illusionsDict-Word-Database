      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "survival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな習俗ももとは何かしら人間の本能的生活に密接な関係のある年中行事から起ったものであろうと思うが、形式だけが生残って内容の原始的人間生活の匂いは永久に消えてしまい忘れられてしまったのであろう。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この洪水で生残ったのは、不思議にも娘と小児とそれにその時村から供をしたこの親仁ばかり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨の山国の風雪の夕、この一軒家に於て稀有の悲劇を演じたる俳優の中で、僅に生残っているのは幸運の冬子｜一人に過ぎぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから桂子は、桂子がフランスを発つて来る間際まで、世紀末生残りの詩人が、まだ飽きずにこんな感じの詩を作つてゐたことを、ちよつとの間、憶ひ出してゐた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すは津波こそ、はや逃げよ、と老若男女われさきにと逃迷ひしかど、しばしが間に打寄て、民屋田畑草木禽獣まで少しも残らず海底のみくづと成れば、生残る人民、海辺の村里には一人もなし、扨こそ初に神々の雲中を飛行し給ひけるは此大変ある事をしろしめして此地を逃去り給ひしなるべしといひ合て恐れ侍りぬと語りぬ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに生残っていた。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の洪水で生残つたのは、不思議にも娘と小児と其に其時村から供をした此の親仁ばかり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄惨な努力を一年ばかり続けたのち、ようやく、生きることの歓びを失いつくしたのちもなお表現することの歓びだけは生残りうるものだということを、彼は発見した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麾下数万の軍勢を見渡しながら、百年後にはこの中の一人も生残っていないであろうことを考えて涕泣したというペルシャの王様のように、この少年は、今や、自己の周囲の凡てに「限られたるもののしるし」を認めて胸をさされるのであった。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺に弁護士になれと云うた奴は彼奴一人じゃ」　又或時傍の骨格逞しい眼付きの凄い老人に筆者を引合わせて曰く、「この男は加波山事件の生残りじゃ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私は可厭な事を聞いた、しかし、祖母と小さい弟妹を死なせて水戸屋を背負って生残ったと言う娘分、――あの優しい婦が確にと、この時直覚的に知りましたが――どんなに心苦しいか……この狭い土地で、嘸ぞ肩身が狭かろう。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、世間が驚嘆したのは実は威力ある肩書のためであって、その実質は生残りの戯作者流に比べて多少の新味はあっても決して余り多く価値するに足らなかったのは少しく鑑賞眼あるものは皆認めた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "京伝馬琴以後落寞として膏の燼きた燈火のように明滅していた当時の小説界も龍渓鉄腸らのシロウトに新らしい油を注ぎ込まれたが、生残った戯作者の遺物どもは法燈再び赫灼として輝くを見ても古い戯作の頭ではどう做ようもなく、空しく伝統の圏内に彷徨して指を啣えて眼を白黒する外はなかった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、この根室に出入する男の顔は、今も昔も、一人残らず知っている」丸辰は、立ちあがりながら、「あいつア、確かに北海丸の安吉だ」「じゃア、生残っていたんか」「助かって、今頃帰って来たんかな」　けれどもやがて女は、ものも云わずに、扉口のほうへ馳けだして行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやそれは只一人の生残り人間なる専制コハクのために奏せられる挽歌であった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ幸運に推移して、いくらかの人間が生残ったとしても、人類の勢力は、約二万年昔に後退するであろう。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生残りの神様も遠からず、この世から追放されてしまうであろう」と心細いことを主張して譲らなかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーナー博士一行の生残者か、それとも遺骸かもしれないが、とにかくそれがロンドン内に隠されていることは間違いなしだ」「うん。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで博士と三名の生残った助手と、それに水戸を交えた四名が上陸した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその度毎に、私はいつも生残つて来るのでした……。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "生残た妻子の愁傷は実に比喩を取るに言葉もなくばかり、「嗟矣幾程歎いても仕方がない」トいう口の下からツイ袖に置くは泪の露、漸くの事で空しき骸を菩提所へ送りて荼毘一片の烟と立上らせてしまう。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今度の売立で、木瓜の卓は六千円といふ値にせり上げられたが、無事に生残つた飛青磁は大分見倒されて二千三百八十九円といふ事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうさ、生残つたものゝ方が辛い場合もあるし、生残るのが辛い場合もあるから。",
              "citation": {
                "source": "余震の一夜",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、敵は海の藻屑となったのに、おれ達は生残った。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルキスに怪我でもあつてはと、王は生残つた奴の恐れに乗じて、女王を抱いたまま、人通りの無い側路へ逃げこんだ。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草へ遊びに来る客は、映画やレヴユーまたは十銭漫才を享楽しようとするので、時代に生残つた落語なぞ縁が遠かつたのかも知れない。",
              "citation": {
                "source": "落語家たち",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
