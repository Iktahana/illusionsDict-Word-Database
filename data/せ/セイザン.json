  {
    "uuid": "f1b6fead-49b5-5b57-a852-c82cd601761c",
    "entry": "生産",
    "reading": {
      "primary": "せいざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
