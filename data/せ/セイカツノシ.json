    "definitions": [
      {
        "index": 1,
        "gloss": "means of living",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれは生活の資料を運搬する労働ではあろうがとにかく人間から見ると一種の球技である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳永は百に一つをおかみさんに献じて、これに次ぐ七八を売って生活の資にした。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつには生活の資を得る手段でもあった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の資どころか、生命の資を原稿の正統な報酬で得られなくても、文章の上や対人関係で一人前に絵書きを脅迫する腕があれば立派に喰つて行ける他人に知らない穴があるやうである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは何か事故が起こるとすぐに、彼らの唯一の生活の資本である運転手免状を取り上げるぞと脅かされる。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　樽野は、川向ふの母の居る町に住む筈だつたが母やＧの顔を見たり、あそこの倅であるといふことを知られてゐる町の人に顔を見られたりするのが無性に厭で、それのこの村には自分の蜜柑の山があつたのでそれを生活の資にあてゝ暮すつもりだつたのである。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一「過去は死したる過去として葬らしめよ」「われをしてわが日々のライフの友たる少年と少女とを愛せしめよ」「生活の資本は健康と金銭とを要す」「われをして清き生活をいとなましめよ」　こういう短い句は日記の中にたえず書かれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一年たたぬうちに父は病死して、母と二人暮しとなり、差し当り食うには困りませんでしたが、私はタイピストとなって生活の資けと致して居りました。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男たちは生活の資本として労働力をもつばかりであると同時に、愛する相手の女に与えるものとしては、私は君を愛する、という言葉しか持たない場合、この言葉が何事をも意味しないといえるであろうか、と。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゲルスの援助と、ニューヨーク・トリビューン紙から送られる一回僅か五ドルの原稿料が生活の資であった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの生活の資料を得る爲に痩せた力のない身體を都會の眞中まで運んでゆく義男の姿を、みのるは小犬を連れて毎朝停車塲まで送つて行つた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場で書いてやった返礼に、米一升をどさりと縁側に抛り出して農婦は帰っていったが、私の文筆が生活の資に役立ったのはこれが初めてだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊庭は、当分は名刺をつくらないのだと、妙な事を云ひながら、大津しもに対して、何の興味もないらしく、「やつぱり、布教師になるには、只の信者と違つて、布教師になる事が、生活の資本となるンですから、実は、これは、相当の金がいるンでしてね……」と云つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして妻子の生活の資にと思った家屋が差押えられて、彼等が忽ち路頭に迷わねばならぬ事を知った時が、思えば悪化の最初であった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "却て自分には彼等の様な穏かな眠が無い、夜も生活の資を得る為に働かねば成らないからとヌエは云つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの刑に処せられた者は、全くその生活の資料を失ってしまうのであるから、その酷刑であることは論を竢たないが、ハワイその他の蛮族中には、タブーを犯す者は、多くはこれを死刑に処するものとするものがあるのに較べたならば、これはむしろ大なる進歩と言わなければならない。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が産を治むる事をやめられてから、一家の主人役に立たれたあなたが、児孫の為に利益を計り権利を主張し、切々と生活の資を積む可く努められたのも、致方はないと云った様な御気の毒なわけで、あなたの方から云えば先生にこそ不平あれ、先生から不足を云われる事はない筈です。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼつぼつ書きものをしてどうやら生活の資を得られるやうになつてゐたからである。",
              "citation": {
                "source": "述懐",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは一頭の熊のために、一頭の熊が与うる生活の資料のために、血眼になっているから、山を眼中に置かない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜木笠、めんぱ（木製｜割籠）、お六櫛、諸種の塗り物――村民がこの森林に仰いでいる生活の資本もかなり多い。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕地も少なく、農業も難渋で、生活の資本を森林に仰ぎ、檜木笠、めんぱ（割籠）、お六櫛の類を造って渡世とするよりほかに今日暮らしようのない山村なぞでは、ほとんど毎戸かわるがわる腰縄付きで引き立てられて行くけが人を出すようなありさまになって来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局彼らは人形を舞わすとか、手品を使うとか、婬を鬻ぐとかいう様な、身分相当の方法によって、生活の資を求めねばならぬ。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその安住を得る迄に、生活の資を求むる事の困難は想像以上であったであろう。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその一方には、本来浮浪漂泊の俗を有する傀儡子の徒の、仏門に隠れて法師姿に生活の資を求めたものもまた少くなかったに相違ない。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって自らこれを生産するもののみが、自主独立の生活を営みうる訳で、その他のものは、みなこれに頼って生活の資を求めねばならなかったのです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは生活の資料であるのかもしれない。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、道徳とか愛国とかいう最も神聖なことを売り物にして、それで生活の資を得ている人たちに対してであった。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者わ、漁撈人としての立場から、鮭お生活の資料として観じているのであり、後者わ、宗教人としての立場から、鮭お神と観じて崇拝の対象としているのである。",
              "citation": {
                "source": "和人わ舟お食う",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "この信仰の背後にわ、これらの魚類や獣類お生活の資料として欠くことのできなかった、生活人――漁撈人乃至狩猟人――としての、アイヌの古い姿が、仄かに動いているのである。",
              "citation": {
                "source": "和人わ舟お食う",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
