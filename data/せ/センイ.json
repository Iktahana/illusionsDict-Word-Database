[
  {
    "uuid": "c981a948-2590-5d3a-b9bc-309ab6e8cfc2",
    "entry": "繊維",
    "reading": {
      "primary": "せんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
