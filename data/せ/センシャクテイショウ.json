        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浅酌低唱的半日の清遊だつた。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅酌低唱によく、風流詩歌を談ずるにふさわしい静夜だが……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の通客粋人が四畳半｜裡に浅酌低唱する、ここは辰巳の里。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩はもう、客を呼ぶのも止してしまい、お滝との祝言ごっこも断念し、二人の妾を左右に引付けて、夜と共に浅酌低唱する気だったのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前に出雲の国から出て来たこの山男も、金と時間があって、江戸の空気に同化して行く器用さがあったために、何時の間にやら一とかどの蕩児になり切って、浅酌低唱に、千金の宵を過す趣味も心得たのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに日本酒は浅酌低唱というところ、小さな猪口を口にふくんで、気長にチビリチビリやるべき性質の飲料である。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なんと、寛ろいだ勘太夫がお笛を相手に、いいきげんで浅酌低唱をたのしんでいる、強いられて二三杯｜舐めたお笛も、眼蓋をほんのりと染め眸子をうるませて、たいそうなまめかしい姿をしていた。",
              "citation": {
                "source": "明暗嫁問答",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
