    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sexual prodigy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "賦性豪邁なる柏軒は福山に奉職することを欲せず、兄も亦これを弟に強ふることを欲せなかつたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "青葉山のテッペンに天守閣を築かず、スキヤ造りの家を造って本丸にかえたり、石垣をきずかず自然にまかせて本格的な築城をしなかったのを、彼の本性豪放の性の然らしむるところであり、しかも彼の風流心の致すところであるとでも考えたら大マチガイであろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿や資性豪放濶達、一面芸術家にして一面武人、政治の才に至っては、岡山の藩主新太郎少将と、優に比すべきものがある。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
