  {
    "uuid": "c2579c33-a42a-5cb6-89bc-c9616df95fec",
    "entry": "井水",
    "reading": {
      "primary": "せいすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "well water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "井水の温度に関する彼の説明は奇抜である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "攝州の住吉だの、茨城、埼玉の某地だのの如きは、十二指腸蟲の巣窟で、そこの蔬菜井水を飮食すれば、危險至極で、其の附近には同患者の多いのは爭ふ可からざることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏コップに井水を盛れば器外に点滴のつくのはすなわちそれではないか」と。",
              "citation": {
                "source": "知と疑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土伝に、応神帝降誕のみぎり、この井水を沸かして洗浴し参らせたりという。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の住吉だの、茨城、埼玉の某地などは十二指腸虫の巣窟で、そこの野菜や井水を飲食すると危険至極で、その附近に同患者の多いことは争えないことである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論下総十五郎の啖呵は、大野ざらしの彫り物の中から、井水のように凄じく噴きあげている最中なのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "土中浸毒に因れる水脈の閉塞及び井水新鑿費増加。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "井水浸毒に因れる飮料の汚害。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒水浸入に因れる共有井水浚渫費の増加。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の寓舎の井水が長崎水品の第一だと云ふことは、此詩の註に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の説によると、その水、山水を用うるは上、江水は中、井水は下である。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "井水の汲み難い平野地の話から、海岸水辺の物語に移るのだ。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉川に遠いのが毎も繰り返えされる失望であったが、井水が清んだのでいさゝか慰めた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「従来あったものはそのままとし、新しく許した芝居興行、徐々に禁止をしようと思う」「結構のことに存じます」「養おうと思うぞ、尚武の気をな」「それこそ願わしゅう存じます」「二万有余の大部隊を率い、春日井水野山で鹿狩りをやる！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、これまで、かかる雑水のまじれる井水を飲むために、病人も出でたるに相違ないとの説であった。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆゑに家毎に此流を以て井水の代りとし、しかも桶にても汲べき流なれば、平日の便利井戸よりもはるかに勝り。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊アケローイオスの大いなる力も彼に並び得ず、潮流深く湧き返るオーケアノスの大威力、　195川こと／″＼く流れいで、海ことごとく湧くところ、あらゆる泉、底深き井水ひとしくいづる本、彼れなほ偉なるクロニオーン天上高く震ふ時、その恐るべき轟雷に、その霹靂におのゝけり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）、温泉并に井水の異状【地震以外の噴火の前兆】　鹿兒島造士館篠本講師に宛たる加治木中學校長田代善太郎氏の通信によれば、加治木温泉は一月七日頃より温度を増加し、又加治木、國分附近の井水は其の水量増加せりと。",
              "citation": {
                "source": "櫻島噴火の概況",
                "author": "石川成章",
                "note": "青空文庫"
              }
            },
            {
              "text": "避難民の言によれば、櫻島の北岸白濱に於ては爆發前井水涸れたりと云ふ。",
              "citation": {
                "source": "櫻島噴火の概況",
                "author": "石川成章",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿兒島市外西田、武、新照院附近の井水は濁り又は涸渇せる事實あり。",
              "citation": {
                "source": "櫻島噴火の概況",
                "author": "石川成章",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の片側に、一、二軒ずつの茅葺き屋根、中には噴出しの井戸もあって御休処の小旗、埃まみれの汗を拭って井水に浸したトコロテンの一｜啜り、なんともいえぬ味があった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さぞ、お寒かったであろうに」「おそれ入りますが、井水はどこにございましょうか」「水？",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井水を汲み上げる音がする。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "井水はかえって暖かく、白いものが立ち昇っているが、それを汲み上げる間に、水桶の底は凍りついてしまう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わしは、この井水をのむたびに、郷土の恩というものを、舌にも心にも沁み入って味うのだ』『和尚、また御説法ですか。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯今、冷たい井水を汲ませまする」「いや、道中、水は一切飲まぬことにしておる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬餌のほうなら源内のお手の物……オ、これや気絶している、数日の疲労があるところへ、ドッと助勢が見えたので、一時に心が弛んだのであろう」　井水を汲んで口へふくませ、自家の薬丹を印籠から取り出しなどしている間に、鴻山は、縛し上げた三次や二人の手下を引っ立て、一室にほうりこんで厳重にとざしてしまった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "みぶんのちがいと申しましても、ういてんぺんは世のつねのこと、とり分けえいこせいすいのはげしいのは戦国のならわしでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水〈しみづ、きよみづ、せいすい〉、神戸〈かうべ、かんべ、かんど、ごうど〉のごとき、一語数訓あり。",
              "citation": {
                "source": "平仮名の説",
                "author": "清水卯三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
