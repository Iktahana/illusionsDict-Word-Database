    "definitions": [
      {
        "index": 1,
        "gloss": "stateroom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甲板に立って帆柱の尖に仰ぐ星、船室で誰やらが欠びをする。",
              "citation": {
                "source": "星",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行て船室へ場を取りませねばと立上がれば婢僕親戚｜上り框に集いて荷物を車夫に渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか船首をめぐらせる端艇小さくなりて人の顔も分き難くなれば甲板に長居は船暈の元と窮屈なる船室に這い込み用意の葡萄酒一杯に喉を沾して革鞄枕に横になれば甲板にまたもや汽笛の音。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギラギラする光の中から、地下室の監房のような船室へ、いきなり飛び込んだ彼は、習慣に信頼して、ズカズカと皿箱をとりに奥へ踏み込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船室に潜り込んだが最後、もう頭が上がらぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく船室に引込んでいて再び甲板へ出ると、意外にもひどい雨が右舷から面も向けられないように吹き付けている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎はわれを導きてその船室に至り、貴嬢の写真取り出して写真掛けなるわが写真の下にはさみ、われを顧みてほほえみつ、彼女またわれらの中に帰り来たりぬといえり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何一つ腕に覚えがあるじゃなし、人の隙を窺って、鈎の先で船室小盗でもするのが関の山だ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば船室よりは甲板こそ乗客を置くべき所にして、下等室は一個の溽熱き窖廩に過ぎざるなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俵はほとんど船室の出入口をも密封したれば、さらぬだに鬱燠たる室内は、空気の流通を礙げられて、窖廩はついに蒸風呂となりぬ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　優しくも学生は盲人を扶けて船室を出でぬ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船室に在りて憂目に遭いし盲翁の、この極楽浄土に仏性の恩人と半座を分つ歓喜のほどは、著くもその面貌と挙動とに露れたり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の船室の前の廊下を通り上手に銅鑼は擦られてゐる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦月丸の舷梯へ達すると、私共の乘船の事は既に乘客名簿で分つて居つたので、船丁は走つて來て、急はしく荷物を運ぶやら、接待員は恭しく帽を脱して、甲板に混雜せる夥多の人を押分るやらして、吾等は導かれて船の中部に近き一｜等船室に入つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの※船でも左樣だが、同じ等級の船室の中でも、中部の船室は最も多く人の望む所である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と盛名隆々たる濱島武文の特別なる盡力があつたので、吾等は遂に此最上の船室を占領する事になつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元來膝栗毛的の旅行であるから、何も面倒はない、手提革包一個を船室の中へ投込んだまゝ直ぐ春枝夫人等の船室へ訪づれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひ終つて、少年が默つて點頭くのを笑まし氣に打ち見やりつゝ、他の三人を促して船室を出た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と少年とを其船室に送つて、明朝を契つて自分の船室に歸つた時、八點鐘の號鐘はいと澄渡つて甲板に聽えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "船室の中央に吊してある球燈の光は煌々と輝いて居るが、どうも其邊に何か魔性でも居るやうで、空氣は頭を壓へるやうに重く、實に寢苦しかつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と呟いた英國の古風な紳士は甲板から自分の船室へ逃げ込まんとて昇降口から眞逆に滑落ちて腰を※かした、偶然にも船の惡魔が御自分に祟つたものであらうか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夕食後例のやうに食堂上部の美麗なる談話室に出でゝ、春枝夫人に面會し、日出雄少年には甲比丹クツクの冐瞼旅行譚や、加藤清正の武勇傳や、また私がこれ迄の漫遊中の失策談などを語つて聽かせて、相變らず夜を更かしたので、夫人と少年をば其船室に送り込み、明朝を約して其處を去つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "前檣と後檣との間を四五｜回も往復する内に其惡感も次第／＼に薄らいで來たので、最早船室に歸つて睡眠せんと、歩む足は今や昇降口を一｜段降つた時、私は不意に一｜種異樣の響を聽いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言つて空嘯き笑つた最早問答も無益と思つたから、私は突然船長を船室の外へ引出した『あれが見えませんか、あれが、あの悲慘なる信號の光を見て何とも感じませんか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は宙を飛んで船室の方に向つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日までは、弦月丸の美麗なる船室に暮して、目醒むると第一に甲板に走り出て、曉天の凉しき風に吹かれながら、いと心地よく眺めた海の面も、今の身にはたゞ物凄く見ゆるのみである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此事を語つて櫻木大佐は笑ひながら『諸君は好奇心から禍を招いた罰として、海底戰鬪艇の竣成した曉にも、裝飾の無い船室に辛房せねばなりませんよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
