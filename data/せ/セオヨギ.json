          "literary": [
            {
              "text": "平泳ぎ、背泳ぎ、両抜手、片抜手、競泳、立ち泳ぎ――等を悉く試みた。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れると、背泳ぎをして悠々と四肢を伸して水の上に浮んだ。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、ちょっと、あがろうぜ」　短く笑って、高志は背泳ぎでプールサイドにむかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎は平泳で前進し、そして背泳ぎに移り、やがて手足の動きを中止した。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
