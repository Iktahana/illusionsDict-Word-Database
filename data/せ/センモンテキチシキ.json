[
  {
    "uuid": "8e7928e6-f637-5a20-95cb-435f4a003d9a",
    "entry": "専門的知識",
    "reading": {
      "primary": "せんもんてきちしき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
