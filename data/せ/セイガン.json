[
  {
    "uuid": "dd624a94-1434-5f2c-a797-a537244167ec",
    "entry": "正眼",
    "reading": {
      "primary": "せいがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
