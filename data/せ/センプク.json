[
  {
    "uuid": "b8aadfa9-d48d-5890-a26e-ed7b9b889ddc",
    "entry": "潜伏",
    "reading": {
      "primary": "せんぷく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
