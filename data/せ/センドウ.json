  {
    "uuid": "0321e025-3dbf-5da8-a145-725f24291db5",
    "entry": "船頭",
    "reading": {
      "primary": "せんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boatman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "韋駄天を叱する勢いよく松が端に馳け付くれば旅立つ人見送る人｜人足船頭ののゝしる声々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とほりかかつた小舟の中で船頭がその女房に向つて何かを云つた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹棹で大きな白い岩を突かうとした船頭は、帽子を水の中に落して、あつと言ふ間もなく、塵芥のやうに、黒い点となつて、引ツたくられてしまつた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく停まつて呼吸を入れてゐた船は、こつちを目がけて、走つて来る、難所中の難所といふ、やぐらの瀑へかゝつて来たときは、波から三尺ばかり船体が乗り出したと思ふと、水煙が噴水の柱のやうに立つて、船頭の黒い立像が、水沫の中から二体浮び出た、火影に映る消防夫の姿のやうに。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船の胴っ腹にくっついていた胴船の、船頭夫婦が、デッキの上で、朝飯を食っているのが見えた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手と火夫とが、船頭に何か冗談を云って、朗かに笑った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "｛１｝『船頭部屋』に「ここも都の辰巳とて、喜撰は朝茶の梅干に、栄代団子の角とれて、酸いも甘いもかみわけた」という言葉があるように、「いき」すなわち粋の味は酸いのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後ろを引詰め、たぼは上の方へあげて水髪にふつくりと少し出し」た姿は、「他所へ出してもあたま許りで辰巳仕入と見えたり」と『船頭深話』はいっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "売っている品は言わずもがなで、食ってる人は大概｜船頭船方の類にきまっている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "津々浦々に海の幸をすなどる漁民や港から港を追う水夫船頭らもまた季節ことに日々の天候に対して敏感な観察者であり予報者でもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出るよう」　船頭は大きい声で呼ぶと、小児の手を曳いたおかみさんや、寺参りらしいお婆さんや、中元の砂糖袋をさげた小僧や、五、六人の男女がおくれ馳せにどやどやと駈け付けて来て、揺れる船縁からだんだんに乗り込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩なら岸へ着いてからにしておくんなせえ」　船頭は叱るように制した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、内地の船頭が土左衛門を舟に積むのを忌み嫌うように。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六帰って来たおふみに、Ｔ「土左衛門は船頭だったよ」　と言う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「水の上でおまんま喰ってる船頭が」Ｔ「違いねえ」　と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「船頭が水に溺れる筈がねえ」　右門無言で立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人垣の背後で死体を覗き込んで居た一人の船頭がある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「罰が当ったんだ」　その声に右門船頭を見る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭、自分の舟に乗ろうとして居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六慌てて「待てッ」船頭の舟逃げる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「待てと言ったら待たねえか」　逃げる船頭が、Ｔ「人に喋るとあの男の様になります」Ｔ「罰が当ります、罰が」　その舟が橋の下へ来た時、　橋の上の欄干に凭れた深編笠の侍が居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭の舟がその真下を通る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭が顔中血だらけになってブッ倒れた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門、伝六に追えと命じ、己れは船頭の舟に飛び乗る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六舟を岸へ着けて川端を追う――　右門船頭を抱き起した。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送って浪之助、お内儀に、Ｔ「船頭どもは大丈夫だろうな」　お内儀が意味あり気に笑った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と歩調を合わして行きたいという誘惑を感じても、如何せんどうも私にはその誘惑に従う訳に行かぬ。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度跛を兵式体操に引き出したようなもので、如何せんどうも歩調が揃わぬ。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "にらいどに、おしよけてかないどに、おしよけてのろがすぢ、せんどう、しやうれ主がすぢ、せんどう、しやうれきみがおすぢ、みおんつかひ、をがましゆうがおすぢ、みおんつかひ、をがま此意味は、楽土への渡りどに、大船おしうけてあれば、此船に祈る巫女のすぢよ、せんどう、しませ。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日のあとのお手紙というのは、いまだに着きませんどうしたのかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
