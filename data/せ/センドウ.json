    "definitions": [
      {
        "index": 1,
        "gloss": "guidance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし案内の剛力（名を勝又琴次郎という）が、今まで幾回も登山したが、頂上へ登らずに、下山したのは、ただの一度しかないと「山運の好い男」を誇っているのが、何だか便りのようにも思われて、私と弟とは、その男に先導されて、闇の中を、行けるところまで行くことにした。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いその学校の卒業生の教授が校旗を先導しに入って来た。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、父親の老先生が朝食後ひどく眩暈を催して水にはいれぬことになってしまったので、小初先生が先導と決った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してすぐれた作家のすぐれた作品を読む時には、作家があたかも読者の「私」の心の動きや運びと全く同じものを、しかしいつでもただ一歩だけ先導しつつ進んで行くように思われるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一つの曲に修熟してその和音や旋律を記憶して後にそのレコードの音を専心に追跡しあるいは先導して行く場合にはかなりの程度までこの選択ができるように思われる。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は「社会の先導者」としての新聞のほんとうの使命を果たすためには、それはむしろやむを得ない当然の事ではないかと思っている。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　詩はいつも時流の先導に立つて、來るべき世紀の感情を最も鋭敏に觸知するものである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば詩の本質は主観であり、かつ元来貴族的のものである故に、西洋文明の精神が潮流するところでは、詩は必然に先導に立ち、文学の一切を越えて崇敬される。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れは踏まれたる石なり家はその上に建つべし「詩人」という言葉は、我々の混沌たる過渡期にあっては、実の芸術家を指示しないで、むしろ文明の先導に立つ、時代の勇敢なる水先案内――航海への冒険者――を指示している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻女山に向った甲軍は、地理に明かな、高坂弾正が先導で、月の西山に没する頃には海津を発し倉科の山越しに妻女山へむかった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮は宜しく先導の役目を尽すべしと云うのであった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉野時代　北條氏の滅亡するや、後醍醐天皇は、伯耆より御還幸の途につかせられ、兵庫迄お迎へ申し上げた楠木正成に、「北條氏を討滅し、今日京都に還幸出来るのは、偏に汝の忠節による」とのお言葉を賜ひ、正成の軍を先導として、京都に入らせられた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供らは N. L. D. の金文字を入れた黒リボン付きの紙帽子をかぶり、手んでに各国の国旗を持ち、楽隊の先導で甲板を一周した後に食卓についた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々ふたりは医師の先導で階段を上った。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仲買人の先導で五階まで昇ると、目の前に半開きの扉があって、そこを依頼人が叩く。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズと警部の先導で我々はぐるりと横門へと回った。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に背中を見せて歩いていた、偶然の先導者はもう無事に玄関近くまで行っている頃、門と、玄関との中程で、左側のかなめ垣がとぎれている間から、お酌が二人手を引き合って、「こわかったわねえ」と、首を縮めて※き合いながら出て来た。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "悦びを以って人々を先導すれば、人々はその苦労を忘れ、悦んでその困難を克服し、人々はその死を忘れる『易経（兌為沢卦・彖伝）』というのは、内兌外兌の応接の状態を、適切明白に説明する言葉であるが、これを君子（学問と徳が備わった人）と人々との間に例えれば、正にこの様である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田氏あたりが先導で作家移民団を引率して出かけてはどうか。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "『閑田耕筆』三に、摂州高槻辺の六歳の男児馬を追って城下に出て帰るに、雨劇しく川｜漲りて詮術なきところに、その馬その児を銜えて川を渡し、自ら先導して闇夜を無難に連れ帰ったので、まず馬を饗し翌日餅を隣家に配ったとある。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "真宗｜嗣ぎ立て即位式に先導せしむると鳴吠徘徊して意忍びざるがごとし、先帝の葬式に従えと諭せば悦んで尾を揺るがし故のごとく飲食す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "下で自動車を乗棄てゝ、彼は先導した。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の生物たちを、あまりからかわないで下さいまし」　バラの先導で、一行は恐る恐る室内に足を踏み入れた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ今回の事件は、中、英、国際の紛争に非ずして、実は黄白消長の関鍵であり、これを換言すれば、即ち、亜洲黄色人種が、白種に滅亡せらるるの先導に非ずして他にはない。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして国民の先導者らは文化に対する最も野蛮な暴行を犯した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一節に曰く野蛮の先導者暗黒時代の松明持孔子を祭りたる廟と今なほ二、三の考古家によりて愛読せらるる『論語』といふ古書における「子の曰く」を研究したる学校とのありし処は今の○○シヤボン屋のシヤボン庫のあたりなりといふ。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "不当なそして又恐らく不充分な先導によって読者への礼を失うことがありはしないかを恐れる。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、批評は読者代表が一般読者へ、作品を紹介し見方を先導することであって、つまり一つ一つ読書術を教えるという教訓性を脱し得ない文芸の一ジャンルと考えられる。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか大騒ぎで、大八車が三台、細引だの滑車だの手落ちのないよう万事気を附け、岡倉校長を先導に主任の私、山田、後藤、石川、竹内、その他の助手、人足など大勢が繰り込みましたことで、仕事は滞りなく予定の時刻の九時頃に終りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "木彫の楠公を天覧に供えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――この過程に於て彼が自己を語るところの言葉即ちアントロポロギーが生れると共に、このロゴスはひとつの獨立なる力となり、彼の經驗の先導となり、支配者となる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
