  {
    "uuid": "4cb5470f-d5ed-514f-a804-70e6d951a37b",
    "entry": "賤女",
    "reading": {
      "primary": "せんじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lowly woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かの賤女いかに美しとて、決して我を誘ひ寄すること能はざるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一賤女が領主の若殿に思はれるといふ幸福な位置をも忘れ果てゝ考へてゐる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて、ダイドーは自墮落女で、クレオパトラは赤面の乞食女、ヘレンやヒーローは賣女、賤女で、シスビは碧瞳ぢゃ何のかのと申せども、所詮は取るに足らぬ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテ時代にてはこれらの名を賤女、賤男の意に用ゐたりと見ゆ〔神の審判〕原文、〔神の思量の中にかれらを見る」。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "賤女の風はしているが京師の公卿に縁ある者、己と備わる品位と美貌は、恥を含んで一層美しく、右門の眼にも見えるのであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方本物の鳰鳥は、賤女の態に姿を変え、自分の居間に坐っていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　楽女とは、高官の邸に飼われて、賓客のあるごとに、宴にはべって歌舞吹弾する賤女をいう。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
