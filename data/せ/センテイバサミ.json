        "examples": {
          "standard": [
            {
              "text": "彼女は盆栽の木を注意深く形作るために、剪定鋏を使用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "剪定鋏を清潔に保ち、病気の拡散を防いでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "これらの剪定鋏は、片手での快適な使用のために設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この剪定鋏はひどく捩れておりますから鍛冶に一ぺんおかけなさらないと直りません。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の近代精神のより健やかなる展開のために先ず入用なのは、誤った技術家が非科学的に使う剪定鋏を引きこませること、及び悪条件にもちこたえつつ、どうやら命脈を保ちつづけて来た一条の民主的、合理的精神の幹に、全く科学的に考慮された接木をして、豊かな結実を可能にする方法ではなかろうか。",
              "citation": {
                "source": "よもの眺め",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
