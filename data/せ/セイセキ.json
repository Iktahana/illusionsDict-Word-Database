      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "results",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その成績を今問はないこととするならば、新短歌は、どうやら詩歌の新しい様式として、既に存在してゐるやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしあたつて先づ、新短歌の成績を考へてみよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は新短歌が現に挙げてゐる成績に偏執し過ぎたかも知れない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学校で少しでも佳い成績をとると、おどさは、世界中の誰よりも喜んで下さいました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして各所で成績を挙げるらしいのだが、無理もない、私も二三度ダマされた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが兄の話になると、――兄は中学に這入つてからといふもの、まるでお話にならない成績を取つてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が学年試験が済んで早く成績表の来るのを待つてゐる時、田中さんから手紙が来た。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やつと来た兄の成績表には「原級」と印肉の判然ついただが、小さな印が捺されてあつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりやあお前が成績を悪くするからだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「成績が悪ければこそ旅行でもしてみる方が好いのですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「併し成績を御覧なさい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の頭を学校の成績で見首つてゐる親も少しは目が開く。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして尠くとも家の者のためには私の不成績は私の頭の悪いことであつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝もＭのおつ父さんに会つたがね、あれはお前が入学当時の成績のことを思つて、あなたのお子さんはよくお出来でつて挨拶をしたが私は冷汗が出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍはお前の成績の悪いことをおつ父さんに話さないのだらうか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校ではわりに成績のよかった自分が、学校ではいつもびりに近かった亀さんを尊敬しない訳には行かなかった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時のあなたの成績次第でね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて、日々の糧の心配なく、専心に書物の中のことと、実験室の成績と突き合せながら、使える部分を自分の工夫の中へ鞣し取って、世の中にないものを創り出して行こうとする静かで足取りの確かな生活は幸福だった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度一｜学期の試験が済んでその採点も終りあとは三十一日に成績を発表して通信簿を渡すだけ、私のほうから云えばまあそうです、農場の仕事だってその日の午前で麦の運搬も終り、まあ一段落というそのひるすぎでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とならば、学術を真剣に研究する研究者の数が増加すれば、そのうちで相当立派な成績をあげて学位授与に十分な資格を具備する人の数も増加するのは数理的に当然のことだからである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の学校成績はあまりよくなかった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでは大学入学の資格はどうしてきめるかとの問に対して、「偶然に支配されるような火の試練でなく、一体の成績によればいい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の盲探しの手数のかかる方法に代わるに簡単で確実な合理的方法を考案してこれを実地に応用し良好の成績を収めた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子の事を思って居ればかえって学課の成績も悪くないのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争でなくても、これだけの心尽くしの布片を着込んで出で立って行けば、勝負事なら勝味が付くだろうし、例えば入学試験でもきっと成績が一割方よくなるであろう。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その成績は予想外に良かった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリとマルセーユ間で試験の結果、好成績を得たと伝えられている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜體中根は平素は決して成績佳良の方ではなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふまでもなく先生は私の三田｜文科生時｜代からの先生であるが、球突では始終喧嘩相手で、銀座裏の日｜勝亭で勝負を爭つて、その成績で風月｜堂の洋食のおごりつこをしたなどもしばしばである。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校へは一切小説本を持ちこまなくなったかわり、勉強もおろそかになってしまって、三年四年となるにつれて、私はせいせきが段々悪くなって、卒業する時は八十七分の八十六番位で出たと思う。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
