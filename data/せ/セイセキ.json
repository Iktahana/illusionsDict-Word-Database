[
  {
    "uuid": "5562b55b-90fa-5454-bb64-2f1af5e44aa4",
    "entry": "成績",
    "reading": {
      "primary": "せいせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
