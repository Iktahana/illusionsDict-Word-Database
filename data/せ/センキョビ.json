          "standard": [
            {
              "text": "選挙日はあいにくの雨だったが、朝から多くの人が投票所に足を運んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カレンダーの選挙日の欄に大きく赤丸をつけて、忘れないようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「選挙日は仕事だから、明日期前投票に行ってくるよ」と父が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そうするうちに、いよいよ選挙日となりました。",
              "citation": {
