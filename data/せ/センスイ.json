    "definitions": [
      {
        "index": 1,
        "gloss": "garden pond",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなたの家の泉水よりは少し廣いさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸後の森からは、小川が一度邸内の泉水を潜って、前の田へと灑がれていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその地図の立派なことは、夜のやうにまっ黒な盤の上に、一一の停車場や三角標、泉水や森が、青や橙や緑や、うつくしい光でちりばめられてありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少時して後、今度は泉水のある処から水を含んで来てそれで砂糖を溶かしその汁を吸うて巣に帰った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその地図の立派なことは、夜のようにまっ黒な盤の上に、一一の停車場や三角標、泉水や森が、青や橙や緑や、うつくしい光でちりばめられてありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナ・ステンのナナが酒場でうるさく付きまとう酔っぱらいの青年士官を泉水に突き落とす場面にもやはり一種の俳諧がある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその地図の立派なことは、夜のようにまっ黒な盤の上に、一々の停車場や三角標、泉水や森が、青や橙や緑や、うつくしい光でちりばめられてありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは空気の中に何かしらそらぞらしい硝子の分子のようなものが浮んできたのでもわかりましたが第一東の九つの小さな青い星で囲まれたそらの泉水のようなものが大へん光が弱くなりそこの空は早くも鋼青から天河石［※９］の板に変っていたことから実にあきらかだったのです。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは空気の中に何かしらそらぞらしい硝子の分子のようなものが浮んできたのでもわかりましたが第一東の九つの小さな青い星で囲まれたそらの泉水のようなものが大へん光が弱くなりそこの空は早くも鋼青から天河石の板に変っていたことから実にあきらかだったのです。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその地圖の立派なことは、夜のやうにまつ黒な盤の上に、一々の停車場の三角標、泉水や森が、青や橙や緑や、うつくしい光でちりばめられてありました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴたりとついて留まったが、飜然と此方へ向をかえると、渚に据った丘の根と、海なるその岩との間、離座敷の二三間、中に泉水を湛えた状に、路一条、東雲のあけて行く、蒼空の透くごとく、薄絹の雲左右に分れて、巌の面に靡く中を、船はただ動くともなく、白帆をのせた海が近づき、やがて横ざまに軽くまた渚に止った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の洞れたる泉水あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "病雁の夜寒に落ちて旅寝かな　　　　　　　　芭蕉僅かの花が散りければ梅は総身に芽ぐみぬ　　井泉水わが足跡人生ひてわれにつゞく朧　　　　　　地橙孫陽の前に鳥ないて安らかな一日　　　　　　　鳳車　これらの句を読んだ時、私は或る物を掴んだように思うた。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳原時代の前後、次ぎ次ぎに産まれる妹たちを脊中に縛りつけられ、遠遊びをしたこともあったが、負ぶったまま庭の柘榴の木に登り、手をかけた枝が析れて、弾みで下の泉水へどさりと堕っこちたこともあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの家の泉水よりは少し広いさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿のお屋敷の浅い泉水とくらべられては困ります。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の内は大きな泉水になって、まわりの樹木は焼けたり折れたりしていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一度来て中の方角は判っているので、赤松の生えた泉水の縁について往くと、其処に瀟洒な四畳半の室があって、蚊帳を釣り其処にお露が蒼い顔をして坐っていた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ階級の生活に許される程度のわずかな面積を泉水や植え込みや石燈籠などでわざわざ狭くしてしまって、逍遙の自由を束縛したり、たださえ不足がちな空の光の供給を制限しようとは思わない。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の中には右のほうに水のきれいな泉水があって、その縁に仮山があった。",
              "citation": {
                "source": "藤の瓔珞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時泉水に面した室の障子が開いて、そこから三十位に見える洋髪のな顔がこっちをむいて莞とした。",
              "citation": {
                "source": "藤の瓔珞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を入ると、泉水から續いた裏の山に山櫻の大きいのが二本ばかり、二分三分咲きかけてゐるのが見えた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "件の泉水を隔てて寝床の裾に立つて居るのが、一間真蒼になつて、桟も数へらるゝばかり、黒みを帯びた、動かぬ、どんよりした光がさして居た。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る／＼裡に、べら／＼と紙が剥げ、桟が吹ツ消されたやうに、ありのまゝで、障子が失せると、羽目の破目にまで其の光が染み込んだ、一坪の泉水を後に、立顕れた婦人の姿。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは十四畳ばかりの座敷で、南側は古風に刈り込んだ松の木があったり、雪見｜燈籠があったり、泉水があったりする庭を見晴している。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い泉水の底に眺める鯉のやうに淡く、吹奏者の姿は忽ち闇の彼方に吸はれて行つた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の書斎は倉と母屋の間にはさまつて、昼間でも薄暗く、縁の下まで伸びてゐる泉水に鯉の跳ねる音が寂を破るだけの静けさだつた。",
              "citation": {
                "source": "繰舟で往く家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は縁側の日向で、泉水を掘らうといふので弥三郎が職人に交つて泥まみれになつて働いてゐるのを見物してゐた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "キラキラと眼蓋の上に降りかゝる滝の様に明る気な木の葉の雫の中で彼が目を開けて見ると、庭先は泉水の痕かたもなく縁下まで濁水がたうたうとおし寄せてゐた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
