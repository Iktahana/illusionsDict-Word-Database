[
  {
    "uuid": "af0ec371-e7eb-515b-8980-737016f4c8bd",
    "entry": "生命感",
    "reading": {
      "primary": "せいめいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
