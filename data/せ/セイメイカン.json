    },
    "definitions": [
      {
        "index": 1,
        "gloss": "feeling of vitality",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軽部の同僚の若い教師たちは、軽部の死位で枯涸されなかったお君の生命感に想いをいたし、腹の中でそっと夫々の妻の顔を想い浮べて、何か頼り無い気持になるのだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の生命感ある「事実のもの」は、常に概念によって抽象されない、具象的のもののみである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの生命感ある芸術品は、すべて表現の上に於て、こうした具体的イデヤを語っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生命感は金魚に、恋のあわれは真佐子に、肉体の馴染みは秀江に。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "画きなぐつたやうな作品が多いが、このなぐり画きに生命感が横溢してゐるから妙である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民としても文学者としてもいわば変り種であるローレンスは、そのようなイギリスの中流、上流社会に対して感じるすべての妥協しにくさを、肉体的な感覚の世界へとけこむことで、宇宙的な生命感の中へ意識をとけこませることで、ヒューマニティーの解放を見出そうとした。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｄ・Ｈ・ローレンスは、あらゆる自然現象のうちに、ほとんど神秘主義に近い生命感をうけとった作家であった。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄瑠璃はその感情のインテンシチーの深さ、美的幻影の濃醇さ、道義的操持の強烈さ、ものを理窟で見ず、機微でとらえる生命感、すべてを永遠なる生滅の法の光りの下に見る宗教的観照の背景等に於て、人間性のあるべき健康なるわだちの上にあるものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの古事記の中に満ちている原色的な、疲れを知らぬ神秘な生命感と合調するものであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの作品は、とかくチャイコフスキーのスラブ的なものというものに足をとられて演奏されることが多く、その結果はかえって作品の生命感を弱めたり甘くしたりする場合が多い。",
              "citation": {
                "source": "音楽の民族性と諷刺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの壁画が感動的であるのは、画面の素晴らしさが、わたしたちに人間のもち得る美感の高さ、深さを、まざまざとした生命感で直感させることであった。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の僕はこの坂路を歩くとき、突然あたり一杯に生命感が漲ることがあつた。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "充実せる現在の宗教的なる生命感である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理的ならざる生命感の摘出に意を用ゐてほしいことである。",
              "citation": {
                "source": "戯曲集『鴉』の印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、ファルスの主題に、精神的な高さを求めることは無理であるが、作品の芸術的価値は、一つの主題から躍動する生命感の強弱によることをも考へたならば、古代のファルスは、その様式としての魅力を近代の舞台に伝へ、そこから、更に新しい時代の呼吸を続けるに至つたと見るのが至当であらう。",
              "citation": {
                "source": "ファルスの近代性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯曲の人物が、往々にして「不必要」な口を利き、「不必要」な動作をすることによつて、作品の「生命感」を稀薄にし、芸術的効果を減殺することがあるのは、ややもすれば「不必要」に幕を開けて置かなければならないからである。",
              "citation": {
                "source": "これからの戯曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろ」一篇は、その間の消息を語るに十分であるが、なほ、この「涙ぐましき小喜劇」をして、溌剌たる生命感の上に、一脈朗らかな詩味を漂はしめるものは、疑ひもなく作者の真摯な芸術家的「眼」である。",
              "citation": {
                "source": "美しき日本語と対話",
                "author": "戯曲「二十六番館」と「おふくろ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは主として、戯曲中の人物が、それぞれ一個の生命をもつて生活してゐるといふよりも、各人物の多少機械的な動きとの対立から、場面場面の生命感を作り出してゐる、乃至は、作り出さねばならぬやうな戯曲に於て、特に然りである。",
              "citation": {
                "source": "近代劇論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは、単なる「文学的」な感じ方であるか、或は、「演劇的」に、漠然とした「生命感」の享け入れに止まつてゐるやうに思ふ。",
              "citation": {
                "source": "演劇当面の問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また――一般に演劇の本質は動作に在りと考へられてゐるが、それは「言葉」と対立する意味のものでなく、「内面的動作」は屡々、言葉として表現されるのであるから、アクシヨンとは寧ろ、「生活力の発動」と解すべきであり、舞台上の生命感そのものである。",
              "citation": {
                "source": "演劇本質論の整理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、その生命感が、一定の空間で、一定の時間に流動する状態が、芸術的に表現された場合、これはもう、リズムといふ範疇以外に説明の方法はない。",
              "citation": {
                "source": "演劇本質論の整理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "客観的な人間描写の努力が、これを要求したとも云へ、対話といふ形式に生命感を盛る根本的な方法として、「語られる言葉」のイメージを適確に捕捉する修業を積んだからだとも云へると思ふ。",
              "citation": {
                "source": "最近の戯曲について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「せりふ」に於けるマンネリズムは、戯曲そのもののなかに於いても、屡々指摘し得るのであるが、俳優は、どんな「せりふ」にでも、その肉声化によつて、一脈の清新な生命感を吹き込み得なくてはならぬ。",
              "citation": {
                "source": "「抽斗にない言葉」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、かういふトオンは、作者の稟質にもよるのだが、これに舞台的生命感を盛るためには、是非とも、西洋劇の伝統たる「心理的リズム」の演技化を必要とするのである。",
              "citation": {
                "source": "劇壇暗黒の弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこに、一脈の生命感をとらへ得たら、その戯曲は、読まれたことになるのである。",
              "citation": {
                "source": "戯曲及び戯曲作家について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "国語教育の補助といふ見地からは、素朴で而も生命感の溢れたせりふで書かれたもの、さういふ標準で選んで下さることが根本的な着眼であると思ひます。",
              "citation": {
                "source": "文芸と国語",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心がたまたまさういふ機縁にふれて、何かしら直截な生命感とでもいつていいやうな、そのまますぐと納得のゆくある感じでもつて眼のさめるやうに覚える時、私はまたいつも、自然の方の側に不断にその用意の整つてゐたのがほのかに推し測られるやうにさへも思はれるのである。",
              "citation": {
                "source": "柘榴の花",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその繊細さ、精妙さのうちに「もちあそび」といってしまえない「生命感」がやどっていた。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅実なしみ／″＼した「生命感」が躍っていた。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命感や世界観のカテゴリーの拒否と共に、ヒュームは進歩の観念をも拒否する。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
