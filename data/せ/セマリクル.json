    "definitions": [
      {
        "index": 1,
        "gloss": "to be imminent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やゝ曇り初めし空に篁の色いよ／＼深くして清く静かなる里のさまいとなつかしく、願わくば一度は此処にしばらくの仮りの庵を結んで篁の虫の声｜小田の蛙の音にうき世の塵に汚れたる腸すゝがんなど思ううち汽車はいつしか上り坂にかゝりて両側の山迫り来る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と咄々人に迫り来る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人馬の交通を遮るべき厳寒の時節も漸く迫り来るのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は怖るべき危害の迫り来るを予知せずに突然死んだのであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「力」としての自然は、眼に見えざる、他の言葉にて言へば空の空なる銃鎗を以て、時々刻々「肉」としての人間に迫り来るなり。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "迫り来る心を押し鎮めて此文を認め終りぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その哀々として吾人の心に迫り来る理由はここにあるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……マイナス一分一秒……」　時計係は、自記航海図と時計とを見較べながら、刻々と迫り来る重大時刻について警告を続けた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七か月より臨月までの苦痛、労働のできる間は種類を選ばず労働して、刻々に迫り来る飢餓と戦った。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "迫り来る敵機　大胆にも飛行島の夜間偵察をおえた柳下航空兵曹長は、艦載機一号を操縦して暗の中を東へ東へとびつつあった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田は死の迫り来る影に直面して、思いの外平気でおれる自分を不思議に思った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「夏目漱石君はズーデルマンの『カッツェンステッヒ』を評して、そのますます序を逐うて迫り来るがごとき点をひどく感服しておられる。",
              "citation": {
                "source": "田山花袋君に答う",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界は無限なる圧力を以て我々に臨み来るものである、何処までも我々に迫り来るものである。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行為的直観的に我々の個人的自己に与えられるものは、単に質料的でもなく、単に否定的でもなく、悪魔的に我々に迫り来るものでなければならない。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の如く絶対過去として我々の個人的自己の根柢に迫り来るものに対して、我々は絶対未来の立場に立つものとして、行為的直観的に何処までも形成的である、創造的世界の創造的要素として何処までも創造的である（我々はいつも超越的なるものにおいて自己を有つ、この論文の終参照）。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界が絶対過去として直観的に個人的自己に迫り来るというのは、機械的にでもなく合目的的にでもなく、我々の魂の譲与を迫り来ることでなければならない。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる了解の対象としてでなく、信念の対象として、行為を唆すものとして、迫り来ることでなければならない。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与えられたものとして自己自身に迫り来るものに自己を奪われるかぎり、超越的一者において自己を有つ真の個物ではない。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（久保謙氏宛　庄原より）　　　迫り来る現実の中に　私はまだすっきりとしない病後の衰えのなかに生きています。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっはは、わっははという声々は行手を塞ぎ、又方々から赤い焔がめらめらと燃え上って迫り来る。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "日毎の親しい訪れは、せまりくる死の跫音のほかになかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂寥と不安をまぎらす友が、せまりくる死の跫音でありうるだらうか。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
