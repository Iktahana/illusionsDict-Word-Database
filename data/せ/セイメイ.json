    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(full) name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このひとの姓名は、はつきり覺えてゐる。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姓名を告げて漱石師より予て紹介のあった筈である事など述べた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し行くと路地の角の塀に掛けた居住者姓名札の中に「寒川陽光」とあるのが突然眼についた。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姓名は臨時にこしらえたものらしい。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある研究所の廊下に所員の姓名を記した木の札が掛け並べてある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、人によっては姓名の第一番の文字のところだけに真黒に指の跡を印している人があるかと思うと、また二番目の字を汚している人もある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ことによるとこの姓名札の汚し方の同じ型に属する人には自ずから共通な素質があるかもしれない。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も大井愛といったような姓名だと Oo I Ai で少し短かすぎ、また 〔Tyo^ So Ga Be Ta Ro^ Za E Mon〕 では少しごたごたし過ぎるかもしれない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一歩進んで姓名の代りに囚人のように三一六五八九二四といったような番号をつけるのも最合理的な一方法であるかもしれないが、そうなるのはやはり悲しい。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、宿帳を取り上げて、さらさらと姓名を書いた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲兵伍長は、腹立てゝいるようなむずかしい顔で、彼の姓名を呼んだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、自分の姓名が書かれてある下へ印を捺して、五円と、いくらか半ぱの金を受取った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官は電車を待たさないために車掌の姓名を自署さしてすぐに帰した。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚はその姓名を聞くと、合点が行ったのかして、急にくつろいだ様子になって、　アア、あの風吹烏から聞いておいでなさったかい。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間水涯に姓名を埋めて、平凡人となり了するつもりに料簡をつけたのであろう。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹介者に連れて行って貰って、些少の束修――金員でも品物でもを献納して、そして叩頭して御願い申せば、直ちに其の日から生徒になれた訳で、例の世話焼をして呉れる先輩が宿所姓名を登門簿へ記入する、それで入学は済んだ訳なのです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに儀式の進行順序や執行者の姓名等は正確に記載されるのが、通例ではなくとも、少なくも理想でありまた可能でもある。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姓名は、僕の主人公にぴつたり合つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姓名からして、すでに劃期的ではないか。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よりよい姓名もあるのだらうけれど、僕にはちよつとめんだうらしい。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一物は姓名も原籍も不明というので、例のとおり仮埋葬の処置を受けた。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "留めて留まらず、姓名を聞ても言ずに。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女姓名だけに金貸でも為そうに見える。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の弱い者が悪事を働いた時の常として、何かの言訳を自分が作らねば承知の出来ないが如く、自分は右の遺失た人の住所姓名が解るや直ぐと見事な言訳を自分で作って、そして殆ど一道の光明を得たかのように喜こんだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　三「僕は高橋信造という姓名ですが、高橋の姓は養家のを冒したので、僕の元の姓は大塚というです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
