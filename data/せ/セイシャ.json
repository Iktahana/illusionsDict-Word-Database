[
  {
    "uuid": "0d415c79-2a73-56e7-8603-08df1ce73554",
    "entry": "斉射",
    "reading": {
      "primary": "せいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "volley (of fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで約一キロメートル前方の山腹で一斉射撃の煙が見えたら、それから一秒余おくれて弾が来て、それからまた二秒近くおくれて、はじめて音が聞こえるわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ城濠の傍近く馬から下り、城兵に鉄砲の一斉射撃を受けながら、悠々としてお茶を三杯飲んだと云うような豪快な逸話を残している丈だ。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は同夜の十時に、全軍に令して一斉射撃で城中を威嚇して居た。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと一斉射撃にて、やがては掃蕩したりしが、冷然として、残忍に、軍は倦みたり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "新戦術　革命軍隊も最初はもちろん従来の隊形を以て行動しようとしたのであるが、横隊の運動や一斉射撃のため調練不充分で自然に止むなく縦隊となり、これに射撃力を与えるため選抜兵の一部を散兵として前および側方を前進せしむる事とした。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし軍事界は戦闘に於ける精神的躱避が大きいため単独射撃は一斉射撃に及ばぬものとしていた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルリ門の附近で、突如、騎兵の襲撃と一斉射撃が起った。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文化的祝砲の一斉射撃はどういう号令によって行われたのだろうか。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らがひざまずいて祈りはじめ哀号しはじめると、皇帝ニコライは慈愛深い父たる挨拶として無警告の一斉射撃を命じた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て端艇に待っていた水兵が、突然短銃で一斉射撃をした。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、右の二つの意見書が両軍対戦における最初の一斉射撃であって、それより双方負けず劣らず多数の意見書、弁駁書等を発して、これを議員、法律家、その他各方面に配附した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "名簿がベルギーへ達した一時間後にイグナチオ・ヴィテリオは、兵列の前に立って一斉射撃で処理されていた。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "止めないと、人造島の心臓部を止めてしまうぞ」この一言が、たしかに利いたとみえて、敵の一斉射撃が、急に止み、一隊は、その場に釘付にされたかたちとなった。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "己が脚をなくした時の片舷からの一斉射撃で、ピューの奴めも眼玉をなくしたのさ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲の音の次に、かなり間をおいてから、小銃の一斉射撃が聞えた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四人の射撃は幾らかばらばらな一斉射撃となったが、しかしその役目は果した。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が敏捷に一斉射撃を返したので、謀叛人どもはもう一度潰走したのだろうと思う。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はシルヴァーに罵詈の一斉射撃を浴せてやりました。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "その銃声が消え去るか去らないに、外からはそれに応じてばらばらな一斉射撃が起り、囲柵のあらゆる側から引続いて一弾また一弾と飛んで来た。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千挺の鉄砲なら、千挺づつ三段にわけて斉射する。",
              "citation": {
                "source": "鉄砲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう訓練のない男達の眼が、彼女に一斉射撃された。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "その号令の下に、道庵の子分たちは、勢い込んで一斉射撃をはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは予て充分の用意がしてあったものと見えて、前列が一斉射撃をはじめると、手桶に水を汲んで井戸から梯子、梯子から屋根と隙間もなく後部輸送がつづきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これはきまって女房から新たに一斉射撃を浴びせられる種になった。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "空に鳴る矢が天狗のいると覚しきあたりに風を切れば、物音はしないが、あらぬ方に向って斉射するとどっと笑いが虚空にひろがる。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスケッタ銃の一斉射撃は、恐るべき破壊力をしめし、一挙に道長の荷駄の半数を倒した。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "起つて諸君が団結して、肱鉄砲の一斉射撃をせられなば、男子は立どころに降伏して、卿等の足下にひれ伏し、泣いて哀を乞ふや必然なり。",
              "citation": {
                "source": "肱鉄砲",
                "author": "管野須賀子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝のような豪雨が降り、一斉射撃のような雷鳴が引っ切りなしに轟いて何千の人々の眠りを妨げた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
