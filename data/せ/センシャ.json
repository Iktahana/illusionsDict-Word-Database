[
  {
    "uuid": "4bb4d8dc-e6e2-5c4d-8184-9d62440ae47c",
    "entry": "占者",
    "reading": {
      "primary": "せんしゃ",
      "alternatives": [
        "せんじゃ",
        "うらないしゃ",
        "うらないじゃ"
      ],
      "is_heteronym": true
    },
    "grammar": {
