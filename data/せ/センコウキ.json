        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鉱石から有用な金属を取り出すために、選鉱機が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新の選鉱機は、効率と選別精度が大幅に向上している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この選鉱機、操作が少し複雑なので、マニュアルをよく読んでください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
