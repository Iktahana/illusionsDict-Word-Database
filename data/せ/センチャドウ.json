        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煎茶道の中興の祖、上田秋成が書いてゐる「もう何も出来ぬ故、煎茶を飲んで死をきはめてゐるばかりだ」と。",
              "citation": {
                "source": "新茶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は後世、煎茶道の中興の祖と仰がれるだけにこの齢になつても、この道には執著を持つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その著書は、煎茶道の祖述、漢印の考証にまで及んでゐる。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽焼の煎茶道具｜一揃ひに、茶の湯用の漆塗りの棗や、竹の茶筅が埃を冠つてゐた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍に九谷焼の煎茶道具が置いてある。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は帰るなり火鉢に手をかざしていると、「どうでござりました」　女将さんが煎茶道具をもって登って来た。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず妾宅に置いてあった玄鶴の秘蔵の煎茶道具なども催促されぬうちに運んで来た。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
