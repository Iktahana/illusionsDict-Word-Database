    "definitions": [
      {
        "index": 1,
        "gloss": "green tea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八｜疊の座敷に六｜枚屏風たてゝ、お枕もとには桐胴の火鉢にお煎茶の道具、烟草盆は紫檀にて朱羅宇の烟管そのさま可笑しく、枕ぶとんの派手摸樣より枕の總の紅ひも常の好みの大方に顯はれて、蘭奢にむせぶ部やの内、燈籠臺の光かすかなり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關で、私たち友達が留守を使ふばかりにも氣が散るからと、お氣にいりの煎茶茶碗一つ。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、紅い襷で、色白な娘が運んだ、煎茶と煙草盆を袖に控えて、さまで嗜むともない、その、伊達に持った煙草入を手にした時、――「……あれは女の児だったかしら、それとも男の児だったろうかね。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎茶も美味いと思って飲むが、自分で茶の湯を立てる事は知らぬ。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな残りなく食べ終り、煎茶茶椀を取上げながらいった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎茶道の中興の祖、上田秋成が書いてゐる「もう何も出来ぬ故、煎茶を飲んで死をきはめてゐるばかりだ」と。",
              "citation": {
                "source": "新茶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう何も出来ぬ故、煎茶を呑んで死をきはめてゐる事ぢや――　小庵を作るときにも人間の住宅に対する最後の理想はあつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は行燈をつけてから、煎茶の道具を取り出した。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は後世、煎茶道の中興の祖と仰がれるだけにこの齢になつても、この道には執著を持つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、煎茶の態度は正しかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その著書は、煎茶道の祖述、漢印の考証にまで及んでゐる。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽焼の煎茶道具｜一揃ひに、茶の湯用の漆塗りの棗や、竹の茶筅が埃を冠つてゐた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側と衝き当りに三段の棚があつて、上の方には紫の紐附の玉露の小｜壺が並べてあるが、それと中段の煎茶の上等が入れてある中壺は滅多に客の為め蓋が開けられることはなく、売れるのは下段の大壺の番茶が主だつた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、別に――あゝ、さう／＼近頃煎茶がとても好きになつたから、良い煎茶があつたら貰つて来て呉れつて――」　桂子は煎茶の箱を探して、それと当分の費用の金包みを添へてせん子に渡してやつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は煙草を嗜むにあらねど、憂を忘れ草というに頼りて、飲習わんとぞ務むるなる、深く吸いたれば思わず咽せて、落すがごとく煙管を棄て、湯呑に煎茶をうつしけるが、余り沸れるままその冷むるを待てり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お貞は煎茶を汲出だして、まず少年に与えつつ、「何だか知らないけれど、御婚礼をした時分は、嬉しくもなく、恐くもなく、まるで夢中で、何とも思やしなかったが、実はおじいさんと二人ばかりで、他所の人の居ない方が、御膳を頂く時やなんか、私ゃ気が置けなくて可かったわ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍に九谷焼の煎茶道具が置いてある。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何喰はぬ面もちにて殊勝気に礼拝し終り、さて和尚に請じらるゝまゝに庫裡に帰りて板の間に荒｜菰を敷きつゝ和尚と対座し辞儀を交して煎茶を啜るに、和尚座を寛げ、われにも膝を崩させて如何にも打解けたる体にもてなし、旅の模様を聞かせよと云ふ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十六日　午後Ｔ氏がわざわざ用意して手荷物の中に入れて来た煎茶器を出して洗ったりふいたりした。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時境は煎茶に心を静めていた。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十ぐらいの柔和なお婆さんが煙草盆を出してくれて、すぐに煎茶を振舞い、しかも、嫁が朝の間拵えたと、小豆餡の草団子を馳走した。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、紅い襷で、色白な娘が運んだ、煎茶と煙草盆を袖に控へて、然まで嗜むともない、其の、伊達に持つた煙草入を手にした時、――「……あれは女の児だつたか知ら、其とも男の児だつたらうかね。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は待合の病人の中を通り抜けて、北向きの小部屋に這入って、煎茶を飲む。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年の頃、石州流の茶をしていたのが、晩年に国を去って東京に出た頃から碾茶を止めて、煎茶を飲むことにした。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆栽と煎茶とが翁の道楽であった。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花房が大学にいる頃も、官立病院に勤めるようになってからも、休日に帰って来ると、先ずこの三畳で煎茶を飲ませられる。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よかよか、人ん事心配せんちゃよか、金持ちどもは卑俗くしなん、構いなはらんがよかたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこさか行ってしまいたい」「どこさか行く云うても、お前がとのような意地っぱりは、人が相手にせんと……」「相手にせんちゃよか！",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせんちゃんはどうしやした」「唯今ちょいとお詣りに。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸一｜番のおせんちゃんを乗せてるんだからの」「そうとも」「こうなると、銭金のお客じゃァねえ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
