  {
    "uuid": "673174c1-492a-5c83-9b65-8005e97280e2",
    "entry": "旌表",
    "reading": {
      "primary": "せいひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "praising someone's good deeds and making them widely known",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "巍は遼州の人、気節を尚び、文章を能くす、材器偉ならずと雖も、性質実に惟美、母の蕭氏に事えて孝を以て称せられ、洪武十七年｜旌表せらる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく上下を一挙に欺騙する官公吏を、あるいは褒賞し、あるいは旌表するこそ心得ね。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "元時代にはかかる場合に、人毎に絹五疋、羊兩頭、田一頃を賞賜して旌表したといふ。",
              "citation": {
                "source": "支那人の食人肉風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の太祖はこの弊風を矯正する目的で、洪武二十七年（西暦一三九四）に詔勅を發して、今後股を割き孝を行ふ者に對して、一切旌表を禁止して居る。",
              "citation": {
                "source": "支那人の食人肉風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど之も一時のことと見え、明・清時代を通じて、自己の股肉を割いて父母に進むることは、最上の孝行として社會に歡迎せられ、政府も亦多くの場合之に旌表を加へた。",
              "citation": {
                "source": "支那人の食人肉風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方官憲は江伯兒を母に孝なる者として、旌表すべく上聞した。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が太祖は江伯兒の行爲は人倫を絶滅せる、以ての外の非行として、大に怒り之を海南島に遠謫し、且つ禮部に命じて、將來に於ける孝行旌表の事例を詳議させた。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこの禁約も支那一流の空文で、爾後明一代を通じて、依然官憲も之を旌表すれば、民間も之を奬揚する（明の張鼎思『琅邪代醉編』卷二十參看）。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "不准旌表（『欽定大清會典事例』卷四百三、旌表節孝の條）。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "雍正六年（西暦一七二八）に、福建の巡撫から管内の孝子李盛山といふものが、肝を割きて母の病を救ひ、母の病は癒えたが、彼自身はその傷重くして遂に死んだから、この孝子に旌表を加へたいと申出た。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "已加恩準其旌表矣（『欽定大清會典事例』卷四百三、旌表節孝の條）。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "とて、特旨で旌表を加へられて居る。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾來二百年の間、依然として割肝※股の風が行はれ、官憲もその行爲が賣名の目的でない限り、之に旌表を加へて居る。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝行の者には、或は官爵を與へ、或は旌表を加へ、或は賦租を免じて奬勵する。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の二の理由を併せ考へ、徐元慶は死刑に處して國法を正し、然もその門閭や墓所に旌表を加へて、禮教を奬めるがよい。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "旌表と誅戮とは、一致することが出來ぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "禮として旌表すべき者を誅し、刑として誅戮すべきものを奬めては、國民をして適從する所に迷惑せしむといふのである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明時代にも清時代にも、すべて元時代と同樣に、割股行孝に對しては、旌表を加へぬ原則となつて居る。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面弊害を認めて、割股を抵制若くば禁約しながら、一面股を割く者に旌表を加へるのは、割股の動機が孝情に本づくと認めるからである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "雍正六年に福建の巡撫から、管内の孝子の李盛山といふ者が、肝を割いて母の疾を救ひ、母の疾は癒えたが、彼自身はその傷重くして遂に死去したから、この孝子に旌表を加へたいと申出た。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "已加恩准其旌表矣（『欽定大清會典事例』卷四百三、旌表節孝の條）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も清時代には、※股割肝の孝行に對して、概して旌表を加へて居る。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてさきの抵制や禁戒も、何時となく弛緩して、結局は復讎が公認に近くなり、割股が旌表を例とするに至るので、支那官憲の不徹底を非難する前に、一應はその孝道を尊重する衷情を諒とせなければならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
