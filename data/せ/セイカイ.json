    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(world of) politics",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四十年に一度の暑さの中を政界の巨星連が右往左往した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペインや、イタリーでは、ナポレオンの方を向いて、政界が退進した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "富豪であり、大地主であり、県政界の大立物である本田氏の、頭蓋骨にひびが入ったと云う、大きな事実に対して、証拠は夢であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界の人たらんとの希望からである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　均平も新聞でその顔を見た覚えはあるが、あの時代の政界を濁していた利権屋の悲劇の一つである。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年に政界にはいって、政友会のために働いたのだが、それは、ほんの四、五年間の事で、その前は市井の実業家だった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界にはいってからの、五六年の間に、財産の大部分が無くなったのだそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は代議士にいちど、それから貴族院にも出たが、べつだん中央の政界に於いて活躍したという話も聞かない。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党方面にも関係して若い癖に地方政界のボスのような形になっていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のお父さんはとにかく政界の第一人者ですからね。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治資金のことなら、一つ僕に心配させて下さい」　鉱三はあっけに取られていたが、やがて終戦になり、政界復帰の機が熟したと見ると、大阪へ電報を打った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に至りて我は既に政界の醜状を悪くむの念漸く専らにして、利剣を把つて義友と事を共にするの志よりも、静かに白雲を趁ふて千峰万峰を攀づるの談興に耽るの思望｜大なりければ、義友を失ふの悲しみは胸に余りしかども、私かに我が去就を紛々たる政界の外に置かんとは定めぬ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その策士陽虎が結局己の策に倒れて失脚してから、急にこの国の政界の風向きが変った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　子路が魯に来ている間に、衛では政界の大黒柱｜孔叔圉が死んだ。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新後の政界の力石じゃないか。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉山茂丸　杉山｜茂丸なる人物が現代の政界にドレ位の勢力を持っているか、筆者は正直のところ、全然知らない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は玄洋社の旧式な、親分｜乾分式の活躍、又は郷党的な勢力を以て、為政者、議会等を圧迫脅威しつつ、政界の動向を指導して行く遣口を、手ぬるしと見たか、時代｜後れと見たか、その辺の事はわからない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に政党屋流にも堕せず、玄洋社流にも共鳴しなかった彼、杉山其日庵主は、単身｜孤往、明治後半期の政界の裡面にグングンと深入りして行った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして左のポケットにはその時代時代の政界の大立物を二三人か四五人忍ばせつつ、彼一流の活躍を続けて来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に彼の左右のポケットに入れられている財界、政界の巨頭連が、どうして彼のポケットに転がり込んで来たか……もしくは転がり込ませられて来たか、知っているものは一人も居ないようである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそんな調子で現代日本の政界財界に、あらゆる機会を利用して法螺の空小切手を濫発している。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肝の潰れた博士を選んで法螺丸は、政界の有力者の処へ腎臓病のお見舞に差し遣わすのだから深刻である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄洋社の連中は何をするかわからぬという恐怖観念が、明治、大正、昭和の政界、時局を通じて暗々の裡に人心を威圧しているのもこの辺に端を発してるのではなかろうか。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界の落伍者の集まりである浪人の多い席であるから、話の落ちて往く処は現代の政党の攻撃であった。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ政界にも、教界にも、旗亭に集まるものも、富豪の骨牌卓のめぐりに寄るものも、社會といふ社會の限、必ず太郎｜冠者のやうなるものありて、もろ人の嘲戲は一身に聚まる習なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支那でも政界の混沌としている時代は退いて隠者になっている人も治世の君がお決まりになれば、白髪も恥じずお仕えに出て来るような人をほんとうの聖人だと言ってほめています。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯友社はこの全体の力で常に文壇に衝ったから、一時硯友社はあたかも政友会が政界に跋扈したように文壇を壟断して、操觚者も出版者も新聞雑誌社も硯友社に拠らざれば文壇の仕事は何一つ出来ないような形勢となった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くも利権割取を政治家の余得として一進一退を総て金に換えて怪まない今の政界にあっては沼南は実に鶏群の一鶴であった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のせいかいやに湿りぽく腰の落つきが悪い。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は台所の方を背中にして坐っていたが、化粧のせいかいつものように、溶けるような目の表情もないかわりに暗い影もなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
