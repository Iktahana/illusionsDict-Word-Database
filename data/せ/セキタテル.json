    "definitions": [
      {
        "index": 1,
        "gloss": "to hurry (up)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
