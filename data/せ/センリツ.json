[
  {
    "uuid": "cefe6b56-2e34-5123-b588-bd8e6ed1f2f7",
    "entry": "戦慄",
    "reading": {
      "primary": "せんりつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
