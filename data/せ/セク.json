[
  {
    "uuid": "8c94b158-2472-58bb-bd4c-25b8d601c660",
    "entry": "塞く",
    "reading": {
      "primary": "せく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-他動詞"
      ],
