  {
    "uuid": "930a7f96-95c0-534f-9faa-77b9e8982449",
    "entry": "晴嵐",
    "reading": {
      "primary": "せいらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mountain vapor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "並木の影涼しきところ木の根に腰かけて憩えば晴嵐梢を鳴らして衣に入る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の何々八景といふのは、白石手簡に八景のはじめは宋人か元人かにて宋復古と申す畫工云々とあるが、それは夢溪筆談に出てゐる度支員外郎｜宋迪の事で、平沙落雁、遠浦歸帆、山中晴嵐、江天暮雪、洞庭秋月、瀟湘夜雨、煙寺晩鐘、漁村夕照、之を八景といつて得意の畫であつたといふのである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふには竹藪があって、晴嵐がまき起ってゐる。",
              "citation": {
                "source": "夏の日のちぎれ雲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月一日（金曜）晴嵐　体格試験。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、木曜島暁嵐（濠洲）船踰赤道向濠南、熱帯風蒸暑不堪、驟雨夜来過木島、暁天涼気醸晴嵐。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "※堅い石場の約束に、話は積る雪の肌、とけて嬉しき胸の雲、吹払うたる晴嵐は、しん新地じゃないかいな……」今井　同志の誓いよりは女の方が大事か。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※堅い石場の約束に、話は積る雪の肌、とけて嬉しき胸の雲、吹払うたる晴嵐は、しん新地じゃないかいな……」今井　同志の誓よりは女の方が大事か。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
