        "examples": {
          "standard": [
            {
              "text": "寄席で披露された世話講談は、人情味溢れる語り口で観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世話講談の題材は、当時のワイドショーのように人々の関心を集めていたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "師匠の十八番である世話講談を聴くために、雨の中、多くのファンが詰めかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "長唄を歌って美音、尺八を吹き、琴を弾じ、古今の物語をよくして、弁舌｜爽かに、世話講談の座敷が勤まる。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "モダン文化のネオン燦然たる前には百年変らざる伝統の世話講談を繰り返している自分に忸怩たるものをおぼえ、思わずこうしたことを呟いてしまったのだろう。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "世話講談では邑井一、低声であったが味のある老練の話振り、「大岡政談」は聞き物であった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
