          "literary": [
            {
              "text": "参考のために、同会設立趣意書を左に写してみる。",
              "citation": {
                "source": "三保寮を訪ふ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生村を創設し、享楽場として自然を有意義に利用せんとする企は学生村設立趣意書に発表してある。",
              "citation": {
                "source": "尾瀬沼の四季",
                "author": "平野長蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "地中海石油株式会社の設立趣意書です。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が停止命令を出さない限り、明日の欧州主要新聞すべてにこの設立趣意書が掲載されます。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "設立趣意書には数値がなく、最少情報だけです。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
