        "examples": {
          "standard": [
            {
              "text": "彼女は、オークションで欲しかったレアな切手を競り落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、会場の雰囲気に飲まれそうになりながらも、ついにその絵画を競り落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "予算を少しオーバーしたが、彼はついにそのアンティーク家具を競り落とすことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
