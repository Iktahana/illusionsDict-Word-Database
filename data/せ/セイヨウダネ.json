    "definitions": [
      {
        "index": 1,
        "gloss": "Western cultivar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ日に甥のＮが西洋種の蘭の鉢を持って来てくれた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋種はあまり好かない。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋種の瓜の膚が緑葉の鱗の間から赤剥けになって覗いていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四　名は知らず、西洋種の見事な草花を真白な大鉢に植えて飾った蔭から遠くその半ばが見える、円形の卓子を囲んで、同一黒扮装で洋刀の輝く年少な士官の一群が飲んでいた。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々あの向うの硝子戸を取りまわした、濃い緑の葉の中に、今でも咲いている西洋種のぼっとりした朝顔の花を透かして、藤色や、水紅色の裾を曳いたのがちらちらする。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋種のサクランボのやうな形の心持大きいので灰色がゝつた青い実である。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは昔の人間であるせいか、西洋種の草花はあまり好まない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花壇にはいろいろ西洋種もまいて、天竺牡丹や遊蝶草などが咲いている。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむかしの人間であるせいか、西洋種の草花はあまり好まない。",
              "citation": {
                "source": "我家の園芸",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋いちごよりは日本のいちごの方が甘味が多い、けれども日本のいちごは畑につくつて食卓に上すやうに仕組まれぬから遂に西洋種ばかり跋扈するのだ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜の実でも西洋のよりは日本の方が小いが甘味は多い、けれども日本では桜の実をつくつて売るといふものがないのでこの頃では西洋種の桜の実がそろそろ這入つて来た。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　それは東洋種と西洋種とに分けられるかも知れない。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども多少の西洋種を交へて居ないものは殆んどないと云つてもいいだらう。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論作品そのものの中にも、多分に三田文学流の西洋種を交へて居る。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ比較的西洋種を交へない作家と云へば、徳田秋声氏位のものだらうと思ふ。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　葛西善蔵氏も、西洋種の交りは少いと思ふ。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに云ふ東洋種と云ふ意味は、西洋種の交つて居ないと云ふ事だ。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、私、ちぬ子さんにいいお土産を持って行こうと思うのよ」そう云って彼女が台所の流し場を指差したのを見ると、西洋種の紅い豆の花や、束の大きい矢車草がぞっぷりと水につけられていた。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花には萩、桔梗、菊、芒、鶏頭などの秋のものの外に西洋種も多く、今はサルビヤが真紅に咲きほこっていた。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間には、西洋種の瓢形南瓜や、馬鈴薯を堆く積んである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪放送局から毎月鳴り物入りの自作や西洋種の噺を放送しだしたのがその翌年あたりから。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "其節御恵贈の朝鮮産西洋種｜梨子、誠にやすらかにして美味、有難存候。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろカーネーションとか、チューリップとか、その他いろいろ西洋種の花を見るが、そのいずれを見ても、子どもの玩具に似て、単に赤いとか黄色いとかいうだけで、花にも葉にも持ち味が浅く、含蓄というものがない。",
              "citation": {
                "source": "味覚の美と芸術の美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　つらつら四季を通じてわが国｜草木の花を見るに、西洋種の花に引比ぶれば、ここに自から特殊の色調あるを知る。",
              "citation": {
                "source": "一夕",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし概して西洋種の草花の一般によろこび植えられるようになったのは、大正改元前後のころからではなかろうか。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "向島の百花園に紫※や女郎花に交って西洋種の草花の植えられたのを、そのころに見て嘆く人のはなしを聞いたことがあった。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "西瓜もそのころには暗碧の皮の黒びかりしたまん円なもののみで、西洋種の細長いものはあまり見かけなかった。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま信州に植えてあるものは、無論昔中国から伝えたのもあろうが、しかし明治年間にその実のよい西洋種を植えて改良を図ったと聞いたことがあった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母は、じぶんだけのためにとってある、西洋種の緑色の葡萄の皮を、手間とヒマをかけて丹念にむきながら、「あたしは、あなたを、かわいいとも……好きだとも、思っているわけじゃない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがほとんど西洋種になっていて、あの馬がわずかに日本の種が残っているらしいというので、それを買ってきたんです。",
              "citation": {
                "source": "美術学校時代の岡倉先生",
                "author": "板谷波山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
