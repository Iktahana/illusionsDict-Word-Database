    "definitions": [
      {
        "index": 1,
        "gloss": "snapping (of fixtures, mechanical equipment, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
