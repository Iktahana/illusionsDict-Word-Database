[
  {
    "uuid": "91809577-6394-5ffa-bb53-1791300cef55",
    "entry": "晴天",
    "reading": {
      "primary": "せいてん",
      "alternatives": [
        "せいでん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
