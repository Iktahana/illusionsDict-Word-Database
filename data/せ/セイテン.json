      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fine weather (i.e. little or no clouds)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仕合せに晴天が続いて毎日よく照りつける秋の日のまだなかなか暑かったであろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天晴天下の物知り顔をしているようで今日から見れば可笑しいかもしれないが、彼のこの心懸けは決して悪いことではないのである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の室生犀星を知つてる僕には、かうした犀星をみても自然であり、深く驚くこともなかつたが、彼の純一な人間的本質を知らない多數の會衆には、いかにそれが晴天の霹靂のやうに感じられたかと思ふと、ひそかに可笑しさをこらへることができなかつた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、あなたのいい方だってことはよく知ってるのよ」　二三日晴天が続いた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の天候異常で七月中晴天が少なかったために、何か特殊な、蜜蜂の採蜜資料になるべき花のできが悪かったか、あるいは開花がおくれたといったような理由があるのではないかとも想像される。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また晴天には現われず「晴れては曇り曇っては晴れる、村雲などが出たりはいったりする日に限って」現われるとある。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうでなかったら曇り日に見たセザンヌと晴天に見たセザンヌは別物に見えなければならないわけである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴天五日を打つと云ふ東京相撲の画びらの眼ざましさは、お末はじめ近所合壁の少年少女の小さな眼を驚かした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱を引き易い黒い色が晴天に遇つて雪を解かしたのだ。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日や四日の風のない雲のない晴天が續く。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更らに又三日か四日かの風のない雲のない晴天が續く。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣がかりな雲は、其の黒い影で、晴天にむら／＼と湧いたと思ふと、颶風だ。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸にも晴天だからいいようなものの、これが雨降りでもあったものなら、たまったものではない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば惚れ合つた男女二人が話をしながら横町を通る時でも、晴天の時と、雨天の時とは、話の調子が餘程違ひますからね。",
              "citation": {
                "source": "小説に用ふる天然",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　翌朝は晴天であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "また晴天の日、松林を走るやうな愉快な疳の高い日の氏は、腸の蟲まで笑ひこける、押へつけられないやうな氣がする。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは何とかして、愚色を装い、「本日は晴天なり、れいの散歩など試みしに、紅梅、早も咲きたり、天地有情、春あやまたず再来す」　の調子で、とぼけ切らなければならぬ、とも思うのだが、私は甚だ不器用で、うまく感情を蓋い隠すことが出来ないたちなのである。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども連日の東風弥々吹き募り、六月土用に入りても密雲冪々として天候朦々晴天白日を見る事殆ど稀なり（中略）毎日朝夕の冷気強く六月土用中に綿入を着用せり、夜は殊に冷にして七月｜佞武多（作者註。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永年連添う間には、何家でも夫婦の間に晴天和風ばかりは無い。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピイロロロピイ――これは夜が明けて、晴天に鳶の鳴いた聲ではない。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に青山の大通は道幅の広いだけに風の当が強く、晴天がつゞくと此寒い風が更に砂を捲いて顔にぶつかるのです。",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶鳶よ、晴天の喇叭卒、鳶よ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は在る、晴天と共に在る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と珍らしい樺太の晴天であったろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴天だ、すばらしい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時は五月の中旬、珍らしい晴天、　ロッペン鳥渡来後一ヶ月、　樺太は東海岸、北｜知床岬の南方十｜海浬、岩島は海豹島の前面、東方。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴天、　六月の上旬、成牡の来島に遅るること、二、三週後。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は晴天で朝から強い日が照りつけた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日に限って、こうまで目立ってたくさんにいっせいにはじけたというのは、数日来の晴天でいいかげん乾燥していたのが、この日さらに特別な好晴で湿度の低下したために、多数の実がほぼ一様な極限の乾燥度に達したためであろうと思われた。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
