    "definitions": [
      {
        "index": 1,
        "gloss": "battleaxe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、歩兵用｜戦斧をはじめに、洋剣の類も各年代にわたっていて、ことに、ブルガンディ鎌刀やザバーゲン剣が珍奇なものだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼の顎や猪の牙が、石弓や戦斧のあいだにおそろしく歯をむきだし、巨大な一対の鹿の角が、その若い花婿の頭のすぐ上におおいかぶさっていた。",
              "citation": {
                "source": "幽霊花婿",
                "author": "ある旅人の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の男は黒色の袍を着て戦斧をひっ提げ、次の大男は赤地｜金襴の戦袍に卍頭巾といういでたち。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんぷうきの風なんてじかに当るのは全く駄目です、それで二階がたまらなくなるのね、しめますから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいよせられたと思ったのは、どこかうしろの方から、大きなせんぷうきのようなもので、ふきつけられたのでしょう。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
