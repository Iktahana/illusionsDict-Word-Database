      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the other day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは、画の話ではありませんが、先日、新橋演舞場へ文楽を見に行きました。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日はじめてお目にかかった時から、そう思っていたのですが、御士族でいらっしゃるのではございませんか？",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、未知の詩人から手紙をもらった。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、或る外国の新刊本をひらいてみたら、僕の友人の写真が出ているのを見て、おどろいた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、未知の詩人から手紙をもらつた。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、先日、それが、はじめて、新聞に出て、世人を一驚させたことである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日南洋から手紙が來て「東京の家にはお前の唯一人の叔母たる小生の母と、小生の妹と家内と三人で侘しく留守をしてゐるから一度訪ねて行きなさい」とそれに書かれてありましたが、私はそれに返事して「僕にはとても行けない。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日かれは人力車に乘つて、三鷹村の私の家へ議論しにやつて來ました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、或る學生に次のやうなシルレルの物語詩を語つて聞かせたところ、意外なほどに、其の學生は喜んだ。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちは、先日のお禮として、これから龍宮城へ御案内しようとしてゐるだけだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ叫びも、狸の不意の訪問に驚き、かつは喜悦して、おのづから發せられた處女の無邪氣な聲の如くに思はれ、ぞくぞく嬉しく、また兎の眉をひそめた表情をも、これは自分の先日のボウボウ山の災難に、心を痛めてゐるのに違ひ無いと解し、「や、ありがたう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も、野道をひとりで歩きながら、ふと考へた。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、私は新宿の或る店へはひつて、ひとりでビイルを飮んでゐたら、女の子が呼びもしないのに傍へ寄つて來て、「あんたは、屋根裏の哲人みたいだね。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、或る外國の新刊本をひらいてみたら、僕の友人の寫眞が出てゐるのを見て、おどろいた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も横浜通の紫紅兄（山崎）の批評で凹んでいるとあるのも、横浜付近の誤謬記事を指摘されたことを、付随して言ったのだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先日バラの苗やカンナの球根を注文するために目録を調べたときに所在をたしかめておいた某農園がここだと分かった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あレあなたは先日何と云いました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五十一段の水車の失敗は先日の駆逐艦進水式の出来損ねを思い出させる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月二十七日『東京朝日新聞』）　　　　　　　　　五十五　　　　　　巨船モーレタニア　先日ルシタニア号の話を掲げたが、その姉妹船モーレタニア号に関する概略の数字だけ比較のために挙ぐれば、船の長さ七百六十フィート、幅が八十八フィート、トン数三万二千。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月二十八日『東京朝日新聞』）　　　　　　　　　五十六　　　　　　天然色写真　先日本紙に載せてあった天然色写真の新法よりなお一層新しい法が見出された。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日のリュミエール会社のオートクローム板は三色の澱粉を混合して作ったものだが、今度のは種板の上に三色の細い線を並べたもので大体の理窟は前のと変りはない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日島崎藤村氏を訪問したら、大作「夜明け前」を執筆中の氏の生活法が、殆んど室生君の日課とよく似て居るらしいので、僕も成程と感ずる所があつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は先日、僕の住んで居る鳴滝村のホン屋連中が数名協同してシナリオを一本書き上げた時の事です。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、手前共親分が石松つあんに色々御厄介に相成りましたそうで、親分に代りまして厚くお礼申し上げます」　と菓子包か何かを差し出して、　「失礼で御座いますが、どうかお納めなすって……」　源兵衛、考え込んでいる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらが主膳に、Ｔ「先日はお小夜さんが御世話になりまして」　と頭を下げる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京を立つとき心殘だつたのはこの編輯後記が書けてなかつたのと、先日飯島を見舞つたとき一度アイスクリームを持つて行くと約束してあつたことだ。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日思いがけなくＴ君が帰省して、いろいろ東京の様子や、最近の文学の傾向や人々の動静をきくことができた。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこにもまた、いろいろな手段がとられていて、先日東京から来たある友達の話によると、外米の入っていない県にいる親戚に頼んだり、女中さんの田舎へ云ってやったりして、送ってもらっている者がだいぶあるとか。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談ではあるが、先日｜田舎で農夫の着ている簔を見て、その機構の巧妙と性能の優秀なことに今さらに感心した。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の朝日新聞社の大展覧会でみた雅邦でもコケオドシとしか見えなかった。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
