[
  {
    "uuid": "9ed49733-4a6c-5f0f-9cd6-de786051fa8d",
    "entry": "先日",
    "reading": {
      "primary": "せんじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
