  {
    "uuid": "5c67a787-d354-5267-89d5-570b45fdbdcb",
    "entry": "脊髄",
    "reading": {
      "primary": "せきずい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
