        "examples": {
          "standard": [
            {
              "text": "本の背幅に合わせて、本棚の仕切りを調整した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「辞書のように背幅がある本は、こちらの厚手の梱包材を使ってください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このアルバムは背幅が5センチもあり、かなりの枚数の写真が収納できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女が屋根と屋根との間から落ちる、やつと自分の背幅程の日向に、自分のおかつぱの影を見付けた時に、小僧とお祖母さんの話声が聞え出してゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩揚げも卸したり、背幅もついて来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "背幅の厚い三穴バインダー二冊に、それぞれ三百五十枚の紙をはさみ、一枚の紙に一点のコピーを貼った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いくら公家衆でも、六百人の人足を出せはばかばかしい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
