[
  {
    "uuid": "1ec9cdd3-358d-53b7-b1df-bc5ac45d5a19",
    "entry": "千倍",
    "reading": {
      "primary": "せんばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
