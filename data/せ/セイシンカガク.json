[
  {
    "uuid": "9a16429e-bee4-5fc2-a95b-eab09b234194",
    "entry": "精神科学",
    "reading": {
      "primary": "せいしんかがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
