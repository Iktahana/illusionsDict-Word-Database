    "definitions": [
      {
        "index": 1,
        "gloss": "worldly wisdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "都会の中央へ戻りたい一心から夢のような薫少年との初恋を軽蔑し、五十男の世才力量に望をかけて来た転機の小初は、翡翠型の飛込みの模範を示す無意識の中にも、貝原に対して異性の罠を仕込んでいた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど私は、彼より世才もあり金儲けの術も知っています。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風の茶亭とは名のみにて、今の世の浮世才子が高く笑ひ、低く語るの塲所なり。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで世才はおありですか？",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬事の周旋は、一行中の世才に長けたる山根氏にまかせて、そのさしづのまゝに切り上ぐ。",
              "citation": {
                "source": "南洲留魂祠",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に世を推移る世才に長けているから、硯友社という小さい天地にばかり跼蹐しないで、早くから広い世間に飛出して※翔していた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、首を振つて、好い加減に口笛を吹きながら、合間に、世才に通ずる楽天家らしい口吻で云つた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世才ある風の任意漂い行く意味にあらずして、世界の大勢に応じ、なお個人性を失わず、而して世界の潮流に先ちて進むを以て教育の最大目的とせねばならぬ。",
              "citation": {
                "source": "教育の最大目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "当世才子ではいけません。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が一度大所へ出でゝ当世才俊と呼ばるゝものと勝負を決したしてふ志願は成れり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木松塘が祝賀の絶句に、「絶世才華絶世姿。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには世才に長けたおつたの伯父が、巧みに魂膽をめぐらしたのであつた。",
              "citation": {
                "source": "玉の輿",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "世才があればこんな混乱期にこそ世の中の随所に空洞を見つけて縦横に金儲けの手を打つこともできるわけだが、私のやうなものはハンコ屋にでもなるのが最上の思ひつきだつたのだ。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "この周の弟は世才がないので家を治めてゆくことができず、数年の間に家がたちまち貧しくなった。",
              "citation": {
                "source": "成仙",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "世才は勿論学才もない。",
              "citation": {
                "source": "天成の詩人",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "学才と世才とに教養を加へてすぐれた批評家で、また詩の最上の愛好者ではあつても、決して天成の詩人ではなかつた芥川が犀星の野生的な詩魂に驚歎したのは当然の事で、芥川の詩を解することの深かつたのを証するものであらう。",
              "citation": {
                "source": "天成の詩人",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど元来世才に長けたる男なれば、巧みにそのボロを押隠して少しも人に知らさねば、これと同窓の因ある花子の兄さへこれを知らず。",
              "citation": {
                "source": "当世二人娘",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方の番頭は充分世才に長じ、人情の弱点を心得ているから、決して初めからお金などを持っては来ないのです。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも頭の良い平次には、少し勘定の合わないガラッ八がちょうどいい相棒であったように、石原の利助のような、年を取った伝統主義の岡っ引には、こうした世才に長けた子分も必要だったのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も頭の良い平次には、少し勘定の合はないガラツ八が丁度いゝ相棒であつたやうに、石原の利助のやうな、年を取つた傅統主義の岡つ引には、斯うした世才に長けた子分も必要だつたのでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その留板の版木が一つか二つ私の家にあったが、父は世才にうとい、ごく単純な人間だったので、その出版事業のため本屋から大変迷惑をかけられたり、何かしたことがいくつか重なったために、神経衰弱になったのだろうと思っている。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を見るの明あって世才に富んで居るにかかわらず非常に親切でまた義に富み、決して人を欺くというような事はしない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、Faraday as a Discoverer. John Tyndall.1868 年初版. 1870 再版. 199 頁.チンダルはファラデーの後任として王立協会の教授になった人で、講演が上手であり、世才もあり、有名だった人である。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はベレニー伯爵夫妻をも、味方だと自称する多くの当世才士らと同様だろうと想像した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問や世才は兎に角、人間としては君が一番出来上っている」「これだ／＼」　と安達君は又眉毛に唾をつける真似をした。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が東京専門学校に望むところは権力に屈して一身の安泰をはかろうとする当世才子の出現ではなくて、真に国民を永世に利するの士のあらわれることである。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御三卿の臣といえば、直参も同様だし、やがては、徳川家の第二の柱石でもある青年たちが、あまりに、世才に走り、文化に洗練されすぎて、規模が小さく、線が細く、時勢を小馬鹿にしているふうの賢さが、見え透いて、嫌な気がした。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
