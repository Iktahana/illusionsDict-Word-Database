  {
    "uuid": "7dc0985d-4e1c-5f77-a961-29ae548dce07",
    "entry": "精義",
    "reading": {
      "primary": "せいぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "detailed exposition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "往時日本で刀剣を尊んだに付け、鮫皮を鑑賞する事夥しく、『鮫皮精義』等の専門書もあり、支那、ジャバ、前後インド諸国の産を夥しく輸入したが、予先年取り調べてペルシア海の鮫皮がもっとも日本で尊ばれたと知った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田学士の『化学精義』は大分進んだでしょう。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "精義入神、聰明竪也。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "精義神に入るは、聰明の竪なり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "美濃部博士の『憲法精義』が以前の滝川問題式に議会の問題として提出されたが、これは初めはあまり相手にされずに終ってしまった。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
