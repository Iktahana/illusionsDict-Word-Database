        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まるで俄づくりの県会議員の選挙事務所のような、プロザイック〔Prosaic ＝おもしろくなく、殺風景な〕な眺めである。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に机まで出し、選挙事務所のような有様だ。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそではありませんな』『わしは、二枚舌は使わん』　三木は、横っ飛びに自分の選挙事務所へ飛んで帰った。",
              "citation": {
                "source": "春宵因縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、三木の選挙事務所へ頼母木の方から使者がきて、昨夜の演説会の費用を半分出せと言ってきた。",
              "citation": {
                "source": "春宵因縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙事務所で使ったイステーブルまで景気よく燃しちゃったんです。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝元村の選挙事務所から国道をバスで帰つて来た。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの選挙事務所でも、県会議員の動静が知れわたるたびに論難が行われた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人が酒の四斗樽を一本寄付してくれたので、選挙事務所に千余名が集まり、大祝杯をあげたが、あまりの雑踏でデモのような状態となり、数十名の警官が出て取締りに当った。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正保寺町の自宅の表に、「厳正中立・玉井金五郎選挙事務所」という看板がかかげられた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "原田は、一日に一度は、かならず、金五郎の選挙事務所に顔を出す。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛べ」　その声で、勇ましい伝令が、選挙事務所まで、全速力で、自転車を走らせる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "益戸の勝と、加藤好夫選挙事務所の人迎へに来り、小松川の二つの小学校で、歴史的につまらん思ひをしつゝ、まづい応援演説をやり、大クサリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二幕二場の、選挙事務所の場は、嫌ひだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
