        "examples": {
          "standard": [
            {
              "text": "スイスにあるＣＥＲＮでは、巨大な加速器を使って宇宙の始まりを探る実験が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ＣＥＲＮで発見されたヒッグス粒子は、物理学の世界に多大な衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "実は、私たちが今使っているワールドワイドウェブ（WWW）は、ＣＥＲＮで考案されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "各国に関連の施設を持つ、欧州原子核共同研究所（ＣＥＲＮ）で、「知識の共有システムを作ろう」として始まった作業がきっかけです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今朝汽車に乗って、同じ線をアルプナッハの湖にそうて、サルネルゼーの片ほとり、ザクセルン Sachseln の停車場に降りた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザクセルンの停車場から、湖の岸をぐるっと廻って、北はずれのサルネンの村に来た。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、りっぱに負債を払いあげてから、娘をつれてリュセルンの町に姿を隠し、人に知られずに、みじめなくらしをすることになった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその前の日に讀んだトルストイの「リユセルン」の最後の一節に關したことであつた。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
