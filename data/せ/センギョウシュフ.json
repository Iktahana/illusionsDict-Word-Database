        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は専業主婦として、毎日家族のために栄養バランスを考えた食事を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「専業主婦だって立派な仕事よ、休みがないんだから」と母が笑いながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供が幼稚園に入ったので、専業主婦からパートタイマーへ復職することを考え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "格言として、夕食は別部屋で食すべし、というのは専業主婦に関する限り、正しい。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
