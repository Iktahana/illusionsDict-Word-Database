[
  {
    "uuid": "2a817599-4f13-5ec5-a81b-54c9e42d1ff7",
    "entry": "千分",
    "reading": {
      "primary": "せんぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
