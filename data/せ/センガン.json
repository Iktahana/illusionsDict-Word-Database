  {
    "uuid": "b26b18f0-2762-5cc9-9c8e-473c6f3a3b2f",
    "entry": "洗眼",
    "reading": {
      "primary": "せんがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "washing one's eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かうして乳汁の洗眼が行はれた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗眼一つしたことがなかったので、不安はよけい激しかった。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れていますよ」　私は洗眼をしてもらい、眼薬をさしてもらって外へ出た。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼科の治療日にはかかさず出かけて洗眼し、薬をさしてもらった。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは吸入器を眼にかけて洗眼と罨法を同時に行なうのである。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の手術をした男は経過良く、今日は洗眼の時水が見えたと言つて手を打ちならし、はしやいでゐる。",
              "citation": {
                "source": "重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その苦痛を天城先生に訴えたら、洗眼器をかして下さった。",
              "citation": {
                "source": "温浴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は温泉につかりながら、天城さんが持ってきて下さった洗眼器で、目に噴水の水をあてる。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と大声を出したら、「そこの棚にあります」見るとアルのでそれを洗眼コップに入れて目を洗ったら、ピリッとする。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、中泉眼科へ寄り、洗眼し、本社の那波氏のところへ平野と共に行き、座員撮影手当の件、その他二三片付け、日劇地下の蛇の目ずしで夕食、日劇のエノケン実演「大陸の花聟」を見る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼は洗った方がいゝときゝ、洗眼器を買って洗ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼科中泉へ寄り、洗眼、血膜炎らしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時近く家を出ると、眼科へ寄る、洗眼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "点薬して、洗眼薬と洗ふ器具を貰って、東宝本社へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗眼、無理せず、寝る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗眼薬が眼に冷たい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終るとすぐ眼科医へ行き、洗眼点薬。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
