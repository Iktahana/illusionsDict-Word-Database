  {
    "uuid": "4d9690d2-165c-5a28-ab79-f8a8e66e259b",
    "entry": "迫り",
    "reading": {
      "primary": "せり",
      "alternatives": [
        "セリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stage elevator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤い攣れた髪毛が額に迫り、その下で紅と栗との軟い顔がほつとり上気してゐる。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の暮家路に遠き人ばかり　薄暮は迫り、春の日は花に暮れようとするけれども、行路の人は三々五々、各自に何かのロマンチックな悩みを抱いて、家路に帰ろうともしないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園にて灼きつく如く寂しさ迫りひとり來りて園内の木立を行けば枯葉みな地に落ち猛獸は檻の中に憂ひ眠れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨り橋を渡るも灼きつく如く迫り心みな非力の怒に狂はんとす。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時薄暮に迫り、分列の式既に終りて、觀衆は皆散りたれども、灰色の悲しき軍艦等、尚錨をおろして海上にあり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ曇り初めし空に篁の色いよ／＼深くして清く静かなる里のさまいとなつかしく、願わくば一度は此処にしばらくの仮りの庵を結んで篁の虫の声｜小田の蛙の音にうき世の塵に汚れたる腸すゝがんなど思ううち汽車はいつしか上り坂にかゝりて両側の山迫り来る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪気な可憐な、ほとんど神に等しき幼きものの上に悲惨なる運命はすでに近く迫りつつありしことを、どうして知り得られよう。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "動くは逢見たき欲よりなり、騒ぐは下に恋しければなり」　女は暫時※惚として、そのすゝけたる天井を見上げしが、蘭燈の火かげ薄き光を遠く投げて、おぼろなる胸にてりかへすやうなるもうら淋しく、四隣に物おと絶えたるに霜夜の犬の長吠えすごく、寸隙もる風おともなく、身に迫りくる寒さもすさまじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人がよみつる歌の事などさま／″＼胸に迫りて、ほと／＼涙もこぼれつべく、ゆかしさのいと堪へがたければ、閨の戸おして大空を打見あぐるに、月には横雲少しかゝりて、見わたす岡の若葉のかげ暗う、過ぎゆきけんかげも見えぬなん、いと口惜しうもゆかしうも唯身にしみて打ながめられき。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天プラや、すしなどがあんなに恐ろしい鬼気をもって人に迫り得るという事を始めてこの画から教えられる。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは各の素質、境遇に依つて必然に二つの傾向に分れるのだと思ふが、前者はその人間が直接人生に触れてゐると云ふ意味に於て表現が比較的手易く真に、或は自然に迫り得る強味がある。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早く豆洋燈に火を移しあたりを見廻わすまなざし鈍く、耳そばだてて「我子よ」と呼びし声｜嗄れて呼吸も迫りぬと覚し。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に三時間の後、黄河に沿うて側面から迫りつゝあった方振武が到着した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　現在、吾々の眼前に迫りつゝある戦争は、どういう性質のものであろうか。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　なお、新しい帝国主義戦争の危機――即ち、三ツの帝国主義ブルジョアジーが××の××的分割をやろうとしていることゝ共に、ソヴェート・ロシアに対する他のもろ／＼の帝国主義国家が衝突しようとする危機も迫りつゝあることに、注意を喚起しておきたい。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は大畝りに、乗上り乗下つて、やがて、野は迫り、山来り、巌近づき、川灌いで、やつと砂煙の中を抜けたあたりから、心細さが又増した。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は入江の口、水狹くして深く、陸迫りて高く、此處を港に錨を下ろす船は數こそ少いが形は大きく大概は西洋形の帆前船で、出積荷は此濱で出來る食鹽、其外土地の者で朝鮮貿易に從事する者の持船も少なからず、内海を往來する和船もあり。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は入り江の口、水狭くして深く、陸迫りて高く、ここを港にいかりをおろす船は数こそ少ないが形は大きく大概は西洋形の帆前船で、その積み荷はこの浜でできる食塩、そのほか土地の者で朝鮮貿易に従事する者の持ち船も少なからず、内海を行き来する和船もあり。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の麓に見ゆるは土河内村なり、谷迫りて一｜寰区をなしことさらに世と離れて立つかのごとく見ゆ、かつて山の頂より遠くこの村を望み炊煙の立ちのぼるを見てこの村懐かしくわれは感じぬ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は下を向いた儘、心は差迫りながら、それで居て閑々として、波の階律に比べて私の動悸が何の位早く打つかを算えて居た。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「平に一同、」「一同｜偏に、」「押して伺い奉る、」村人らも異口同音にやや迫りいう――巫女　知らぬ、とおっしゃる。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と咄々人に迫り来る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」清水の雫かつ迫り、藍縞の袷の袖も、森林の陰に墨染して、襟はおのずから寒かった。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は皆さんが、たといいかなる手段をもってお迫りになろうとも、自分でこの革鞄は開けないのです。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人馬の交通を遮るべき厳寒の時節も漸く迫り来るのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は怖るべき危害の迫り来るを予知せずに突然死んだのであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十六）　お葉が黙って考えているので、重太郎は又もや迫り寄った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、冬子も強請むように迫り問うた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つく／＼ぼうしがいらだゝしく鳴く、その声が迫りくるやうにこたえる。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島あたりへ来ると、寒さがみりみり総身に迫り、窓硝子に白く水蒸気が凍っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
