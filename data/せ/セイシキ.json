      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "formal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文化文政には正式な髪は丸髷と島田髷とであった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "正式な平衡を破って、髪の形を崩すところに異性へ向って動く二元的「媚態」が表われてくる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の人は正式の教育を受けない独創的気分の勝った人に往々見受ける事で甚だ惜しむべき事である。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、以上述べたのは、当時、おのおの別々の音として意識せられ、文字の上に書きわけられているものの正式な発音であって、実際の言語においてはそれ以外の音が絶対に用いられなかったのではない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは漢字の正式の読み方として我が国に伝わったのであって、古くから日本語に入った漢語においては、もっと日本化した音になっていたであろうが、しかし正しい漢文を学ぶものには、この支那の正しい読方が平安朝に入っても伝わっていた。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような拗音は、恐らく漢語として古くから学んだものであろうと思われますから、奈良朝においても正式に漢文を読む時には多分拗音があったろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間へ出て私達の信ずるところを説く、私達共同で出來る正式な方法としてはさしあたりそれ以外にはない。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際北京の正陽樓や小有天あたりで正式な支那料理を食ふなどは、君子人にとつてはちつと險呑な事だと云へぬでもない。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後おもちゃ屋で虫めがねのレンズを買って来て、正式の幻燈器械を作ろうとしたが失敗した。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮な暴力的なことをやらなくたって、正式に娘を貰えばいいじゃないか、それなら俺れだって賛成だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一度、中津は正式に嫁に貰って、孫のように可愛がってやったら！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世間の人ばかりでなく、奉行所関係の役人たちでも正式の記録を作製する場合は格別、平常はやはり世間並にすべて拷問と称していたらしい。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえにもいう通り、今までの笞打、石抱き、海老責は正式にいう拷問ではない。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし嫉妬の感情は判ります」　信吉は正式の結婚はしなかったが、女と同棲した経験はあった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが田村道子となっているのは、たぶん新聞の誤植であろうと、道子は一応考えたが、しかしひょっとして同じ大阪から受験した女の人の中に自分とよく似た名の田村道子という人がいるのかも知れない、そうだとすれば大変と思って、ひたすら正式の通知を待ちわびた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は其抒情文に依つて多少僕の文學的の才を認めてくれたのか、文學者たることを許してくれたと同時に、當座の小遣ひとして金を十圓だけ托送して呉れて、後は月々正式に送ると云ふことである。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその評判が最高度に達した頃に村役場へ「勇作を娘の婿養子にする」という正式の届出が後家さんの手で差し出されたので、その評判は一層、輪に輪をかけることになった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "孩児の頃より既に音律を好み、三歳、痘を病んで全く失明するに及び、いよいよ琴に対する盲執を深め、九歳に至りて隣村の瞽女お菊にねだって正式の琴三味線の修練を開始し、十一歳、早くも近隣に師と為すべき者無きに至った。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすつかり正式の読経の姿勢になつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は贅沢と正式に結婚する費用と時間と無駄を惜しむ。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校から正式の合格通知が来る。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "合格ならば、一週間以内に、正式の通知が来るのだそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正式の通知の来ないうちは、気をゆるめてはいけないのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、其時に将門は正式の訴状を出して其事を告げたから、朝廷からは良兼を追捕すべきの符が下つたのだ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに将門は公の手の廻るのを待たずに、良兼に復讐戦を試みたのか、或は良兼は常陸国から正式に解文を出して弁解したため追捕の事が已んだのを見て、勘忍ならずと常陸へ押寄せたのであつたらう。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花嫁は裾模様の長い着物を着て、金襴の帯を背負ひ、角隠しつけて、堂々正式の礼装であつた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお台所の下ばたらきむすめも、いまではせいしきに、宮中づきのごぜん部係にとりたてられたので、ひろ間のとびらのうしろにたつことをゆるされました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
