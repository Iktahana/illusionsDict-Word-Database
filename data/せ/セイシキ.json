[
  {
    "uuid": "0587f36f-2e3e-52bc-9fb1-49927ebdbee0",
    "entry": "正式",
    "reading": {
      "primary": "せいしき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
