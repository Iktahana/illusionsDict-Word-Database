[
  {
    "uuid": "342c6acc-53a3-5297-8e97-1cc8446fd7e0",
    "entry": "生殺与奪",
    "reading": {
      "primary": "せいさつよだつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
