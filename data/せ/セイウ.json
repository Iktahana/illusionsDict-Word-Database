[
  {
    "uuid": "a615f66b-e0a6-5a2d-bae4-90fb1dc19c4b",
    "entry": "晴雨",
    "reading": {
      "primary": "せいう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clear or rainy weather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古い昔の天測器械や、ドルイドの石垣などは別として、本当の意味での物質科学の開け始めたのはフロレンスのアカデミーで寒暖計や晴雨計などが作られて以後と云って宜い。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また平日一般の日本国民は京都市の晴雨に対しては冷淡なるも、御大典当時は必ずしも然らざるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の地における各時季の気温や、風向、晴雨日の割合などは勿論、些細な点についても知識の有無に従ってその方面の準備の有無は意外の結果を来たすであろうと考えられる。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日後に挙行される遠泳会の晴雨が気遣われた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敏感な重藤は、正確な晴雨計のように、すぐ、それに気づいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この晴雨計の使い方を知っているかね、一つ測って見給え」などと云った。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし均平との関係はそれきりにはならず、商売を始めてから、その報告の気持もあって、ある日忘れて来た袱紗だとか、晴雨兼用の傘などを取りに行くと、均平はちょうど、風邪の気味で臥せっていたが、身辺が何だか寂しそうで、顎髭がのび目も落ち窪んで、哀れに見えた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の晴雨を詳に考ふるなるべしと思へば、天のさま悪しゝ、舟出し難しなど云はれんには如何せんと、傍観する身の今さら胸轟かる。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て晴雨に關せざるなり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで笠を冠つてとは晴雨共に旅客に大なる便宜を與へる。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとつて其のスヰッチが往々にして、呼吸困難の有無であり、鹽酸コカインやヂウレチンのきゝめ加減、天候の晴雨、昔の友人からの來信の有無等である。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の心理的動搖が氣壓に何かの影響を及ぼすものだとしたら、午後の職員室の此のモヤ／＼したものは、確かに晴雨計の上に大きな變化を與へてゐるに違ひないと思はれた。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　扨、時計や晴雨計を持たぬ所では、草木を觀察して時や天氣を察知した例多し。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英（タンポポ）は、本邦で朝開き午以後萎むといふが、歐洲では、毎朝五時に開き午後八時に閉るから牧童の時計とし、又、晴雨計たり。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルリハコベは雨近付ば必ず花を閉ぢ、午後二時頃定つて花萎むから、英國の古諺に、其徳聞き盡し難く、述べ盡す可らずと云ひ、貧者の晴雨計と俗稱さる。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の父上は舵座にあぐらをかいて、時々晴雨計を見やりながら、変化のはげしいそのころの天気模様を考えている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって晴雨も定めがたかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴雨寒暑というようなものがこれほど気分に影響するものとは思いもよらなかった葉子は、寝起きの天気を何よりも気にするようになった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この湯は晴雨によって温度を異にし、雨となると少し過ぎる位いの熱さとなる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ウェールグラス（晴雨計）や、テルモメートル（寒暖計）や、ドンドルグラス（震雷験器）などを見せられると、彼らは、子供が珍しい玩具にでも接したように欣んで騒いだ。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に転室した当初の私の窓を得たよろこびは晴雨につけ視野にはいる、樹の梢の一つ一つにも及んだ。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠まで来て空工合を眺めればその日の晴雨のことは大概解る、普段でも自分は何かの場合には朝のこの時刻に此処まで馬を飛ばして雲行きを眺めに来るのだが思惑の外れるやうなことは滅多にない――山番はそんなことも云つた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴雨共によろし、寒くさへなければ（私は暑さには強い）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く眼が覚める、雨が降つている、だが、私は晴雨にかゝはらないで歩くのである。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴雨兼帯とも言いたい馬丁の冠った高帽子まで彼にはめずらしい物であった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は春が来ても種子をまく心配もせず、二百十日が近づいても別に晴雨を気にするほどの苦労もしておらぬのに、間違いなく日々米の御飯を食べることができる。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「駄目だよ……」「だからさ、記者の頭って晴雨にかかわらないから、そンなものを背負って行ったって駄目なものは駄目よ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴雨計二、寒暖計一、時計二、メガホン三、コンパス十二、暴風雨計一、日本国旗と各国旗｜若干、信号旗一式、大工道具、はり、いと、マッチ、ひうち石、ボタン。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "治ったら応分に出せいうとります。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤兵衛の嬶め、俺がいつか小豆一升貸せいうて頼んだのに、貸せんというてはねつけやがったものな。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
