    "definitions": [
      {
        "index": 1,
        "gloss": "leather-soled sandals (geta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
