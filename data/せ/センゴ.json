[
  {
    "uuid": "6007a088-46e0-57dd-aff8-139740a353a6",
    "entry": "譫語",
    "reading": {
      "primary": "せんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "talking in a delirium",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして熱の高い時には譫語のように人形の口真似をして、パパアやママアを叫んでいたということだ。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "とき／″＼譫語のように「まあ、面白い」とか「ほんとに人を莫迦にしてるよ」と言って、唐突にぱか／＼と笑います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱はげしくて譫語のみ言いしを、エリスがねもごろにみとるほどに、ある日相沢は尋ね来て、余がかれに隠したる顛末を審らに知りて、大臣には病の事のみ告げ、よきように繕い置きしなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが又、その譫語のうちに、普通人にはチンプン、カンプンの囚人用語が、チョイチョイ混っているのに気が付きますと、Ａは忽ち、今までの恐怖心理から一ペンに解放されまして、見る見る持ち前の記者本能に立ち帰ってしまったものだそうです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論此れとても句の裏面には殘燈の下に枕を欹てゝ居る作者の居室の光景の潜在像は現在して居て、それがなければ此等の句は全然無意味な譫語に過ぎないのであらう。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "看病にはフエネルラとて、聾ひたる女を附けられしかば、幸に我｜譫語も人に怪まるゝことあらざりしならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、是れ皆熱の爲めに發せし譫語のみ、苦痛の餘なる躁狂のみ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと聞くと誠に出任せな譫語のようだが実は支那に古来虎多く、その民また特に虎に注意して色々と区別を付ける事あたかもわが邦で鷹や馬に色々種別を立てたごとし。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱劇しくて譫語のみ言ひしを、エリスが慇にみとる程に、或日相澤は尋ね來て、余がかれに隱したる顛末を審らに知りて、大臣には病の事のみ告げ、よきやうに繕ひ置きしなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って天命を疑い、大人を軽んじ、お言葉を侮り、ひたすら自己の私情を基本にして、勝手気ままに昂ぶり、いわゆる形式呼ばわりして先人の訓を卑しみ、形式に囚われると云っては大道に従わず、自己の発露・個性の展開などと譫語・妄言する者は皆この同類である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "気も不覚なれば母は譫語のやうに言出せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "譫語新しき美をわれは求める。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間のある人人には……世間のある人々には、その日々の消光がひとりで牌を打つパシアンスの遊の如く、またはすつかり覺えこんだ日課を夢うつゝで譫語に言ふ如く、またはカフェエに相變らずの顏觸と薄ぎたない歌留多札を弄ぶやうだ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは烈しき熱に冒されて病の床に横はりつつ、なほよく死にいたるまで譫語を口にせざりき。",
              "citation": {
                "source": "呼子と口笛",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜から妻は高熱のために譫語をいうようになりました。",
              "citation": {
                "source": "猫と村正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父さん、房ちゃんは最早駄目よ」　熱の譫語とも聞えなかった。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　手術した晩に、安らかな気持なのだが頭の中がオレンジ色がかった明るさで、いかにも譫語が云いたくてたまらなかったのは面白い。",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬のためにああいう状態になっているときの譫語は、全く我を知らずに口走るのではなくて、先ず、何かとりとめなく喋りたいという明瞭な欲望が感じられた。",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは熱が高いので、譫語に「こら待て」だの「逃がすものか」だのと叫んだからである。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎は時々譫語した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱劇しくて譫語のみ言ひしを、エリスが慇にみとる程に、或日相沢は尋ね来て、余がかれに隠したる顛末を審らに知りて、大臣には病の事のみ告げ、よきやうに繕ひ置きしなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に付小弟次第に譫語す、宜しく妄聴し給はる可く候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの男の作は癲癇病みの譫語に過ぎない。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が覚醒しないで、そのまま私の腕に死んでゆくかも知れないという心配よりも、譫語の中で両人の秘密をいい出しはせぬかということが、むしょうに恐ろしくなって来ました。",
              "citation": {
                "source": "麻酔剤",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、彼女はほんとうに危っかしい譫語をはじめました。",
              "citation": {
                "source": "麻酔剤",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "場違いのステテコだ……てんで船中の大評判になったんだそうで……おまけに二人とも……大変だ大変だ……とか何とか変な譫語を並べたもんですから、念のために血を取って調べてみると恐ろしいもんでゲス。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、病院へかつぎこまれる途中も譫語に英語をしやべつてゐた。",
              "citation": {
                "source": "貝殼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと点せ」　夜具からヒョイと顔を出すと、譫語のように紋兵衛は云った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそのむらがる枝の葉かげに　ぞくぞくと繁茂するところの植物およそ　しだ　わらび　ぜんまい　もうせんごけの類地べたいちめんに重なりあつて這ひまはるそれら青いものの生命それら青いもののさかんな生活。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘ごころのあやしさはもうせんごけの花かいな。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
