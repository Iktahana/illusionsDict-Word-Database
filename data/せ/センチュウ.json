    "definitions": [
      {
        "index": 1,
        "gloss": "on board a ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二階の一室狭けれども今宵はゆるやかに寝るべしと思えば船中の窮屈さ蒸暑さにくらべて中々に心安かり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時船中の食堂で卓を囲んで皿の肉をつついている人には船が進んでいようがいまいが何の痛痒も感ぜぬ、船が動けば皿の肉もそれを食っている自分自身もやはり一緒に動いて行くからだ。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校や中学校で太陽系を説くのは丁度船中で船内の事のみを教えているようなものである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五にごく近頃、ハンブルヒのシュリックという有名な造船家が大きな独楽を船中に取付け、これを迅速に回転すると横揺れがほとんど止まるという巧みな考えを出し、小形の船で実験したら非常に好結果を得たので更に目下エルベ、ヘリゴランド間通いの千トンくらいの客船に取付けるのを製造中だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船は砂の中へ深く埋れて引卸しの見込みはないが、幸いにその船中に備付けの発電機と一つの汽缶とが無事であったからそのままこれを利用し、海岸まで線を引いて市中を照らしているそうな。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしとと来た雨の夜泊の船中で、寝ねがてた苫の雫の音を聞いていると翁の胸はしきりに傷んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫に当る雨音を聞きながら一夜を寝苦しく船中に明した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七三年のナイル旅行の船中で稿を起したのが、足かけ五年目に脱稿したのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月十一日『東京朝日新聞』）　　　　　　　　　十七　　　　　　船内の消毒　船中で鼠を駆り、また消毒をするために亜硫酸瓦斯を用うる事があるが、その効験に関する詳細な調査の結果に拠れば、鼠や害虫の類はわずかに〇・五プロセントの亜硫酸を含む空気で二時間も燻せば絶滅する事が出来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽笛が船中の人の眼をさましたのだ。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　此の船中に話したがね、船頭はじめ――白癡め、婦に誘はれて、駈落の眞似がしたいのか――で、船は人ぐるみ、然うして奈落へ逆に落込んだんです。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早袂別の時刻も迫つて來たので、いろ／＼の談話はそれからそれと盡くる間も無かつたが、兎角する程に、ガラン、ガラ、ガラン、ガラ、と船中に布れ廻る銅鑼の響が囂しく聽えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、海上の規則では、船の出港の十｜分乃至十五｜分前に、船中を布れ廻る銅鑼の響の聽ゆると共に本船を立去らねばならぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（船中の號鐘は一點鐘より八點鐘まで四時間交代なり）『おや、とう／＼一｜時になつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五回　「ピアノ」と拳鬪船中の音樂會――鵞鳥聲の婦人――春枝夫人の名譽――甲板の競走――相撲――私の大閉口――曲馬師の虎　翌朝、銅鑼の鳴る音に驚き目醒めたのは八｜時三十｜分で、海上の旭光は舷窓を透して鮮明に室内を照して居つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中八｜時三十｜分の銅鑼は通常朝食の報知である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中朝の食事は「スープ」の他冷肉、「ライスカレー」、「カフヒー」それに香料の入つた美麗しき菓子、其他「パインアツプル」等極めて淡泊な食事で、それが濟むと、日出雄少年は何より前に甲板を目指して走つて行くので、夫人も私も其後に續いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處でも長い航海では船中の散鬱にと、茶番や演劇や舞踏の催がある。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは興行のためにと香港へ赴かんとて、此船に乘組んで居つた伊太利の曲馬師の虎が檻を破つて飛び出した事で、船中鼎の沸くが如く、怒る水夫、叫ぶ支那人、目を暈す婦人もあるといふ騷ぎで、弦月丸出港のみぎりに檣燈の微塵に碎けたのを見て『南無阿彌陀佛、此船には魔が魅つて居るぜ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "海蛇丸が我弦月丸の右舷に衝突して、風の如く其形を闇中に沒し去つた後は、船中は鼎の沸くが樣な騷であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……船中にて然やうな事は申さぬものだが、龍宮場末の活動寫眞が宣傳をするやうな風説を聞いて、乘らざるべけんやと、旅費の苦しいのが二人づれで驅出した。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉殿は、船中において嚇怒した。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弟は、学校を出て船に努めるようになり、乗船中、海の色の恍惚に牽かれて、海の底に趨った。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、渡欧の船中、印度洋で眺めた南十字星の美しさは、いつまでも忘れ難い。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子は殆ど地球の裏と表とに距る大西洋を渡る帰朝途上のアメリカ近くの汽船中で彼を嗅ぐことが出来た。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日、戊申、将軍家、三浦三崎に渡御、船中に於て管絃等有り、毎事興を催す、又小笠懸を覧る、常盛、胤長、幸氏以下其射手たりと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ船路のさまたげと、金内怒って荷物の中より半弓を取出し、神に念じてひょうと射れば、あやまたずかの人魚の肩先に当り、人魚は声もなく波間に沈み、激浪たちまち収まって海面はもとのように静かになり、斜陽おだやかに船中にさし込み、船頭は間抜け面で起き上り、なんだ夢か、と言った。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復の船中の恋愛、帰ってきたぼくは歓迎会ずくめの有頂天さのあまり、多少神経衰弱だったのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中でもこれのお蔭で随分と陰鬱にもされた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し腑に落ちんことがあるなら、どういうわけでそう為にゃならんのか、分りませんちゅうて、教えて貰いんされえ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
