        "examples": {
          "standard": [
            {
              "text": "清華大学は、北京大学と並び中国で最も権威のある大学の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は交換留学生として、一年間清華大学で工学を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "清華大学の広大なキャンパスを自転車で移動するのは大変だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "連れて行かれたのは、清華大学教授、日本文学に精しいといふ銭稲孫氏の家である。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は浴衣がけでその中庭へ向いた籐椅子に倚りかゝりながら、大元帥府、外交部、日本公使館、清華大学政治科と、塩崎を相手に早速プログラムを立ててゐたが、その時であつた。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国系の清華大学にも行って、いろいろの人に会った。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
