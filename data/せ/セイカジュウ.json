          "standard": [
            {
              "text": "橋の設計において、車両などの動荷重だけでなく、自重による静荷重も計算に入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倉庫の床が耐えられる静荷重の限界を確認してから、荷物を積み上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家具の重さによる静荷重で、カーペットに深い跡がついてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "静荷重にやっと耐えているようなハーケンとわずかつま先がのるくらいのスタンス、――というより外傾ぎみのフットホールドでＮは確保していた。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            }
          ]
        }
