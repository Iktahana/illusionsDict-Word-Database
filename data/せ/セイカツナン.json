    "definitions": [
      {
        "index": 1,
        "gloss": "difficulties in living",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "従兄妹同｜志で恋し合つて、青木さんの境遇にすれば多少早過ぎもしたのであつたが、互に思ひつめた若々しい熱情のまゝに思ひ切つて結婚生活にはいつた二人は、まる三年｜間を※たその頃になつて、可｜成りな生活難にとらはれてしまつた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は公家衆など生活難から歌道の秘事という事を唱え、伝授に托して金を捲き上げた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は、のんきなるも、山中にも、社會一般否以上の生活難ありて、あけても炭燒き、暮れても炭燒き、つい一里の山坂一つ越すの暇だに無き也。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一日労働してこれだけのものをも得られないといふほどそれほど生活難の社会ではない。",
              "citation": {
                "source": "谷合の碧い空",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉山の死の原因について新聞紙は種々の憶測を下して多くは生活難のためといった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉山の死の原因を単なる生活難に帰するは決して穿ち得たものではない。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、夫が四月となり、五月となるに従つて、生活難の烈しい圧迫が、容捨なく二人を襲ひ始めた。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活難の事、紛擾の事、一つ所に長くとまっていられぬ事、学科以外に柔術の教師をした事、ある教師は、下駄の台を買って、鼻緒は古いのを、すげかえて、用いられるだけ用いるぐらいにしている事、今度辞職した以上は、容易に口が見つかりそうもない事、やむをえず、それまで妻を国元へ預けた事――なかなか尽きそうもない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後の淫風と生活難の誘惑　昔から大変災のあとに必ず吹き起る事になっている淫風は、蕩々として彼女達職業婦人を包んだ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を飛び出したい　現代の少年少女がその親達から聴くお説教は、大抵、生活難にいじけた倫理道徳である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は最初から生活難の背景、又は商売的の意味を持ったもので、男性では俳優その他の芸人、外勤員、祈祷師、各種の治療師、活弁、呉服屋、ボーイ等の男淫売式？",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の方は興味本位、享楽本位から来たもの――今一つ突込んで云えば、思想カブレ、流行カブレ、虚栄、ウヌボレ、自暴自棄なぞいう内的原因から起った不良性の嵩じたもので、生活難の背景だの、商売的の意味だのが極めて薄い。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次は一般市民の生活難である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今の先、一人の工夫が余りな生活難のため、発作的に気を取り乱し、丁度其処へ走って来たトラックの車輪の下へ態と手を差し込んで、レールを俎に、四本の指を断ち切って了ったのを見た。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の妻は日々に募ってゆく生活難を書いてやった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は新聞の三面記事などに生活難とか、病苦とか、或は又精神的苦痛とか、いろいろの自殺の動機を発見するであろう。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "往時の閑人はこんな輩に驚かないやうに、武士道や禅学で胆を練つたものだが、今の人達は、武士道や禅学の代りに、お蔭で「生活難」で鍛へられてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の説によると、下級吏員の生活難は、その女房連が他から「奥さん」と呼ばれる、あの一語に根を置いてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この食糧品の暴騰から来る生活難を済ふには、朝鮮米を行き渡らせるのもよからうし、方針を過つた仲小路氏を農相の椅子から引きずり下すのもよからうが、今一つそれよりもずつと良い方法が残つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報の間違10・30（夕）　生活難にもとづく従業員の不足から、この頃電報の遅れがちなのは、実に困つたものだが、それよりも困るのは電報の文字に間違の多い事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　斯う云って居る目には生活難を感じながら平身低頭して朝夕神に仕えて居なければならない貧しい神官のあわれさが、しみじみと浮び見えて居た。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活難という悩みはどの職業にも共通ですけれど、医師はそれ以外に医師法や刑法の窮屈な条文から起る種々な悩みがあります。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――生活難ぢやない、生存難だ、いや、存在難だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵は鼠も生活難らしい（此頃また鼠が来てゐる）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は生活難に苦しみつゝある三千代をたゞの昔の三千代よりは気の毒に思つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの生存競争の劇しい生活難を何う逃避したものかと、消極的にそれを考へつゞけてゐた。",
              "citation": {
                "source": "浪の音",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家が生活難をどう考え、どう解決してゆくかという問いであったと思う。",
              "citation": {
                "source": "見落されている急所",
                "author": "――文学と生活との関係にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文相は、父兄からのつけとどけのない大学教授たちの生活難について語り、私立学校の入学にからむ父兄からのつけとどけを、やむを得ないことだと語っています。",
              "citation": {
                "source": "求め得られる幸福",
                "author": "――今こそ婦人の統一を――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『キング』は労働者の家庭にも農村にも入るのだが今日の軍事経済政策による深刻な生活難で、どこの誰の爺さんと孫が実際こんなにヌクヌク安楽な目をして暮らしているか？",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日では恋愛から心中しないけれども、生活難から心中する親子が少くなくなって来ていることを私たちは見ているのである。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
