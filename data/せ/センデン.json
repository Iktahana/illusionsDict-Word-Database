  {
    "uuid": "811e0727-d66e-5619-a741-7509669dfc13",
    "entry": "閃電",
    "reading": {
      "primary": "せんでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flash of lightning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし私の死にたいお願いが聖意にかないましたならば、只今すぐに私の生命を、燃ゆる閃電にお付し下さいませ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な雲が出た、――と叫び呼わる程こそあれ、閃電来り、瞬く間も歇まず。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷奇蹟、絶倒せんとして視えざる氷をやぶり、疾行する狼を殺す、畜生の如きも金屬なれば閃電を怖るる事もつとも烈し、詩人よ汝の手を磨け。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔日暴風雨を凌ぎ、疾雷閃電の猛威を以て、中原を席捲し去りたる夢は今｜何処にかある。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "（赤人）　白雲、黒雲、積雪、潰雪、閃電、猛雷、是等のものを用役し、是等のものを使僕し、是等のものを制御して而して恒久不変に威霊を保つもの、富嶽よ、夫れ汝か。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち閃電のように源の側を駆抜けて了いました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "進む浪人も、退いた浪人も、草に滑った刹那「ええいっ」　右頭上八相に構えていた一人が、閃電の如く――ぱあっ、と鈍い音と共に、つつと上った血煙――「うわっ」　と、遠巻にしていた旅人、駕屋が、自分が斬られたように叫んで、顔色を変えて、二三間も逃げた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日閃電雲を焚き、けふ日は燃ゆれ、ひとたび來ては巖を去らず。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "閃電を見るのみならず、落雷に撃たれたり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の口にするところは重に彼ら夫婦間に横たわる気不味さの閃電に過ぎなかった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生涯自分の著書の出版記念会すら断わり続けて来て、とうとう一度もそんな賑やかなことを避けて催さなかった宇野浩二は、自分をせんでんするとか威張ってみるとかいうことをしないで、銭湯でみがきあげたからだを好みのよい着物につつんで、そして晩年その一篇も書かないで死んだ。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんは、すぐに、むせんでんわでけいしちょうへしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをみると、こばやしくんは、むせんでんわで、けいしちょうのなかむらけいぶにしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
