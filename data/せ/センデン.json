[
  {
    "uuid": "7db329cb-978e-59ad-bb99-7c51698e7daf",
    "entry": "宣伝",
    "reading": {
      "primary": "せんでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "publicity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "政府が盆踊を禁ずるのも、国民が欧米人の真似をするのも、固有の日本文化が亡びるのも、すべて皆基督教の宣教師が宣伝するためであり、一切の悪は耶蘇教の罪に帰せられた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代になって、これが各種の伝染病菌の運搬者、播布者として、その悪名を宣伝されるようになり、その結果がいわゆる「蠅取りデー」の出現を見るにいたったわけである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "享楽しながら商売の宣伝になるのは能率のいいことである。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば近頃世上で大分もてはやされる色々の社会的の問題に関する弁論や主張や宣伝中の一、二パーセント、あるいは二、三十パーセント、事によるともっと意外に大きいパーセントがやはり一種のシッタシズムの産物ではあるまいかという疑いが起った。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジァンペートロというバリートンが当時異常な人気を呼んでいて、なんでもある貴族の未亡人から、自分の願いを容れてくれなければ自殺するという脅迫を受けて困っているというような噂が新聞で持て囃されたが、しかしそれは単に宣伝のための空ごとだというゴシップもあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎や猿蟹合戦のお伽噺でさえ危険思想宣伝の種にする先生方の手にかかれば老子はもちろん孔子でも孟子でも釈尊でもマホメットでもどのような風に解釈されどのような道具に使われるかそれは分からない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまたある種の思想を宣伝演繹することのためでもない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌『流行』の宣伝部長のカリタは、ミサコを自室に案内すると、隣室の同棲者に三人の食事を云いつけた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、『流行』の宣伝部長は化粧した冷酷な顔に鼻眼鏡をかけながら、「そうさ、俺達の友情はこの東京で育つに工合がいいんだ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし妾は宣伝はわすれないわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒霞渓がいゝとか「天下の名勝」だとか云って宣伝するのも、主に儲けをする彼等である。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊内における組織的活動、軍国主義と資本主義のためにする軍隊の使用に反対する啓蒙的な宣伝は、兵営に這入ろうとする革命的な青年たちのやらねばならぬ仕事である。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田を散歩した後に須田町で電車を待ち合わせながら、見るともなくあの広瀬中佐の銅像を見上げていた時に、不意に、どこからともなく私の頭の中へ「宣伝」という文字が浮き上がって来た。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は特別な「何々デー」というのでもなかったし、途中で宣伝の行列や自動車に出会った覚えもない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、私はその待ちおおせて乗った電車の上で、この「宣伝」という文字について取り止めないいろいろの事を考えてみた。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝という文字自身には元来別にそう押しつけがましい意味はなくてもよいように思う。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般的に宣伝というものの手段方法が必ずしも穏やかで物静かであってはいけないという事は考えられない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の宗教家や聖賢の宣伝にはかなり平和的なのもあったように思われる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日の「宣伝」という言葉には、まさにそれとは反対な余味があり残味がある。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合にまた宣伝の目的がほんの一時的のものであるとすれば、それで結構なわけであるかもしれない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の宣伝の効果が花火のように輝いて消えるころに乙の宣伝が砲声のようにとどろいて来る。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり身にしみるような宣伝はわりに少ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "善い事だから宣伝しなければならないという強い信念の下にすべての宣伝は行なわるべきものであろう。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうの宣伝ならば、宣伝さるる事がらの絶対価値に対する強い信念があっての上での事に相違ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生涯自分の著書の出版記念会すら断わり続けて来て、とうとう一度もそんな賑やかなことを避けて催さなかった宇野浩二は、自分をせんでんするとか威張ってみるとかいうことをしないで、銭湯でみがきあげたからだを好みのよい着物につつんで、そして晩年その一篇も書かないで死んだ。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんは、すぐに、むせんでんわでけいしちょうへしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをみると、こばやしくんは、むせんでんわで、けいしちょうのなかむらけいぶにしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
