        "examples": {
          "standard": [
            {
              "text": "江戸時代、潜伏キリシタンたちは信仰を守るため、密かに集会を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "史料からは、潜伏キリシタンの厳しい生活の様子がうかがえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "潜伏キリシタンの文化は、日本の歴史におけるユニークな一面である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "日曜ごとに長崎港外の島々や海岸の漁村、山の中の潜伏キリシタン村落をまわって貧しい病人に薬を与えたのだった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "迫害を避け静かに信仰を守り通すために移り住んだ潜伏キリシタンの一族で、みんな大山姓を名乗り、ただ一軒加藤といううちがある。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
