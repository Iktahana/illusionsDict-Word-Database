    "definitions": [
      {
        "index": 1,
        "gloss": "the world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やつぱり形式に於ても経験世界を肯定しなきや万人の芸術品とは言へないのでせうか？",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは世界の壊滅を願ふ！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂の尾と、ラム酒とに、世界は分解されしなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族旅行と木箱との過剰は最早、世界をして理知にて笑はしめ、感情にて判断せしむるなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――われは世界の壊滅を願ふ！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、とまれ、芸術が世界を通じて昨今衰微してゐることは争はれない所であらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界といふのは、誰しもが多かれ少かれ有してゐるものではあるが、未だ猶、十分に認識対象とされたことはないのであつた。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、その世界を聊かなりとも解明したいのであるが、当抵手に負へさうもないことであるから、仮りに、さういふ世界に恋著した宮沢賢治が、もし芸術論を書いたとしたら、述べたでもあらう所の事を、かにかくにノート風に、左に書付けてみたいと思ふ。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家にとつて世界は、即ち彼の世界意識は、善いものでも悪いものでも、其の他如何なるモディフィケーションを冠せられるべきものでもない。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとつて「手」とは「手」であり、「顔」とは「顔」であり、即ち名辞するとしてＡ＝Ａであるだけの世界の内部に、彼の想像力は活動してゐるのである。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等すべて彼の創造した新らしい芸術は、一一に私を驚かし、私の心にさわやかな幸福と、未だかつて知らなかつた新世界の景物を展開してくれた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもさうした純潔の詩人の生涯こそ、かの音楽家のそれと等しく、人生の最も神聖なる住宅、即ち道徳及びその他の感情生活の世界を支配する最高至美の権威でなければならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸当初の日に一瞥して嘔吐を催し、現代日本の醜悪面を代表する都会と罵り、世界のどんな汚い俗悪の都市より、もっと殺風景で非芸術的な都市と評した東京は、彼が死んでも住みたくない所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭離一切娑婆世界の厭世観は、ヘルンの多くの作品中に一貫して、その特殊な文学情操の基調となってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその悲哀の意味を知ってるものは、世界にただ二人の、妻と良人よりなかったのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ今、私の世界となりました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の国々を漂泊して、ついに心の郷愁を慰められなかった旅人ヘルンは、最後にまたその夢の中で漂泊しながら、見知らぬ遠い国々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし私は、室生犀星以外のいかなる文壇人とも交際がなかつた上、特に小説家については全く未知の世界に屬してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ態度が、職業的に習性となつてるその小説家的態度が、ある冷酷な――酒に醉はない――觀察本能を、我々ちがつた世界の人間に印象させるにすぎないのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲシュタルト心理学が持ち出され、全体主義という合言葉も生れて、新しい世界観が、そろそろ登場の身仕度を始めた。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の世界観をはっきり持っていなくても、それでも生きて居れる人は、論外である。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と質問してみて下さい、と答えて逃げ去ったとかいう話しがあるけれども、何千万年まえの世界には、どんな動物がいたか、一億年のちにはこの世界はどんなになるか、そんな話は、いったい実になるものかどうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場は躊躇せず、その報いられなかった世界的な名手がことさらに平気を装うて薄笑いしながらビイルを舐めているテエブルのすぐ隣りのテエブルに、つかつか歩み寄っていって坐った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの若き芸術家たちが世界に呼びかけた機関雑誌。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "企てた、とたんに、世界じゅうの小説がにわかに退屈でしらじらしくなって来るのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドッテテドッテテ、ドッテテド、　でんしんばしらのぐんたいは　はやさせかいにたぐいなし　ドッテテドッテテ、ドッテテド　でんしんばしらのぐんたいは　きりつせかいにならびなし。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　でんしんばしらは、みんなまっすぐを向いて、すまし込んで通り過ぎながら一きわ声をはりあげて、「ドッテテドッテテ、ドッテテド　でんしんばしらのぐんたいの　その名せかいにとどろけり。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドツテテドツテテ、ドツテテドでんしんばしらのぐんたいのその名せかいにとゞろけり。",
              "citation": {
                "source": "月夜のでんしんばしらの軍歌",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
