[
  {
    "uuid": "ab0f4fa6-f7c7-5b37-a8f3-f114837a27ad",
    "entry": "正誤",
    "reading": {
      "primary": "せいご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
