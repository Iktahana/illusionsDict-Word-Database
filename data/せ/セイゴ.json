    },
    "definitions": [
      {
        "index": 1,
        "gloss": "correct or incorrect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国府津と小田原の中間に「雀の宮」という駅があったようだと子供達と話していたら、国府津駅の掲示板を見ていた子供の一人からそれは「鴨の宮」だという正誤を申込まれた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の巨大な平面が、かく人の觀念を正誤する。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の巨大な平面が、かく人の観念を正誤する。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はこんな事が氣にかゝつて一々正誤しないと心持ちがわるかつた。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "正誤「閑天地」四の終り、土井晩翠君に与ふる詩の七行目、「夜影の雲もつひて」は「夜影の雲もつひえ」の誤植也、茲に正誤す。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に正誤表を作った事や、象嵌で版型を改めた事を言った。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにその正誤表がまだ世間に行き渡っていない。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで正誤表を作ったと云うのは虚言だと云う人がある。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正誤表は先ず第一部のが出来て、多少世間に出ている。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中私の手許から贈遺した本には、正誤表の出来た後、それを添えなかったことはない。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書肆富山房も誠意がないではなかったが、買った本は誰が買ったか分からぬので、正誤表の送りようがないと云うことであった。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国劇場で第一部の興行のあった時、第一部の正誤表は出来ていたので、富山房はそれを劇場で配布しようかとも云った。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今既に印刷し畢っているファウスト考には、右の第一部、第二部の正誤表を合併して、更に訂正を加えて添えてあるのである。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　正誤表に載せてある誤には、誤植もあれば、誤写もある。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　以上のうちで伊庭君の指摘せられた誤訳は、他の誤植や誤写なんぞと一しょに、最初別々に印刷した第一部と第二部との正誤表に載っているが、杉君と向君との指摘せられた誤訳は両部を合併して、ファウスト考に添えるはずの正誤表にだけ載っている。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今後幾度でも、機会を得次第に正誤して行く積であるから、あらゆる読者に尚沢山指摘がして貰いたい。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳本ファウストにはまだ正誤が公にして無い。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに第一部の正誤が出来たので、一面紙型を象嵌で直し、一面正誤表を印刷することを富山房に要求した。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし燼余の五百部は世間の誅求が急なので、正誤表を添えるに遑あらずして売り出された。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで第一部は未正誤本が五百部世間に流布していて、その他は象嵌済の正本なのである。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部の正誤は私の作ったのが目下富山房の手にある。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも紙型は象嵌で直し、未正誤本には正誤表を添える積でいたところが、世間の誅求が急なので、未正誤本が正誤表を添えずに売り出された。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に世間に出ているのも富山房にあるのも、第二部は悉くこの未正誤本である。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また魚では、川えび、小あぢ、せいご、きす、といつたやうな小魚までもが、脂がのつて、うまく口にせられるやうになるのも、この季節を私達に親しましめるものの一つである。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒やせいごを釣る人達がいた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡良瀬川では鱸、せいご、ぼらの投網打ち、鮭網、鰻の袋網。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにせいご布告を知るまでは、生きた心地もございませんでしたで」「空井戸といったが、深さは」「それがえらい深い空井戸で、八、九丈もございましょうか」「水はないな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
