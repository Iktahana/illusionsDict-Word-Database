[
  {
    "uuid": "cb0d7079-6c24-5bc8-8110-92a4782a5f9c",
    "entry": "背高",
    "reading": {
      "primary": "せいたか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
