    "definitions": [
      {
        "index": 1,
        "gloss": "seasonal festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供の初節句、結婚の披露、還暦の祝い、そういう機会はすべて村のバッカスにささげられる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油地獄にも、ならずものの与兵衛とかいう若い男が、ふとしたはずみで女を、むごたらしく殺してしまって、その場に茫然立ちつくしていると、季節は、ちょうど五月、まちは端午の節句で、その家の軒端の幟が、ばたばたばたばたと、烈風にはためいている音が聞えて淋しいとも侘びしいとも与兵衛が可愛そうでならなかった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件は今から七日前、娘のお春が三つの節句の雛を片附けた晩のことであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち二月も過ぎて、娘のお春の節句が來た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あとはまたお節句に団子をこしらえてやるせに、それにつけて食うんじゃ。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど今ごろ五月の節句のかしわ餅をつくるのにこの葉を採って来てそうしてきれいに洗い上げたのを笊にいっぱい入れ、それを一枚一枚取っては餅を包んだことをかなりリアルに思い出すことができる。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドド……胴と……足が……ベベベ別々に……ワワワワァ――ッ……」　時は徳川十一代将軍家斉公の享和二年三月十一日、桃のお節句以来、晴れ続いた朝のことであった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……雛の節句のあくる晩、春で、朧で、御縁日、同じ栄螺と蛤を放して、巡査の帳面に、名を並べて、女房と名告って、一所に詣る西河岸の、お地蔵様が縁結び。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一重桜三十九「忘れもしない、ずっと以前――今夜で言えば昨夜だね――雛の節句に大雪の降った事がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昨日はお雛様のお節句だわね――その蛤と栄螺ですって。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私許でも、真似事の節句をします。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい今年の三月、熱海へ奉公に出ておった、お前ぐれえな新造がの、親里の吉浜へ、雛の節句に帰るッて、晩方通りかかっての、絞殺された処だぜ、なあ、おじい。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……横寺町で、お孃さんの初のお節句の時、私たちは此を御馳走に成つた。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、京橋に住む知人の家に男の児が生まれて、この五月は初の節句であるというので、私は祝物の人形をとどけに行くのであった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初の節句の祝い物が途中で毀れたなどといっては、先方の人たちが心持を悪くするかも知れないと思ったからである。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千恵造の三度目の結婚式は、三月桃の節句の吉日に挙行された。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お節句の人形によく似てる。",
              "citation": {
                "source": "狸と与太郎",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學二年か三年の雛祭りのとき學校の先生に、うちの人が今日は雛さまを飾るのだから早く歸れと言つてゐる、と嘘を吐いて授業を一時間も受けずに歸宅し、家の人には、けふは桃の節句だから學校は休みです、と言つて雛を箱から出すのに要らぬ手傳ひをしたことがある。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "油地獄にも、ならずものの与兵衛とかいふ若い男が、ふとしたはづみで女を、むごたらしく殺してしまつて、その場に茫然立ちつくしてゐると、季節は、ちやうど五月、まちは端午の節句で、その家の軒端の幟が、ばたばたばたばたばたと、烈風にはためいてゐる音が聞えて淋しいとも侘びしいとも与兵衛が可愛さうでならなかつた。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた、Ｎ君はべつな本をひらいて私に見せたが、それには、「翌天保四年に到りては、立春吉祥の其日より東風頻に吹荒み、三月上巳の節句に到れども積雪消えず農家にて雪舟用ゐたり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ陰暦で年中行事をやっている僻遠の土地では、その日は朝から仕事を休んで端午の節句をやっていた。",
              "citation": {
                "source": "月光の下",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の国の三月は、まだ雪が消えないから、節句は四月にしたらしい。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜も過ぎたり、菖蒲の節句というでもなし、遊びではなかったので。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度五月の節句に、催しの仮装の時、水髪の芸子島田に、青い新藁で、五尺の菖蒲の裳を曳いた姿を見たものがある、と聞く。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の節句にも、お雛様に進ぜさした、振出しの、有平、金米糖でさえ、その可愛らしいお口よごしじゃろうに、山家在所の椎の実一つ、こんなもの。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "節句の粽貰いしが、五把の中に篠ばかりなるが二ツありき。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩早く、物見高く、町中見栄を張りたがり、裏店の破れ障子の中にくすぶっても、三月の雛の節句には商売道具を質においても雛段を飾り、娘には年中派手な衣裳を着せて、三味線を習わせ、踊を仕込むという町であった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛は五節句だと言っては、里方から物をもらい、子供の七五三の祝いだと言っては、里方から子供に衣類をもらうのでさえ、心苦しく思っているのだから、暮らしの穴をうめてもらったのに気がついては、いい顔はしない。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに反撥するように、吉田は、「あの橋のところまで馳せっくらべしよう。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの春、男の子を産みましたけれど、この五月は初のせっくです、華やかに祝ってやりたくぞんじます。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
