[
  {
    "uuid": "775976e0-40aa-51de-9106-5a5fe15dea6c",
    "entry": "先刻",
    "reading": {
      "primary": "せんこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
