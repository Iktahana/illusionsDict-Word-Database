      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a short while ago",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世に、真実と、虚飾との二つがあることは先刻知れ渡つてゐる。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の誤解が度重り、Ｂがなんとか伸理解明せんものとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の連れの男は僕の丁度直ぐ前の席に、もう先刻から眠つてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が如何に現実にとつてまどろつこしいものであるかは、諸君も先刻御承知であらうし、恐らく諸君が考へてゐられる以上にそれは事実だ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻まで頻りに喋舌つてゐた三田村はスツカリ黙つてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういへば先刻トラックに積み込む時、先生の物らしい物がないとは一寸思つた所だつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の先刻捨てに行つた塵芥が、裏庭の風の吹いて来る方寄りであつたことを「誠意がない」と勝手に決めて始めたお説教以来ブツ続けである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、これは先刻、太宰が呟いた言葉じゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には、その真面目臭つた顔の小僧と、先刻「お嫁さん」と云つた時の小僧とが、どうしておんなしなんだらう？",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長室で、彼は卓に頬肘を突いて、眠さうな、赤い顔をして先刻から考へてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが野田寺町の先刻云つた家であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた隣の父の居間からは彼の聞き覚えのある声と、父と母との上づゝた調子の話が先刻から絶えずしてた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは一人｜先刻から考へることがあつたの。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコと足音が後頭に響くと、先刻父と話してゐた弟が来て、トランプをしようと言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう嘲るやうに先刻の言葉を言つてみたが、何だか気懸りな言葉だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関先に夫らしい足音がすると、先刻から火鉢に凭つて時計ばかりみてゐた妻君は、忙しげに立ち上つて玄関に行つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その、呑気さうな言葉付が彼女には歯痒かつたが、その社長が、自分を可なり大事な者に考へてゐたことがその口振で分ると、彼女は急に、先刻解雇者の名前をみた時から忘れてゐた、それは若い女らしい、それを頭に浮べれば乳房のくらげのやうに伸縮し始める、その理想を再生させることが出来た。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『だから謝罪たと云ツてるぢやないか、先刻から。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方と思つた彌次連は、先刻から傍若無人の暴言を小面憎く思つて居た、敵であつたのだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻、菊池寛氏へもわが生きかたの粗雜貧弱を告白して、いまは大事の時だ、めそめそ泣いて歩きまはつてゐたつて仕樣がない。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラロシフコーなど讀まずとも、所謂、「人生裏面觀」は先刻すでに御承知である。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　龜は先刻から、ただ默々と鰭を動かしてゐるばかり。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、けふの兎は、何か内證の思惑でもあるのか、いつものやうに狸に向つて侮辱の言葉も吐かず、先刻から無言で、ただ技巧的な微笑を口邊に漂はせてせつせと柴を刈つてゐるばかりで、お調子に乘つた狸のいろいろな狂態をも、知らん振りして見のがしてやつてゐるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「とお仰ると……先刻あなたにお会ひした兎のことですか？",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、頭の上を見ると、谷に冠さるようにのさばって、古い、大きな、先刻のと同類の楊の梢が一本ぶらりと垂れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃平が、先刻、未だ日の暮れないうち、朝飯の菜にとて、山款冬数十茎を折って来たのを、みんなして、退屈｜凌ぎに、繊維を抜いては、鍋へ投げ入れる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がまた少し来た、夜になると、甲府市の電燈が黄いろの珠のように、混沌の底から、ボーッと見えた、先刻の汽船といい、この電燈といい、人間に遇わずに、山から山を伝わって、野獣のような生活をつづけていた人々の胸をおどらせた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "油紙の天幕には、チロチロと漣の刻むような光りがする、岩石の間に、先刻捨てた尻拭き紙までが、真赤にメラメラと燃えている、この窪地一帯に散乱する岩石の切れ屑は、柔らかく圭角を円められて、赤い天鵝絨色が潮しはじめた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から、殊に私の眼をひいた一人の四十前後の男の患者がありました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先刻までは悲しみと疲れとにやつれ果てていた老母の顔が、さも嬉しそうに、今まで見たことのないほど嬉しそうにかがやいて見えるのであった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
