[
  {
    "uuid": "c00bf940-cbfd-5e6a-baa2-2b357257a784",
    "entry": "政治問題",
    "reading": {
      "primary": "せいじもんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
