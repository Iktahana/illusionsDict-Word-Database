    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unavoidable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第六章　医学博士ジョン・ワトソンの回顧録（続き）　捕らえられた男はすさまじい抵抗を見せたが、別段我々に敵意を抱いているわけではないらしく、詮無いと悟ると愛想よく微笑み、今の争いで怪我はなかったかとこちらを気遣ってまでくれた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんなことを言っても、詮無いことだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、芸術にもつと観念が必要だなぞと云ふ人も、せんないことを云つてゐるに過ぎない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠者の翁はこれを聞くと、あばら家の門に佇みながら、俄に眉をひそめて答へたは、「はてさて、せんない仕宜になられたものかな。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御隠居様、　今年も亦思う通り実りがありませんない。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の用心が西納屋の方から裏座敷の方へ廻つて来た時に、裏座敷の話の声を聞いて、『お嬢様まだ帳場の戸が閉つて居りませんない』と注意して居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "十人も居つたかも知れませんない』『十人も？",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "○私もせめて矢島君の様な役割に廻つて居れば、先生もはりあひあつてよかつたのにと思つてもせんないことを時々思ひ出してはゐます。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、直次さんの夢を見て、気にかかってせんないから、一寸しらせに来たら、来ておられるって……」　縫子は、一里半歩いて、来ているのであった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ、ほんに、まあ、せんないこといのう」　つや子は、来合わせてくれた沢田の主人と息子にたのんで、一旦高いところへうつした衣裳箱を、今度は二階へあげて貰いはじめた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあちゃんのように、人ばかり頼んでも、たべさせる御飯だけでもせんないいうてじゃが、男たのまいで、どう、なろうかいの。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいでになり、第一日第二日まだお気持がきまらず、それがわかりましたが、もう今日では、あなたのお心もよくのみこめたから、いっそせんない思いをさせることは云うまい、云うたとてどうなろうか、というところに落付いて、こんなに皆が大切にしてくれるのもあなたのおかげ、と思っていらっしゃる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いくらかせんないところもありますのよと仰言ってですし、それもよくわかるわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことになるのだったら、去年のあきにそなたと祝言をするのではなかったが、いまそれをいい出してもせんないことだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いからまアまアせんないが、強いが兵法などと考えたら大間違い。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも女性が巻き込まれたとあっちゃ、理性を期待しろと言ってもせんないことだった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "利家は苦笑の下に、うなずいて、「せんない奴よのう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手討となってもせんない所を、それくらいなお仕置で御勘弁ねがえるものなら有難い仕合せ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "会えぬなら、ここにいてもせんないこととあきらめたわえ」「でも、お疲れも」「日ごと、日ねもす、輿にゆられて行く憂さは、言いしれぬほどだが、しかし……」　と、後醍醐は、いちばいお声を低くした。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう申すもせんない。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたがきいてもせんないこと」　次の部屋へ近侍が来ていた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せんない憂いを」　と、彼は思う。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
