    "definitions": [
      {
        "index": 1,
        "gloss": "Spanish-Japanese",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
