    "definitions": [
      {
        "index": 1,
        "gloss": "divination (using bamboo divination sticks)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
