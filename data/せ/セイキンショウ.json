        "examples": {
          "standard": [
            {
              "text": "彼は小学校の6年間、一度も休まずに登校して精勤賞をもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎朝誰よりも早く出社していた彼女に、会社から精勤賞が授与された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「精勤賞を狙っていたのに、インフルエンザで一週間休んじゃったよ」と彼は悔しそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしそれでも欠席することはなく精勤賞を貰っていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "評定所出仕の命をうけてからも、精勤賞をもらった程だった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
