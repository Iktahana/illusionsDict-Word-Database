[
  {
    "uuid": "cfdbb3f1-523d-51ac-90d9-42a432485c8d",
    "entry": "生誕",
    "reading": {
      "primary": "せいたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "birth (esp. of a famous person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このことは姓と結び合せて自分を宮城縣人と思ふ人もあるらしいが、たゞ生誕の地といふだけで、三ヶ月後には仙臺を去り、それから土木技師である父の轉勤につれて東京・神戸・熊本・博多・長崎と轉住した。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ世の中に、運命が自己の生誕の日の十干十二支や、九宮二十八宿やなんぞによつて前定して居るものと信じたり、又は自己の有して居る骨格や血色やなんぞに因つて前定して居るものと信じて、そして自己の好運ならざるを歎ずる者ほど、悲しむ可き不幸の人は無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかかわらず一方ではまた彼は自分の子供らの運勢をその生誕時の星宿の位置によって読み取ろうとしているのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで踊る彼女であってこそ、今やカッスルのパアトナアとしてのみのカッスル夫人ではない一個の新しい独自な踊りてとして生誕し得るわけである。",
              "citation": {
                "source": "表現",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隈公園といふのがあつた、そこは侯の生誕地だつた、気持のよい石碑が建てられてあつた、小松の植込もよかつた、どこからともなく花のかをり――丁字花らしいにほひがたゞようてゐた、三十年前早稲田在学中、侯の庭園で、侯等といつしよに記念写真をとつたことなども想ひ出されてしようぜんとした。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡立つ透明のなかから花びらを纏って生誕する一つの顔。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、この世に生誕しない子供たちが殆ど天使にまがう姿で青い川岸の花園のなかに蹲っている。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは音楽学校であつたが、ふと彼の目には原子爆弾から突如生誕した建物のやうな気もする。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは上に樵山の事を記した後、其父の誰なると其生誕の何年なるとを知ることを得た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九四年三月号の『マックワールド』誌は、マッキントッシュ生誕一〇周年を祝うとして日本版独自企画の「徹底検証　マッキントッシュ伝説」という大特集を組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子の生誕地は『史記』によると、魯の昌平郷陬邑である。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは新たな人間の生誕、新たな人生観の確立である。",
              "citation": {
                "source": "新たな世界主義",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類生誕の劫初より縹渺と湧いて来るような淋しさだった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の詩人は、すでにこの時に生誕していたのだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一は鬼才ブレエキ作“Sun-Flower”にして、その二は作詩典雅をもてあらはれたるランドル七十五歳生誕日の翌某女友に遣れる述懷の詠なり。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンブラントのねらったところは、救世主の生誕を見て安心して死んで行かれるわが身の幸福を神に感謝するシメオンの心情と、シメオンの預言にわが子の偉大な運命を知った聖母の心情である。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛は相互に孤立しては不具である男・女性が、その人間型を完うせんために融合する作用であり、「を味う」という法則でなく、「と成る」という法則にしたがうものであり、その結果として両者融合せる新しき「いのち」が生誕するのだ。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七八二年生誕一八五四年永眠の哲学者で、絢爛にして強壮な思索の持主であつたさうだ。",
              "citation": {
                "source": "ラムネ氏のこと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、世は変り、あに世の変りを信ぜざるべけんや、即ち私は新日本の生誕を信じる故に敢然グラスをとつて強かあふり、今日も尚生きてをり、世の一大変転を命をかけて実証するに至つた。",
              "citation": {
                "source": "足のない男と首のない男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｕ・Ｒ・Ｓ・Ｓも生誕十五年をむかえている。",
              "citation": {
                "source": "新らしき性格感情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生誕十五年のロシヤでは急速に変化を断定することはできぬ。",
              "citation": {
                "source": "新らしき性格感情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｕ・Ｒ・Ｓ・Ｓも生誕十五年をむかへてゐる。",
              "citation": {
                "source": "新らしき性格感情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは上宮太子御生誕後幾年になる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向の諸地方を旅行すると、たとえば神武天皇生誕の地とつたえられる狭野神社の宮司は、あいにくこのあたりには古墳が少いので、と云って残念がっておったし、また高千穂の町では、この山中には古墳がたくさんあります、この奥の米良にも集団的にあります、と云って威張っていた。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、戦争時代の終滅と、新しい現実の生誕を、ハッキリと、改めて発見したのだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教の起源の美しい物語や、キリスト生誕のときの田園の光景がじゅんじゅんと説かれる。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『改造』より二カ月遅れて生誕した『解放』には福田、堺両氏及び帝大新人会の一派が相拠っていたが、このうち福田氏は約一年ののち、『改造』に専ら執筆するようになり、十数年間博大の筆陣を布いて一世の注目を惹いていたのであった。",
              "citation": {
                "source": "十五年",
                "author": "山本実彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その著者袋中は寛永十一年に九十一歳だとあってみれば、その生誕は天文十三年で、江戸時代以前の故事もかなり知っておったであろうし、特にその長年月間扱い慣れていたところから、所謂サンカモノの何であるかくらいの事は、よく通暁しておったに相違ない。",
              "citation": {
                "source": "サンカ者名義考",
                "author": "――サンカモノは坂の者",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢諭吉生誕百年祭を祝うきょうび、日本の出版屋にとって涎の垂れる記録である。",
              "citation": {
                "source": "福沢諭吉",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
