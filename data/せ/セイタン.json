    },
    "definitions": [
      {
        "index": 1,
        "gloss": "charcoal making",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一萬二千町歩にもわたる奧地の自然林に炭燒の煙の登るのを見、多量の製炭が架空索道によつてそこから運び出さるゝやうになつたのも、そんなに舊いことではないといふが、これなぞもその一例であらう。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた一方には文芸や思想の上においても、ちょうど県町村の計画をもって、製炭技術の講習会を開催すると同じように、縁もゆかりもなかったことを教えられる場合が多い。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
