[
  {
    "uuid": "7b509daf-1454-5367-b10c-fefe3ca3c4ac",
    "entry": "星河",
    "reading": {
      "primary": "せいが",
      "alternatives": [
        "せいか"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Milky Way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仰ぎ見る大ぞら、晴に晴れて、黒澄み、星河霜をつつみて、遠く伊豆の岬角に垂れたり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生は大袈裟に形容すれば、日星河岳前にあり、室生犀星茲にありと傍若無人に尻を据えている。",
              "citation": {
                "source": "出来上った人",
                "author": "――室生犀星氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐佐木君は温厚の君子、幸ひに先生の言を容れ、君が日星河岳の文字に自ら題して猥談と云ふ。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒然として来り我等を茫莫のうちに残すもの、ああ……咏歎の星河、燦々の星河、極みなき……。",
              "citation": {
                "source": "四人",
                "author": "芥川多加志",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江の石亭が雲根志にいはく前編※異之部信濃国高井郡｜渋湯村横井温泉寺の前に星河とて幅三町ばかりの大河あり、温泉寺の住僧｜遷化の前年に、此河中へ何方よりともなく、高さ二尺ばかりなる自然石の方にしてうつくしき石塔一ツ流れきたる、実に彫刻せるごとくにて天然の物なり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、がん丈で、せいが高かった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさなくって、せいがひくいので、その子供達は、ほかの男女工達と同列の椅子に腰かけては、作業台に手が届かなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰掛の下にもう一ツ、台を置いて貰わないと、仕事台に、せいが届かなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、せいが高いので寧ろ痩せて見える敏捷らしい男だった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むやみにせいが高くて頑丈さうな曲った脚に脚絆をぐるぐる捲いてゐる人もあった。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにせいが高いので、教室でもいちばん火に遠いこわれた戸のすきまから風のひゅうひゅう入って来る北東の隅だったのです。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、たいへん、みるみる陳のあたまがめらあっと延びて、いままでの倍になり、せいがめきめき高くなりました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はあなたは、もう僕の五倍もせいが高いでせう。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三毛猫は殊にせいが低かつたので、だんだん乗り出して、たうとう足が腰掛けからはなれてしまひました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はあなたは、もう僕の五倍もせいが高いでしょう。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　楢夫はすっかり面白くなって、自分も立ちあがりましたが、どうも余りせいが高過ぎて、調子が変なので、又｜座って云いました。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　楢夫はすっかり面白くなって、自分も立ちあがりましたが、どうも余りせいが高過ぎて、調子が変なので、又座って云いました。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせいが父のあとについて送りだそうとすると、浅田は、「お嬢さん、もうようございます。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万人が行ったり来たりする賑かな往来、そこでおせいが何百人何千人となく行き遇った人々、その中には、おせいが歩いているような気持で歩いている人がやはりいたのだろうか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、たいへん、みるみる陳のあたまがめらあつと延びて、いままでの倍になり、せいがめきめき高くなりました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもせいがきれていけない。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のせいが丁度立つ位であった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくせいもくせいがにほふよ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豹島といって、おっとせいが黒山のようにいたり、ロッペン鳥が雪のように翔けていたり、それはお伽噺にあるようなおもしろい島があるそうです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大へん、ごせいが出ますね。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "門のベルにはせいがとどきません。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でも、それからのち、ふた冬とおりこすと、もみの木はかなり、せいが高くなりましたから、うさぎはもうただ、そのまわりを、ぴょんぴょん、はねまわっているだけでした。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはもう、去年、つれていかれた木とおなじくらい、せいが高くなったし、すっかり大きくそだってしまった。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしトゥロットのうでは、ミスのうでのやうに大きくもなく、黄色くもないのでいせいがありません。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一人ではせいがないやうに仰る。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
