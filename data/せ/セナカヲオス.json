          "literary": [
            {
              "text": "」そう云って背中を押す。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は子の背中を押すようにして「此処をかたづけたら直ぐ寝るでなお前は前へ寝てなえ、ほんとにお前は賢いえ。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そないにはれがましゅう思わんでもいいわな」　背中を押すようにして云ったんで、「いらっしゃいよ、ネ、私知らない事はおしえてちょうだい、そいであそびましょうよ。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　列に立っている重吉の背中を押すようにしながらひろ子があわてて相談した。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨ばった足でフェンウィックの背中を押すと、前によろけ、こけ土に倒れたので、細腕で喉を掴み、馬乗りになった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
