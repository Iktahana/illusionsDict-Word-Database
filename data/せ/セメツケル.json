        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "善昌をつかまえて、さあ、覚光と手を切るか、さもなければお前がふだんの行状を残らず信者に触れて歩くぞと云って、うるさく責め付けるというわけです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その社会的な弱点を改正しようとしないで、女は、女は、と女のおくれをせめつけるのは甚しい矛盾だ。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端にかいくぐった孫兵衛、その利腕をねじとッて、左手で女の喉をせめつける。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
