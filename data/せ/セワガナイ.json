        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「また同じ間違いをして、本当に世話がないやつだな」と上司に呆れられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何度注意しても聞く耳を持たない彼には、もう世話がないと匙を投げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "酔っ払って道端で寝てしまうなんて、全く世話がない大人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
