        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いろいろお世話になりました　　いろいろお世話になりましたねえ　　いろいろお世話になりましたさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　「妻」だとか「お嫁」だとかつて世話じみてるんですもの………。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　如何せ世話じみるんだけれど。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん茶店の人たちも、あのお客は、ただ口が重いだけで、別段に惡だくみのある者でないといふことが判つた樣子で、お客さんのお嫁さんになるひと仕合せですね、世話が燒けなくて、とをばさんに冗談言はれて、私は苦笑して、やつと打ち解けて來たころには、はや十一月、峠の寒氣、堪へがたくなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの人は、大隅君の博識に無条件に心服し、何かと大隅君の身のまわりの世話を焼いていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病な私には、人の結婚の世話など、おそろしくてたまらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに小生は、君もご存じのとおり、人の世話など出来るがらの男ではない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少からず気になっていたが、私は人の身の上に就いて自動的に世話を焼くのは、どうも億劫で出来ないたちなので、そのままにして置いた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また媒妁人は、大学で私たちに東洋美術史を教え、大隅君の就職の世話などもして下さった瀬川先生がよろしくはないか、という私の口ごもりながらの提案を、小坂氏一族は、気軽に受けいれてくれた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、こんどの世話はごめんこうむる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の豊田様のお家に、ずつと世話になつてゐました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の豊田様のお家に、ずっと世話になっていました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから今度田中さんが、その家には子供も大勢だし、誰も世話する者がないから自分が世話をしに、満洲のその家に世話に行くんだつて。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを故意に漂母と言ったのは、一つはユーモラスのためであるが、一つは暗にその長屋住いで、蕪村が平常世話になってる、隣家の女房を意味するのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の江戸時代の日本人は、理髪店で浮世話や将棋をしながら、殆んど丸一日を暮して居た。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の方は近所の者などがかわるがわる世話をしているようであった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の中学にかなりに好い口があって世話しようとした先輩があったが、田舎は厭だからと素気なく断ってしまった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世話をやいている事務官らしいのが自分に向って何か言っているが、何を云ってるか分らない。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン教授には三学期通じてずっと世話になって特別の優遇を受けたような気がしていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この豚存外に心利きたる奴にて甲斐々々しく何かと世話しくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はかよわい身一つで病人の看護もせねばならず世話のやける姪をかかえて家内の用もせねばならず、見兼ねるような窮境を郷里に報じてやっても近親の者等は案外冷淡で、手紙ではいろいろ体の好い事を云って来ても誰一人上京して世話をするものはない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と下女とをかわるがわる手伝いにやっていたが、立入って世話しているとまた癪にさわる事が出来て、罪もない妹に当りちらす。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう家に不幸のあった時には村じゅうの人が寄り集まって万端の世話をする。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世話人があまりおおぜいであるために事務はかえって渋滞する場合もある。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この忙しいのにどんなに世話を焼かすか知れぬと頭ごなし。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われかのひとをこととふに〕宮沢賢治われかのひとをこととふになにのけげんもあらざるをなにゆゑかのとき協はざるクラリオネットの玲瓏をわらひ軋らせわらひしや",
              "citation": {
                "source": "〔われかのひとをこととふに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳に響くはただ身を焼く熱に湧く血の音と、せわしい自分の呼吸のみである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大犬は青や紫や黄やうつくしくせわしくまたたきながら云いました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気がうすくなった為に、はねをそれはそれはせわしくうごかさなければなりませんでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ黒な家の中には黄いろなラムプがぼんやり点いて顔のまっかな若い女がひとりでせわしく飯をかきこんでゐる。",
              "citation": {
                "source": "女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
