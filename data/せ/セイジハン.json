    "definitions": [
      {
        "index": 1,
        "gloss": "political offense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殺された旅僧は、政治犯人ではなく、諸方を荒した強盗であるとのことであったが、はっきりしたことは判らなかった。",
              "citation": {
                "source": "風呂供養の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍍金鉄格子に囲まれた中で、我々は、わが政治犯達及び刑務所長ウルムブラント氏と共にカヴァを飲んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の義父、老ポエは、マターファ側の政治犯、我々を獄中のカヴァの宴に招いて呉れた酋長等の一人だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国防軍の統帥権と、経済上の支配権、印度公債の利権賦与と塩専売法の否定運動、それに何より政治犯人の控訴権の獲得だ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "數へがたい程の幾多の悲慘事が今までに階級的政治犯人の身の上に起つた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "数えがたいほどの幾多の悲惨事が今までに階級的政治犯人の身の上に起った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉浦啓一は力づよい、飾りない言葉で第四年目の三・一五を記念し、ブルジョア・地主のひどい政府が、どんなに党員たちを苦しめるか、死ねがしに扱うか、いやいや現に党員の誰とかを警察のコンクリートの床になげつけて殺した事実をあげて、政治犯人即時釈放を要求しました。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルール占領反対、戦争反対、大戦当時の政治犯大赦、労働者の協同戦線、というような当日の標語が、いやにおさまり返った雄弁で長々と説明された。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか、じゃ政治犯だね。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、最後の場面で、政治犯でシベリアに流刑される人々にまじったカチューシャが、その人々の感化から自分の過去の不幸の意味を理解し、人間としてそこからぬけ出してゆく途がわかってみれば、ネフリュードフの自己満足のための犠牲はいらないこととわかって、ネフリュードフと訣別する。",
              "citation": {
                "source": "復活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを見ると、帝政時代のロシアが政治犯をどんなに虐待したかが、アリアリわかる。",
              "citation": {
                "source": "ロシアの過去を物語る革命博物館を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄の手枷足枷まではめたレーニンが、一八九五年にまだ大学生で政治犯としてシベリアに送られた時の人相書がある。",
              "citation": {
                "source": "ロシアの過去を物語る革命博物館を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父ちゃんボリシェヴィキだもの、いるだろう、ここに」　一たん階下に降りて帝政時代の政治犯人が、檻禁されていた牢屋の模型を見物する。",
              "citation": {
                "source": "ロシアの過去を物語る革命博物館を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の監獄が治安維持法の政治犯と云っても非転向の共産主義者をどう扱ったかという歴史的事実の片鱗も描き出されている。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又、自づと獄内での待遇が違ふように、世間の見る眼も普通の破廉恥罪と政治犯とは大分違つてゐた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢代から六朝を經て、唐代にかけて、嶺南地方は政治犯罪者、若くばその家屬の遠謫される場所であつた。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく政治犯罪者――知識階級に屬する――が貶謫されて、その儘南方に永住する者、即ち當時いはゆる落南の人士が次第に多きを加へ、又唐の中世の安史の亂、さては唐末五代の亂に、北方の士庶の難を南方に避くる者も尠くなかつた。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命博物館には、種々様々の革命的文献の他に帝政時代、政治犯が幽閉されていた城塞牢獄の監房の模型が、当時つかわれた拷問道具、手枷足枷などをつかって出来ている。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゼンチン各所監獄を転々とした末に、政治犯四名とともに「蕨の切り株」へ連れてこられて機関銃弾で追われながら沼地へと追いやられた。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月四日、連合軍総司令部の指令によって、治安維持法の撤廃、政治犯人の釈放、言論、出版、集会の自由が命令された。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルガリア、一切の政治犯人を釈放声明七月三十日（日曜）〔欄外に〕　赤軍ワルソーに迫る。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "タガンカ監獄にゐる子供達は、其処に送られた政治犯人によつて発見された。",
              "citation": {
                "source": "死んだ魂",
                "author": "エマ・ゴオルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "４．輿論の要求は、暴力行爲を犯した者を除いて一切の政治犯人を釋放せよと云ふにあつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは城廓として築造され、王宮として用いられた時代もあったが、永い間政治犯の牢獄として用いられていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にこれらソラチの囚人の大部分が、内地全土の殺人強盗の最凶悪犯と内地全土の自由民権運動の最精鋭政治犯から成っていたことを忘れてはならぬ。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋一の貿易港、世界稀有の魔都「道徳無し」と云われている享楽と罪悪と、政治犯人の絶好の隠れ場所たる上海の夜景！",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人物はまず穏健な政策によって政治犯の鎮圧に当たっていた独裁官であるが、彼はその面前にひざまずいて号泣しながら、メーリコフ襲撃のかどによって捕えられて、極刑に処せられようとしていた一青年の命ごいをしたのである。",
              "citation": {
                "source": "「あかい花　他四篇」あとがき",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "クック船長の報告の一節に、土人と立って話をしていると、土人らはたまりかねて涎を流し、いくども手で口を拭いたとあり、英国はこの島へ印度の政治犯人を送ってワラ族の食膳を賑わしたという実績もある。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、政治犯罪、出版に關する犯罪又はこの憲法第三章で保障する國民の權利が問題となつてゐる事件の對審は、常にこれを公開しなければならない。",
              "citation": {
                "source": "新憲法の解説",
                "author": "日本國憲法",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
