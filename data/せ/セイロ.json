[
  {
    "uuid": "e052d877-c825-59cb-9ff1-18c8e508ec73",
    "entry": "正路",
    "reading": {
      "primary": "せいろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
