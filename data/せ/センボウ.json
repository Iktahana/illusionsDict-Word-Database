      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "envy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実際彼の妻のように、良人に対して忠実な奉仕をする女性は、普通の西洋婦人の中にはほとんどなく、これほどまた男が殿様扱いにされる家庭生活も、西洋では考え及ばないことであるから、ヘルンの手紙をよんだ外国人たちが、いかにその日本の友人を羨望したかが想像される。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私以外の人間が実に羨望に絶えないもののやうに思はれた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の欲深さは、自分に無いものを他人に見て、他人の幸福ばかりを羨望する。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が彼を羨望して、人生の「所得人」と言ふのはこの爲である。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の如き鹽センベイにて晩酌する徒輩にとつて、室生君酒席の贅澤は羨望の至りである。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かな屈辱……ところが今日は人見がおたけを意識しながら彼の演説の真似をしたりするのを見ると、ある忌わしい羨望の代りに唾棄すべき奴だと思わずにはいられなくなっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もし自分が「眼」のたちの人間でそれに相応した業務をもち、それによって成果を得られるならば、「鼻」のたちの人がそれによって得られる成果を羨望しないところに、この人生の良き現実の世界が在り、自他の区別が整然とついた立派な差別相が保てるのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がともあれ、婚礼の夜の春美こと児子｜賀来子の著しく化粧栄えのした容貌は、人々を瞠目させ、千恵造は羨望された。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子はかなりの近視で、こちらの姿は眼に入らなかろうが、こちらからはあまりに毎日｜見馴れて、復一にはことさら心を刺戟される図でもなかったが、嫉妬か羨望か未練か、とにかくこの図に何かの感情を寄せて、こころを掻き立たさなければ、心が動きも止りもしないような男に復一はなっていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして又、一言一句の末にまで容赦なき拘束を受けて、何事に限らず、その思ふ所をそのままに言ふことを許されない境遇にゐた彼等は、翁の大膽なる論文とその大膽を敢てし得る勢力とに對して、限りなき羨望の情を起さざるを得なかつたに違ひない。",
              "citation": {
                "source": "トルストイ翁論文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "木賃宿を泊り歩いているうちに周旋屋にひっ掛って、炭坑へ行ったところ、あらくれの抗夫達がこいつ女みてえな肌をしやがってと、半分は稚児苛めの気持と、半分は羨望から無理矢理背中に刺青をされた。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が為めに私はあらゆる世の賞讃と羨望とを受けた。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "營々役々として錙銖の利を爭つて、成功して資本家となつてゐるものも、これを羨望しつつ勞動者となつてゐるものも、Platon の目から見れば等しく賤業者（β）である。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから自己の製作を發表して貰はうと切望して居る一方に他人の成功に對しては恐ろしい羨望の眼を以て見て居た。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸をかきむしられるような女々しい己の気持が羨望ではないかと、李陵は極度に惧れた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかな老人の言葉と怡々たるその容に接している中に、子路は、これもまた一つの美しき生き方には違いないと、幾分の羨望をさえ感じないではなかった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が明るく、オレンジの香が何処からか匂っていた、既に此の世の戦を終え、こんな美しい熱帯の夜、乙女等の唄に囲まれて静かに眠っている故人に対して、一種甘美な羨望の念を私は覚えた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羨望、嫉視、自己の前途への不安、酸つぱい葡萄式の哀しい矜恃、要するに之等の凡てを一緒にした漠然たる胸騷ぎ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――他人の趣味を訊ねに行くことはちよつと面白いだらうな、その仕事こそ私には趣味が感じられさうだ、と私は心から羨望した。",
              "citation": {
                "source": "趣味に関して",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも羨望らしい表情はなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで歩いているだけでも、羨望に価するのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　併しその悪口は、四苦八苦の生活に喘いでいる百姓達の、羨望の言葉だった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、男性に対する絶望的な憧憬と、強い羨望の心が少女を苦しませた。",
              "citation": {
                "source": "咲いてゆく花",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その昆虫学の標本の蒐集は、スワンメルダム（６）のような昆虫学者にも羨望されるくらいのものだった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "手古奈の母方の曾祖父物部於由といふ人は葛飾に名のかむばしき大丈夫にて、一とせ館の騎射に召され、拔群の譽れを立てた、恩賞には、殿の言添に依て相思の美人と結婚を遂げ一國の羨望を雙身に集めたといふことである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神上からみると、まことに無意味な浅薄な結婚であったけれど、世間の目から羨望の中心となり、一｜時近郷の話題の花であった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――　それはそれとして、如上の事柄なども翻つて考へて見るまでもなく、ローマン的な傾向を持つ作家の一面として見るならば、決して難ずべき程のことではなく、却つて長所として羨望に堪へぬ独特な才能である。",
              "citation": {
                "source": "彼に就いての挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一寸余談にわたるが、僕の友は幸福な恋に酔ひながら金髪の恋人の腕をとつて意気揚々と帰朝して、僕に羨望の熱を挙げしめた。",
              "citation": {
                "source": "なつかしき挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノルマンは、無言で、竹見の間に、通せんぼうをして立つ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハハハハハハ」　通せんぼうのように両手をひろげて、その笑いは、もうまるで怪鳥の啼き声のよう……あわれ脇本門之丞、痴欲に心狂ったかと見えます。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
