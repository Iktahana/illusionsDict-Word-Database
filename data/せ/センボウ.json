[
  {
    "uuid": "62f08764-3b28-5501-96aa-624a375640cf",
    "entry": "羨望",
    "reading": {
      "primary": "せんぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
