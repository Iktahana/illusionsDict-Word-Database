        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　背もたれに寄りかかった私が愛飲の葉巻を吹かすと、ホームズも身を乗り出して要点ごとに細長い人差し指で左の手のひらを叩きつつ、これからふたりして赴くことになった事件のあらましを聞かせてくれるのだった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんたいがどっしりした作りの、背もたれの高くて分厚い、肘かけの部分も広く安定した、少なくとも四十年くらいは前のものだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "両腕を肘かけに置いて、背もたれに体を頭を預け、軽く昼寝をしているような姿勢だったわ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして背もたれに体を預け、視線をまっすぐに前へとのばした。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "背もたれのついた低いストゥールがカウンターの外側にならんでいる。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな丸い貝がらを垂直に立てたような背もたれのある籐椅子だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "背もたれに背を預け、腕や脚から力を抜き、ほんのりと微笑すら浮かべて、彼女は窓の外を見続ける。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアのわきにあった小さな椅子に、僕は背もたれを前にしてまたがった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "背もたれだけのある簡素な椅子に、腰を中心にして微妙に体をひねって、絵のなかの後藤美代子はすわっていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "右肩の下から肩甲骨のぜんたいを背もたれに預け、上体はやや右に傾いていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子の背もたれに体を預け、脚を組み、彼は両腕も組んだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば夏子さんの写真なら、それを見る人の誰もが、一枚ごとにそのなかに物語を読んでいく」　そう言ったヨシオはテーブルに両足を上げ、ソファの縁に向けて腰を滑らせ、背もたれに体を預けて両手の指を頭の上で組み合わせた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ生きてるな、おまえ」　太い声でそう言い、椅子を持ちあげて半回転させ、背もたれを前にして、またがった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子に座ると背もたれに跳び上がるのが聞こえ、耳元で唸るのが聞こえました。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
