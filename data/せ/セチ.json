[
  {
    "uuid": "6dcb6e06-bc6e-5ac9-8ffd-d19d7b9e580b",
    "entry": "世知",
    "reading": {
      "primary": "せち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "worldly wisdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世知辛い行きつまった内地で儲けられない埋め合せはここでつけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今より思へば殺し参ゐらせたらむやも計り難けれど、世知らぬ乙女心のおぞましさに其時は夢更心付き候はず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っているものは世知だけで、思想もなにもチンプンカンプン。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾手掛けなら知らないこと、この世知辛い世に顔や縹致で女房を貰う者は、唐天竺にだってありはしない。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、其素質が、真の寺家風でなく、堂上風にも向かぬわびしがりとうき世知りであつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏犬の遠音を、里あるしるしとした詩人も、実は、浮世知らずであつた。",
              "citation": {
                "source": "山のことぶれ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何になろうとか、何をしようとか思わない事は無論ないでしょうけれども、世の中が、そう自分の思い通りにならない事もまた能く承知していますから」　なるほど彼の卒業した時代に比べると、世間は十倍も世知辛くなっていた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして孟子の「乱臣賊子懼」を後世の事とし、「知我者其惟春秋乎」をもまた「後世知丘者以春秋」と書きかえたのである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一）　子張問う、十世知るべきか。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○さてまた芭蕉が行状小伝は諸書に散見して普く人の知る所なり、しかれども翁の容※は挙世知る人あるべからず。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、厳しくつらい放浪暮らしで、その間に世知辛い知恵を学んだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪気とか純真とか言うのは良いことですが、世知辛い世の中でひとりぼっちの女にはむなしい武器でしかありません。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもねえ……従兄さんのところにゐるけれど、――こりやあなただけに言ふんだから、誰にもスベらせちやあ嫌ですよ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜の町を仰向勝ちにスタスタと歩きながら、「……あなただけに言ふんだから、誰にもスベらせちやあ嫌ですよ……」つてことばがヒツキリなしに頭を往来した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、まだ君が、『遺言の積り』であつて、『真実の遺言』で無いからだ、と、真実の遺言を書かせちまはなければ、プロレタリア文学はならないだらうか？",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまた、罹災民は「二十年も前のことなどこのせち辛い世の中でとても覚えてはいられない」という。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪を引かせちゃ大へんだぜ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同じ源から出たエネルギーはせち辛い東京市民に駆使される時に苦しい唸き声を出し、いらだたしい火花を出しながら駆使者の頭上に黒い呪を投げている。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このせち辛い世の中に、まるで、自給自足時代の百姓のように、のんきらしく、──何を食って居るのかしらんがともかく暮して居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつに見せちゃいけねえ、見せちゃいけねえ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、見せちゃいけねえ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつに見せちゃいけねえ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつに見せちゃいけねえ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじけさせちゃったんだな。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲が下の方と上の方と、すっかり反対に矢のやうに馳せちがってゐたのです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非とも英、伊戦争にまで展開させて、欧州を今一度大混乱に陥れ、ロシアの極東政策をお留守にさせちゃって、その間に支那奥地の英、仏の勢力と、共産軍の根拠をタタキ潰さなくちゃならんというのが、日本の当局者の意向なんです」「そう都合よくまいりましょうか」「行きますとも。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが戸外が急ににぎやかになって、町の中を狂気のように馳せちがう人馬の足音が聞こえだしたと思うと、寺々のかねが勢いよく鳴りはじめました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その人でさえ、可いかね、都合のいい時でないと、容易に顔を見せちゃくれない……」「沢山よ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の中を這出して、片息になってお前、本尊の前へにじり出て、台に乗っけて小さな堂を据えてよ、錦の帳を棒の尖で上げたり下げたりして、その度にわッと唸らせちゃあ、うんと御賽銭をせしめてやがる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえの持てるだけ持ってうせちまえ。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
