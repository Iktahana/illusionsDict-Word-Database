[
  {
    "uuid": "cbefe66b-d287-5f4e-be50-ee68b40e4d70",
    "entry": "専門雑誌",
    "reading": {
      "primary": "せんもんざっし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
