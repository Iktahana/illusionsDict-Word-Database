    "definitions": [
      {
        "index": 1,
        "gloss": "an endless variety of forms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
