        "examples": {
          "standard": [
            {
              "text": "コンサートのアンコールでは、往年のヒット曲を並べた華やかな接続曲が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "吹奏楽コンクールの自由曲として、地元の民謡をテーマにした接続曲を演奏することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "パーティーのBGMとして、有名な映画音楽の接続曲が会場内に軽快に流れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "音楽として聞かれるものは、速歩調やあるいは――祭りの日に――アドルフ・アダムの接続曲を奏する田舎楽隊、華想曲をひく教会堂のオルガン、町の娘たちのピアノの練習、などばかりだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トリスタンとイゾルデ」にはストコフスキーの「交響的接続曲」があるが、編集も上手、指揮もうまいが、それだけのことで、劇的な展開もゆとりもふくらみも余情も失われる。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
