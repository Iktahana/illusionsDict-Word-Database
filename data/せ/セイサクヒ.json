    "definitions": [
      {
        "index": 1,
        "gloss": "manufacturing cost",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし政府出品ではなく、出品は個人出品ですが、奨励策として、個人の製作費を補助したのであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "栃の木で老猿を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョブズはプリント基板の製作費をざっと二五ドルとはじき出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇ドルの値段で一〇〇枚は売れるに違いないとウォズニアックに断言し、総製作費の約半額にあたる一三〇〇ドルずつを持ち寄って、話を進めることにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい彼のひとは、谷村さんから金を借りると、すぐ姉の絵の具を買つてやつて自分はまた銀座あたりのカフエーなぞを歩いて、姉の製作費を捻出していたとの事でありました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは市場の関係で、日本の数倍といふ金を製作費にかけ得るからだ、と。",
              "citation": {
                "source": "映画の観客と俳優",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その収入から製作費いっさいを支払ってみると純益はほとんど残らぬか、足が出て赤字になっています。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝劇なら帝劇で新劇の公演をやって、連日満員であってもたかだか、そのシバイの製作費と小屋代と税金が払えるか払えないかであって、その劇団全員の生活費に当てる金などまるで残らないのが普通だ。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
