    "definitions": [
      {
        "index": 1,
        "gloss": "the mistake of a wise man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
