  {
    "uuid": "6db51917-4cd6-50ed-a6ab-1d7af599e7da",
    "entry": "姓名判断",
    "reading": {
      "primary": "せいめいはんだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
