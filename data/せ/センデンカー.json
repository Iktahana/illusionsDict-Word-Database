        "examples": {
          "standard": [
            {
              "text": "街を走る宣伝カーから、賑やかな音楽と商品の情報が流れてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "選挙運動では、候補者の名前を連呼する宣伝カーが各地を回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末の商店街は、イベントの宣伝カーで賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "売人は各家庭の主婦の前で直接店を開いて効能を述べたてる宣伝カーでもありうるのだ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの売人は、人に厭がられずに、直接品物を持ってあらゆる家庭を訪問できる宣伝カーであり移動商店でありうるからだ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま仕事部屋の外で宣伝カーなるものがわめいている。",
              "citation": {
                "source": "年の瀬の音",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
