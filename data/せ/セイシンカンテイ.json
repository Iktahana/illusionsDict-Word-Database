    "definitions": [
      {
        "index": 1,
        "gloss": "psychiatric examination",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
