[
  {
    "uuid": "aa557681-7378-5848-84cd-2aec3949a4b1",
    "entry": "船尾",
    "reading": {
      "primary": "せんび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
