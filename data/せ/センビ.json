    "definitions": [
      {
        "index": 1,
        "gloss": "stern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「日直上ト兵」　ワーイ「食券持ってイモン袋取りに来い」「オーイ、田中、田中、日直上ト兵ッ」（居ない）○紹介　船尾で寝ていた。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは無風の暑苦しさに絶へかねて船首から船尾の方へ行つた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は習々と東方から船尾を拂つて船首へと吹き出してゐるのだ。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓て船尾の方へ來て見ると、此處は人影も稀で、既に洗淨を終つて、幾分の水氣を帶びて居る甲板の上には、月の色も一段と冴渡つて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄は少しも心付かなかつたが、唯見る、我弦月丸の左舷船尾の方向二三｜海里距つた海上に當つて、また一｜度微な砲聲の響と共に、タール桶、油樽等を燃燒すにやあらん、※々たる猛火海を照して、同時に星火を發する榴彈二｜發三｜發空に飛び、つゞいて流星の如き火箭は一｜次一｜發右方左方に流れた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とばかり、遙かに指す左舷船尾の海上。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が一等運轉手は急はしく後部甲板に走つたが、忽ち一令を掛けると、一個の信號水夫は、右手に高く白色球燈を掲げて、左舷船尾の「デツキ」に立つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言終つた時、怒濤は早や船尾の方から打上げて來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叫びつゝ、頭を廻らすと、此端艇を去ること程遠からぬ洋上には、先刻の白色巡洋艦は小山の如き浪に漂蕩しつゝ、其後檣縱帆架と船尾とには、旭輝く大日本帝國の軍艦旗は翩飜と南風に飜つて居つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦「日の出」の甲板では、後部艦橋のほとりより軍艦旗飜る船尾に到るまで、多くの乘組は、列を正して、我端艇の歸艦を迎へて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れば奇怪の船、我に信號を試みんとならば、果して如何なる手段をか取ると瞻めて居ると、忽ち見る、海蛇丸の、檣上、檣下、船首、船尾、右舷、左舷に閃々たる電燈輝き出でゝ、滿船を照す其光は白晝を欺かんばかり、其光の下に一個の異樣なる人影現はれて、忽ち檣桁高く信號旗が上つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞻むれば一｜隻の海賊船は轟然たる響諸共に、船底微塵に碎け、潮煙飛んで千尋の波底に沈み去つた、つゞいて起る大紛擾、一艘は船尾逆立ち船頭沈んで、惡魔印の海賊旗は、二度、三度、浪を叩くよと見る間に影も形も。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲のすぐ上を一｜隻の飛行船が、船尾からまっ白な煙を噴いて、一つの峯から一つの峯へちょうど橋をかけるように飛びまわっていました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾に到ってよくよく見るならば、この船には全く一つの舵もついていないのだ。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は紺絣の着物、それに袴をつけ、貼柾の安下駄をはいて船尾の甲板に立っていた。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、よろめきながら船尾のほうへ廻ってみた。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも左のはうに、肩が傾いて心細く、船尾のはうからだんだん沈没しかけてゆく軍艦の姿に似てゐる。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、観客のなだれに押しまくられ突きまくられて、とどのつまりが船尾の一端に坐り込みの、芸づくしということになったのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私たちはまた船尾の方へ廻った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高瀬舟の船尾には赤の枠に黒で彩雲閣と奔放に染め出したフラフが翻っている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀人は平生の如く船首に立つて紅の衣を着てゐたが、私は船尾にゐて戀人の後姿を瞶めてゐた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はひらりと身を飜して、劍の束に手をかけると、鳥は船尾の直ぐ後の海中に落ちた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に脱走者は船から七八間離れた渦の中を船尾を※つて鮮やかに島の方へと泳いでゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にゐた二人の島民水夫が其の場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾の燈火が水に尾を曳き、船は滑るように橋の下を左へ曲って行く。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に脱走者は船から七、八間離れた渦の中を船尾を廻って鮮やかに島の方へと泳いでいた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にいた二人の島民水夫がその場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾に腰かけた若者はうつむいて一心にヴァイオリンをひいている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもその時、魚銛発射手のムレアドが船首から船尾へやって来て、右舷船首にあたって奇妙な声がすると報告した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はひとりの水夫に命じて、船尾へ鉄砲を取りにやった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
