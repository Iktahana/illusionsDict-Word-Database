        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "廣岡と同じことを云ふんやつたら、廣岡の方が先口ぢやからして。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方が落胤騒動としては先口で、云って見れば天一坊の元祖に当る訳。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "月ぎめの人でも、年ぎめの人でも、先口に貸してあげるわ。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女に五ツ年上のロイゼルは先口を開いた。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学座が先口なので、これを許した。",
              "citation": {
                "source": "「道遠からん」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "先口の文学座にこれをゆるした。",
              "citation": {
                "source": "一言（「道遠からん」について）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、後からその矢倉石を発見した体力のある鰍の夫婦は、先口の鰍夫婦を追い払って、前に産卵した矢倉石の天井へ産みつける。",
              "citation": {
                "source": "鰍の卵について",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしたとえ、その娘が、ほかの家の少女にしても、父親は、前に一｜度人形のことで、おばあさんと顔なじみだったから、おばあさんは、あなたが、先口だといって、人形を売りました。",
              "citation": {
                "source": "お父さんの見た人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、最初にご貴殿において、お訪ね下されたのが拙者の屋敷、言って見れば先口で。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先口だから、もう少しこっちを贔屓にしたら好かろうと思うくらいであった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすると、そこには規則正しい組織があるとか、あるいは先口から順じゅんにゆくというわけだね。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幽霊の移転",
                "note": "青空文庫"
              }
            },
            {
              "text": "韮山　そりゃ、私の方の証書の書き代え以前の話だから、書式にすれば銀行の方が先口かも知れません。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度なら先口よりも一段と灼だァ、驚くもんかい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "先口がつかえているんだから」「八五郎親分の煙管みたいね」「何をいやがる」　八五郎は脂でジワジワする煙管をあわてて仕舞い込みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番の先口さんですから、択り取り見取りでございますわ」　と安子夫人は又頻りにくれたがる。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は先口だから尚お具合が悪くなる。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方が先口の積りで待っているんですから」「僕もその積りでいたんですけれど」「有望だと仰有ったじゃありませんか？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ」「先口が二つあって、その方からヤイ／＼言われたものですから、市岡さんの方はまだ白紙のまゝですよ」「はゝあ」「何れ書き込みの時、御相談申上げることになりましょうから、その節は何分宜しくお願い申上げます」「承知致しました。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一つ案じられるのは先口だ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが纒まらないようなら、僕は余っ程何うかしている」「しかし先口ってことがある。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが怖いんだ」「先口は絶対にない」「何故？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題が重大だから、本能的に然うなるんだろう」「成程」「経済方面からも先口はないと断定出来る。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柴君は一も二もなく引受けてくれた」「先口は？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文子さん／＼って悉皆当てられて来た」「君が当てられるくらいなら余っ程だろうね」「まあ／＼、帰ってから話す」　先口のないのは何よりの安心だった。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは此方から見れば然うだけれど、先方に何んな都合があるかも知れない」「でも先口のないことは確めたんだろう？",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「先口がないからって僕にくれるか何うか分らない」「分らないから申込んで見るのさ。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分と五分と言いたいところだけれど、四分六分だろう」「先方が先口だからかい？",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何しろ先口ですし、お家がレッキとしていますから……」「はゝあ」「と申すんでございます。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先口から考査されると、此方の番にならない中に何方か及第してしまう。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
