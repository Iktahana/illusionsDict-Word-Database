        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎日下駄を鳴らして通ってうるせえのは。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寝ていなさるが枕頭に嬢様呼んで何か細い声で話をしておいでるようで……」「そうか」「まア上って晩まで遊んでおいでなされませえの」「晩にでも来る！",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は水だがうぶすなのそえかえびす女に戸地男（そえはせえの意）　この狄は北狄と言ふところでして、とぢと何れも佐渡の北側にあります。",
              "citation": {
                "source": "相川おけさ",
                "author": "村松おけさ、佐渡牛などのこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるせえのは、それさ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女ばかりの一と世帶――と言つたつて、羅生門河岸の青大將臭せえのとは違つて、大年増から中年増、新造から小娘まで揃ひも揃つたり、箱から出し立ての、雁皮を脱がせたばかりと言つた、樟腦臭い綺麗首が六人」　八五郎は大きく身振りをして、八つ手の葉つぱのやうな左の掌へ、右手の人差指を一本添へてニヤニヤするのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、若い衆、小せえの、何をするんだい」　慌てて留めたのは老人。",
              "citation": {
                "source": "大菩薩峠",
                "author": "市中騒動の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番小せえのが、奴に丁度いいんだよ。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
