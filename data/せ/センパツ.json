[
  {
    "uuid": "178f5ea2-e58c-53ef-be79-85175999d0c7",
    "entry": "先発",
    "reading": {
      "primary": "せんぱつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
