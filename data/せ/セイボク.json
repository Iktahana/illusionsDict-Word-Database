          "literary": [
            {
              "text": "秋冷盈至之処、益御清穆起居奉賀候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "時下窮陰之候｜筆硯いよいよ御｜清穆奉賀候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "粛啓　時下残暑凌ぎがたく候処益※御清穆の御事と存上候　却説　伯爵様折入って直々貴殿に御意得度思召に被在候間明朝九｜時御本邸へ御出仕可然此段申進候　早々頓首花岡伯爵家八月十五日富田弥兵衛内藤常太郎殿　富田さんは家令だ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹啓、厳寒の砌り愈※｜御清穆に渉らせられ大慶の至に存じ上げます。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
