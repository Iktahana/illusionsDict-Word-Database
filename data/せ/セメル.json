      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to attack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "命に従わず朝を軽んずるというので、節刀を賜わって関白が愈々東下して北条氏を攻めるというのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大高城に最も近い丸根、鷲津を差置いて、寺部なぞの末城を先きに攻める法はないと独合点して居たからである。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「智慧伊豆ともあろうものが、外国船の力を借りて城を攻めるとは、国の恥を知らないものか」手厳しい批評を城中で為して居る者が居る。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨守は「今こそ攻めるべし、遅るれば必ず後より追撃されん」と忠直卿に言上した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻められる慶喜に此の感懐があつたとすれば、攻める薩長側にも、称揚さるべき佳行があつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田君は、戸石君と二人きりになると、訥々たる口調で、戸石君の精神の弛緩を指摘し、も少し真剣にやろうじゃないか、と攻めるのだそうで、剣道三段の戸石君も大いに閉口して、私にその事を訴えた。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "形をもつて空間を攻めるといふやり方は、その描き残された空白の部分に、強い物質性が顕れる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、方便的の手法と言つたやうな形があるけれども、しかし、それは、わざとその弱点を攻めるやうな――抵抗療法的なところがあつて、微妙に、且つ有効にその境に至ることが出来るものである。",
              "citation": {
                "source": "心の絵",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、むかしのロックンロールにかぎる」　あれからさきの話もききたいが、とりあえず、外堀から攻めることにしよう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻めるも護るも、これで押徹せばよいのだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあと二ヶ年を余に貸し与えよ」影の大統領「不可だ」大統領「無人飛行機で日本を攻めるアイデアがあるのだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに異人館を攻めるの、黒船を燒撃するのと云つて、大勢から軍用金を取立てゝゐる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この芝兼さんは攻める方でなく、守る方であつた。",
              "citation": {
                "source": "手数将棋",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの寺田梅吉六段のお父さんの、寺田浅次郎五段もなかなかこの手数将棋の名手であつたが、この手数将棋といふものは見てゐてもなかなかおもしろく、攻める方が五十手なら五十、六十手なら六十といつた具合に、最初に約束しておいただけの手数の数の碁石をもつてゐて、攻める方で一手させば、守る方では、「はい、一つ。",
              "citation": {
                "source": "手数将棋",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻める方は、せつかちな人ほどいけない。",
              "citation": {
                "source": "手数将棋",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は攻める方で、耳が遠く、きこえるのかきこえないのか、トボけたやうな感じで、一手さしても石をなかなか渡さないのである。",
              "citation": {
                "source": "手数将棋",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この手数将棋は繰りかへしていふやうに非常に興味の深いものであるが、やはり攻める方と守る方とであまり段がちがひすぎると面白くない。",
              "citation": {
                "source": "手数将棋",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総攻撃開始とは、何処を攻めるというのであるか？",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学史上最大の天才と言われるアルキメデスは、ローマの軍隊がシシリーのシラクサの城を攻めるに及んで、これに極力反抗し、自分の科学をあらゆる武器に応用した。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上では土地の如き利用物がなく、防禦戦闘は至難であり、防ぐ唯一の手段は攻めることである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "リージンの大柄な口紅を濃くつけた細君は、いかにも夫の手抜かりを攻める面持で、自分たちのいる横で二人だけあっちへのせろ、と云っている。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、前にふさがった女は、一層彼女に擦りつき、攻めるような、からかうような快活な凝視で、房の注意を促した。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうですね、少しは何か食べられますか」　それを捕え、まさ子は半分冗談で攻めるように、「国府津へなんか来いと仰云るから悪いんですよ」などと云った。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか本人の心ばかりでもございますまいが、斯う云ふ山師の仕事には得て山師が左右に付くもので、主人の知らない惡事を澤山するものでございますから、鑛業人一人を攻める譯ではないが止むを得ない、責任者であるから名を言ふので。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ五百は彼が兼松石居に従って経史を攻めるのを見て、毫も容喙せずにいた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で一人を攻めるのである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣の国の殿様もこんどこそ大丈夫と思って出した難題を、またしてもわけなく解かれてしまったのでがっかりして、それなり信濃国を攻めることをおやめになりました。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「起きとりゃ蚊が攻めるし、寢るより仕方がないわいの。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何はともあれこんな日に、偶然二人を攻める道具の揃った東野の宅へ来合せたということは、二人にとって幸運か不運かまだ彼には分らず、何かとしきりに云いたくなるのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧｜心敬が「ただ数奇と道心と閑人との三のみ大切の好士なるべくや」と言ったというが、芭蕉の数奇をきわめた体験と誠をせめる忠実な求道心と物にすがらずして取り入れる余裕ある自由の心とはまさしくこの三つのものを具備した点で心敬の理想を如実に実現したものである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
