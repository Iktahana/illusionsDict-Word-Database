[
  {
    "uuid": "0faf68e3-744a-566e-9163-363b33f4f96e",
    "entry": "攻める",
    "reading": {
      "primary": "せめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
