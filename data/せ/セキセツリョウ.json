    "definitions": [
      {
        "index": 1,
        "gloss": "amount of snowfall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
