      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "washed rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "次の壇へ御洗米と塩とを純白な皿へ盛ったのが御焼物の鯛をはさんで正しく並べられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝は、も一つお神酒とお洗米を持って来てくれないか、お倉の方へな」「よろしゅうございます、すぐ持ってまいります」「それじゃ、俺は前へ往ってるから」「それじゃすぐ持ってまいります」　定七はすぐ腰をあげて出て往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしました」　定七は一方の手に神酒徳利と洗米の盆を乗っけた三宝を持ち、一方の手に土蔵の鍵を持っていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はそういう連中のために、大師河原のお札が品川にあったり、堀ノ内のお洗米が新宿に取り寄せてあったりして、それをいただいて済ました顔で帰る……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたいさんは、「清い藁少々と、半紙と、鹽と洗米とを用意して下され。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つて、藁を取つて注連繩を作り、半紙で御幣を作り、それと洗米と鹽とを持つて裏の畑の方へ行つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙の奥には老母の信心する日吉さまとかの御洗米が、一ト袋｜捲き込まれてあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同が順々に京子の脣へ水を濡つてから、顏へ白い片布を掛け、白い屏風を立て廻らして、枕元の小机には、水と鹽と洗米とを盛つた土器を置き、細い燈明の火がチラ／＼してゐた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにハルピンに着くのが明日の十三日、私は何だか厭な気持ちがして、母が持たしてくれた金光さまの洗米なんかを食べてみたりしたものです。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕に燈明と、水と、小豆と、洗米を供えてまわるのが私の役目とされていた。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は勿論のこと現在でも、みな前もつて別火潔斎して、身を浄め心を直くし、当日は楽屋へ壇を築き、翁面を安置し、神酒と洗米を供へ、これを大夫以下順次に頂戴して舞台へ出る。",
              "citation": {
                "source": "よくぞ能の家に",
                "author": "二十四世　観世左近",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、半蔵夫婦が供える神酒や洗米なぞを喜び受けるかのように。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島県｜平附近の例をいうと、正月十一日の農立ての日の朝、今年｜苗代にしようと思う田に行って初鍬をいれ、三所に餅と神酒・洗米とを供えて、これを早稲・中稲・晩稲の三通りに見立てて置く。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
