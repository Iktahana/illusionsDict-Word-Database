          "standard": [
            {
              "text": "戦後の住宅建設ラッシュに伴い、この地域では製材業が地域の基幹産業として発展した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "安価な輸入木材の増加により、国内の小規模な製材業は苦境に立たされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の代から続く製材業を守るため、若き経営者が新しい販路を開拓しようと奮闘している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "製材業を営む父の七人の子どもの真ん中に生まれ、国民学校の四年で敗戦を迎えた古山にとって、図書館は好奇心をみたす絶好の広場だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
