        "examples": {
          "standard": [
            {
              "text": "このコーヒー豆の生産国はエチオピアで、フルーティーな香りが特徴です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "原材料の生産国によって、最終的な製品の価格が大きく変動することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラベルには、生産国だけでなく具体的な農園名まで詳しく記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "敵は世界に誇る大型飛行機の生産国である。",
              "citation": {
                "source": "真珠",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産国となるべし、生産機関の発達する必然の理に従い、自然の結果によりて平民社会となるべしと。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
