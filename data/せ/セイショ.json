      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "printed style (of writing Chinese characters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それによつて見ると、隷書と同時に正書行書も行はれて居つた形跡が明かで、隷書と正書を一紙の中に書いて居るのもあり、又王羲之と大抵同時代の文書の中には、既に行書すらも行はれて居ることが證明される。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はいつも速記者に口授して書かすので、私の書いたものといつては先づ校正書位のものでせうからね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世上には偽書七十二巻を作って流布し、正書は誰にも見せなかった。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡太郎義家が奥州征伐にでかけるとき、はじめて天皇が正書を義家に授与された、ということになっている。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭学者｜新宮凉庭が、長崎から帰って、ここに順正書院という塾を開いたとき、自分が先に立って弟子たちといっしょに加茂河原から石を運んで、流れや池を造ったのだという。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
