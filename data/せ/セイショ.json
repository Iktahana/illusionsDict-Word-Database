[
  {
    "uuid": "f9eddbd8-73e6-55bd-9710-c7b78a2d37ca",
    "entry": "正書",
    "reading": {
      "primary": "せいしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
