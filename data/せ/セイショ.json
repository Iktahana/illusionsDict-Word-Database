  {
    "uuid": "433bf596-a849-5c19-b23e-13e689379f78",
    "entry": "盛暑",
    "reading": {
      "primary": "せいしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "height of summer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甲府は盛暑は東京よりも暑いときいたが、実際である。",
              "citation": {
                "source": "スケツチ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れも盛暑の季節に登らないのを遺憾とした。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが盛暑の候であったなら、どんなに味品高い鮎であったろう。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一　八月の盛暑の頃であつた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
