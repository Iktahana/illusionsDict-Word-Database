    }
  },
  {
    "uuid": "7812bcb2-58f2-5794-8caf-f33323fe5114",
    "entry": "誓書",
    "reading": {
      "primary": "せいしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "written oath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誓書および遺詔を出して授けたまい、敢て天に違う者あらば、朕が為に之を伐て、と言い訖りて崩れたまえるなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、前年長政に与えたる誓書あるに拘らず、長政に対して一言の挨拶もしなかった。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の点は、ピイクロフトがこの盛大なる結構な会社の職にありつく時、宣誓書を書かされたと云うことだ。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に引いたガスターの書に出たルマニアの伝説には、最初犬も猫もアダムに事えて各その職に尽し、至って仲よく暮したが、後患を生ぜざらんため協議して誓書を認め、犬は家外、猫は家内を司る事とし、猫その誓書を預かり屋根裏に納めた。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は約束だとて受け付けず、犬その約束を見たいというから、委細承知と屋根裏に登ると、原来かの誓書に少し脂が付きいたので、を殺し食ったが、犬は猫が誓書を示さぬを怒り、これを咬んで振り舞わした。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来犬猫を見れば必ず誓書の紛失を咎め、猫また※を追究すると。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府案第十二条は、この五人の委員が「任命後最高裁判所長の面前に於て正規の宣誓書に署名してからでなければその職務を行ってはならない」としている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正規の宣誓書の内容は一般に知らされていない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その年の暮に大石内蔵助が、かねて城明渡しの際｜恩顧を蒙った幕府の目附方へ御礼かたがた、お家の再興を嘆願するために、番頭奥野将監と手を携えて出府した際、小平太は何物かに後から押されるような気がして、内蔵助の旅館を訪ね、誓書を入れて義徒の連盟に加わった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代の精神と、もう一つは、世が太平になったために、ひとたび主に放れた浪人は喰うことができない、何人も抱え手がないという事実に圧迫されて、小平太のほかにも、誓書を頭領にいたして、新に義盟につくもの前後｜踵を接した。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓書、といういさましい文章を講堂でよみあげた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ即ち松下村塾血誓書の出で来りたる所以なり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この中には、新庄藩主｜戸沢上総介殿の誓書が入っているのです。",
              "citation": {
                "source": "峠の手毬唄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊王｜攘夷を朝廷に誓い奉る誓書です。",
              "citation": {
                "source": "峠の手毬唄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ちなさい、――帰るのはいいが、もし新庄藩の者が受取りに来たらどうなさるか」「さあ……それは」「この文匣がなくてはいけないでしょう」　伊兵衛はそういって座をすべり、うやうやしく紐をとくと、中に入っていた誓書を取出し、そのあとへ手早く偽筆の誓書を書いて入れた。",
              "citation": {
                "source": "峠の手毬唄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――余の誓書が参るよりも先に、小寺家より当家へ質子を送るべきではないか」「そうです。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、一束ねにした誓書をたずさえて、旧小寺家の付人のほとんど全部の者が、宗円の前に出て、このまま黒田家の家中として留め置かれたいと願った。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今年の正月下旬のことであるが、そのとき郡代と双方と三者のあいだに、「今後は境を越えない」という誓書を取交わした。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後もし問題が起こったばあいに、相手がその誓書を悪用すれば、こちらにも非分があったことになりかねない。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで孝也がいってその理由を述べ、誓書を取戻して来たのであった。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義山公の法要で高野山へいって、九月でなければ戻らない筈だ」　――弾正（伊達｜宗敏）さま御出府のあとにて、安房（同｜宗実）さまが御上座、まず老臣誓書のことが出ました。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって神文誓書して、なにごとによらず、互いに熟議相談しておこなうこと、独り主君にもの申すことあるべからず。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長の死を、彼らが知ったのは、その日の七刻下がり（午後四時）の頃だったから、宗治の切腹直後、誓書の交換が行われてから、わずか一刻（二時間）ぐらいな後でしかない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉会の式として、（いずれ協力一致して、幼君を奉戴、異背あるまじき事）　の誓書を納れ、これを故主信長の霊前に供え、併せて、評定の結末を直ちに報告することになった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いぶかりつつ眸をこらして正面の仏龕ほのかな辺りを見ると、厨子、位牌、金壁、供華、拈香などの厳かなものの影のうちに、さきの誓書一束が供えられてあるのが一しお目につく。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、誓書を以て、「勝豊以下、家中一統、御手に属しますれば、以後のおさしず、宜しきように」　と、秀吉のすすめに応じて来たものである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ誓書を認めて差し出した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
