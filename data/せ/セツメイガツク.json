[
  {
    "uuid": "a9fd9916-cea0-5d93-984e-d81723d65499",
    "entry": "説明がつく",
    "reading": {
      "primary": "せつめいがつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
      "ctype": null,
