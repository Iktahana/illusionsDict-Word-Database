          "literary": [
            {
              "text": "精神衛生上もディスプレイには消え、ハードディスクには止っていただきたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、あの病院は精神衛生上よろしくないよ」「そうね、恐しいところね」「しかし、上顎の人が、あんなに多いとは知らなかったね」「それに、あれは、直ぐ転移するらしいの。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが精神衛生上、暇つぶしや退屈凌ぎが有っている価値をここで一々評価している暇はない。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の精神衛生の見地からね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
