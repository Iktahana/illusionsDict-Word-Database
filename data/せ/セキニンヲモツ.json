    "definitions": [
      {
        "index": 1,
        "gloss": "to be responsible for",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分のする事は一つ一つに考慮と全責任を持つた。",
              "citation": {
                "source": "小学生のとき与へられた教訓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら常におのれの発したる一語一語に不抜の責任を持つ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さまは、姉だからと云って、私のすることに責任を持つことないじゃないの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば、前川さんに、どんなことをしてもらっているにしろ、お姉さんがあの奥さんに、責任を持つことないじゃないの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの推量は――それは単に私自身の推量であるに相違ないが、その事実に対して私はあくまでも責任を持つのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しその男はあの血腥い事件の一々の部分に対する責任を持つてはゐないかも知れない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分責任を持つてはゐないだらうと云つても好からう。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――手前は看守長だと言うんなら、手前は言った言葉に対して責任を持つだろうな。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は君の政策戦略に責任を持つね」大統領「御念に及び申さぬ」ゼルコフ「もし失敗したらどうする。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達が相互の愛に責任を持った以上、その結果たる生活にも、責任を持つべきであったのだ。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが責任を持つから任せろといふことを、双方の代表に向つて云つたのだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはただ、彼等の今日の生活の形がどんなものであらうとも、彼等が自分の過去に對して責任を持つものであることを望むんだ。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハロルド・ロイドの「防疫官」と題する喜劇を説明して居るとき嘔吐を催おしたのであるが、真正のコレラであると決定した頃には、ぎっしりつまって居た観客は東京市中に散らばって、防疫の責任を持つ当局の人々は蒼くなったけれども、もはや後の祭であった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、僕については大使館で責任を持つことにして、もう数カ月間追放を延ばして貰おうというのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "市政に責任を持つ市長の希望なんだ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして病氣を直してやるまで責任を持つと云ふ約束の外には、こちらは殆ど執着もなくなつてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＰＣ―９８０１の立ち上げの先頭に立ったあと、パーソナルコンピューター全体の販売促進に責任を持つポジションについていた浜田俊三は、ＰＣ―１００を前にして当惑していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云っても、勿論彼が、彼のした行為のあらゆる結果に、責任を持つ気でいた訳ではない。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の生活を大手術してかかるには、まづ、名前だけの夫婦関係を断ち切るべきであらうかと、里子の行末に就いて、直吉は、責任を持つべきものかどうかを疑問に思つてゐる。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、牧田氏は所員の不始末に就いて、自分で責任を持つ限りにはあまり文句を云ふ人物でもない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿に責任を持つなンて気の毒みたいだわ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　谷崎潤一郎氏に答ふ　次に僕は谷崎潤一郎氏の議論に答へる責任を持つてゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々の些少な責任感はあっても、自分の一生に自分が責任を持つというような、生活の礎となるべき責任感は存しない。",
              "citation": {
                "source": "生活について",
                "author": "――地方の青年へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ幼稚園にいるうちに智慧の悲しみを知ることには責任を持つことにも当らないからね。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分のやったことに責任を持つだけであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ幼稚園にゐるうちに智慧の悲しみを知ることには責任を持つことにも当らないからね。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで赤痢にでも罹かれば全くともかくもの御蔭だ」「いいさ、僕が責任を持つから」「僕の病気の責任を持ったって、しようがないじゃないか。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自由を現象界から駆逐して英知的の事柄としたのでは、一般にカントの二元論となり終わり、われわれの意識を超越した英知的性格の行為にわれわれが責任を持つということが無意味になってしまう。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
