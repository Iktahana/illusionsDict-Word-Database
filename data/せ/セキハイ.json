        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の敵手は決勝まぎわに腹痛を起こして惜敗したと伝えられている。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次点者は十三という数で惜敗したそうである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの“トキノワダイ”は、氏の在世中は、スタート癖が惡かつたり、勝つべきときに惜敗したり、少しも、氏を熱狂させるほどよろこばしたことのない馬である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のおせきはいつもよりも綺麗に化粧しているのが、月のひかりの前にいっそう美しく見えた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のおせきはいつもよりも綺麗に化粧してゐるのが、月のひかりの前に一層美しくみえた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "威張る者がいなくなった代り、せきはいそがしくなった。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
