    "definitions": [
      {
        "index": 1,
        "gloss": "overhanging snow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "常念の肩には大きな雪庇ができるように聞いていたが、もう落ちてしまったのか、問題にするほどのものはなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍肩は西から吹き上げた風がすぐ槍沢へ吹き下ろすので、雪庇はできないらしい。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルには雪庇といわれるほどのものはなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師堂附近の雪庇は平凡な形のもので、その上を歩いても落ちなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒部五郎岳は登りも降りも平凡な尾根で雪庇もなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪庇もない緩い尾根だ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上からちょっと行くと左の尾根へ雪庇がつづいているので、それを伝って降った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを登り切ると常念乗越で雪庇等もなく風のために雪も殆んど吹き飛ばされたガラガラ道が常念の小屋までつづいている。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前常念とのジャンクションから頂上までは本沢へ向って相当大きな雪庇がつづいていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに大きな雪庇が一ノ沢に向ってできているので、尾根の端を歩くのは危険である。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな雪の少ない十二月の初めでさえ雪庇ができているのだから冬期は随分大きくなるであろう。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東天井の中山へつづく西尾根には小さい雪庇が南向へつづいていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上附近にさえ雪庇というほどのものはなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本尾根の取付きにも問題になるような雪庇はなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷ノ池附近には相当大きな雪庇が東側へ出ていたが、三月頃ほどのこともなさそうだし、つらくてもタンネの中を行けば心配はない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長次郎のコルには雪庇はなかったが風のために少し雪の窪みができていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜戸岳には左俣側へ向って、のぞくこともできないほど大きな雪庇がつづいている。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜戸岳から笠ヶ岳までの尾根は平凡で、雪庇もあまり出ていなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからちょっと進んだところで不注意にも雪庇をふみはずして小代谷側へ落ち、ひどく身体を叩き付けられた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの急な雪庇を登るのはつらかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一時ここで雪の止むのを待った方がよいに違いないと思って、風陰を探しながら歩いていると、また雪庇をふみはずし、こんどはまっさかさまに投げ出されてぞっとした。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速雪庇の下を掘って入る。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕はまださっきの雪の孔の中で眠っているか、もしくはその前に雪庇から落ちたようだが、あのまま倒れていて、今夢を見ているのではなかろうかとこう思って、声を限りにどなってみた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで取付きやすい左のチムニーに入ったが、これには全部雪がつまっていて上の方に雪庇さえ懸っていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雪庇を落すために二、三度努力してみたけれど、ピッケルが思うようにとどかぬので、諦めてその下に雪のトンネルを斜めに掘り始めた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この谷にはよく雪庇ができているので、なるたけ右寄りに巻いて谷を渡る方が安全である。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この附近は随分風が強いとみえて雪は固くなっているし、浄土側には一部雪庇ができてその下には大きなスカブラができている。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪庇の軒下をえぐり取ってその向うに吹きだまりをつくっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに彼らは雪庇の穴を発見した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿州側にはきわどい雪庇が張り出ていた。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
