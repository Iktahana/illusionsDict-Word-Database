        "examples": {
          "standard": [
            {
              "text": "祖父は最近、摂護腺の肥大による排尿のトラブルに悩まされているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "摂護腺は男性特有の臓器であり、精液の一部を産生する重要な役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定期的な検診を受けることで、摂護腺に潜む病気を早期に発見することが可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お父さんを金沢の病院に入れるためにいろいろやっているそうです、病気は老年との関係でしょうが、手術を必要とする摂護腺肥大で癌のおそれある由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前カラ予ニハ前立腺（青年時代花柳病ヲ患ッタ頃ニハ摂護腺ト呼ンダモノダガ）肥大症ガアリ、トキ／″＼残尿ガ溜ッタリ、尿ガ出ナクナッテカテーテルデ導尿シタリシタコトガ二三回アル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
