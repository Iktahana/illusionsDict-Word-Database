[
  {
    "uuid": "47a74c36-536d-56ac-adb5-a40427e3a3dd",
    "entry": "切迫",
    "reading": {
      "primary": "せっぱく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
