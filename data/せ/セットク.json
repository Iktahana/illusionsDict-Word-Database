[
  {
    "uuid": "f845b063-cd8c-5ba5-9230-6c80d70da039",
    "entry": "説得",
    "reading": {
      "primary": "せっとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
