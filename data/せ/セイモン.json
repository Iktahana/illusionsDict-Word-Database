          "literary": [
            {
              "text": "入口に琴曲指南｜山勢門人何とかの何枝と優しい書風で書いた札が掛けてあった。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、六日、毎夜、大勢門口大手の脇へ、人せうじたゝき、畳上り候音きこへたてるに付、支配方より新八呼に参り、町方御家中、此已後たてらぬ様に御触御座候。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
