    "definitions": [
      {
        "index": 1,
        "gloss": "cosmopolitan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
