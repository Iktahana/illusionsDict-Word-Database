          "literary": [
            {
              "text": "丁度都では此時参議｜右衛門督藤原忠文を征東大将軍として、東征せしむることになつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「征東大将軍｜宗良親王、信濃におわしたので信濃宮、そのお方のご遺跡をはじめとし、南朝方の諸将の遺跡が、随分信濃にはあるようでござる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義仲、法皇を法住寺殿に囲み、ついにこれに逼り奉りて征東大将軍の宣旨を得て頼朝討伐の準備をする、遠く秀衡にまで院宣を申し下して頼朝を夾撃せんとする。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
