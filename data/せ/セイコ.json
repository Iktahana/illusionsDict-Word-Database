    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Seiko",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがこの一週間ばかり旅行して昨十日夜に帰って来ますと、私の机の上に森下氏のお手紙と新青年の六月増大号と、「アヤカシノゴセイコウヲシュクス○トシ○タミ○フミ○チヨ」という岡山発の電報がほかの手紙とゴッチャになって乗っています。",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその過程でＩＢＭが激しい互換機との競争にさらされたのに対し、日本電気は唯一セイコーエプソンの挑戦はあったものの市場の独占を存分に楽しんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フントウ　ヲ　シャス、セイコー　ヲ　イノル、キカンブカフ　一ドー　セーラー　ショクンと電報文みたいに片仮名で書いてあった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セイコーエプソンは、この挑戦に打って出る覚悟を決めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八七（昭和六十二）年三月、セイコーエプソンがＰＣ―９８０１互換機を発表した段階で、日本電気はすぐさま、互換ＢＩＯＳと互換ベーシックに著作権侵害があるとして法廷闘争に訴えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　アイヌの宅神チセイコロカムイとオシラ神　北海道に住するアイヌ族の間には、今もってやはり一種の宅の神を祭っている。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをチセイコロカムイという。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "チセイは家の義で、チセイコロカムイは、家を持つ神の義である。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん地方により、家風により、いろいろ違ったものがあるらしいが、しかし多くの神々を祭る中でも、このチセイコロカムイは家にとって第一番の神であるという。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるオシラ神また一種の宅神として、アイヌのチセイコロカムイと同一起原の物ではなかろうかというのである。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからばアイヌがイナオを衣服として毎年チセイコロカムイに着せるということ、またその身体が木の棒に彫刻を加えて、人体を表わしたものであるということ、さらにそれを家の神として崇敬するということのごときは、すべてわがオシラ神において見るところと一致するものであるといってよい。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　オシラ神の名義　アイヌの宅神たるチセイコロカムイが、果してオシラ神と密接の関係を有するものであるならば、その根原がアイヌの方にあって、東北地方のオシラ神は、前記のごとくその遺風の存するものと解するを妥当とする。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらオシラ神が一方ではオヒナすなわち雛人形とその名称を同じゅうし、一方では蝦夷神のすなわち夷神たるチセイコロカムイと多くの類似点を有するの事実だけは、とうてい否定することができないと信ずる。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セイコウヲシユクス」私は無意識にその文句を口誦んだ。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
