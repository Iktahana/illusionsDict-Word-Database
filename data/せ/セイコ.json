    },
    "definitions": [
      {
        "index": 1,
        "gloss": "worldly affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世故に慣れているというまででなくても善良の老人は人に好い感じを持たせる、こういわれて悪い気はしない。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は疑う、太祖の人情に通じ、世故に熟せる、まさに是の如きの詔を遺さゞるべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈夫づくりの薄禿の男ではあるが、その余念のない顔付はおだやかな波を額に湛えて、今は充分世故に長けた身のもはや何事にも軽々しくは動かされぬというようなありさまを見せている。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎野口君は予より年長でもあり、世故にも長けてゐた。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は世故に長けて來ると共に段々情愛を深めて行くものだが、今の四十以上の女は皆當り前のやうに男に對する心を全く子供に向けてしまう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "殉死を許した家臣の数が十八人になったとき、五十余年の久しい間治乱のうちに身を処して、人情｜世故にあくまで通じていた忠利は病苦の中にも、つくづく自分の死と十八人の侍の死とについて考えた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い歯は見せないぞという気持ちが、世故に慣れて引き締まった小さな顔に気味悪いほど動いていた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世故に慣れきって、落ち付き払った中年の婦人が、心の底の動揺に刺激されてたくらみ出すと見える残虐な譎計は、年若い二人の急所をそろそろとうかがいよって、腸も通れと突き刺してくる。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は急に青味を増した顔で細君を見やったが、その顔は世故に慣れきった三十女のようだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は何かなしに新聞に投書でもする人は世故にも長け文章にも長じた中老人だとばかり思っていたから、中坂思案外史も伯父さん分に当る年配の人だとばかり信じ切っていた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒沼伝兵衛の死――藤助のゆくえ不明――暗がりの怪しい男――この三つを一つに結びつけていろいろ考えたが、何分にも世故の経験に乏しい長三郎の頭脳では、その謎を解くべき端緒を見いだし得なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや世故にたけたといわれる年頃では、そういう階級の狭い生活が多くの女の心に偏見と形式と家常茶飯への没頭、良人の世間並な立身出世に対する関心をだけを一杯にしていたであろう。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　世故に長けた友人は、そう言って下宿を出て行った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に世故にたけていることも、エレガントであることもできないのである。",
              "citation": {
                "source": "十月の文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本質的には世故にたけた、十分妥協性をもったものなのだが、それを語る語りかたの独特に意識ある態度のために風格が発生し、その確信をもって押してゆく雰囲気の魅惑に大作家らしい趣、生活力が具わっているのではないのだろうかと考えたのであった。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙かに世故にたけて、その装いの風情で女としての社会的、文学的存在を守ってゆく方向で出発したことはさきにふれたとおりである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然かも父祖の遺業に安居して天産に衣食せる人民は悠々として世故に迂なるを以て四年の水害に苦しみ四年の凶斂に悩み、更に居村滅亡の猾策に遭ふも詭弁甘言の惑ハす処となりて自ら陥穽に墜落するを知らざるなり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧は特に悍と称すべき女でもなかったらしいが、とにかく三つの年上であって、世故にさえ通じていたから、くみが啻にこれを制することが難かったばかりでなく、動もすればこれに制せられようとしたのも、固より怪むに足らない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "西川に伯仲する秀才なれども、世故には西川よりも通ぜるかも知れず。",
              "citation": {
                "source": "学校友だち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新来の客は、どんな場合にも決してまごつくようなことがなく、いかにも世故に長けた人間であるという実を身をもって示した。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうですよ、パーウェル・イワーノヴィッチ、」と、マニーロフはその顔に、ただ甘ったるいというだけではなく、世故にたけた如才ない医者が甘くさえしてやれば患者が悦ぶと思って矢鱈に甘味をつける水薬同様、しつこいと言ってもいいほどの表情を浮かべて言うのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "人情の向背も、世故の転変も、つぶさに味って来た彼の眼から見れば、彼等の変心の多くは、自然すぎるほど自然であった。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "世故に長けた先生はそれにはわざと答えずに、運動帽を脱ぎながら、五分刈の頭の埃を勢よく払い落すと、急に自分たち一同を見渡して、「そりゃ毛利先生は、随分古い人だから、我々とは少し違っているさ。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通それが早分りのする人情｜世故に通じた一般的のものだけに、金持ちや、物分りのいいという世間学通の人たちのいう事はこれと一致した。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の世故人情に通じてゐたことは彼の談林時代の俳諧を一瞥すれば善い。",
              "citation": {
                "source": "続芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、嚢の口から順々に這い出して火の気のない部屋の中を、寒そうにおずおず歩いたり、履の先から膝の上へ、あぶない軽業をして這い上りながら、南豆玉のような黒い眼で、じっと、主人の顔を見つめたりすると、世故のつらさに馴れている李小二でも、さすがに時々は涙が出る。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、濡鼠になった老人の姿が、幾分の同情を動かしたからで、また一つには、世故がこう云う場合に、こっちから口を切る習慣を、いつかつけてしまったからである。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家　最も善い小説家は「世故に通じた詩人」である。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "利口な人、世故に長けた人とふつう称讃されておる人たちを見るに、彼らは自ら少しの反省をなすこともなしに、人間はこんなもの、社会はこんなもの、女はこんなものなどと勝手に決めてしまい、そしてそれに協った幾つかの規矩準繩を作って只管にそれを実行しようとしておる。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる世故に長けた人、世慣れた人が自分らのみが他の人々を本当に理解しておりまた他の人々を愛する権利をもっておるかのように考えて振舞っておることほど私には滑稽なものはない。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
