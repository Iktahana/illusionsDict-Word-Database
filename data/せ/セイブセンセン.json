    "definitions": [
      {
        "index": 1,
        "gloss": "Western Front (of WWI)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
