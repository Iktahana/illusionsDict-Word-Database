[
  {
    "uuid": "d2f90337-7401-5c94-8dba-83a9ec81ce38",
    "entry": "生面",
    "reading": {
      "primary": "せいめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
