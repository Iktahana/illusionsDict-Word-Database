    "definitions": [
      {
        "index": 1,
        "gloss": "mental derangement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "精神錯乱したるその瞬息に、懐なりし出刃は渠の右手に閃きて、縁に立てる男の胸をば、柄も透れと貫きたり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく不思議なことではあるが、精神錯乱を暗示したのは船長自身であって、その怪しい行為の原因が単なる特異の風変わりとは認められないのであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "――云わずと知れた、彼は例の神秘的な精神錯乱の発作に捕われたのです。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師は泥酔で精神錯乱の結果だらうとした。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして警察は僕が妻の死を悲しんだ余り精神錯乱せる者と見倣してしまつた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それはすぐ手近にある唯一の本であったし、また私は、今この憂鬱症患者の心をかき乱している興奮が、これから読もうとする極端にばかげた話のなかにさえ慰安を見出すかもしれない（精神錯乱の記録はこの種の変則に満ちているのだから）、というかすかな希望をいだいたのであった。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "田上博士の説によると、会社の窮境よりも黴毒による一時的の精神錯乱が自殺の原因となっているだろうとのことであるが、これは単なる想像にすぎぬと博士は言った。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神錯乱で自殺してしまったよ。",
              "citation": {
                "source": "僕の昔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――戦争のさなかにも、また、長い捕虜生活中にも、突然精神錯乱をおこす兵隊があつたが、砲弾炸裂の衝撃や、囚れのなかの死の恐怖や、仲間同士の葛藤なぞが原因で、ふつと狂ひ出す兵隊があつた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の医師たちは死体解剖の後、精神錯乱の疑いをぜんぜん否定した。",
              "citation": {
                "source": "作家的思想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、彼は週期的に精神錯乱を起す不幸な先天的欠陥があつて、そのたびに異常に突きつめた世界へ走り、幾日も睡らず考へ又書きつゞけ、その手記を私の所へ送つて自殺を計る。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "語学でも分るやうに特異な頭脳であつたが、週期的な精神錯乱のせゐなどあつて、構成や表現が伴はず、眼高手低、宿命的な永遠の傑れたディレッタントであつた。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストリリはその場に嘔吐、昏倒し、早速収容手当をしたが、二日目には邪熱を発し、眼は一所を注視して動かなくなり、手足の筋は硬直するし、胃は食餌を受けなくなり、精神錯乱を見るに至つて、医者も全く全快を断念してしまつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "病中精神錯乱したといふことであるし、潜入の決意も忽然たる平癒も共に幻覚の暗示から由来してゐる。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はたぶん遺伝梅毒だつたと思ふ、周期的に精神錯乱し、その都度自殺を試みる。",
              "citation": {
                "source": "暗い青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の周期的な精神錯乱のことであらうか。",
              "citation": {
                "source": "暗い青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部は我が身を、フィラデルフィア迷路の中に彷徨しながら精神錯乱した男に較べて、脳髄のしびれて来るのを感じたことでありました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "語学でも分るように特異な頭脳であったが、週期的な精神錯乱のせいなどあって、構成や表現が伴わず、眼高手低、宿命的な永遠の傑れたディレッタントであった。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かほかの人がそんな話を私に伝えたとしたら、私だってそれは精神錯乱のたわごとだと考えただろう。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "知事は、私がさっき喚きたてたのは、精神錯乱の一時的再発だったと考えたらしく、またすぐ以前の思いやりのある態度に変った。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この人は、孤独と精神錯乱から出てくる一つの楽しみを味わってもいるのです。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ温和にして猫のごとく従順な君コン吉が、こんなふうにむやみに乱暴を働くというのは、多分、かねて神経衰弱の徴候をはらんでいた君の頭の鉢が、「変り咲き」の国花の花鉢に接触したとたん、交流した精神錯乱の過剰電気が、君の大脳の電極でスパークしたのに違いないよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットの精神錯乱はすでに十年前に自然治癒していたことはこれでもう疑う余地のないことになりました。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそうした事がすべて、怖ろしい精神錯乱のうちに見た悪夢だったのだと思ったのです。",
              "citation": {
                "source": "寡婦",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自殺者の如きも新聞紙上に現はれる直接の原因は精神錯乱とか、家内の不和とか財政不如意とか失恋とか様々であるが、尚其先きの原因を尋ねれば孰れも生存競争に於て適者が栄え蔓つて、不適者に生存の余地を与へぬに基づくこと故、人口の増加するに随ひ自殺者の年々多くなることも亦到底避けられぬかも知れぬ。",
              "citation": {
                "source": "芸術としての哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高名な博士たちが、力を合せて、それほどでもない王を無理矢理精神錯乱につくりあげてしまったらしい形跡があるが、上からの要請があれば、どんなことでもやってのけそうな連中のことだから、それもまた驚くようなことはない。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷酷な処刑ぶりを見るなり、兵隊達は精神錯乱をおこした。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼等は狂人であるのだが、もし私が何か彼等の例を私に移すならば、私自身また彼らに劣らぬ精神錯乱と見られるであろう。",
              "citation": {
                "source": "省察",
                "author": "MEDITATIONES",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵のためには精神錯乱であり不合理であつたが、その味方にとつては奇蹟とも呼ばるべき彼等の「誇り」であり、新鮮さであり、そして精神上の純潔さであつた。",
              "citation": {
                "source": "〔翻訳〕ステファヌ・マラルメ",
                "author": "ヴァレリイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし神は決して精神錯乱して、この処罰の置き違えをなし給うたのではない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
