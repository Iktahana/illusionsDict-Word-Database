[
  {
    "uuid": "c439551e-84fe-50f9-8b27-41616123c7c8",
    "entry": "精神錯乱",
    "reading": {
      "primary": "せいしんさくらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
