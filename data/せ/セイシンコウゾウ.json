        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地震の多い日本では、制震構造の建物が多く建設されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この高層ビルは、最新の制震構造を採用しているため、地震に強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "制震構造は、地震の揺れを吸収し、建物の被害を軽減する技術だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
