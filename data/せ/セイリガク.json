          "literary": [
            {
              "text": "蘇氏の策論に殿せしものは即ち朱子の性理学也。",
              "citation": {
                "source": "凡神的唯心的傾向に就て",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "一起一倒要するに性理学の範囲を出でず、抽象し又抽象し推拓し又推拓す、到底一圏を循環するに過ぎず、議論｜愈高くして愈人生に遠かる。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            }
