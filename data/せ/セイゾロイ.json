    "definitions": [
      {
        "index": 1,
        "gloss": "assembling (in full force)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ワラ、おまえも、あがってこい」　塔の上では、カメラのセッティングのために撮影用のライトが点灯され、全員がせまいところに勢ぞろいした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはおそらくその頃の進歩的な婦人たち全員の勢ぞろいとも云うべき盛観であったろうと思う。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時に終業すると、文選場で一同勢ぞろいをして、カントクのところへ残りの仕事をひっつかんでデモで押しかけた。",
              "citation": {
                "source": "大衆闘争についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四人の家臣らは、家族を連れ、家財道具を持って、当日、八幡社の広場に勢ぞろいをすることに決めた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから勢ぞろいして火元の湯屋へ繰り出したのだが、その夜は乾いた北西が吹いていて、どうにもならなかった。",
              "citation": {
                "source": "舞馬",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスピストルやガス銃を持った突撃隊が、警視庁に勢ぞろいをしたのは、翌日のおひる近くであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには怪塔ロケットが七八台も勢ぞろいしているそうだ」「ふむ、怪塔ロケットは一台かぎりかと思っていましたが、七台も八台もあるのですか。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人位でぶつかってみろ」　三人の逞しい警官が、たちまちその場に勢ぞろいをすると、一、二イ、三と声を合わせ、「エエイッ」　と扉にぶつかりました。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、ボートのうえで手提信号灯がうちふられていたが、全部のボートが無事勢ぞろいをしたことを伝えたものであろう。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時刻になると、伊東の海にはイワシ船が勢ぞろいをし、見張り船に誘導されて、所定の位置へ走るもの、待機のもの、明治初年の海戦を見るようである。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事務所を一歩でれば、隣は大劇場の楽屋口で、その道の並木の下には十六七の娘たちが三々五々、またエンエンと勢ぞろいしてスターの楽屋入りを待っている。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある天気晴朗の夏の朝、グラン・ミューレの氷壁の下に勢ぞろいをした六人の人物。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同はまたにわかに勢ぞろいして、本陣の四方を固める。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日を期し、総代四人のものが勢ぞろいして本庁の方へ同行することもおぼつかない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢ぞろいをすることのじょうずな羊は、はなればなれになりません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目では算えきれないぐらい、ざッと十人ちかいアンチャンが勢ぞろいしている。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、あなた、犯人はとてもつかまりません」　明朝十二時に新十郎の家で勢ぞろいすることにして、一同は別れ、めいめいが思い思いのところへ探偵にでかけた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の部屋々々にタンスが並び、着物がおさまるにつれて、土蔵の中にはより上等の嫁入り衣裳貴金属がひそかに勢ぞろいをととのえているのであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんだら一｜遍勢ぞろいをして、顔を見おぼえておかんことにはつごうが悪いテ」「御家老殿も、先刻そのようなことをおっしゃっておられた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日が元日らしいためには、どんな条件が必要かといえば、門松・トソ・雑煮というような形式はさておき、私の経験によれば、まず何よりも、家族が多少改まつて勢ぞろいをするということである。",
              "citation": {
                "source": "時　処　人",
                "author": "――年頭雑感――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一行勢ぞろいをして、大きに期待しながら出かけたが、このような場合によくある如く、殆ど何も打ち寄せられていなかった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす青い灰色の光のカーテンを背景にして、蒼ざめた悲しげな人間の顔が勢ぞろいして、ハリスも既にその仲間入りをしているかのように彼に向かって頷いたり、わけのわからないことを早口で話しかけたりしながら、空中をふわりふわりと浮いて過ぎてゆくのがみえた。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝の七時、一木の組は彼の家で勢ぞろいした。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発までには準備や勢ぞろいに暇どって、雲龍寺を出たのが午後一時、館林通過が二時半頃であった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "セムシ詩人が森の妖婆の杖みたいなものに縋って玄関から出てくると、外に勢ぞろいの見送りの娘子軍の中から、あやかさんが、「内海さんはムリじゃありませんこと。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂君は、学校で篠崎君からこんどの事件のことを聞いたものですから、まず、いとこの羽柴壮二君に電話をかけ、羽柴君から少年探偵団員に伝えてもらって、一同、桂君のところに勢ぞろいをしたうえ、篠崎家を訪問することになったのです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう、篠崎始君をくわえた、七人の少年探偵団員は、なるべく、おとなたちのじゃまをしないように、門の前に勢ぞろいをして、いろいろと相談をしていましたが、ぼくたちも、手をつかねてながめていることはない。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、佐々木兄弟の行動から、今朝の勢ぞろいの事でも嗅ぎ知ったら、これは由々しい手ちがいになる。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つきましては、小角は微力ですが、三万の野武士と、裾野から駿遠甲相四ヵ国の山猟師は、わたくしの指ひとつで、いつでも目のまえに勢ぞろいさせてごらんにいれます。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東の空がしらみだしたら一番｜貝、勢ぞろいの用意とおもえ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
