    "definitions": [
      {
        "index": 1,
        "gloss": "west wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頂上内院火口の西壁、剣ヶ峰の側からなぎ落されて、直線に突き切ること三里、力任せにたち割った絶壁の斜面に、墜石崩石は、ざっくばらんにほうりだされている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一列に並んでいる古い銅像と黒い柱との間に、西壁の阿弥陀が明るく浮き出して、手までもハッキリと見えている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは西壁の浄土図にのみ執着したが、壁画はなお他に三つの大壁と八つの小壁とに描かれている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本殿の西壁には非常な大きさの厚い金の板の上に日の神が表現せられている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "西壁のほかにもあらゆる部分に金の板や間柱が嵌められている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
