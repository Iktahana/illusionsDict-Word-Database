        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはちょうど手ぬぐい浴衣もあればつづれ錦の丸帯もあると同様なわけであって、各種階級の購買者の需要を満足するようにそれぞれの生産者によって企図され製作されて出現し陳列されているに相違ない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして評判は広告と宣伝によって高まるとすれば、書籍の生産者が売薬化粧品商と同一の手段を選ぶのは当然のことであって、これをとがめるのは無理であろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "消費者の占めていた地域の上に初めて生産者が氾濫し、生産者群の地帯が膨張するのだ。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程われわれは立派な生産者だ。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な生産者には違ひあるまいが、生きて行く先の無いことも間違ひなしだ。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産的各省ハ私人生産者ト同一ニ課税セラルルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此裁決ハ生産的各省個人生産者及ビ勞働者ノ一律ニ服從スベキ者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "又機械や工場ができて、社会の生産力が非常に進んで来ると、かくの如き機械や工場は、凡ての生産者がめい／＼所有することは不可能でもあり不必要でもあるやうになつて来る。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、これ等の生産機関は一部少数の人の手に握られ、これに反して大多数の生産者は自己の生産機関をもたないで、生産機関の所有者に労働力を提供し、その代りに、賃銀を受けとつて生活するやうになる。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産者の仲間の一人にならなければならなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "各地に生産者組合とか出荷組合とかいふものがある。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産の上の進歩が、生産者にとつての眞實の喜びにまでなつてゐないと云ふのなら、それがさうであるやうな状態にまですべてが改善されねばならぬ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "産米檢査制度も、重量の差額から來る、生産者の損失を掩護することについて、適宜な方法を取るべきではないだらうか？",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それも生産者のものだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産者一般のものではなく、小作人といふ生産者に特別なものである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "賠償金一瓩一圓四錢の三等品になつたかも知れないものが、その日がたまたま雨天だつたといふだけのことで、賠償金一瓩七拾四錢の四等品と認定されねばならぬとしたら、生産者にとつて諦め切れぬことではないか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は家庭のために必要であるばかりでなく生産者の一員として必要であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、文学の大衆化が、従来の作家たちの新しい努力の成果への希望とともに、文学の生産者としての大衆に対する倍旧の期待なしに云われるとすれば、結局は健全性を失って、やはり文壇的な一つの風潮として個々の作家にそれぞれの角度で反映するに止ってしまうのである。",
              "citation": {
                "source": "文学の大衆化論について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場・農村に於ては特に生産者としての婦人を、また生産者の妻や妹を、また出征兵士の家族たる婦人を、街頭サークルに於ては多分その主たるメンバーを成すだろう失業せる婦人を。",
              "citation": {
                "source": "メーデーに備えろ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術を生産するものが、芸術の生産者が生れはじめた。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから軍需生産者に、補償金として支払われるということでもある。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュペングラーが「婦人は同僚でもなければ愛人でもなく、ただ母たるのみ」という標語を示した時、母たるドイツの勤労女性の生活苦闘の衷心からの描き手であったケーテ・コルヴィッツは、どんな心持で、この侵略軍人生産者としてだけ母性を認めたシュペングラーの号令をきいただろうか。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義的民主主義は社会生産の形態を、利潤の要求から直接生産者への享受に進展させているから。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのドイツの人がファシストだとか、そこに責任があるというのでなく、地主、軍需生産者、旧軍人の権力であるファシズムの権力を、動揺的な小市民層、学生などがうけ入れたということが今日のドイツの人々をあれほど悲惨にし、食べるものもない、着るものもないという状態に陥れた。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――確実で増大率でソヴェトのプロレタリアートは自身が文学の生産者となりつつあるのだ。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは文化の生産者の方から見たことだが、もっと意識の低い大衆殊に、農村の婦人大衆に向ってソヴェト映画が文化啓蒙の役割を演じていることは全くすばらしい。",
              "citation": {
                "source": "ソヴェト同盟の芝居・キネマ・ラジオ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産者となった」一九三〇年の初春に行われたラップの大会は、歓喜をもってこの事実を認めた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
