        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「このごろはお前も景気がいいと見えて、なかなか貯金にも精が出るのう。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう、尼僧の取締りの※曇弥さんも、あなたが大へん御精が出ると感心して居られました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えらい精が出るのオ。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤三郎はそのまま土手の方へ行こうとして、フト研屋の店を覗込んで、「よくお精が出るな。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）善助　みんな好く精が出るな。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「精が出るな、景気はどうかい」「上がったり下がったりでござんす」「世間の景気を聞いているんじゃねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙がしい中でよく精が出るな。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）町人にしては毎日よく精が出る。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お千代　長七さんや義平さんのほかにも、この道場へ通つて來る町人衆はまだ六七人ございますが、どの人もみな精が出るには感心して居ります。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは本郷三好坂だよ」「本郷六丁目も来ているぜ」「ふふん、浅草七軒町もいらあ」「おっと、最上の浪人もいらあ」「全くもってご精が出るな、とっ代え引っ代え飽きもせずに、やって来るのはいいとしても、時々ひどく乱暴するので、たいして有難い客ではないよ」「有難くないばかりかい、迷惑至極というものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご精が出るの、え、島原」「うん」というと腰かけた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご精が出るの、娘さん達や」将右衛門立ちどまって話しかけた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何にもいらないことにして、さつぱりときまりをつけてしまつたんだから、いよ／＼これからは勉強に精が出るでせう、さうなることをあなたは望んでゐたんだから。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺や、御精が出るね。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「精が出るね」「へへ、ちっともお帰んなすったのを知らねえで……外はお寒うがしょう？",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると母親が、「御精が出る事、一寸しゃべりませんかもうじきお茶が出ますよ」と云って入って来た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「相変らず精が出るようですね？",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たいへんに精が出るな。",
              "citation": {
                "source": "酒屋のワン公",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "定臣　　へえ、女房を貰ふと精が出るもんだね。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "サダ　　精が出るね、イワさん。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーター・ビール、エールなどに含まれるアルコール含量を確かめる方法　一定量のビールを取り、ガラスのレトルトに入れ、受容器をつけ、穏やかな熱で蒸留して酒精が出る限り続ける。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日逢ってるじゃないですか」「朝食会だけはよくお精が出るのね」「いや、これはやられました。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……初午だというのによく精が出るの」「へッへ、おほめで痛みいりやす」「陽気に向うと蛤汁は臭ってかなわんな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "この節ア、だいぶと、精が出るの」　近日｜俄か仕込みの同心言葉。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝介　（岩の多い小道を靴音とステッキの音をさせて近づいて来ながら）やあ、金吾君、精が出るねえ！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、大層精が出るぢやないか」「へエ、へエ、有難うございます、お蔭で助かります」　申松はピヨコ／＼と職業的なお辭儀をしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "茶汲み四人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに月の良い晩は白梅の精が出るといふ位の老木で、その祟りも考へなきやなりません」　主人金兵衞は、今度は白梅の精を本當らしく擔ぎ出すのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "白梅の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親方、大層精が出るぢやないか」　仕事場でせつせと仕事をして居る勘太に、平次は敷居越しに聲を掛けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凉み船",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺さん、精が出るね」「おや錢形の親分」　番太の吉六は、膝の上の藁埃を拂つて腰を伸ばします。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お長屋碁會",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お角さん、精が出るね」「おや、錢形の親分さん」「昨夜は忙しいことだつたらうな」「そりや逮夜の法事ですもの、坊さんだけでも五人も呼びましたよ」「家中の者は誰も外へ出なかつた事だらうな」「ところが皆んな一度づつは出ましたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "心中崩れ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
