        "examples": {
          "standard": [
            {
              "text": "熟したトマトは、鮮やかな紅色を帯びている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の描いた絵には、情熱を表すかのような鮮紅色のバラがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この花、すごく鮮紅色で綺麗！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それを選鉱所で、銅をふくんでいる石と、ふくんでいない石とによりわけ、ふくんでいるものを熔鉱炉に入れてとかすという順序なのだ。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は坑内の見学をおわると、選鉱所を見て、それから熔鉱炉の工場へと案内してもらった。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "選鉱所でよりわけられた鉱石は、熔鉱炉でとかされ、むだなものをとりのぞく。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
