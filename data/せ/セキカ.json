[
  {
    "uuid": "b138bbb7-3a73-58fd-ad35-6d0f2f891902",
    "entry": "石化",
    "reading": {
      "primary": "せきか",
      "alternatives": [
        "せっか"
      ],
      "is_heteronym": false
    },
    "grammar": {
