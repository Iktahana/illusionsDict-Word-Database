    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reflection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吾輩は茲で、アラヽギ諸同人に忠告を試みたい、我諸同人の歌は、概して形式を重じ過ぎた粉飾の過ぎた弊が多いやうであるから、石川君の歌などの、とんと形式に拘泥しない、粉飾の少しもないやうな歌風を見て、自己省察の料に供すべきである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし適当な科学的常識は、事に臨んで吾々に「科学的な省察の機会と余裕」を与える。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう省察の行われるところにはいわゆる流言蜚語のごときものは著しくその熱度と伝播能力を弱められなければならない。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ省察の結果が誤っていて、そのために流言が実現されるような事があっても、少なくも文化的市民としての甚だしい恥辱を曝す事なくて済みはしないかと思われるのである。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくもこの二つのものの比較はわれわれの科学なるものの本質に関する省察の一つの方面を示唆する。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常茶飯の世界のかなたに、常識では測り知り難い世界がありはしないかと思う事だけでも、その心は知らず知らず自然の表面の諸相の奥に隠れたある物への省察へ導かれるのである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の所説は、一見はなはだしく詭弁をろうしたもののように見えるかもしれないが、もし、しばらく従来の先入観をおいて虚心に省察をめぐらすだけの閑暇を享有する読者であらば、この中におのずから多少の真の半面を含むことを承認されるであろうと信ずる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは科学にたずさわるほどの人々の慎重な省察を要することと思われる。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は自分の仕事にどれ程の自覺を持つてゐるのか、またどれ程自己省察の眞劍さを缺いてゐるのか、それは判らない。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼はかう思つて心に深い省察を加へて見た。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅中に私の不注意を実証する出来事が三つあつた、敬治居で眼鏡をこわしたことが一つ、途上辨当行李をなくしたことが一つ、そしてあとの一つは帰庵して、すこし酔うて茶碗を割つたことである、こゝに記して自己省察の鍵とする。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾病の説（其二）自ら招くと、自ら招かざるとに約して論ずれば、自ら招いて病を得た者は、自ら省察を加へて同一事を繰返さぬやうにせねばならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に張る氣の事を説くも、再三に亙つて居るから、人少しく自ら省察すれば、おのづから其の消息を悟り得よう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又身の欲する所と心の欲する所と牴牾するが如き場合、即ち慾と道義心との相爭ふ場合などを省察したるより發したのでも有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の欲するところと心の欲する所と牴牾する場合も、詳しく省察すれば碁の爭ひの如きもので、交替爭鬪である、同時爭鬪では無い、一室一主である、一室二主では無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶詳しく省察すれば輾轉して休まざる一の骰子の或は一を示し或は六を示して居るやうなもので、本是一個物である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――東京監獄の二週日は浅はかな小生の為には何よりの貴い省察と静思の時間を与へて貰ひました。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の永い間の焦燥、憂慮、省察、求信、之等は決して徒事では無かつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながらあの市ヶ谷の監獄生活は誠に貴い省察と静思との時間を汝に与へたと、鏡の中から悲しげな両の瞳が熟視める……　あれから苛酷な世の嘲笑と圧迫は日夜続いた、それでも汝は能く耐えた、と又剃刀が冷たい辷りを額に続ける……　鶏頭、鶏頭、記憶は悲哀を再燃させる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お玉は最初主人大事に奉公をする女であったのが、急劇な身の上の変化のために、煩悶して見たり省察して見たりした挙句、横着と云っても好いような自覚に到達して、世間の女が多くの男に触れた後に纔かに贏ち得る冷静な心と同じような心になった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（考へて見れば、元々世界に對して甘い考へ方をしてゐた人間でなければ、厭世觀を抱くわけもないし、自惚やか、自己を甘やかしてゐる人間でなければ、さう何時も「自己への省察」「自己苛責」を繰返す譯がない。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "省察を以てしては決して能はざらん。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で招くのと自分で招かないのとに限って論じれば、自分で招いて病を得た者は自分で省察を加えて、同じ事を繰返さないようにしなければならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに張る気の事を説くのも再三に亘っているから、各自少しく自分で省察すれば自然とその消息を悟り得よう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また身の欲する所と心の欲する所が相反するような場合、即ち欲と道義心とが相争う場合などを省察した結果から発したのでもあろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の欲するところと心の欲する所とが相反する場合も、詳しく省察すれば碁の争いのようなもので交替闘争である、同時闘争では無い。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚詳しく省察すれば転々して休まない一ツのサイコロが或いは一を示し或いは六を示しているようなもので、本はこれ一物体である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾子の心では、既に学び既に伝えられていて、そして習わないようなことが有れば、その身に学んで人に受けたものを無駄にするだけでなく、その習わないという事が、直ちにこれ一大悪事・一大不徳事・自らを欺くこと・独りを慎まないこと・浅ましくも愚かな事であると、日々に深く省察を加えていたのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸り気を斥け驕り昂る心を捨て、静寂の中で省察を誠実に行い、我々と聖人との関係を思えば、人誰か古聖が大慈の父母の様で、我々が不幸の児の様に思わないであろうか、聖賢の恩恵は我々をスッポリと包み我々を援助し、我々の愚かな者は聖賢に背き聖賢を疎外する。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "智的生活は実にこの種の固定し終った生活の認識と省察によって成り立つのである。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
