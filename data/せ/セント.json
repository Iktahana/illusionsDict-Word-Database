  {
    "uuid": "cda34041-d9d9-56f6-99b0-af1043884511",
    "entry": "せんと",
    "reading": {
      "primary": "せんと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
