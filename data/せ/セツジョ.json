    "definitions": [
      {
        "index": 1,
        "gloss": "cut off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我々の獲た報道によれば不必要な冗語を一切除いた事件の眞相は次の如くである。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふモオリアックは、それ等の悲慘な作中人物どもの上に何處からともなく徐々に一條の神々しい、「冬の光線」に似た痛々しい光線を浴びせかけて行くのでありますが、その作品からカトリック的な要素を一切除いてしまつたら、そこには室生さんと大へん似通つてゐる一人の西洋の作家がゐるやうな氣がするのです。",
              "citation": {
                "source": "「神々のへど」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺臓とか腎臓とか二つある内臓の一つは切除された。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学説によると、もし人間が生きるのに直接必要でない肉体部分――つまり心臓や肺臓は是非必要だが、手足や二つ以上ある内臓は、これを切除するか又は一つに減らしてしまう。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳房を切除した左胸部には殆ど傷痕は残っていないが、放射線のため薄黒く焼かれている。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡さんは胸部疾患のため、先年、肋骨を八本も切除したという経験者である。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、左の乳房は切除されて直るので、妻の左胸部は扁平である。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり手術が長びくのは、切除する可能性の多いことを示すものではないか。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳房を切除した左胸部に、放射線の深部治療を受けるためである。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "石山教授自身も僅かに第一回目には右肺切除の手術を行ったという口供書しか残していない。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、心臓、脳、全肺切除手術などは、今日でこそ各方面の外科医が行っているが、十数年前の当時では、検事の論告通り「世紀の大手術」であった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "成形手術より更に望ましい肺の切除方法を、より効果的に進めるための人体手術は、外科医ならどうしてもやって見たい問題だったと思う。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生きた人間を解剖すること自体、絶対に許されざる非人道的行為であるにも拘らず、その犠牲者の屍体の一部を切除した上、その肉塊を平気で食べるなど、まさに鬼畜の所業である。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も近世の醫學では手術で白内障の水晶體を切除き、強い凸レンズの眼鏡をかけて、六七十パーセントまでは視力を回復するといふのは、誰でも知つて居ることです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の守袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康でよく肥えていた者たちの死体は、四本足のも二本足のも、注意深い食肉解体処理作業員がするように殆どの固形臓器を切除され持ち去られていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、確かにその時点で我々には判っていたのだ、先に発見した気違いじみた六体の埋葬物、即ち六つの不完全体の内の一つ――著しく不快な臭気を微かに漂わせていた一体――はレイクが精査しようとして切除した標本をかき集めたものに違いないと。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の歯と口もまた注意深く用心しなければならないし扁桃腺炎がしばしば起きるようだったら扁桃腺を切除する。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻は、前述の改良隆鼻術と、軟骨切除によって随意に変形し、口も目と同様広狭自在である。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻は前述の改良隆鼻術と、軟骨切除によって随意に変形し、口も目と同様広狭自在である。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑骨折にさいして彼は骨の突き出た端を切除した。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫瘍の切除は非常な古代におけるインド医療で行われていたが、ヒポクラテスの外科では普通のことではなかった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "結石切除術　コス島およびクニドス島のアスクレピアドは病気の現象について構造的な関係を示すこと無く論争をしていた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "）専門家によって膀胱結石切除術が行われた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキサンドロスの息子シリア王（紀元前150年）アンティオコス（Antiochus）の後見人ディオドトスの扇動により膀胱結石切除術師が膀胱結石と言って10才のアンティオコスを殺す忌まわしい殺人事件が起きた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "このクリュシッポスは最近のフリードリッヒ・エスマルヒ（Esmarch：ドイツの外科軍医、1823-1908）と同じように四肢切除の前に血液を取り除き、また水腫の治療に蒸気浴を使ったと云われる。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はカリエスの治療に胸骨の一部を切除し、また側頭動脈の結紮をしたと言われている。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術の多くは、男性割礼、女性割礼、去勢、マイカ手術（尿道割礼）、帝王切開、卵巣切除、のように性と関連している。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は少年時代から結核で、小学校二年生のとき、右｜股間淋巴腺の切除手術を受けたことがある。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに胃の手術の歴史ではビルロートの名前が残っている（＊ビルロート胃切除術）。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "1809年にケンタッキーの高地に住んでいたマグダウェルは世界で最初に卵巣腫瘍を切除する勇気を持った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
