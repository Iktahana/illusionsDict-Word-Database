[
  {
    "uuid": "bdd31382-c466-5c0f-8b3e-1457207e9731",
    "entry": "世間並み",
    "reading": {
      "primary": "せけんなみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
