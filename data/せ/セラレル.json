    "definitions": [
      {
        "index": 1,
        "gloss": "to do",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術家にとつて世界は、即ち彼の世界意識は、善いものでも悪いものでも、其の他如何なるモディフィケーションを冠せられるべきものでもない。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホオ……と僕はお道化てゐるんだがまだ見ぬ先生に意地の悪い気持を抱いてゐるんだが、煙草をまづく感じ出すと、飛行機のみならず、洋服掛にまで、異常な好奇心を覚ゆるのであつた――とにかく御幸福なお方であらせられるよ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」審判の冷酷の声が、ふたたび発せられる。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼女が、今は昔恋の罪のために父君から塔の中に幽閉せられるやうになつた姫に関する悲しい歌をうたふのを聞いた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋殿が例えば「狸」と仰せられると加八は一同の顔色を注意深く観察して誰が「狸」であるかを観破するために云わば読心術の練習のようなことをする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷の音が次第に急になって最後にドシーンと落雷したときに運｜拙くその廻送中の品を手に持っていた人が「罰」を受けて何かさせられるのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくがっかりして、しかし結局あきらめて辛抱して待って、さてもういいかと思って催促すると、今度は何とかがどうとかして何とかで工合が悪いからもう二、三日待てという、その何とかが実に尤千万な何とかで疑う余地などは鷹の睫毛ほどもないのだから全く納得させられる外はなかった。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃活動写真で色々な空中戦の壮烈な光景を見せられる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局の雇や、税務署の受附などに、時おり権突を食わせられる度に、ますます厭になった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、それは困る、と生物學者のはうから抗議が出て、とかく文學者といふものには科學精神が缺如してゐる、などと輕蔑せられるのも不本意である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひはまた、氣にいつたからとて、あまりしつこくお伺ひしては、つひには極度に嫌惡せられ、殺害せられるほどのひどいめに遭ふから節度を守れ、といふ禮儀作法の教科書でもあらうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その草庵の垣根越しに、そつと覗いてみた者は、なあんだ、とがつかりさせられる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙臺の人たちの愛國の至情に接して、外國人たる彼さへ幾度となく瞠目し感奮させられる事があつたのでした。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど改造社から、井伏さんの作品集が出版せられるさうだが、それに就いて何か書け、と改造社のＭ君に言はれて、私は、たいへん困つたのである。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような川渉りを、幾回もさせられるのである。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "両山脈の相対する間隔は、直径約一里もあろうか、間の岳の頂までは、この河原から一里半で達せられる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他｜亜細亜大陸のヒマラヤ大山脈中にも似寄った意義の山名は少なからず発見せられる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに御自分の両眼の間に新聞紙を拡げて前に突き出して左右の眼で外界を御覧になると御疑問が解決せられるのです。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして飲みたくない酒を嘗めさせられ、食いたくない雑煮や数の子を無理強いに食わせられる事に対する恐怖の念をだんだんに蓄積して来たものであるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年急に襲うて來た「改造」の嵐の爲に、我邦の人の心に自然なあらゆるものが根こぎにされて、其の代りにペンキ塗りの思想や蝋細工のイズムが、新開地の雜貨店や小料理屋のやうに雜然と無恰好に打建てられて居る最中に、それ程とも思はれぬ天然の風景が方々で保存せられる事になるのは、せめてもの事である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある金属の酸化物例えばマグネシアのごときものは普通の温度では電気を通さぬが、熱せられると電流を通じ、そのために灼熱して強い白光を出す。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あついたちりめんといふのは私の女学校時代の学期の合間に着せられる着物についた帯地のちりめんでした。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には自分に潜んでいて、却って山に現れ出て、逆に自分に気付かせられるようなこともあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ厠に上られてはこされているからだろう」女神の化粧は自分で納得ゆくまで何遍でも仕代えさせられるので永い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片親の父に相談してみても物堅い老舗の老主人は、そんな赤の他人の白痴などに関まっても仕方がないと言って諦めさせられるだけだった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、沙弥とは言え、寺門に属する自分を誘惑した罪科として、あのかよわい姫まで罰せられるとも知れない。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るだけ我儘をさして呉れる男か、それとも絶対的に服従させられる強い男とならばね。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「一生に一度は真剣な気持ちにさせられるものにぶつかってみたいと思うことは、そりゃあたし達にだって、ちゃんとあるわ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美的な放恣、つつましやかな自由、それはどうあるべきかと追求されてもこまるけれど、とにかく以上の字義どおり何れの女性も心術として欲しい、結果はおのずから達成せられるでありましょう。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ふとしたことから、私は現実のおまえに気付かせられることがある。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
