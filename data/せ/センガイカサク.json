        "examples": {
          "standard": [
            {
              "text": "「残念ながら入賞はしませんでしたが、選外佳作として名前が掲載されました」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "選外佳作という結果を受け止め、次こそは最優秀賞を取ると心に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンクールのパンフレットの最後に、選外佳作の作品名が小さく並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのときは『或る怪電波の秘密』といったような題であったが、これが見事に一等二等を踏みはずし、選外佳作となった。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて「万朝報」に週一回発表される短編小説には、熱を上げて何回も出したが、たった一度、選外佳作に入ったにすぎない。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
