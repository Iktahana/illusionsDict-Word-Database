    "definitions": [
      {
        "index": 1,
        "gloss": "being already (well) aware",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
