        "examples": {
          "standard": [
            {
              "text": "体育館の入り口で、クラスメイトたちが背の順に並んで整列した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私はクラスで一番前だったので、背の順で並ぶのがいつも少し恥ずかしかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はい、背の順に並んで！」という先生の合図で、運動場がにぎやかになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幕が上ると同時に左手の雛壇から鼓の音がして、両側の花路から背の順に並んだ踊子の群が駆けるやうに足波揃へて進んで来た。",
              "citation": {
                "source": "父",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の順に長い行列を作っているので、小さいのは前の方で聖像に近く、大きいのはうしろに立っている。",
              "citation": {
                "source": "身体検査",
                "author": "ソログーブ・フョードル",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の順に坐り並びぬ糸取女五月十七日　大崎会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　背の順にならんだので一番前の席にいたちびの岡田磯吉は、まっさきにじぶんが呼ばれたのも気おくれのしたもとであったが、生まれてはじめてクンといわれたことでもびっくりして、返事がのどにつかえてしまった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
