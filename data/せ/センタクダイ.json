        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ナプキンを決めておけば食事｜毎にその洗濯代として二十五サンチームぐらいの小銭を支払わなくても済むからである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯代は滞なく潤沢に払ひくれたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯代その他　国立劇場コメディイ・フランセエズでは、専属俳優の下着類は一切、劇場の方で洗濯してやることになつてゐる。",
              "citation": {
                "source": "ふらんす役者気質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の劇場の中で、洗濯代劇場持ちといふのは数へるほどしかない。",
              "citation": {
                "source": "ふらんす役者気質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラマールの下宿代は、敷布類の洗濯代はむこうもち、一週に一度の入浴つきで一ヵ月一九五〇フランだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他洗濯代や下女の心づけを合せても、月五百法未満で済むような下宿は、学生町にもあまり多くはない。",
              "citation": {
                "source": "二人のセルヴィヤ人",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、洗濯代をはらわずにいるのだ。",
              "citation": {
                "source": "小指一本の大試合",
                "author": "山中峯太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポールさん、洗濯代をはらってください」と、ジョージがきていうと、「なに？",
              "citation": {
                "source": "小指一本の大試合",
                "author": "山中峯太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにって、前の月の洗濯代が、まだいただかずにあるんです。",
              "citation": {
                "source": "小指一本の大試合",
                "author": "山中峯太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯代ばかりでなく、倶楽部の代金まで、まるではらわなくなった。",
              "citation": {
                "source": "小指一本の大試合",
                "author": "山中峯太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――それから瓦斯代、電燈代、水道代、薪炭代、西洋洗濯代等の諸雑費を差し引き、残りの二百円内外から二百三四十円と云うものを、何に使ってしまうかと云うと、その大部分は喰い物でした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
