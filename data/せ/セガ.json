        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詩集『悲歌』は可なりな人気を博したとはいへ、猶人々は彼女をかの浪漫派時代の女詩人達、タストやセガラやエルザ・メルクールの輩と並べて考へてゐたものだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーベンスやゲーンスボローやないしはアルマタデマに無くしてセザンヌ、ゴーホあるいはセガンチニなどに存するところのものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本｜繁二郎氏のセガンチニを草体で行ったような牛の絵でも今見てもちっとも見劣りがしない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド、イタチニハ　タツタ　ヒトツ、ヨク　ナイ　クセガ　アリマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今おもふとたしか、あれは、イタリアのセガンチニイだつたらしい。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "セガンチニイは今でこそ日本のどんな畫學生でも知つてゐるが、その頃はたづねる友人もなかつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ガタ・エネ・セガレツ？",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "セガンティニーの繪畫に山岳美の不思議な光景が、人を魅惑するやうに浮ばせてあるのは何人でもが認むるところであるが、これは歐羅巴アルプスの必然の表現であつて、一種の地方色である。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "セガンティニイほどに狹く、不可思議ではない。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲畑、親子、　　　　　　　　仏国の兵士の話、瀧口の話、（日露）従軍十二月　二日　最後の晩十二月　三日　立つ朝、寒いもやの濃い日、朝ミス　ハセガワに会う。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、昔みたセガンテイニの絵がふと思ひ出された。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けた処には、セガンチニの死ぬるところが書いてある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "セガンチニが一度も窓を開けず、戸の外へ出なかったら、どうだろう。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "センジテノムト、ノボセガ、ナオッテ、カオリガヨロシイ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノアイダ、オクツテ、クダサツタ、ハナノクスリ、オツイデノトキ、スコシオクツテクダサイ、センジテノムト、ノボセガ、ナオツテ、カホリガ、ヨロシイ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中巻新来朝五国聯合　バード・ストーン一座大曲馬プログラム　（午後一時開演）（同　五時終了）★１……君が代行進曲　専属音楽団★２……文字を解し、計算し、地図を読む馬　米国理学博士　アスタ・セガンチニ夫人★３……二頭立戦車曲芸　◇第一戦車　〔伊太利〕　ルビヤ・ベルチニ嬢。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ホオオオ……それは……ミセス・シムラは何という名前になっておりますか」「……アスタ・セガンチニ……一番初めのプログラムに出ておいでになります。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワハハハハハハハハハハ……お伽話だ……地底の蜃気楼……アッハッハッフッフッフッ……アスタ・セガンチニ……あの近眼婆さん……オースタリ人の志村のぶ子……アハハハハ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "欺されている事……」「……………」「ジョージはマダム・セガンチニと夫婦になるために逃げたのです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワハハハハハハハハハハ……｜お伽話だ……｜地底の蜃気楼……アッハッハッフッフッフッ……アスタ・セガンチニ……あの近眼婆さん……オースタリ人の志村のぶ子……アハハハハ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその一瞬の光景は僕には忘れ難い印象を與へた一枚のセガンティニばりの繪にちがひなかつた。",
              "citation": {
                "source": "牧歌",
                "author": "恩地三保子孃に",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、やりやがったな」　さっそく紺屋のサブチャンの手首をつかんで放さず、片手にショウコ物件を握って、質屋のセガレのシンちゃん、喫茶のノブちゃん、時計ラジオ屋のトンちゃん、酒問屋のハンちゃん、四名の者をよび集めた。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は暫く下界に住んで来て、さてこの山嶽をば通りしなに既にセガンチニの画境の種々相を感得することが出来た。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "セガンチニもいろいろなものを画いた。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "セガンチニは、すべてそういうものをば種々の原色の顔料で、一筆一筆に盛りあげている。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月八日（水）　詩をかくハセガワ尚来る。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
