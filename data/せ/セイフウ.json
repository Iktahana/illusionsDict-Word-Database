[
  {
    "uuid": "141448f7-55e4-572b-8d89-7e37e062e2a4",
    "entry": "清風",
    "reading": {
      "primary": "せいふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "breath of fresh air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今や落日、大洋、清風、蒼天、人心を一貫して流動する所のものを感得したり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この時清風一しきり園林の梢に渡る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は山に倚り、水に臨み、清風を担い、明月を戴き、了然たる一身、蕭然たる四境、自然の清福を占領して、いと心地よげに見えたりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予かつて数これを試みしに、山本氏の「清風」は茶の至美なる者にあらずと雖、神味｜頓に加はりて、霊気心胸に沁むものあるを覚ゆ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋上の眺めは左右に岸壁を見、白沫立つてたぎり流るゝ川に臨むのであるから、緑蔭水聲、おのづから兩袖に清風を湧かす概があつて、名も餘り高く無いところだが、小じんまりして溪谷美のあることを感じさせられる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても清風吹きて不淨を掃へば、山野一點の妖氛をも止めず。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち茲に暫らく閑天地を求めて、心頭に雲を放ち、胸底に清風を蔵し、高眠安臥、興を暮天の鐘にさぐり、思を緑蔭の流光に托し、風鈴に和して吟じ、雨声を友として語り、この夏中百日を暢心静居の界に遊ばんとす。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに永劫に絶えざるの清風吹く、これ汝の尤も親しき友にあらずや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "埋火をかき起して炉辺再びにぎはしく、少婦は我と車夫との為に新飯を炊ぎ、老婆は寝衣のまゝに我が傍にありて、一枚の渋団扇に清風をあほりつゝ、我が七年の浮沈を問へり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに眠に就くべき心地ならねば、窓に坐して清風明月に對せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は、ぬば玉の夜、清風そよぐ時にあらはれてこそ人のあはれみも深かるべきに、夕日沈まなくにまだき主じ顏にも出でたらむには、うせなんものは、其光のみにはあらざらむ。",
              "citation": {
                "source": "日月喩",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは漫々たる蒼波、見るからに心地よく、清風陣々として、凉氣船に溢る。",
              "citation": {
                "source": "月の東京灣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男獨り甲板の上に、この清風明月を占む。",
              "citation": {
                "source": "月の東京灣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "明月の下、蘆花雪を吹くのほとり、願はくは、黄塵にけがれたる衣を江上の清風に振ひ、手づから巨蟹を捕へて、扁舟の巾に醉臥せむ哉。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島が爆破したのではありますまいか」「うむ、そうかもしれない」　駆逐艦清風の艦橋で、双眼鏡を手にとって語る二人の将校があった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆逐艦清風は、いま浮かぶ飛行島へ、海上あと十キロのところまで近づいていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは長谷部少佐が、昇進とともに艦長となった駆逐艦清風であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では直ちに出かけることにしましょう」　駆逐艦清風は、速力をゆるめて、静止へ――。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪問客５・７東京日日（夕）　西園寺公を田中村の清風荘に訪ねて往つた政治家達が、数多い訪問客のなかで、老公とうち解けて会つてくれるのはまづ自分だけだといつたやうな事をてんでに吹聴するのはをかしなものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、さつぱりする、清風こゝろよし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲學書一卷を讀破して未了の知識に逢着する時、快は則ち快ならむも、終日勞し來りて新浴｜方に了り、徐ろに一盞の美酒を捧げて清風江月に對する時と孰れぞ。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて、随筆のように「清風徐ろに吹来つて」を書いた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、「清風徐ろに吹来つて」　　　　　　　　　（明治初期二）　三宅花圃が昭和十四年の春ごろ婦人公論にのせた「思い出の人々」は、いろいろの意味から面白い自伝であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで、ちょっとした随筆を二三篇かき、その一つであった「清風おもむろに吹き来つて」という随筆がきっかけとなって、明治から現代までの文学史と婦人作家の研究にとりかかった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清風明月何無主　　清風明月何ぞ主なからむ、嘗賭一身贏得來　　嘗て一身を賭して贏ち得来たる。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（東坡前赤壁賦、「天地之間、物各有主、惟江上之清風與山間之明月、取之無禁、用之不竭。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」）六月十四日菩薩蠻清風明月吟詩臥　　清風明月、詩を吟じて臥す。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
