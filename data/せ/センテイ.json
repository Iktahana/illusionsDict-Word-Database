    "definitions": [
      {
        "index": 1,
        "gloss": "the late emperor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "敬曰く、先帝｜若し敬が言に依りたまわば、殿下｜豈此に至るを得たまわんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍は後に幼帝を廃して、さらに景帝を擁立し、それを先帝の陵に奉告しようとして、門を出て車に乗ると、俄かに大風が吹いて来て、その車をゆり動かしたので、車はあやうく傾きかかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常にお美しい方でございます」　もしそんなことがあったらと大御心が動いて、先帝の后の宮へ姫宮の御入内のことを懇切にお申し入れになった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしておいでになって、母宮のことばかりを思っておいでになるよりは、宮中の御生活にお帰りになったら若いお心の慰みにもなろうと、お付きの女房やお世話係の者が言い、兄君の兵部卿親王もその説に御賛成になって、それで先帝の第四の内親王は当帝の女御におなりになった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十三日の雷雨の烈しかった夜、帝の御夢に先帝が清涼殿の階段の所へお立ちになって、非常に御機嫌の悪い顔つきでおにらみになったので、帝がかしこまっておいでになると、先帝からはいろいろの仰せがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "真宗｜嗣ぎ立て即位式に先導せしむると鳴吠徘徊して意忍びざるがごとし、先帝の葬式に従えと諭せば悦んで尾を揺るがし故のごとく飲食す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "後先帝を慕うの余り死んだので、詔して敝蓋を以てその陵側に葬ったとあり。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨月　では、先帝のみささぎに参拝して、それからおたずね申しまする。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、宮は先帝に可愛がられたので、一時は今の御門の母方の人達が、何のぐらゐ眉を蹙めたかしれないのだつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで「瑞典のパンテオン」と呼ばれる、リダルホルムス教会――｜騎士の島という語意だが――この歴代の王様を祀ってある壮麗な拝殿の内部、古い木の尖塔の反対側の角のところに、日本先帝陛下を記念し奉る御紋章が安置してある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "先帝陛下が御崩御になって中野の先の浅川に御陵が出来た頃の話なんですよ。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "西漢の昌邑王は、その先帝の孝昭帝の喪を勤めず、孝道に背くといふ點で、大臣の霍光に廢された（『漢書』卷六十八、霍光傳參看）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜其一部に※クトリヤ女皇と先帝との戴冠式に用ひられた宝冠や、宝石と貴金属で華麗を尽した沢山の花環やが陳列されてゐる。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は先帝の喪に服して涙｜未だ乾かざれども、厚氷その片端の解くる如く心は既に新しき御代の春に和らぐ初日うららかなる下に、草莽の貧女われすらも襟正し、胸躍らせて読むは、今上陛下朝見第一日の御勅語。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは二十一年頃、先帝の思召しで、三条公と岩倉公との事蹟を調べて置くようにとの仰せがあったので、それと共に維新の際いわゆる勤王党であった旧藩主が、右の両家と共に事蹟を調べる事になって、その結果二百六十の旧藩主華族諸家もこの調べをする事に御沙汰があった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく耐うる人は強き人　ドイツの先帝フリードリヒ陛下が不治の病気に罹りて数日間病床に呻吟し、しかもその病気は苦痛の最もはげしいものであったので、かたわらに侍するもののみならず、国民全体がふかき同情をよせ、一日も早くご平癒あらんことを祈った。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は秋好中宮と言って、六条御息所と、その夫、早く亡った先帝の皇太子との間の子である。",
              "citation": {
                "source": "反省の文学源氏物語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即位式が、先帝崩御と共に行はれる様になり、大・新嘗祭りは、仲冬の刈り上げ直後の行事と変り、日の御子甦生の産湯なる禊ぎは道教化して、意義を転じ、元旦の拝賀は詔旨よりも、賀を受ける方を主とせられる様になつて行つた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先帝の存在は大将の生活の中軸であり、核心であった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先帝を失うて後の大将の生活は自滅するよりほかなかったであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "平城天皇の御代になつてから、先帝の遺詔として、本官に復されるまで、二十年待たなければならなかつた。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に、宮廷領の分立並びに、平安朝における先帝観・後院制度の生れて来る理由があるのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は白壁王を立て、左大臣永手、兄の参議良継と謀議して、宣命使をかたらひ、大市を立てる宣命に代へて、白壁王を立てる旨を宣らせ、先帝の御遺詔であると勝手な文句をつけたさせた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "下に「先帝御手跡」とある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝明天皇の御筆かと思うたのは一瞬時、陛下は已に先帝とならせられたのであった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風鈴の短冊が先日の風に飛ばされたので、先帝の「星のとぶ影のみ見えて夏の夜も更け行く空はさびしかりけり」の歌を書いて下げた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船橋の方には、先帝の御為に上げるのか、哀々とした念仏の声が長く曳いて聞こえる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先帝が崩御なされて、次帝が天子としての資格を得る為には、此物忌みをせねばならぬ。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人は、此お寝床の事を、先帝の亡き御身体の形だといふが、其はよくない。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が高卒以上でなければ、嫁に行かん、恋愛もせんていふ規約、わしらで作つたわ。",
              "citation": {
                "source": "すべてを得るは難し",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
