[
  {
    "uuid": "9fb75129-ac5f-5363-9dba-6396bf70ac4a",
    "entry": "先帝",
    "reading": {
      "primary": "せんてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
