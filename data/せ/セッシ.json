[
  {
    "uuid": "b103c0d5-3434-5cdc-be9c-453ecd6241c7",
    "entry": "切歯",
    "reading": {
      "primary": "せっし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
