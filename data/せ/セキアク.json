    "definitions": [
      {
        "index": 1,
        "gloss": "accumulation of bad deeds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "急に左半身不髄の症状に襲はれた、積悪の報いいたしかたなし、飲みすぎ食ひすぎはつゝしむべし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も積悪の報い、甘受いたしませう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会に多数を制していた政府反対党の人々も、大隈内閣の与党と称せられる人々も、もし一片の良心を存しているなら、今更のように時代の激変に驚いて、国民の前に自分たちの過去の積悪を愧じ入ると共に摯実な内省の人に帰らざるを得ないであろう。",
              "citation": {
                "source": "鏡心灯語　抄",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし積悪の報と思えば、これも致し方はございますまい。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は思へり、「平家は、栄華身に余り、積悪年久しく、運命末に望めり」と。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まあ、それが、積悪の醤や油の天命じゃろうよ」",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後暫らく会はないでゐたが、矢張り何かと伝へて呉れる人があつて、彼は益々｜強慾になり貸金の回収手段の非道さは随分泣かされてゐる人間も多く、家作も次々に建てたが、最近手を出した製氷所が失敗して、癲癇になつたのも積悪の報だらう、と云ふ噂を聞いた。",
              "citation": {
                "source": "鳥羽家の子供",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども敗戦のあげくが、軍の積悪があばかれるのは当然として、戦争にからまる何事をも悪い方へ悪い方へと解釈するのは決して健全なことではない。",
              "citation": {
                "source": "特攻隊に捧ぐ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はこの戦争の中から積悪の泥沼をあばき天日にさらし干し乾して正体を見破り自省と又明日の建設の足場とすることが必要であるが、同時に、戦争の中から真実の花をさがして、ひそかに我が部屋をかざり、明日の日により美しい花をもとめ花咲かせる努力と希望を失ってはならないだろう。",
              "citation": {
                "source": "特攻隊に捧ぐ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "積善の家が忽ち断絶して、積悪の家に却つて余慶のある事もある。",
              "citation": {
                "source": "人類の将来",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「積悪の酬い、因果応報」こう云ったのは老師である。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の佐吉は積悪に責めさいなまれるように、縁側へ崩折れてガタガタ顫え、ガラッ八も、与次郎も、万七でさえも、顔色を失って、成行きを見詰めるばかりです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "金権政治の金蔓を絶つためにはこれもやむをえないのだと北槻中尉らは言うが、俺は奴らの積悪に対してこれは当然のことだと考える。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "その積悪がバレた末、ついに今日のお仕置きの破目となったにちがいない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来、清盛の肖像には摂津築島寺の清盛｜甲冑姿の像、山城六波羅蜜寺の法体像、京都曼殊院の束帯像など幾種となくありますが、いずれも端正な美丈夫で、積悪の酬いのため、赤鬼青鬼の迎えをうけ、炎の車で地獄へ持って行かれたとする入道相国の既成概念とは、およそ別人であることが分かります。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
