  {
    "uuid": "e35de46d-66f2-545e-9336-bf26546df589",
    "entry": "施餓鬼",
    "reading": {
      "primary": "せがき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
