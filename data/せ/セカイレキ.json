        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世界暦二千二百年　人類は地球の支配権を遂に植物に譲らなければならなくなる。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦二千百五年　第四氷河期は終熄を告げた。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦二千五十五年　第四氷河期が襲来！",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦二千一年十三月十三日　宇宙戦争が勃発する。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦二千年一月十九日　大西洋横断の旅客機と貨物機が二ヶ月前より頻々として行方不明となっていたが、その事件を調査の結果本日一大発見成る。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百九十九年四月一日　第三世界戦争が勃発する。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百九十年　人間の寿命は無限となし得ることに成功する。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百八十年　火星探検は不成功に終る。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百六十年八月八日　月世界探検に成功する。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百五十五年　地球一周が十二時間で出来るようになる。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百四十九年十月　日本の食糧欠乏問題が解決する。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界暦千九百四十七年　飢餓のため日本人死するもの続出。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
