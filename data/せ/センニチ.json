    "definitions": [
      {
        "index": 1,
        "gloss": "one thousand days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして運命の一万数千日の終りの日が忍びやかに近づくのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その法令が、無事な一万何千日間の生活に甚だ不便なものである場合は猶更そうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田巻草千日草｜天竺牡丹と各々手にとり別けて出かける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが飯綱の法のはじまりで、それからその子｜盛縄も同じく法を得て奇験を現わし、飯綱の千日家というものは、この父子より成立ち、飯綱権現の別当ともいうべきものになったのであり、徳川初期には百石の御朱印を受けていたものである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの虫にとってはわれわれの一日は彼らの千日に当たるのかもしれない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千日の夜あけ方、和蘭陀の黒船に、旭を載せた鸚鵡の緋の色。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千日が間、能書の僧数百人を招請し、供養し、これを書写せしめしとなり。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）※一日逢わねば、千日の思いにわたしゃ煩うて、針や薬のしるしさえ、泣の涙に紙濡らし、枕を結ぶ夢さめて、いとど思いのますかがみ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "他アやんと別れ、やがて千日前の大阪劇場の前まで来た。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "この力が千日前を、心斎橋を、道頓堀を、新世界を復興させたのだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前の歌舞伎座の横丁――昔中村鴈治郎が芝居への通い路にしていたとかで鴈治郎横丁と呼ばれている路地も、以前より家数が多くなったくらいバラックが建って、食傷路地らしく軒並みに飲食店だ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前も心斎橋も、道頓堀も、新世界も、あ、それから、法善寺横丁も、鴈治郎横丁も、みんな復興しましたよ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前や心斎橋や道頓堀や新世界や法善寺横丁や鴈治郎横丁が復興しても、いや、復興すればするほど、大阪のあわれな痩せ方が目立って仕様がないのである。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下味原町から電車に乗り、千日前で降りると、赤玉のムーラン・ルージュが見えた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南海通の波屋書房の二、三軒先き、千日前通へ出る手前の、もと出雲屋のあったところに、ハナヤという喫茶店が出来ていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハナヤはもと千日前の弥生座の筋向いにあった店だが、焼けてしまったので、この場所へ新らしくバラックを建てたらしかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのはつまり、亀吉が豹吉にいいつけられて小沢十吉を当てなく探しに、千日前のハナヤを出た頃――。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、中之島公園の暗がりの中を一息に、図書館の前まで駈けつけた時、自分の到着を待っていたのは千日前の喫茶店の前で、自分を掏ろうとしたあの間抜けの掏摸一人ではなく、十数名に及ぶ隼団の団員だと判ると、豹吉は思わずにやりとしたくらい、ゾクゾグとうれしかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のよく行く千日前のハナヤという喫茶店へ午前十時に行って三十分間だけ待ってろ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに、千日前｜界隈の見晴らしの利く建物の上から、はるか東の方を、北より順に高津の高台、生玉の高台、夕陽丘の高台と見て行けば、何百年の昔からの静けさをしんと底にたたへた鬱蒼たる緑の色が、煙と埃に濁つた大気の中になほ失はれずにそこにあることがうなづかれよう。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "上町に育つた私たちは船場、島ノ内、千日前界隈へ行くことを「下へ行く」といつてゐたけれども、しかし俗にいふ下町に対する意味での上町ではなかつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一の成長と共にすっかり老いこみ耄碌していた金助が、お君に五十銭貰い、孫の手をひっぱって千日前の楽天地へ都築文男一派の新派連鎖劇を見に行ったその帰り、日本橋一丁目の交叉点で恵美須町行の電車に敷かれたのである。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国魂神社の裏を抜け、坂道を降りて千日前に出た。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前から法善寺境内にはいると、そこはまるで地面がずり落ちた様に薄暗く境内にある祠の献納提灯や灯明の明りが寝とぼけた様に揺れていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、赤玉がカンバンになると、女と一緒に千日前の寿司捨で寿司をたべ、そして、五十銭で行けと交渉した車で萩之茶屋の女のアパートへ行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪に帰ると、彼は道頓堀や千日前のカフェーを飲み歩いた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前楽天地（現在歌舞伎座）横町のカフェー喜楽の年増女給とねんごろになり、宝塚旧温泉で関係を結んだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "職を探すべく千日前の安宿に泊っている内に、所持金を費い果して、その日は朝から何もたべていない。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日程経った頃だったろうか、千日前のお午の夜店で、夜店外れの薄暗い場所に、しかもカーバイト代を節約した一層薄暗い店を張っていると、おっさん一杯くれと若い男が前に立った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみると大阪へ来ると直ぐ板屋橋の寿司屋の出前持ちになったが、耳が遠くて注文先からの電話がよく聞きとれぬから商売の邪魔だと、今朝暇を出され、一日中千日前、新世界界隈の口入屋を覗きまわって板場の口を探していたが見つからず、途方に暮れていたところだという。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
