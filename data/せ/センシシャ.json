[
  {
    "uuid": "07ba2810-f706-5802-a3bd-5bf60d7f048c",
    "entry": "戦死者",
    "reading": {
      "primary": "せんししゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
