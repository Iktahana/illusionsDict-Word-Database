[
  {
    "uuid": "1823ea55-5639-5155-a38e-6b1cac119e7d",
    "entry": "寂寥",
    "reading": {
      "primary": "せきりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
