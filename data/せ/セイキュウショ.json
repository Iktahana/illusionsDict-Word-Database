        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "挨拶とともに番頭がズイと掌で押出して、扨て默つて顏色を窺つた、盆の上には、湯札と、手拭が乘つて、上に請求書、むかし「かの」と云つたと聞くが如き形式のものが飜然とある。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上に、封を切った手紙や請求書などが、のっかっていた。",
              "citation": {
                "source": "碁の手直り表",
                "author": "菊地寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんなら月末に請求書を出してもらいましょうか」さすがに声は顫えていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、請求書という巧い言葉を思いついたので、豹一の興奮はいくらか静まった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし安二郎は請求書ときいて、飛び上らんばかりに喜んでいた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら、こうしたためた短冊に請求書を添えて編集部に送ってしまうのが、侘び寂を解する者の道である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが『対応』化作業の請求書の金額は、実に立派であった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二三日すると、肉屋の店に、件の判事からの仕払請求書が来た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人と共に門司行、請求書調製。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "石段の上の入口敷物の下に、瓦斯会社の請求書が挟めてある。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親たちの集めた三〇〇〇ドルは数週間で使い果たされ、ゼネラルエレクトリックから送られてくる高額の請求書を前にして、学校側は二人の両親に料金の一部負担を求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "請求書の額をはね上がらせる一方で、二人は互いに一目置く仲となり、しだいに友情を育てていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村の脱ぎ捨てた仕事着のポケットの中からは時々、小料理屋の勘定書や請求書などが出てきた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああだ、君の顔をみると、家賃の請求書に見えて仕方がないよ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて小塚検事は筆を取って予審請求書に署名をした。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は烏啼に対し請求書を出そうと考えた。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で君の方へ請求書を廻すことにしよう」「おい猫々先生。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで請求書がくるんだろう。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "請求書を御見せなさい、僕が今即座に払ってあげます。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、十万フランの払出請求書を書いた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、それならばというので、請求書を五千フランに書き改めると、銀行では、それに相当する英貨で、払ってくれた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは選挙資格審査請求書提出期限の二日前のギリギリの日であり、現知事が今のところ一人舞台として無競争選挙かといわれているときのことであった。",
              "citation": {
                "source": "実践について",
                "author": "――馬になった話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は審査請求書を書きあげて、期限の日の夜の十一時四十五分、ちょうど時間一杯というときに県庁にもち込んだのだそうである。",
              "citation": {
                "source": "実践について",
                "author": "――馬になった話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "リザヴェッタは何かの勘定の請求書ででもあるのかと、非常に不安な心持ちで開封すると、たちまちヘルマンの手蹟に気がついた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月分の俸給を京都から振替で送金したので、その他の分を併せて五百円だが、払出請求書を三十一日に出しておいたが、これもとても当分は手に入りそうもない。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "請求書は来ません、よこして下さいと云ってありますが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう受とって来た請求書、つづけてかきかけましたが、いつも別封にとおっしゃるのを思い出し別にいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二十七日朝　〔巣鴨拘置所の顕治宛　目白より（封書　速達）〕　十二月二十七日　これは請求書だけの分です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
