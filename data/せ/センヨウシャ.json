          "literary": [
            {
              "text": "数台まって、やっと乗りこんだ電車は行く先の関係で殆ど労働者専用車だ。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は外国人と腕を組んで新宿駅に行き、珍しい外人専用車の省線の電車に乗せて貰つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "占領中も、米軍の専用車に乗らず、普通の汽車に乗り込んできたのである。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "給水専用車や、ドラム罐を積んだトラックで補給するが、数が少くて廻り切れない。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
