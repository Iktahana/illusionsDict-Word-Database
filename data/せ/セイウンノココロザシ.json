    "definitions": [
      {
        "index": 1,
        "gloss": "high (lofty) ambition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
