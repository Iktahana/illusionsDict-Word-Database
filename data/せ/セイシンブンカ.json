[
  {
    "uuid": "baffb65f-4ee2-5c1f-8e2f-2363603b6745",
    "entry": "精神文化",
    "reading": {
      "primary": "せいしんぶんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
