[
  {
    "uuid": "306dc4d6-3e35-5888-8956-20cbe6379bee",
    "entry": "製造",
    "reading": {
      "primary": "せいぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
