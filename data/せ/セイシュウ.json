[
  {
    "uuid": "f1f164c3-ca3e-5b51-9ef6-1ab497e668f6",
    "entry": "聖週",
    "reading": {
      "primary": "せいしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Holy Week",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神聖週間には、月曜から土曜の晩まで、六日間というものはパンと水ばかりで、ただ生の野菜を食べるくらいのものでござりますが、それさえも、制限がありまして、毎日食べるわけにはまいりません。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダリヨはいろいろと祭の準備を整え、非常な熱心と献身的な態度とを以て聖週の行事を手伝った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワリニャーニは初め京都で聖週を迎えたいと考えていたらしいが、高槻に着いたのがもう月曜日の夕方で、復活祭の準備は急がなくてはならなかったし、それに信長が二三日中に上洛して京都で派手な祝祭を行うことになっていたので、かたがた神父たちは暗黒の諸儀式や復活祭を高槻で行って貰うようにと望んだ。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
