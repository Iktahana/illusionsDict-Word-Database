        "index": 1,
        "gloss": "burning sun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "繋船木曜島南湾、路入濠洲最北関、赤日炎風涼何在、只余熱帯樹陰山。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この近海はなお熱帯圏内にあれば、昼間は赤日炎々たれども、朝夕の南風はすでに秋冷を送り来たる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤日炎々、はじめて酷暑を覚ゆ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤日石林気というのも又つくばいの銘でなければならない。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
