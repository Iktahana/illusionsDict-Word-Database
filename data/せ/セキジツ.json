    "definitions": [
      {
        "index": 1,
        "gloss": "old days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "衣食住さへ足りればいゝ人達は、不景気にも関らず、昔日よりも元気でこそあれ落胆してゐるとは思はれぬ。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、芸術家は、昔日よりも、一層の孤独を必要とするであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが作家等が昔日のやうに、楽々と筆を執つてゐないことだけは事実である。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては「統一」の要求は忘れ果てられるのみならず、昔日の粗朴ささへもが、はや「血迷つた粗朴さ」でしかないのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのやうな烈しい愛と熱とがもう私と友とを昔日のやうに結びつけることが出来なくなつたのであらうか。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良仕事にも、夜なべにも昔日のように精が出なくなった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか昔日の力士｜逆鉾を思い出させるものがある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今このガンスの作品を見て昔日のこの感じを新たにするような気がした。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああわが最愛の友よ（妹ドラ嬢を指す）、汝今われと共にこの清泉の岸に立つ、われは汝の声音中にわが昔日の心語を聞き、汝の驚喜して閃く所の眼光裡にわが昔日の快心を読むなり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われをしてしばしなりとも汝においてわが昔日を観取せしめよ、わが最愛の妹よ！",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿頭の佛蘭西の老紳士が昔日の腕前を見せて呉れんとバイオリンを採つて彈くか彈かぬに歌の曲をハツタと忘れて、頭撫で／＼罷退るなど隨分滑かれたのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には自分になまじい物質的な利得ばかりを与えながら昔日の尊敬を忘れ去り、学商呼ばわりする世情を、気狂いのようになって悲憤慷慨することもある。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾瀬の水、今は飲むに堪へず、溷濁汚腐、昔日の地志の此を称せしを疑はざるを得ざるなり。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自動車で行ける路でも無いので、昔日の健脚、今の寢足、しかた無いからまた中禪寺へ歸つた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の気焔は益々昂まって、例の昔日譚が出て、今の侯伯子男を片端から罵倒し初めたが、村長は折を見て辞し去った。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の如くにして今日の開化も昔日の蛮野に異ならざるなり。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔日暴風雨を凌ぎ、疾雷閃電の猛威を以て、中原を席捲し去りたる夢は今｜何処にかある。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "春や来しと覚ゆるなるに、我牢室を距ること数歩の地に、黄鳥の来鳴くことありて、我耳を奪ひ、我魂を奪ひ、我をしてしばらく故郷に帰り、恋人の家に到る思ひあらしむ、その声を我が恋人の声と思ふて聴く時に、恋人の姿は我前にあり、一笑して我を悩殺する昔日の色香は見えず、愁涙の蒼頬に流れて、紅ゐ闌干たるを見るのみ。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところに収めたる当世風の花簪、一世一代の見立にて、安物ながらも江戸の土産と、汗を拭きふき銀座の店にて購ひたるものを取出して、昔日の少娘のその時五六歳なりしものゝ名を呼べば、早や寝床に入れりと言ふ、枉げてその顔見せてよと乞へば、やがて出で来りて一礼す。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔日のわが不平、幽鬼の如くにわが背後に立ちて呵々とうち笑ふ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊皇攘夷の代りに、今や公武合体といふスローガンが尤もらしく振りまはされ、幕府は朝廷を擁して、天下の諸侯に昔日の威を以て臨まうとしてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟のミクロフトは、実によく僕の書斎を管理していてくれて、新聞紙などまでが、全く昔日の通りにきちんと整理されていた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常にキレイではあったし、また凡ての位置は昔日のままであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔日、スタンフォードとそれほど親しいわけではなかったが、私が心のこもった挨拶をすると、スタンフォードもうれしそうな顔を見せてくれた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白き樂の調は耳より入りて胸に達し、昔日の不興をば少しも殘さず打ち消しつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどその歡喜をなしゝは昔日の事にして、今これが記念を喚び起せば、一として悲痛に非ざるものなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは物語の昔日の過に及ばんことを慮りしに、この御館を遠ざかりたりしことをだに言ひ出づる人なく、老公は優しさ舊に倍して我を※待し給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝若し我が昔日の生涯を語らず、彼の馴るゝ小鳥の事、愛らしき歌妓の事などを祕せんと誓はゞ、われは汝を伴ひてジエノワに往くべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
