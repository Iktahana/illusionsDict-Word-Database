    "definitions": [
      {
        "index": 1,
        "gloss": "height (e.g. in a form)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
