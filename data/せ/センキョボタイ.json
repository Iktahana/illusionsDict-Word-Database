        "examples": {
          "standard": [
            {
              "text": "その候補者は地元の建設業界を強力な選挙母体として、着実に票を固めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特定の政党や宗教団体を選挙母体に持たない無所属候補が、異例の快進撃を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "選挙母体の弱体化により、今回の選挙は予想外の苦戦を強いられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このプランに従って上述の七部門および綜合一部門を加えて八部門からそれぞれの関係する学界、協会を選挙母体として一〇八名の刷新委員が決定した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならばこの委員会も従来の学閥ギルドそのままの選挙母体から選出されているからである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
