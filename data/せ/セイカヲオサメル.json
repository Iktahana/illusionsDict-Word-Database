        "examples": {
          "standard": [
            {
              "text": "わが社の製品が海外市場でシェア1位を獲得し、世界的な成果を収めるに至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しいトレーニングに耐え抜いた選手たちが、国際大会で輝かしい成果を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年にわたる平和外交が実を結び、ついに隣国との国境問題で歴史的な成果を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこでは、ヴェルレエヌ、グウルモン、ラフォルグ、マラルメ等の詩人の後援によつて、先づ、詩の朗読が行はれ、次で詩的戯曲の上演が企図されたが、遂に予期の成果を収めることはできなかつた。",
              "citation": {
                "source": "近代劇論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどの骨折りも、一つとして成果を収めることができなかった。",
              "citation": {
                "source": "墓地へゆく道",
                "author": "DER WEG ZUM FRIEDHOF",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
