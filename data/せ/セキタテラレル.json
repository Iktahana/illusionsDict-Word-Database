    "definitions": [
      {
        "index": 1,
        "gloss": "to be hurried",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "駅から町の中心に通ずる道路を、われわれは急きたてられるやうにして歩いた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急きたてられるやうな思ひで、深水に暇を告げた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの意味かわからないけれども、彼女は、急きたてられるやうに寝台から滑り降りた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝実枝にさんざん急きたてられるまでクニ子はひと時花畑に入りこんでジキタリスの花の数をかぞえてみたり、向日葵と背比べをしたり、薔薇の匂いに小鼻をうごめかしては悦に入ったりするのであった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいや、嬉しいこっちゃなあ」　いねは自分の嬉しさもこめて、急きたてられるままに手織の絣の着物に着かえ、中幅帯を引上に結んだ。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅で乗換える時、途中下車して町の容子など見てみたいと思ったが、何かせきたてられる想いで直ぐ大阪行きの汽車に乗り、着くと夜だった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "院はこの邸における人目も恐ろしく思召されたし、日が昇っていくのにせきたてられるお気持ちも覚えておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが沈黙つてゐると、二人とも何かにせきたてられるやうな気持ちであつた。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私あなたに会つてゐると、せきたてられる気持になるの。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く別れて帰らなければいけないやうな、せきたてられる気持になるのよ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は、手に持っていたろうそくに、せきたてられるので絵を描くことができずに、それをみんな赤く塗ってしまいました。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、おのおの方……」　時日はせまる、壺はわからぬ、上役にはせきたてられる……で、自暴自棄になっている高大之進、いきなり、抜いたんです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの日々は異教の神々の名がついている一週のうちの何曜日とかいうのではなく、二十四時間に細分され、時計の刻みでせきたてられるものではなかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "民俗学的な魅力はもとよりでしょうが、言語や文学や音楽や舞踊や建築や彫刻や、もろもろの工藝に至るまで、心を打つものが山ほどもあるのですから、眼も忙しく心もせきたてられる想いでありました。",
              "citation": {
                "source": "沖縄の思い出",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　道江をめぐって　次郎は、まもなく、せきたてられるようにして、朝倉先生の門を出た。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで自分の思うままに生きられる、という解放感にせきたてられるような気持で、故郷を出て来た。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと面白くなったぞ」かれは思わず呟いた、「ひとつ新島に泥を吐かせてやろう、おれの大洗もでたらめだがいま頃はあの男もでたらめを考えているに違いない、しかし、どっこい、その手はくわなの……」　浴槽からあがると、せきたてられるような気持でかれは風呂場から出た。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、たいてい六、七人は集まって、与平にせきたてられるまで、話したり笑ったりしていった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は、愛好する作者の活発な創作や、同好の友の快活な空想によってせきたてられる。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
