    "definitions": [
      {
        "index": 1,
        "gloss": "rice(-cleaning) mill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "工業的騒音を好まざれど精米所の音響と、投機的熱狂を繰りかえす。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "買って来たのは玄米らしく、精米所へ搗きに出しているのが目につく。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所の汽笛で、やっと、人間にかえったような気がした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ふのだが、私は、下駄のままで精米所へのこのこはひるほど無神経な男ではない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所の機械の音が、どつどつと、だるげに聞えて来る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはこの町の唯一の精米所でもあり、金持でもあった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな門を入ると、水車仕掛の大きな精米所が、直にお島の目についた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所の主人が建ててくれたと云う、その新座敷へ、お島も時々入って見た。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ精米所の主人がやって来て、炉縁に胡坐をかくと、そこにごろりと寝転んでいたお爺さんは直に奥へ引込んで行った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所の主人の前には、直に銚子がつけられて、上さんがお酌をしはじめた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの家も、精米所のお蔭で持っているのさ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のいる間、お島は家を出て、精米所へ行ったり、浜屋で遊んでいたりした。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所では、東京風の品のいい上さんが、家に引込きりで、浜屋の後家に産れた主人の男の子と、自分に産れた二人の女の子供の世話をしていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所の主人や、浜屋の内儀さんなどに、家賃や、時々の小遣などの借のたまっていた壮太郎のために、双方の談合で、その質に、お島の体があずけられる事になったのであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃になると、いつも炉端に姿をみせる精米所の主人が、もうやって来て大きな体を湯に浸っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "市へお島を私と住わしておこうと云う相談も出たが、精米所の補助を受けて、かつかつ遣っている浜屋の生計向では、それも出来ない相談であった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、精米所の主人に、内密で金を出してもらって、Ｔ――市の方で、何かお島にできるような商売をさせようと云うのが、浜屋の考えつめた果の言条であった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「立つにしたって、浜屋へもちょっと寄らなくちゃならないし、精米所だって顔を出さないで行くわけにいきやしませんよ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の温泉宿や、精米所の主人もいた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "精米所の主人は、月に一度くらいは急度蠣殻町の方へ出て来るのであったが、その時は上さんと子供をつれて来ていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "好い奥様になったということ」　精米所の主人は、浴衣がけで一座の真中に坐っていながら言った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島はその一人からは夏のインバネス、他の一人からは冬の鳶と云う風に、孰も上等品の註文を取ることに抜目がなかったが、いつでも見本を持って行きさえすれば、山の町でも好い顧客を沢山世話するような話をも、精米所の主人が為ていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉づいた手に、指環などを光せている精米所の主人のことを、小野田は山にいた時のお島の旦那か何ぞであったように猜って、彼等が帰ったあとで、それをお島の前に言出した。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
