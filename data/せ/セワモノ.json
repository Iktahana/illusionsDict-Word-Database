    "definitions": [
      {
        "index": 1,
        "gloss": "sewamono (Edo-period drama about contemporary life)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "音の効果的な適用は、市井文学、いわば世話物に多い様である。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音の効果的な適用は、市井文学、いはば世話物に多い様である。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔どこやらで旧俳優のした世話物を見た中に、色若衆のような役をしている役者が、「どれ、書見をいたそうか」と云って、見台を引き寄せた事であった。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、怪談の狂言に時代物もあるが、怪談として凄味の多いのは世話物である。",
              "citation": {
                "source": "怪談劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味から云って、世話物は舞台の装置も人物の扮装もアッサリしていて暑苦しくない。",
              "citation": {
                "source": "怪談劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今なら舞台監督兼作者となったのが水蔭で、一番目の『積る怨切子燈籠』という半世話物の仇討劇も二番目の何とか太平記といった大塔宮の吉野落を材とした一幕物も皆水蔭の書卸しであった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近松巣林子の世話物は、殆んど情死を主材としてをるに拘はらず、それは正に当時の町人的世界観の勝利をあらはしてゐると見てよいのである。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は高坐で伯山の「天一坊」を聴いたことが無いので、高坐と舞台との間にどれだけの相違があるかを知らないが、物が物だけに、これは「髪結新三」などの世話物とは違って、原作以上に劇化されているものと察せられる。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし団十郎自身はあまりこの役を喜んでいなかったらしく、今度の大入りについても、さのみ得意の色をみせないで「なに、団十郎が久しぶりで世話物をするというので、めずらしがって来るだけのことです。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保以前の近松の淨瑠璃は古典的で、之を時代物といひ、又唐人物といつた彼の國姓爺合戰の如き、其芝居が足かけ三年つゞけてうつて尚流行つたが、國姓爺後日合戰を出した時にはそれ程人氣を呼ばなかつたといふことで、茲に於て近松は一轉して世話物を書くことになつた。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論前から少しは世話物もかきつゝあつたが、專ら世話物で當てたのは享保初年以後であつた。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすみ子には幼いころ見た絵草紙から脱け出た娘が、父の浄瑠璃の中の世話物がかった娘に対するように、その美と情緒とに受身になって流れて行くよりなかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才を信ずる以上は、その作が世話物であらうが、時代物であらうが、そんなことには頓着しないで善い。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "班女といい、業平という、武蔵野の昔は知らず、遠くは多くの江戸｜浄瑠璃作者、近くは河竹｜黙阿弥翁が、浅草寺の鐘の音とともに、その殺し場のシュチンムングを、最も力強く表わすために、しばしば、その世話物の中に用いたものは、実にこの大川のさびしい水の響きであった。",
              "citation": {
                "source": "大川の水",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあね、いって見れば、あたしは、女団洲と呼ばれたくらいだし、自分でも、団十郎のすることの方が好きだから――わかりもしないくせに、高尚ぶってるといわれたりしたけれど、もともとお狂言師は、生世話物をやらなかったからねえ。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが癖になってて、新世話物に行けなかったのかも知れない。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しいことにはジオルジユ・グランと云ふ俳優が世話物に掛けてこそ一流だが、今度始めて斯う云ふ時代物に手を着けたので、其モリエエルは未成品だと云ふ外は無い。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど世話物の三幕目でいざと云う場になる前に、色男の役をする俳優が身繕いをすると云う体裁である。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその勤務は主として世話物語りが持場で、之れは太夫の選擇に依つて毎日出し物をきめるが、別に忠臣藏の九段目と太閤記の十段とは必らず座元の指定通り語らねばならぬ義務を負はされる。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのをかしみが勝つて、卑俗であり、また写実傾向が深くて、世話物じみたものは、所謂「能狂言」の方に所属させられ、その古典味が勝つて、笑ひを催す実感の欠けたものは、次第に優雅化せられて、能楽の領分に這入つて行つたものである。",
              "citation": {
                "source": "鶴が音",
                "author": "――鶴亀の芸能――",
                "note": "青空文庫"
              }
            },
            {
              "text": "能に於ける曾我物は後の語の世話物とでも申しませうか、さうした意味のものゝ様です。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やはり彼のえろきゆうしよんを純世話物式でないと言つたとすれば、問題の焦点と言ふよりも、菊五郎によつて暗示せられた羽左衛門芸術の解釈の緒口は、やつぱり此点に求めるのが、本たうであらう。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の芸質に、時代物の味ひを濃く感じた菊五郎の率直な語は、その世話物よりも、却て時代物から受けた印象を、世話物の上に落して見たものではないか。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時、はじめて世話物の子役を勤めたことになる。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生世話物で、彼のをこつきを見ると、もう占めたものだ、と言ふ気がした。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お家物は「武家階級の世話物」であるが、真女形はやはり、時代物のいきではたらき、時代の気分を表現する。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざんぎり物なども、世話狂言の引き続きと言へば、正統的なものと考へられさうだが、世話物の中でも、殊にあてこみ・場当り・一夜漬けの傾向の甚しく残つて見えるものである。",
              "citation": {
                "source": "雑感",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
