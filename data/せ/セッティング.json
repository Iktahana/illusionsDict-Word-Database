        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "劇団は、観客を魅了する斬新な舞台セッティングを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台美術家は、物語の世界観を表現するために、巧妙なセッティングを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "セッティングには、照明、小道具、背景幕などが含まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
