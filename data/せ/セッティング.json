        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "映画監督は、舞台のセッティングに細部までこだわった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の前に、部屋のセッティングと資料の準備を終えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新の音響機器のセッティングに、専門家が呼ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「ワラ、おまえも、あがってこい」　塔の上では、カメラのセッティングのために撮影用のライトが点灯され、全員がせまいところに勢ぞろいした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみたちの感動的な再会は、おれがセッティングしてやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　スタニスラフスキーのオペラは、芝居とオペラとの調和が狙いどころの由、群集をリズム（音楽）に合わせて動かし、イタリーの無駄な遊びを整理しようとして居るところ、セッティングを、四本のコラムをどこまでも利用して居るところ、面白かった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ボーン・セッティングは、骨つぎか。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロフォンのセッティングをほぼ終わり、テープをまわして試験録音しつつ、最後の調整がおこなわれた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
