[
  {
    "uuid": "b2f70f31-925a-525a-a272-54b130a5dc6b",
    "entry": "摂生",
    "reading": {
      "primary": "せっせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
