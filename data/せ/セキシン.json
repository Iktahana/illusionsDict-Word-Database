        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一寸の虫にも、五分の赤心がありました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸の蟲にも、五分の赤心がありました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱のめくり暦は十月五日を示して、余白には、その日の用事が赤心の鉛筆で細かに記してあった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしたちは、レヤチーズの赤心に報いなければならぬ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸の虫にも五分の赤心がありました。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君への忠義の赤心に、理由はございません。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにこの京都の御所に対し奉る御赤心と、それから敬神崇仏のお心の深さは、その御一生をつらぬいて不変のもののやうでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それよりも、周さんをして長大息を発せしめたものは、この短いたよりの中に貫かれている鮮やかな忠義の赤心であった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教はクリード（信仰個条）にあらざるなり、宗教は聖餐にあらず、洗礼にもあらず、但しは、法則にも、誡命にもあらざるなり、赤心の悔改と赤心の信仰とは、いかなる塲合に於ても尤も大なる宗教なり。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども蘇峰先生は、悉皆の詩人哲学者小説家を以て、ベベルの高塔を築くものなりとは言はれざりし、神知霊覚といふ事は先生も亦た之を認められたり、赤心を以て観るといふ事も大に吾人の心を得たるものなり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなれば我は赤心を棒げて人々に依頼せしに、人々は我をして鹽の柱と化すること彼ロオト（亞伯拉罕の甥）が妻の如くならしめしぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と蝶吉の項を抱いて口移しに噛んで含めるように、自分の赤心を語るため、今まで久しい間、時に触れ、折に当って、動かされた、至憐至愛の情の切なるを、ここに打明けて語ったのである。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に政権の独占を憤れる民権自由の叫びに狂せし妾は、今は赤心資本の独占に抗して、不幸なる貧者の救済に傾けるなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへ絶句を題する者あり、いわく、〈赤心国に許すは平時よりす、敵を見て躯を捐ててさらに疑わず、権は忌み皐は庸にして皆遁走し、同時に難に死すは只青獅のみ〉と。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ対談数刻に渉ってもかつて倦色を示した事がなく、如何なる人に対しても少しも城府を設けないで、己れの赤心を他人の腹中に置くというような話しぶりは益々人をして心服せしめずには置かなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "情なの横笛や、よしや送りし文は拙くとも、變らぬ赤心は此の春秋の永きにても知れ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしや他にはあらぬ赤心を寄するとも、風や何處と聞き流さん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其余の事ハ不分明、小弟思ふニ、三吉大夫が陸軍をおさめたまいし時ハ隊中一同皆報国の赤心を振起し、大夫の賢なるをかんじ居候よし也。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之これを伐たんと云ふ輩は敢て私心を挾むに非ず、愛國盡忠の赤心を事實に顯はさんとすることなれば、一概に之を咎む可らずと雖ども、國を愛するには之を愛するの法なかる可らず、忠を盡すには之を盡すの路を求めざる可らず。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて支那の君主は、赤心を臣下の腹中に置くことが難い。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "字句に何等の技巧はないが、全篇赤心の結晶である。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて支那の君主は、赤心を臣下の腹中に置くことが六ケ敷い。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤心をもって、公のため、天下のために働いてみる」「そうか」　大久保が、こう云った時、女中が「旦那様が、お召しでござります」　と、云って来た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "どンと土間におりて、「ああ、わが赤心、――」と呟いた、「国に報いんと欲す」　格子戸の錠前が外された。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「噫我赤心欲報国」と起し、「蓑笠独耕石水浜」と結んだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようの次第で新藩主には徳川方より聊か嫌疑を受けられた結果であるか、遂においてけぼりを食わされたので、この上は帰藩して飽まで佐幕の旗を翻えし、赤心を明かにしようと決心された。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤心報国真荒男が朝廷思ひの忠実心　眼を血に染めて、焼刃見澄ます国のため念ひ痩せつる腸を　筆にそむとて、吾が世ふかしつ仇に向き　※たゝきけむ古人に　ならひてこそは、国に仕へめ正宗の大刀の刃よりも、国のため　するどき筆の鉾｜揮ひみむ国を思ひ寝られざる夜の　霜の色。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
