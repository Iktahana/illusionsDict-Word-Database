[
  {
    "uuid": "f86b1fca-65f2-50d4-9a3a-f26fa20c5693",
    "entry": "戦時",
    "reading": {
      "primary": "せんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
