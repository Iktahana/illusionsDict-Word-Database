        "examples": {
          "standard": [
            {
              "text": "単身赴任中ではあるが、住民票は家族が暮らす自宅、つまり生活の本拠に置いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判所は、彼が平日の大半を過ごしているマンションを事実上の生活の本拠と認定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「海外を飛び回っていても、やはりここが私の生活の本拠なんだと実感するよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "町中の雰囲気や、駅頭の雰囲気と、子供たちの生活の本拠の家の中の雰囲気とが、何か違つたものを感じたのであらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に彼が釈放されても生活の本拠が既になくなっているのだ。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは海岸を生活の本拠として、そこから川ぞいに山入りした古俗の反映であります。",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の本拠を失ったワグナーを襲った最初のものは、おそろしい窮乏であったことは言うまでもない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
