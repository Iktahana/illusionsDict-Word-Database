    "definitions": [
      {
        "index": 1,
        "gloss": "positive number",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正数が負数に化ける。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正数の系列は正数と負数との系列にまで――論理的に――止揚される、歴史的には之が算術から代数学への・算術的方法から代数的方法への発展を意味している。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "正数と負数との単なる対立はそれ自身としては少しも弁証法を構成しない、ただ正数が負数にまで、――歴史的に――拡張されたという、この歴史性をその経歴としてこそ、正数と負数とは弁証法的であることが出来る。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば小倉金之助博士が数学史や数学教育論を書いたにしても、今日では恐らく誰も純正数学者（？",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
