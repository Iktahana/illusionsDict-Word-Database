        "examples": {
          "standard": [
            {
              "text": "トヨタが開発した「かんばん方式」は、世界中で採用されている効率的な生産方式だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多品種少量生産に対応するために、従来のライン生産方式からセル生産方式に切り替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しい生産方式を導入したことで、リードタイムを大幅に短縮することに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "國家間の差別、および人種間の反目は、ブルジョアジーの發達のために、通商の自由のために、世界市場のために、生産方式およびそれに相應する生活關係の同一化のために、もはやだんだん消滅しつつある。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の工業分野におけると同様に、陶磁器製作の面でも、曾てのギルド的製作方法が商業主義的大量生産方式の色彩を色濃く帯びるに従って、この趣味的美的陶磁器生産も、また時代の波に置去られ、孤立化し、少数化するに至るのである。",
              "citation": {
                "source": "日本のやきもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
