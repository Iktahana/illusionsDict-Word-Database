    },
    "definitions": [
      {
        "index": 1,
        "gloss": "marriage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不良と思う村娘の結婚には、旧家と村長の威光を以て意地悪く成婚を妨げた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の成婚は私事であって、外部からの容嘴はあり能わぬ。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日、摂政宮御成婚の日。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもと村の秘密行事との関係、神託と子どもとの交渉は、前に既に書いたが、其上に、子を生む事が成婚の理由でもあり、同時に離縁の原因にもなつた古代の母たちは、其上に夫と違うた秘密な生活様式の為にも、呪はれて居たのであつた。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦の狐窟　御成婚の挙式をひかえて、山田康彦氏が東宮侍従長に昇格された。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春となる桜の枝は何となく花なけれどもむつまじきかな　次のは「源三位頼政家集」にある歌だが、ことし御成婚の正田美智子嬢に寄せたような歌なので、載せておく。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三四・三・三）その十一　御成婚式も間近い。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりは吉田大納言定房の末裔の吉田博光氏で、皇太子さまの御成婚に儀進をつとめられた甘露寺掌典長とは、ご親戚か親友か、とにかく、よほど親しいことばがたきの由。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
