          "literary": [
            {
              "text": "多分、聖痕と云う心理学用語を御存知でしょうが、あのフランス・カレッジの先生は、一人の田舎娘を見出して、それから聖像凝視が因で起る、一種の変態心理現象を発見したからなんですよ。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代の深傷を生ま生ましく刻印され、その傷痕をして聖痕たらしめよ。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
