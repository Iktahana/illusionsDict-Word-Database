[
  {
    "uuid": "52932eef-8249-54db-827e-34eac700861f",
    "entry": "成婚",
    "reading": {
      "primary": "せいこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
