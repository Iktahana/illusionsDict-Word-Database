  {
    "uuid": "49df0a25-d309-5498-a7dc-579f3d5cdfd3",
    "entry": "選地",
    "reading": {
      "primary": "せんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "selection of a site (for a castle, burial mound, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感傷の手わが性のせんちめんたる、あまたある手をかなしむ、手はつねに頭上にをどり、また胸にひかりさびしみしが、しだいに夏おとろへ、かへれば燕はや巣を立ち、おほ麦はつめたくひやさる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとびとよ、美しきひとびとよ、つねに君はせんちめんたるなれ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "指にふれ得ずして、指さきの纖毛に觸れうるものの感覺に、私の心靈は光をとぎ、私のせんちめんたるは錐のごとくなる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした私の子供じみたせんちめんたりずむをお笑ひ下さるな。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よかよか、人ん事心配せんちゃよか、金持ちどもは卑俗くしなん、構いなはらんがよかたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し腑に落ちんことがあるなら、どういうわけでそう為にゃならんのか、分りませんちゅうて、教えて貰いんされえ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、此の稍々せんちめんたるな人が深夜、人気ない部屋に在って思う、こんな感動は、暫くすると、その感動を静かに見守る何物かによって、次第に其の光彩を失いかけて来た。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の低利資金だって、払へる見込の有る者でなけにゃ貸せんちふものな。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこさか行ってしまいたい」「どこさか行く云うても、お前がとのような意地っぱりは、人が相手にせんと……」「相手にせんちゃよか！",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本のかうした大衆的な芸術に、あゝしたせんちめんたりずむな気分は、最早滅びる時期が来たのだと思ふ。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、大衆芸術には当然感傷味がなければならぬのではあるが、現代では、さうしたせんちめんと以外に、もつと外の或ものが加はらなければならぬのだと思ふ。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを話し出しますと何だかせんちめんたるな心がおこつて来ますが、一体今迄の民俗学にはこのせんちめんたるが多分に這入つて居りました。",
              "citation": {
                "source": "三河の山村",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はそれを卒業しようと心掛けて来たのですが、今度がその「民族」との別れでありますから、まう一遍だけ、そのせんちめんたるを使はしていたゞきます。",
              "citation": {
                "source": "三河の山村",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民族」の集りが、今度「民俗学」に変ると共にかうしたせんちめんとに属する表現法を止めたいと思ひます。",
              "citation": {
                "source": "三河の山村",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "態と申進候天人天降り被成供せんちよふむていは天主様より火のすいちよ被成候間何者なりとも吉利支丹に成候はゞ爰許へ早々可有御越候村々庄野乙名草々御越可有候島中に此状御廻可有候せんちよ坊にてもきりしたんに成候はゞ被成御免候恐惶謹言。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、六日の夜二人で家までかえる途中、せんちなことを云うようになった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "情を喜び、苗字を問ふと、弟せんちよが「之はきよすのはんと申すなる」と言ふ。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せんちめんたるもあすこまで行くと不幸ですなあ！",
              "citation": {
                "source": "寡婦",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせんちゃんはどうしやした」「唯今ちょいとお詣りに。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸一｜番のおせんちゃんを乗せてるんだからの」「そうとも」「こうなると、銭金のお客じゃァねえ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚ンながら駕籠定の竹と仙蔵は、江戸一｜番のおせんちゃんを乗せてるんだと、みんなに見せてやりてえんで。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「どうかそんなことは、もういわないでおくんなさい」「評判娘のおせんちゃんだ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "のう竹」「そりゃァもう仙蔵のいう通り真正間違えなしの、生きたおせんちゃんを江戸の町中で見たとなりゃァ、また評判は格別だ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おせんちゃんが垂を揚げておくんなさりゃ、どんなに肩身が広いか知れやァしねえ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おせんちゃんにゃ、千｜人の男が首ッたけンなっても、及ばぬ鯉の滝のぼりだとは、知らねえんだから浅間しいや」「八つぁん。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やッ、おせんちゃん。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だがおせんちゃん。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのお鍋も女なら、おせんちゃんも女だが、おんなじ女に生れながら、お鍋はなんて不縹緻なんだろう。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            }
          ]
        }
