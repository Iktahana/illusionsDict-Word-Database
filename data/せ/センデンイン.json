        "examples": {
          "standard": [
            {
              "text": "彼女は、このイベントの成功のために、優秀な宣伝員を雇った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新刊の発売に向けて、宣伝員がメディアへの露出を増やしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、商品の魅力を最大限に引き出す才能のある宣伝員として評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いまだにニコライ・ロマノフの写真を飾って上帝に十字を切る一団、北東の秘密活動本部をここへおく第三国際の宣伝員、すべての主義と世の動きとをよそに在りし日を夢みる階級――それらの露西亜人とその家族たちが、しばらく政治と闘争と謀策を中止して一夜の受楽のためにこうして集っているのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はオデッサの大学を出ると直ぐ第三国際の宣伝員として黒海に沿うすべての都会の裏街で売春婦たちと一しょに人参と洗濯｜石鹸を食べて生活しました。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は来た隣炭山の兄弟達へ早く宣伝員派遣古河坑の支部へ水島定子！",
              "citation": {
                "source": "夜明の集会",
                "author": "波立一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の観察によると、彼女は大阪から出張した宣伝員にちがひなく、或は私と同じ船で帰るかも知れない等といひます。",
              "citation": {
                "source": "美女",
                "author": "西東三鬼",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
