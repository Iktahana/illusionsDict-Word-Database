  {
    "uuid": "faf7d819-e8ef-5d00-bd96-dd6a3fc0d84d",
    "entry": "旋盤",
    "reading": {
      "primary": "せんばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
