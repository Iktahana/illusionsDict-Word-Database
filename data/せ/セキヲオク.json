    "definitions": [
      {
        "index": 1,
        "gloss": "to be enrolled (in a college, course of study, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かれは高野山に籍を置くものだといった、年配四十五六、柔和ななんらの奇も見えぬ、懐しい、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻をしめ、土耳古形の帽を冠り、毛糸の手袋を嵌め、白足袋に日和下駄で、一見、僧侶よりは世の中の宗匠というものに、それよりもむしろ俗か。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいったって、どうせ、籍を置くだけなんだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は高野山に籍を置くものだといつた、年配四十五六、柔和な、何等の奇も見えぬ、可懐い、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻を占め、土耳古形の帽を冠り、毛糸の手袋を箝め、白足袋に、日和下駄で、一見、僧侶よりは世の中の宗匠といふものに、其よりも寧ろ俗歟。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特殊撮影技術を集めた『ＳＦＸミュージアム』や、映像作家たちの仕事をさらう『映像の先駆者』シリーズの関連で、初めて渡米すると、ＭＩＴ（マサチューセッツ工科大学）の研究所、メディアラボに籍を置くというボブ・スタインという人物から連絡がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青年は何も学術に秀れてゐたからとかといふ理由ではなく、近くのカレツヂに籍を置く、たつたひとりの日本人といふだけの資格で、臨時雇ひの栄を蒙つたのです。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に文学を志していたのであったが、一日も早く父母の生活を支えねばならぬという立場から、奨められて電機学校に籍を置く。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐沢家の関係から、貴族院に籍を置く、伯爵や子爵が殊に多かった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ、新聞社に籍を置く僕さえも、あの時ばかりは苦々しく思いました。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについてはわたしの新聞社に籍を置くことにしないか。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、わたしは新聞社に籍を置くことになって、最初は校正係の助手を命ぜられた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐沢家の関係から、貴族院に籍を置く、伯爵や子爵が殊に多かつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は又、或教會に籍を置く基督信者で、新教を奉じて居ながらも、時々舊教の方が詩的で可いと云つて居た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は又、或教会に籍を置く基督信者で、新教を奉じて居ながらも、時々は旧教の方が詩的で可いと云つて居た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎に集った普通学部の青年で教会に籍を置くものは、それぞれ仕度して、各自の附属する会堂へと急いで行く。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母のお蔭で、東京大学に籍を置くまでになつたが、種々の障礙のために半途で退学した。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼロックス社のパロアルト研究所に籍を置くアラン・ケイとアデル・ゴールドバーグという著者は、人が何かを生み出すための新しい道具を作ろうと考えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来、一九七七（昭和五十二）年から一九七九年までの三年間で、府中事業場に籍を置く情報処理の技術生産部隊の三分の一近い七〇〇名が指名を受け、五〇〇名が営業とシステム部門に、残りの二〇〇人がマシンの保守や運用の部門にまわされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして開発、製造側からは、かつてシステム１００で浜田とコンビを組んでいた、府中のコンピュータ技術本部第二開発部に籍を置く戸坂馨が加わってまとめられたのが、このプランだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "生年に三年の差はあるものの、東京の世田谷に生まれ、私立有名大学の理工系に進み、同じ会社の同じ部門に籍を置くことになった二人の経歴には、共通項が多い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがフィールドサポート部に籍を置く早水には、いかにもオフィスコンピューター用のプログラム開発を打診するかのようにして彼らを訪ねることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッケージソフトの流通卸として設立された日本ソフトバンクに籍を置く松田には、理想や夢や期待を削ぎ落とした日本の市場の実体が、ありのままに見えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "上司の古川享をはじめ、アスキーのソフトウエア部門に籍を置くスタッフは、自社オリジナルのアプリケーションをなんとか成功させたいと願っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の花を統べ給ふ情知りのさくや姫よ、自分の心にも花を咲き満たせ給へとかう歌つた作者は青春期になほ籍を置くもののやうに恍惚としてゐる。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も二人共に基督教へ籍を置くゆゑ、自然そこへ行つたのだらう。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はバッケの勧めで、自由に科目を選択してもいいといふ条件で附属演劇学校に籍を置くやうになつたが、コポオの講義だけは欠かさずに聴いた。",
              "citation": {
                "source": "ジャック・コポオの印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大の仏文科に籍を置くやうになつたのはそのためである。",
              "citation": {
                "source": "陸軍士官から",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出てゐなくとも、試験さへ通れば別科に籍を置くことができる。",
              "citation": {
                "source": "明治大学文芸科に演劇映画科を新設する件",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が現職（註、大学教授のこと）であり晩香（註、菊乃さんのこと）が花柳界に籍を置くならば、名教の罪人でもあろうが、私は既に教壇を退き晩香も一旦人の正妻となり離婚後であった」　とある。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その六　暗い哉　東洋よ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、当時の庄屋問屋本陣なるものの位置がその籍を置く公私の領地に深き地方的な関係のあったことを忘れてはならない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
