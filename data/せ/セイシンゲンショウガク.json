    "definitions": [
      {
        "index": 1,
        "gloss": "The Phenomenology of Spirit (1807 book by Georg Wilhelm Friedrich Hegel)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
