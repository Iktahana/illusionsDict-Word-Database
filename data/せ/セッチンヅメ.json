        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "終盤、王将を隅に追い詰める「雪隠詰め」という戦法がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手の王将を雪隠詰めにするため、慎重に駒を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最終的に、完璧な雪隠詰めにより、相手プレイヤーは投了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
