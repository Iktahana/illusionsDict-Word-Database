        "examples": {
          "standard": [
            {
              "text": "お弁当の具材が混ざらないように、プラスチックのセパレータで仕切りを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "書類整理のために、バインダーの中にインデックス付きのセパレータを差し込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "機械の中に蓄積した油分を除去するため、オイルセパレータを定期的に清掃する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "バタ製造機械のうち、セパレータ二百圓。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            }
          ]
        }
