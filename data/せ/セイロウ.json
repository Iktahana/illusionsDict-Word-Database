[
  {
    "uuid": "e8e6fac1-a455-5469-b0d3-4c5f6f73623e",
    "entry": "晴朗",
    "reading": {
      "primary": "せいろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天気晴朗ですが波はべら棒に高いです。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」と彼の暗記しおる公報の一つ、常に朗読というより朗吟する一つを始めた、「敵艦見ゆとの警報に接し、連合艦隊は直ちに出動これを撃滅せんとす、本日天候晴朗なれども波高し――ここを願います、僕はこの号外を読むとたまらなくうれしくなるのだから――ぜひここをやってくださいな。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時今迄は晴朗であつた大空は、見る／＼内に西の方から曇つて來て、熱帶地方で有名な驟雨が、車軸を流すやうに降つて來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、吾等は大暴風雨の後に、晴朗な天氣を見るやうに、非常の喜びを以て大佐の家に着いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞は身心晴朗でなければならない、足もかろく気もかろくなければならない、そしておちつきがなければならない、すなほさがなければならない。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "・いつしよにくりやへとびこんだは蛙の子・ゆふざればトマト畑でトマトを味ふ・さびしうなつてトマトをもぐや澄んだ空・煙ひろがるゆふべの山はうごかない　八月廿七日晴朗、新秋清涼の気天地に満つ、身辺整理、心境平安、澄んで沈むのか、沈んで澄むのか、とにかく落ちついた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気晴朗、鳥の空に囀ずる日に、何ぞ明日のことを悩まんやという、極めて楽天的な現実思想は、古来から日本人に一貫している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀、銀、銀、銀、　天気晴朗なれども浪高し。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明くれば天氣晴朗なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気晴朗の日でも品川の海には突然颶風を吹き起すことがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡鹿半島は一望晴朗としてテーブルへ掛けた絨布の如く平らかで且つ青い海の上に低く長く連つて其先端にとがつた金華山が聳えて見える。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "天氣晴朗で波は靜かであつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "回覧板の事など、ちっとも気にしていないらしい落ちついた晴朗の態度にも感心したが、それよりも、あのいたわりの声の響きの気品に打たれた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気晴朗の日には一羽や二羽はかならず大空に舞っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気晴朗の日で、舟を呼んで渡ると、たちまちに空も水も一面に晦くなった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一度近づいて見ては、その滑かな美しい肌の下、晴朗とした黒味勝の眼の底の、温かい心を感ぜずには居られぬ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外の天気常に晴朗。",
              "citation": {
                "source": "雲の日記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "・この笛、おかしいかさみしいか、また吹く（鶯笛）・青葉あざやかな身ぬちへポリタミン・明けてくる空へ燃やす・とほく朝の郭公がなく待つものがある　シヤンがゐるので垣のかなめが赤いので　五月十六日日本晴、むしろ日本的晴朗とでもいふべきだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地晴朗、身心清澄なり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中は晴朗だつたが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が、吾々の晩年に吾々の任務を果たし、吾々の共同行為の義務を尽した後に、公平無私の芸術や、ゲエテの晴朗や、純粋の美を望むのは、善い事でもあり自然の事でもある。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其等の人々や其等の民族には、其の晴朗は、無感覚即ち死の前兆に過ぎない。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも次第に雲が晴れ渡って青空が晴朗に輝き暖気を増して来た。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫でも次第に雲が晴れ渡つて青空が晴朗に輝き暖氣を増して來た。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁村の書を講ずる声は咳嗄れているのに、竹逕は音吐晴朗で、しかも能弁であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本は黒崎の友人でこの試みに共感していた玉城重信と玉置晴朗とともに、群馬県桐生市の桐生第一養護学校を訪ね、脳性麻痺の子供たちにとってどんな道具がふさわしいのかを探りはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、「今日晴朗なれども浪高し」の号外は出ても、勝敗は容易にわからなかった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると暴風雨数日の後、たった二人だけ生き残って絶海に漂流する事又十数日、遂に或る天気晴朗な払暁に到って、遥か東の方の水平線上に美々しく艤装した大船が、旗差物を旭に輝やかしつつ南下して行くのを発見した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日天気晴朗なれども波高し、というのが日本海軍の海戦記の常套語だと聞く。",
              "citation": {
                "source": "情意の干満",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心中も、本日天気晴朗なれども波高し。",
              "citation": {
                "source": "情意の干満",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
