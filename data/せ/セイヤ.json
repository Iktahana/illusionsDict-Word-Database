    "definitions": [
      {
        "index": 1,
        "gloss": "Christmas Eve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
