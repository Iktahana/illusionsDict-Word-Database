    },
    "definitions": [
      {
        "index": 1,
        "gloss": "starry night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう説を聞いて星夜の空を仰いでみる。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて星も星夜のように白金の棘を長く煌き放っている山の夜空の不思議さ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　外は星夜で風の無い静かな晩である。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜提兵星夜到江干｜為説三韓国未安明主日懸旌節報微臣夜繹酒杯観｜春来殺気心猶壮｜此去妖氛骨已寒｜談笑敢言非勝算｜夢中常憶跨征鞍　如松、更に進み、先ず先鋒の将をして、行長陣に告げて曰く、「沈惟敬｜復来る。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は星夜に独り天を仰いでそこに神を見た。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四壁沈々、澄み徹りたる星夜の空の如く、わが心一念の翳を著けず、冴えに冴えたり。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は星夜の深い闇がいっぱいに拡がってどっかで下手な浪花節をうなって居るのが聞えて来た。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、長距離の騎行と、晴れた夏の星夜の下の露営は、彼によい結果をもたらした。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そとは星夜で、白樺や菩提樹の梢が、優しい春の若葉を夜気のなかに匂わしている。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "星夜の空の薄光り心を遠く誘ひつゝすゞしくそよぐ風のねは神のかなづる玉琴に觸れてやひゞく天の樂、昨日の夢と悲みし浮世の春は替はれども見ずやとこよの春の花散らでしぼまで大空の星のあなたにほゝゑむを。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二日（日曜）雨夕方から晴、夜は星夜になった。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "声――あの父の呼ぶ声は、斯の星夜の寒空を伝つて、丑松の耳の底に響いて来るかのやう。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に是の星夜の寂寞を破つて、父の呼ぶ声が丑松の耳の底に響いたのである。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "『星夜』というものを書いたのもあの林の中だ。",
              "citation": {
                "source": "北村透谷の短き一生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "星夜　月はないけれど、星が一杯かがやいていた。",
              "citation": {
                "source": "泥葬",
                "author": "竹内浩三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておれも遅くとも来年には、などと、夜の浜に打ち伏したまま、星夜の中に京へのなつかしいおもいをたどるのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の国と乙の国との煙火師が、星夜の空中を競技場として火焔の魔術戦をやりあうという例はこのほかにも珍しくはない。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古墳にまがう星夜の形……。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "星夜潜行　達眼は達眼を知るという。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓はすべて庭園に出され、まさに星夜の盛宴というべき光景。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌を噛んで星夜をねめつけながら呪死せんか。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉の麗しさ、耳の白さ、また、眼にふくむ愁いの悩ましいばかりなど、思いがけぬ場合ではあり、星夜の光に見るせいか、この世の人とも思えぬのであった。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "城楼の上、銀河は煙り、星夜の天は美しかった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は、独り星夜の外に出ると、長嗟して、天へ語った。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明はこれを諸軍に頒って、星夜の野営に、蛮土の涼を共に楽しみながら、また馬謖と対して、彼も一杯を酌んだ。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵、暫時棒立ちになってたが気のせいやろうと又歩き出さんとすれば、Ｔ「引ッ込めッたら　引ッ込めッ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつけしからんと他の水兵みな起ち上がって、サア出せいやなら十杯飲めと迫る。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの清水も気のせいやら、流が沢山痩せました。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うるせいや、きさま読め！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊吉はこゝにゐるけに安心せいや――あゝ、よしよし」と子供にでもいふやうにものを言つてゐたが、すぐに戻つて來て土間に下り立ち、竈の上の釜の湯につけてあつたらしい銚子をとるとふたゝび襖の向ふへかくれて行つた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
