          "literary": [
            {
              "text": "先任者ティンダルが病気でやめたその後を継いだのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後にはそうではなくて先任者が順々に後任者を推薦し選定するようになった。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて自分がその局に当ってやって見ると、かえって自分の見縊った先任者よりも烈しい過失を犯しかねないのだから、その時その場合に臨むと本来の弱点だらけの自己が遠慮なく露出されて、自然主義でどこまでも押して行かなければやりきれないのであります。",
              "citation": {
                "source": "文芸と道徳",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし1709年の冬はひどく寒かったが熱心に仕事をして1710年には先任者の誰よりも優れた植物リストを刊行した」とハラーは書いた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
