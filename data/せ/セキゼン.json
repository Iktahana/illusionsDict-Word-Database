[
  {
    "uuid": "36fdb083-7efe-5e8f-a616-36b93b477475",
    "entry": "寂然",
    "reading": {
      "primary": "せきぜん",
      "alternatives": [
        "じゃくねん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
