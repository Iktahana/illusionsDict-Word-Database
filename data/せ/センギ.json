  {
    "uuid": "9713b4c8-8a9f-5c55-9e05-0a04e95ae13e",
    "entry": "先議",
    "reading": {
      "primary": "せんぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
