          "literary": [
            {
              "text": "二人はせいぜい忠実に政務を執るぐらいの、いわば具臣とでも申すべき人物でございましょう。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍医が政務を執ることを禁じたので、老臣の合議によって藩政の処理がおこなわれることになった。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは陣頭に立って戦い、きょうは政務を執るに忙しい彼であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
