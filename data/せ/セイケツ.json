[
  {
    "uuid": "1a679e55-a79e-51da-bd8b-e1a2d27adb58",
    "entry": "清潔",
    "reading": {
      "primary": "せいけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
