        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いよいよ巨人軍と神々との戦闘が始まると双方に夥しい戦没者ができる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "体位向上徒歩奨励、幼児保健の問題、戦没者の母子寮の設立などと全く背までくっついていて離れられない双生児の歩む姿である。",
              "citation": {
                "source": "風俗の感受性",
                "author": "――現代風俗の解剖――",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の三人には、暗殺者ブラーエの手に狙撃された、ワレンシュタイン軍の戦没者の名を附けたのでした。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園の洲には官軍戦没者の墓地がある。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "賞罰のことも片づくと、彼はまた、祭壇をもうけて、戦没者の霊を弔った。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
