[
  {
    "uuid": "d9b841a6-1366-5829-927d-620437834188",
    "entry": "精神生活",
    "reading": {
      "primary": "せいしんせいかつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
