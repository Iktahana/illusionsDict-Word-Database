[
  {
    "uuid": "edc06409-5d38-528f-a8f5-7a30c633952f",
    "entry": "精勤",
    "reading": {
      "primary": "せいきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
