          "standard": [],
          "literary": [
            {
              "text": "「亜剌比亜の医師カアシッシュの不思議なる医術上の経験」といふ尺牘体には、基督教の原始に遡りて、意外の側面に信仰の光明を窺ひ、「砂漠の臨終」には神の権化を目撃せし聖｜約翰の遺言を耳にし得べし。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亜剌比亜の医師カアシッシュの不思議なる医術上の経験」といふ尺牘体には、基督教の原始に遡りて、意外の側面に信仰の光明を窺ひ、「砂漠の臨終」には神の権化を目撃せし聖約翰の遺言を耳にし得べし。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亞剌比亞の醫師カアシッシュの不思議なる醫術上の經驗」といふ尺牘體には、基督教の原始に遡りて、意外の側面に信仰の光明を窺ひ、「沙漠の臨終」には神の權化を目撃せし聖約翰の遺言を耳にし得べし。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "楷書に片仮名を交ぜた榛軒の尺牘には、宛名が抽斎賢弟としてあった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他今の清浦子が県下の小学教員となり、県庁の学務課員となるにも、優の推薦が与って力があったとかで、「矢島先生｜奎吾」と書した尺牘数通が遺っている。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五十九　庚午｜旺秋の茶山の尺牘には種々の人の名が見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち七月二十二日附の書で、亦わたくしが饗庭篁村さんに借りた一括の尺牘の中にある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年詩画騒動之詩、尺牘とも見申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詩尺牘とも」見たと、茶山は云つてゐるが、※斎詩集にはそれかと思はるる詩も見えない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "饗庭篁村さんの所蔵に菅茶山尺牘の断片がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花亭の文は竹柏園の蔵儲に係る尺牘で、九月四日の日附がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条霞亭の尺牘に拠るに、通称は弥之助である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又此年甲申八月十七日後に茶山が蘭軒に寄せた尺牘がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此系図と尺牘とに就いて、姪孫女の誰なるかを究めて見ようとおもふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞亭｜解褐の年は、わたくしは岡本花亭の尺牘に本づいて辛巳となした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "記して此に至つた時、わたくしは的矢の北条氏所蔵の霞亭尺牘一｜篋を借ることを得た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に引くべき生日後の尺牘断片に、茶山はかう云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紙上自筆の文字を見るに、茶山は未だ必ずしも尺牘を作るに人を倩はなくてはならぬ程衰へてはゐなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの推定の本づく所は、此年四月頃の茶山の尺牘の断片と、次年戊子元旦の蘭軒の詩の註とである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者尺牘断片は下に其全文を写し出して、その何故に此年四月の所作ならざるべからざるかを明にするであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是がわたくしの目睹した唯一の慊堂の尺牘である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小島成斎の九月二十二日の尺牘に拠つて言ふのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その三百十九　わたくしは日記｜尺牘等に拠つて柏軒の癸亥｜淹京中の事を叙し、四月四日に至つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は枳園｜尺牘の註脚である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めわたくしは澀江抽齋傳中の壽阿彌の事蹟を補ふに、其｜尺牘一則を以てしようとした。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "人そのものの表われは、如何なるものにも表われているであろうが、特に古人を見る場合は、墨蹟判断を一番となすことは論なきところであって、例えば秀吉を見んと欲せんか、一秀吉の尺牘で秀吉は窺われるのである。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って尺牘にも大字を書く。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その経験でいうと、良寛様とて未熟時代があって、若かりし頃の書（屏風に書かれている書の時代まで）は、別段のこともないが、後年六十歳頃にもなられてからは、俄然妙境に入り、殊に尺牘の如きは、まことにたまらないまでのものである。",
              "citation": {
                "source": "良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "春陽堂主人の請ふにまかせ、自ら断膓亭尺牘を編む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後尺牘を編纂すること前日の如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
