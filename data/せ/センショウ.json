  {
    "uuid": "9f324ee3-e9e2-5dc3-9556-bcf4f1c5a54e",
    "entry": "船檣",
    "reading": {
      "primary": "せんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船々の甲板、船々の船檣、そして船々の煙突は焔のように輝いている。",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船檣の湾内に林立せるありさまは、東洋第一の要港たるの名に背かず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "依って、船檣に青龍の牙旗をひるがえした船を見給わば、これ呉を脱走して、お味方の内へすべり込む降参船なりと知りたまえ」　と、云い送った。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
