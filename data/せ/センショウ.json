  {
    "uuid": "a6c44768-e1c0-5a7e-8699-130194b8f178",
    "entry": "選奨",
    "reading": {
      "primary": "せんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
