    },
    "definitions": [
      {
        "index": 1,
        "gloss": "recommendation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
