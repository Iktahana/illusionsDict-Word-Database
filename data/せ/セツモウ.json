        "examples": {
          "standard": [
            {
              "text": "真っ白い雪原を長時間見続けていたせいで、雪盲に近い状態になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "登山の際は、雪盲を防ぐために必ずUVカット機能のあるサングラスを着用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雪盲になると目が激しく痛み、一時的に視力が低下して行動不能に陥る危険がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "昨日強烈な紫外線の中を、眼鏡をかけずに歩いていたので雪盲にかかったのだ。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "また雪眼鏡を嫌ったため、多少雪盲の気味で、涙がしきりに出る。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
