[
  {
    "uuid": "c896ef83-5ae7-5b29-8e54-b03d23f1998c",
    "entry": "占領下",
    "reading": {
      "primary": "せんりょうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
