    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony to celebrate crossing the equator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あと五時間もすると赤道へ近づきますから、赤道祭には酒を無制限にして、大宴会をやるように命令してください。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなが酔って大騒ぎをしているうちに、私は気づかれないように少しずつ船を岸へ寄せます」　十時頃になると、赤道祭がはじまった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午頃から前日にもまして盛大に赤道祭がはじまったが、午後三時十五分、恐ろしい震動が起った。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "）三〇、船中の英王戴冠式および赤道祭　二十一日、快晴。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、朝日新聞に三回（『花と兵隊』『美しき地図』『陸軍』）、毎日新聞に二回（『海と兵隊』『赤道祭』）書き、読売新聞にははじめてであったが、この日本の三大新聞には、それぞれ顕著な特色があることを感じた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
