    "definitions": [
      {
        "index": 1,
        "gloss": "strength of a thousand men",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
