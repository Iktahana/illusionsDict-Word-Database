    },
    "definitions": [
      {
        "index": 1,
        "gloss": "legal wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "化け物もやはり人間と自然の接触から生まれた正嫡子であって、その出入する世界は一面には宗教の世界であり、また一面には科学の世界である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵も味方も共に景慕する所なるに、君には其の正嫡と生れ給ひて、先君の譽を傷けん事、口惜しくは思さずや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて秀衡その後を承けて奥州大半を虜掠したとあってみれば、曩祖頼義・義家の正嫡を承けて、すでに天下一統の形勢にある彼れ頼朝たるもの、いかんぞその臥榻の傍において、この夷人の鼾睡を容るすことが出来ようや。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "参学しきたること、すでに二千一百九十年、正嫡わづかに五十代。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時平は此の国経の弟、長良の三男に当る基経の子であるから、彼と国経とはまさしく伯父甥の関係になるのであるが、地位から云えば故太政大臣関白基経の長子であり、摂家の正嫡である時平の方が遥かに上で、すでに左大臣の顕職にある年の若い甥は、老いぼれの伯父の大納言を眼下に見｜下していたのであった。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと御正嫡たる後深草には、何の御失政もあったのではない。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇太子の冊立にあたって、正嫡だけを立ててはゆけない。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ少々、ご奇矯であろうとも、執権職の空座をめぐッて、内輪争いを見るよりは、やはり、ご正嫡をあがめておくに如くはない」　という考えなのである。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利将軍家の正嫡は、室町幕府の滅亡後、各地を転々とし、天正十八年、徳川家康の擁護で、やっと下野塩谷郡の喜連川に一万石の封土を得て落着いた。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
