      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fresh meat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此日は之れ当年第一の夏漁、頓て見る村童頻々として来往し、人々一尾を携へざるなく、家々鮮肉を味はざるなし。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "また他の学者はある種の鶚の前へカンバスで包んだ腐肉を置き、その包みの上に鮮肉の一片をのせた。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた後の例でも鮮肉を食ったために腐肉のにおいに興味がなくなったのかもしれない。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に横たわる鮮肉のような夕映の雲を凝視した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片の鮮肉を得るのさえ極めて困難であり、盛夏の候でさえ一｜封度の新鮮なバタはなかなか買えるものではない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし十銭玉一枚で、血のしたたる鮮肉が、五、六｜斤も来るというのは馬肉のほかにない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
