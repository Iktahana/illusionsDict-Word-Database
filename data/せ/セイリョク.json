[
  {
    "uuid": "6a5add98-a0b9-565d-b35c-618f2b50bc31",
    "entry": "勢力",
    "reading": {
      "primary": "せいりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
