[
  {
    "uuid": "1d1297d7-0a06-5c0b-9430-6a262021186c",
    "entry": "征夷大将軍",
    "reading": {
      "primary": "せいいたいしょうぐん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
