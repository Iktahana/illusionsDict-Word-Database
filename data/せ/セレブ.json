        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "話し声がきこえて、庭の奥から、散歩帰りのセレブリャコーフ、エレーナ、ソーニャ、テレーギンが出る。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　じつにいい、じつにいい。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　いや済まないが、お茶はわたしの書斎へ持ってきてくださらんか。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……エレーナ、セレブリャコーフ、ソーニャ、家へはいる。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幕――第二幕セレブリャコーフ家の食堂。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ、あけ放した窓の前の肘かけ椅子にかけて、まどろんでいる。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　（目がさめて）誰だ、そこにいるのは？",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　レーノチカ、お前か。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　いいや、息苦しくてならん。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）セレブリャコーフ　朝になったら、図書館でバーチュシコフの全集を捜してみておくれ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　朝になったら、バーチュシコフを捜してくれ、というんだよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　ツルゲーネフは、痛風から扁桃腺が腫れたという話だ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　さしずめお前なんか、いちばんわたしを見るのが厭な組だろうよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　お前がそう思うのも、無理はないさ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　お前の言うことを聞いていると、まるでわたしのせいでみんな病気になって、退屈して、せっかくの若い盛りを虫ばまれているのに、このわたしだけが生活を楽しんで、なに不足なく暮しているように聞えるね。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　どうせそうだよ、みんなわたしに責め殺されるのさ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　別にどうとも。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　妙な話じゃないか。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　わたしは一生涯、学問に身をささげ、書斎になじみ、講堂に親しみ、れっきとした同僚たちと交際してきたものだ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人さまにご迷惑をかけっぱなしで……セレブリャコーフ　お前さんのアーストロフなんか、わたしになんの用がある？",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　あんな唐変木とは、わたしは話もしたくないよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　なん時だね？",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　どうも息苦しい。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（水薬をわたす）セレブリャコーフ　（いらだって）ええ、それじゃない！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　（おびえたように）いや、それは困る！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　ああ、勝手に行って寝るがいい。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　（妻に）ねえ、お前。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレブリャコーフ　みんな寝られないで、へとへとなのに、わたし一人、泰平楽を並べているわけだな。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーナ　（セレブリャコーフに近寄って、やさしい声で）いかがですか、旦那さま。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（セレブリャコーフの肩に接吻する）さ、旦那さま、お寝床へ参りましょう。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
