        "examples": {
          "standard": [
            {
              "text": "国境の緊張が高まる中、国王は最強と謳われる精鋭軍を派遣する決断を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精鋭軍が城門をくぐると、その威風堂々とした姿に民衆から大歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "数で勝る敵軍を、訓練された少数の精鋭軍が奇策で打ち破った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さだめし祝電であろうと思って読んでみると、「貴様の撃沈したのは、あれはみな、わが海軍の精鋭軍船である。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん宣戦布告などのことはなく、英ソ両国の精鋭軍団は、一方的に軍事行動を起したのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
