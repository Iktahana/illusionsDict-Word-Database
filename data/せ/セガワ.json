    "definitions": [
      {
        "index": 1,
        "gloss": "back of a leatherbound book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "久保田はしばらく立って、本の背革の文字を読んでいた。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその箱の半以上を、茶褐色の背革の大きい本三冊が占めていて、跡は小さい本と雑記帳とで填まっている。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い箱から、背革に記してある金字が光を放っている。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "背革の文字をあちこち見ているところへ、奥さんが出て来られた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保田は暫く立つて、本の背革の文字を読んでゐた。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "万国地図と海図との懸かった、一方の壁へ背を向けて、背革紫檀の古風で寛濶な、肘掛椅子に腰をかけ、嘉右衛門はバラードを弾いている。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼はそれには別に耳を貸さうともしないで、ただ不思議さうに、老人の手にしてゐる聖書の背革が傷んでゐると見えて一面に膏藥のやうなものが貼つてあるのや、その老人のぶるぶる顫へてゐる手つきが何となく鷄の足に似てゐるのを眺めてゐた。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼はそれには別に耳を貸そうともしないで、ただ不思議そうに、老人の手にしていた聖書の背革が傷んでいると見えて一面に膏薬のようなものが貼ってあるのや、その老人のぶるぶる顫えている手つきが何となく鶏の足に似ているのを眺めていた。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に言った三つの書物は、背革の文字で見ると、ドイツの原書である。",
              "citation": {
                "source": "冬の王",
                "author": "ハンス・ランド　Hans Land",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色笠の読書用電燈が、帳面の白い紙面や本の背革をしんと照している。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはＳといふ外国商館のまへで、注文帳の黒の背革よりもくろい。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、時候はずれのむしざけをだしたりなんかして、まったくくいあわせがわるかった。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "『はせがわくんきらいや』という絵本に魂の奧をつかまれ、この作家の本を出したいと願った。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は廻り合せがわるく、これ迄転々と職業を変えて、この節はそれでも千住のゴム会社に勤めているが、衣川は去年から職を失って、ぶらぶらしていた。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は実直な船員を一人見つけたのであったが、――さて、今、ちょうどそれと同時に、もう一人の実直な船員の知らせがわかって来たのである。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォルトンの手紙（第一）イングランドなるサヴィル夫人にセント・ペテルスブルグで、一七××年十二月十一日　虫の知らせがわるいからとあんなに御心配くださった僕の計画も、さいさきよくすべりだした、とお聞きになったら、お喜びくださることとぞんじます。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「最近起ったこのふしぎな出来事ほど、めぐりあわせがわるくて人を苦しめたことは、たしかにどこにもありませんよ。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと食合せがわるかったのねえ。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "印東忠介は、只今、新吉原「はせがわ伏見屋」で逮捕されました。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今度は手くせがわるい児童が声をあげて泣き出しました。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
