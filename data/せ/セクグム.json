    "definitions": [
      {
        "index": 1,
        "gloss": "to bend down with a round back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
