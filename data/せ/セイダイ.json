[
  {
    "uuid": "abc25982-d40a-5ffd-87a2-8bd04dfbcd0d",
    "entry": "正大",
    "reading": {
      "primary": "せいだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
