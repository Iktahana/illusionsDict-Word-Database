          "literary": [
            {
              "text": "悠々風景　中山陵や明の孝陵や石人石獣をみたり、紅葉がなかなかきれいであった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、石柱や石獣が残っているのを見ると、以前はもっと立派だったのでしょうね。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
