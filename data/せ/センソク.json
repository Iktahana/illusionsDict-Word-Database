[
  {
    "uuid": "319aba53-a52e-5c1b-9569-23b9f6d1f478",
    "entry": "船側",
    "reading": {
      "primary": "せんそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "side of a ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに船側に添って乱れて駛りのぼる青い腹の、まるで白竜のような新鮮な波の渦巻と潮※とをつくづくと俯瞰しては、何とか歌にまとめようと苦吟もして見た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "船側は、すでに塗られた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、太古ノア巨船に乗って洪水を免るるを、何がな災を好む天魔、錐を創製して船側を穿ち水浸りとなる、船中の輩急いで汲み出せども及ばず、上帝これを救わんとて、蛇に黠智を授けたから、『聖書』に蛇のごとく慧しといったのじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "益々近づくその船を見れば、黒い煙突には○のマークが躍り、船側には黒くまぎれもない釧路丸の三文字が、鮮かにも飛沫に濡れているのだった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板上の灯火が、暗い海を船のまわりだけを、ほの明るく照らしていたが、その光の中に、突然｜海豚の群のようにきらきら光る銀色の魚雷が群をなして船側目がけてとびこんだ――と思ったら、次の瞬間、天地も裂けとぶような大爆発が船内にひびきわたり、汽船は吹きとぶような大衝動をうけた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぶらんてんか、手前は」　船側の上から一等運転士が訊いた。",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コロンブス時代の船だろ」「アメリカ大陸発見以前の遺物だ」「船側はもう苔むしている。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、さらばさらば」　と、金博士は事務長に挨拶すると、舷をまたいで、傾斜した船側の上を滑り台のように滑って、どさりと百花咲き乱れる花壇の真中に、トランク諸共尻餅をついたのであった。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほばしらは折れ、船側はくぼみ、通風筒はみにくくまがり、見るもむざんな姿であった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船側に小汽船を連結してこれを動かす。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "槲の椎骨をした、その厚い船側は、磨れて、皺よつて、濕氣と鹹氣とがしみ透つてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "船側に平行して、棒形のローラーが一本つけてあり、舷の内側に、木製の傘形のものが立っていて、その上に、カタン糸の糸巻見たいな恰好をした、直径三寸ばかりのローラーがはめてある。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_553.png、横292×縦200）入る］図‐553」のキャプション付きの図（fig55990_554.png、横269×縦200）入る］図‐554　肥後の海岸を立去る時、一人の漁夫が船側へ来た。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
