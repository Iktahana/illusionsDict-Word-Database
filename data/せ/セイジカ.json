    "definitions": [
      {
        "index": 1,
        "gloss": "politician",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり我が国では、技術家も猶多分に政治家である場合に助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の政治家たちは、たいてい家庭を捨てているようです。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつけの良い家庭を営んでいる政治家は、少いように思われます。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつけのよい家庭を維持しながら、よい仕事も出来るという政治家もあってよいと思います。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかつて私たちの敬愛の的であった田舎｜親爺の大政治家レニンも、常に後輩に対し、「勉強せよ、勉強せよ、そして勉強せよ」と教えていた筈であります。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家肌のひとで、多少、政黨にも關係があつたやうである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、今仮に詩的性情を持つ一青年があつたとして、かの成巧せる実業家、成巧せる政治家が、子供や孫、一族郎党でもゐなかつたとしたら、どんなに退屈するものであるかは、一寸理解され難いのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これも未来の立派な政治家ですな」　校長は背ろ手を組んで、同意の笑を満面に湛えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者で同時に政治家らしいペンク教授の人柄がやはり反映しているような気もした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其著者を誰とかする、即ち當時廷臣とし、軍人とし、政治家として夙に盛名あるも、未だ文筆の人としては左までに顯はれざりしラロシフコー公爵其人なりとす。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いかにも、「廷臣とし、軍人とし、政治家として夙に盛名ある」ラロシフコー公爵その人の息吹が感ぜられる尊嚴盛大の文章である。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、私は今まで一度だつて、政治家になつたことはないし、なりたかつた事もないのだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "健忘症の政治家や気まぐれな学界元老などの手に任せておくにはあまりに大切な仕事である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千年の間に二十回とか三十回といえばやはり稀有という形容詞を使っても不穏当とは云えないし、目前にのみ気を使っている政治家や実業家達が忘れていても不思議はないかもしれない。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "設立者としての政治家、出資者としての財団や実業家達が、二、三年か四、五年も研究すれば颱風の予知が完全に的確に出来るようになるものと思い込んでいるようなことがないとは云われないような気がするからである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少しく精細に云って見るならば、役人の家庭、職人の家庭、芸人の家庭、学者の家庭、新聞記者、政治家、農家、商家、其の外に貧富の差がある、智識の差がある、夫婦諸稼の家庭もある、旦那様奥様の家庭もある、女の多い家、男の多い家、斯く数えて来たらば際限がない。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時母に送った手紙に「あんなに不器用では実験家として成効しそうもない」と云ってこの政治家の余技を評している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの大政治家の能力と独創的天分とに感服すると同時に、科学的考察力の欠乏を認めた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターリングの家の来訪者名簿には、内外の一流の学者の名前の外に英国一流政治家の名前も見える。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄としての價値要素は、武將プラス政治家の綜合天才であるけれども、尊氏は武將として、それほど大した軍略家でなく、いつも大軍を擁して戰ひながら、概ね負けてばかり居るし、政治家としての手腕も、家康や秀吉に遠く及ばない。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜口雄幸がどうしたとか、若槻が何だとか、田中は陸軍大将で、おおかた元帥になろうとしていたところをやめて政治家になったとか、自分たちにとっては、実に、富士山よりも高く雲の上の上にそびえていて、浜口がどうしようが、こうしようが、三文の損得にもならないことを、熱心に喋って得々としている。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、こんなちょっとした例を見ただけでも、環境の作用だけで「人間」を一色にしようとする努力が無効なものである、という、その平凡な事実の奥底には、普通政治家・教育家・宗教家たちの考えているとはかなり違った、自然科学的な問題が伏在していることが想像されるようである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで政治家、軍人、実業家、ファシスト、マルキシスト、テロリスト、いずれもこんな不定な未来の事は問題にしていない。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国でも実業家政治家の中には人と会食するのが毎日のおもなる仕事だという人があると聞いてはいるが、三百六十五日間に四百回の宴会はどうかと思われる。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的な知識などは一つも持ち合わせなくても大政治家大法律家になれるし、大臣局長にも代議士にもなりうるという時代が到来した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれらの技術官は一国の政治の本筋に対して主動的に参与することはほとんどなくて、多くの場合には技術にうとく理解のない政治家的ないし政治屋的為政者の命令のもとに単に受動的にはたらく「機関」としての存在を享楽しているだけである、と言ってもあまりはなはだしい過言とは思われない状態である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は、若いときに一人でふらりと東京に出て来て半分政治家、半分商人のような何だか危かしいことをやって、まあ、紳商とでもいうのでしょうか、それでも、どうやら成功して、中年で牛込のこの屋敷を買い入れ、落ちつくことが出来たようです。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ世界十幾億万人の中、平気な人でないものが幾人ありましょうか、詩人、哲学者、科学者、宗教家、学者でも、政治家でも、大概は皆な平気で理窟を言ったり、悟り顔をしたり、泣いたりしているのです。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
