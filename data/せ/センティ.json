[
  {
    "uuid": "b23f712b-f638-51ed-a8b9-3bd9d1ff63ee",
    "entry": "センティ",
    "reading": {
      "primary": "センティ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "senti (one hundredth of a Tanzanian shilling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺の留守の下宿へまたセンティメンタルな手紙がきているにちがいない、早く返事をかいてやらねば可哀そうだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は同胞というセンティメンタルな封建的な感情に誘惑された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様にはまだ文学者じみたセンティメンタリズムが影を潜めてはいないのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　センティメンタリズム、リアリズム、ロマンティシズム――この三つのイズムは、その何れかを抱く人の資質によって決定せられる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう見方によって生きる人はセンティメンタリストだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "センティメンタリストの痛ましくも甘い涙は私にはない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又本能を現実のきびしさに於て受取らないで、センティメンタルに考えるところに肉慾の世界という堕落した人生観が仮想される。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "好んで愛を語る人は、頭の軟かなセンティメンタリストと取られるおそれがありはしまいか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ、完全にセンティメントが欠如してるからな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "對象の價値を認めてやらない同感はセンティメンタルな淺薄と偏狹とに墮する。",
              "citation": {
                "source": "生みの力",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋氏の其の言葉の意味は、即ち、對象の實際持つて居ないものを、持つて居て貰ひたいと思ひ、又、持つて居るやうに感ずるのがセンティメンタリズムであると云ふ意味でもあるやうだ。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして花袋氏は此のセンティメンタリズムの分子を、ドストイェフスキイが澤山持つて居ると云つて居る。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が簡單なので、其の意味ははつきり分らないが、之れを同氏のセンティメンタリズムの解釋に依つて推測して見ると、即ちドストイェフスキイは、實際人間生活の内容に含まれて居ないものを、含まれて居ると思つて觀て居るとか、又た含まれて居れば好いと云ふ風に思つて空想して居ると云ふ意味だと思はれる。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドストイェフスキイの作品には非常に純粹な人道的の精神が強く含まれて居ると普通に言はれて居るから、花袋氏はその點からドストイェフスキイをセンティメンタルだと斷じたものであらう。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをセンティメンタリズム、若しくは甘いと見るのは、この人間と云ふものを單に一方の立場からのみ見た偏した觀方であつて、一方のもう少し深い人間の本質を無視した批評であると言はねばならぬ。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋氏がセンティメンタリズムを排斥されることは著しいことだが、極力排斥すればする程、何處か花袋氏の中にセンティメンタルな、臆病な點が未だ殘つて居ることが感じられる。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋氏がセンティメンタリズムに反抗する心を忘れて了ふ程になつたら、其の時こそ初めて花袋氏の生活にも藝術にも一大飛躍の現はれる時であると思ふ。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し人間に其の本質がないのにドストイェフスキイが之れを描いて居るのなら、それは確かにセンティメンタリズムだと言へる。",
              "citation": {
                "source": "人間の本性",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、その人達と暫くの間でもその惨めな生活を共にして、その人達の苦しみを自分の苦しみとして、もし幾分でも慰められるものなら慰めたいというようなことを、センティメンタルな調子でいった。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔの個人主義的な考えの上からは、私がいつまでも、そんなよそごとを考えているのは、馬鹿馬鹿しいセンティメンタリストのすることとして軽蔑すべきことかもしれない。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、今私を捉えている深い感激は、彼のいわゆる幼稚なセンティメンタリズムは、彼の軽蔑くらいには何としても動かなかった。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はあんまりセンティメンタルに考え過ぎているのだよ。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれをＴのように単に幼稚なセンティメンタリズムとして、無雑作に軽蔑することもできないし、無視することもできないのだ。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影像の一つ一つに、私の心はセンティメンタルな沈黙を深めてゆく。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
