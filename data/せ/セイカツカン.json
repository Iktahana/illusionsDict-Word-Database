    "definitions": [
      {
        "index": 1,
        "gloss": "life cycle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "前の「我を厭ふ」の句と共に、蕪村の侘しい生活環境がよく現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の江戸時代には帰らないでも、せめて巴里かロンドン位の程度にまで、余裕のある閑散の生活環境を作りたい。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福人といふことは、室生の場合に於てはそれだけでなく、その性格と生活環境との、矛盾のない調和状態を指してるのである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）日本の気候では、ただ秋だけが快適であり、よく人間の生活環境に適している。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んな生活環境に居ても、芸術は芸術です。",
              "citation": {
                "source": "附「歌へる日まで」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人個人の人間性への自覚、道徳的・宗教的愛の実践というものが人生を浄めると考えたトルストイは、大地主であり貴族である自身の生活環境に対する批判から、農民の素朴な信仰、飾られない人間性を理想化し或る意味では美化して高く評価した。",
              "citation": {
                "source": "ジャンの物語",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方プロレタリア文学の作家は、社会情勢の推移とともに、新しい生活環境とその日常の裡にある勤労者の生活を語らんと欲して、時代の空気の影響もあり、地味な一見ありふれた自然主義リアリズムに近づいた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは左翼的な意識の有無が第一の問題とはならず、或る勤労条件、生活環境におかれた一人の人間が、自分の人間らしい心持から周囲と摩擦し、自分自身の内にある新しいものと古いものとの間の矛盾を感じ、使うものと使われる者との必然的な利害の対立を感じ、そこに人間らしい解決を求めようと努力している。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスチアーナという女の愛に失望したマリオ・ルドヴィッチ中尉が従来の生活環境と感情とから脱却するために、アフリカのリビヤへ赴きそこの守備隊に加って土民征服に出かける。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はそう言って、自身の生活環境と心持を真面目に説明した。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に晩年に押詰められた私達のこの年齢では、故郷は相当懐しいものであつていゝ筈だが、私の現在の生活環境が余りに複雑なためか、或ひは私の過去の生活が影の薄いものであつたためか、他の田舎の町を素通りするのと、気持は大差はなかつた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人のひとの性質というものも生活環境の複雑な関係によって作用されているものであるのだから、久美子さんがそういう内輪な気質であるとしても、その気質にしたがって、別に目下生活問題として職業につかねば食うに困るということはない本間家の生活状態が反映していると見られるのである。",
              "citation": {
                "source": "短い感想",
                "author": "――家族円卓会議について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださえ「力よりも寧ろ優美さにおいてまさる」文章をかくツルゲーネフが、上述のような生活環境にあって、作中に女の人物を書く場合特殊な情緒の集注をもって描いたのは自然なことである。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、現実の生活において何が彼等を斯くもはなれ難く結びつけたかといえば、それはツルゲーネフやクロポトキンが文学的には書く価値のないものと考えた、日常の仕事を中心とする生活環境そのものではなかったろうか。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本のステッキというものに就いて或は赤皮の靴というものに対して、もと私がそこに感じたのは、せいぜい趣味としてそこに現れているそれ等のものの持主の生活環境への想像に止っていたが、今はそうではない。",
              "citation": {
                "source": "問に答えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイが彼の貴族地主としての生活環境の中で、結婚と家庭生活の実体を厳しく省察したとき、人道主義的な立場からそれを懐疑したのは当然であった。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新帰朝者という人は、こういう若い女性のいじらしい大努力に立つ計画性にはふれていない生活環境にいるのでしょう。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品は、作者が年若い少女であったことと、その少女の生活環境にあわして社会的に積極的な取材であったこと、単純だが濁りのない人間感動などによって、その時代の文学に一つの話題となった。",
              "citation": {
                "source": "作者の言葉（『貧しき人々の群』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三という年ごろも、女の生涯からみれば、何かそこに配偶の年や生活環境ということからもかかわって来る様々の変化が予想されないものでもないのかもしれない。",
              "citation": {
                "source": "小鈴",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の生理をいう場合、それがはっきり犬の生理とちがう点は、犬の一生にはない人間の社会生活環境から来る生理的影響がとりあげられなければならないことである。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合そういう心理が文学的にどういう反応を示すかというと、やっぱり文学というものは闘争を描き、同じような生活環境を描いている労働の文学よりも何かもっと違ったところに文学の本質はあるのじゃないかと、逆にブルジョア文学の雰囲気的なものにひきつけられる気持にもなってゆきがちです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "限られた生活環境で、これらの人々の受動的にならざるを得ない読者の性質ということをまじめに考えさせられる。",
              "citation": {
                "source": "病菌とたたかう人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藪の鶯」は当時二十一歳であった彼女の生活環境である上流官吏の家庭・社交の雰囲気を、まざまざと反映している。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中里恒子は、彼女の特殊な生活環境によって、日本の上流家庭の妻となり、母となっている外国婦人の生活をしばしば題材として来ている。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの作品には、彼女の生活環境と彼女自身のうちにある根深い封建的なものが、反抗と解放への激情と絡みあって、生のまま烈しく噴出している。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "引続いて「人々の中」、「主人」、「私の大学」等に描かれている二十歳前後までの若いゴーリキイの生活環境の中で――ヴォルガ通いの蒸汽船の皿洗い小僧、製図見習小僧、波止場人足、そして一種の浮浪者であったゴーリキイに写真を撮ってやろうという程彼を愛する者はおそらく一人もなかったであろう。",
              "citation": {
                "source": "マクシム・ゴーリキイによって描かれた婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この生活環境の特徴的な事情は、十三歳頃のゴーリキイの成育の中に微妙な反映を与えている。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田正子というひとは、丁度この前後の潮流との関係もあって、広い社会へ押し出されたのであったが、それが従来の所謂文学とはちがったものであることをつよく印象づける条件として、彼女の場合にもその生活環境の条件が特に正面に押し立てられたのであった。",
              "citation": {
                "source": "若い婦人の著書二つ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者の生活環境は、孤立していて、政治にも実業にも、文化一般の活動にさえも参加しなかった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
