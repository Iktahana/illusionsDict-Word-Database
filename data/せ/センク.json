[
  {
    "uuid": "522175a3-9f74-5cf7-a6ee-183fca4f40e1",
    "entry": "先駆",
    "reading": {
      "primary": "せんく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
