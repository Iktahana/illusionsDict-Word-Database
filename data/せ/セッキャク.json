[
  {
    "uuid": "7a573125-1636-54c9-aaca-b84205a79762",
    "entry": "接客",
    "reading": {
      "primary": "せっきゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "serving customers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを、帰って来た時に渡して呉れるのですが、あちらでは、約束をして置かないで人を訪問するのは、留守へ出掛けるものと定めて置いてよい位、誰でも、接客日でない日には、のらくら家で時間を潰してはいないものです。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を新しく飾ったり、椅子の置き場所を代えたり、一つ部屋もなるたけ目先を変え心持よくして、午後からは接客をします。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛嬢の競争者の夫人を喜ばないのであるが、宮の思召しをはばかって、当夜は子息たちを何人も送り、接客の用を果たさせもした。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い、ときどき訪問すると約束をした言葉があるので、彼女の接客日ときまっている木曜日に、勇気をふるって出かけて行った。",
              "citation": {
                "source": "ふみたば",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "病中は接客の煩もなく、何等清閑を妨げるものもないから、羈旅以上に読書に耽けることが出来る。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夕接客に忙殺され、交際に日も亦足らぬ繁劇の人が静かに読書に親しみ得るは此境が最も適してゐる。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            },
            {
              "text": "接客　父祖数代江戸生れで、本当の江戸児――東京児――だということを誇りにしてる、老婦人がある。",
              "citation": {
                "source": "条件反射",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり一日が、接客の為に忙殺される。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに感謝すべきことは、船長遠藤友吉、機関長鈴木豐馬、事務長吉田信夫諸君、その他船員達の接客法が一層誰れにも快適の感を与へたことであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫し了ると幾度でも小孩が茶を注ぐのは寺院のみならず、支那一般の接客法である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の宴会の接客法だと云つて、二夫人自らの箸で屡料理を私の皿に載せられもした。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那店員の接客術の上手な事は日本人の及ばない所がある。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らには接客用の卓が置かれてあった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他子規氏の名の高くなると共に、漢詩家や、書家やその他の文芸家が時々出入する、居士は一々歓迎して意見を闘すという風なので、下女も遣わぬ母刀自と妹さんは、看病の外これらの接客の用向きだけでも昼夜多忙であったのだ。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、かりに私とみよ子との間が、お酌と接客との間のようなものだったと仮定しても、あなたのその評価は全然あべこべだったろう。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "オコウちやん狙ひの客は姿を消したけれども、お酒さへ安く飲めりやいゝんだといふ新客が次第にふへて今では昔日の隆盛をとりもどしたから、コックにバーテンに接客サービス、天来の敏腕家も手が廻りかねる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てフランスの詩人ジャン・コクトオが、接客の儀礼を鮮やかに身につけた日本婦人の多くをみてこれを「奉仕の女王」と呼んだ。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫が考えているような通念からみれば、接客業というものは最低以下の職業ですが女房をそういう最低以下の地位に落して稼がせるぐらいなら、男の職業がない筈はありませんよ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その四　人形の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　接客業の女というものは、交際なれているように思われがちだが、実際はアベコベである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "接客のサービスとか、仕入れだとか、デパートに教えられる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "気まりが悪かったが、あたりを見廻してからのれんをくぐって入ると、よい鴨でも舞い込んだと思ったのであろう、しどけないなりをした接客婦がゾロゾロ出て来たのには大いに面食らった。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "風紀風俗を最も端的に表現している接客商売と、警察行政との深い相互作用は、広く知られている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段は社会的に弱い地位におかれた個人や所謂弱い商売（接客業其他）に強く当っている警察が今度は同じことをやる暴力団と正反対の立場に廻ったのだから、之は何と云っても推賞しなければならぬ企てなのだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の場合に見受けられるように、興行は一般接客業と同様に当局に対して阿諛的であり、支配社会に向かって事大的なものであるのが通り相場であるが、そこからこの種の職業組合がおのずから当局肝煎りの官許組織となり、検閲の合理化のための機関ともなるのである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさにその朝、我らが自負の根元たる｜長い部屋が最後の仕上げを施され、至高の接客をするにふさわしい面目を備えたのも否めない事実であった。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真向いの家はさすが欧州人の家だけあって寝室、書室、接客室などもあってなかなか立派な家で、多くの下僕があちこちと忙しそうに働いて居りました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は階下の接客室へずっと入って行きましたが、日本語を長く使わなかったものですからちょっとうまく出ない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "楼上の接客室で逢いましたが、その容貌は温厚｜篤実でその中に威儀｜凜然として侵すべからざる一種の徳を備え英語もなかなかよく出来る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "登り詰めた道の正面に内殿の接客室がある。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々二人はこの接客室に案内されました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
