[
  {
    "uuid": "14760f93-224e-5143-8103-573551574699",
    "entry": "攻め",
    "reading": {
      "primary": "せめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
