      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "attack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向こうところに敵なくして剣の力で信仰と権勢を植え付けて行った半生の歴史はそれほど私の頭に今残っていないが、全盛の頂上から一時に墜落してロシアに逃げ延び、再びわずかな烏合の衆を引き連れてノルウェーへ攻め込むあたりからがなんとなく心にしみている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヨツとした動機から彼は石垣島征服を思ひ立ち、直ちに大兵を率ゐて石垣島を攻めたのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジリジリ石垣島を攻めたてた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらまた目の前の母が、悔悟の念に攻められ、自ら大罪を犯したと信じて嘆いている愍然さを見ると、僕はどうしても今は民子を泣いては居られない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが下駄を片手にぶらさげて跣足で田の畦を逃げ廻るのを、村のアマゾン達が巧妙な戦陣を張ってあらゆる遁げ路を遮断しながらだんだんに十六むさしの罫線のような畦を伝って攻め寄せて行った。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな妨害に抗しても、天津、北京へ、攻めのぼらずには置かない意気を示した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの部隊が各々、西北角や、泰安門や、新建門を占領して行くに従って、柿本の部隊の幹部は、やっきになって自分の持場を攻めあせった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　村に攻めこんだ歩兵は、引き上げると、今度は村を包囲することを命じられた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "与一の弟の与二は大将として淀の城を攻めさせられた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きるとから夜おそくまで入れ代わり立ち代わり人に攻められた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三円借せ、五円借せ、母はそろそろ自分を攻め初めた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙に取すました調子で看護婦や妹の友達などが出入する室で色々と世話を燒くのだらう、始終良心に攻められて居る樣な顏をして實際も多少は攻められながら萬人の行く大道を利口に先走りする典型だなと相島は益すと、はツと夢が覺めた樣になつて相島はふツと氣息を天井に吹いた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末はそれでもその後少しも腹痛を覚えずにしまつたが、力三はどつと寝ついて猛烈な下痢に攻めさいなまれた挙句、骨と皮ばかりになつて、九月の六日には他愛なく死んでしまつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、宗教的な罪障感なぞに攻められ、時々身も世もあられず悔いて居る。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下藤吉郎の昔から秀吉は、数知れぬ難攻不落の城々を攻めた経験の持主であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は天才の直覚力をもって、この欠点を感じ取り、そこへ手を入れるので、嘗て攻め落されないあるいは和睦を申込まない城とてはありませんでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上つい、うかうかと維摩の話をしてしまいましたが、肝心の話は私たちがもし病苦に攻められたとき、どう自分で慰めたらいいかという問題であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少くとも仏教においては、出発の最初が科学的、文化知識的の結晶として、当時かなり発達していた印度の諸学派を、理攻めにして攻め降し、かくして仏教の存在隆盛を確かめて来た科学と哲学を基礎とする宗教ですから、いつの時代でも、真の仏教はこの出発精神に背きません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥に攻められる人間は、冷たい死を寝床のようにも慕うものであることを知ったか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔の牙に噛み攻められ、殆ど自己の信任を失して仕舞うほどの心を引立てて、面を焦さんばかりの罪にまともに向き合って、その中より生命の浄化の秘密を探り出す般若の行道、これこそもっともお前に相応したものである。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）斯くしてやう／＼馬を得たれば、無事に伊豆まで乘りつけて、おなじ月の十七日には八牧の屋形を攻めほろぼし、源氏再興の基をひらく。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治元年の七月、越後の長岡城が西軍のために攻め落された時、根津も江戸を脱走して城方に加わっていた。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人も此の石攻めに逢っては堪らぬ、市郎も実に途方に暮れた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内に石碑があつて、慶長五年｜関ヶ｜原役の時に、山内一豊がこゝに茶亭を築いて、東海道を攻め上つて来た徳川家康を饗した古跡であるといふことが彫刻されてゐる。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとからサアが刀を抜いて、攻めて来る敵を片っぱしから刀も鎧も一打に切って切って切りまくりましたので、敵は大敗けに敗けて逃げてしまいました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、せめて木村夫婦の所を訪ねようといふ気もあるのだが、まだ訪ねない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝえ、私がせめてもの気晴らしに、嫌な湯槽の中をさへ慕つて来たから思ふことなのであらう。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、窓ぐらいにしてもらいたい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりかまえて、一日一日を、せめて悔いなく送りたまえ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
