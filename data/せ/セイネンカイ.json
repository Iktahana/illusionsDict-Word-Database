    "definitions": [
      {
        "index": 1,
        "gloss": "young persons' association",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "消防組の赤い半纒を着た人たちや、青年会の連中が邸内のあちこちに眠そうな手で蚊を叩いていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年は村々に青年会などという文化的なものがあるからおそらく昔のような事は見られまい。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長や、区長や、校長先生や巡査が青年会場に集まって、いろいろに首をひねったけれども、第一、居なくなった原因からしてわからなかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、娘の親たちへ知らせなければなるまい……というので、とりあえず青年会員が二人、娘のうちへ自転車を乗りつけると、晴れ着をホコリダラケにしたその娘が、おやじに引き据えられて、泣きながら打たれている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから夜通しがかりで青年会をやり直します。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局　鎮守の森の入口に、村の共同浴場と、青年会の道場が並んで建っていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その年も押しつまったある夜、紙芝居をすませて帰ってきますと、今里の青年会館の前に禁酒宣伝の演説会の立看板が立っていたので、どんなことを喋るのか、喋り方を見てやろうと思いながら、はいって聴きました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹羽さんが青年会において『基督教青年』という雑誌を出した。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどここにも学校が建った、ここにも教会が建った、ここにも青年会館が建った、ドウして建ったろうといってだんだん読んでみますと、この人はアメリカへ行って金をもらってきて建てた、あるいはこの人はこういう運動をして建てたということがある。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私は剣舞が好きで、それを青年会や同窓会でよくやりますが、不思議なことには、私が不断借りてつかつてゐる刀、それは言ひ伝へでは、何でも其昔、虎之助さんが先生から譲つて頂いたとか、貰つたとか申すものださうで、真か偽か知りませんが、息子の秀雄さんがさう申しました。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その刀――手紙をよこした青年が、虎之助君の子息から借りて、青年会の席上などで剣舞をやるといふ刀、それは確か関兼英の銘のある刀である。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、村役場員、駐在所員、区長、消防｜頭、青年会長、同幹事といったような、村でも八釜しい老若が一ダースばかり下座に頑張って、所狭しと並んだ田舎料理を盛んにパク付いては、氏神様から借りて来た五合、一升、一升五合入の三組の大盃を廻わしている。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その玄関に打ち違えた国旗と青年会旗の下に、男とも女とも附かぬ奇妙な恰好の人間が、両手を支いて土下座している。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の在郷軍人団と青年会の有志で初めて組織された野楽隊なのである。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "村で、たつた一人だけ、東京の大学を出たといふ理由で、隣りのＮ村では青年会の団長などを務め、いろ／＼と威張つてゐる作次の一族が、その候補者にならうといふ運動があつたが、はじめからそれには納屋の連中がをさまらぬのであつた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川氏の雄弁６・13（夕）　亡くなつた足立｜通衛氏の告別式が大阪青年会館で行はれた時、弔演説をした宮川｜経輝氏は、霊魂の一手販売人のやうな口風で、名代の雄弁を揮つて、警察が干渉でもしなければ一日でも喋舌り続けようとする意気込を見せた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頃教会の方で捨吉と一緒に青年会なぞを起して騒いだ連中が何となく青年の紳士らしい靴音をポクポクとさせて遣って来るのにも行き逢った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時分のことを思うと青年会だ親睦会だ降誕祭だと言って半分夢中で騒いだ捨吉の心は何処へか行って了った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明治四十一年二月東京青年会館において述――",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中のゲーテとシルレルとの二人の作を全部取寄せるように、青年会館の前の三才社に注文してくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、四月三日の夜、神田の青年会館に文化学会主催の言論圧迫問責演説会というのがあって、そこへ僕らが例の弥次りに行った事を書いた記事だ。",
              "citation": {
                "source": "新秩序の創造",
                "author": "――評論の評論",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えて四月に至り、第二回講演会を本郷区仏教青年会館に開催したが、長谷川の開会の辞半ばにして突如臨監の警官から解散を命じられたことは吾々主催者として最も意外とするところであった。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ふるさとちかい空から煤ふる（再録）　　　　□　この土のすゞしい風にうつりきて（小郡）小郡へ着いたのが七時前、樹明居へは遠慮して安宿に泊る、呂竹さんに頼んで樹明兄に私の来訪を知らせて貰ふ、樹明兄さつそ来て下さる、いつしよに冬村居の青年会へ行く、雑談しばらく、それからとう／＼樹明居の厄介になつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九月二日）百十四○日本青年会のことについて何か意見はないかといふ話であつたが、余の意見として発表するほどの特別な意見は持たぬ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせよ一つの団体がある以上は何か事業でも起さねば甚だ薄弱な会合になつてしまふやうな傾きはあるが、しかし日本青年会は事業的の団結でないのであるからどこまでも精神的団結でやつてもらひたいのである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな雑誌を出してその地方へ往た時に会員を尋ねて話する位の交際をしてそれだけで日本青年会の値打は十分にあると思ふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は日本青年会のどこまでも実着に真面目にあることを願ふばかりである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜、美土代町の青年会館に「社会思想講演会」の開かれることを。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
