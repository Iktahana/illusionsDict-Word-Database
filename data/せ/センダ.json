    "definitions": [
      {
        "index": 1,
        "gloss": "hydroplane (submarines)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「深度三十メートル」　潜舵手が明瞭な声で報告しました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついせんだって僕は太宰治という男に逢ったよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、せんだつて私のところから借りて行つたシメノンの探偵小説を風呂敷から出して、「うまいですね。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐よりも、ずっと背が高いのにせんだんの気の小さいポチポチ花。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「エーと仰せられましても、エーでごわせんだ。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人に聞いてみると、せんだって四つ目垣の朽ちたのを取り換えたとき、植木屋だか、その助手だかが無造作に根こそぎ引きむしってしまったらしい。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんだんの花のこぼれる南国の真夏の炎天の下を、こうした、当時の人の目にはスマートな姿でゆっくり練り歩きながら、声をテノルに張り上げて歌う文句はおおよそ次のようなものであった、「エーエ、ホンケーワーア、サンシューノーオー、コトヒーラーアヨ。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして河畔に茂った「せんだん」の花がほろほろこぼれているような夏の日盛りの場面がその背景となっているのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　九官鳥の口まね　せんだって三越の展覧会でいろいろの人語をあやつる九官鳥の一例を観察する機会を得た。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話はちがうが、せんだって日比谷で「花壇展覧会」というものがあった。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、せんだって上映されたシャリアピンの「ドン・キホーテ」はそういう意味ではむしろ不純なものであったかと思う。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画や、それからたとえばせんだっての「人生の設計」なども、この大きな問題を考究するときの資料になるべきものであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　実写映画に関する希望　せんだって「北進日本」という実写映画を見た。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついせんだってのあのベーブ・ルースの異常な人気でも、ことによると彼の特異な人相に負うところが大きいのかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年日本の紅がインドへ輸出されるのでどうしたわけかと思って調べてみると婦人の額に塗るためだそうだという話をせんだって友人から聞いていたが、実例をまのあたりに見るのははじめてである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またついせんだっても、僕がこんなに放蕩をやめないのもつまりは僕の身体がまだ放蕩に堪え得るからであろう。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついせんだっても、この町の病院に勤めている一医師から電話が掛って来て、今晩粗飯を呈したいから遊びに来いとの事であった。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんだんのえだひかるんだ。",
              "citation": {
                "source": "ひかる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食いながら女中の話を聞くと、せんだってなんとかいう博士がこの公園を見に来て、これはたいへんにいい所だからこの形勝を保存しなければいけないという事になり、さらに裏手の丘までも公園の地域を拡張する事になった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎寺のお小僧さんで、やっぱり朝稽古に通う、おなじ年頃の仲よしの友だちが来かかって、抱起したので助って、胸を痛めもしませんだが、もう一息で、睡りながら川へ流れます処。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……サ……ここから出せ……出してくれ……この檻の中から……そうして一緒に研究を完成しようじゃないか……ね……ね……後生だから……」　私は思わず熱い涙に咽せんだ。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、お待たせして申しわけごぜえませんだ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばちがあたるならこの足がいたむだらうに、ちくりともしませんだ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まことに申しわけありませんだ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午になつて腹の空かねェちふものは、牛だつて人間だつてありませんだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが坊さん、ああして難儀させにや、子供は一人前になれませんだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「可笑しいにも何にも、わしは偉い人がどんなもんか、よく知りませんだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達にや、とてもそんな諦めのよいことは、出来ませんだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんだってお嫂さんが、兄さんに、「綺麗なひとの絵姿を私の部屋の壁に張って置いて下さいまし。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついせんだつて僕は太宰治といふ男に逢つたよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
