    "definitions": [
      {
        "index": 1,
        "gloss": "seasonal court banquet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宮中の節会の日なんぞ、急いで家を出る時は歌も何もあったものではありません。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "元三日が過ぎてまた今年は男踏歌であちらこちらと若い公達が歌舞をしてまわる騒ぎの中でも、寂しい常陸の宮を思いやっていた源氏は、七日の白馬の節会が済んでから、お常御殿を下がって、桐壺で泊まるふうを見せながら夜がふけてから末摘花の所へ来た。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬の節会であったから、これだけはこの宮へも引かれて来て、女房たちが見物したのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬節会の白馬を青馬と訓ますを古く不審しく思うた人少なからぬと見え、平兼盛が「ふる雪に色もかはらて曳くものを、たれ青馬と名け初けん」と詠んだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその雪や白粉も、光線の工合で青く見えるから白を青と混じ呼んだらしい（「白馬節会について」参照）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に節会をその花下に開き、青年男女をして誦歌相｜誘わしむ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "所の者どもたびたび像内へ草木が生え込むを抜き浄め、以前はその時｜節会を設け種々の競戯し、近隣のみかは、英国中より勇士来集して土地の勇士と芸競べせしも、何となくやんでいまだ六十年にならぬ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "というは、昔英国の五月節会に大流行だったモリス踊のホッビー・ホールスとて頭と尾は木造で彩色し、胴は組み合せで騎手の腰に合せ、下に布を垂れてその脚を覆す造馬がそれによく似居る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピュリタン徒繁昌の際五月節会とともに禁止され、王政恢復後また行われたがいつとなく廃れおわる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（付）白馬節会について　白馬を貴ぶ例諸邦に多し。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日と馬の数こそ和漢の白馬節会と異なれ、その事甚だこれに近し。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、越前の佐伯氏長が、その国の選手として相撲の節会に召されることになった。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、自分は越前の者であるが、今度相撲の節会で召されて参るものである」というと、女はうなずいて「それは危いことである。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "左馬寮、右馬寮の馬が前庭に並べられ、左近衛、右近衛の武官がそれに添って列立した形は五月の節会の作法によく似ていた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二月十八日）謝肉祭　待ち焦れて居た二月｜二十日の謝肉祭、その前後｜五日に亘つて面白かつた巴里の無礼講の節会も済んで仕舞つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃は女の服装が一変するから色彩の点からも華やかな節会であらう。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の幕は※ルサイユの宮廷の大節会で仮装した幾多の諸侯と貴婦人が華麗な園内の其処彼処に舞踏の団を作つて遊び狂つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣にある昔の市長の住んだドガアルの宮殿はモネが此春｜描いた絵で見知つて居たが、僕の着いた当日は何かの節会で縦覧させない。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドリヤ海は春の様に霞んで碇泊してる大小の汽船は節会の為に満艦飾をして居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "士官は中世から今迄引続いてる海軍造船所へ伴れて行つて節会に関らず縦覧させて呉れた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また許したまへ、此処にあるそこばくの歌を、節会の日に喜び狂ふ学生等の如く、君があたりに捧ぐることを。",
              "citation": {
                "source": "失楽",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……榾を焚く田舎の囲炉裏……都会のサロンの煖炉……おお家庭の季節、夜会の季節会話の、読書の、音楽の、劇の、踊の、愛の、鑑賞の、哲学の季節、乳呑児のために罎の牛乳の腐らぬ季節、小さいセエヴルの杯で夜会服の貴女も飲むリキユルの季節。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲の節会には、雅楽が附きものであつた。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬の節会に、犯人を作つて梅の白枝で打擲すると言ふ例があるが、北陣で検非違使が雑犯を裁断する式も、白馬節会のつきものです。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の相撲の節会が、初秋の行事だつたからである。",
              "citation": {
                "source": "草相撲の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷では、早くに、すべての行事が整頓せられて、相撲節会なども出来たのであるが、これは、村々の行事がとり入れられたと見るよりも、宮廷も、もとは一箇の邑国であつたので、その当時から行はれて居たと見る方がよいと思ふ。",
              "citation": {
                "source": "草相撲の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中古以後、相撲の節会に、左方の力士は葵花、右方の力士は瓠花を頭へ挿して出たが、瓠は水に縁のあるものだつたので、水の神の所属の標らしく、葵は、それに対立する神の一類を示したのだと思はれる。",
              "citation": {
                "source": "草相撲の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も、土俵入りなどゝいふ事が行はれるが、宮廷の相撲の節会にも、舞ひが伴うて居る。",
              "citation": {
                "source": "草相撲の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初春「青陽の節会」に象つたもの、新年の祝賀能である。",
              "citation": {
                "source": "鶴が音",
                "author": "――鶴亀の芸能――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
