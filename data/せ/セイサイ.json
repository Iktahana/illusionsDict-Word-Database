[
  {
    "uuid": "63e126c5-4940-553d-ae07-ffd086c84410",
    "entry": "制裁",
    "reading": {
      "primary": "せいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
