  {
    "uuid": "12e03dca-3e87-5334-83fa-e8726fe763d5",
    "entry": "聖別",
    "reading": {
      "primary": "せいべつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
