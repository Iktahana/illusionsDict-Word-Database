    "definitions": [
      {
        "index": 1,
        "gloss": "beater (on a hunt)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
