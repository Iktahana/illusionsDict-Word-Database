[
  {
    "uuid": "4b7f374d-f258-536a-8fa2-aba570e19a82",
    "entry": "成人",
    "reading": {
      "primary": "せいじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
