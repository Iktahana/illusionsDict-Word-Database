  {
    "uuid": "ab72bcdd-c5c9-54e7-af03-7fc509e6551d",
    "entry": "石剣",
    "reading": {
      "primary": "せっけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sword-shaped stoneware found in archeological sites in eastern Japan dating to the end of the Jomon period",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "石神井明神の神体たる石剣の如きもその一なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "では何を使うかと言えば、――わたしはブラッシュを動かしながら、時々どこかの博物館にあった石棒や石剣を思い出したりした。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に向かって曲がった両の角は、あくまで鋭く馬琴が形容した通り、烏犀か石剣というほどである。",
              "citation": {
                "source": "越後の闘牛",
