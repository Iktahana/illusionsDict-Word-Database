[
  {
    "uuid": "a0545f4e-c818-575e-9321-db30ee34e335",
    "entry": "先哲",
    "reading": {
      "primary": "せんてつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ancient wise men",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晝は終日兵術を修し、夜は燈下に先哲を師として、治亂興廢の理を講ずるなど、頗る古の賢主の風あり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲いはく……君子はあやふきに近よらず、いや頬杖で讀むに限る。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲｜曰く、知る者は言わず、言う者は知らずと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲曰く、時は黄金である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時ぞやも、自分等の所謂先哲の遺訓なるものの内容が、どれだけ空虚になつてるかも稽へず「べからず」十五箇條を作つて天下の女學生を救はうと企てた殊勝な老人達があつた。",
              "citation": {
                "source": "文藝中毒",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ただ先哲、孫呉空は、※螟虫と変じて、夫人の腹中に飛び込んで、痛快にその臓腑を抉るのである。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局荘子は先哲のどの道にも就かず、己れの道を模索し始めた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "實ニ貴族ノ土地徴集ヲ決行スルニ、大西郷ガ異議ヲ唱フル諸藩アラバ一擧討伐スベキ準備ヲナシタル先哲ノ深慮ニ學ブベシトスル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マルクス」ト「クロポトキン」トハ未開ナル前世紀時代ノ先哲トシテ尊重スレバ可。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等ハ舊時代ニ生レ其ノ見ル所歐米ノ小天地ニ限ラレタルノミナラズ、淺薄極マル哲學ニ立脚シタルガ故ニ、躍進セル現代日本ヨリ視ル時單ニ分科的價値ヲ有スル一二先哲ニ過ギザルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に科学者は扠ておき哲学者といふ奴は多くは先哲の蓄音器である。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は日蓮聖人を人格者・先哲として尊敬しても、霊格として信仰することは断然止むべきだと考えたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同時に先哲の想像力の使い方を学び、あわせて探偵小説を読むを怠らないのである。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二宮尊徳に似た手段は先哲叢談続編に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲叢談續編に「先生後獲罪、謫在越之高田、（中略）無幾王室中興、先生嘗得列官于朝」と書してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "】　分署長ははなはだ冷淡にコワリョーフを迎えると、食事の後で審理をするのは適当でないとか、腹を満たしたら、すこし休息するのが自然の掟だ（こう言われて八等官は、この分署長は先哲の残した箴言になかなか詳しいんだなと見てとった。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつまた、後来この挙に傚い、ますますその結構を大にし、ますますその会社を盛んにし、もって後来の吾曹をみること、なお吾曹の先哲を慕うが如きを得ば、あにまた一大快事ならずや。",
              "citation": {
                "source": "慶応義塾の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはいわく、倫理教科書は道徳の新主義をつくりたるに非ず、東西先哲の論旨を述べてその要を示したるまでのものなれば、その何人の手になり、また何の辺より出でたる云々の詮索は、無益の論なりとの説もあらんなれども、鄙見をもってすれば決して然らず。",
              "citation": {
                "source": "読倫理教科書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東観漢紀」を示すのではないかと言ふ疑ひは、先哲以来宿題である。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は火災保険生命保険の必要を論述せんとして曲亭馬琴の夢想兵衛を引き、日本に於ける金銀価格の歴史を論ぜんとして先哲叢談に朱舜水が日本金価廉也、中国百倍之といへるを引けり。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故わたくしは先哲の異例に倣うとは言わない。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元に有朋堂文庫本の『先哲叢談』が投げ出されてあった。",
              "citation": {
                "source": "梅雨晴",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲諸家の手写した抄本の中には容易に得がたいものもあったとやら。",
              "citation": {
                "source": "梅雨晴",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸先哲の嘉言善行にして世に伝えらるるものは既に鮮くない。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝は原念斎の『先哲叢談』に審である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "国ノ先哲ニ子平ソノ人アリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は優越感によつて生きてゐない――俺は此事を社會の前に、先哲の前に、自分の前に、公言することを憚らない。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲の書、父や恩師の教えを、俺はいったいどこへきいて来たのだ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからしばらく「雲遊萍寄」して、ここに先哲の風をまねようと思う。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国情、民俗に適するように同化改造することはあり、日本の社会を基礎として適当の意見をも出し、実際に役立つような形のものにはなっているけれども、ここに実際社会上の適用に長じていることはうかがわれるが、純哲学上の学説の樹立に至りては支那の諸先哲に一籌を輸したものであった。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
