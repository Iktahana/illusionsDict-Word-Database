        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、みんなは、「よいしょ。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "断頭台に、のぼるか、よいしょ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐口は晩酌の最中で、うるさいと思ったが、いやにしつこく挑んで来るので着物を脱いで庭先に飛び降り、突きかかって来る才兵衛の巨躯を右に泳がせ左に泳がせ、自由自在にあやつれば、才兵衛次第に目まいがして来て庭の松の木を鰐口と思い込み、よいしょと抱きつき、いきせき切って、この野郎と叫んで、苦も無く引き抜いた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を持ち上げるとき、よいしょ、と掛声して、はっと思った。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いままで、自分が、よいしょなんて、げびた言葉を言い出す女だとは、思ってなかった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいしょ、なんて、お婆さんの掛声みたいで、いやらしい。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を持ち上げるとき、よいしょ、と言ったり、お掃除しながら、唐人お吉を唄うようでは、自分も、もう、だめかと思う。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいしょ、と小さい声で言ってみて、路のまんなかの水たまりを飛び越す。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいしょと、水たまりを飛び越して、ほっとする。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、来た、それ、よいしょ」　髪の乱れた色の青い女が曳き出された。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから文吉が「したこらよいしょ」と掛声して、土手の土に棒を打ち下ろす振りをすると、「ほい、ほい」と合の手を入れます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横綱はじめ力士一同人力車で挨拶まわりをすることになったが、横綱ひとり大き過ぎて合乗用の俥にも乗れず、といって俥なしの挨拶まわりも淋しいと考えた挙句、横綱の腰に太い紐をまわし、その紐を人力車二台にひかせて、横綱自身よいしょよいしょと練り歩いて、恰好をつけ、大阪じゅうを驚かせた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よいしょウ、よいしょウ」「おもいぞ、おもいぞ」「いそぐな、いそぐな」「急いでもわれんぞ、急ぐな急ぐな」「居るぞう、居るぞう」「怕いぞ、怕いぞ」　権兵衛の伴れている下僚は武市総之丞と云う男であった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏、角力の巡業があり、横綱はじめ力士一同人力車で挨拶まわりをしたが、横綱ひとり大き過ぎて合乗用の俥にも乗れず、といって俥なしの挨拶まわりも淋しいと考えた挙句、横綱の腰に太い紐をまわし、その紐を人力車二台でひいて、よいしょよいしょとひき廻して練り歩き、大阪じゅうを驚かせた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小太郎と、深雪と、庄吉と、四人で、話をしていた南玉が「よいしょ、只今」　と、立上って、入口の格子戸の外に立っている大家へ「急ぎか。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よいしょ」「こらっ」　二人は、足を踏ん張り、土を掴み、歯を食いしばって、押出していた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お風呂のお仕度が出来ました」　障子の外からお梅が声をかけたので、慶太郎は「よいしょっ」と起きなおって部屋を出て行った。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を添えて抜きだして、よいしょ、よいしょと力づけ次の足を前に出す。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よいしょ」　玉太郎が気合をかけた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よいしょ」　みんなが、それに和した。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よいしょ、よいしょ」　疲れもどこかに吹きとばせとばかり、四人は力をいれた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイッチ入れろ」「よいしょッ」　と、ぐぐぐぐッと地鳴りのような響がして、けたたましく警鈴が鳴りだした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、よいしょ」「よいしょ、おやァ……」「よいしょ、よいしょ」　意外にも、箱自動車は動き出して、穴の斜面をゆらゆらとゆれながら上へ押しあげられて行った。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
