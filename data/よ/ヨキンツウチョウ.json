        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五挺のピストルと、八千円の預金通帳を肌身につけて離さなかった山崎は、ぱたりひっくりかえった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中に小口当座｜預金通帳とあって、横に里見美禰子殿と書いてある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く現在の私は、先月亡くなった父将軍の預金通帳によってこうしているのですからね。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中に小口当座｜預金通帳とあつて、横に里見美禰子殿と書いてある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、金庫の中の当座預金通帳を見てきたが、五百万円あまり残ってますね。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人前奏曲　篠田昌吉と川波美与子のふたりは、あの晩は覆面の男の麹町のアパートに一泊して、その翌日、百万円を預金通帳にしてもらって、それを受け取ると、黒覆面の世話で、その日のうちに、墨田区吾嬬町の小さなアパートにひと間を借りた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便預金通帳書式も同様です。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
