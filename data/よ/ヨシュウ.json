    },
    "definitions": [
      {
        "index": 1,
        "gloss": "preparation for a lesson",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の椅子に社長をすわらせたつもりにして、その前に帳簿を並べて説明とお世辞の予習をする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が来ると、簡閲点呼の予習を兼ねた在郷軍人会の訓練がはじまり、自分の仕事にも追はれたので、私は暫く名曲堂へ顔を見せなかつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はまた、とき／″＼予習して行った既定の歌詞の章句や歌曲から全然離れてその場の思いつきで何事かを唄い出すときがある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事が済むと、君枝に今日の勉強の予習をさせる。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は生徒間になんだか獣に縁のあるような綽名を付けられている若い人で、その時はただ挨拶して別れただけであったが、その後わたしが学校の予習などを怠ると、彼はかならず私を嚇して「君はまた芝居へでも行ったのだろう。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店をやっている人が来て、近々その店を閉めて、子供の予習所にするという話をした。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、演習の時間に一人の学生が自分の当る番であるのに予習をしてきていなかった。",
              "citation": {
                "source": "西田先生のことども",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月に入ると、近所の国民学校の講堂で毎晩、点呼の予習が行われていた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなが、こうして予習に来ているのを、君だけ気づかなかったのか」　はじめ教官は穏かに正三に訊ね、正三はぼそぼそと弁解した。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一度も予習に出なかったくせにして、今朝だけ出るつもりか」　教官はじろじろ彼を眺めていたが、「裸になれ！",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月に入ると、近所の国民学校の講堂で毎晩、点呼の予習が行はれてゐた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなが、かうして予習に来てゐるのを、君だけ気づかなかつたのか」　はじめ教官は穏かに正三に訊ね、正三はぼそぼそと弁解した。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一度も予習に出なかつたくせにして、今朝だけ出るつもりか」　教官はじろじろ彼を眺めてゐたが、「裸になれ！",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ予習復習の奮励が教室でめき／＼と眼に立つ成績を挙げるのを楽しみにした。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには一度もマイコンにさわったこともない幹部もいるとかで、事前に手渡された『マイコン操縦法入門』と題するテキストをみながら、実際に社内のマイコンを動かし、予習に取り組む姿がチラホラ目立ち始めている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、復習だの予習だのする必要は全然私にはなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして学校の予習復習なんかとても出来やしない。",
              "citation": {
                "source": "舞踏病",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人の足音、入り交る声、波ならぬ喞筒とも覚ゆる水の音、また桶より流す水の音、また例の火事の際の予習の初まりつれ、最上層の甲板にてはボオトを降ろすならんなど、寝返りして目の開きし瞬間に我が思ひしは之れにて候ひき。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつもひとりであるときするようにランプの掃除をして、薄暗い三分芯に灯をともして、そうして明日の代数の予習をはじめた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中学入学の予習をしているので、朝も早く、晩日が暮れてから遠い由比ヶ浜の学校から帰ってくるのだった。",
              "citation": {
                "source": "父の出郷",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではひとつ予習をしてみるかな。",
              "citation": {
                "source": "父の葬式",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯四月十一日の午前のへんな爆撃は今度の予習だったかも知れない。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は予習も復習も宿題もしたためしがなく、学校から帰ると入口へカバンを投げ入れて夜まで遊びに行く。",
              "citation": {
                "source": "石の思ひ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏川の母はもう七十をすぎた年だが、田舎の武士の堅苦しい躾の中で育つた人で、中学時代の夏川は漢文の復習予習を母についてやらされたものだ。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ数学にハあまり興味を持たないのか、さっぱり思はしくないので心配しましたが、此の度の中学入学受験予習のおかげで大分頭が鍛へられて少々難かしい問題もたやすく解かれる程度に進んだ様ですから、此の分ならば本学期末あたりから、もう大丈夫だとよろこんでゐます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日のこと、それは自習時間といつて、夕食後から寝に就くまで、自習室に籠つてそれぞれ学課の予習復習をしなければならぬ時間であつたが、私の少年の胸にかねがね鬱積していた疑問の爆発する機会が来た。",
              "citation": {
                "source": "いわゆる「反省」は我々を救うか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての仕事を一度原始的に引き戻して、人間自然の発祥から比較検討し直して見ることの予習をやって見る必要は無いか。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "キツネだと云ふので、あてられては大変と皆よく予習して行つた。",
              "citation": {
                "source": "カイダイ",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し予習は、子供自身にうち任したがいい。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
