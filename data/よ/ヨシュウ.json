[
  {
    "uuid": "d1216976-608a-595e-9b3a-99e6049e0f49",
    "entry": "予習",
    "reading": {
      "primary": "よしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
