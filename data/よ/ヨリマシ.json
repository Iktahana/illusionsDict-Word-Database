[
  {
    "uuid": "7379d241-979f-51bb-9098-7825b51e08c6",
    "entry": "憑坐",
    "reading": {
      "primary": "よりまし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
