    "definitions": [
      {
        "index": 1,
        "gloss": "child or doll used as a vessel for a spirit invoked by a shaman or miko",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "武林無想庵氏の話によると、この余裕性をもたない都市は、世界で紐育と東京だけださうだが、それでもまだ喫茶店があるだけ、東京の方が大阪よりましかも知れない。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別役の精様がこないだから連れて行てくれい云いよりましたがのうし。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但、御陳情によりまして以後、唄うたいの新出願者は決して許可しないことにいたしましょう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はそばへかけよりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず今晩はおめぐみによりまして不思議に助かりました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教｜巫徒の「よりまし」「よりき」の事と少し似てはいるであろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟がだんだん近よりました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云って婆やのそばへ駈けよりました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは思わずかけよりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "場合によりましてはそんな事でもありましたかも知れましねえ。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生れて来る子供のためにもあの人に偉くなって貰わねばと思い、以前よりまして声をはげまして、あの人にそう言うようになったが、あの人はちっとも偉くならない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、来よりました」　男はそう私の耳に囁いて、あと、一言も口を利かなかった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちは、ひっそりとしていましたが、まもなく、あの小さな女の子が出てきて、そっと、とり小屋にしのびよりました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンネスと旅の仲間は、すぐに、町の中へはいっていかないで、町はずれの、とある宿屋によりました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまも、自分の船に乗ろうとして、船のそばへあゆみよりました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、みぞほり人夫の家によりました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "にくまれて、世にすむかひわ、なけれども、かわいがられて、死のよりましか。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、こか（古歌）のごとく、わしも、歯がいたくて、世にすむかひわ、なけれども、ねずみとらずの、ねこよりましか。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが千古の英雄ナポレオン一世も、この戰ひの敗軍によりまして、遠くセントヘレナの孤島に幽囚の身となりました。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い道を帰るよりましだから」と、またすわりなおしてしまいます。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体出不精な処へ、お蔭様、店も忙しゅうございますし、本所の伯父伯母と云った処で、ほんの母がたよりました寄親同様。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の婿めが、あんた、マニラでころっと逝きよりましてな」「マニラ……？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子のお父つぁんも、わいが無理矢理｜横車振ってマニライ行かしたばっかりに、ころっと逝ってしまいよりました。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒をのんでいた叔父が二こと三こと喋ると叔母は、猫の子よりましだんがナと云った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの顔を注意してみると、皆自分よりましな顔をしていた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで、叔母は、悪い奴にそそのかされて家出しよりましてんと云いふらした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
