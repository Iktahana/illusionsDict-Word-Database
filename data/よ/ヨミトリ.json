    "definitions": [
      {
        "index": 1,
        "gloss": "reading (e.g. by a scanner)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
