    "definitions": [
      {
        "index": 1,
        "gloss": "to delight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "単なる意志だけで為されたことは、為されたその時だけホンの瞬間熱病的に嬉しいかも知れなくても、なんの意義あることでもないし、人を喜ばすことでもない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にあつて、たゞ叫びの強烈な人、かの誠実に充ちた人だけが生命を喜ばす芸術を遺したのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年の文展や院展を見に行ってもこういう自分のいわゆる外道的鑑賞眼を喜ばすものは極めて稀であった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今日まで女を喜ばすべく半襟を買はなかつたが、若し彼の娘に此等の品を與たら如何に喜こぶだらうと思ふと、僕もうれしくつて堪らなかつた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは、明かに冗談でむしろ、内川を喜ばす一つの手段の如く見えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「科学ファン」を喜ばすだけであって、ほんとうの科学者を培養するものとしては、どれだけの効果がはたしてその弊害を償いうるか問題である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながらわが国の書店やデパート書籍部に並んでいるあの職人仕立ての児童用絵本などとは到底比較にも何もならないほど芸術味の豊富なデザインを示したものがいろいろあって、子供ばかりかむしろおとなの好事家を喜ばすに充分なものが多数にあった。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二年間の貯蓄の三分の二を平気で擲って、錦絵を買い、反物を買い、母や弟や、親戚の女子供を喜ばすべく、欣々然として新橋を立出った。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来快楽を目的とする音楽でさえもドイツ人の手にかかるとそれが高等数学の数式の行列のようなものになり、目を喜ばすべき映画でさえもこの国でできたものは見ていておのずから頭痛のして来るようなのがはなはだ多い。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた鹿狩りの場に現われた貴族的なスポーツ風景は国粋主義の紳士淑女を喜ばすものであり、シャトーにおける生活の空虚と痴愚を露骨に風刺する多数の画面は卑近な民衆イデオロギーに迎合するものであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは朝以来のぼくの態度の続きとして必要であるし、又、今先ぼくが明日子に接唇したということはとにかく彼には済まないと思える行為であったから、その償いとしても彼を喜ばす必要がある。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の好きな鳥右ヱ門は、かういふものをたくさん作つて人々を喜ばすことは、ずゐぶん人のためになることだと考へたのでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に、お父さんは、人を喜ばすのが好きだったようだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き頃、世にも興ある驕児たりいまごろは、人喜ばす片言｜隻句だも言えずさながら、老猿愛らしさ一つも無し人の気に逆らうまじと黙し居れば老いぼれの敗北者よと指さされもの言えば黙れ、これ、恥を知れよと袖をひかれる。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い水面の上の赤、白、黄――旗、幕、造花等の裝飾――是等は十分予の視感を喜ばすに足るのである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して是れは所謂「御神體」を崇め、それを喜ばすが爲めに行はれたのだと云ふ事を發見するに至る。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結構より言ふ時は、第一輯は序巻なり、而して第二輯の第一巻は全篇の大発端にして、其｜実は「八犬伝」一部の脳膸なり、伏姫の中に因果あり、伏姫の中に業報あり、伏姫の中に八犬伝あるなり、伏姫の後の諸巻は、俗を喜ばすべき侠勇談あるのみ。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "余を以て是を見れば、我国の古神学は或は俗を喜ばすべき奇異譚を編むには好材料たるべきも、到底｜所謂幽玄を本とする想詩を構ふるに適するものならず。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の楽しさが即ち男を喜ばす言葉や仕草となって現われるのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "万彦の話に耳を傾けていた宮地翁は、河野久の話を聞くと、もし万彦が己と河野久とのことを知っておって、己を喜ばすために作りごとを云うのではないかと思ったので、そのままに聞き流してその日はなにも云わなかった。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者の世の中にふえるということは、ただ活版屋と紙製造所を喜ばすだけで、あまり社会に益をなさないかも知れない。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神、その独子、聖霊及び基督の御弟子の頭なる法皇の御許によって、末世の罪人、神の召によって人を喜ばす軽業師なるフランシスが善良なアッシジの市民に告げる。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私の小説は沢山の方を喜ばすことは出来ないかも知れません。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には、貴族、君主、又は今日の場合では一般購買者を喜ばすことができなければ文学は存続することは許されないからである。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人を喜ばすためになら何かちょっとした罪くらいなら犯してもよいと思った位であった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間には病院の内も外も私の散歩になれて、新しい感味が單純な頭を喜ばす事は少くなつた。",
              "citation": {
                "source": "嘘をつく日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしクリスマスの日だけは子供の日ですから、大人の人は一生懸命になって子供を喜ばすようにしてやって頂きたいと思います」　皆は又も手を拍って賛成しました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前を喜ばす眞實のロミオを搜して來う。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この渓間ではなにも俺をよろこばすものはない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この溪間ではなにも俺をよろこばすものはない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
