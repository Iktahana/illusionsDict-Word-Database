    "definitions": [
      {
        "index": 1,
        "gloss": "unsteadily (walking)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
