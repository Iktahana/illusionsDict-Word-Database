        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "記憶は見知らぬ波止場をあるいてにぎやかな夜霧の海にぽうぽうと鳴る汽笛をきいた。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大都市の冬に特有な薄い夜霧のどん底に溢れ漲る五彩の照明の交錯の中をただ夢のような心持で走っていると、これが自分の現在住んでいる東京の中とは思えなくなって、どこかまるで知らぬ異郷の夜の街をただ一人こうして行方も知らず走っているような気がして来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家も、燈灯も、畑も、森も、川も、丘も、そして歩いてゐる我我の體も、灰を溶したやうな夜霧の海に包まれてゐるのであつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りの絶えた四条通は稀に酔っ払いが通るくらいのもので、夜霧はアスファルトの上までおりて来ている。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面には湖水が遠く末広がりに開いて、かすかに夜霧の奥につづいていた。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸の内の夜霧がさらにその空想を助長したのでもあろう。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ大空には皎々とした月が冴え渡つて、もう夜霧が降りたのでせう、近所のトタン屋根も往来の地面も湿れたやうに白く光つてゐました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春のおぼろ月の淡い光が川原の薄い夜霧を透して加茂の流れにほのかに映っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人の夜霧に没する痩せたうしろ姿を見送り、私は両肩をしゃくって、くるりと廻れ右して、下宿に帰って来た。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川沿いの町はとっぷりと暮れ、藍墨いろの家並と藍墨いろの川の面を籠めた夜霧が、咽喉に冷たく吸い込まれるほど藤紫に濃くなって来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに見える軒の灯は夜霧にうるんで、何度眼を瞬いても自分が寝呆けているような気がいたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかあかと据ゑし蝋燭薔薇潮す片頬にほてり、すずろけば夜霧火のごと、いづこにか林檎のあへぎ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と濁ごゑ屋根低き山家の土間は魚燈油のくすぶり赤く、人いきれ、重き夜霧に朦朦と地獄の光景現じいづ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い夜霧が草の葉末におりて四方は薄絹に包まれたようである。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜霧がひきちぎって投げられたように、ほの白くそこここに流れていた。",
              "citation": {
                "source": "殺神記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草の上には夜霧が最早しっとりおりていた。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかと申し伝えろよ」　言い捨てると、さてまた退屈じゃが何処へ参ろうかなと言わぬばかりに、ぶらりぶらりと的もなく更け静まった都大路を、しっとり降りた夜霧のかなたへ消え去りました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "破鐘　　　　　　シャルル・ボドレエル悲しくもまたあはれなり、冬の夜の地炉の下に、燃えあがり、燃え尽きにたる柴の火に耳傾けて、夜霧だつ闇夜の空の寺の鐘、きゝつゝあれば、過ぎし日のそこはかとなき物思ひやをら浮びぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "破鐘悲しくもまたあはれなり、冬の夜の地爐の下に、燃えあがり、燃え盡きにたる柴の火に耳傾けて、夜霧だつ闇夜の空の寺の鐘、きゝつゝあれば、過ぎし日のそこはかとなき物思ひやをら浮びぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人がそのような夜更しをするさえ既に危険であるのに、殊にこの辺りの海は夜霧が多く話に聞けば兇悪な大｜鱶さえも出没すると云う。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋の軒近くまで夜霧が深くかかつて來て、電燈の光が光鋩もなくぼんやりと濡れてかがやいてゐるのを前にして、東京生れの妓が靜かに爪彈か何かで三味線を彈いてゐるさまなどがをりをり繪になつて私の眼に映つて見えた。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜霧でびっしょり濡れた朝の街路の上を拡声器から出るラジオの音がガンガンと響いてゆく。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）の七　淡い夜霧が田畑の上に動くともなく流れて、月光が柔かに湿うてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　淡い夜霧が田畑の上に動くともなく流れて、月光が柔かに濕うてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "海関の尖塔が夜霧の中で煙り始めた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夜霧にぬれて飽かずに川ふちを歩いたものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は私の部屋をよぎりながら轟々と走り去る。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔けむりは時に丘丘の〕けむりは時に丘丘の、　　栗の赤葉に立ちまどひ、あるとき黄なるやどり木は、　　ひかりて窓をよぎりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
