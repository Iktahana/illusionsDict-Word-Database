    "definitions": [
      {
        "index": 1,
        "gloss": "mercilessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白樺や五葉松は、制裁もなければ、保護もなく、永えに静粛に、そして厳格に、造化の大法を、寸分容赦なく行ってゆくように、この自然の王国から、定まれる寿命を召されて、根こそぎに、谷の中にたわいなく倒れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者のうちでそれらの誤謬を発見された方は容赦なく示教を惜しまれないように願いたい。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの中は一廻も太ったように思われて痒さが耐らなかったが、しまいにはげっそり痩せたと感じられてずきずき痛んでならぬ、その上を容赦なく歩行く内にも入交りに襲いおった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり凝りすぎてもからだにさわるから午前だけにしたいと思ったが、午前中に一段片付けたつもりで昼飯を食いながらながめていると間違った所が目について気になりだす、もう一筆と思ううちにとうとう午後の時間が容赦なくたってしまう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと聞きたいと思うところで容赦なく歌は終わってしまう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容赦なく酷刑に処すべきである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って画面には写っていない人間や発音体の音が容赦なく侵入してくる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾度かできるだけ冷静になって自分の気持を考えてもみ、容赦なく解剖してもみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪がこの邊に住んでゐた百姓の一人息子を容赦なく避難の小舟から奪ひ去つたのだ。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の間に於ける親子の關係に於ても、學校に於ける師弟の關係に於ても、社會生活に於ける成員としての關係に於ても、この僻見は容赦なく採用された。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの萬有を情け容赦なく鞭ち／＼つた恐ろしくも小氣味いゝ暴王は老い盡す。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開け放たれた戸口から悔恨は、風と一緒に容赦なく吹込んでゐた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八「※、わはは、はは、」多磨太は容赦なくそのいわゆる小羊を引立てた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時も裏町の人数八九名に取占められて路地内へ遁げ込むのを、容赦なく追詰めると、滝は廂を足場にある長屋の屋根へ這上って、瓦を捲くって投出した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪はぐるぐる巻にして油つ気もないので後れ毛は容赦なく、骨ばつた頬のまはりに乱れて居た。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挺の鉛筆削でも容赦なく留置された。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがた見えずなりたる、美人の小腕を邪慳に掴みて、身を脱れんと悶えあせるを容赦なく引出しぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今頃は其の窓も容赦なく取毀されて、継母の執念も其の憑る所を失ったであろうか。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は彼女の上に容赦なく降積んで、さながら越路の昔話に聞く雪女郎のような体になった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に牛九郎爺さんはその巨大な母家をアトカタもなく取片付けて隣村の大工に売払い、数多い雇人をタタキ放し同様にして追出してしまい、有る限りの田畑をソレゾレ有利な条件で小作に附け、納まりの悪い小作人の所有の田畑は容赦なく法律にかけて、自分の名前に書換えて行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船は、容赦なく進む。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字の精は彼の眼を容赦なく喰い荒し、彼は、ひどい近眼である。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "質の悪い肉の癒着は荒療治でも容赦なく截り分けなければならない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、夜更けとともにおびただしく出て来た蚊は、寿子の腕や手や首を、容赦なく刺すのだった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイモンは容赦なく死刑場に引き出されました。",
              "citation": {
                "source": "デイモンとピシアス",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのかわり今度は寒気が容赦なく押寄せて来た。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容赦なく生命を刻んで行く冷たさで、くるくると絶間なく動いている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "微塵でも正義に背く奴は容赦なくタタキ斬り蹴飛ばして行く人という感じに、一眼で打たれてしまうのであった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも述べた通り、「能楽」という芸術は、新作物を受け付けぬどころでなく、逆に旧作のものの中でも芸術価値の薄いものは、容赦なく自然消滅をさせつつ発達向上して行く芸術である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "折柄、五月雨の水勢｜烈しきに、容赦なく押流された。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
