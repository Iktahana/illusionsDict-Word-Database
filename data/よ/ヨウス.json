      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "state (of affairs)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて中の一人が、「云ふことは分らないから、一つ農学士様の話す様子を見てやらう」といふことになり、「なんだい、まるで腰抜みたいぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「罪と罰」でも、「田園交響楽」でも、「阿部一族」でも、ちゃんと映画になっている様子だ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の決闘は、この雑誌（文章）に半箇年間、連載せられ、いたずらに読者を退屈がらせた様子である。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いつまで経っても、出世できない様子です。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹も、そのころは、痩せ衰えて、ちから無く、自分でも、うすうす、もうそんなに永くないことを知って来ている様子で、以前のように、あまり何かと私に無理難題いいつけて甘ったれるようなことが、なくなってしまって、私には、それがまた一そうつらいのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はかるく狼狽の様子で、「くらべたりするもんじゃないよ」と言って笑ったが、すぐにけわしく眉をひそめ、「いや、ものごとはなんでも比較してはいけないんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はたしかにずば抜けて語学ができる様子だから、僕たちの書いた原稿をフランス語に直しておくれ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん薄暗くなって色々の灯でいろどられてゆく上野広小路の雑沓の様子を見おろしていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は独り息子であるから、ずいぶん可愛がられて、十年ほど前にお母さんが死んで、それからは厳父は、何事も大隅君の気のままにさせていた様子で、謂わば、おっとりと育てられて来た人であって、大学時代にも、天鵞絨の襟の外套などを着て、その物腰も決して粗野ではなかったが、どうも、学生間の評判は悪かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれが、やがて大隅君のあの鬱然たる風格の要因にさえなった様子であったが、思いやりの深い山田勇吉君は、或る時、見かねて、松葉を束にしてそれでもって禿げた部分をつついて刺戟すると毛髪が再生して来るそうです、と真顔で進言して、かえって大隅君にぎょろりと睨まれた事があった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うまく、まとまった様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂氏の夫人は既に御他界の様子で、何もかも小坂氏おひとりで処置なさっているらしかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の事も子供の事も、ちっとも心配していない様子で、ただ、お庭の植木の事ばっかり言って寄こします。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やっぱり、その事が先生にとっても、まず第一に気がかりになる様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しんから、ほっとなされた御様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに大隅君も心細くなった様子で、おい、この家でモオニングか何か貸してくれないものかね、と怒ったような口調で私に言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とれいの鷹揚ぶった態度で首肯いたが、さすがに、感佩したものがあった様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども山崎氏は、不思議にも、いま、成功して居られる様子であります。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思念を現はしてゐるその様子を会得しなければならない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなんら怒つた様子もみせなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＳ子の様子伺ひに出掛けて行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳かな入学宣誓式が行われて、自分も大勢の新入生の中にまき込まれて大講堂へ這入ったが、様子が分らないのでまごまごしていると、中に一人物馴れた日本人が居ていろいろ注意してくれて助かった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ美術学校の方から車が二台｜幌をかけたのが出て来たがこれもそこへ止って何か云うている様子であったがやがてまた勧工場の方へ引いて行った。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右脇には句集など取散らして原稿紙に何か書きかけていた様子である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狸」でない子がわざとなんだか落着かないような様子をして天井を仰いでみたり鼻をこすってみたりして牽制しようとするなどはきわめて初歩であるので、その裏をかくつもりで「狸」自身がわざとそのような振りをすることもある。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の午後に谷中へ行ってみると寛永寺坂に地下鉄の停車場が出来たりしてだいぶ昔と様子がちがっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑喉場の前に日本式の小さい帆前が一艘ついて、汀には四、五人ほど貝でも拾っている様子。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人達はあまりに変つた王の様子にタヾ恐ろしさの為に震つてばかり居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間の酔ぱらつて居る家来も流石に王のこの様子に気づいたのか急にヒツソリとなつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し謝源は少しも残念がる様子もなく或夜コツソリと一そうの小舟で首里からのがれて行つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
