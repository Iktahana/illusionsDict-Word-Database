[
  {
    "uuid": "afc1fead-7904-54de-ab4c-c6e15d67bace",
    "entry": "酔わせる",
    "reading": {
      "primary": "よわせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
