        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、ある程度まとまった部数を作らなければ採算が成り立ちにくいという出版固有の事情がかかわって、書き手と読み手の願いは時にすれ違ってしまいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずらりと並んだコピー機に学生たちが張り付き、吐き出されてきたコピーを専用の機械が製本のためにばたばたと二つに折っていく光景を思い浮かべると、なんだかその様が、書き手と読み手の願いのすれ違いを象徴しているように思えてきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして全ての読み手と全ての書き手は、二つの世界の間でなんらかのものを取り落とす。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版社に頼らず、自分の手で作品を形にしようと決心した書き手は、読み手にどう知らせるか、どう手渡すかという問題に直面し、結果的には効果的な答えを見いだせずに終わる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして読み手と書き手を縛ってきた鎖を断ち切り、新しい本の世界を開いていくのではないかと思い始めたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田正子や山びこ学校の生徒たちの綴方は、印刷された本になるという〈奇跡〉があって初めて、たくさんの読み手の心を揺り動かすことができた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごくごくわずかな部数の本を出会いの場としても、書き手の与えてくれる縦糸と、読み手の心が紡ぎ出す横糸を編み、大切な人生の一こまを織りあげることはできるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの『しかし』や祖母の『蜉蝣』に新しい光が当たり、印刷物である限りは決して出合うことのなかったもう何人かの読み手を、獲得できるのではないか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み手として、こうした体験をしてみると、自分のホームページを作る際も、読みやすさという点を無視できないと思うようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産された印刷本の中心的な読み手となったのは、ルネサンスの中核となった人文主義者たちです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "朗読が、読み手の表現としての性格をもつのに対し、音訳では、読み手の解釈や感情表現は、排除することが求められる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ無関係な第三者がひとの艶書のぬすみ読みをするときにこっけいの興味が加わらないはずはないわけであるが、書き手が節操上の徳義を負担しないで済むくろうとのような場合には、この興味が他の厳粛な社会的観念に妨げられるおそれがないだけに、読み手ははなはだ気楽なものである。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒藤権右衛門はみごとわれら天誅を加えたれば、意を安んじて可なり――卍」　文言はなんの変哲もなさそうに見える簡潔なものでしたが、これを読んだ読み手がただの読み手ではなかったものでしたから、瞬時も待たずに、鋭い声が右門の口から飛んだので――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度カルタの読み手になる時には、最初のカラ一枚で是非ともそれを詠まう、そいつを俺の得意にする――と呟いて、繰返してＢにうたはせてゐた。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠の木目の見える本箱の中には桂園派の歌書のめずらしくても読み手の無いような写本が入れてある。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "デカメロンそのままを春陽堂から出版したって読み手はないにきまっている。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ主観の叙述はほとんどなくなる訳だとまたおっしゃるかも知れませぬが、前から何遍も申す通り無論あるところでは主観も客観も双方一致しているので、書き手の心持、読み手の心持で判ずるよりほかに手のつけようのない場合がいくらでもあります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み手として優れているか特色があるか、それとも優れていなくても特色がなくても、それに職業的か習性的かの経験や訓練を有とうと心掛けて生活しているもの、之が所謂批評家だ。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き手の願いと読み手の思いを、算盤勘定が阻む。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（新生三月号をよみて）",
              "citation": {
                "source": "書信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通は手もとふるへて巻納めぬ、二通も同じく、三通四通五六通より少し顔の色かはりて見えしが、八九十通十二通、開らきては読み、よみては開らく、文字は目に入らぬか、入りても得よまぬか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌をよみて其の枝の紅梅の莟を解かんとするにあらず。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△放浪によりてえたる貧しき収穫より――旧作□美しき人を泣かして酒飲みて調子ばづれのステヽコ踊る旅籠屋の二階にまろび一枚の新聞よみて一夜をあかす酒飲めど酔ひえぬ人はたゞ一人欄干つかみて遠き雲みる酔覚の水飲む如く一人に足らひうる身は嬉しからまし　　　　　　　△　△　△△先日の句会では愉快でした。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見えぬながらも、よみてけるに、九一ろうどのわ、しんがん（心眼）なるべしと、ひざ打ちたたいて、かんしんした。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の足鐶　　　――死人の家をよみて――囚徒らの足にはまばゆい銀のくさりがついてゐる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、全體醫業は甚だ六箇敷物にて、始終書物をよみて學問せねば出來ぬものなり。",
              "citation": {
                "source": "養生の心得",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい歌のよみてであった。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりごとに幽世に入るとも、吾は　現世に在るとひとしく　歌をよむのみ歌よみて遊ぶ外なし。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を血に染めて　焼刃見澄ます※国汚す奴あらばと　大刀抜きて、仇にもあらぬ　壁に物いふ※ひとりごとに歌よみて、遊ぶ外なし。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○巻向の山辺とよみて行く水の水泡のごとし世の人吾は　〔巻七・一二六九〕　柿本人麿歌集　人麿歌集にある歌で、「児等が手を巻向山は常なれど過ぎにし人に行き纏かめやも」（巻七・一二六八）と一しょに載っている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
