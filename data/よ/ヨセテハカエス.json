[
  {
    "uuid": "39a32aa4-8871-5386-8198-90db92b73846",
    "entry": "寄せては返す",
    "reading": {
      "primary": "よせてはかえす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
