    "definitions": [
      {
        "index": 1,
        "gloss": "going to bed early",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「灰汁桶のしずくやみけりきりぎりす」「あぶらかすりて宵寝する秋」という一連がある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜枯時の事ながら、月は格子にあるものを、桑名の妓達は宵寝と見える、寂しい新地へ差掛った。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尊さに、その晩ばかりはちっとの酒で宵寝をした、叔父の夜具の裾を叩いて、枕許へ水を置き、（女中、そこいらへ見物に、）　と言った心は、穴を圧えて、宗山を退治る料簡。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も宵寝の早起きだったのて、台所ではもう焚きたての飯の匂いがしており、七輪にかかった鍋の蓋の隙間から、懐かしい味噌汁の甘い煙も噴き出していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝはまた、それだけのもので、やはり所在なくて、宵寝をします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寝の習慣を持っている川辺家の人々は、皆寝しずまって、月のみが、樹木の多い庭園を昼のように照していた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の声があまりに激しいので、宵寝の都人も夢をおどろかされたらしい。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寝をしたのであまり早起だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寝が覚めてから長い夜であつたが、よい月夜でもあつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "めづらしく宵寝、いろ／＼の夢を見た、とき／″＼眼が覚めて、孤独のおもひが澄みわたつた、身に迫つてちんちろりん、虫もさびしいのだろう！",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寝も好きなら宵寝も好きなる事、百日紅の如きは滅多になし。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼寝ばかりではない、朝寝も宵寝も致します。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾の道中は、御岳おろしが、いかにこの剃下げの顱頂部にしみ込んで、幾夜、宵寝の夢を寒からしめたことか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が泣く声にまた今宵寝もせであかす人の世のわがくるしみをおもへかし。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時頃帰ってロッパ君の稽古場へ遊びに行こうか富士市へ行こうかと思いましたが、結局どっちへも行かないで宵寝をしてしまいました。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "新見家は朝が早いので宵寝だが、今夜は主人が留守だから特別に早く寝た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は唯この一ともとに雑沓するという老木の枝垂れ桜は葉も落ちて、ただ黒々とさながら宵寝という姿であるのを、疎らな人通りの誰顧みる者もなく、平野屋の栗めしの立て看板が夜目にも白々として、少し前までは時刻がらごった返して居たらしいのが、今は掛けつらねた提灯のみが明るく、少しは静かになった風である。",
              "citation": {
                "source": "六日月",
                "author": "岩本素白",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜この辺に何か立廻らなかったろうか」「ヘエ――、何か来たかもわかりませんが、何分あの雪で、宵寝をしてしまいましたんで」　重吉は少し迷惑そうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "除夜年ひとつ老いゆく宵の化粧かな　　　　几董　大三十日の晩の句で、今宵寝ればまた一つ年を取るというその宵に化粧をする女を咏じたものである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰汁桶の雫やみけりきり／″＼す　　　凡兆あぶらかすりて宵寝する秋　　　芭蕉「桶の灰の中に水を入れて、下の口から少しずつ灰汁が落ちる仕掛になっている、古風な家のさま、その灰汁の音が何時の間にか止んでしまった。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寝して、昼寝するまで、宵寝して、時々起きて、居睡りをするという歌を思い出して、彼は苦笑を禁じ得ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寝の一睡から醒め、飯を食うておる折へ、ちょうど御辺がお訪ねというので、食べかけたもそのまま、半分で膳を退げさせてしもうたのでござる。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると悠吉も正子も同じように今日は宵寝をするといい出した。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寝をしているんだ。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らの酒もりがすんで、宵寝に入ったと見えたらそれが機だ。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜の散歩はよいね、方々で夏祭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた何とよいねむりだつたらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "団員のだれかにそっといいつけて、しらせる方法があると思うわ」「房枝、お前は、わしより気がつよいねえ」「だって、バラオバラコって、どんな人だかしらないけれど、こんなわるいことをする人を、そのまま、ほっておけませんわ」「命があぶない。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二たび武石峠へ「きのうよりはよいね」と、宿から常念岳の鋭いピラミッド形なせる姿をながめて、私はＭ君にいった。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺に荷駄を積んだのとどつちがいいかと聞くと、お客さんも上手に乘つてくれるといいが、たいがいなら荷物を三十貫位積んだ方がまだよいねといふことであつた。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
