        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プラトンはソクラテスがポティダイアの陣營において一晝夜立ち續けて瞑想に耽つたといふことを記してゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンはソクラテスがポティダイアの陣営において一昼夜立ち続けて瞑想に耽ったということを記している。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山へは、夜立ちして十三里｜日着きする。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく後陣のものが町に到着して一息ついたと思うころには、本陣ではすでに夜立ちの行動を開始した。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉次の仲間がいつも泊る家へ、馬を一頭取りにやったり、腹ごしらえや弁当など作らせている間に、夜立ちのつもりが、いつか夜明けの早立ちぐらいな時刻になっていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、難行苦行だろう」「一行の者に対しては、あえてムチを振るッて克己させ、時には夜立ち暁立ち。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜立ちと見ゆる二｜挺の駕が、筑波屋をあとに宵を急いで、江戸川の土手へさしかかッて来る。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかに元気づいた多市、ポンポンと手を叩いて「オイ、姐さん姐さん、誰でもいいや、お急ぎの夜立ちだ、草鞋に握り飯を揃えてくんねえ」　その間に目明しの万吉、トントンと降りてきた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見たものみな身の毛もよだち大地も感じて三べんふるえたと云うのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の毛よだちて、思わず※呀と叫びぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「京管領細川右京太夫政元は四十歳の比まで女人禁制にて、魔法飯綱の法愛宕の法を行ひ、さながら出家の如く、山伏の如し、或時は経を読み、陀羅尼をへんしければ、見る人身の毛もよだちける。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと言ひやうもない身の毛もよだち　ぞつとするやうな思ひ出ばかりだ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の毛よだちて、思はず※呀と叫びぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筧の音して、叢に、虫鳴く一ツ聞えしが、われは思わず身の毛よだちぬ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀財宝とは異なりて、天地のつくりなせるものをしばらくかりて我飢を医せんにはと、心むら／＼と乱れて、あはやわれ履を瓜田に入れむとせし刹那、我影のあまりに明かなるに、仰げば隈なき一輪の月魄、天つ御神のにらみたまふかと思はれて、そゞろに身の毛よだち、穴あらばとばかりに身をちゞめて、月を拝みてぞ泣きし。",
              "citation": {
                "source": "月譜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の者は、凄まじい殺気に閉じられて、身の毛もよだち、息を詰めて、ただ茫然と主従の決闘を見守るばかりであった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、同時に、右門も伝六も、おもわずぞっと身の毛がよだちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕はこの答を聞いた時になぜか身の毛がよだちました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に夜風が一下しして、煙が向うへ靡いた時、赤い上に金粉を撒いたやうな、焔の中から浮き上つて、髪を口に噛みながら、縛の鎖も切れるばかり身悶えをした有様は、地獄の業苦を目のあたりへ写し出したかと疑はれて、私始め強力の侍までおのづと身の毛がよだちました。",
              "citation": {
                "source": "地獄変",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に夜風が一下しして、煙が向うへ靡いた時、赤い上に金粉を撒いたやうな、焔の中から浮き上つて、髮を口に噛みながら、縛の鎖も切れるばかり身悶えをした有樣は、地獄の業苦を目のあたりへ寫し出したかと疑はれて、私始め強力の侍までおのづと身の毛がよだちました。",
              "citation": {
                "source": "地獄變",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕はこの答えを聞いた時になぜか身の毛がよだちました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見た、みんなのからだは、急にぞっとして身の毛がよだちました。",
              "citation": {
                "source": "黒い人と赤いそり",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その痛ましさ物凄さに一同は身の毛がよだち、銘々が鋭い痛みを感じるようにさえ思われたのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、このおじいさんを見ると、なんとなく体じゅうが、ぞっとして、身の毛がよだちました。",
              "citation": {
                "source": "銀のつえ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京管領細川右京太夫政元は四十歳の比まで女人禁制にて、魔法飯綱の法愛宕の法を行い、さながら出家の如く、山伏の如し、或時は経を読み、陀羅尼をへんしければ、見る人身の毛もよだちける」という生活であったという。",
              "citation": {
                "source": "露伴先生と神仙道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、母わずらいつきて死しけるが、その夜より怨霊来たりて助八を悩ましければ、恐ろしさやるかたなく、身の毛よだちて覚えけるゆえ、妻子をすて、かみをそり、湯殿山行人にさまをかえ、諸国修行せしより後、怨霊またも見えずなりしとかや」　また、某氏の報知に、「近江国愛知郡北蚊野村に宇野うめといえる者あり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔力の無限の跳梁と思えば身の毛もよだちますが、少くとも天候というものを知ってその科学を学んでいれば、ホホウというところもあり、おのずからの笑いもあるわけね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは笹原がかなり広く続いたところであるのに、いま通り過ぎたと思った浅吉さんの姿が、もう見えないものですから、わたしの身の毛がよだちました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
