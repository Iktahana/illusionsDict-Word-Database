    "definitions": [
      {
        "index": 1,
        "gloss": "four (long cylindrical things)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
