    "definitions": [
      {
        "index": 1,
        "gloss": "to make oneself understood (in some language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海外旅行では、簡単な英語で最低限の用が足せるくらいにはなりたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このフレーズを覚えておけば、現地で困った時でも用が足せるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は片言の日本語でも、なんとか日本の生活で用が足せるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此奴が、このまゝくたばつてしまへば、今こそのうのうと鞍から降りて、何ものよりも切なくこゝまで持ち辛えてゐた用が足せるぞ！",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be able to relieve oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長い会議の途中で、どうしても用が足したくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サービスエリアに立ち寄って、まずは用が足せる場所を探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供はトイレに行きたい時、「用が足したい」と正直に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
