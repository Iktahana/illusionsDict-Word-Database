[
  {
    "uuid": "7e34b6b6-e63a-5ae0-88b7-a16380ae2d0e",
    "entry": "用品",
    "reading": {
      "primary": "ようひん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
