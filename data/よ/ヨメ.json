[
  {
    "uuid": "92b9d6d9-30f4-5950-81e3-c89c9ae0eb7e",
    "entry": "嫁",
    "reading": {
      "primary": "よめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
