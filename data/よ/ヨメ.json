    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bride",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――いつたい何処までゆきなさる、――いえ、兄の嫁の危篤を知らせに、此の下の村まで一寸。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　だつてねえ………あたし「奥さん」だとか、「妻」だとか、「お嫁」だとかつて言葉が嫌なのよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　「妻」だとか「お嫁」だとかつて世話じみてるんですもの………。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くから母に死なれ、父は頑固一徹の学者気質で、世俗のことには、とんと、うとく、私がいなくなれば、一家の切りまわしが、まるで駄目になることが、わかっていましたので、私も、それまでにいくらも話があったのでございますが、家を捨ててまで、よそへお嫁に行く気が起らなかったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん茶店の人たちも、あのお客は、ただ口が重いだけで、別段に惡だくみのある者でないといふことが判つた樣子で、お客さんのお嫁さんになるひと仕合せですね、世話が燒けなくて、とをばさんに冗談言はれて、私は苦笑して、やつと打ち解けて來たころには、はや十一月、峠の寒氣、堪へがたくなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大隅さんのお嫁さんが見つかりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ、お嫁さんのおじいさんは、槍の名人だそうですからね、大隅君だって油断は出来ません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんを迎えに、はるばる北京からやって来たのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御自分の嫁さんと逢うんじゃないか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は意気込んで、「あいつには、もったいないくらいのお嫁さんです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうはじめてお嫁さんと逢うんだというのに、十一時頃まで悠々と朝寝坊しているんですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、その原因をあれこれと指摘し、罪を社会に転嫁するような事も致しません。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には、その真面目臭つた顔の小僧と、先刻「お嫁さん」と云つた時の小僧とが、どうしておんなしなんだらう？",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんと兄とは、昨日の晩、兄の嫁のことから喧嘩をしてゐたが、良子には、それはどんな理由なのか分らなかつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "………あなたもお嫁入――人の奥さんにでもおなんなすつた方が遂々は………。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度お父さんがあそこの養子さんにお嫁さんの心配をするんでそのことに就いて一寸……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里へ引上げると間もなく次姉は市から一里くらい西のＡ村に嫁入りをしたので、あとは全く静かな淋しい家庭であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほその上、鬼どもに對し、親和の情を抱いてゐるのであるから、何の恐れるところもなく、圓陣のまんなかに飛び込んで、お爺さんご自慢の阿波踊りを踊つて、むすめ島田で年寄りやかつらぢや赤い襷に迷ふも無理やない嫁も笠きて行かぬか來い來い　とかいふ阿波の俗謠をいい聲で歌ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、その原因をあれこれと指摘し、罪を社會に轉嫁するやうな事も致しません。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は切なく叫ぶ、「この大根、嫁かずであれ、――今に」　といい、あとをも見ずに駈け去った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この大根、嫁かずであれ、――今に」そういうかと思うと、たちまち、男はまた、不器用にも俊敏に去った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はやはり「この大根、嫁かずであれ、――今に」といって駆去った男が、その翌日、何にも獣は持たずに水のほとりに来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお金でいまに太郎の美くしいお嫁に着物を買つてやるのです…………太郎はどこからかきつと美くしいお嫁さんを連れて来ませう…………そのお嫁さんは、ひよつとするときつい意地悪るかもしれません。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は美くしい着物を着たお嫁さんをまた一だんと好みませうから。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんが、わたしをいぢめるお嫁さんでもおかまひなし、わたしは太郎のよろこびのために、そのお嫁さんに美くしい着物を買つてやります。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな太郎の為に…………太郎の美くしいお嫁さんに着物を買ふため麻のハンカチ古い革手袋、昔はやつたお高祖づきんの布つ片へ、そつと貯めて置かうとするお金なんです。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れきった空からは、かすかな、そして長閑な世間のどよめきが聞えて来る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これは他の仮名にもあることで、「こ」でも、古くは「古」の類と「許」の類とにわかれているのを、共に「こ」と読んでいるのですから、止むを得ないことですが、しかし、その場合には、「古」の類も「許」の類もこれを「こ」とよめば後世の語と一致するから、これを共に「こ」と読むのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼の全集一卷を通じてよめば、恐らくすべての讀者が、彼の中に流るる眞の作家的モチーフを發見することができるだらう。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原には、よめな、つくしのたぐひ、せり、なづな、すみれの根もぼうぼうと生えてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
