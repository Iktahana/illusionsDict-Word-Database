        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と緊張のあまり聲がしやがれて、足がもつれ、よろよろと千鳥足で階段を昇り、見渡すと、そこは萬疊敷とでも云つていいくらゐの廣い座敷になつてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、よろよろ立つて、鬪ふのである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかは泣きそうになって、よろよろと落ちて、それからやっとふみとまって、もう一ぺんとびめぐりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかはがっかりして、よろよろ落ちて、それから又二へん飛びめぐりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　よだかはがっかりして、よろよろ落ちて、それから又、四へんそらをめぐりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんばん鐵のかぶとむし　月のあかりも　つめくさの　ともすあかりも　眼に入らず　草のにほひをとび截って　ひとのひたひに突きあたり　あわててよろよろ　落ちるをやっとふみとまり　いそんでかぢを立てなほし　月のあかりも　つめくさの　ともすあかりも眼に入らず　途方もない方に　飛んで行く。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野菊がよろよろと咲いている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が思わず立上ると、同時に花子のやつれた姿がよろよろと死の首で辛うじてささえられた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い銀の雲の下で愕いてよろよろしてゐる。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら土の中から一ぴきのうすい緑いろの小さな蛙がよろよろと這って出て来ました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫ぐらゐの髪のちゞれた子が列の中に居ましたがあんまり足が痛むと見えてたうとうよろよろつまづきました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子はよろよろして恐ろしさに手をあげながらうしろへ遁げようとしましたら忽ちその恐ろしいものの口がぴくっとうごきばっと鞭が鳴ってその子は声もなく倒れてもだえました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れた子はしばらくもだえてゐましたがそれでもいつかさっきの足の痛みなどは忘れたやうに又よろよろと立ちあがるのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一郎はまるでその赤い眼に吸ひ込まれるやうな気がしてよろよろ二三歩そっちへ行きましたがやっとふみとまってしっかり楢夫を抱きました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに一郎のかなしかったことはどうしたのか楢夫が歩けるやうになってはだしでその痛い地面をふんで一郎の前をよろよろ歩いてゐることでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎のすぐ前を楢夫がよろよろしてゐるのです。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大烏はよろよろ立ちあがって蠍を見て又｜身体をふるわせて云いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　蠍は二人につかまってよろよろ歩き出しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとではみんな顔色を変えてよろよろしましたが二人はこらえてしゃんと立っていました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　豚はあんまり悲しくて、辛くてよろよろしてしまう。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻草を纒ったような船夫達が何人も群れて、白く化粧した女を調戯いながら、よろよろと歩いていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波は、だるそうにうねって、きたない帆をかけた船が、岸のすぐ近くをよろよろと、とおって行きます。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私もよろよろしながら、それでも雪について歩いた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩手を頭のうしろに組んで、校庭をよろよろとさまよひ歩く法もおぼえた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
