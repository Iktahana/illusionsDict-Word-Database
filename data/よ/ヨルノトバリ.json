        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……夜の帳はやゝ迫る。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠っていよいよ尊げに見え、夜の帳に引き包まれて益々美しいその姿は「聖壇」から真正面にあった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つながら黒々と夜の帳に包まれている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の帳が降りかかると、再びその姿は見えはじめ、湖面に影像を落して、その後ろには陰影が顫へながらついて行く。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに開巻第一の歌　夜の帳にさきめきあまき星の今を下界の人の鬢のほつれよ　を取つて見よう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋の月世界はいと静かに涼しき夜の帳に睡り、黄金の魚一つその差延べし手に光りぬ、初秋の月。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夜の帳が下り、狼たちは丘で吠え、怖がった羊たちはハイタの足元に集まっていました。",
              "citation": {
                "source": "羊飼いハイタ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岳は夜の帳をかかげて、下界の子の歓びにほほえむように、この群集を見下ろしておる。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はそこからよくかへるたび振仰ぐと、いま歓語して来た許りの二階の窓の灯が、その灯かげに浮きだしてゐる細い手摺りが、さうしてさして広からぬ女の家全体が、おぼろ／＼の夜の帳りの中にいかにもいとしくなつかしく花やけき感じで見えてゐた。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の帳は迫っている。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その湖水さえ次第次第に、夜の帳に包まれて、灰色なすかと見るほどもなくやがて宵闇につつまれた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしていると、すぐ夜の帳が落ちかかるからな。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "完敗した億万長者は、あざが出来、めまいがするものの、無傷で立ち上がってみれば、プルマンカー急行の尾灯が夜の帳にだんだん消えて行く。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の帳の下には腐敗と退廃が隠れている。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天辺は私の部屋の窓の下にあたるのだが、夜の帳が落ちると早速近所の猫が皆集まってくる。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう間もなく、夜の帳も降りるでしょう。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごすれば、夜の帳はいよいよ迫って来て、村まで行くにさえ、差し支えそうになってきます。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の帳が降りた後、一人の女の人がベッドの近くに置き忘れた椅子を取ってこようと中に入ったのですが、叫び声を上げて飛び出してきました。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが大門を入ったときには、もうまったく夜の帳が下りていた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "土浦に着いたら、もうすっかり夜の帳が下りていた。",
              "citation": {
                "source": "遁走",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の帳はふかくおりて徳川方の陣地はすでに見えなくなったが、すぐ前面の人穴城には、魔獣の目のような、狭間の灯が、チラチラ見わたされた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、嫁方の庭燎の火を、途上で、こちらの脂燭に移し取った騎馬の使者は、それを先に持ち帰って、初夜の帳の燈台に点火しておく。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
