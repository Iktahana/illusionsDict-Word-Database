    "definitions": [
      {
        "index": 1,
        "gloss": "to be absorbed in reading",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのおかげで私は電車の中で難解の書物をゆっくり落ち付いて読みふける事ができる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家事の手伝いも、花壇の手入れも、お琴の稽古も、弟の世話も、なんでも、みんな馬鹿らしく、父や母にかくれて、こっそり蓮葉な小説ばかり読みふけるようになりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うろうろうろうろ読みふける。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん高級な読書の仕方は、鴎外でもジッドでも尾崎一雄でも、素直に読んで、そうして分相応にたのしみ、読み終えたら涼しげに古本屋へ持って行き、こんどは涙香の死美人と交換して来て、また、心ときめかせて読みふける。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し眉根を寄せながら、手紙に読みふける木村の表情には、時々苦痛や疑惑やの色が往ったり来たりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を借りて来て読みふける、新聞だけは読まずにはゐられない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私が当時彼らの精神的雰囲気を作っていたヘルデルリンを初め、ニーチェ、キェルケゴール、ドストイェフスキーなどに深い共感をもって読みふけるようになったのは、マールブルク大学に移って、ハイデッゲル教授について学ぶようになってからのことである。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七八年にＴＲＳ―80を手に入れたケイパーは続いてアップル※も買い求め、関連の雑誌に読みふけるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私が、何時でも、貴女の書かれたものに接する度に、貪る様に読みふけるのです。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みふける塚田を思ひやつてのことであらう。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方にはそこに置いてある新版物を見つけて当時評判な作者｜仮名垣魯文の著わしたものなぞに読みふける客もあれば、一方には将棋をさしかけて置いて床屋の弟子に顔をやらせる客もある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物に読みふけるもの、編物に余念のないもの、雑談に興じるものなど。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（腰をおろして読みふける）ソーニャ　（テーブルに向って腰かけ、帳簿をめくる）じゃあ、ワーニャ伯父さん、勘定書から始めましょうね。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "久我が予知したように、その後、葵は召喚されることもなかったので、毎朝、ゆったりした気持で、新聞に読みふけることが出来るようになった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日、参考書を読みふけることもあり、たまに妹二人を誘つて映画をみに行くこともあつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と手ずから重衡の手紙を開くと、むさぼるように、読みふけるのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験というものがある以上、片方の耳では、講義も聞いておかなければならず、それに、人に知られず読みふけるところに、つまみ食いのたのしさに似た不思議な魅力があったのかもしれない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神秘宗教だとか、心霊学だとか、妙な本ばかり読みふけるものだから、つまらない夢を見るのだ。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食済むと伊原青々園の「演劇談義」に読みふける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく寐言のやうなることのみよみふける哥人の多きより、すこしも学才ある人などは、歌をたゞはかなきものに思ひうとんじ、たけきことゝは、詩にのみ赴くめり。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
