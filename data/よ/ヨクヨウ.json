[
  {
    "uuid": "e9de2c87-6365-50b8-9018-2e22079b11c7",
    "entry": "抑揚",
    "reading": {
      "primary": "よくよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
