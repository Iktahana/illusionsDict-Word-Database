          "standard": [
            {
              "text": "歴史の中には、貧困や文化的な背景から幼児殺しが行われた悲しい記録がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会において、幼児殺しは重大な犯罪であり、厳しく罰せられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "報道で幼児殺しの事件を知り、その動機や背景に深い悲しみを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "デトロイト市の探偵が同市郊外に起った二件の幼児殺しに関する一件書類を持って派遣されて来ていて、この審問に立ち合ったが、それは何うやら尊敬す可き長老の働きではなかったようだ。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
