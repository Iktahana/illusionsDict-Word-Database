    "definitions": [
      {
        "index": 1,
        "gloss": "to read (a book, etc.) over again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "結局、「赤と黒」を読み直すことがその都度の結論だが、僕は「ジュリアン・ソレル」という小説を書こうと思う。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は煤烟全部を読み直す暇がないので、判然した判断を下すに躊躇するが、当時の新聞は連続して欠かさず眼を通したものだから、未だに残つてゐる、其時の印象は、恐らく余に取つて慥かなものだらうと考へる。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから、また、ぼちぼち八犬伝を読み直すのだから。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赧くなりながら一生懸命に読み直せば読み直すほど、みんなは笑いくずれる。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってから一度読み直すと、すぐ書留にして山野に送った。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――海へ、仮名を読本にある通り正確に、又漢字は間違わぬよう、自分で読み直す習慣を厳重に申し送るべし。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時読んだものを年取ってから読み直すということはごく普通の現象だ。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一遍読んですぐ又読み直すという人もいる。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し何か書いて、読み直すと、どうだ、まるで口まねになつてしまつてゐるのだ！",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の給仕が気を利せて『芳賀さん』と読み直す。",
              "citation": {
                "source": "検疫と荷物検査",
                "author": "杉村楚人冠",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、努めて、上演後刊行された戯曲を読み直すやうにしてゐた。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文句にギクリとして、初瀬は、それを読み直す代りに、その頁をひろげたまま昭和十七年の一冊を手にとつて、全く無意識に中ほどのところをバタリとひろげた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝手紙をもう一度読み直す。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "保枝は、この手紙を、晩にもう一度読み直すつもりで、帯の間へはさみました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから改めて読み直すと市川｜海土蔵だ、海土の土の字の下へ点を打ったりなんかしてごまかしていやがら。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間私はぼんやりして、縁側から狭い庭でも眺めるか、または寝床の中でざっと眼を通した新聞を、も一度読み直すかするより外はない。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学の研究を女などに妨げられてはならぬ』と思ひ直して読んで来た処をまた始めから読み直すと少しは解つて来る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こう書いて見たが、読み直すと何だかむずかしくって解らない。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の鋭くない私が、読み直すひまもなくただ書き流したものだから、そのうちには定めて矛盾があるでしょう。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の急いた彼には、それを読み直す暇さえ惜かった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らの身体で記した言葉であるはずなのに、訳了したしばらくのちにその文を読み直す自分は、どこか別の世界に迷子になったかのようでした。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "千種は千種で、もう一度それを読み直す勇気もなく、激しい動悸で息がつまりさうなのを、顔色に出すまいと、椅子の背に片肱を支へて、横向きにそつと腰をおろした。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今度珍しく読み直す機会に恵まれ、自分の踏んできた経路を鳥瞰図的に見る事が出来て、自分ながらちょっと面白かった。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を出て行く二人の後ろ姿を見送りながら、頭陀袋から手紙を取出して読み直すと、「――名月の宵、箱根間道太閤道の辻堂にて、非業に相果つる五或は七の屍を見る可し、いずれも救い難き五悪の輩乍ら末期の引導頼み入るもの也――」と美事な筆跡で書いてあるのです。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔訳本を読んでいたときは感心しなかったのですが、こうして読み直すといけます。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "知るのはこの人が日頃たいせつにしまっている文章をあらためて読み直すことにあった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、自分の独創になったものだと信じてる楽句の中に、他の作曲家らの手になった断片が、むりやりにどうかこうか綴り合わせられてるのを、読み直すたびごとに見出したからである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先覚」をよみなおす。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを手伝ってとじ、序よみなおす。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
