        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "注意すべきことは、牧野さんは、予備科を終ってから、文学部の和漢文学科へ進まれたことである。",
              "citation": {
                "source": "牧野伸顕伯の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がロンドン大学予備科の教授に就任したのは、一八七〇年の暮で、爰でも彼の人格と、学力とは、彼をして学生達の輿望の中心たらしめた。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央大学の予備科に一、二か月席を置いたのも一緒であった。",
              "citation": {
                "source": "初めて西田幾多郎の名を聞いたころ",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と蟹はよびかけました。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年生たちによびかけられるのがうれしいからくぐったのであります。",
              "citation": {
                "source": "一年生たちとひよめ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とよびかけたりします。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、その男は、マタンによびかけました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめから今にいたるまで、「太郎君」というれいぎ正しいよびかたをつづけている人が、ただひとりあった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、かた一方のがけの上からむこうのがけにむかって、「おーイ」とひと声よびかけると、それがこだまになってこちらへ帰ってくる。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日目に支那の兵が退いてく時つかめえられてしよびかれた。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのめくは髪のなよびか、衣の香か、えこそわかたね。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おばあさんは泣き／＼よびかけました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はアラビヤ人の遊牧民に仮装してゐましたので、彼の方からよびかけられなかつたら、私は全然気づかないでしまふところでした。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、おゝ船長と、全で毎日会つてゐる人にいふやうに、のんきに私をよびかけました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うッふ、ねずみはきいきい歯ぎしりして、わらくずや木切れに、どんなによびかけたことでしょう。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルダはもっと大きなこえで、よびかけてみました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　京子は後からよびかけた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　よびかけられて振り向くと、三津子さんはパラソルをつぼめて、その百日紅の木かげに立っていました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体どうしたんですか、サチ子さん」　僕はたまらなくなってサチ子によびかけた。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛語とは、慈愛のこもった言語をもって、他人によびかけることです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻の様にそう思うと、お婆さんは眼鏡をふきながら、　仙ちゃんかえ、お入りよ　孫をよびかける様に云った。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二甞ては、吾もなよびかのあえかの人と相知りて、世にうつくしき事榮のあまた夜にこそ醉ひにしか。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、山よ、酒よ、水よ、とよびかけずにゐられない私。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまりこれは読者のきわめて小ブルジョア的興味によびかけ何枚かの銀貨を釣り出そうとする、ブルジョア婦人雑誌つきものの猫とそのシッポの如き題目なのであります。",
              "citation": {
                "source": "ゴルフ・パンツははいていまい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "保守派、反対派は欣喜雀躍してツルゲーネフのそのよびかたを、それから適用するようになった。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の目ざめた婦人大衆は、自分たちの真心からのよびかけが、世界の姉妹たちによって聴かれることをどんなに願っているでしょう。",
              "citation": {
                "source": "国際民婦連へのメッセージ",
                "author": "――「女性を守る会」から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、全世界の婦人によびかけた。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然、子供たちは、お母さま、ああちゃん、とそれぞれのよびかたで母に向って、おじさんからきかれたことをそのままくりかえして、なあに、ときいた。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一月に自分の手から一票一票と三百万の票を党におくった人々の心に「風知草」が描いた代々木本部創立当時のおもかげは、何のよびかけももたないだろうか。",
              "citation": {
                "source": "事実にたって",
                "author": "――一月六日アカハタ「火ばな」の投書について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても「死後に語ってきかせたもの」などと言うのは大変｜可笑しいことに聞えるかも知れないが、これも事情を申して置かねばならないことであるが、諸君もかねてお聞きおよびかと思う例の心霊研究会で、有名なるＮ女史という霊媒を通じて、作者がその亡友から聞いた告白なのである。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
