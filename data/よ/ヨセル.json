[
  {
    "uuid": "080e374a-e511-5b57-a2ef-b79b76b062fe",
    "entry": "寄せる",
    "reading": {
      "primary": "よせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
