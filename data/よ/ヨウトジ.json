          "literary": [
            {
              "text": "何か親密な話を切り出す機会を捉えようとじれているらしい。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "由良はこれはいよいよ信者も性根を出しだしたと思ったが、まさか蹴りつけるわけにもいかないので、どうすることかしばらくさせるままにさせてみようとじっとしていると、だんだん信者は由良の片足を高く上の方へ上げていった。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っぱずして、投げ退けようとじっと気合を窺いながらも、胸の中は煮えくり返った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、懸命に力をしぼってもがき遁れようとじれながらも、対手はそも何者であろうかと、必死に考えずにおられなかった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
