[
  {
    "uuid": "5de1be58-6f88-58b9-9f40-18e489758f80",
    "entry": "黄泉",
    "reading": {
      "primary": "よみ",
      "alternatives": [
        "こうせん"
      ],
      "is_heteronym": false
    },
    "grammar": {
