        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外もあんまり涼しくはなかつた、家の中よりか涼しいくらゐであつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりかまだ歩いてゐた方がマシである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧の通りに僅々七十年間に、ソクラテスからジイド迄読破することが出来たといふのは、もとより負けじ魂に由るものであるが、注意すべきは、その負けじ魂といふよりかも、我等が粗朴であつたからである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……王がよろめき倒れてかたわらの石によりかかり、神の助けを祈っているところへ敵将が来て首と腹を傷つけた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらあ、一月娑婆に居りあ、お前さんなんかが、十年暮してるよりか、もっと、世間に通じちまうんだからね。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の坂だらけの町を、あるかないか當てにならない宿を求めて歩き※はるのでは第一折角保養に來た本來の目的に合はない、それよりか寧ろ東京の宅の縁側で咲殘りのカンナでも眺めて欠伸をする方が遙かに有效であらうと思つたのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色絹の簾の縁がしつとりと濡れて居り、簾の生地の竹の手觸りの冷え／″＼しさに、目をとめて見れば、いつの程よりか外には時雨のやうに冷い細雨がしとしとと降つて居たのである。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の道を通る人もないので、私は安心してその柱によりかゝつた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも求婚の競争者が相当ございましてね」　という意味のようなことを話しかけると、妻は「まあまあ、そんなお話、どうでもいいじゃございませんか」「それよりかまだ山の中でおとうさまがお見残しのとこもございましょう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあの姉弟はもうつかれてめいめいぐったり席によりかかって睡ってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふではあの一ばんの姉が小さな妹を自分の胸によりかゝらせて睡らせながら黒い瞳をうっとりと遠くへ投げて何を見るでもなしに考へ込んでゐるのでしたしカムパネルラはまださびしさうにひとり口笛を吹き二番目の女の子はまるで絹で包んだ苹果のやうな顔いろをしてジョバンニの見る方を見てゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいの高い二本のでんしんばしらが、互によりかかるようにして一本の腕木でつらねられてありました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二は、家の前の檜によりかかって、考えました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして私達の愛撫の花はおそらく私達よりか、それを咲かした土地よりか、生きながらへる。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、助力し合つて、夢みたり、失せやすい思ひ出をすこしでも引きとどめたりすることの、何んといふよろこび……思ひ出はすぐそばにやつて來て、夏のときよりかずつとよくそれが見られたものだ。",
              "citation": {
                "source": "冬",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一瞬間、橋の欄干によりかかりながら、立つてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その側の安楽椅子によりかかって寝ているイサックの黒い顔に未来の文明が浮き出ていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　摩天楼の鏡の面からつやぶきんをとるために、私は、藍色のカーテンで市街に向ってひらいた窓を閉ざすと、「――それよりか、君のコオセット・ボタンがいくつあるか計算さしてもらいたいもんだね。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯貴人の像をイジくるよりか、それはわが党の『加と男』のために、じゃアない、ためにじゃアない、「加と男」をだ、……をだをだ、……。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "義母は一寸と其方を見たばかり此時自分は思つた義母よりか老婦人の方が幸福だと。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君がこれを読むよりか、僕がこの題で話した方がよさそうだ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りは登りよりかずっと勾配が緩やかで、山の尾や谷間の枯れ草の間を蛇のようにうねっている路をたどって急ぐと、村に近づくにつれて枯れ草を着けた馬をいくつか逐いこした。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來志村は自分よりか歳も兄、級も一｜年上であつたが、自分は學力優等といふので自分の居る級と志村の居る級とを同時にやるべく校長から特別の處置をせられるので自然志村は自分の競爭者となつて居た。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来志村は自分よりか歳も兄、級も一年上であったが、自分は学力優等というので自分のいる級と志村のいる級とを同時にやるべく校長から特別の処置をせられるので自然志村は自分の競争者となっていた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州よ我子よと呼びつつ走りゆくほどに顔のなかばを朱に染めし女｜乞食いずこよりか現われて紀州は我子なりといいしが見るうちに年若き眼に変わりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "話してしまってから、さもがっかりしたように枕によりかかったまま目をねむって黙ってしまったので、長座は悪いだろうと思って遠慮してすぐに帰って来た。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
