        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして三月の後には区立病院の産婆養成所の入学試験に及第した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九月、川上音二郎の妻貞奴、女優養成所を開く。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女教師の中、誰と誰とは女高師を出たといふ觸込で來てゐるが、實は臨時教員養成所を出たゞけであること。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有一館は政府の圧迫を受けて、解党を余儀なくせられた自由党の過激派の手で経営せられた壮士の養成所であった。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市中はこんなあらゆる種類の「不良養成所」である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、悪行をすすめる養成所と云ったようなものが、此の世には沢山あるので御座います。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出発」は教員養成所の老猾な旧師を中心に、若い人々の真摯な探求心を殺し、卑屈な人生の出発をよぎなくされた青年の苦悩を真面目にとりあげている。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば教員養成所というところが共産主義という言葉ばかりで脅えている。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは観念的である、共産主義という言葉を一つもしらないでもよりよく生きたいと願っているのはすべての人の心であること、主人公のその本心にじっくり心をおいて生活のなかでめぐりあってゆく経験として教員養成所のことも描くべきであった。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校といふ學校は、皆鼠賊の養成所で、教育家は、好な酒を飮むにも隱密と飮む。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校といふ学校は、皆鼠賊の養成所で、教育家は、好な酒を飲むにも隠密と飲む。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたし、病院へは入らんと、うちから養成所へ通ふけに。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うちから養成所へ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦の養成所は、郡内の村々を、一學期毎に移動し、自轉車で通ふことが出來、時間も午後一時から三時か四時迄であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お道はその小さな胸で、家にゐて養成所へ通ふ場合と、病院へ看護婦見習で入る場合との、負擔の大小、自家に及ぼす影響について比較してみただらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は豫定通り、この春から郡の看護婦の養成所に通つてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "教科書は以前から縣下だけでも統一なく、學校によりまた養成所によつて、まちまちなものを使つてゐるが、そのうちに警視廳の防疫課長だつた某氏の著が段々に一般化して行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一昨年、縣の試驗官の一人であるＮが、看護學の本を書き、早速それを採用した某養成所の生徒はその年の試驗に好成績であつたが、その他の養成所は一樣に成績不良といふ事が起つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうな問題を試驗に出したのは、自分の本を賣らうとする心からだと、養成所の教師の間にも非難があつたが、試驗が通らぬといふことは實際問題だ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お道の通ふ郡の養成所はもとのままだつたが、さういふことは直に生徒の間に擴まつて、皆不安がつてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "養成所の教科書のほかにＮのものを買つて持たずにはゐられなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學校からお道と一緒で、今度もやはり一緒に養成所に通ひ出した少女がゐるが、お道の所へ遊びに來てその不安を云つてゐるのを駿介は聞いた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しいなかにも忙しい時には、お道は自分から養成所を休むことがあり、皆もすまないと思ひながら、默つてさうしてもらふのほかはなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "養成所は休まねばならぬ日が多かつたが、それでも卒業の時には優等で、賞として檢温器をもらつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の工場学校と云えば体のいい徒弟養成所か、さもなければ製糸所の女工さんなどをプロレタリアの女として目ざまさない為に、いろんなブルジョアくさい女学校の型ばかりの真似をして、役にも立たない作文だの、活花だの、作法だので労働の中から自ずと湧く階級的な心持を胡魔化すのです。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツのカイゼルスウェールト温泉へ母と姉とで逗留したとき、フロレンスは二人の貴婦人たちが入湯や社交に日を消している間をぬけ出して、同地の看護婦養成所に三ヵ月以上も滞在した。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年にはナイチンゲール看護婦養成所を開設した。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相場師夫婦は眞の親も及ばない程千登世を慈んで、彼女の望むまゝに土地の女學校を卒業さした上更に臨時教員養成所にまで進學さしてくれたのだが、業｜半でその家が經濟的に全く崩壞してしまひ、軈て養父母も相次いで世を去つてしまつたので、彼女は獨立しなければならなかつた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "お巡さんに聞いたって、お巡りさんは、養成所の試験問題に無かったから、知らん、と答えるだろう。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
