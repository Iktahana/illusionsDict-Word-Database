[
  {
    "uuid": "869948f7-f41e-538b-8a5e-94f091943f31",
    "entry": "杳として",
    "reading": {
      "primary": "ようとして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "副詞"
      ],
