[
  {
    "uuid": "28e9f4db-4572-57bf-9b83-d5d736944c6e",
    "entry": "予備",
    "reading": {
      "primary": "よび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
