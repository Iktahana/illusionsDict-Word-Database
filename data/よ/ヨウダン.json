  {
    "uuid": "19fe1826-361b-5a87-815b-271b01bbef13",
    "entry": "溶断",
    "reading": {
      "primary": "ようだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
