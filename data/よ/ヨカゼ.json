        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夢のうちなる遠近法、夏の夜風の小鎚の重量、それ等は既になし。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は窓から心地よい夏の夜風を受けながら、口笛を吹いてた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の河沿いの道路に面した格子窓には風鈴が吊されて夜風に涼しい音を立てていたように思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪の望むままに一同で観覧車に乗り高い杉の梢の夜風に吹かれた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿つた野原の黒い土、短い草の上を　　夜風は吹いて、　死んだつていいよう、死んだつていいよう、と、　　うつくしい魂は涕くのであつた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダー、ダー、ダースコ、ダーダ、青い　仮面この　こけおどし、太刀を　浴びては　いっぷかぷ、夜風の　底の　蜘蛛おどり、胃袋ぅ　はいて　ぎったりぎたり。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かなよひで、どことはなしに青｜葉の香をにほはせたかぐはしい夜風が庭先から流れてくる。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで蒸熱かった此｜一室へ冷たい夜風が、音もなく吹き込むと「夜風に当ると悪いでしょうよ、私は宜いからお閉めなさいよ、」と客なる少女、少年の病気を気にする。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると夜風は涼し過ぎる。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その星の光を仰いでうっとりと突っ立っているうちに、薄ら寒い春の夜風が肌にしみて、彼は急に死ぬのが恐ろしくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の夜風が戸外の杏の枝を揺がしていた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（無上｜甚深微妙法　百千万｜劫難遭遇　我今見聞得受持　願解｜如来第一義）　力いっぱい声かぎり、夜風はいのりを運び去りはるかにはるかにオホツクの黒い波間を越えて行く。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり夜風が寒い晩だのに、男は羽織も着ず帽もなしで、いかにも身すぼらしいふうをしていた。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダー、ダー、ダースコ、ダーダ、青い　仮面この　こけおどし、太刀を　浴びては　いっぷかぷ、夜風の　底の　蜘蛛をどり、胃袋ぅ　はいて　ぎったりぎたり。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「夜風さかまき　ひのきはみだれ、月は射そゝぐ　銀の矢なみ、打ぅつも果てるも　一つのいのち、太刀の軋りの　消えぬひま。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の隙間や床下から寒い夜風が吹きこむので二人は手足も縮められるだけ縮めているが、それでも磯の背部は半分外に露出ていた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套を着ない懷に夜風がしみて空の星が交る／″＼近くなつたり遠くなつたりする樣に光る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は身にしみ通る夜風に顔をしかめながら、八時の夜行に間に合ふやうにと東京駅に急いだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽坂の往来はびしよ／＼にぬかるんで夜風が寒かつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉蜀黍は穗も葉も枯れ切つて十坪程の地面に立つてゐたが、その穗先きは少し吹きはじめて來た夜風に逆つて、小ぶるひにふるへてゐるのが空に透いて見えた。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には滴る星の光が縷められ園林の葉枝は夜風を迎え始めた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夜風も厭わなければいけない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突張りの白木の柱が、すくすくと夜風に細って、積んだ棚が、がたがた崩れる。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……上衣無しで、座敷着の上へ黒縮緬の紋着の羽織を着て、胸へ片袖、温容に褄を取る、襲ねた裳しっとりと重そうに、不断さえ、分けて今夜は、何となく、柳を杖に支かせたい、すんなりと春の夜風に送られて、向うから来る姿。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのお弱い貴女が、また……何で、今時分、こんな処に夜風は毒の、橋は冷えます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪｜颯と夜風に乱して白き衣服を着けたるが、月明りにて画けるごとく、南をさして歩むがごとし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、夜風も、白露も、皆夢である。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼神に横道なし、と云う、情に抵抗う刃はない筈、」　枢をかたかた、ぐっと、さるを上げて、ずずん、かたりと開ける、袖を絞って蔽い果さず、燈は颯と夜風に消えた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、会社のほうでは穏便がいいというので、むろん片手落ちの裁判だけれど、私が因果を含められて、雇を解かれたのさ」　白糸は身に沁む夜風にわれとわが身を抱きて、「まあ、おきのどくだったねえ」　渠は慰むる語なきがごとき面色なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の文よ、そよかぜよ、ただ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
