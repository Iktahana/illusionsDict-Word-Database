    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to compose (a Japanese poem)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが出来ないばかりに、私は涙ぐんで蹲りながらおまえの歌を詠む。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず歌幸を祈らばやとて詠む。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにすぐ古くさい歌やなんか思い出すしまた歌など詠むのろのろしたような昔の人を考えるからどうもいやだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無名の青年　――こんな歌を詠むあなたが人情を解さぬと云う筈はありません。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはここへ来てからの、心覚えの童謡を、明が書留めて朝夕に且つ吟じ且つ詠むるものだ、と宵に聞いた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸作は食卓越しにわたくしの腕を揺り、「鐘の音は、もう済んだ」と言って、手を離したわたくしの耳を指さし、「歌を詠む参考に水鳥の声をよく聞いときなさい。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詠むべき目的物は結句にいふといふのが先づ原則である。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず同志の励みになるものじゃそうな」「貴公は皆の中で一番学問が出来とるけに、嘸いくつも詠む事じゃろうのう」「ウム。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、眼前の景物を題に一首二首と詠むことになりました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "温泉宿の庭",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌に對する私の考へを極く簡單に言ふと、歌は自分を知りたいために詠むもの、守り育てたいために詠むもの、慰め樂しませ勵ますために詠むものと私は思つて居る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "歌と宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の曾つて詠んだ一首に、わがこころ澄みゆく時に詠む歌か詠みゆくほどに澄めるこころか　といふのがある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "歌と宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそんな夜に詠む歌なども平凡ではなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌を詠む才なども豊富であろうとは思われない。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の恋愛をする者の詠む歌には相手を悪く見て仇人という言葉を三句めに置くことにして、それをさえ中心にすれば前後は何とでもつくと思ったものらしい」　などと源氏は夫人に語った。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに和歌に猴を詠む時もっとも多く用いるマシラなる名は古来摩斯※の音に由ると伝うるはいぶかし。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌は兎に角として俳句は、僕は男の歌も嫌ひですが、歌なんか詠む女も詰らないと思ふね。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の家は高山一の老舗で、娘は歌も詠むし詩も作ると云って一軒の料理屋に連れて行かれた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてすると、高山一の庭のいい家を見せようと云って、その歌を詠む娘や芸者たちを引率した儘また他の料理屋へ行った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その男がうめくように一句｜詠むじゃないか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の宵やほのかにゆらぐ恋心、京弥これを詠む、とはどんなものぞよ」　パッと紅葉がその頬に散ったに違いない。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見てぞ仲麻呂のぬし「我が國にはかゝる歌をなむ神代より神もよんたび、今は上中下の人もかうやうに別れ惜み、よろこびもあり、かなしみもある時には詠む」とてよめりける歌、「あをうなばらふりさけ見れば春日なる三笠の山にいでし月かも」とぞよめりける。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "「辞世にまで猿の眼を詠むようでは、やっぱり猿の一件が祟っていたのかも知れない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ來たばかりで、朝に夕に故郷の母のことを思つて打しをれてゐると、そこにその時分丁度十三四で、年のわりに聰明で歌を詠むことが上手で、多い同胞の中ではことに器量の好い窕子がそつと寄つて來て、『お前、泣いてゐるの……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻、お前は歌を詠むのじゃな」「父さまに習うたけれど、わたしも不器用な生まれで、ようは詠まれぬ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この道をも私は通る」以下の詩、及び淫売婦に贈つた数篇の詩篇をよむものは、どんなに長い間、彼が霊的に苦しんで居たか、そして今の彼がどんなに健全で高潔な愛の信仰の上に立つて居るかを知るであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の暇あなた本よむです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ本をよむ、話たくさん、私にして下され』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井川の水｜涸れ／＼にして蛇籠に草離々たる、越すに越されざりし「朝貌日記」何とかの段は更なり、雲助とかの肩によって渡る御侍、磧に錫杖立てて歌よむ行脚など廻り燈籠のように眼前に浮ぶ心地せらる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
