    "definitions": [
      {
        "index": 1,
        "gloss": "four people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "佐竹、太宰、佐野次郎、馬場、ははん、この四人が、ただ黙って立ち並んだだけでも歴史的だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸知つた程度の人が、五人ゐはしたが、その中の四人はＩの尊敬者であり、一人は、朴直な粧ひをした通人で、愚直な私など相手にして呉れるべくもなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯殿でまだ沸き切らぬ湯をチヤブチヤブさせて遊んでゐる四人の小さな子供等こそは、実は一番喧しかつたのだが、長男に就いての一件の起こつてる時なので、他の四人の子供は何だか可愛い気がして、何時ものやうにとても「やめろ！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで妻君は一流の三四人中に数へらるべき所謂スター女優なのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人の人が、追悼文を書いてゐるのですが、その四人の人の名も、私は知つてゐません。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人とも、早稻田の先生なのでせう。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　四人のひとを尊敬する　四月廿二日の朝、私は、こんど出版する豫定の「愛と美について」といふ書き卸し短篇集の校正刷を、床の中で受け取つた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人のひとが私のいままでの惡評を押しのけて、敢然と投票した。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの四人を忘れては、ならない。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの四人を永久に尊敬する。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう言つて、けれども、お情、と言ひ切つてしまつては、まじめに投票して下さつた四人の人に、すまないぞ、と思つた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の晃平を主として、四人の猟師を雇って出発した。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石は人の手入れを経ない、全くの自然石で、不思議にも中はおのずと、コ字形に刳ぐられていて、濶さは一坪半ぐらいはあろう、四人ぐらいは潜れそうであるが、うっかり立てば頭を打ちつけるほどに低い。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから第五、第六の「あたかも」が、未だ続いて挙げられるが、もうその点は打ち切って、私たち同行四人が、シャスタ山に登ったのは、大正八年（一九一九年）九月十一日のことで、未だこの山の草分けを記念するための、シッソンの名が残っていた時分であった。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "終りに、この一文を、同行四人の中、馬術の達人であった神田憲君の霊前に献げる。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬ間に、爪先上りとなって、馬返しまで着くと思いがけなく村の男女が、四人ばかり籠をしょって、こっちを見ている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の子供等と、四人の大人にとつて、二ヶ月以上も、井戸から水を取り上げた事実は、この二人の借家人の、左まで鋭からざる神経にも相当な影響を及ぼした。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "デッキには新聞紙を敷いて三四人も寝ていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服、私服の警官隊が四人、前後からドカドカッと入って来た。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ内務省と大きく白ペンキでマークしたトラックが一台道を塞いで止まつてその上に一杯に積んだ岩魂を三四人の人夫が下ろしてゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸りのバスが澁川に近づく頃、同乘の兎も角も知識階級らしい四人連の紳士が「耳がガーンとした」とか「欠伸をしたらやつと直つた」とか云つたやうな話をして居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ内務省と大きく白ペンキでマークしたトラックが一台道を塞いで止まってその上に一杯に積んだ岩塊を三、四人の人夫が下ろしていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカッパにウエーヴをかけない支那女学生が三四人、巧いフランス語で話し合っている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は小田原在に在る穀物商で、妻も娶り兄妹三四人の子供もできたのだが、三十四の歳にふと商用で東海道へ足を踏み出したのが病みつきであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは本部へ行ったり、停車場まで酒を呑みに行ったりして、室にはただ四人だけでした。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺ吉だの三、四人は、もう泳いで、さいかちの木の下まで行って待っていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つはどれにするかな　もう四人だけ渡っている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛石の上に両あしを揃えてきちんと立って四人つづいて待っているのは面白い。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにん――　十から十三四ぐらいまでの男の子が鉄柵の前へ並び、小さい木の磨台をおっぴらいた両脚の間へ置いて靴磨きをやってる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにんはサンタクロースがとりわけ気にかけている妖精たちでした。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
