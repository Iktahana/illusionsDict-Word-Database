        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またよき人の説ならんからに多くの中には誤りもなどかなからん。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知りたる女にあらねど、うつくしき顔の笑をば含みたる、よき人と思いたれば、怪しまで、隠れたる児のありかを教うるとさとりたれば、いそいそと従いぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが身ひとつのための貪慾に非ず、名知らぬ寒しき人に投げ与えむため、または、かのよき人よろこばせむための金銭の必要。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知りたる女にあらねど、うつくしき顔の笑をば含みたる、よき人と思ひたれば、怪しまで、隠れたる児のありかを教ふるとさとりたれば、いそいそと従ひぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小紋の小袖に丸帯と思えば、寺には、よき人の嫁ぐならいがある。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき人の男につきて下りて住みけるなり。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "『祖母さんよき人です。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして神輿が御旅所にある一週間は、參詣人が引きもきらない、この一週間に無言詣でをしたものは、どんな願の筋でも叶へられるといふことで、家を出るから往復の道すがらどんなことがあらうとも物を言はないで、お詣りするよき人もある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき子であれ、よき夫（或は妻）であれ、よき父であれ、それ以外によき人間となる常道はない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩馬場孤蝶氏は大杉君を「よき人なりし」といっているが、僕も彼女を「よき人なりし」野枝さんといいたい。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "СССРの新社会制度が　此世にもたらしたよき人間的美の一つとして、自分はそれを感じるのであった。",
              "citation": {
                "source": "無題（七）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其余十人｜許もよき人来候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "66よき人よ、盃と酒壺を持って来い、水のほとりの青草の茂みのあたり。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "この壺に手がある、これこそはいつの日かよき人の肩にかかった腕なのだ。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「涙は理智の薄明り、感情の灯し火」とうたえる久米、真白草花の涼しげなるにも、よき人の面影を忘れ得ぬ久米、鮮かに化粧の匂える妓の愛想よく酒を勧むる暇さえ、「招かれざる客」の歎きをする久米、――そう云う多感多情の久米の愛すべきことは誰でも云う。",
              "citation": {
                "source": "久米正雄",
                "author": "――傚久米正雄文体――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又けしてきりよふのよき人をつれになりたりいたしたれバならぬ事なり。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにもっともよき人を選んでね」「薹がたってはお終いだから……」「まア、有難う！",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき人は悲しみ淡し我がどちは死と涙をば並べて思ふ　善人賢人の悲しみを見るに淡々として水の様だ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "本居は、　　唐人と人はいへども、唐人のたぐひならめや、孔子はよき人と申して居る。",
              "citation": {
                "source": "東漢の班超",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "本居は、聖人と人はいへども、聖人の類ならめや、孔子はよき人。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "折返して今度は伯父よりの手紙に、学資を失いて活版職工となりしよし驚き気遣うところなり、さらに学資も送るべし、また幸いに我が西京に留学せし頃の旧知今はよき人となりて下谷西町に住うよし、久しぶりにて便りを得たり、別紙を持参して諸事の指揮をその人にうけよと懇ろに予が空想に走する事を誡められたり。",
              "citation": {
                "source": "良夜",
                "author": "饗庭篁村",
                "note": "青空文庫"
              }
            },
            {
              "text": "○いくらでもよき人を雇えるならとにかく、我々中以下の生活では、主婦と云う地位が、実にわずらわしい。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき人をうしないたりとて。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらはあとにくるもののために、もっとも正しき人となり、もっともよき人となるべく努力しなければならん。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん髪はむすばず結はず、土に曳き尋する藤を挿してゆけ、かぐろの髪と紫と大路に浪をなさむ時、みやこをとめはさうぐるひ、千人にわけて与へよと、おん跡おはむそのなかに、われもまじりて西鶴の経師が妻のふりに似る、よき人得よと祝ぎて帰らむ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金属も火も知らぬ、かよわき中の強さ、よき人の稀に持つ素顔の気高さ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし若し貴族趣味といふものが、平俗凡庸卑劣淺薄を憎み、よりよき人の世を憧憬する事を指すのならば、自分は確かに貴族趣味だ。",
              "citation": {
                "source": "貝殼追放",
                "author": "向不見の強味",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人類に對する親しい感情」を多分に持ち、且人類の醜惡なる事實の力強さに壓迫を感じて惱む自分は、どうかしてよりよき人の世の出現を希望すると同時に、醜惡なる人間の影を潛める事を熱望してゐる。",
              "citation": {
                "source": "貝殼追放",
                "author": "向不見の強味",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきひとの側へにありてなにをかたらむすずろにもわれは思ふゑねちやのかあにばるをかくもやさしき君がひとみに海こえて燕雀のかげもうつらでやは。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "種子を哀しめ、よきひとよ、冷たく、小さき芥子のたね、その一粒に心せよ、歔欷けかし、日の光。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
