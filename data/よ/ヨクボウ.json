[
  {
    "uuid": "67725cd0-9913-5f23-9b70-912e674272c1",
    "entry": "欲望",
    "reading": {
      "primary": "よくぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
