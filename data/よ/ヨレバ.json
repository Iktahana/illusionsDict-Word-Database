        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しま、私の貧弱な歴史的知識によれば、精神を閉却した時にその社会は幸福ではなかつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の告白によれば、自分の良人に対する真の愛は、その時初めて起ったという。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の臆斷する所によれば、最近の芥川君はたしかに一轉期に臨んでゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし芥川君は――自分の見る所によれば――實に詩を熱情する所の、典型的な小説家にすぎなかつたから。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私の信ずる所によれば、彼の自殺における「漠然たる不安」の一つは、近く來らんとする彼自身の心境的革命にまで、名状しがたき不安の困憊を感じたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋新吉は私によれば良心による形而上学者だ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考えるところによれば、「恋さまざま」の「さまざま」は「散り散り」の意味であろうと思う。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーペンハウエルの説によれば、詩人と、哲学者と、天才とは、孤独であるように、宿命づけられて居るのであって、且つそれ故にこそ、彼等が人間中での貴族であり、最高の種類に属するのだそうである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によれば今も同じ東京に居るかも知れぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に青木原一帯の丸尾（先人の説によれば「転び」のなまりならんという）を超越して、多くの側火山と噴気口を行列させている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハーシェルの調べた結果によれば太陽は半時間に一万マイルくらいの速度で飛んでいる、一日たてば四十八万マイルだけ目的地に近寄ってはいるがその行先はあまりに遠い虚空の果で、百年や二百年の短日月では一向近寄ったようにも見えぬのである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一説によれば chicane の略で裁判沙汰を縺れさせる「繊巧な詭計」を心得ているというような意味がもとになっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "他説によれば chic の原形は schick である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『昔々物語』によれば、昔は普通の女が縫箔の小袖を着るに対して、遊女が縞物を着たという。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず田辺尚雄氏の論文「日本音楽の理論附粋の研究｛４｝」によれば、音楽上の「いき」は旋律とリズムの二方面に表われている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ボオドレエル自身の説明｛９｝によれば、「ダンディズムは頽廃期における英雄主義の最後の光であって……熱がなく、憂愁にみちて、傾く日のように壮美である」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた他の半面の考え方によれば、科学者の知識は「物自身」の知識ではなくて科学者の頭脳から編み上げた製作物とも云われる。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　予報の可能不可能という事は、考え方によればあまりに無意味なる言葉なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで前の物質の定義によれば物質のように見える。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
