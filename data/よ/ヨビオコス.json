[
  {
    "uuid": "3cf0dedf-007f-5898-8cd7-ea7525a48838",
    "entry": "呼び起こす",
    "reading": {
      "primary": "よびおこす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
