[
  {
    "uuid": "ec20ff37-c228-59cb-bd3b-d2383b44ec0c",
    "entry": "横",
    "reading": {
      "primary": "よこ",
      "alternatives": [
        "ヨコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
