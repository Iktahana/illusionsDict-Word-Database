    },
    "definitions": [
      {
        "index": 1,
        "gloss": "personal ornament (adorned with gemstones, and usu. worn by the nobility in ancient India or adorning Buddhist statues)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）　瓔珞をかざり黄金の太刀をはいた一人の立派な青年が外の疊石の青い苔にすわってゐた。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上がったものは結局「言語の糸で綴られた知識の瓔珞」であるとも云える。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な瓔珞をかけ黄金の円光を冠りかすかに笑ってみんなのうしろに立ってゐました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫がやはり黄金いろのきものを着、瓔珞も着けてゐたのです。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "端厳微妙のおんかおばせ、雲の袖、霞の袴ちらちらと瓔珞をかけたまいたる、玉なす胸に繊手を添えて、ひたと、おさなごを抱きたまえるが、仰ぐ仰ぐ瞳うごきて、ほほえみたまうと、見たる時、やさしき手のさき肩にかかりて、姉上は念じたまえり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの説によると、「玉虫色の小さな馬に乗って、猩々緋のようなものの着物を着て、金の瓔珞をいただいた」女が空中から襲って来て「妖女はその馬の前足をあげて被害の馬の口に当ててあと足を耳からたてがみにかけて踏みつける、つまり馬面にひしと組みつくのである」。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お星さまをちりばめたやうな立派な瓔珞をかけてゐました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天人の衣はけむりのようにうすくその瓔珞［13］の天盤からかすかな光を受けました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瓔珞のかがやきと黒い厳めしい瞳。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓔珞は黄や橙や緑の針のようなみじかい光を射、羅は虹のようにひるがえりました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※12　瓔珞＝仏像の装飾に用いられるインドの装身具。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天人の衣はけむりのようにうすくその瓔珞は昧爽の天盤からかすかな光を受けました。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人もあれば美しい瓔珞をかけた女子もございました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子供らは羅をつけ瓔珞をかざり日光に光り、すべて断食のあけがたの夢のようでした。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お星さまをちりばめたような立派な瓔珞をかけていました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かに進んで禮をする時、牡丹に八ツ橋を架けたやうに、花の中をが前後に三｜人屬いて、淺緑の衣に同じ裳をした……面は、雪の香が沈む……銀の櫛照々と、兩方の鬢に十二｜枚の黄金の簪、玉の瓔珞はら／＼と、お孃さん。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髻結いたる下髪の丈に余れるに、色｜紅にして、たとえば翡翠の羽にてはけるが如き一条の征矢を、さし込みにて前簪にかざしたるが、瓔珞を取って掛けし襷を、片はずしにはずしながら、衝と廻廊の縁に出づ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二二ヽ五ヽ一二ヽ）〔堅い瓔珞はまっすぐに下に垂れます〕〔冒頭原稿なし〕堅い瓔珞はまっすぐに下に垂れます。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天衣、瓔珞のおん装でなくても、かかる場面へ、だしぬけの振袖は、狐の花嫁よりも、人界に遠いもののごとく、一層人を驚かす。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "麗娟常に身の何處にも瓔珞を挂くるを好まず。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女、幽に青き瓔珞を輝かして舞へば、山の端の薄を差覗きつゝ、やがて月明かに出づ。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪らず袖を巻いて唇を蔽いながら、勢い釵とともに、やや白やかな手の伸びるのが、雪白なる鵞鳥の七宝の瓔珞を掛けた風情なのを、無性髯で、チュッパと啜込むように、坊主は犬蹲になって、頤でうけて、どろりと嘗め込む。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "端厳微妙のおんかほばせ、雲の袖、霞の袴ちらちらと瓔珞をかけたまひたる、玉なす胸に繊手を添へて、ひたと、をさなごを抱きたまへるが、仰ぐ仰ぐ瞳うごきて、ほほゑみたまふと、見たる時、やさしき手のさき肩にかかりて、姉上は念じたまへり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方には華の瓔珞、金銀、錦の幡天蓋、※瑁の障子、水晶の簾。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たてに、斜に、上に、下に、散り、飛び、煽ち、舞い、漂い、乱るる、雪の中に不忍の池なる天女の楼台は、絳碧の幻を、梁の虹に鏤め、桜柳の面影は、靉靆たる瓔珞を白妙の中空に吹靡く。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀の瓔珞、七宝の胸かい、けしの花のような軽い輿。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださへも益良夫ごころ溢れ揺り抑へもあへぬを、見透かせば渦巻く霧の瑠璃雲の漂ひが上、数かぎりなき糠星の瓔珞の中、あなあはれ不尽の高嶺ぞ、今し今、一きは清き紫の朝よそほひに出で立ち立てれ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようらくつゝじ、いはがらみ、みやましぐれ、なゝかまど、羊齒類。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
