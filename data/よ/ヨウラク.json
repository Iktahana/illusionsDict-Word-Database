[
  {
    "uuid": "aeee6f8c-7007-569e-bc4e-7b5daeb63910",
    "entry": "瓔珞",
    "reading": {
      "primary": "ようらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
