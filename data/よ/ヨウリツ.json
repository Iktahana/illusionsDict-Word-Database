    "definitions": [
      {
        "index": 1,
        "gloss": "backing (for a position)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
