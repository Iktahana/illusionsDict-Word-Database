    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fertile land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶室は寂寞たる人世の荒野における沃地であった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処こそ人生といふ沙漠中の沃地である。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共はこの沃地に湧き出る詩の霊泉を汲んで、もつと広く深い想像の世界へ踏込まねばならない。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東寄りの方には矮小な黒檜白檜の一叢が沙漠の沃地を見るが如くに碁布しているけれども、其他は茫々たる草原で、五、六寸から一尺あまりに延びた禾本科や莎草科の植物が吹き募る東南の風に靡いている。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの植民地はいずれも、蒙昧野蛮な諸民族の住んでいた地方に樹てられたものであり、彼らはたやすく新来住者に屈服し、その結果新来住者は云うまでもなく豊富な沃地を獲得した。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもあれ汝勝てりとも、王プリアモス其爲に汝に主權與ふまじ、子ら彼にあり、彼の意は堅し、謹愼又深し、或は我を亡さばトロイア人は賞として、果園と耕土――すぐれたる沃地汝のために割き、　185與ふることを念とすや？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の大業がほぼ完成した翌年の初夏は、今までの荒蕪な河原は、青田のそよぐ豐饒な沃地と變つてゐた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかも歴世の国富を擁し、名門に生れ、天嶮と沃地をもち、そしてまたとない時代に遭いながら、その生命を、実に勿体ないほど、つまらなく終ってしまった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "北支の戦禍を避けて、南へ南へ移住してくる漢民族は、その天産と広い沃地へわかれて、たちまち新しい営みをし始めていた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これを呉に較べてみれば、呉は富強にして山川沃地広く、兵馬は逞しく、長江の守りは嶮。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢が見えないほど高い欅に、細い芽がちよくちよく顏を出して來ました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛並もよくちぢれていて上等だ。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は、相場、鉱山などに引かかって、大分不景気だったようですが、もと大蔵省辺に、いい処を勤めた、退職のお役人で、お嬢さん育ちだから、品がよくちょっと権高なくらい。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、親戚ではございませんが、鰐淵さんとは父が極御懇意に致してをりますので、それに宅がこの近所でございますもので、ちよくちよくお見舞に上つてはお手伝を致してをります」「はは、さやうで。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「普段でも、母はこんなにちよくちよくと此方の家をあけてゐるんでせうか？",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋も初めはちよくちよく口を利いてゐるが、何時とはなしに口を噤んで了つて、煙草をぷかぷか吹かしながら、話す者の顏を交る交る無遠慮に眺めてゐるか、さもなければ、ごろりと仰向けに臥て了ふ。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの農民組合の野郎が性こりもなくまたこの池田さちよくちよくやつてくるいふやないか。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そら、この女んとこだよ、お前さんの御亭主がちよくちよく通つとるのはね！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、それは見せました、こないだ私がお宅から帰ると、都合よくちょうど先の人が来合わせたものですから」「それで、御覧なさいましてどんなお口振りでした？",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――清治のことは、お前さん一人が一生懸命骨を折つてゐたンで、こんなことはいへたことぢやないンだが――大學の頃から、ちよくちよく俺の方へ來てくれてゝねえ――家のおそのの親類に福といふ娘がゐて、まア、清治といゝ仲になつたわけだ‥‥」　そのといふのは大吉郎を久江からうばつた女である。",
              "citation": {
                "source": "夜福",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊庭はちよくちよくやつて来たが、昔の不義理に就いては、もう責めなくなつてゐたし、此の頃いゝ仕事でもみつけたのか、仲々立派な服装をしてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソウ頭がよくちゃ始末が悪いね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、興宗といふ畫家が――美術院派の畫家で、有名な「落葉」の屏風を殘した今村紫紅の兄さん――いつものやうに父とお酒を飮みながら――興宗は大酒で、父とは年齡が違ふが、うまがあふので、ちよくちよく來てはお酒びたりになつてゐた――何時かはなしが「郭子儀」の幅のことになつて、もしかするとそれは楓湖でせう。",
              "citation": {
                "source": "「郭子儀」異變",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡子は京都者の軽い意味で云ふ横着と云ふ言葉が、東京者に悪い感じを与へるのと、東京の人が軽い意でちよくちよく嘘と云ふ言葉を遣ふのが京の人に不快を覚えさすのとは、一寸説明した位で分らない事だから、こんな時には黙つて居るより仕方がないと思つて居る。",
              "citation": {
                "source": "帰つてから",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ生田葵君のやつてゐた「活文壇」といふ雜誌に、知與子とか謝豹とか署名して、ちよくちよくシエレエの詩の飜譯が出たものです。",
              "citation": {
                "source": "小山内謝豹",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私はふつうの刺身ほど厚くは切らぬが、極端に薄くしないで、よく洗うと、なるほど晒しくじらのようにちりちりとはならないが、体よくちりちりとなる。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大里　　君も、さうちよくちよく顔を出すのは、多分落ちついてゐられんからだらうが、引きあげたすぐ後といふやつが、よくあるんでね。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとちよくちよく顔をお見せになるのかと思つたら……。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "二見　　多分、ちよくちよくお邪魔に上がることゝ存じます。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、運よくちょうど電気が来て、蛍光灯が煌々と輝いていたので、非常に嬉しかった。",
              "citation": {
                "source": "壁画摸写",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
