[
  {
    "uuid": "d6cdcd34-6932-54e0-a2c5-0acd78120ed1",
    "entry": "予稿",
    "reading": {
      "primary": "よこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
