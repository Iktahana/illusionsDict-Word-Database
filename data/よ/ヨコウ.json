    },
    "definitions": [
      {
        "index": 1,
        "gloss": "preliminary draft",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの記事に関しては、予稿ですね。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよこうなったら、おれひとりの力でやりとげるのだ。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病心がいよいよこうじてくると、世の中のすべての物がことごとく自分を迫害するもののように思われる。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "証拠がないので今まで堪忍していたが、いよいよこうと見極めが付いたら、あたしは不二屋へ蛇を持って行って、いつかお此を責めたように、お里をむごたらしく責めてやりたい。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよこうしちゃあいられない――。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうたしかな証拠があるかぎりは………」　とポオ助教授はいよいよこうふんの色をしめし、「ギンネコ号はうそをついていると断定しないわけにはいかない。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "武揚は五稜郭にたてこもったときにも、これをだいじにもっていましたが、いよいよこうさんしたとき、「国家のために役だたせてください。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへも、えび錠をかけるとよの手もとを見まもりながら、伸子はいよいよこうして日本を離れようとしている自分を痛感した。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、いずれにせよこうしたいきすぎのあいだで中間を保つことは、つまり、手紙を正しく判断することは、ほんとうに不可能なのです。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にせよこういう場合は、後に浅ましいと思う迷いをする。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
