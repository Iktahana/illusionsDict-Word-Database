    "definitions": [
      {
        "index": 1,
        "gloss": "keep (it) steady (after a turn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
