        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「では何分とも、よろしくお願いいたします。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくお願いいたします」　ほとんど入神の演技でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「割に素直に書かれて在ると思いますから、いい作品だと思いますから、どうかよろしくお願いいたします。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "御多忙中を大変恐縮に存じますが、本紙新年号文芸面のために左の玉稿たまわりたく、よろしくお願いいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、お委せいたしますから、何うかよろしくお願いいたします。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくお願いいたします。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだ子は小声で藤枝に、「先生、伊達さんの事をどうかよろしくお願いいたします」　と歎願するように云つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「これから一生懸命働きますから、よろしくお願いいたします。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――またどうぞよろしくお願いいたします」「誰さん――お光さんでしたね。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞよろしくお願いいたします」　もちろん日本語で云ったのであるから、カランスには意味は解らなかったが、お島の態度のつつましさが、その好感を招いたらしく、彼は頷いて微笑をした。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ、なにも知らない子供で、たいしたお役にもたちますまいが、どうぞ、よろしくお願いいたします。",
              "citation": {
                "source": "おさくの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌な噂が立っちゃあ、客足が遠のきますから、どうか親分さん、あんまりぱっとならねえように、よろしくお願いいたします。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえとも、よろしくお願いいたします」　私は、このときの感激を、いまでもわすれない。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうかよろしくお願いいたします。",
              "citation": {
                "source": "藪落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿部が東京の大学まで行ったということを聞いて居ったし、彦太郎も非常に心強く思って、へえ、そうして貰えれば私も大助かりです、どうぞ、よろしくお願いいたします、と叮嚀に頭を下げた。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦太郎は話を聞きながら、わくわくと胸の高鳴るのを覚え、へえ、いろいろとお世話様でございます、こういう書類のことなどは一向わかりませんから、よろしくお願いいたします、と云って、ポケットから黒い皮のサックを出して、阿部の方に押しやった。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "子爵夫人さま、私どものことをあなたの聖き御親戚枢機官様へよろしくお願いいたします。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ぶんどうかよろしくおねがいいたします。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくおねがいいたします。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
