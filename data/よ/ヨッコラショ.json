          "literary": [
            {
              "text": "「よっこらしょ、よっこらしょ」　一郎は、斜面をのぼっていった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うン、――よっこらしょい」と長造は煙管をポンと一つ、長火鉢の角で叩くと、立ち上った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、水を、出しますだよ……よっこらしょと！",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よっこらしょっと、こりゃあ重いや。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体を拭くことも出来やしない」　何といって見ても、彦太郎が黙っていて答えないので、父親は仕方なく、よっこらしょと立上って、勝手｜許へ下りて、ゴソゴソと夕餉の支度にとりかかるのであった。",
              "citation": {
                "source": "夢遊病者の死",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い扉を突き抜けてはっきり聞こえてきたのは、中でメリッサが一心不乱に掃除中らしく大騒ぎしており、ティルダがよっこらしょとベルの所へ行かざるを得なかった。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして無造作にテーブルの上を片づけて、患者をよっこらしょっと乗せた。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　運転手にそう命令して、じぶんは大トランクを、「よっこらしょ。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
