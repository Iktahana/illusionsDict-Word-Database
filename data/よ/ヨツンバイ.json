    "definitions": [
      {
        "index": 1,
        "gloss": "crawling on all fours",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山男がすっかり怖がって、草の上を四つん這いになってやって来ます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーン市内の青年男女の有志者が、芝生の上で終日、四つん這いになって暮しているのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後で学校の森林へ入り、掌と足尖とで森の空地をかもしかのように四つん這いになって跳び歩き、またいろいろの他の獣の歩きかたを示されました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐々ながら巌頭に四つん這いになると、数十丈遥か下の滝壺は紺碧を湛えて、白泡｜物凄く涌き返るさま、とてもチラチラして長く見ていることが出来ぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌を出せ、手を挙げろ、四つん這いになれ、寝ころんで見ろ――いまに始めますぜ、また。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "で注意深く下駄を脱いで、四つん這いになって、橋の袂の道を横ぎった。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフはいきなり泥濘の中へ四つん這いになってつんのめった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしくなければ、私は尻からげになって、四つん這いになって石道を歩きたい位だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が、敵へ尻を向けて、大急ぎに、四つん這いに這い乍ら、逃出すと、二人、三人、と、周章てて、這い出した。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "雌の河童は逃げてゆくうちにも、時々わざと立ち止まってみたり、四つん這いになったりして見せるのです。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピッケルのピックを雪にたたき込んでそれに噛りついて、四つん這いのまましばし頂の憩いを楽しむ。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つん這いになって進む者。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は父の黒んぼたちが彼の娯楽のために四つん這いになったところを見たことがあり、馬に見立てた彼らに乗って、乗馬「ごっこ」をしたことがあった。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら食用になる野草の球根や蔓茎を植えるのに、足だけで体を支えることができず、四つん這いにならねばならなかった。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその日、千代は畑の畦の間に、膝頭と肱とで四つん這いになって、着物を泥だらけにしている。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つん這いになって這いながら、私は彼等の方へそろそろと、しかし脇目もふらずに進んで行った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の白い岩は、矮林の上に十分見えてはいたが、まだ八分の一マイルばかり出洲を下ったあたりにあって、矮木の間を時々は四つん這いになって這いながらそれに近づくまでには、かなりの時間がかかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "念に念を入れて、私は四つん這いになり、何の音も立てずに小屋の隅の方へそろそろと進んだ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言ったような余裕を見せたのは、さすがに見苦しくもありませんでしたが、中には正銘に狼狽して四つん這いの形になった者もないではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その三尺位のずぶ濡れの体が、四つん這いになり、私の布団の上に這い上ってきた。",
              "citation": {
                "source": "幽霊",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、熊を横眼で睨みながら、竿を投げだし、四つん這いに這って坂を這いはじめたが、うまく腰が動かない。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして病人が苦しむ時にはきっと四つん這いに這い歩き狐のような鳴き方をした。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五兵衛はカッと目をあけ、口もあけて、何かいいたげに、四つん這いに倒れて死んだのだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて上品に出来あがった脚がくたびれてしまうと、こんどは両手を使い出して、猛烈に飛び上がってみたり、四つん這いになって逆立ちの稽古をやり始めた。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そら、ここんとこさ」　で、彼が四つん這いになって、第八号が仲間にはぐれそうになっているのを引き戻している最中、その頸に、肌とシャツの間に角砂糖が一つ、ちょうどメダルのように、糸で吊してあるのが眼についた。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の少年が四つん這いになって熊になります。",
              "citation": {
                "source": "アイヌ宗教成立の史的背景",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで自分も四つん這いにならなくっちゃ仕方がないと諦めをつけた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の段々を四五遍通り抜けて、二度ほど四つん這いになったら、かなり天井の高い、真直に立って歩けるような路へ出た。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝口二丁目と宇田川町は眼と鼻の間だ、四つん這いになって行っても、一刻（二時間）もかかるはずはないじゃないか」「あっしも変だと思いましたよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私がしらべて解らんという事はない」　南老人はそんな事に驚くような柄ではありません、浩一郎から借りた虫眼鏡、それを持って、四つん這いになったまま、室から室へと隅々まで調べて居ります。",
              "citation": {
                "source": "古銭の謎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
