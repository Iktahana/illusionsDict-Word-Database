    "definitions": [
      {
        "index": 1,
        "gloss": "slow witted fellow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白木屋の火事の時に、屋上が焼け落ちるかもしれないと言っておどかす途方もない与太郎があったそうであるが、鉄筋コンクリートの岩山は火には決して焼けくずれない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "断るまでもなく与太郎の囈語みたいなものである。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と一緒にうちへ遊びに来ないかい」　と与太郎は言いました。",
              "citation": {
                "source": "狸と与太郎",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっといろんなものになって御覧」　化け物は与太郎がちっとも怖がらないのでつまらなくなって、狸になってしまいました。",
              "citation": {
                "source": "狸と与太郎",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると与太郎は真青になって、「ワア狸が出たあ。",
              "citation": {
                "source": "狸と与太郎",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり今まで目標として研究したのは純プロ階級の江戸ッ子……熊公、与太郎、ガラッパチの旧跡で、ブル階級のそれではない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢の自然と言つては堅過ぎるが、成程江戸時代から考へて見ても、湯屋と与太郎とは横町の方が語呂がいゝ。",
              "citation": {
                "source": "もゝはがき",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼だが、その――何と仰言られる名前でしたかな」「はい、この松岡長吉でも」と門田与太郎は同輩の男を示して阿賀妻に紹介した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ自分の肩をならべて行って、もとの軽格武士である門田与太郎は、「ねえ、阿賀妻さん」と話しかけた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご家老――」と大工の与太郎が云った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あの日には三十俵五人｜扶持の門田与太郎であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、長さんは――」と与太郎はどぎまぎしたようにくりかえした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は門田与太郎を見やった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは門田与太郎であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は門田与太郎の袖をひいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、執拗いほど門田与太郎を呼んだことも、耳許で喚きかえされてようやくそれと感づいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼は、怪我人の容体を懸念する前に、彼の前にいる門田与太郎をまともにのぞきこんだのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出目やそっ歯や、ひろくもない額に年より早い横じわの見える門田与太郎の顔は、それは見ただけで、人の上に立ち、人をひきいてはきはき処理出来る貌とは受け取れなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "門田与太郎は腕を組んで、ふるえる身体をおしつけていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に門田与太郎のひきいる小分隊が本隊と切り離された。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とは二つの車輪のような間柄にある門田与太郎もそこで立ちどまった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "門田与太郎が提灯を取って「こちら――」と導いた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、そうあって下さればよいが」と門田与太郎がつづらを摺りあげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "門田与太郎はその上で云った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この記事を読んで会員の一人である掏摸与太郎は慨歎した。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時代ぢや、落語の与太郎がもうけますよ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ながら最上先生裏口営業の荒かせぎは与太郎の力業と異るところはないだらうな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "与太郎の荒かせぎ、そんなものは時代ぢやないです。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前までは日本的なるものゝ発見、今日ビは与太郎の発見、色々と発見なさるですよ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、分りました、与太郎の発見これまた趣向だアね。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
