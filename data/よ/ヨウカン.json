[
  {
    "uuid": "2e8ff3c6-f518-5d00-8650-322b97837df7",
    "entry": "洋館",
    "reading": {
      "primary": "ようかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Western-style house (esp. one built in the Meiji or Taisho periods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは丁度、深い密林の中で白堊の洋館を見る時のやうな感じである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派なる洋館も散見す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから五六｜軒置いて錆朽ちた洋館作りの写真館が在る。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階、二階、人が住んでゐるのかゐないのか、息詰まるやうな靜けさを包んだ、安普請の洋館だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味で、狹い路次の奧にあつた、木造の、あのささやかな洋館は日本麻雀道のためには記念保存物たる價値を持つてゐるかも知れない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "處處に寺院の屋根や洋館の塔などが際立つて聳えてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁が厚い洋館の二階から発射される弾丸が、ヒウヒウと、街路の上をとび交うた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――低地を距てた洋館には、その時刻、並んだ蒼桐の幽霊のような影が写っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、きっと蝉時雨の降る植物園の森の裏手の古びたペンキ塗りの洋館がほんとうに夢のように記憶に浮かんで来る。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく西洋館で、――とにかく西洋窓のついた日本座敷で、日曜学校で使いそうな長い腰かけと四角なテーブルがおいてあった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僕夫妻が、私の棲んで居る小さな洋館とはまるで関係のない直ぐ傍の昔風の小さな日本家屋に生活して居るのです。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………箱根路を我越え来れば伊豆の海や沖の小島に浪の寄る見ゆ…………これは源実朝の詠んだ金槐集中の歌ですが、私は私の洋館の窓をあけたてする時などによくこの歌をうたって居ます。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから五六軒置いて錆朽ちた洋館作りの写真館が在る。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の影が渚を打って、ひたひたと薄く被さる、藍色の西洋館の棟高く、二、三羽｜鳩が羽をのして、ゆるく手巾を掉り動かす状であった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五　さて半時ばかりの後、散策子の姿は、一人、彼処から鳩の舞うのを見た、浜辺の藍色の西洋館の傍なる、砂山の上に顕れた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白亜の洋館に行き養魚の有様を見んと訪えば、ここに偶然にも、僕の旧知、法科大学生｜福田甚二郎君がいて、種々養魚上の説明をしてくれ、ここの所長をしている谷口利三郎氏も出て来られて、雨中に学術上の説明をしてくれた。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　銀行を横にして、片側は燒け原の正面に、野中の一軒家の如く、長方形に立つた假普請の洋館が一棟、軒へぶつつけがきの（川）の字が大きく見えた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま此のバラツク建の洋館に對して――こゝに見取圖がある。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――振返つた洋館をぐわさ／＼とゆするが如く、貨物車が、然も二臺。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れの青空の中に隣の西洋館の屋根の煙出しが並んで三本あった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜと云って――その煙を吐いている赤い煙突のある西洋館の青年は、彼女の病気が癒ってしまうと、やがてぴったりと遊びに来るのを止めてしまったのだから。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と満足して、泪でぼんやりした眼で、青年のいなくなった西洋館の屋根を眺めた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は結婚して、西洋館の隣とは異う家に住んでいた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそこの窓から見えるものは西洋館の屋根の三本煙突ではなかった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、昔あの三本煙突の西洋館にいた炊事婦であったことを思い出した。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "解剖室は、校舍から離れた獨立の建物で、木造の西洋館である。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の墓場は大きなペンキ塗の西洋館で切れる。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして平野の所所に、風雅な木造の西洋館が、何かの番小屋のやうに建つてゐた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし邸を見上げると反対に洋館を増築したり、庭を造り直したりした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの蒲焼（鑵詰）ライスカレー（同上）あずきようかん（同）栗のきんとん（同）ほーじ茶、ココア、角砂糖（斯うたくさんは食えんわい）小包は厳重にして置いて呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
