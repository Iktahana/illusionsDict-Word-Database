              }
            },
            {
              "text": "いつも、中腰になって上背をよじるようにして手早く縒り合わせていく。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南岳をよじる時私は、たしかにそう感じた。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのラミアーの手紙というのが、おそろしく曲線的な身をよじる現代女言葉でかかれている。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機に似た爆音がするとギョッと身をよじるみなの気配のなかに動かぬ影となってゆくものがまたもふえ、その影のそばでみつけるＫ夫人の眼。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            }
          ]
        }
