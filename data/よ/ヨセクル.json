[
  {
    "uuid": "f6e1edca-a5c2-548a-adc4-5b079a30e37d",
    "entry": "寄せ来る",
    "reading": {
      "primary": "よせくる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-来る",
        "動詞-自動詞"
      ],
