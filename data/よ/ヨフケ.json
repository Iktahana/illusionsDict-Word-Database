        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夏麻挽く、海上潟の、沖つ州に、船は停めむ、さ夜更けにけり。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊売りが問題の夜更けに問題のアパート階上の洗面場で怪しい男の手を洗っているのを見たという証言のあたりから、記者席の真犯人に観客の注意が当然集注されるから、従ってその時に真犯人は真に真犯人であるらしい挙動をして観客に見せなければならないこと勿論である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝茶店内部　夜更けて――　表戸を開けて七五郎のお袋のお勘婆さんが顔を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ココア色の女の皮膚に雷紋の入墨をしたような夜更けであった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば秋の温泉塲の靜かな夜更けなどに、好もしい相手と勝負に熱中しながら、相當腕が出來なければ冴た。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後教師都に帰りてより幾年の月日｜経ち、ある冬の夜、夜更けて一時を過ぎしに独り小机に向かい手紙｜認めぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂をなかば偽りとみるも、この事のみは信なりと源叔父がある夜酒に呑まれて語りしを聞けば、彼の年二十八九のころ、春の夜更けて妙見の燈も消えし時、ほとほとと戸たたく者あり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の三階から見下ろす一町くらい先のある家で、夜更けるまで大声で歌い騒ぎ怒鳴り散らすのが聞こえた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に夜更けを待って秘密の祈祷をつづけるというのも少しおかしいと、一の番頭の重兵衛が、それとなくお豊に注意したが、かの行者を固く信用しているお豊は絶対に耳を藉さなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「夜更けてこッそりお詣りすると」Ｔ「必ッと願いが叶うんですッて」　「そんな馬鹿な事」　伊吉は信じない。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから夜更けて湯へゆくことはその抵抗だけのエネルギーを余分に持って行かなければならないといつも考えていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは溪の上にだるま茶屋があって、そこの女が客と夜更けて湯へやって来ることがありうべきことだったのである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　どうして喬がそんなに夜更けて窓に起きているか、それは彼がそんな時刻まで寝られないからでもあった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　喬は夜更けまで街をほっつき歩くことがあった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新京極に折れると、たてた戸の間から金盥を持って風呂へ出かけてゆく女の下駄が鳴り、ローラースケートを持ち出す小店員、うどんの出前を運ぶ男、往来の真中で棒押しをしている若者などが、異様な盛り場の夜更けを見せている。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新京極を抜けると町はほんとうの夜更けになっている。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬は腰に朝鮮の小さい鈴を提げて、そんな夜更け歩いた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人びとのなかでは聞こえなくなり、夜更けの道で鳴り出すそれは、彼の心の象徴のように思えた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事もないのに夜更けの道に立ってぼんやり畑を眺めているようなふうをしている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうち人びとが掴まされたビラの類が不思議に街の一と所に吹き溜められていたり、吐いた痰がすぐに凍り、落ちた下駄の金具にまぎれてしまったりする夜更けを、彼は結局は家へ帰らねばならないのだった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて彼が便所へ通うと、小窓の外の屋根瓦には月光のような霜が置いている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が欠けるに随って、Ｋ君もあんな夜更けに海へ出ることはなくなりました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りも夜更けになるとこの通りである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯しがつよく吹いている夜更けであった。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして薄雲かかり日光寒し」同二十二日――「雪初めて降る」三十年一月十三日――「夜更けぬ。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野の冬の夜更けて星斗闌干たる時、星をも吹き落としそうな野分がすさまじく林をわたる音を、自分はしばしば日記に書いた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更け、潮みち、童らが焼し火も旅の翁が足跡も永久の波に消されぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小躍りするような音を夜更けた札幌の板屋根は反響したが、その音のけたたましさにも似ず、寂寞は深まった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて山から出て来た猪が、年の若さの向う不見、この女に恋をして、座敷で逢えぬ懐中の寂しさに、夜更けて滝の家の前を可懐しげに通る、とそこに、鍋焼が居た。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よふけの部落のひろつぱで。",
              "citation": {
                "source": "どらが鳴る",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
