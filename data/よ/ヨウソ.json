    "definitions": [
      {
        "index": 1,
        "gloss": "any serious skin eruption",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
