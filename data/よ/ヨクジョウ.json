[
  {
    "uuid": "91b053fb-0739-566d-9f59-b65e5904c9eb",
    "entry": "浴場",
    "reading": {
      "primary": "よくじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
