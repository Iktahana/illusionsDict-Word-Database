      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bathhouse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何故といつて、あの温泉は、田舎の百姓が湯の隅で念仏を称へたり、不潔な女をひやかしたりするやうな、全然田舎風の空気をもつた浴場であつて、周囲の新鮮な自然と全く不調和であるからである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場へ行って清澄な温泉に全身を浸し、連日の疲れを休めていると、どやどやと一度に五、六人の若い女がはいって来て、そこに居たわれわれ男性の存在には没交渉に、その華やかな衣裳を脱いで、イヴ以来の装いのままで順次に同じ浴槽の中に入り込んで来た。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処小駅ながら近来海水浴場開けて都府の人士の避暑に来るが多ければ次第に繁昌する由なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では海水浴場の岩角にこの烏貝が群っていて、うっかり踏付けて足の裏を切らないよう用心しなければならない。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし東京市民が申し合せをして私宅の風呂をことごとく撤廃し、大臣でも職工でも皆同じ大浴場の湯気にうだるようにしたら、存外｜六ヶしい世の中の色々の大問題がヤスヤス解決される端緒にもなりはしまいか。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の有名な物理学者が近頃ロンドンのローヤルインスチチューションでやった講演の中で「人は何故浴場で歌いたくなるか」という問題を提出したら聴衆は大いに笑ったそうである。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると浴場で歌うという傾向は江戸ッ子に限らないと見える。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学者の説によると、第一に水の流出する音が人の声を誘う、第二には浴場の壁は普通の家のように音波を擾乱するものがないためによく反響して声が充実して聞えるためだという。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの説が日本の浴場にも通用するかどうか少し疑わしい。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし田舎にはまた人工的の風呂の代りに美しい自然に囲まれた日光浴場がある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に鉄道が拡がっても製糸工場が増しても、まだまだそこらの山陰や川口にはこんな浴場はいくらも残っているだろう。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ君とＺ君だけは自分の大浴場説に賛成した。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし浴場に附属した礼拝堂と図書館と画廊と音楽堂と運動場の建築が必要であると云って、それで三人でこの仮想的浴場のプランを画いてみたりした。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は浴場で屡々、結婚の感触を衝けた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど斯ふ言ふのが温泉場へ行く人、海水浴場へ行く人乃至名所見物にでも出掛る人の洒落た口調であるキザな言葉たるを失はない。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地を出発する前日に、炊事場の隣の入浴場で、汗とホコリを流した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の毎夜下りてゆく浴場はその溪ぎわにあった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場は石とセメントで築きあげた、地下牢のような感じの共同湯であった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浴場は非常に広くて真中で二つに仕切られていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは浴場についている水口で、絶えず清水がほとばしり出ているのである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉の浴場は溪ぎわから厚い石とセメントの壁で高く囲まれていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その階下が浴場になっていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場は溪ぎわから石とセメントで築きあげられた部厚な壁を溪に向かって回らされていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは豪雨のために氾濫する虞れのある溪の水を防ぐためで、溪ぎわへ出る一つの出口がある切りで、その浴場に地下牢のような感じを与えるのに成功していた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶は浴場の桶だった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一夜は小田原の「本陣」で泊まったが、その夜の宿の浴場で九歳の子供の自分に驚異の目をみはらせるようなグロテスクな現象に出くわした。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤怒をさえ覚えて、寝床を蹴って起き、浴場へ行って、広い浴槽を思いきり乱暴に泳ぎまわり、ぶていさいもかまわず、バック・ストロオクまで敢行したが、心中の鬱々は、晴れるものでなかった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の海水浴場に行ってみたことがありますか。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯村のその大衆浴場の前庭には、かなり大きい石榴の木が在り、かっと赤い花が、満開であった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生もずいぶんトボケた人で、わたしのようなずっと年のちがったものをつかまえても、よくじょうだんを言われました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
