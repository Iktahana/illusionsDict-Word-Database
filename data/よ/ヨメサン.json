        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だんだん茶店の人たちも、あのお客は、ただ口が重いだけで、別段に惡だくみのある者でないといふことが判つた樣子で、お客さんのお嫁さんになるひと仕合せですね、世話が燒けなくて、とをばさんに冗談言はれて、私は苦笑して、やつと打ち解けて來たころには、はや十一月、峠の寒氣、堪へがたくなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大隅さんのお嫁さんが見つかりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ、お嫁さんのおじいさんは、槍の名人だそうですからね、大隅君だって油断は出来ません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんを迎えに、はるばる北京からやって来たのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御自分の嫁さんと逢うんじゃないか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は意気込んで、「あいつには、もったいないくらいのお嫁さんです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうはじめてお嫁さんと逢うんだというのに、十一時頃まで悠々と朝寝坊しているんですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には、その真面目臭つた顔の小僧と、先刻「お嫁さん」と云つた時の小僧とが、どうしておんなしなんだらう？",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度お父さんがあそこの養子さんにお嫁さんの心配をするんでそのことに就いて一寸……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお金でいまに太郎の美くしいお嫁に着物を買つてやるのです…………太郎はどこからかきつと美くしいお嫁さんを連れて来ませう…………そのお嫁さんは、ひよつとするときつい意地悪るかもしれません。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は美くしい着物を着たお嫁さんをまた一だんと好みませうから。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんが、わたしをいぢめるお嫁さんでもおかまひなし、わたしは太郎のよろこびのために、そのお嫁さんに美くしい着物を買つてやります。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな太郎の為に…………太郎の美くしいお嫁さんに着物を買ふため麻のハンカチ古い革手袋、昔はやつたお高祖づきんの布つ片へ、そつと貯めて置かうとするお金なんです。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "己らは痘痕と濕つかきは大嫌ひと力を入れるに、主人の女は吹出して、夫れでも正さん宜く私が店へ來て下さるの、伯母さんの痘痕は見えぬかえと笑ふに、夫れでもお前は年寄りだもの、己らの言ふのは嫁さんの事さ、年寄りは何でも宜いとあるに、夫れは大失敗だねと筆やの女房おもしろづくに御機嫌を取りぬ。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「兄さんのお嫁さんかも知れないわ」　「まさか……」　「お父っつあん、読んでみたらどう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張り兄さんのお嫁さんでしょう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺っつあん、何を笑ってるんだい」　「今日は」　「静坊、一杯呉れ、冷でいいよ」　「はい」　お静、酒を出し乍ら、　「七五郎さん、兄さんったらね、知らないうちにお嫁さん貰ってるのよ」　「石松が……？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七五郎が、　「石松、帰って来るのか」　「兄さんのお嫁さんから此処へ手紙が来たの。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見せて呉れ」　「知らない」　「見せろよ」　「兄さん、何時お嫁さん貰ったの」　「おい、手紙何処にあるんだ」　「妾達に内緒でお嫁さん貰ったりして、お父っつあん怒ってたわよ」　「そんな事訊いてやしねえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度嫁に来られるお嫁さんのお里もわたくしは知っています。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただお父さんが可哀そうだったの、始めて済南へ連れて来る子供とそれから花嫁さんにまでこんなことをさせなけりゃならんかと思ったら、お父さんが可哀そうで、涙がこぼれたわ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「そうしたら妾をあんたのお嫁さんに呉れてやるって」　伊吉困った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へ帰って「お嫁さんはきれいなかたでしたか」と聞かれれば「きれいだったよ」と答える。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴なんかもうあったってないったって、お嫁さんは来るんだから。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　三疋がカン蛙のおうちに着いてから、しばらくたって、ずうっと向ふから、蕗の葉をかざしたりがまの穂を立てたりしてお嫁さんの行列がやって参りました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あそこの内では今日よめさんが来るのだというではありませんか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、私はお姫さまをおよめさんにしたくなりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが大臣は、ずっと前から、お姫さまを自分の息子のおよめさんにしたいと思っていたものですから、「そんなにいそいで約束をあそばないで、もう三月ほど、待たせなさいまし。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、わしの娘をおよめさんにする者は、四十枚の皿に宝石を山もりにして、それを四十人の黒んぼのどれいに持たせてよこさなければいけない。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、私、あなたのおよめさんになりたいと思っています。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
