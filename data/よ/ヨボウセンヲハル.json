          "literary": [
            {
              "text": "私は父を怒らしてはならないと思つて予防線を張るためにその室に行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと、私が家に帰ってから訴えるであろうところの不平を言わせまいと、まずその予防線を張るのだった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "万全を期する為二重の予防線を張ることを考えついた。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
