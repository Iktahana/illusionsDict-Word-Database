[
  {
    "uuid": "e3d9ecd8-5db7-5314-bde4-4701b468eb2a",
    "entry": "余念がない",
    "reading": {
      "primary": "よねんがない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
