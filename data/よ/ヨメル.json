    "definitions": [
      {
        "index": 1,
        "gloss": "to be able to read",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おたまじゃくしさえ読めるかどうか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも例えば長母音を勝手に二音に数えたり、重母音を自己流に分けたり合したりすると短歌と同じ口調に読めるものが多数にある。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側で新聞が読めるか読めないかというくらいの明るさの時刻が開花時で、開き始めから開き終りまでの時間の長さは五分と十分の間にある。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃあ読めば読めるのだな。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから読めるようになったら。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "読めるようになったらどうしたのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には清三がいろ／＼むずかしいことを知って居り、難解な外国の本が読めるのが、丁度自分にそれだけの能力が出来たかのように嬉しいのだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの中は変な仮名文字だから読み苦くって弱りましたが、段々読むに慣れてスラスラと読めるようになった。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "象形文字であろうが、速記記号であろうが、ともかくも読める記号文字で、粘土板でもパピラスでも「記録」されたものでなければおそらくそれを文学とは名づけることができないであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字で書き現わされていて、だれでもが読めるようになったものでなければ、それはやはり科学ではない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた、ある特別な科学国の「国語」の読める人にとっては、アインシュタインの相対性原理の論文でも、ブロイーの波動力学の論文でも、それを読んで一種無上の美しさを感じる人があるのをとがめるわけにはゆかないであろうと思う。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考えてみるとドイツ人の論文の中に、少なくもまれには、愚にもつかない空虚な考えをいかめしい数式で武装したようなのもある、そのわけが読めるような気がした。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五年生の人は読本の（二字空白）ページの（二字空白）課をひらいて声をたてないで読めるだけ読んでごらんなさい。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この事務所の書記の数はいつもただ四人ときまつてゐましたから、その沢山の中で一番字がうまく詩の読めるものが、一人やつとえらばれるだけでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら俺にも読める。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとやそっとの横文字の読める百姓になったところで貴様、それが何んの足しになるかさ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新以前、会津侯が江戸登城の折は四千余尺のこの山道を通られたということで、路傍の叢中には一基の古碑、その面に「右塩原あら湯｜道、左会津道」と刻されてあるのが蘚苔に覆われて読める。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、読めるか何うか判らんですが、兎にかく何んなものだか、是非一度見たいもんですな。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から倉持も宿坊にしている銀子の入りつけの家で、二た座敷ばかり廻っているうちに、女中からもそのことを言われて、町中みんながとっくに知っており、知らぬのは当の自分だけだと感づき、客たちの目にさえそれがありあり読めるように思えて来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前はコンスタンチェとして、その下に書いた苗字を読める位に消してある。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二　前回は、「その下に書いた苗字を読める位に消してある。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵はまだ塾へは行つてゐなかつたが、お父さんから一字、お祖父さんから二字といふ風に、少しづつ教へて貰つて、もう仮名や、やさしい漢字は、読めるやうになつてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵は、はやくそれが読めるやうになりたい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と僕が無遠慮に尋ねたら、津田さんは笑って、「とても読めるもんじゃないよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の黒板には、次のような文字が乱雑に、秩序無く書き散らされ、ぐいと消したところなどもあるが、だいたい読める。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国語を自由に読める先生が、この津軽地方には、ひとりもいない。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空払ふ月の光におひにけり走りちりぬるゐのこ雲かな」とよめる歌は、おもしろしとも思へねど、ゐのこ雲といふ名を伝へたる功は此歌にあるべきにや。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの申さるるをききてよめる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし外の恨みなりせば、詩に詠じ歌によめる後は心地すがすがしくもなりなん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
