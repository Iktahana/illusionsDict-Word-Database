    "definitions": [
      {
        "index": 1,
        "gloss": "(Western) clothing store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まっ白になった柳沢洋服店のガラスの前その藍いろの夕方の雪のけむりの中で黒いマントの女の人に遭った。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市電で心斎橋まで行き、アオキ洋服店でジャンパーを買ひ、着てゐた制服と制帽を脱いで預けた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "話を綜合すると、　今暁四時半、隣家の富田洋服店の三階の火熨斗場から発火して、一間と離れない丸善の二階へ直ぐ燃付いて、瞬く中に仮営業所の全部に火が廻って、到頭隣家の二三軒までも焼落ちて了った。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸が六枚、其内側に吊した白木綿の垂帛に洋燈の光が映えて、廂の上の大きなペンキ塗りの看板には、「小宮洋服店」と書いてあつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事が凡て無造作で、心配一つあるでなく、善とか惡とか云ふ事も全く腦裡から消えて了つて、渠はそれからそれと靜かに考へを※らして居たが、第一に多少の思慮を費したのは、小宮洋服店から如何にしてモット金を取るべきかと云ふ問題であつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今朝、小宮洋服店の主人が主筆ン所へ行つたさうだがね。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は今日また頻りに其※話をして居たが、不図小宮洋服店の事を思出した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸が六枚、其内側に吊した白木綿の垂帛に洋燈の光が映えて、廂の上の大きなペンキ塗の看板には、「小宮洋服店」と書いてあつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事が凡て無造作で、心配一つあるでなく、善とか悪とか云ふ事も全く脳裡から消えて了つて、渠はそれからそれと静かに考へを廻らして居たが、第一に多少の思慮を費したのは、小宮洋服店から如何にしてモツト金を取るべきかと云ふ問題であつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんとは、若い時からの知合で、それに斯の女の出して居る洋服店は経師屋の家作だつた。",
              "citation": {
                "source": "死の床",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺には高等洋服店｜何某と記してあった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄はそのたびに弟をつれて、前の主人へ話をつけたり、新しい洋服店へ交渉したりした。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、撮影されている「女主人」は「おでんや」、フランス女の洋服店主、支那料理店主、東京一高価な靴店セキドの女主人、洋服布地店主など、つまり有閑婦人の消費的生活、浪費趣味をとりあげ反映しているにすぎない。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはフェンチャアチ街一四九番のブリストウ＆スタアリング洋服店。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "その洋服店と呉服店とは、いづれも高い西洋建てで、賑やかな街の兩角を占領して、嚴しく分立してゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、田舎の店には無い品で桑港でも一、二流の商店以外には扱っていないから探り易いというので、そのボリヴィアの外套を持って刑事達が、桑港オウクランド市などの名ある婦人洋服店を廻り歩いたものである。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その当時、山崎洋服店が、塔のついた店を新築して、それがなか／＼珍しく、殊にショーウインドウには当時大家の西瓜の切り口を写生した油絵と、娘が琴を弾ずる油絵がかかっていて、非常に評判であった。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は、カフェー・ライオン、八十四銀行、三共のオリザニン、山崎洋服店がこの四角に陣取っている。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田絨店、米田洋服店、明治屋、海老屋、越後屋、近常、みな昔のままのところに栄えているのは喜ばしい。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕立屋の名前はサンフランシスコ・モーリー洋服店と入っている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その靜かな通りには骨董店だの婦人洋服店だのが軒なみに竝んでゐる。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身が握っていたのでは、金は他人の眼に見えないだろうし、第一洋服店の前に立って、洋服を注文したところで、背丈肉付もわからなければ、店の方でも声ばかりするのでは驚いて、不思議な噂話がパッと拡がらねばならぬ。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子店や洋服店はないのであろうか。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その静かな通りには骨董店だの婦人洋服店だのが軒なみに並んでいる。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎洋服店の裁縫師でもなく、天賞堂の店員でもないわれわれが、銀座界隈の鳥瞰図を楽もうとすれば、この天下堂の梯子段を上るのが一番｜軽便な手段である。",
              "citation": {
                "source": "銀座",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
