[
  {
    "uuid": "b89431ba-ab4f-568c-a5d2-3393ef94ffff",
    "entry": "溶岩",
    "reading": {
      "primary": "ようがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lava",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山一つさえその通り――「まだそのときのわたくしは、きしゃな細火を背骨にし、べよべよ撓るほどの溶岩を一重の肋骨として周りに持ち、島山の中央の断れ目から島地の上へ平たく膨れ上っただけの山でした」　世の中は、ただうとうとと、あま葛の甘さに感じられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間にところどころ溶岩で成れる洞穴があった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日自動車で鬼押出の溶岩流を見物に出かけた。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度に大小の災害はあって、ひどいのは須走口一合目に在る小富士を噴出させたり、精進湖と西湖は、もと一つの湖であったのを山から溶岩を流して今のように二つの湖に中断したり、富士にも富士山麓の形態にさえ多少の影響を及ぼしている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白煙｜濛々と立昇る地獄穴｜溶岩を覗いて、未醒画伯と髯将軍、快哉を叫んで躍り上がったところが、忽ち麓から吹き上ぐる濃霧に包囲されて、危うく足踏み外し白煙中へ捲き込まれんとし、二人、一生懸命｜巌に獅噛み付いて、ようよう命を陥さずに済んだそうである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして宿の前に滝を懸けた断崖なども溶岩の流れの毛すじほどの皺に相違なかろうと。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この坂はアシクラ断崖の北端にあたって、霧ヶ峰登山中第一の急坂であるが、（此の断崖は霧ヶ峰溶岩流冷却の際、板状節理をなしたもので、建築用具の平石と称して、盛に採掘せられる。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの妄想に不断の燃料を加えて、愈々益々それを白熱化し絶えず溶岩を虚空に向かって奔出させる物凄いヴォルカノの姿にしてみたいと思っている。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺や落葉松の間の、溶岩の散らばった路を上って行くと、急に平らな丘の上に出て、浅間はもう眼の前に噴煙をあげていた。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空の果の真赤の雲の間には光芒四射する太陽が一つあって流れ動く金の玉のごとく、大昔の荒漠たる溶岩のなかに包まれている。",
              "citation": {
                "source": "不周山",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れる金の玉が、大昔の溶岩のなかに包まれているようである。",
              "citation": {
                "source": "不周山",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂漠の西方へ三本半の真ッ黒い溶岩の流出が見える。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "左下りに溶岩と焦石の急斜面。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼の三方に鼎足の勢を成して聳立しているのが、外輪山の一である黒檜山、中央火口丘の地蔵岳及び溶岩流の凝結した鈴ヶ岳である。",
              "citation": {
                "source": "那須、尾瀬、赤城、志賀高原",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目黒の行人坂の上から南に折れた台地（高さ三三米）の西端からは、附近の松の木や目黒台の木が邪魔をするが、滝子山の横から頂上を辞した許りの農鳥岳の左の斜面が、白熱した溶岩のようにはみ出して、南へ南へと流れているのが見える。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日に霜がむすぶと――冬のあいだの氷が融ける日でもそうなることがあるが――砂は溶岩のように斜面を流れ落ちはじめる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方には溶岩やマグマが実際に存在し、陽の射さぬ海の水は熱いのだろうか。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正初年の爆発によって海水になだれ入った溶岩の岬が、すぐ目の前にあった。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤く焼けた溶岩の、不気味なほど莫大なつみ重なりであった。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "各方陣は雲霧に襲われた火山であり、溶岩は雷電と争闘した。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの黒くなったところが溶岩の跡です」　と小林さんが説明を始めた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶岩が真黒に見える。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜島、溶岩が流れて盲目縞、くっきり青き袴腰かな。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桜島、溶岩が流れて盲目縞、くっきり青き袴腰かな」　と三輪さんはもう一遍繰り返して、「和歌かね？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の近くに溶岩の岩がいくつか転がっていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山の岩だという大きな黒い溶岩の固まりのような岩が、庭のあちこちに、きわめて効果的に美しく配置してあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままハイウエイをいくと、溶岩による台地の上に出た。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶岩が細かく砕けて出来た、黒い砂の海岸だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその傷口から、溶岩が噴き出て流れ落ちた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぶしいほどに赤い、灼熱をとおりこして透明感すらたたえた、溶岩の滝だった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
