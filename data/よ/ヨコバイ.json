      {
        "index": 1,
        "gloss": "sidewise crawl (e.g. of a crab)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ガラガラ蛇が横ばいをするのも奇妙である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その話しかたが横ばいなんだそうです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは木の上に登ろうとしましたが、横ばいですからいくら登っても登っても落ちてしまいます。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カニは、つめをふりたてて、横ばいをしながら、砂地からエモノをさがして食う。",
              "citation": {
                "source": "海の青と空の青",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀にピッタリ身をつけて、カニのように、横ばいをするほかはないのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばけガニは、八本の足で、よこばいをするのですから、とても、にげあしがはやくて、さすがの明智にも、なかなかつかまりません。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
