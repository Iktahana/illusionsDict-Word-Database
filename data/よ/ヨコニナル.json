[
  {
    "uuid": "07fe0c31-5774-5f75-ab3f-9cf10b958ddc",
    "entry": "横になる",
    "reading": {
      "primary": "よこになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
