        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜すがら温き春雨に、　　　　　風信子華の十六は、黒き葡萄と噴きいでて、　　　　雫かゞやきむらがりぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……晃　委しい事は、夜すがらにも話すとして、知ってる通り……僕は、それ諸国の物語を聞こうと思って、北国筋を歩行いたんだ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ、かく思ひて其の夜すがら三坂峠を越え行くに、九十九折なる山道は、聞きしに勝る難所なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜すがら両個の運星｜蔽ひし常闇の雲も晴れんとすらん、隠約と隙洩る曙の影は、玉の緒長く座に入りて、光薄るる燈火の下に並べるままの茶碗の一箇に、小き蛾有りて、落ちて浮べり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルネオの海ダヤク人はタウ・テパン（飛頭蛮）を怖るる事甚だし、これはその頭が毎夜体を離れ抜け出でて、夜すがらありたけの悪事を行い、旦近く体へ復るので里閭これと交際を絶ち、諸の厭勝を行いその侵入を禦ぎ、田畠には彼が作物を損じに来る時、その眼と面を傷つくるよう竹槍を密かに植うる。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の習なればさまで驚くにあれねど、夜すがら、いもねられず、暁近くなりてしばし目どろみぬ。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母　　はれま、結構なお教訓ぢゃ、夜すがら此處に居殘っても、聽聞がしたいわいの。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命の路に、雌鳥羽に、はた雄鳥羽に、唇觸れあひて相寢ぬる伏葉の亂れ、魂合へる美し睦びに、月は夜すがら見ぞ惚けぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れがたみ一こよひ天なる花苑の美し黄金のおばしまに、夜すがら君や立すらめ、すずろに胸のときめくは。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の発言で、めいめい食べ物を持ち寄って、それを拡げながら夜すがら酒をちびちび飲んでいることもあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢路を辿る心地して、瀧口は夜すがら馳せて辛く着ける和歌の浦。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜は夜すがら寐もやらで東雲に出でゆきぬ。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜すがら二人の夢温かきことむかしの如かりき。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は終日降り、夜すがら降った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立から本降りになって、雨は夜すがら降った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平作やお米が踊る彼等が夢の中にも、八幡の賑合は夜すがら海の音の様に響いて居た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯念ず、しづかにはた圓やかに白蝋を黄金の臺に點して、その焔いく重の輪をしめぐらし燃えすわる夜すがら、われは寢ねじと。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯さけぶ夜すがら手摺れし火桶かこみて影もおぼろなる燈火の下に煮る茶の味は紅楼の緑酒にのみ酔ふものの知らざる所なり。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の夜すがらわれは唯泣くひとり泣く。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜になつても燈をも點けず、夜すがら眠らず、今にも自分が捕縛され、獄に繋がれはせぬかと唯其計りを思ひ惱んでゐるのであつた。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜になっても灯をも点けず、夜すがら眠らず、今にも自分が捕縛され、獄に繋がれはせぬかとただそればかりを思い悩んでいるのであった。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三日　星野子より文學界の投稿うながし來る、いまだまとまらずして今兩日は夜すがら起居たり。",
              "citation": {
                "source": "「樋口一葉全集第二卷」後記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農夫らは夜すがら寐ねず、看守りて脂肪に富める牧牛を　550取るを許さず、貪婪の獸は餌にあこがれて、勢猛く襲へども遂に其意を遂げがたし、勇武の手より放つ矢と、さすが畏るゝ炎々の松明かれに飛び來れば、あらび乍らもたぢろぎつ、＊やがて曙光の到るとき恨抱きて遠く去る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村も「ある山寺へ鹿聞きにまかりけるに茶を汲む沙弥の夜すがらねぶらで有りければ晋子が狂句をおもひ出て」という前書で、「鹿の声小坊主に角なかりけり」という句を作っているから、山中の寺までわざわざ鹿を聞きに行ったものと見える。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど火傷のくるしさ、食欲も出ず、夜すがら彼は眠れもしなかった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夜すがらの饗宴と歓談に更かした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はよすがら虫の音が哀れにももれて参ります。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛髮長きアカイアの諸人、舟より酒を買ふ、そのあるものは黄銅に、或は光る鋼鐵に、或は皮に、あるものは牛に、或は囚へたる奴隷に代へて酒を買ひ、豐かの宴を用意しつ、　475かくてよすがら長髮のアカイア族は樂めり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどよすがらクロニオーン、其胸中に災難をたくらみ高く雷震ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして床に屍を乘せ、其頭より足にかけ、柔軟の布被むらせ、上に雪白の氈おほひ、よすがら長く勇猛のアキルリュウスの側に、ミルミドネスの諸將卒パトロクロスを悲めり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
