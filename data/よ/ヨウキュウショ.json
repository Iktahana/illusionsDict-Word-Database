[
  {
    "uuid": "031d956e-3a80-51f0-a054-072b8ded05ef",
    "entry": "要求書",
    "reading": {
      "primary": "ようきゅうしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
