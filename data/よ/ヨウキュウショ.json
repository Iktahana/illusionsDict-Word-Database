    "definitions": [
      {
        "index": 1,
        "gloss": "written request",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「そうさなあ……出帆の間ぎわに要求書をブリッジへ持って行くか？",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "要求書を、やつの目の前へつきつけるんだよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「要求書は僕が原稿を作って、それがまとまった上で、清書して判をおして、それから提出ということにしようね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今、それらの条項に、要求書としての形を与えるために、苦しんでいるのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからね、要求書を出す間ぎわになって、それを見せて意見を聞いたら。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそのあとからストキ藤原が、清書された要求書を持って続いて行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水夫一同は、その要求書どおり要求しますから、要求を容れてください。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその要求書に判をおしてください。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗礁はありうるが、水夫らが要求書を出すなんてことが！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ、使いとしてこの要求書の提出とその説明とを引き受けて来たのです」ストキはチーフメーツの戦術にはつり込まれなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはどうだっていいようなものだけれど、誤解があるといけないからいっときますが、この要求書は最初あなたに出したんですよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではあなたは、私たちの要求書の決定権を持たないというときながら、握りつぶす権利を持ってることになりはしませんか、握りつぶすことは否定することじゃありませんか、否定する権利だけ持っていて肯定する権利を持たないと言うことは、このごろの流行にしても、理屈には合わないじゃありませんか。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースン、お前はこれを知らなかったのかい」チーフメーツはその机の上の要求書を指さしてきいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手には要求書を引っつかんでいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水夫めらが要求書を出しているのです。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は要求書を船長の前へ差し出した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原は船長とチーフメーツとが要求書のことを話しているのを、おもての出入り口からながめていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長はチーフメーツの要求書を見ようともしなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな寝言が書いてあるんだか見せたまえ」船長は要求書を取った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "波田、おまえは自分から進んで、この要求書に捺印したんじゃないだろうな。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、まるで、ばかにしたような態度を、要求書へ向けていたのだが、今では、それが非常に尊いものででもあるように、チーフメーツの前から、自分の前へ引き寄せて、ながめ初めたのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、その要求書にある条項を、一々説明しましょうか、もし、お求めになるならば」藤原は言った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもありがとう存じました」藤原は、判のおされた要求書を、ポケットに収めながら言った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千四百五十六｜萬七千八百九十九｜枚、若しくは二千三百四十五｜萬六千七百八十九｜枚の選擧權要求書が、毎日々々大八｜車で衆議院に運びこまれるとしたら、如何に無神經でも堪るまいぢやないか。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ用意していた「決議文」と「要求書」の内容を説明して、皆の承諾を得ればよかったのだ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼は全職工の前で、ハッキリと、今迄の経過を述べ、一人も残らない賛成をもって「工場委員会」の委員選挙制が決議されたことを報告し、「決議文」と「要求書」を提出した。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「要求書」を手にもった専務はそれを持ったまゝ自分が今どうすればいゝかを忘れたように、あやふやな様子をした。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――然しそれがすべて、この要求書が承諾され、規約の中にハッキリそうと改正されてからの事にしたら、お互いに相談が出来ると思われます。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日の夕方、東交代表河野争議部長が、下唇を突出し気味に背中を堅くして椅子にかけている山下局長に向って整理案撤回要求書を差し出しているところを撮った写真が出た。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でっぷり太った角がりでチョビ髭を生やした河野が詰襟服姿で起立し、要求書の両端を押えて山下局長へ向ってひろげている場面である。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
