    "definitions": [
      {
        "index": 1,
        "gloss": "another place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "余所の蒲団の行先は分からない。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れか余所の伯母さんが来て寸を取っているらしい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは余所から借りて来たものでなくて、やはり作者自身から自然に歌の中に流れ込んだもののように見える。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方林で囲まれ、南が開いて余所の畑とつづいている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所から見たならば、若いうちによくあるいたずらの勝手な泣面と見苦しくもあったであろうけれど、二人の身に取っては、真にあわれに悲しき別れであった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子も真の親の様に思ってくれ私も吾子と思って余所の人は誰だって二人を兄弟と思わないものはなかったほどであるのに、あとにも先にも一度の小言をあんなに悔しがって夜中泣いて呉れなくともよさそうなもの。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家の方に背中を向け、余所余所しく。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）も少しで余所余所しくお嬢様とでも仰ゃりそうな処でしたね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公ヂックが牧師の内に往って、牧師夫婦と話をしているうちに、牧師が余所へ出てしまう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで先ず、貸したように、預けたように、余所の蔵に秘ってありますわ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の夜縄をやるのは矢張り東京のものもやるが、世帯船というやつで、生活の道具を一切備えている、底の扁たい、後先もない様な、見苦しい小船に乗って居る余所の国のものがやるのが多い。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は丁字形に二つ並べた、奥の方の縁台に腰をかけて、掌で項を圧えて、俯向いたり、腕を拱いて考えたり、足を投げて横ざまに長くなったり、小さなしかも古びた茶店の、薄暗い隅なる方に、その挙動も朦朧として、身動をするのが、余所目にはまるで寝返をするようであった。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして私と将棊をさすより、余所の奥さんと不義をするのが望なの？",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、余所の抱妓でも、そこは姐さん、他人に気兼で、たしなめる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "繻子の帯もきりりとして、胸をしっかと下〆に女｜扇子を差し、余所行の装、顔も丸顔で派手だけれども、気が済まぬか悄然しているのであった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所のおじさんの鳥さしが来て、私ン処の橋の詰で、榎の下で立留まって、六本めの枝のさきに可愛い頬白が居たのを、棹でもってねらったから、あらあらッてそういったら、叱ッ、黙って、黙って。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所のものはどうであろうとちっとも心には懸けないように日ましにそうなって来た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だもの、どうして学校の先生をはじめ、余所のものが少々ぐらいのことで、分るものか、誰だって分りやしません。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所なら可いが、雪の下はちと、なあ、おい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁山泊の割符でも襟に縫込んでいそうだったが、晩の旅籠にさしかかった飢と疲労は、……六よ、怒るなよ……実際｜余所目には、ひょろついて、途方に暮れたらしく可哀に見えた。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何うです、泊りませんか……ッたってね、私も実は、余所の別荘に食客と云うわけだが、大腹な主人でね、戸締りもしない内なんだから、一晩、君一人ぐらい、私が引受けて何うにもしますよ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "りく　内の背戸にありますと、ただの草ッ葉なんですけれど、奥さんがそうしてお活けなさいますと、お祭礼の時の余所行のお曠衣のように綺麗ですわ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも知らない不束なものですから、余所の女中に虐められたり、毛色の変った見世物だと、邸町の犬に吠えられましたら、せめて、貴女方が御贔屓に、私を庇って下さいな、後生ですわ、ええ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――高原さん……それは余所の娘です。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は余所の娘御には相違ないてな。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――船大工が謡を唄う――ちょっと余所にはない気色だ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔なべてはしけく　よそほひて〕宮沢賢治なべてはしけく　　よそほひて暁惑ふ　　　　　　改札をならび出づると　　ふりかへる人なきホーム　　　陸の橋歳に一夜の　　　　旅了へしをとめうなゐの　　ひとむれに黒きけむりを　　　そら高く職場は待てり　　　春の雨",
              "citation": {
                "source": "〔なべてはしけく　よそほひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去よながいながい孤獨の影よその影を岩にひきずる冬の日の薄暗い濱邊に立つて意味のふかい人生を見る。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ私たちのかうした友情は、世にも珍なる彼のはればれしき男性的性情と、やや女性的で憂鬱がちなる私の貧しき性情との奇蹟めいた会遇によつて結びつけられた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ日本の詩壇に自由詩形が紹介されて以来、真に日本言葉のなつかしいリズムを捉へて、之を我我の情緒の中に生かしたものは、室生以前には一人も無かつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
