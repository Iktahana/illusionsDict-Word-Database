    "definitions": [
      {
        "index": 1,
        "gloss": "taking a wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほとんど園長の物置小屋に住み続けて、めったに家へは帰らない息子の留守の暇に明かして、二人はもう嫁取りの相談ばかりであった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁取りだとか、法事だとか、何かのお祝いだとか、そういう事だと、お恵達は誘い合って、喜んで出掛けた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁取りといふことから、話はいつか猥雜な方に移つて行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "へへへ、嫁取りに文字ったので」「江戸の者は泥棒まで洒落っ気があるな。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らに酒をうんと飲ませて、地主と小作人との親睦を計るのが、今日の嫁取りの大きな目的の一つでもあつた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、声自慢の人足たちが、嫁取り唄を一度に唄ひ始めた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "来るか／＼と迎へて見れば　花も恥ぢらふ花嫁ご　嫁取り唄のやり取りの内に、花嫁の荷は、来た人足の肩から、迎へた人足の肩へ移された。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間のつなぎにとて、酒が出る――嫁取り唄はもう済んだ。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……行ってみると漁場の争奪、漁師の喧嘩、発動機船｜底曳網の横暴取締り、魚市場の揉め事、税金の陳情なぞ、あらん限りのイザコザを持ち掛けて来る上に、序だからというので子供の名附親から、嫁取り、婿取りの相談、養子の橋渡し、船の命名進水式、金比羅様、恵比須様の御勧請に到るまで、押すな押すなで殺到して来る。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのところのお嫁取りなんて、御本陣と御本陣の御婚礼ですからねえ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお母さまが今まで達者でいて、今度のお嫁取りの話なぞを聞かっせいたら、どんなだずら――」　半蔵も生みの母を想像する年ごろに達していた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで代々、親戚の者とばかり、婿取り嫁取りをしていたのだそうな。",
              "citation": {
                "source": "鸚鵡蔵代首伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……高貴なお方は高貴なお方同士で、下賤な人間は下賤な人間同士で、嫁取り婿取りをなさいましたほうが、事なかれ主義という点で、よろしいようでございますよ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火難、盗難、待ち人、失せ物、お手の筋から人相家相、嫁取り婿取り養子の口、昨夜の夢見がどうだとか明日の天気はこうだとか、ないしは狐狸の憑から天狗様の祟りまで、聞かしてやろうってえ心意気さ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそいつらはそいつらだけで、嫁取りをしたり婿取りをしたり、金を貸し合ったりお茶を飲んだり、悪いことをしては隠し合ったり、時々間違っていいことをすると、ソレ君子だ慈善家だ、ワーッと云って祭り上げたり、酷い奴になるとそいつを利用し、チョクチョク金を儲けたりする」武士あがりらしい山窩が云う。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁取りの話がほかで進んでるやもの。",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大の男でねえかよ、思いきりよく嫁取りする気になってくれと、附きに附いて言うが、へえ駄目だあ、あんまり言うと怒り出す始末でね。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこの山里では、お嫁取りの飲み明かし歌い明かし、そぞろにその泰平さにほほ笑まれるのであったが、その来る嫁というのが甲州八幡村と聞いて竜之助は、また思わでものことを思わねばならぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "来春には倅に嫁取りもしなけりゃならねえので、その時の間に合せようと思って実はめっけ出してきたんだ。",
              "citation": {
                "source": "蒲団",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ともかく新しく嫁取りもしましたことでございますし、家中はさすがに賑わっておりますから、私も別段なんとも思わず寝に就いたわけなのでございました。",
              "citation": {
                "source": "蒲団",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁取りも出世も、三十までがまんしろと、人相に顕われているというのである。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の四狂言一、母と兵隊　佐々木邦作二、嫁取りアルバム三、ロッパの開拓者四、日本の姿十一月十四日（木曜）　九時半起き、入浴、朝食して十時半に出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嫁取り婿取り」が丁度見られた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
