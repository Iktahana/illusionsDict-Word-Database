[
  {
    "uuid": "eb1e1315-fdcf-5784-8ae1-83bb50649b18",
    "entry": "予知",
    "reading": {
      "primary": "よち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
