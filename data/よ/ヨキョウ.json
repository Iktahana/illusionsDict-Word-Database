    "definitions": [
      {
        "index": 1,
        "gloss": "performance (at a party or banquet, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "映画のほかに余興とあってまね事のような化学的の手品、すなわち無色の液体を交ぜると赤くなったり黄色くなったりするのを懇意な医者に準備してもらった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりおり余興に見せられる発声漫画などはこの意味ではたしかに一つの芸術である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この団体がここを引上げるという前夜のお別れの集りで色々の余興の催しがあったらしい。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ある大学の運動会では余興の作りものの中にやはりこの煙突男のおどけた人形が喝采を博した。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余興として笑ってしまうには、あんまり意地が悪かったのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには表に　ビジテリアン大祭次第挙祭挨拶論難｜反駁祭歌合唱祈祷閉式挨拶会食会員紹介余興　　　　以上と刷ってあり私たちがそれを受け取った時丁度九時五分前でした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの大祭にぶっつかったのですから職業｜柄私の方ではほんの余興のつもりでしたが少し邪魔を入れて見ようかと本社へ云ってやりましたら社長や何かみな大へん面白がって賛成して運動費などもよこし慰労旁々技師も五人｜寄越しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、彼を拗らすためのように、夫人は勧められて「京の四季」かなにかを、みんなの余興の中に加って唄った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この芸妓は、昨夜の宴会の余興にとて、催しのあった熊野の踊に、朝顔に扮した美人である。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、彼は部下の余興を見なければ、酒が咽へ通らないという奇病を持っていたから、その鯨のような飲酒欲を満足させるためには、兵隊たちは常に自分の隠し芸をそれぞれストックして置く必要があった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "余興の中で、隊長を喜ばせるのは、何といってもまず浪花節であった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の余興に老人のむかし話を一度聴きたいと思ったからである。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人は舞台より二階の余興の方に気を取られてしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は生業として手品師兼芸人をやっており、日が暮れたあと兵士向けの食堂を廻って歩き、その場その場でささやかな余興をやるのだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芸者諸君、さう喰つて許りをらんで、何か余興をやらんか、陸軍記念日の兵卒達の余興より、おぬし等は本職だから、うまいぢやらう、槍さびがいゝぞ』　と客は芸妓達に所望するのであつた、爾来この三人組は『資本』にやつてきた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六りん子や男達は酔つ払つてバーの女給達のサービスを必要としないほど隅にをけない余興がとびだした、酒場を出た、全く夜になつてゐた、――りん子さん、今夜は貴女は何処へかへるつもり――わたしだつて帰る家位あつてよ、――いや、いや、これは失礼しました。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭の余興として各寮から余興を一つづゝやるので、その時自分達は南寮の余興として出演したのだ。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時迄狂言などは一度も稽古をした事はないし、余り見た事もないのだが、余興として出演すると、二円ばかりの慰労が出るのでその頃小遣に困り抜いて居た自分達は、進んで買つて出た訳なのだ。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が来て、十一時を過ぎると愈々余興が始まつたが、他の寮の余興と云へば皆凝つたもので、やんやと云ふ大喝采、夫を見て居る久米や自分の心持は、イラ／＼して立つても居ても堪らないものであつた。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、順番が近づいたので、自分達は衣装を変へて余興場の後で出番を待つて居ると、運の悪い時は仕方のないもので、自分達の「鎌腹」の前は、外から招いた本職の狂言師の狂言であつたには駭いた。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康公が行水役の下女に産ませた上総介忠輝は有名な暴君だったが、その領地に無類の豪飲今猩々庄左衛門あり、忠輝海に漁して魚多く獲た余興に、臣民に酒を強いるに、この漁夫三、四斗飲んで酔わず、城へ伴い還り飲ましむるに六斗まで飲んで睡る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは銀製の鴨を余興に進らせたと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへあたかも山椒の魚の問題が起こったので、事件はひどくこんがらかったのですが、それは一種の余興にすぎないことで、毒草事件とは全く無関係であるということが、後でようやく判明したのです。",
              "citation": {
                "source": "山椒魚",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それから後は社内の余興的の催しは一、二度あったそうだが、半公開的に大袈裟に催したのはただ一回ぎりであった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内の数ヶ所で始まっている余興は、それ／″＼に来会した人々を、分け取りにしているのだろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どうでしょう、それよりも今夜は、なにか、よきょうでもなさっては！",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよきょうから二学期だわ。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよきょうは、島にいくんだ。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、いよいよきょうは一件を持って、お出ましかえ」　と笑うお藤の眼を受けて、「あい。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子は、課業をはじめる前いつもどおり帳面と本とを並べている浅原蕗子に、「浅原さんいよいよきょうでおしまいですよ。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
