[
  {
    "uuid": "e2b27f62-d59b-5f55-b5ec-02963adef207",
    "entry": "余興",
    "reading": {
      "primary": "よきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
