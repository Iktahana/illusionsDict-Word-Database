[
  {
    "uuid": "05c22853-8d25-5a59-857b-c3480cddc71b",
    "entry": "予審",
    "reading": {
      "primary": "よしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
