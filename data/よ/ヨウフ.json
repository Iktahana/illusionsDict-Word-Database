[
  {
    "uuid": "800f97d6-6654-55ef-93d9-32c2c11c3843",
    "entry": "養父",
    "reading": {
      "primary": "ようふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
