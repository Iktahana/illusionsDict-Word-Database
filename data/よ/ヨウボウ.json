[
  {
    "uuid": "1909960f-f4d1-5464-8b5f-056fcd6045a3",
    "entry": "要望",
    "reading": {
      "primary": "ようぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "demand for",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それとおなじ意味に於て、私は『情理をつくした俳論』を要望する。",
              "citation": {
                "source": "最近の感想",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が紀昌は一向に其の要望に應へようとしない。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが紀昌は一向にその要望に応えようとしない。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小品ばかりか難しい曲も弾けることは、要望に応えて、メンデルスゾーンのリートや私のお気に入りを何曲か演奏してくれたことからもよくわかる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来訪者の数を知りたい」という要望は強かったようで、京都インターネットはその後、データをとって教えてくれるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇四年九月三〇日に開かれた同年第二回の小委員会には、関係者間ですでに協議が進められている改正要望事項をまとめたとする資料が提出された。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、保護期間の死後七〇年への延長を求める、ＪＡＳＲＡＣからの要望が盛り込まれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日に向けて、小委員会の事務局は、およそ三二〇の関係団体に、著作権法の改正に関する要望事項を照会していた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、五〇年を超える保護を希望する場合には「少額の手数料を納付するよう求める」などの方法を検討すべき、とする要望が一件あった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "親委員会における論議で、検討課題として追加するよう要望が出された著作隣接権に関して、吉川著作権課長は同会において、「隣接権の保護について、現時点で検討を行うことにするということは、少しまだ時期尚早」と発言した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに、要望のある適用除外規定を追加しようとするのが、「権利制限の見直し」である。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "中では、そもそもの火付け役を演じたＪＡＳＲＡＣが、同小委員会の事務局の求めに応じて二〇〇四年八月三一日に提出した、三つの主張からなる要望書が、比較的良くまとまっている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼なかでも本多顕彰氏は『も一つ前の問題』といふ題下に、近来の大激憤を洩してゐる、彼の論旨は、政治家に要望して『政治が文学に話しかける時、政治は己れの中のヒューマニズムを省みなくてはならない――』といふのである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、平和的手段を要望する側の気勢は、反対に静けさを加えた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月号の「人間」　座談会　「笑いと喜劇と現代風俗と」　　　　　　　岩田豊雄「海軍」　　獅子文六――このひとは「自由学校」┐　　辰野隆　　　　　　　　　　　　　　├　　福田恒存　　　　　　　　　　　　　┘福田恒存　　諷刺、喜劇はジャーナリズムでも要求されているし　読者の要望もある。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は今や、超階級の政治の要望せらるべき時代を迎えているのである。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、陸軍大学幹事坂部少将から熱心な印刷の要望があったが、充分に検討したものでもないので、これに応ずる勇気も無く、現在も私の手元に保存してある次第である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの簡単明瞭な見地から在満兵備の大増加を要望した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その集団はなるべく強く統制せらるるものが、良くその力を発揮し得るのだから統制の強化を要望せらるる反面、民族感情や国家間の利害等によりその強化を阻止する作用も依然なかなか強い。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国の国防的状態はドイツと同一ではなく、ただちにドイツの如くなり得ない点はあるであろうが、極力合理的に空軍の建設を目標として着々事を進むると同時に、航空が陸海軍に分属している間も一層密接なる陸海空軍の協同が要望せられる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の統制完全であり、戦争目的第一であるドイツは機密としたが、日本の現状はむしろ勇敢に必要の数を公表し、国民に如何に彪大な生産を要望せらるるかを明らかにすべきであると信ずる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤労するこの社会の大多数者の芸術化の要望が湧き上って、過去の文学の形式、内容は、全く新しい光りの下に見直されはじめた。",
              "citation": {
                "source": "今日の文学と文学賞",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウラのオヤヂのコヾト、トナリのオカミのコヾト、それはすべて子に対して妻への、夫への不平であり、要望である（彼等には夫も妻もゐないのだ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」竹村はさう言つて、作家としてよりも、寧ろもつと広い意味の修業を彼に要望した。",
              "citation": {
                "source": "彼女の周囲",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発のはじめから、保守の重いかげとたたかいつつある日本民主化の途上で自分たちの血と涙とをとおして平和を要望し、そのための世界的協力を切望している日本の婦人大衆の誠意をここに披瀝いたします。",
              "citation": {
                "source": "国際民婦連へのメッセージ",
                "author": "――「女性を守る会」から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の大衆が支配者の各種の政策にも拘らず根本に於て民主主義への要望を身から離さず、それが反ファシズムの情意ともなって現われるのだが、之を大量的に即ち大衆的に、そして最も実際的に代表する唯一の政治活動形態は、この政党を通じてでしかない、と考えたからだ。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、軍部の見解のこの転向は、予算額の総額を少しでも縮小したいという国民の要望に対応する回答として生じたものだった。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴取者は生きている　あちらこちらでラジオのことが考えられている様子で、十二月号の『中央公論』に宮原誠一氏が「放送新体制への要望」という文章をかいていられる。",
              "citation": {
                "source": "ラジオ時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済の力の相違が国民の文化生活の間に懸隔をもたらさないと同時に、男であり、女であるという偶然なことで、受け入れる文化のよろこびの範囲が大変掣肘されたり、又は文化の創造力への関心の度がちがったりしないようになることも、一つの切実な要望であろう。",
              "citation": {
                "source": "実際に役立つ国民の書棚として図書館の改良",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
