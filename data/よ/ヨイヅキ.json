    "definitions": [
      {
        "index": 1,
        "gloss": "evening moon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「帰途のほどは宵月じゃ、ちらりとしたらお姿を見はずすまいぞや。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵月の頃だったのに、曇ってたので、星も見えないで、陰々として一面にものの色が灰のようにうるんでいた、蛙がしきりになく。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」力に任して突飛ばせば、婆々へたばる、三吉｜遁る、出合頭に一人の美人、（木賃宿のあの人の）宵月の影｜鮮麗なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "・うらは山で墓が見えるかな／＼・かな／＼ゆふ飯がおそい山の宿・よい宿でどちらも山でまへは酒屋で・宵月がみんなの顔にはだかばかりで行程二里、所得は銭六十二銭、米一升九合。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "……折から宵月の頃であった。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の中の七日、珍しく朝凪ぎして、そのまま穏かに一日暮れて……空はどんよりと曇ったが、底に雨気を持ったのさえ、頃日の埃には、もの和かに視められる……じとじととした雲一面、星はなけれど宵月の、朧々の大路小路。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑いよ／＼濃かにして、夏木立深き處、山幽に里靜に、然も今を盛の女、白百合の花、其の膚の蜜を洗へば、清水に髮の丈長く、眞珠の流雫して、小鮎の簪、宵月の影を走る。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵月の頃だつたのに曇てたので、星も見えないで、陰々として一面にものゝ色が灰のやうにうるんであつた、蛙がしきりになく。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……音信の来しは宵月なりけり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面の色は惨として夕顔の花に宵月の映へる如く、その冷なるべきもほとほと、相似たりと見えぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "微曇のした空に宵月が出てぼんやりした光が庭にあった。",
              "citation": {
                "source": "宝蔵の短刀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、急に微笑を湛へて、何か弁解の辞を述べはじめたが、もう僕の耳はぐわん／＼と鳴つてゐるばかりで何も聞えず、往きがけと違つて十一貫の倉市をまるで軽々と担ぎあげて、宵月夜の畦道をどんどんと駆けてゐた。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の粉やあるじかしこき後家の君尼寺や善き蚊帳垂るゝ宵月夜柚の花や能酒｜蔵す塀の内手燭して善き蒲団出す夜寒かな緑子の頭巾眉深きいとほしみ真結びの足袋はしたなき給仕かな宿かへて火燵嬉しき在処　後の形容詞を用いる者、多くは句勢にたるみを生じてかえって一句の病となる。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶壁に夕日うらてる紅葉かな裏表きらり／＼と散紅葉山はくつ日のてりわける紅葉かな　帰る人毎に紅葉一枝の夕日を荷ふて宵月の尾の上にかゝる頃日光町に着きたり。",
              "citation": {
                "source": "日光の紅葉",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりひつそり雑草の中・雨の、風の、巣を持つ雲雀よ、暮れてもうたふか・宵月のあかり、白いのはやつぱり花だつた・よい雨のよい水音が草だらけ　活けられて開く花でかきつばた　五月廿一日細い雨、風は落ちた、頬白が機嫌よく囀るうちに、日が照りだしていよ／＼初夏日和となつた、もう湯あがりに浴衣がほしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・虫が火のなか声もろともに無くなつた・そばの花もうてふてふきてゐる・さびしさにたへて草の実や・さびしい手が藪蚊をうつ・月夜風呂たく麦わらもにぎやかに燃えて・宵月ほつかりとある若竹のさき　七月廿三日晴、シアヤ／＼／＼（これは蝉）ヒヨロ／＼／＼（これは私）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたゝね、宵月のうつくしさ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵月、そして星空、うつくしかった。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・枯枝の空ふかい夕月があつた　凩の火の番の唄　雨のお正月の小鳥がやつてきて啼く　空腹かかへて落葉ふんでゆく・枯木ぱちぱち燃える燃える　誰も来ない夜は遠く転轍の音も　宵月に茶の花の白さはある・三日月さん庵をあづけます　一月七日寒の雨、考へさせる雨だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ほつかりと宵月のある枯枝で・風がでて葉が鳴るゆふべの祈り・春風の豚でうめく・日向の椿がぽとりと水へ・春がきたどろ／＼の蓮を掘つてゐる・草の芽乞食が荷をおろした　三月一日くもつてはゐるがぬくい、さすがにもう春らしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夜に入って宵月が出て居った。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の裏側にのみある月と覚えて淡く寒く欠けたる　師走の空にかゝる十日位の半ば欠けた宵月の心持で、東京の裏側を照らすとは言ひ得て妙といふべく、或はこれ以上の表現はあるまいとさへ思はれる位だ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の粉やあるじかしこき後家の君尼寺や善き蚊帳垂るゝ宵月夜柚の花や能酒蔵す塀の内手燭して善き蒲団出す夜寒かな緑子の頭巾眉深きいとほしみ真結びの足袋はしたなき給仕かな宿かへて火燵嬉しき在処　後の形容詞を用ゐる者、多くは句勢にたるみを生じてかへつて一句の病と為る。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、宵月に照らされて、フラフラ歩いて来る人影がある。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はひとやのやみならで今宵月照る戀の園、やすらひの戸もかげやけど、きかずやあはれ、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　宇津木兵馬は、今宵月明に乗じて中房を出で、松本平の方へ歩みます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の人物は落したものを捜す体で何かを取り上げると、突然前とは全く違つた態度になつて、極めて明瞭に浄瑠璃外題梅柳中宵月、勤めまする役人………と読みはじめる。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の人物は落したものを捜す体で何かを取り上げると、突然前とは全く違った態度になって、極めて明瞭に浄瑠璃外題「梅柳中宵月」、勤めまする役人……と読みはじめる。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう夜の宵月に照らされ、城門のような岩壁の前に、桂子が立っていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と激しい下知がくだって、捕吏の一団が小突きあいつつふたりの足跡を踏んだ時は、すでに塀のそとには人かげらしいものもなく、道路をはさむ畑に薄夜の靄気がこめて、はるかの伏屋に夕餉のけむりが白く長くたなびくばかり――法恩寺橋のたもとに、宿なし犬が一匹、淡い宵月の面を望んで吠え立てていた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
