    "definitions": [
      {
        "index": 1,
        "gloss": "having served one's purpose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "餅屋が構図を飲込んで、スケッチブックを懐に納めたから、ざっと用済みの処、そちこち日暮だ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――頼まれた事は手廻しに用済みと成つたでな、翌朝直にも、此処を出発と思ふたが、何か気に成る……温泉宿、村里を托鉢して、何となく、ふら／＼と日を送つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長者用済み還って妻に問うに、主が出で往った日来た限り、一僧も来らずと答う、長者寺に往って問うに、われら不如法の家に入らぬ定めだと対う。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は会場に参り、前約通り、もはや用済みのこと故、自作を持って帰るつもりで行くと、会頭初め幹部の人々が立っていて、「ちょっと、俟って下さい」という。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "聖上行幸当日のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人来たか数えてもみないが、あとの小町娘たちにはもうご用済みだからと申し伝えて、引きさがるように手配しろよ」「…………」「…………※」「血のめぐりのわりいやつだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれでご用済みになるゆえ、はよう帰ってたんといただきなさいよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶の衆もな、かきねができたらもうご用済みでござりますゆえ、ゆっくりお説教でもお聞きなさいよ」　数珠つまぐって、静かに会釈しながら立ち去っていったのを見送るともなく見送ったその目に、はしなくも映ったのは、そこの本堂の前の階段口に、麗々と建てられてある次のごとき一札でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついきのう染め上げて、もうご用済みになりましたんで、倉入りさせようといま調べていたんですが、これが何か？",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勇みに勇んであいきょう者が飛び出していったのを見送りながら、いまかいまかと命令のあるのを待ちうけていた自身番詰めの小者たちをさし招くと、「もうご用済みだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳しいＮＡＳＡの規準には適合できなかったものの、地上でなら充分使い物になるトランジスターを部品メーカーから大量に調達したり、電子機器メーカーから用済みとなった計測器を仕入れてきたりと、環境の特殊性を存分に生かして、マッカラムは教室の整備に努めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、漸く御用済みとなった二人は、用意よく山鹿の持って来たカンテラを頼りに、帰路についた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停戦会議が成立して結局俺達臨時に御用済みにつき……と来るかも知れん」「全く遣り切れんねえ。",
              "citation": {
                "source": "お菜のない弁当",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや有難う、御用済みだ……。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用済みの雄鯵は、他の水槽の中に投げ込まれる。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると下じゃその合図で、そろそろと瓦斯を抜くから、おめえサン方は、御用済みになった観測軽気球みてえに、斜めになって頭を振りながら、御帰還あそばすッてことになるんだア。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」四　十三日の後には、福島へ呼び出されたものも用済みになり、湯舟沢峠両村の百姓の間には和解が成り立った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十日の歩役を勤めた後、今度御用済みということで、残らず帰村を許された若者らは半蔵のところへも挨拶に来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "夥しい数のマッチが散乱し、それには元通りのも折れたのも使用済みのもあって、もう一つの小さな謎を形作っていた――謎といえばまた、そこらに転がっていた二、三のテント布と毛皮の外衣には我流で非正統的な切れ目が入れてあり、想像の及ばぬ用途に応用しようという不器用な努力を物語っていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も特徴的な装飾の前の床に懐中電灯の使用済み電池が落ちているところからみて、例の他の者どもも最近この彫刻の帯に注目したのだろう。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ、それで用済みだ。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的地に着きさえすれば、忽ちつまみ出され御用済みしだい解放されるのだから、生命にも、財産にも、べつだん差障りはないのだし、何十里走らせようとも別にまた駕籠賃だの、酒料だのを要求される心配は更に無いとはいえ、ぶったくられた当人と、その身寄りの者の迷惑といったらたとうるに物がないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く知らないものを、朝から晩まで根掘り葉掘りお取調べをうけて、まだ、なかなか御用済みにならないばっかりじゃなく、かんじんの、わたしよりも一件に近い人はみんな姿を隠してしまったものですから、わたしだけが、人身御供のようになって動きが取れないじゃありませんか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう工合に困るか、末弘春吉の語るところによると、――町内から応召者が出るたびに、彼は立派な歓送旗をつくり、やがて用済みの旗がたまると、それでもって着物をつくった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子に乗って馬鹿なことをやると、御用済みになっても、旧の木阿弥に戻れないかも知れないぜ」　と案じてくれる。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御就職のことで私が駈廻っていた間は下にも置かないようにして下すったのに、御用済みになれば生返辞ばかりですもの」「占まった」　と安達君は慌てゝ立って、座蒲団を持って来て、「奥さん、さあ、何うぞお敷き下さい」　と薦めた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　山本はその場で原稿を書いて、応援の記者に持たせてやると、もう用済みだった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の一（発端）",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用済みの上もお沙汰あるまで、出先大石殿の手に従いて在役の事。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
