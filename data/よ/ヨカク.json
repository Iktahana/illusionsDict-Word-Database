[
  {
    "uuid": "cb485e76-9cc2-5016-bb74-f46de69c8964",
    "entry": "予覚",
    "reading": {
      "primary": "よかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hunch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同時に不幸にして、雷雨の予覚は当り過ぎるほど当った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もその予覚は常に来る可き悲劇に向て顫へてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだんに細かく筆を使って似せるほうと色の調子とに気を配り始めるとそろそろむつかしくなる事が予覚されるようになって来た。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはおそらく教授のドッペルゲンガーのようなもので、そうして未来の悲運の夢魔であり、眼前の不安の予覚である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れた枕紙が氷のごとく冷えて、不吉の予覚に震えるおぬいの頬を驚かした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠くても眠り切れない興奮と困憊の異様な混濁の上に、まだ／＼先に困難を控へてゐるのを予覚すると、こゝろが却つて生々として来て愉しくないこともない。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあたかも主人の功名を予覚しているように、大事のお鉄砲を肩にして大股に歩いて行った。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼等は、スティヴンスンがそうであった様に、絶えざる病苦によって短命の予覚に脅され通しではなかったのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球が今の世代になって彼らを襲う危険の性質も異って来、かつての避難所ももはや意味をもたなくなったにもかかわらず、現在新大陸にいる駱馬は、死や危険の予覚を得た際には、皆必ず昔の彼らの祖先の避難所のあった場所を指して逃れようとするという。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも能静氏が、自分の死期の近い事を予覚したものであろうか。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いまにも何人かゞこの襖を開けて自分を見るであろうという予覚によってたまらなく不安でならなかった。",
              "citation": {
                "source": "咲いてゆく花",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東にむかった社殿に幾種の絵馬が懸けつらねてあって、そのうちにかの白鷹の絵馬も見えたので、二人は近寄って暫く無言で見あげていたが、やがて半七は自分の予覚が適中したようにほほえんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "老練の船頭すらもまだそれを発見し得ない間に、かれがどうして逸早くそれを予覚したのであろうか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の胸に時どき兆していた怖ろしい予覚が現実となって現われたのに驚かされた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて廓の颶風がここへ舞い込んで来て、それからいろいろの渦を巻き起すことはありありと眼に見えているので、お時は毎朝の空を眺めて、きょうが其の破滅の悪日ではないかと、いつも怖ろしい予覚におびやかされていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍従もその運命は予覚しているので、めったに館へと帰られず、さっきからここらに行き迷っていたのであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十歳の童女から、いつの間にか、十八歳の今のクララになって、年に相当した長い髪を編下げにして寝衣を着たクララは、恐怖の予覚を持ちながらその男を見つめていた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か挙げられるナ、主義者だろうと、誰いうとなく予覚して胸を躍らしていると、やがて七、八人の警吏が各々弓張を照らしつつ中背の浴衣掛けの尻端折の男と、浴衣に引掛け帯の女の前後左右を囲んで行く跡から四、五十人の自警団が各々｜提灯を持ってゾロゾロ従いて行った。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その口付きから直ぐに、「だが……」と来るのを予覚しながら、私はぢいつとその顔に見入つて居る。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この夜こそ、恐らく、彼れが大きな天空を眺めて楽しむ最後の時となるだろうという事を、独り黯然と予覚するのであった。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどむしろ彼等の死前に於て、怨念の予覚が私の心へ喰い入って来る事は度々あった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は靄の多い朝なぞ、随分と犬が死の予覚のために苦しがって鳴くのを聴いた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し強い地震があると、又そのあとにゆり返しが来はしないかという予覚におびやかされて、やはりどうも落着いていられない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう私がなんの予覚もなしに大正十二年九月一日を迎えたのであった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとになってみると、そんなことでも一種の予覚というような事が考えられる。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明治二十四年の六月、この座で初めて上演された桜痴居士の作で、団十郎は今度が二度目であったが、その衰残のすがたが著るしく眼について、恐らくこれが最後の舞台ではないかという一種の予覚を我々にあたえた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の予覚が現実となって、「春日局」が遂に最後の舞台となったことなども語られた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し強い地震があると、またそのあとにゆり返しが来はしないかという予覚におびやかされて、やはりどうも落ちついていられない。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上人の歌に、とも跳ねよかくても踊れこころ駒　　弥陀のみのりときくぞうれしき　いかに遮られぬ光に悦び充ち足りたか覗うことが出来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが反対に、万事がうまく行き（全能の主よかくあれかし）、何かの拍子でこの手紙が破棄されず、お前の手元に渡ることがあったなら、頼むから信じるすべてのものにかけて、愛するお前の母の思い出にかけて、またふたりの愛にかけて、これを火の中にくべ、二度と思い出さずにいてくれるとありがたい。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
