[
  {
    "uuid": "617d7297-03de-5d0d-8bdb-b6b8e8f79db9",
    "entry": "与太",
    "reading": {
      "primary": "よた",
      "alternatives": [
        "ヨタ"
      ],
      "is_heteronym": false
    },
    "grammar": {
