          "literary": [
            {
              "text": "決定的な診断がつき、まあ、あと三年は生きているだろうとの予後判定だった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は予後判定にとくに注目して「最良の医師は、まずベッドサイドにおいて患者の現在、過去および将来を見抜き明らかにし、患者たちが発言で省略したものを追加することにより、予後判定ができる者である。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は重箱の隅を突っつく理論を非難し詳細過ぎる予後判定にたいして特に反対した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
