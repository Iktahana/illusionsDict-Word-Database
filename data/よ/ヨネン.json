  {
    "uuid": "ee7454c3-d2f1-52d0-8c5f-f4623cb754ed",
    "entry": "四年",
    "reading": {
      "primary": "よねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
