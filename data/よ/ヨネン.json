    },
    "definitions": [
      {
        "index": 1,
        "gloss": "four years",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大正四年元旦――",
              "citation": {
                "source": "竹",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年五年と経つても、いつかう何も書けさうもない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「長女の婿は三、四年前に北支で戦死、家族はいま小坂の家に住んでいる筈だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だったと思います。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大正四年の初め頃だつたか終頃であつたか兎も角寒い朝、その年の正月に亡くなつた弟を歌つたのが抑々の最初である。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年の十一月に死んだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年四月、小林に紹介さる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年八月頃、いよいよ詩を専心しようと大体決まる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年同人雑誌「白痴群」を出す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正四年より現今迄の制作詩篇約七百。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことは三四年振りだつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四年前の日が追憶の涙で堪えきれなくなつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸郷昭和四年の冬、妻と離別し二兒を抱へて故郷に歸るわが故郷に歸れる日汽車は烈風の中を突き行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川沖觀艦式　　昭和四年一月、品川沖に觀艦式を見る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年前に文学士になってから、しばらく神田の某私立学校で英語を教えていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "師と子規と親密になったのは知り合ってから四年もたって後であったが懇意になるとずいぶん子供らしく議論なんかして時々｜喧嘩などもする。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十四年の暮であったと思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（明治三十四年九月）",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十四年十二月）",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十四年十一月）",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐田太左衞門氏は、ゆゐしよある老舖の御主人にして、これまた、長者のふうあり、もののわかりのよきこと無類、三四年前、私と一緒に銀座うらを漫歩せしことありしが、私をしてまるで、鏡花、荷風などの老文士とともに在るが如き思ひを懷かしめた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと隣って、一段高く梯子段を上ったところに、浅間神社を勧請した離屋が、一屋建ててあり、紀伊殿御祈願所の木札や、文化年間にあげたという、太々神楽の額や、天保四年と記した中山道深谷宿、近江屋某の青銭をちりばめた奉納額などがあった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川家御朱印（天文二十四年）にも、村山室中で魚を商なってはならぬとか、不浄の者の出入を止めろとか禁制があって、それには、この村山なる事を明示している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷河で思い出したが、私が桑港にいるとき、一九二四年九月十八日の夕、新聞の号外売りが、声高く「ラッセン火山大爆裂、シャスタ氷河大融解」と、大の字｜尽くしで呼んでいるので、耳寄りに思って買って見ると、いかにもシャスタ山の、氷河融解、大洪水来と、拳大の活字で見出しがついている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ太平洋岸でも、有名な航海者「ヴァンクウバア」が、フッド火山や、ベエカア火山や、レイニーア火山を発見してから、三十四年も後に、シャスタは、やっと存在を認められた。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜だつたので、小学校四年の男の子も、私もそれを聞いてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
