    },
    "definitions": [
      {
        "index": 1,
        "gloss": "another idea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　できるだけ余念なさそうな口調で言って、前方の西郷隆盛の銅像をぼんやり眺めた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩角を一つ曲ると、かすかな燈火の灯かげに照し出され、一人の若い男が、天井から垂れ下っている大きな乳房に吸い付いて余念もなく啜っている不恰好なさまを見出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が余念なく話をしながら帰ってくると、背戸口の四つ目垣の外にお増がぼんやり立って、こっちを見て居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハア彼の紅｜梅がいゝ事ねへと余念なく眺め入りし後より。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、先生方や先輩達の、本当に学問に余念のない愉快な態度が嬉しかった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもが、さし向かえば、些の尊敬をするわけでもない、自他平等、海藻のつくだ煮の品評に余念もありません。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "長火鉢に寄っかかッて胸算用に余念もなかった主人が驚いてこちらを向く暇もなく、広い土間を三歩ばかりに大股に歩いて、主人の鼻先に突ったッた男は年ごろ三十にはまだ二ツ三ツ足らざるべく、洋服、脚絆、草鞋の旅装で鳥打ち帽をかぶり、右の手に蝙蝠傘を携え、左に小さな革包を持ってそれをわきに抱いていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア政府は、ひたすら、戦争の準備に余念がない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "４５＝お兼の室　お兼さん、室の隅の鏡を取り出して御化粧に余念が無い。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "45＝お兼の室　お兼さん、室の隅の鏡を取り出して御化粧に余念が無い。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の眼の下では彼らがやはりだんまりで、しかも実に余念なく組打ちをしている。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらと襖があいて、「あの、」ゆきさんが、余念なくそう言いかけて、はっと言葉を呑んだ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小川君は、しかし、余念なさそうに、そう言う。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『そうね』とお絹が応えしままだれも対手にせず、叔母もお常も針仕事に余念なし。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷ややかな陰の水際に一人の丸く肥ッた少年が釣りを垂れて深い清い淵の水面を余念なく見ている、その少年を少し隔れて柳の株に腰かけて、一人の旅人、零落と疲労をその衣服と容貌に示し、夢みるごときまなざしをして少年をながめている。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年あり、藁を積み重ねし間より頭を出して四人の者が余念なく仕事するを余念なくながめいたり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日ふたりは余念なく釣っていますと、いつの間にか空が変って、さっと雨が降って来ました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉ちゃんはもう、とっくに風邪なおって起きちまってるのに見舞いに来るなんて」「でも、来てやったんだい」　蓑吉は、こまごましたおもちゃを並べるのに余念が無い。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉はもう大胆に取り澄して、分取ったおもちゃを並べるのに余念ない風をしている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやが、余念もなくそんなにして居る或日の午後であった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月はやはり土間の轆轤台の前に坐って居て工作に余念も無い。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月は仕事の三昧に入り、筆を働かすに余念も無い。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勇美子は余念なく滝太郎の贈物を視めていた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎はなぜかもう胸がいっぱいになってもう一ぺん向うの谷の白い雪のような花と余念なく月光をあびて立っている母子の熊をちらっと見てそれから音をたてないようにこっそりこっそり戻りはじめた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の娘は楽しそうに、波打際を徘徊しながら、蟹を追い貝を拾うに余念もなかったが、しばらくして姉娘は急に叫んだ。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し私はただ閑静だと思ったばかりで、別に寂しいとも怖いとも思わず、斯ういう夜の景色は確に一つの画題になると、只管にわが職業にのみ心を傾けて、余念もなく庭を眺めていたが、やがて気が注いて窓を鎖じ、再び寝台の上に横になると、柱時計が恰も二時を告げた。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二十余年の間、彼女は此の窟を宿として、余念もなく赤児を育てていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大樹の聳ゆる下に落葉焚く煙が白く※って、彼のお杉｜婆は窟を背後に、余念もなく稗の粥を煮ていたが、彼女の耳は非常に敏かった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青扇は卓に両｜肘をついてコップを眼の高さまでささげ、噴きあがるビイルの泡をぼんやり眺めながら余念なさそうに言った。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の座敷は殿方ばかりにて、ビール又は正宗の空壜を作るによねんなし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
