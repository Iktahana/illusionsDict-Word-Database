    "definitions": [
      {
        "index": 1,
        "gloss": "to reach the point where ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
