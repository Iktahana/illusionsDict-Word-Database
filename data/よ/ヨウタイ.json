    "definitions": [
      {
        "index": 1,
        "gloss": "immature form (of an organism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
