[
  {
    "uuid": "1058d578-5e13-5ccb-b4dc-75873eee95e8",
    "entry": "浴す",
    "reading": {
      "primary": "よくす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
