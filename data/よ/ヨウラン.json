    "definitions": [
      {
        "index": 1,
        "gloss": "orchid of Western origin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは、今を盛に咲き満ちた見事な西洋蘭の一鉢であった。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一茎九華なる※蘭は中国特産の蘭品である、すなわちいわゆる東洋蘭の一種で Cymbidium scabroserrulatum Makino の学名を有する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が野にりようらんと在るやうに各々も各々の意志によりたい。",
              "citation": {
                "source": "傾ける殿堂",
                "author": "上里春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
