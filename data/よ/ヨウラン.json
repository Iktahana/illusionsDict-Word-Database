[
  {
    "uuid": "d9d3e59b-bc8e-5ae6-9083-50a5b64d906d",
    "entry": "揺籃",
    "reading": {
      "primary": "ようらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cradle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……愛せよ揺籃より柩にまで汝を愛せし者を愛せよ、わが愛したる者のみ独り、今も猶我をば愛す。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来最後まで同所長事務取扱の職に留まってこの揺籃時代の研究所の進展に骨折っていた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもシーザーやポンペイの活躍していた恐怖時代のローマの片すみで静かに科学の揺籃をつづっていたこの人の心境をうかがわせるに足るのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、物の表面の「粗度」の物理的研究はまだ揺籃時代を過ぎない。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現代ではまだ、学者で新聞雑誌にものを書くことが悪い意味でのいわゆるジャーナリズムの一部であるように考える理由なき誤解があるのと、また一方では新聞雑誌の経営者と一般読者とが、そういうものの真価値を充分に認識しないのとで、この種の特殊文学はまだ揺籃時代を脱することができないようである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い蓋をした揺籃車の中に嬰児が眠つてゐる。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二十）　病と貧と　（続）　噫、貧困は実に天才を護育するの揺籃なりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の一文人｜嘗て驚嘆して曰く、あゝ我が国の丸木小屋は夫れ大人物を出すの揺籃か、と。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『その昔、よろこび、そは朝明、光の揺籃に星と眠り、悲しみ、汝こそとこしへ此処に朽ちて、我が喰み啣める泥土と融け沈みぬ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は燃え街の黒い多角形の空いちめん死滅の揺籃はゆらぎそして大きな児供は夢を見始める。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "種族の花お前の精神は肉体はひさしく落葉松の揺籃に眠り嵐の氷片を餌として暮した、松の細根は泥土に埋りあたりは海のやうな苔土帯湿潤の火は燃える山猫のやうに痩せてゆく季節の毒気に萎んでゆく種族の花、愛奴　愛奴今日も高巓のななかまどの樹に腰かけて肺患の呼吸に鬚をふるはす。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後この女愛らしい男児を生むと、毎夜靴を作る男ありて「眠れ眠れわが子、汝をわが子と知った日にゃ、汝の母は金の揺籃と金の著物で汝を大事に育つだろ、眠れ眠れわが子」と唄うた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三世紀の初めウェールスのルエリン公、その愛犬ゲラートをして自身不在ごとにその幼児を守らしめたが、一日外出して帰って見ると揺籃に児見えず。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが揺籃の後ろに児の啼き声がする。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世欧州で大いに行われた教訓書『ゲスタ・ロマノルム』にはいわく、フォリクルスてふ武士妻と婢僕を惣伴れで試合に出掛け、ただ一人の児を揺籃に容れ愛する犬と鷹を留め置く。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人大いに瞋って来り迎うる犬を斬り殺し覆った揺籃を視ると、児は無事で側に蛇殺されている。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺籃の前で道は二つに分かれ、それが松葉つなぎのように入れ違って、しまいに墓場で絶えている。",
              "citation": {
                "source": "二つの道",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者は印度文明の揺籃地に関する最新の発見報告であって、其発堀せる遺物の精巧なる写真数十葉は何れも皆東洋芸術の根本資料として最も貴重なるものである。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博文館が此の揺籃地たる本郷弓町を離れて日本橋の本町――今の場所では無い、日本銀行の筋向うである――に転じたのは、之より二年を経たる明治二十二年であったと記憶する。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、同じ日本の俗曲でも、河東節の会へ一緒に聴きに行った事があるが、河東節には閉口したらしく、なるほど親類だけに二段聴きだ、アンナものは三味線の揺籃時代の産物だといって根っから感服しなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点において、探偵小説家としてのデビューをとった作者のためにも、作者らの手によって揺籃時代を通過しつつある日本の探偵小説の前途のためにも、私は作家の自重をのぞんでやまない。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年の日を養ひし大揺籃のわだつみよ、ほだしも波の鴎鳥、呼びかふ声を耳にして、磯根に近き岩枕汚れし眼、洗はばや。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺籃の記臆（ねんねしなされ。",
              "citation": {
                "source": "桜さく島",
                "author": "春のかはたれ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が野にりようらんと在るやうに各々も各々の意志によりたい。",
              "citation": {
                "source": "傾ける殿堂",
                "author": "上里春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
