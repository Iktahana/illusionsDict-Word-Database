        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "善い哉、丸山君の思いやり。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず領内に入った時、「善い哉、由や、恭敬にして信なり」と言った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んで邑に入った時、「善い哉、由や、忠信にして寛なり」と言った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ子路の邸に入るに及んで、「善い哉、由や、明察にして断なり」と言った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善いかな、善い哉、乃至、文字語言あることなし。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "三五　輕く止め難き、恣まゝなる心の調伏善い哉、調伏されたる心は樂を引く。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇六　善い哉聖を見ること、（聖と）共に住するは樂なり、凡愚を見ずんば常に樂なるべし。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "公曰く、善い哉、信（まこと）に如し君君たらず、臣臣たらず、父父たらず、子子たらずんば、粟ありと雖も吾得て諸を食まんやと。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長が鼓構えの所作も善い哉。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "大颱風を知らせる冷風が、そよめきだしてきた程度にすぎますまい」「ゆえに、真の賢人を求め、万民の災害を、未然に防ぐこと、或いは、最小最短になすべく努めることを以て、劉備は自分の使命なりと信じているわけですが」「善い哉、理想は。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の事ことごとく定まる後、初めて郷土に一｜炉を持ち、百姓とともに耕すこそ身の楽しみ、また本望でなければなりません」「善い哉、趙雲の言」と、孔明もともに云った。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "善い哉、善い哉」と、膝をうった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "火よいかなれば獸類の如く汝は沈默して言はざるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・この花を見つけた蝶の白い風・陽が落ちるそよ風の青い葉が落ちる・ゆふ風いそがしい蜘蛛のいとなみがはじまる　六月廿五日明けゆく空、朝風はよいかな。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに入浴、湯はよいかな。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼寝はよいかな、まさに一刻千金に値する（二刻は百金！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "味ふ酒、よいかな、よいかな。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "かるかやを活ける、よいかなかるかや。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉も実もすつかりおとしてしまつた木のゆうぜんたるすがたはよいかな、うらやましいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠はよいかな、よいかな、昔の面影が十分に残つてゐる、松並木がよい、水音がよい、風もわるくない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・日かげりげそりと年をとり・そこらに冬がのこつてゐる千両万両・地つきほがらかな春がうたひます・ゆふべはゆふべの鐘が鳴る山はおだやかで・鴉があるいてゐる萠えだした草　三月十一日晴、晴、朝酒はよいかな、よいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえに、どういうお礼をしたらよいかな？",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと錆びづよいかな物の臭ひがして來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの駅では何という宿がよいかなどと訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツは野球がよいかな……次には女の児として想像して見る。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "テテポッポ、カカポッポと山鳩が鳴くと松江では申します、その山鳩が鳴くと大喜びで私を呼んで『あの声聞きますか、面白いですね』自分でも、テテポッポ、カカポッポと真似して、これでよいかなどと申しました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よいかな、兵は神速をとうとぶ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山へ行く、山はよいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵はよいかな、日光はありがたいかな、小鳥のうたはよろしいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中湯田温泉に浸る、飯蒸器を買ふ、温泉はよいかな、そして飯蒸器はありがたいかな（こんな器具でも手持のそれとの間にはいろ／＼改良された個所がある、日進月歩といへば大袈裟だらうけれど、時々刻々進んでゆきつゝある時代を感じないではゐられない）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
