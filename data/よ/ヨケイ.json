[
  {
    "uuid": "918e8082-20dd-5107-a792-225d26a5e547",
    "entry": "余慶",
    "reading": {
      "primary": "よけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
