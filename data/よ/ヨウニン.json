[
  {
    "uuid": "8cf685ca-5e7d-5456-9400-28b88e81099a",
    "entry": "傭人",
    "reading": {
      "primary": "ようにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "employee",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ミサコが堅固な意志をとりかえすと、ふたたびポール商会は、事務と秩序と美にたいする感覚をとりかえして、使傭人たちが忙しそうに饒舌り、お世辞と商才が火華のように顧客を魅了した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇、日傭人夫が困ることも事実だ、私もその仲間の一人！",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "なみだによごれためるとんのづぼんをはいて私は日傭人のやうに歩いてゐるああもう希望もない　名譽もない　未來もない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なみだによごれためるとんのづぼんをはいて私は日傭人のやうに歩いてゐるああもう希望もない　名譽もない　未來もないさうしてとりかへしのつかない悔恨ばかりが野鼠のやうに走つて行つた。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しがない日傭人の兵隊たちは、戦争よりも飢餓を恐れて、獣のように悲しんでいた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度昔、彼が玄武門で戦争したり、夢の中で賭博をしたりした、憐れな、見すぼらしい日傭人の支那傭兵と同じように、そっくりの様子をして。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "役儀上、ぜひとも人数を揃へなければならない場合は、傭人足を頼むわけである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、朝の御飯のお給事をし、晩にはおやすみになるのを伺います、姑に仕えるとは、どんなことなのです、あなたがいけないとおっしゃるのは、傭人の給金を惜しんで、自分で働くことができないばかりじゃありませんか」　母親は黙ってしまったが、嫁に言いこめられたのを慚じて泣きだした。",
              "citation": {
                "source": "青蛙神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て藁が竭きると傭人は各自に其繩を足から手へ引つ掛けて迅速に數を計つては土間から手繰り上げながら、繼がつた儘一｜房づゝに括つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭人は大釜の下にぽつぽと火を焚いてあたつて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、一燻べあたつたらようがせう、今直に明くから」と傭人がいつてくれてもお品は臀から冷えるのを我慢して凝然と辛棒して居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭人がそれを發見して竊に主人の内儀さんに告げた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは僅かなことだから棄てゝ置いて遣れといつたが然し傭人は一つには惡戯から米を明けて其の代に一｜杯に土を入れて置いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは傭人の惡戯を聞いて寧ろ憐になつて又こちらから仕事を吩咐けてやつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に袋へ米と挽割麥とを交ぜたのを入れて、それから此れは傭人にも炊いてやれないのだからお前がよければ持つて行つて秋にでもなつたら糯粟の少しも返せと二三｜斗入つた粳粟の俵とを一つに遣つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し非常な勞働は傭人の仲間には忌まれた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは傭人も彼に倣つて自分も其の勞力を偸むことが出來ないからである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日巡査は隣の傭人を連れて來て壁際の木の根を檢べさせたが櫟の根は案外に少かつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭人等は笑つて勘次の容子を見て居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になつてから勘次は土藏から出されて傭人の側に一｜夜を明した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは傭人の口を堅く警めて外へ洩れないやうと苦心をした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭人もすつかり眠りに落ちたと思ふ頃内儀さんとおつぎとの黒い姿が竊に裏の竹藪に動いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里では傭人の給料が暴騰して來た程どの村落からも壯丁が行つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏の傭人の爲に抱へてある醫者に見て貰つても、老病だから藥を飮んで見た處で、さう效驗が見えるのではないがそれでも、飮みたけりや飮むが善いといふのみで別段身に沁みていつてくれるのでもない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "狹苦しいにしてもきちんとした傭人部屋の周圍の土に箒目を入れて水でも打つて見たり、其處らで作る朝顏の苗を貰つてどんな姿にも鉢へ植て見たりして居ると奉公が辛くも思はないのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の母も気の毒に思つたし、僅に三人の家族のうちでそれも私の父は大概他出して居るので家に在るものは母と私と二人のみで、傭人が寂しい夜をやつと賑はして居たに過ぎない不自由だらけな生活であつたのだから、針仕事の出来るといふのを幸に一時預つてやらうといふことにも成つたのである。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよさんは又何かいはうとしたが傭人が畑から帰つて来たので私のもとを去つた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
