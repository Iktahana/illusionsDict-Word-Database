[
  {
    "uuid": "af87a6b9-5414-5431-822b-27807fbe7487",
    "entry": "読み下す",
    "reading": {
      "primary": "よみくだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
