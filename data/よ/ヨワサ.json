        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "からだの弱さうな人だと思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱さうな、気の弱さうな人であるけれども、あれで却々野心家だとも思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "非難は、自身の弱さから。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱さ――これのある人間はいつたい善良だ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気の弱さは、気の弱い人が人を気にしない間、善良をだけつくるのだが、人を気にしだすや、それは彼自身の生活を失はせる、いとも困つた役をしはじめる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、弱さ、かね」とＹ君に、笑はれても、私は抗辯することもできず、かの赤犬の出現以來、もう、めつきり氣が弱くなつて、それからの議論は、ことごとく私の敗北になりました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は殊に夏、私を非常に衰弱させるが、それで希はくは飲みたくないものだが、夜になつて月が山の端にのぞくと、詮方もないことだ、私は飲み出してしまふのである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山の準備をしたくも、碌なものがないところで、この節の日本アルプスの登山口の、設備の方が、よほど行き届いているくらいだから、その貧弱さの、見当がつくであろう。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由はまだよく分らないが、ことによるとこれは人工物の弱さを人工で補強することの出来る一例ではないかと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は美女なりに、醜女は醜女なりに、いかにも女性の心の弱さ、お洒落さ、見栄坊であることを象徴して好い。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前と始終顏を合せながら、それをとうとう詞では云ひ出す事の出來ない自分の弱さを、臆病さを知り盡したから‥‥‥‥。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の薄志と云つた、自分の弱さと云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、賣れの惡い、氣弱さうな女は諦めたやうにまたもとの椅子に歸つた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ドライヴ　身体の弱いものがいちばんはっきり自分の弱さを自覚させられて不幸に感ずるのは、この頃のような好い時候の、天気の特別に好い日である。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　その時私は、その聲の弱さに、また顏の頼りなさに、私の嫌な嫌な、眞赤な嘘の證據を見たのだつた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の子供はいかにも弱さうだつた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貼りかえられた白い障子に照っている日の弱さはもう冬だった。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心弱さから彼女はそれを夫に秘していた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の一人相撲はそれとの対照で段々神経的な弱さを露わして来ました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かにの弱さいくじなさをののしってみたところでかにをさるよりも強くすることは人力の及ぶ限りでない。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつれあひのひとの弱さが齒がゆかつたし、それへつけこむ葉藏の兄も兄だ、と相變らずの世間の話として聞いてゐたのである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人の弱さが、かえって私に生きて行こうという希望を与える。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮説が確かめられる時は、自分の神経の弱さ、腹の弱さ、臆病さの確かめられる時であるというのはきわまりなく不愉快な恥ずかしい事である。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同時にその弱さの素因がいくらか科学的につきとめられて従ってその療法の見当がつくとすれば、それはまたこの上もない心強い喜ばしい事である。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の弱さと戦う戦士としては決して弱くなかった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の芥川君には先年｜雑司が谷の墓地で見た時のような心弱さといったようなものは見えなかった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　京子は、女性のすべてのかよわさをからだにあらわして哀願した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つになるひよわさうな男の子が、誰の中にも入らずに、蓆の片隅にえんこして、ぼんやりみんなの遊ぶのを見てゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "○出かけて、帰つてきて、庵のよさ、自分のよわさがよく解る、山頭火には其中庵の外におちつくところなし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑を耕して菜を播く準備をして置く、土のよろしさと自分のよわさとを感じる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
