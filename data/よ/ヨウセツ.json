[
  {
    "uuid": "9f194506-0d1f-538a-b7f2-f3fcd3416367",
    "entry": "溶接",
    "reading": {
      "primary": "ようせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "welding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "溶接工が、ハンマー取って金敷の上を叩いたりするようなことになるよ」職工長「つまらねえなあ、じゃあ一つ始めるか」技師長「何を始めるって。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この野望に充ちた一人の作家は、作品をこなしてゆく腕にたよって、例えば「生きている兵隊」などでは、当時文壇や一般に課題とされていた知性の問題、科学性の問題、ヒューマニズムの問題などを、ちゃんと携帯して現地へ出かけて行って、そこでの見聞と携帯して行った思想とを一つの小説の中に溶接して示そうとした。",
              "citation": {
                "source": "今日の読者の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品は他の理由から物議をひきおこしたが、作品の実際として注目をひくとすれば恐らくその溶接技術の点であったろう。",
              "citation": {
                "source": "今日の読者の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村班員は、瓦斯溶接で穴をうめております。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうした」「見つけた穴は、ぜんぶ溶接でふさぎました。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぐりつけるごとき一抹の時の悪寒の底に、個人をその溶接の一関連体とする巨大なる溶鉱炉が、姿をおこす。",
              "citation": {
                "source": "レンズとフィルム",
                "author": "――それも一つの性格である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぐりつけるごとき一抹の時の悪感の底に、個人をその溶接の一関連体とする巨大なる溶鉱炉が、姿を起す。",
              "citation": {
                "source": "物理的集団的性格",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは煉瓦職人が煉瓦を積んで生計を立て配管職人が汗をながして溶接しているのと同じ意味で書くことによって生活していることを意味している。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "年式不明の古いセダンの、ピラーと屋根を溶接機で焼き切ってオープンにしてある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむなく扉ノブから手を離そうとしたが、金属に溶接されたみたい。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
