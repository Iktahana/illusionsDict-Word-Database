        "index": 1,
        "gloss": "to send for (doctor, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その内呼びにやるぜ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやっぱり「由」の人力車を呼びにやるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「呼びにやるまで来るな！",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼びにやるとやっと一度位は来た。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内の者もおどろき騒いで、すぐに近所の医者を呼びにやると、医者は暑気あたりの霍乱であろうと診察した。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいした仕事でもないから近所の人に頼もうと云うことになって、早速徳さんを呼びにやると、徳さんは快く来てくれた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大変だと騒ぎ出して、またもや医師を呼びにやる。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいした仕事でもないから近所の人に頼もうということになって、早速徳さんを呼びにやると、徳さんはこころよく来てくれた。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃でまた媒妁人を呼びにやると、媒妁人は花聟が戻つて來たのだと早合點して、喜びながら飛んで來たが、自分の役目は若い男女を取持つのでなくて、老僧夫婦と花嫁とに親子の盃をさせることであつた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "（局票とは大阪の逢い状のように、校書を呼びにやる用箋である。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、こうしておいたんだがね、――もし談判が調えば、車で御嬢さんを呼びにやるからこっちへ寄こしてくれって。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると直に塾の書生さんを走らせて鳶頭を呼びにやる。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後の神尾主膳の挙動は気忙しいもので、面を洗う、着物を着替える、家来を呼ぶ、配下の同心と小人とを呼びにやる、女中を叱る、小者を罵る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長を呼びにやる積りであるらしい。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした、何があつたんだ」　平次と八五郎が飛び込むと、夜中に呼出されたらしい番頭の徳三郎が、「あ、親分方、丁度良いところで、今呼びにやるところでした」　さう言へば、町内の者が二三、何やら支度をして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "正月の香り",
                "note": "青空文庫"
              }
            },
            {
              "text": "井村は、大胡坐をかいて、酒を命じ、芸子と太夫を呼びにやる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の云うことなぞ信用ができないと云いながら、少し顔色が悪いくらいですぐ呼びにやるんですもの。",
              "citation": {
                "source": "柘榴",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、医者を呼びにやる召使もいなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今呼びにやるよ」　と答えて、お父さんは僕を顧みた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは、蒋門神親分のお持ち物でございますからね」「だからよ……蒋門神を呼びにやるより、そこのすべたを泣かした方が、野郎をここへ素ッ飛ばせて来る早道だろうじゃあねえか」　聞くと、帳場の女は、横の肉切り台に向って包丁をうごかしていた数名の料理人に向って、女将軍のように、往来を指さして叫んだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜ文聘はこれへ来ないか」　と、呼びにやると、ようやく文聘はあとから来て、列将の端に立った。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
