[
  {
    "uuid": "7481070d-7a83-5458-a7eb-cfce4824ec32",
    "entry": "夜討ち",
    "reading": {
      "primary": "ようち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
