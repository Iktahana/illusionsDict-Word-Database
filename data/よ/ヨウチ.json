    },
    "definitions": [
      {
        "index": 1,
        "gloss": "night attack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "各粗末なしかも丈夫そうな洋服を着て、草鞋脚絆で、鉄砲を各手に持って、いろんな帽子をかぶって――どうしても山賊か一揆の夜討ちぐらいにしか見えなかった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "米價はその頃も高値だつたが、敢て夜討ちを掛ける繪圖面ではないのであるが、町に向つて檜の木戸、右に忍返しの塀、向つて本磨きの千本格子が奧深く靜まつて、間の植込の緑の中に石燈籠に影が青い。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎君も勿論くわしいことは知らないのであるが、足利時代の遠い昔、三好家はその土地における豪族であって、なにかの事情からＫの土地に住む豪族の森戸家へ夜討ちをかけて、その一家を攻めほろぼした。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "信綱、氏鉄、夜討ちの現場を視察して、城兵の死骸の腹を割かしめて検した処が、海草の類を見出した。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえで　敵は誰やらわからぬが、人数はおよそ二三百人、修禅寺の御座所へ夜討ちをかけましたぞ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　にわかにきこゆる人馬の物音は、何事かと思うたに、修禅寺へ夜討ちとは……。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春彦　寄せ手は鎌倉の北条方、しかも夜討ちの相談を、測らず木かげで立聴きして、その由を御注進申し上ぎょうと、修禅寺までは駈けつけたが、前後の門はみな囲まれ、翼なければ入ることかなわず、残念ながらおめおめ戻った。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつら　上様お風呂を召さるる折から、鎌倉勢が不意の夜討ち……。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚三　御城下を、夜討ちにするじゃのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると為朝はおそれ気もなく、はっきりと力のこもった口調で、「わたくしは久しく九州に居りまして、何十｜度となくいくさをいたしましたが、こちらから寄せて敵を攻めますにも、敵を引きうけて戦いますにも、夜討ちにまさるものはございません。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜討ちなどということは、お前などの仲間の二十｜騎か三十｜騎でやるけんか同様の小ぜりあいならば知らぬこと、恐れ多くも天皇と上皇のお争いから、源氏と平家が敵味方に分かれて力くらべをしようという大いくさだ。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして心の中では、「何もしらない公卿のくせによけいな差し出口をするはいいが、今にあべこべに敵から夜討ちをしかけられて、その時にあわててもどうにもなるまい。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると案の定、その晩夜中近くなって、敵は義朝と清盛を大将にして、どんどん夜討ちをしかけて来ました。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼長はまさかと思った夜討ちがはじまったものですから、今更のようにあわてて、為朝のいうことを聞かなかったことを後悔しました。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして為朝一人に射すくめられて、その守っている門にはだれも近づきませんでしたが、なんといっても向こうは人数が多い上に、こちらの油断につけ込んで夜討ちをしかけて来たのですから、はじめから元気がちがいます。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっかへ夜討ちに出かける前刻のような凄じい沈黙で並んでいる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "百人にもあまる武士たちが、焚火を焚いたり割籠をたべたり、武器の手入れなどをやりながら、「明暦義党……」　とか、「萩丸様……」　とか、「今夜夜討ちして……」　とか、「今度こそ遁がさぬ……」　とか、そんな言葉を云い合っているのが、断片的に聞こえて来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今夜夜討ちをかけるとか！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤケクソに大仏殿へ夜討ちをかけて火をかけて、ブザマなことをやりながら、やっぱり負けて逃げだしている老蝮であった。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この怨みが積って保延七年の二月定明は時国を夜討ちにした。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の時国は夜討ちの為に深い傷をうけて死に瀕する時、勢至丸に向って云うことには、　お前はこのことから会稽の恥をおもい敵人を怨むようなことがあってはならぬ。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "一所では篝火の火が、亭に燃えついて火事を出してい、一所では軍兵同志が、夜討ちと誤信し、疑がい合い、同志討ちをして斬り合っていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから、第一の木戸の辺から、吹き立てる法螺貝の音と共にワッと揚がった鬨の声、木曽方が夜討ちをかけたと見える。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、鈴川方に、栄三郎が坤竜を佩して夜討ちに来ていることはきのうの午さがりから豆太郎の偵査によって当方にはわかっていた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、平家方は教経を大将として夜討ちをかけようという計画が、持ちあがっていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐房は長引いては事はかえって面倒と覚り、その夜、夜討ちをかけることにして武者所にふれ廻った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜討ちでも、昼討ちでも、この義経を討てる者が、日本国にいるわけはないぞ」　義経の威勢におされて、五十騎は易々と道を開いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを夜討ちすべきか、それとも明日襲うべきか」　と尋ねれば、田代冠者という者が進み出て、「平家の勢は三千余騎、味方は一万余騎でございますから、遥かに有利、明日の軍に延ばされるなら平家方も軍勢増しましょう、今は夜討ちがよろしいと存じます」　と述べると、土肥次郎が、「よういった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身動きをしてな、（寝ようちゃあ、寝ようちゃあ、）とよたよた体を持扱うわい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　もちろんそこの百姓はしようちしました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
