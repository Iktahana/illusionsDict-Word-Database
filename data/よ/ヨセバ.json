[
  {
    "uuid": "80b32408-cb21-5ccd-a65f-b62c1f9b1a44",
    "entry": "寄場",
    "reading": {
      "primary": "よせば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
