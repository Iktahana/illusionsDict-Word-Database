    "definitions": [
      {
        "index": 1,
        "gloss": "gathering place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川西を出たときから、新しい愛執が盛返されて来たようなお島たちはそれでもその月は可也にあった収入で、涼気の立ちはじめた時候に相応した新調の着物を着たり着せたりして、打連れて陽気な人寄場などへ入って行った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政中江戸に行われて、寄場はこれがために雑沓した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寛政六年三月九日、非常之節御寄場に差出。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場末に人寄場のあろうはずがないというのが、私の記憶に霞をかけるせいだろう、私はそれを思い出すたびに、奇異な感じに打たれながら、不思議そうな眼を見張って、遠い私の過去をふり返るのが常である。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその頃この習慣を珍らしいもののように興がって眺めていたが、今となって見ると、こうした鷹揚で呑気な気分は、どこの人寄場へ行っても、もう味わう事ができまいと思うと、それがまた何となく懐しい。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人足の寄場であった石川島。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『梅見船』第一巻「お房寄場に物の本を読む所」と題したる挿絵もまた妓家の二階にして、「火の用心」と「男女共無用の者二階へ上るべからず」と張紙したる傍の窓下には、女の鏡台多く据ゑ並べありて、数人の歌妓思ひ思ひに艶しき身の投ざまを示したり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "……非人｜寄場の勧化比丘尼のほうも残らず浚いましたが、このほうにもいなくなったなんてえのは一人もねえんです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに非人の寄場といいながら、よくもまあこうまで集めたと思われるほど、五つから七つぐらいまでの乞食の子供をかずにしておよそ五十人ばかり。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄場はおろか、橋の下、お堂の下をはいくぐっても、その小童をさがしだし、あいつに鼻をあかしてやらなけりゃアおさまらねえのだ」「へい、ごもっとも」　藤波は険悪にキッと唇のはしを引きしめ、「ごもっとも。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お静の父親の船宿は、石川島の人足寄場と小さな堀をへだてて塀ずりあわせになっているんで石川島へ行った帰りなどによく寝ころがりに行くんで、それでこういう話を知っているんです……」「おお、そうか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで、石川島の人足寄場のほうは、ちょっと上役人をいためつけ、おれは江戸無宿だからどうともままにしてくれと言ってひっくりかえれば、即座に島へぶちこんで、けっこうな手仕事をさずけてくれる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆の田浦岬の二十四五里の沖あいで行きがた知れずになった十一人の片われが、まさか石川島の人足寄場にいるとは思わない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けば、あなたの家は人足寄場のすぐ塀外。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙を石につつんで投げこめるところといったら、まず人足寄場のほかはない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊一　ハハハハ、ときに、一｜刻ばかり前に貴公を訪ねて来た上郷村人足寄場の者だといった変な男にはあったか？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも寄場あたりでも、今度のわれわれの挙に加わりたい志を持った者が何十人かいるそうだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊一　だが寄場人足がわれわれの味方で無くて、他にどんな味方があるか？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　……ウム、人足寄場の人が後を追うて五、六人で来て、そこで待っているそうだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔦　上郷村とかの寄場の人達があの人を慕ってすぐそこへ来ているそうで、それに会いに。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙　仙太郎さん、その寄場の人達というのはどうなさったのすえ？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは寄場の人足で、中の一人は第四場に出た者。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水木　そうだ、お前の手の、寄場の者等十人余りは何処にいるのか？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、俺と一緒に来た寄場の者達十一人も、もしかすると、き、き、斬ったのか？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊一　ハハハハ、時に、一｜刻ばかり前に貴公を訪ねて来た上郷村人足寄場の者だと言った変な男には会ったか？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも寄場あたりでも、今度の我々の挙に加わりたい志を持った者が何十人か居るそうだ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊一　だが寄場人足が我々の味方でなくて、他にどんな味方があるのか？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、根が骨太の岩乘なからだであつたから、十日も經たぬうちに全快し、食慾は舊の如く旺盛で、色慾などもちよつと出て來て、よせばよいのに、またもや兎の庵にのこのこ出かける。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせばよいのに、早くしないかとせき立てておいて、座敷のほうへもどって、横になってけさ見た新聞をのぞく。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一羽でよせばよかったのを、もう一羽と長追いをしたのが運の尽きだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
