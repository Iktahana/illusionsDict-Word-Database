[
  {
    "uuid": "76484a9b-9f58-505a-b024-4097c488fbb1",
    "entry": "浴する",
    "reading": {
      "primary": "よくする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
