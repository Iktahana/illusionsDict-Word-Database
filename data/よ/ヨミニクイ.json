    "definitions": [
      {
        "index": 1,
        "gloss": "hard to read",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本文は、すべて平仮名のみにて、甚だ読みにくいゆえ、私は独断で、適度の漢字まじりにする。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みにくい文章である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけてみますと、読みにくい中国語で、　『わたくしは紅倫です。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三才図会は漢文で少し読みにくいが、「相伝ふ、昔、当国（津軽）の領主、岩城判官正氏といふ者あり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謄写刷りの読みにくい字で、誤字も多かったが、八十頁余りのその記録をその夜のうちに読み終った。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈悲深き神よ、我々の命を守らせたまえ」と、ブルブルした読みにくい字で書いてよこす様なことになったのだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問に掴み処が無ければ読みにくい、掴み処があれば之が分かる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の俗支那語で書いたらしくてちょっと読みにくい。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘亭流の細字で役割を記してあるのがかなり読みにくい上に、古来の習慣として“捨役”なるものが附け加えられている場合が往々ある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な出来で、なかには画かと思はれるやうな読みにくい文字もあつたが、それも却つて面白かつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といくらか慌て気味の目で読みにくい文字を追つてゐたが、やがてまたひとり言のやうにいひ足した。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちいかな主観的な叙述でも、ある程度まで真を含んでおらんと読みにくいものである、そう截然と片っ方づけられるものじゃないと云う事であります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエニーはカールの読みにくい原稿の清書もよくした。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、踊っているような読みにくい字を西班牙語だといったのも、また、この本は十二世紀に出来たのだと請合ったのも、売った当人レクトル・エケクランツの鬚だらけな口ひとつだったからだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "この写楽はいいでしょう――が、このへんになるとどうも――それから広重――と、氏は読みにくい昔の日本文字を自由に読みこなして――東海道五十三次｜掛川之宿。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本をこめた世界思潮を知る上に役立つ本にちがいないけれども、すこし読みにくい編輯方法である。",
              "citation": {
                "source": "世代の価値",
                "author": "――世界と日本の文化史の知識――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月二十五日）『近古名流｜手蹟』を見ると昔の人は皆むつかしい手紙を書いたもので今の人には甚だ読みにくいが、これは時代の変遷で自らかうなつたのであらう。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「変わった梵字とか申すような字はこれに似ておりますが読みにくい字で書かれましたものでも御参考になることが混じっているようでございますからお目にかけます。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に出版社では、単価が高く部数の読みにくい書籍はそこそこの部数を刷って売り出し、市場動向を見て必要とあらば増し刷りする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈読みにくい画面〉というイメージの元凶は、テレビである。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで近づけるほど解像度が上がれば、画面で読みにくいとは誰も言わなくなる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ホームページは、読みにくいのが辛い。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "行間の詰まった読みにくい文章が、ゆったり組んだきれいな文字で、ページをめくりながら読めるようになった。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "達者過ぎて読みにくい字だった。",
              "citation": {
                "source": "母親",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横でそれを受けとって、あけて、読みにくいローマ綴りの字を辿ると、そこには八ガツ一ヒタモツドゾウチカシツニテシスアトフミと一並び書いてあった。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みにくいかも知れないが、是でも一生懸命にかいたのだから、どうぞ仕舞迄読んでくれ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みにくいかも知れないが、これでも一生懸命にかいたのだから、どうぞしまいまで読んでくれ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど読みにくい。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月も二三日で終るというころ、伸子は多計代からのよみにくい草書の速達をうけとった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたが来てからと思って……」「じゃ、すぐたのもうよ」　二人は薄桃色の紙によみにくい紫インクでかかれた献立表を見て食べるものを選んだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
