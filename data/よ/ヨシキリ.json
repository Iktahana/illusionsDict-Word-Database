    "definitions": [
      {
        "index": 1,
        "gloss": "reed warbler (esp. the great reed warbler, but also the black-browed reed warbler)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河畔の蘆の中でしきりに葭切が鳴いている。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田圃の小川では、葭切が口やかましく終日騒いで居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葭切、水鶏の棲家になる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城沼、多々良沼など、館林地方の平野の水には、蘆萩の間に葭切が鳴いて初夏の釣遊が忘れられぬ。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより凡十年を経て、わたくしは外国から帰って来た当時、橋場の渡のあたりから綾瀬の川口にはむかしのままになお蘆荻の茂っているのを見てしばしばここに杖を曳き、初夏の午後には葭切りの鳴くを聴き、月のあきらかな夜には風露の蕭蕭と音する響を聞いて楽んだ。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日、とうとう堪忍袋の緒をきらしたＥ師は、彼女を拉して竜泉寺あたりの風雅な宿屋へと出かけた（ああ、その頃の台東区竜泉寺には、いまだ美しい蓮田があり、葭切が鳴き、アベックに好適な水郷だった！",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺や葭切りのなく声などもよく聞いた。",
              "citation": {
                "source": "左千夫先生への追憶",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音が昼は葭切のやうにカラクヮイチ――カラクヮイチときこえ、夜は螽※のやうにギイスチヨン――ギイスチヨンといつて続いてゐた。",
              "citation": {
                "source": "夏の月",
                "author": "川端茅舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清夫は笑って、「いや、よしきり、お早う。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが林の向ふの沼に行かうとして清夫の頭の上を飛びながら、「清夫さん清夫さん。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今度は、林の中の小さな水溜りの蘆の中に居たよしきりが、急いで云ひました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが林の向ふの沼の方に逃げながら、「ふいごさん。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきり（よし原すゞめ、行々子）は、麥の蒼空の雲雀より、野趣横溢して親しみがある。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滿潮の時は、さつと潮してくる浪がしらに、虎斑の海月が乘つて、あしの葉の上を泳いだほどの水場だつたが、三年あまり一度もよしきりを聞いた事……無論見た事もない。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、よしきりだが、あのおしやべりの中に、得もいはれない、さびしい情の籠つたのがうれしい。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物と聞く切干大根の甘いにほひをなつかしんで、手製ののり卷、然も稚氣愛すべきことは、あの渦卷を頬張つたところは、飮友達は笑はば笑へ、なくなつた親どもには褒美に預からうといふ、しをらしさのおかげかして、鴻の臺を向うに見る、土手へ上ると、鳴く、鳴く、鳴くぞ、そこに、よしきり。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川原には葦がしげつて中でよしきりが鳴いてゐます。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが何処かで羽音をたてる。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸の原の中でよしきりがじゅく／＼呟きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷺町から下流はもうすっかり平地の河の姿になって、水は淀み、岸は泥砂をねばらせて、まばらに在る葭の中によしきりが鳴いています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しく光る葭原の中からよしきりが皮膚を抓るような鳴き声を立てゝ、快活に葭から出たり入ったりしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく川の両岸はよしきりの頻りに鳴く葦原つゞき、その間にところ／″＼船つき場と漁家が見え、川はだん／＼幅を拡めて来ますと、ついに海――。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりがぎょぎょしと鳴いた。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが啼きつゞける、お前はまつたくおしやべりだね、裏店のおかみさんのやうに。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが鳴いていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長閑によしきりが鳴いている。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが群れて芒の中で、騒がしく啼き立て羽搏きしたが、一斉に立って晴れた空へ、碁石を蒔いたように散って見せ、すぐに一、二町はなれた野面へ、また一斉に落ち込んだ。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月で、夜どおしよしきりが鳴いた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが頻りに鳴いて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろびろと夷隅の川の海に入る岬のかなたに虹立ちて居りよしきりのここだ来啼ける河口にかかる木橋は年古りにけり虹かゝる岬のはての叢松は小さく群れて目にさやかなり（こういう景色の雄大な優美さは、なかなかブランカ歌人の力量に及びません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
