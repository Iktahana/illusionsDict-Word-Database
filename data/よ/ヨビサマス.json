[
  {
    "uuid": "d8478ebd-f4e5-5600-bc74-3ebfd13b2e29",
    "entry": "呼び覚ます",
    "reading": {
      "primary": "よびさます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
