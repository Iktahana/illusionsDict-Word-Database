    "definitions": [
      {
        "index": 1,
        "gloss": "far away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神女遥かに芳香を飛ばして歌いしこと、室中を翔りあるく天仙としては、さることなれども、遥遠なる海島に棲む仙女とては、少しく其当を失す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道の不可思議なること、これ類似の第三点、目的地の遥遠なるに拘わらず、忽ちにして達せしこと、これ類似の第四点なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
