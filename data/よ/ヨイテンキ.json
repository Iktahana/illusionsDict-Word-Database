          "literary": [
            {
              "text": "晴れ上がった良い天気だった。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで一行は追いついてきて「良い天気になったので立山へ登りたくなってきた」と言ってラッセルを代ってくれた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに良い天気だこと。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日前、今日のような良い天気でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼らはそれを表には出さず、潮の流れとか、釣り場の水深とか、良い天気が続いているとか、今日は何を見たとか、そういうことを穏やかに話すのだった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
