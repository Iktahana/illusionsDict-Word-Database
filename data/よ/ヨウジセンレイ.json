        "examples": {
          "standard": [
            {
              "text": "カトリック教会では、生後まもない赤ちゃんに幼児洗礼を施す習慣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は両親の意向で、幼児洗礼を受けてクリスチャンになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼児洗礼の意味について、牧師から詳しい説明を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "教会ではこのところに基づいて幼児洗礼の可否を論ずるそうですが、妙なことを議論するものです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーセが許したから離婚は合法的であるとか、幼児の我に来たるを許せとイエスが言われたから幼児洗礼は合理的であるとか、そういう具合に議論をするのは心の硬い証拠です。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
