[
  {
    "uuid": "bf312040-6ac6-5bd5-b731-3c9b99044394",
    "entry": "よそ行き",
    "reading": {
      "primary": "よそゆき",
      "alternatives": [
        "よそいき"
      ],
      "is_heteronym": false
    },
    "grammar": {
