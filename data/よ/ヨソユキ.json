    "definitions": [
      {
        "index": 1,
        "gloss": "going out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてみた後にわれわれは、事によると、せっかくのその修正の成果が意外にも単調一律なよそ行きの美句の退屈なる連鎖になりおおせたことを発見して茫然自失するようなことになりはしないか。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつと、いつも裸ん坊でゐるのが、よそ行きの着物をきたから、窮屈なんだらう、と考へた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそ行きの着物といつたつて、れふしたちのは、普段着とどれ程も変つてゐない、厚ぼつたい手織の木綿であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、あの人もお仕事を休んで、新聞の広告しらべて、私もせんに一、二度、名だけは聞いたことのある有名な皮膚科専門のお医者に見てもらうことにきめて、私は、よそ行きの着物に着換えながら、「からだを、みんな見せなければいけないかしら」「そうよ。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」あまりのばからしさに、男爵は警戒心さえ起して、多少よそ行きの言葉を使った。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "木之助はよそ行きの晴衣にやはり袴をはき、腰に握り飯の包みをぶらさげ、胡弓を持っていた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから問題になっている曽田屋の娘、お政とお時の姉妹が寺参りに行くとかいうので、髪を結い、着物を着かえて、よそ行きの姿で普請場へ行ったんです。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその原稿料を、むだに使わず、まず質屋から、よそ行きの着物を一まい受け出し、着飾って旅に出た。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘を潮来へやるときに、売物には花とかいうんで、着ていた黄八丈を引っぱがして、小柳のよそ行きと着換えさせてやったもんですから、娘の着物はそっくりこっちに残っている」「むむ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜も積もるかな」　栄之丞は夕方の空を仰いで、独りごとを言いながらよそ行きの支度をした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "年じゅうやぶいりをしているようだが、きょうはおまえ、よそ行きのやぶいりかえ」「おこりますぜ、からかうと！",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ともそれ／″＼に一寸したよそ行きの着物を着てゐた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、母はよそ行きの一番いゝ着物を着ていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様は勿論ですが、自分も髪をゆい直したり、着物を着かえたり、よそ行きの帯を締めたりして、一生懸命にお化粧をして、日の暮れるのを待っていました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "免状授与式の日は勿論であるが、定期試験の当日も盛装して出るのが習いで、わたしなども一張羅の紋付の羽織を着て、よそ行きの袴をはいて行った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はよそ行きの切口上で最初から挨拶した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さあ、お見せ」「ホホホホ――」「さあお見せ、といったら」「髪がこわれるわよォ、折角｜結ったのにィ――」　女は両袖をパッと左右に開いて、男の前によそ行きの顔をしてみせた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直なことをいうと感情を害し、自己の生活などを全然客観し得ない、あるままの而も綺麗なよそ行きな部面だけを照し合わせていき合って行かなければならないのは、私にとって苦痛であり、物足りなさが増す一方であった。",
              "citation": {
                "source": "大切な芽",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女のひとはすっかりよそ行きの化粧と盛装で、白いショールをはずし、それを両手にからみつけるように持って立ち、「何がよろしいんでしょうねえ、何でもいいっておっしゃるんですよ」と、ものを書いている主人に、馴れない、すがりつくような様子で云っている。",
              "citation": {
                "source": "日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性の作家が、生活の為に創作をする事の少い現在の状態は、動機も純粋になると同時に、一種よそ行きな、拵えると云う心持を創作の時に持たせる事がありはしまいかと思う。",
              "citation": {
                "source": "概念と心其もの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、かの女として充分燒きもきすべきよそ行き衣類質出しの件は何とも云つてゐない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "往來の人々も、平日とは違つて、よそ行き姿の景氣がいい樣に見える。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "およめさんはよそ行きのきれいな着物が、どろでよごれるのもわすれて、水田のなかへはいって行きました。",
              "citation": {
                "source": "たにしの出世",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしげは、豊太郎に早めに暇を貰つて、着がへるとさつさと新しいよそ行きの下駄を出した。",
              "citation": {
                "source": "一の酉",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、凡そ二十分、寫眞の上の顏よりは、刻下の寒さをとて、外套の頭巾、目深くかぶれるに、他の三子、いづれも襟もしくは頭巾を脱して、凛々たる寒風の中に、よそ行きの顏してすましこみたるは、年若きだけに殊勝げなり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度パリで買って私の気に入ったパンタロンは、よそ行きも常も婚礼も朝から晩まで着通して、今なお着用しているがさすがに、縞が磨滅して来た。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして今度は自分が高等によび出され、正面に黒板のある警官教室みたいなところを通りがかると、沢山並んでいる床几の一つに娘さんがうなだれて浅く腰かけ、わきに大島の折目だった着物を着た小商人風の父親が落着かなげにそっぽを向きながらよそ行きらしく敷島をふかしている。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、よそゆきの言葉でお答えになった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏目がふつくりとする……而して、緋無地の背負上げを通して、めりんすの打合はせの帶の間に、これは又よそゆきな、紫鹽瀬の紙入の中から、横に振つて、出して、翁に與へた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつきり男ぶりのいゝ處へ、よそゆきから歸宅のまゝの、りうとした着つけである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
