  {
    "uuid": "288a35a9-2aaf-523b-9e20-3cd806616a85",
    "entry": "止せ",
    "reading": {
      "primary": "よせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
