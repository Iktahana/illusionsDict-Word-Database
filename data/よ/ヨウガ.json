      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Western painting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられてゐて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられていて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの点が、彼の句を枯淡な墨絵から遠くし、色彩の明るく印象的な西洋画に近くしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、これらの句には、洋画風の明るい光と印象があり、したがってまた明治以後の詩壇における、欧風の若い詩とも情趣に共通するものがあるからである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画風の感覚による構成である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城のやうな洋画的の山でもなければ、妙義のやうな文士画風の山でもない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃田舎では石版刷の油画は珍しかったので、西洋画と云えば学校の臨画帖より外には見たことのない眼に始めてこの油画を見た時の愉快な感じは忘られぬ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日の洋画家中唯一の浅井｜忠氏を除けばいずれも根性の卑劣な※の声を打消していった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の二科会の洋画展覧会を見ても「天然」を描いた絵はほとんど見付からなかった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画家並びに図案家としての津田君は既に世間に知られている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美学者や心理学者はこれに対してどういう見解を下しているか知らないが、とにかく東洋画｜殊に南画というものの芸術的の要素の中にはこれと同じようなものがある事は疑いない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代西洋画が存在の危機に瀕した時に唯一の救済策として日本画の空気を採り入れたのは何故であろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合にこの室の屏風からは何物をも受取る事が出来ないので、今度はその隣りにある洋画臭い風景画に移って行くと、その新しい描き方に少時足を止めさせられたりする。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評でも書いてみようという成心を持っていない、通り一遍の観覧者の多数は、おそらくこういう感じを抱いて洋画の方へ移って行くに相違ない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画部から受けた灰色の合成的印象をもって洋画部へはいって行くと、冬枯れの野から温室の熱帯樹林へはいって行くような気持がするのは私ばかりではあるまい。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展の洋画については私はあまり取りたてて云うほどの変った考えを持ち合せない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画部では好きなのが除外例であるのに反して洋画部では悪い方のが特に眼につく。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るく鮮やかであった白馬会時代を回想してみると、近年の洋画界の一面に妙に陰惨などす黒いしかもその中に一種の美しさをもったものの影が拡がって来るのを覚えるのは私ばかりではあるまい。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう点で、これらの絵は、有り来りの油絵よりは、むしろ東洋画に接近しているかもしれない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田氏の日本画は一流のものであるが、今年の洋画はただの一点で、それがあまりに投げやりである。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画の方へ行くと少し心持がちがう。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯浅氏の回顧陳列もある意味で日本洋画界の歴史の側面を示すものである。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ると白馬会時代からの洋画界のおさらえができるような気がする。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの面の顔の表情に、どこか西洋画で見るパンの神のそれに共通なものがあるような気がしてならなかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画と西洋画の区別が年と共にいよいよ分からなくなって来た。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにそうかと云って、洋画家で絵絹へ油絵具を塗る試みをあえてする人、日本画家でカンバスへ日本絵具を盛り上げる実験をする人がないのはむしろ不思議なくらいである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画を通じてルソーやマチスや、ドランやマルケーなどのようなフランス絵の影響がこっそり日本画の方へ入り込んでいるのを発見する。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画でも日本画でも人物の顔をなるべくスチューピッドに描く事が近年の流行のようである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画の方に「測候所」があると、日本画の方にも「測候所」及び「海洋気象台」がある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、洋画の方には鎧武者や平安朝風景がない。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
