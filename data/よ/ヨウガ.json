[
  {
    "uuid": "30f25df9-5ed7-5e90-873d-9a94005c7d7e",
    "entry": "洋画",
    "reading": {
      "primary": "ようが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
