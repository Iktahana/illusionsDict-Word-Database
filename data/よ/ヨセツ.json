[
  {
    "uuid": "38cce7c0-4f03-5f7f-bc6c-25709a84ee65",
    "entry": "余接",
    "reading": {
      "primary": "よせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cotangent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「お前は、人をよせつけないから、ザンパンが有ったってやらないよ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それから、炊事場へ露西亜人をよせつけることはならん。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、お互ひの頭をよせつつ、なほ鳥渡の間その寫眞に眼をそそいだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりのお百姓は、「どろぼうをよせつけないやうにするには、犬をお飼ひになるにかぎります。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らを脅して肉片によせつけないようにするには、たいへんな努力と注意が必要だった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪問者は一人もよせつけなかった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌どもを少しよろしと聞きて、船のをさしける翁、月頃の苦しき心やりに詠める、「立つなみを雪か花かと吹く風ぞよせつゝ人をはかるべらなる」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿だつてつまらなく女を傍によせつけてばかりはゐない……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣をつくつて力んでゐるふうは少しもないのにそこからさきはよせつけぬといふところがあり、うかつに順吉の過去にふれることを阻むものがあつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし強い僧は手ごろの若木を引きぬいて武器とし、それを打ちふって首をなぐりつけ、恐ろしい力でなぎたててよせつけなかった。",
              "citation": {
                "source": "ろくろ首",
                "author": "ROKURO-KUBI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは朝から人をよせつけません。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に戦争の起っているときであれば、誰しもこの事から超然とはしがたい悩みふかまる内心の問題であり、おそらく久慈も立ち騒ぐ周囲のものらの言動にことよせつつ、蔽いきれぬ彼の悩みも、文面多忙な匂いに変りむら立っているのかとも矢代は想像した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの冬は、どうして、こんなに人がいないのだろう、たまに、人のいる別莊をさがしてみても、そこの人達は、ペットを棒で追ったりしてよせつけてはくれない。",
              "citation": {
                "source": "美しい犬",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから下だらない奴とのつき合ひなんかよせつてんだよ』『お前さんと私とは違ふつて云つてるぢやないか。",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "陥没と、大湿林の天険がいかなる探検隊もよせつけぬといわれる、この大秘境の墻の端まできたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの御姫様は御気象も並々ならず御闊達でいらっしゃいましたから、なまじいな殿上人などは、思召しにかなう所か、すぐに本性を御見透しになって、とんと御寵愛の猫も同様、さんざん御弄りになった上、二度と再び御膝元へもよせつけないようになすってしまいました。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、団長がいっても、スミ枝がいっても、よせつけなかった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う力強いものが目の前にあると余計自分の命が危くなる様で、なるたけ、そばによせつけなかった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ相手は鉄片をそばによせつけないという、不思議な力のある怪塔ですぞ。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この知らせをきいて、長男や女房が野良から駈けつけてみると、キコリたちがエイエイと大木に切りこんでおり、門前には助六が六尺棒を握りしめて、女房子供もよせつけない。",
              "citation": {
                "source": "餅のタタリ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすぐらいスタンドのあかりを枕許によせつけて、父はそこに喘いでおります。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学は怪談をよせつけない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符売場から、楽屋口から、待合室から、劇場を十重廿重にとりまいて占領した娘子軍は、実にボージャク無人、余人をよせつけない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの家にも来たがっているけど、おかあさんよせつけないようになさるの。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　時局の波は、この東北の山間の村々にも、ひたひたと押しよせつつあった。",
              "citation": {
                "source": "荒蕪地",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ困ることにはあいつは気むずかしくて、医者などはいっさい傍によせつけないから、看護夫の態で住みこんでそれとなくやってもらうほかはないんだが、それも承知してくれるか」「そんなことはなんでもない」「それはありがとう。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを大きくなってから、すこしの損得で、兄弟げんかをしたり、たがいにゆききしないものがあれば、また中には、大恩のある、母親をきらって、よせつけないものがあるといいますから、世の中は、おそろしいところですね。",
              "citation": {
                "source": "煙と兄弟",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛田　　よせつたら、よさないか。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "金田　　よせつたら……君はそれがいかんのだよ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
