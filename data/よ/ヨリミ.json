    "definitions": [
      {
        "index": 1,
        "gloss": "pushing an opponent out with one's body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寄り身になって横へ払った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この掬ひ投げを打つた時、双葉の右足が前に出てゐるのは必定で、安芸がこれを懸命に防がんとして左足が外掛けにからんだ瞬間に、双葉の両廻しをぐいつと満身の力で引きつけて浴せかけたものだから安芸の寄り身が物を云つたのだらう』云々。",
              "citation": {
                "source": "双葉山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は引分け専門の力士もいたし、足ぐせの名人、吊り専門、寄り身の名人といろいろあったが、うっちゃりの名人というのは聞かない名人だ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに紋也は押し返したが、一刀流での寄り身捨て身だ、交叉した太刀の交叉をといて、ハッと柔かに上へ上げて、兵馬がそれへのっかかって、袈裟掛けに切り込んで来たところを、左のほうへ体形を捨てた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の寄り身に驚かず、悠然立っていることは、それにも勝して至難である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐く呼吸あらく「寄り身の手」膝を掻こうと飛び込んだ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふて腐ったようなのが三十人ばかり、「なんだなんだ」といいながら、寄り身になって久太夫のほうへ詰め寄ってきた。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を振ろうとすると下手をこじる、ぐいぐいと寄り身になって緊めあげる。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよ、作品観賞に際して抽象的視点（例へば「語感」の如き）を与へて、その点よりみるといふことは意義がない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "西根よりみめよき女きたりしと、　　角の宿屋に眼がひかるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝うつりいよりみだらひ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども真なる信仰の教法よりみれば、この願いもこの満足も無きがごとくにはかなきものなり。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの工場でも何よりみんなのいやがる罰金制、歩増制度、強制貯金などが行われているのは、誰でも知っている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど我が立脚點よりみるときは、感情は主觀の理想にして、觀相は客觀の理想なり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば或る点よりみれば進歩主義たるべく、また他の点より見れば保守主義たるべく、けっして保守もしくは進歩の名をもってこれに冠することを得べからず。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "「賛成するもしないも、お父様の御機嫌をなおして頂くにはそれよりみちがないでしょう」　姉は云いきかせるような口振りになった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その唇や手の動き具合よりみれば、彼女たちは確かに何か活気のある話をしているようであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これははなはだ着実な議論であるが、さらに一歩を進めて高い見地よりみれば、老子の言うごとく、名の名とすべきは常の名にあらずである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉を裏面よりみれば、衰えぬときは、周公のことを夢にまでも見たということを含んでいるであろう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで主治医の注意によりみんなが枕頭に集つた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの原理的性格よりみれば、それは單なる「物」であるに盡きる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間性の觀點よりみれば、物の美しき又は眞なる姿に見入る喜びは現在を樂しむ喜びである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この觀點よりみて、時の無終極性、終りなき果てしなき時、は何を意味するであらうか。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの論證は、純理論的觀點よりみれば、極めて薄弱なる論據及び推理の上に立つてゐるであらうが、背後にあつてそれを支持しそれに生命を與へる思想や信念は、生の源より發したものであり且つそれぞれ典型的意義を有する。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如き觀點よりみられたる主體は他者において自己を實現する働きの中心乃至出發點である。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間性の觀點よりみられたるかくの如き高次的純粹客體の擔ふ性格こそ、「無時間性」（Zeitlosigkeit）の意味における永遠性に外ならぬ。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして時間性の觀點よりみられたるかくの如き純粹的高次的存在のもつ性格こそ永遠乃至不死（〔aei on, athanaton, aio_n, aio_nion〕）である（六）。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故文化的生の全體といふ觀點よりみれば、哲學は主體の自己實現の一契機を一時的に特に抽き出し、それのみに注意を集中し他を忘れるものに外ならぬ。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの目的が死後に達せられるといふは、純眞なる觀念主義の立場よりみれば、達せられぬと告白すると何の擇ぶ所があるであらうか。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを時間性の觀點よりみれば、現在と將來との間の離反不一致が空間性なのである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
