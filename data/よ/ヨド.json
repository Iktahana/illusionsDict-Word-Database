    "definitions": [
      {
        "index": 1,
        "gloss": "pool (in river)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『仰臥漫録』に「顕微鏡にて見たる澱粉の形状」の図を貼込んであるのもそういう意味から見て面白い。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、言葉の後半は、口の中で澱んで、ああ、とか、うう、とかいふやうにしか聞えない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煙が澱んだ空気の中をくねりながら昇る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ草分け時代の空気が、澱んでいる。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪解の水に漉されて沈澱した砂は、粒が美しく揃って、並の火山礫などとは、容易に区別が出来る。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の空気を下の関までそっくり運ぼうとでもするように車室内の空気はムンムン沈澱していた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ三色に染め分けた澱粉を使って一枚の板を三枚に代用するだけの手品である。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず細かい粉のよく揃った澱粉を青赤黄の三色に染め分け、これを適当な割合で丁寧に混合する。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし種板の一点に青い例えば空の色が写ったとすればその色の光は青の澱粉だけしか通らぬから、従って青い粒の裏に当る部分だけが感じて、現像すれば其処の銀が還元する。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の障子を開けた外は重なった峯の岨が見開きになって、その間から遠州の平野が見晴せるのだろうが濃い霞が澱んでかかり、金色にやや透けているのは菜の花畑らしい。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは温泉から沈澱したのです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉から沈澱したのです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には薄く酸化鉄が沈澱してあたりの岩から実にはっきりしていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折詰の飯に添えた副食物が、色々ごたごたと色取りを取り合せ、動物質植物質、脂肪蛋白｜澱粉、甘酸辛鹹、という風にプログラム的に編成されているが、どれもこれもちょっぴりで、しかもどれを食ってもまずくて、からだのたしになりそうなものは一つもない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今度仏国のカルメットという人の発表した所に拠ると、酒精で沈澱させたツベルクリンの一プロセント溶液を眼に点ずると、健康体ならば何の異状も起らぬが、少しでも結核のあるものならば、二十四時間内に充血して紅くなるという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日のリュミエール会社のオートクローム板は三色の澱粉を混合して作ったものだが、今度のは種板の上に三色の細い線を並べたもので大体の理窟は前のと変りはない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『道徳教』でも『論語』でもコーランでも結局はわれわれの智恵を養う蛋白質や脂肪や澱粉である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日々に憔悴し、血色が悪くなり、皮膚が老衰に澱んでしまった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "形のいい鼻の粗い魅力がうす黒い建物に吸いこまれると灰色のホテルの壁にそって彼女の影がコンクリートの階段を中年女の靴音をのこして一歩、一歩、女の強い忍従が右に折れると、或る部屋の扉を繊奢な澱みもなく暴々しくノックした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "其場所が全たく僕の氣に入つたのである、後背の崕からは雜木が枝を重ね葉を重ねて被ひかゝり、前は可り廣い澱が靜に渦を卷て流れて居る。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬を辿つて奧へ奧へと泝るに連れて、此處彼處、舊遊の澱の小蔭にはボズさんの菅笠が見えるやうである。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝の水は澱んで腐り、泥の中からは棒振りが尾を出していた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは潜む蒼穹に、　　　　　あはれ鵞王の影供ぞと、面さへ映えて仰ぎしを、　　　　いまは酸えしておぞましき、澱粉堆とあざわらひ、いたゞきすべる雪雲を、　　　　腐せし馬鈴薯とさげすみぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　硫黄猛しき現場監督の、　　　　こたびも姿あらずてふ、元山あたり白雲の、　　　　澱みて朝となりにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業式三宝または水差しなど、　　たとへいくたび紅白の、甘き澱みに運ぶとも、　　　鐘鳴るまではカラぬるませじと、うなじに副へし半巾は、　　慈鎮｜和尚のごとくなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早池峰の西どなりの群青の山の稜が一つ澱んだ白雲に浮き出した。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊の木の中でも樺の木でも、またかれくさの地下茎でも、月光いろの甘い樹液がちらちらゆれだし、早い萱草やつめくさの芽にはもう黄金いろのちいさな澱粉の粒がつうつう浮いたり沈んだりしています。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は決して澱粉蛋白脂肪だけで生きて行かれるものではない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が言い澱んでいると、先輩は、どれどれと言って私の手から巻紙を取り上げて、「むかしの事だから、どんな文句か忘れてしまった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な色をしたきれぎれの雲が、沸きたつては澱み、澱んではまたゆるゆると流れてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
