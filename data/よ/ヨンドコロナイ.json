[
  {
    "uuid": "bf1d52b2-41d2-5678-9c74-c584aeb58914",
    "entry": "拠所無い",
    "reading": {
      "primary": "よんどころない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
