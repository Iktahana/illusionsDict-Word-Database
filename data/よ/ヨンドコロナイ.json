    },
    "definitions": [
      {
        "index": 1,
        "gloss": "can't be helped (of situation, reason, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "結局よんどころないと云う事で、自分は母と一緒に出掛けることになった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妹と二人で家をあけちゃあ困るんですけれど、きょうはよんどころない御代参を頼まれたもんですからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "走り書きの短い手紙で、よんどころない訳があって死にますから先立つ不孝はゆるしてくださいというようなことが書いてあったので、おふくろはまたびっくりして、すぐにその書置をつかんで私のところへ飛んで来ました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころない時は非人も致します。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには罹災後のよんどころない不摂生もあろう。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶望から生み出されたよんどころない諦めには相違ないのですが、なにしろ愚痴ひとつ言わないで、ひどく思い切りのいいような様子で、元気よくいろいろのことを話していました。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出先によんどころない用が出来て、時刻がすこし遅くなったので、急いで家を出て、鬼ばば横町にさしかかると、横町の中ほどの大溝のきわに、ひとりの真っ白な婆が坐っているのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷御徒町に住んでいる諸住伊四郎という御徒士組の侍が、よんどころない用向きの帰り路に日本橋の浜町河岸を通った。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実はきょうの午後に、よんどころない葬式があって北千住の寺まで出かけまして、その帰り途に三、四人連れで千住の通りを来かかると、路ばたの鰻屋の店先で鰻を割いている男がある。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして日が暮れると、土地の人でもよんどころない用事のほかは外出しなかったらしい。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはむしろ好機会であると思ったので、お筆はよんどころないような顔をして、お蝶と友之助との秘密をあばいてしまった。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかに速く動くよ、六月の雨は、寄せ集められて、最上川に」「大波は巻きつつ寄せる、そうして銀河は、佐渡島へ横切って延び拡がる」　このごろ、よんどころない必要から、リグヴェーダの中の一章句と称するもののドイツ訳を、ちょうどこんな調子で邦語に飜訳しなければならなかった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しようがないから」「どうすることもできないから」「よんどころないからあきらめている」というような心持ちで、いかにもつまらない冷やかな家庭を作っていねばならないのか、ああ考えるのもいやだ……。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実はよんどころない人に頼まれて案内して来たんですが、親分、逢ってくれますかえ」「ここまで連れ込んでしまった以上は、逢うも逢わねえも云っちゃあいられねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はよんどころない事情を訴えて、かさねて金の無心をたのむと、甚右衛門はやはり承知しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所といい、事件といい、主人持ちの彼に取っては迷惑重々であったが、よんどころない羽目と覚悟をきめたらしく、かれは検視の終るまでおとなしくそこに抑留されていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかの時にそんな挨拶を聞くくらいなら、お前なんぞに用はないのだ」　彼女は怒って立ち去ろうとするのを、一行は追いかけて、頻りによんどころない事情を説明して聞かせたが、王婆は見返りもせずに出て行ってしまった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はほかによんどころない義理があって、半七は午頃から日本橋辺へ出かけたが、例の一件が気になるので、その帰り道に青山へ足を向けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪忍して下さい」　彼女が泣きながら訴えるのを聞くと、お光の奉公している三河屋のお内儀さんは、よんどころない義理で二十両取りの無尽にはいっていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで切れる縁ならば、こうして切れてもよんどころない。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "林之助が努めて相手の視線の外に逃がれ出ようと顔をそむけているのも、彼としてはまことによんどころない事情であった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも運命――これもよんどころない災難とあきらめて、妹の死んだ跡を弔って遣るより外はありませんよ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同士撃ちはよんどころないとしても、敵は大勢である。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その無理からこゝに一つの事件が出来したのは、まことによんどころないことでした。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎　よんどころない用があつた……。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよんどころない不運と諦めも致しませうが、せめては無實の罪といふことをお上へ申立てまして、父彦兵衞の惡名を清めたうござります。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころない羽目で世話をしたものの、あれで無事に納まってくれればいいがと、庄屋も内々心配していると、不思議なことには、それからまた半月と過ぎ、ひと月と過ぎてゆくうちに、お年はめきめきと元気が付いて来て、顔の色も見ちがえるように艶々しくなった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "当番その他のよんどころない差支えでない限り、ひと晩でも参詣を怠らなかった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は主人が出ましてお話をいたす筈でございましたが、よんどころない用事が出来まして、残念ながら俄かに欠席いたすことになりました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
