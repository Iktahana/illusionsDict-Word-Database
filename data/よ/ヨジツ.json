[
  {
    "uuid": "43c182b9-094b-5de8-9182-df5955700271",
    "entry": "余日",
    "reading": {
      "primary": "よじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "remaining time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "開演期間二十余日の間毎晩一度ずつ躓かなければならないことを考えると俳優というものもなかなか容易ならぬ職業だと思われる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山を攀じ、峠を越えてここに十有余日。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "欣弥　一別以来、三年、一千有余日、欣弥、身体、髪膚、食あり生命あるも、一にもって、貴女の御恩……白糸　（耳にも入らず、撫子を見詰む。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十余日間打ち通して、古今稀なる大入と称せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、新富座の一番目「赤松満祐」中幕「勧進帳」二番目リットンの翻案「人間万事金世中」、大入りにて、六十余日を打ち続け、京浜在留の外国人より、引幕を贈りて総見物あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "相距ること二十余日、天と地の間に於てこの距離は幾何ぞ。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この暑さにこの幼い子を十余日の旅に連れあるくことは危険でもあり、少々｜果断にも過ぎた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ことしももう余日がないので、来春になったらばいよいよお蝶を輿入れさせるということに取りきめて、まずこの一件も一埒明いたのでした。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳町の百二十余日、予はついに満足を感ずることができなかった。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、信玄は海津城に謙信は妻女山に相対峙すること十余日に及んで、いつか九月九日｜重陽の節句になった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十年の六月、突然｜急痾に犯されて殆んど七十余日間｜病牀の人となった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境を守って、松倉家からの注進を聞きながら、脾肉の嘆を洩しているうちに、十余日が経った。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考では、矢張、『道』だの、『輝ける朝』などよりも、初期の『四十余日』や『お寺の児』や『暗い家』などの方が光つてゐるやうに思はれた。",
              "citation": {
                "source": "『水野仙子集』と其他",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年を三六五日にするために歳の終りへもってきて『五日の剰余日』を置いた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一覚が申すとおり木屑を焼き捨てやっと七十余日かかって、その木を伐り倒したので、かくて帝の御悩御平癒ましましければその樹の生いありし所を名づけて栗田郡と号しけるとなん。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は老媼の家に、一月の下旬から三月の初めまでざっと五十余日の間ほとんど毎日のように熱心に通った。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局へ出かける、とてもうらゝかな日である、久しぶりに――四十余日ぶりに理髪、そして久しぶりに――十余日ぶりに入浴、身も心も軽くなつた、――二十八銭の保健的享楽といへばいへるだらう！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして百余日にわたる牢獄生活、これを通じまして天野検事がその時にもらされました一ツの嘆声が実はこの三鷹事件の本質であったということを感じてきたのであります。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そして百余日のあいだそんなやりもしないのにそんな共同正犯なんて、そんな馬鹿なことがあるものかという気持と、私は自分の潔白を申しでて来たにもかかわらず、髪の毛をつかんでそしてあの武蔵野市の警察の玄関をひきずり歩かされ、そして警察の権力によって牢獄につながれている。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらをうけて、二十三歳の水野仙子は「四十余日」「娘」など書いている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十余日を経て五尺ばかりの大幅見事に出来上りたるつもりにて得々として帰り直に浅井氏に示す。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃のぐあいが少しよくなった頃には、締切日があと十余日くらいになってしまった。",
              "citation": {
                "source": "健康と仕事",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平洲為之称有疾、謝来客、息講業十余日、無朝無暮、語言一室、若引緒抽繭、縷々不尽」であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寓湯江村法岸精舎十余日。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で事があつて、京の街に住むこと二十余日にして、又嵯峨に帰つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）此頃頭瘡を病み、家居して療養すること四十余日に至る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月、日光に赴き、十余日にして帰る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とくと、勘考仕りますが、府内へ到着するまでには、未だ未だ余日もあること。",
              "citation": {
                "source": "大岡越前の独立",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は此の世にいわば幕屋に住めるごとく宿り、あるときは谷間をたどり、あるときは広野をよこぎり、あるときは山の頂きをよじつつあった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
