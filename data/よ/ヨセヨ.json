    "definitions": [
      {
        "index": 1,
        "gloss": "for heaven's sake (Pete's, mercy's, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
