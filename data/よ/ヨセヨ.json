        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女達はしきりに気もちわるがってよせよせと云う。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、おい、バキチ、あんまりみっともないざまはよせよ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兄のラクシャン第三子が「よせよせいたづらするなよ」と止めたがいたづらの弟はそれを聞かずに光る大きな長い舌を出して大学士の額をべろりと嘗めた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兄のラクシャン第三子が「よせよせいたずらするなよ」と止めたがいたずらの弟はそれを聞かずに光る大きな長い舌を出して大学士の額をべろりと嘗めた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿江は本当に恐ろしがって招き猫のような恰好をした）乱暴はよせよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺はいやだよ、よせよ」と自分にからみついてくるガンベの鉄のような力強い腕を払い退けながら、柿江の足は我にもなくガンベの歩く方に跟いていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホレーショー、いい加減の事を言うのは、よせよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが、よせよせと言った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毛布は、よせよ」「ケチだなあ、お前は」　とさらにしつこく、ねばろうとしていた時に、女房はお膳を運んで来た。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、とまた考えて、ごちそうさまでした、とだけ言って、それで引きさがるのは、なんだか、ふだん自分の銭でお酒を呑めない実相を露悪しているようで、賤しくないか、よせよせという内心の声も聞えて、私は途方に暮れていた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせよせ」上さんの肩の所に手を掛けて、二三遍ゆさぶって置いて、自分の床に据わった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな大でこ／＼のハイカラ女などよせよ」と村松に蔭で注意された時も、義雄は心で、どんな美人でも、おのれの物にならないうちは、人と云ふものは冷笑するものだからと思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、よせよせ」僕は三味線を取りあげて、脇に投げやり、「おれが手のすじを見てやろう」と、右の手を出させたが、指が太く短くッて実に無格好であった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北山からかうのはよせよ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬二郎の奴と話なんかするのよせよ」　正勝は微笑を含んで、しかし睨むようにしながら言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでもないのよ」「あいつが散歩に誘ったって、一緒に散歩なんかするのよせよ」「それでも、急に冷淡にするわけにはいかないのよ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまらんことを云うのは、よせよ、聞かれるぜ」　半ちゃんは口をつぐんで苦笑した。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もう馬鹿な事をよせよ。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはまさんなんかかわいそうな所があるんだアな、同病｜相憐むというんじゃねいか、ハヽヽヽヽヽ」「あん畜生、ほんとにぶちのめしてやりたいな」「だれを」「あの野郎をさ」「あの野郎じゃわからねいや」「ばかに下等になってきたあな、よせよせ」　おはまがいるから、悪口もこのくらいで済んだ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせよせ、婿にゆくなんどいうばかな考えはよせ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあおめえの親類の話じゃあねえか」「よせよ」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よせよせ」などという声がする。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柄にないことはよせよ。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もどってきたら、半殺しにしてやる」「よせよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふたりでずっと、おれのことを笑ってたんだ」「よせよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「令子ちゃんがいなくなるんだからね」「よせよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だれのことだ」「よせよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺書をさがしそうになったぜ」「よせよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……令子のことをいってるんじゃないんだ」「じゃあ、だれのことだ」「よせよ、ほかにだれが――」　非常口のほうから、笑い声と足音が響いてきて、高志は開きかけた口を閉じてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝにむかしつ人の母、一日片時も忘れねばよめる、「住の江に船さしよせよわすれ草しるしありやとつみて行くべく」となむ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
