    "definitions": [
      {
        "index": 1,
        "gloss": "to call out to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後も教授が厳粛な顔をしてこの人の名を呼びかける度に笑いたくなって困ったのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しのぶ塚と云うを見ているうち我を呼びかける者あり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然すぐ前の溝の中から呼びかけるものがある。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでに心身の緊張をほぐし、徐ろに食欲に呼びかける時間なのだ。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花道へ現れた紙屋治兵衛に「モダンボーイ」と呼びかける弥次馬の声などもただ笑って聞いてばかりもいられないような気がする。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子が跡から菅笠を被って出ると、母が笑声で呼びかける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は何かに呼びかけるような表情になって、眼を開けたまゝ固くなっていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの通る時刻と前後して隣の下宿の門の開く鈴音がして、やがて窓の下から自分を呼びかける同郷の悪友ＴとＭの声がしたものである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ人を目当てにしたものか、遺族ないしは会葬者に対して読まれるものだろうか、それとも死者に呼びかける形式で会葬者に話しかけるものだろうか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お――い、お――い」　患者が看護人を呼ぶように、力のない、救を求めるような、如何にも上官から呼びかける呼び声らしくない声で、近松少佐は、さきに行っている中隊に叫びかけた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して全世界のブルジョアはむろん歓迎の辞を以てあなたを呼びかけるでしょう、帝国主義者は、数多の贈物をもたらすでしょう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやかしていると、「ドクトルの旦那さん、降誕祭贈物はいかがです」と呼びかけるのもありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとから不意に鋭い声でプール・レ・ポーヴルと呼びかける。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って眼前の「妖魔詩話」が私に呼びかける呼び声もまたやはりこの漠然とした不思議な印象の霧の中から響いてくるのは自然の宿命である。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早く言えば一種の骨董芸術で、現代人に呼びかける処は一つもない。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の顔が見えると妹は後の方からあらん限りの声をしぼって「兄さん来てよ……もう沈む……苦しい」　と呼びかけるのです。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんでねえか」　道の方から木叢ごしにこう呼びかける弟の声がした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩の内容するものは、常に主観の呼びかける絶叫であり、祈祷であり、そして要するに純一の感情――気分、情調、パッショーンである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、向うは、もう気がついたらしく、西洋人の訛ったアクセントで呼びかけるのが聞えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イチロ、イチロ」「イチロ」　息子の名を呼びかけるそれらは女の声もあるし、男の声もあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何処で覚えたか下等な人を呼びかけるアメリカ語を使い、口笛を嚠喨と吹いた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と母屋に呼びかける）野中の妻、節子、登場。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女房は夕露の濡れた目許の笑顔優しく、「ああ、そりゃもう今日明日という内に、直きに娘になるけれど、あの、三ちゃん、」　と調子をかえて、心ありげに呼びかける。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、その声は山の怪異の呼びかける声で、万一それに応じでもすると、一晩中応答しなくてはならぬが、そんなに長く声の続くものでない。",
              "citation": {
                "source": "死んでいた狒狒",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠の家から小学や中学に通うのだが級友たちがいつかわたしの身柄を知って「やい、小狸」と呼びかけるのをどんなに侮蔑と感じたことか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きみい（君）　と兄は妹へ話す話頭の前にかならず、こう呼びかける。",
              "citation": {
                "source": "兄妹",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六歩すると藤さんがまた呼びかける。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早く云えば一種の骨董芸術で、現代人に呼びかけるところは一つもない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若さで、はち切れそうな青年紳士が、先へ打たせている同じ馬上の夫人に呼びかける。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、かた一方のがけの上からむこうのがけにむかって、「おーイ」とひと声よびかけると、それがこだまになってこちらへ帰ってくる。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
