[
  {
    "uuid": "6ff7f11d-c2a2-5d0d-8fec-e1377865efd8",
    "entry": "予想以上",
    "reading": {
      "primary": "よそういじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "名詞-の形容詞"
