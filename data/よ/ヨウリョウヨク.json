[
  {
    "uuid": "869612d5-5ce5-55cd-9c7b-74bb7da91092",
    "entry": "要領よく",
    "reading": {
      "primary": "ようりょうよく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "副詞"
      ],
