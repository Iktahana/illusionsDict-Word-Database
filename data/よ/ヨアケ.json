        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "藤村氏に於ける文學の本質は、その「若菜集」の出發から、大作「夜明け前」の今日に至る迄、一貫して本質上の「詩」であり、詩精神なのである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けの三時までさまざまの議論をいたしましたが、雌雄決せぬままに蒲團にぶつたふれて寢てしまひました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明け方の風がうすら寒く、爽かに吹いて来た。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は猶母牛の注意を男共に示して置て寝てしまった夜明けて後男共は今暁の死犢を食料にせんことを請求してきた。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日島崎藤村氏を訪問したら、大作「夜明け前」を執筆中の氏の生活法が、殆んど室生君の日課とよく似て居るらしいので、僕も成程と感ずる所があつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにそれは夜明けんとする時の最初の鶏鳴であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇が迫って来るのは早く、夜明けはおそかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉清輝は、警戒兵も居眠りを始める夜明け前の一と時を見計って郭進才と橇を引きだした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の夜明け方に時鳥を聞いた。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、やはり夜明けごろに窓外の池の汀で板片を叩くような音がする。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩手山巓外輪山の夜明け方、　　　　息吹きも白み競ひ立ち、三十三の石神に、　　　　　米を注ぎて奔り行く。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けにはまだ途方もないしきっと雲が薄くなって月の光が透って来るのだ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方ない夜明け迄に一ぺん宿へ引っ返し日が出てから改めて出掛けよう。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の空が黄金色になり、もう夜明けに間もありません。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明け前の寂寞を破るあの不思議な音と同じものだとはどうしても思われない。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けの光が森の上に拡がって、露の草原に虫が鳴いている。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中部屋の縁のない赤ちゃけた畳、びんつけ油のにおい、竹の行李の底から恥かしき三徳出して、一枚、二枚とくしゃくしゃの紙幣、わが目前にならべられて与えられたような気がして、夜明けと共に、電話した。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けのまちには、人ひとり通らなかった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと夜明けに近いころ、雪婆んごはも一度、南から北へまっすぐに馳せながら云いました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けまでに向うへ行かなくちゃ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文は短けれど読みおわりて繰り返す時わが手振るい涙たばしり落ちぬ、今｜貴嬢にこの文を写して送らん要あらず、ただ二郎は今朝夜明けぬ先に品川なる船に乗り込みて直ちに出帆せりといわば足りなん。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず夜明けのセーヌの川岸が現われる。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下男の吉蔵は、まだ夜明け前の広い台所の真中へ三四枚の藁筵をひいて、近所の四五人の倔強の若者等と大釜の湯を取り分けて※た真赤な番茶を、前の夜から焚いて用意して置いた麦飯を、大きな茶碗に山盛りにした上からかけては、黄色な沢庵などを忙しく箸で挟み乍ら、何杯も何杯も代えるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと夜明けに近いころ、雪婆んごはも一度、南から北へまつすぐに馳せながら云ひました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けまでに向ふへ行かなくちや。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "令史少からず顛動して、夜明けて道士の許に到り嗟歎して云ふ、寔に魅のなす業なり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山の峰の上に横たわった紫色の雲の隙間から、さっと金色の光が流れて、加茂川の水の上にキラキラと輝き、先斗町に夜明けが来るまで、鶴雄は一睡もせずに「罪と罰」を読んでいた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けの蛙の唄はよろしい。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまたその声は、やわらかな笛の音のように、或るいは夜明け前の鴬の唄声のように、やさしく澄んでいるのだった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭二人は或る日林檎の畑の中で明日の夜明けに手をとりあって村から逃げ出す約束までした。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
