    "definitions": [
      {
        "index": 1,
        "gloss": "hitting the side of the head (kendo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
