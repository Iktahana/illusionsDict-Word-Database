    "definitions": [
      {
        "index": 1,
        "gloss": "to lean against",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（両手にて取りいたる画家の手を放し、椅子の背に寄りかかる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "つと立ち上ってビクトロラの傍に行って、またスキーパの曲に、針をあてがうと、ビクトロラに寄りかかるような姿勢をしながら、嘲笑を浮べて新子に話しかけた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど大雪だ」「とても、二三日はたたれませんよ、ゆっくり御逗留なさい」　焦生と老人が向き合って※に寄りかかると、老婆と女の子が御馳走をこしらえて持ってきた。",
              "citation": {
                "source": "虎媛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげ上がった頭には、小さい天鵞絨の喫煙帽が、そのつるつるの片方へ寄りかかるように乗っかっている。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が近づくあいだに、ご婦人は身体を支えようと木の幹に寄りかかる。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "髮に微笑を含んで清い小川の岸に寄りかかる少女子、金雀花、金髮の金雀花、色白の金雀花、清淨な金雀花。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "愁に沈む女よ、落葉松よ、石垣の崩に寄りかかる抛物線。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもう地上の何物にも寄りかかることが出來なくなつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "べつたり土の上に腰を下し、手も足も投げ出し、藁のなかに首を突つ込むやうにして寄りかかる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鋤に寄りかかる癖があるからで、それでまた左の肩を別段にそびやかして歩み、体格が総じて歪んで見える。",
              "citation": {
                "source": "糸くず",
                "author": "LA FICELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して一人で寝に行かうとはしないが、平気でアクビをし、母親の肩へ寄りかかる。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（マイケル卓の上に袋をおき向う側に行って煙突の側面に寄りかかる。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、感情がいつも緊張しており、何かしら新しいものを見っけては喜んで寄りかかるが、さて、ゆっくりした気分になりはじめると、それから離れ去らずにいられなくなり、新しいものにふたたび注意を奪われ、それをまた見棄てて別の新しいものを求めるのだった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちか　　（愛作のそばへ近づき、肩へ寄りかかるやうにしてその白髪を時々ぬく）だつてお前さん、あとでぐづぐづいはれるのはいやぢやないの。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "またも精根次第に疲労れ、岩壁に寄りかかると尾張宗春、朦朧状態に落ち入ってしまった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それも、軽くやさしく寄りかかるのだから、男のほうでは、すこしも重荷にならないというタイプである。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れた旅人が路傍の大樹のもとに暫しの休らいを求めるように、柱というものは寄りかかるためにあるものだ。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩下には深い海があって、あの世へ行けますが……」　ルースの声が聞き取れないほど小さくなり、椅子に寄りかかる姿は、肉体的にも精神的にも疲労困憊している。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の手を見て、船尾に寄りかかる背中の感触を意識すれば、これが夢ではなく本当に起きた事だと分かった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして船尾の板に寄りかかると、自分が死んでいないとはっきり分かった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいの高い二本のでんしんばしらが、互によりかかるようにして一本の腕木でつらねられてありました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた――どうでしょう、天狗様の方が股が裂けそうな大胡坐で、ずしんと、その松の幹へよりかかると、大袈裟な胡坐ッたら。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が「主観的」と呼んでいるのは、もとよりかかる皮相の見解でなく、作者の物を見る態度の上で認識が感情の中に融化しており、気分的な情趣となっている態度を言うのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "常念寺の土塀の西南のすみに、小さな家が土塀によりかかるように、（事実、すこしかたむいている）建っている。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　一度横目を流したが、その時は、投げた単衣の後褄を、かなぐり取った花野の帯の輪で守護して、その秋草の、幻に夕映ゆる、蹴出しの色の片膝を立て、それによりかかるように脛をあらわに、おくれ毛を撫でつけるのに、指のさきをなめるのを、ふと見まじいものを見たように、目を外らした。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩故障を容れしに、氏子総代、神主と一つ穴で※言揚々として、むかしよりかかる英断の神官を見ず、老樹を伐り倒さば跡地を桑畑とする利益おびただしとて、その時伐採り見て哭きし村民を嘲ること限りなし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「王の狂人となりて、スタルンベルヒの湖に近き、ベルヒといふ城に遷され玉ひしことは、きのふ新聞にて読みしが、さてはその頃よりかかる事ありしか。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりかかる作品の常としてその光景、その対話等に著者独特の修飾あるは当然ながら、この作がある事実の詩的表現であることは疑うべくもない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も臥るか柱によりかかるかしていて、私を見ると息を切らせ乍ら這い寄って来るんです。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "月狂は人間はつまり壁によりかかると云ふことをよく言った。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
