        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜っぴて、幸子は帰らずにしまった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かしら、こりゃ夜っぴて探してもむだらしい、もう止しましょう。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　村の人たちは夜っぴてねなかったうえに、山の中を歩きまわったので、たいへんくたびれて村に帰ってきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがノウトルダムの、いや、世界に名だたる巴里の、妖怪像なんだが、より驚くべきことは、夜になって魔性の巴里が「べつの生」を持ち出すが早いか、これらの奇像群がのこのこ塔を下りて来て夜っぴて町じゅうをうろつく一事である。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと数学には自信を持っている古山は、水漏れの報告を受けて参考にした論文を家に持ち帰り、夜っぴてアルゴリズムを当たりなおしてみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ、夜っぴて、爺さんと二人っきりでさ、火もないとこに無言の行だったからなあ」　ゴム靴の釦をはめている中尾の背へ、龍子は気弱く、「恩に着るわよ」と声をかけた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが僕の方は、君、」と、ノズドゥリョフが言うには、「夜っぴて、話をするのも胸糞の悪い、いやな夢を見たんだよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜っぴてよ、蝋燭でよ、銭勘定したり、横浜までゆくのに、旅費がなくって、宿場の牛太郎までしやがったことわすれてやがる。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、――昨夜夜っぴて煙草ばかり呑んでいたもんだから、すっかり舌が荒れてしまった。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無茶なことをなさるじゃあござんせんか――昨夜は、夜っぴてでござんしょう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山越えは更に迷うばかりでござろう、今もその相談を致しておりましたが、そこで、こういう風に――」　夜っぴて燃しつづけていた焚火の上に、彼は更に一握りの枯れ枝を投げ入れた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜っぴて松籟が耳についた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠航専門の甲板部の為吉とは話も合わないので、夜っぴて唸っていても、為吉は別に気に止めなかったのである。",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきにも大望があるというからには、しつッこく、二度、三度、と又の逢瀬はねだれない――せめて、今夜一晩は、明けるまで、夜っぴて、思いのたけをいってやらなくっては――　雪之丞の、あの凛として、白梅のような美しい顔が、目にうかんで、彼女の魂を、鋭く、しかし、甘ったるく、噛み破ろうとするのであった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつァ無理だ、訊く方が無理だ、寝ずの番だって人間だ、夜っぴて起きていた日にゃア、明け方には眠くなるからねえ、そんな細かい変梃なことに、気の付くはずはありゃしない。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジョンのすぐ横で、船荷の宰領（註八一）みてえに寝ましたよ、――夜っぴて、枕を並べてね。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が下ったとかで、夜っぴて女房に、腹をさすらせたり、足をもませたりしていたそうです」「重宝な現場不在証明ができたものだな」と課長は、薄笑いをした。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人並よりすこし長い彼の手が、女給の変装の下にすぐ細いサスペンダアをしている彼女の腰をかかえて、夜っぴて「黒い底」を廻った。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュボーフィ・オニーシモヴナは、その手紙をすぐさまペチカの掻取り口で燃やして、余人はもとより当の縞服の婆さんにさえ口外せずに、夜っぴて神に祈りをささげた。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山の町で自動車ポンプのサイレンの音を聞きおぼえてきて、月のいい晩に得意になって夜っぴてうウうウとやった。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十郎は、この場面を想像して、ひょっとすると噴き出すかも知れないぞと夜っぴて閉口していた。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）ドゥニャーシャ　犬はみんな、夜っぴて寝ませんでしたわ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時には彼女は自分の身を、鶏小屋に雄鶏がいないとやはり夜っぴて眠らずに心配しつづける雌鶏にひきくらべてみるのだった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "別嬪がいて、夜っぴて踊れる好い処へ案内するから」と云うのだ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜っぴて看病して、翌朝は影のように生色を失って、社へかけつけると、せつ子に会って、報告した。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何条もって耐るべき大切の商売物、肉は崩れ、骨は飛び、一瞬にしてめちゃめちゃになってしまうのだったが、こうでもしなけりゃ俺夜っぴて寝られねえものと平気で空嘯いていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しさに恐らく血が騒いで、師匠の家へかえっても夜がら夜っぴて寝られないだろうとおもった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで妹は、夜っぴてまた寝られなかった。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしクリスマスの晩に、大ぜいの友人を家へ招いたり、あるいはキャバレーなどで酒を飲んで夜っぴて騒ぐのは、日本の習慣であって、アメリカのクリスマスは、いわば家庭の行事である。",
              "citation": {
                "source": "ウィネッカの冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの旅人は、よっぴて山道をあるいてゆくだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
