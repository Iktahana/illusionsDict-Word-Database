[
  {
    "uuid": "25a943a3-b307-5ec9-808f-962d34d6c77b",
    "entry": "溶液",
    "reading": {
      "primary": "ようえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
