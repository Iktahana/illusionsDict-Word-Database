          "literary": [
            {
              "text": "それは村の予算外のものであるから、仲間同志で負担する取り極めであった如くである。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の予算外の大失費のため、今度は会社の方が沈没した。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、母にいいつけられない予算外のお菜まで買ったりした。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おみよさんがいつの間に帰って来たんだろう」　それが第一に判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "この稲刈りにはおとよさんがいなかったらかえってほかの者らには統一ができたのだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いてもらおうと思う方がよっぽど無理だ」　おはまは喉のつまったような声をして突然、「おとよさんがいなくなったらわたしゃどうしよう」「おとよさんはいなくなりゃしないよ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやだいやだ、おとよさんがいくらえい女でも、ぬしある女、人の妻、いやだいやだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の髪の毛が顔へふれた時むらむらとおとよさんがいじらしくなった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
