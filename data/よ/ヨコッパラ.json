        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "団扇のような胴船が、浚渫船の横っ腹へ、眠りこけていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次急に横っ腹を抱えて「痛え痛え」と苦しみ出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「鹿の黄いろな横っ腹なんぞに、二三発お見舞もうしたら、ずいぶん痛快だろうねえ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから横っ腹が痛くてたまらないんだ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊は青空の水々しい横っ腹へ、いっぱつ鉄砲を射ち込んでやりたい情欲に似た欲望を感じたのだ。",
              "citation": {
                "source": "兵隊の死",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でないと、このナイフを横っ腹へつきさすよ」　あくる朝、ゲルダは、森のハトの言ったことを、のこらず山賊の娘に話しました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう言って、ヤギの背中にまたがると、その横っ腹をかかとでけとばして、大通りをいっさんにかけだしました。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人になってもこの心理作用はなかなか消え失せないので、電車の中や汽車の中、その他到る処にこの気分の発露を見受けられますようで……尤も理由なしに咬み合いは始めませんが、一寸足でも踏むか横っ腹でも突くと、何だこの野郎、失敬な奴だという気持になります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで酒を飲んだ帰りらしい、ほろ酔い機嫌で親父橋まで来かかると、橋のたもとの柳のかげから一人の男が飛び出して、不意に信次郎の横っ腹を突いたので……」「相手は誰だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて第二発目のストキの拳固がボースンの横っ腹へ飛んで来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はこの缶の横っ腹にあいている二つの穴に目をつけた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その魚が飛んで来て、芸妓の横っ腹を突いたもんだから、芸妓もきっと死に物狂いになって、そこにある櫂を取って無茶苦茶に相手を撲ったに相違ない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "クックックッと早引の忠三、横っ腹を抱えたものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その使用目的は、雨天の折など、向うから自動車が狭い路にも係らず泥をハネかしながらやってくるごとき場合に、「気をつけろ」と注意を与えても、先方が聞き入れざるときは、やむなくこいつを自動車の横っ腹に抛げつけるなり。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも慾が手伝って、無分別に請け合って、一本の蝋燭をあずかって帰って、念のために蝋燭の横っ腹へ小さい穴をあけて見ると、なるほど金がはいっているのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「集団農場へ気をひくためにゃ、これんばっかりも役にゃ立たねえネ」　自分の横っ腹のところを指さして、「ここんところを、逆にひっぱられるみてえだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば年寄りの栗毛などは、馭者のアントンのむちを横っ腹へ食らいはしまいかとたえずびくびくしながら、乾草の山をかき分けているのですが、これは馬のことですから、もともとすわるなんて芸当はできないのです。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "プセットは足をのばして爪で絨氈を引っかき、尻尾で自分の横っ腹を叩いていたが、突然、夢中になって半開きの戸口から驀直に庭の方へ駆けだした。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の上では、プセットはすっかり落ちついて、相手の牡猫の横っ腹へ肩をなすりつけていたが、そのとき如何にも馬鹿にしたような風で、ちらと老嬢の方を見たっきり、体をのばし、首をふりながら、平気で巫山戯つづけた。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、プセットが通り路にまごまごしていると、つかまえて、頭といわず、肩といわず、殊に横っ腹を厭というほどひっぱたいた。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが或る朝、常よりも激しく責め折檻をして、横っ腹を手ひどくひっぱたくと、プセットが矢庭に跳び起きて、脚をあげ、毛を逆立てたので、「おや、わたしを引掻く気だね。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "船艙では、破戸漢どもが首をのばしてガルールの帰りを待っていたが、間もなく大濤がどっと船の横っ腹へ打衝かって船体がはげしく揺れだすと、帆檣がギイギイ鳴る。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ強情張るか……」　と云ううちに、青竹が吾輩の横っ腹へピシリと巻付いた。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生懸命で、上からブラ下げた綱に縋りながら、船の横っ腹に取付いて、穴の周囲にポンポンポンと釘を打ち並べると、八番ぐらいの銅線を縦横十文字に引っかけまわした。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い高い波の横っ腹に引き残して来る推進器の泡をジイッと振り返っていると、七千噸の船体が千噸ぐらいにしか感じられなくなって来る。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思ううちに、やがて谷底へ落ち付いた一｜刹那、次の波の横っ腹に艦首を突込んでドンイイインと七噸から十噸ぐらいの波に艦首の甲板をタタキ付けられる。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老茶色ルバーシカの男は、真面目くさった顔つきで、ときどき横っ腹を着ているものごと痒きながら、札をひろったり、捨てたりしている。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘だと思ったら、横っ腹を見ろ。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、間抜けな弁公の奴、鈍刀で、横っ腹を突かれたのがもとで、身動きも出来ねえことになる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君たちだったら、美事に、横っ腹をぶすりとやられるところだ。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
