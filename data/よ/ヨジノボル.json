[
  {
    "uuid": "94afdd69-da60-5533-9596-377989e3bc19",
    "entry": "よじ登る",
    "reading": {
      "primary": "よじのぼる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
