[
  {
    "uuid": "a9b2b958-60e3-5489-9bf8-250616ccf4fa",
    "entry": "余韻",
    "reading": {
      "primary": "よいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
