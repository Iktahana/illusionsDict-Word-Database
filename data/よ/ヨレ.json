        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまりオレのギターは、ハチャメチャのヨレヨレのドシャドシャだったのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "札が、もうヨレ／＼になり、文字も微かにすり切れてしまふ頃の歌留多会が最も若い選手達の胸を踊らせたらしい。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "作業服はヨレヨレながら、その声は気味の悪いほどしっかりしていた。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時ハ何処ノ国籍ニ属スルヤ全ク不明ナリシガ只今マデ数日間観察セルトコロニヨレバ○国人ナルモノノ如シ。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ノ一団ハ何ヲナセルヤ」相手「予ノ今日マデノ観察ニヨレバ、明カニ軍事的施設ヲ作リツツアルモノノ如シ。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮士荻野六郎は達磨のように赤黒く、毛虫｜眉で、いがくり頭で、デップリと肥って、見てくれの強そうな、胸をふくらましてヨレヨレの袴を穿いていた。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うは一つに、彼地にて娶りし仏蘭西ブザンソンの人、テレーズ・シニヨレに餞ける引手箱なりと云う。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこからフウッと吹き出した鬼気とともに、テレーズ・シニヨレの横顔が現われたのであった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、精緻な輪廓に包まれ、捲毛の金髪を垂れているのが、トレヴィーユ荘の佳人テレーズ・シニヨレの精確な複製だったのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにいっそう薄気味悪いことには、擬うかたなくそれが、黒死館で邪霊と云われるテレーズ・シニヨレだったのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢エテ和尚ニ告ゲ、乞ウ、亡僧ノ事例ニヨレト。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は美術商を営んで居るピニヨレ夫人の一人娘エジツが植物園や公園へ僕等を案内して呉れた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論ピニヨレ夫人も和田垣博士の旧識であるが、エジツは曾て博士の滞在中英語を教へて貰つた弟子である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんのピニヨレは何時も白い紗で髪から首筋を包んで居てラフワエルの描いた聖母像を想はしめる優しい面立の女だが、娘はお母さん程美しくは無いけれど気立は更に一層素直であるらしい。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途に芝居の前の其家へ寄ると、ピニヨレ夫人は僕等にカンキナ酒を注いで出し乍ら「今夜お差支が無いなら山荘の方へ馬車で御案内したい」と云ふ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐を旅館で済ました後ピニヨレ夫人の門から馬車に乗つたのは夜の八時半であつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもヨレヨレのブルースに、大きなボヘミアンネクタイをブラつかせてゐる。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体には、初めは高い値段のものだったろうが、いまはヨレヨレになってむさくるしいというより外はない天鵞絨の洋服をつけ、何十年か前に流行ったような細い黒ネクタイを締めている。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らせる間もなくてどうも……」　といったけれど、大隅の洋服はヨレヨレになりところどころ鍵裂きや泥に汚れて、一と目でそれと、連日の悪戦苦闘を物語っていた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先は亡くなつた社会党のジヤン・ジヨレスの死骸もこゝに祭られました。",
              "citation": {
                "source": "農民自治の理論と実際",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨレヨレの国民服をきて、長さ一尺足らず、幅四、五寸の手垢でよごれたズックの小さなボストンバッグを手にもって、疲れきって現れたのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなヨレ／＼のワイシャツじゃア、新円階級に見えるものか。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前日――つまり、昭和二十二年九月十七日のことであるが、ヨレヨレの白衣をまとうた一人の傷痍軍人が倉田家の玄関に立っていた。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
