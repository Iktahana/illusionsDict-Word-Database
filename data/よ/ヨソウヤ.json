        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "』『さてはてめえ、馬の予想屋だな？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "挙句の果てに賭場のあにいや予想屋にケチをつけてブン殴られ、鼻血を流し、前歯を折つてしまふのである。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "予想屋と同じぐらゐ無造作である。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三日の間に、私は競輪の選手と予想屋を招待して、その話もきいた。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "予想屋はそれを見て予想を立てるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の見た東海道某市の競輪は、穴のでる競輪場だと予想屋がしきりに絶叫していたが、たぶん、そうだろうと私も思った。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の見たレースでは、あらゆる競輪新聞や予想屋が、全然問題にしていなかった選手が逃げきって勝った。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "予想屋でもやろうかと思ってはいるが、脚がこれでね」　フトンをのけて見せた。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくは罪なことのできない性分だから、予想屋じゃ客がつかないだろうよ。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "予想屋、浮浪者、ニセ医者、役者、ありとあらゆることをやつてきた男だ。",
              "citation": {
                "source": "青君の追跡",
                "author": "THE PURSUIT OF MR. BLUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして、大物の予想屋は意気消沈。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、一般大衆の間では、はったり屋や予想屋が彼らの途方もない見せかけによって、中庸の範囲内で抑えるよりも、より容易に信用を受けると言えよう。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと予想屋だ、忌々しい連中だ、いつも競馬ファンの嫌われ者め。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん少佐が雇った予想屋の一人でしょう、落ちぶれた連中を多少うさん臭い仕事に使うのでしょう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "信頼できる助手二人に打ち明けて、三人以外誰も知らないだろうと思っていたところ、厩舎に漏れてしまい、妙な経路でこの計画を聞きつけたのがチャフィ、入りびたりの酒場から我が身を引き離しさえすれば、厩舎情報に一番詳しい予想屋だった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらでは、予想屋さんの声、そして、第一レース売出しのベル。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ゲエムだけやろうという事になったが、黒ずんだ羅紗の上をのろのろ歩く球が、なんだか生き物みたいで薄気味が悪くなって来て、勝負のつかぬうちに、よそうや、よそう、と言って、外に出てしまった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はもう訊問はよそうや。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガソリン自動車とか木炭自動車とか申しまして……」「えへん、えへん、ああ、もうそんな話はよそうや」　また博物館が話の中にあらわれた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、目の玉がとびだすほど高いけれどね」　品物が高いそうなといわれても、それじゃあ銀座へ行くのはよそうやという者はなく、どんな品物がならんでいて、どんな高い値段札がついてるかを見たいというので、若い人はもちろん、いい年をした老人などもわっしょいわっしょいと銀座へおしだした。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんな話はよそうや。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の性質でやむなく不規則雑然としておるけれども、本来は意外にキチョウメン、然し、どうも、まア、よそうや。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新ちゃん、あぶないからよそうや。",
              "citation": {
                "source": "はととりんご",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがね光ちゃんよ、おどろくなよそうやって火を消しちゃってまだブスブスとくすぶっている背戸のところでみんながやっとホッとして息を入れながらお互いに顔を見合わせてみたらバケツ・リレーの先頭に立っていたのが、お宅の小父さん光ちゃん、君のお父さんだったんだ！",
              "citation": {
                "source": "詩劇　水仙と木魚",
                "author": "――一少女の歌える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが言葉をかけるのはよそうや。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「車を拾って、大急ぎで行こう」「もう、よそうや」「なに言ってるんだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
