    "definitions": [
      {
        "index": 1,
        "gloss": "night watch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋の夜に若侍どもが夜詰めをしていた。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平七は庄五郎と同職で、しかも従弟同士であるので、無論に昼夜詰め切りで働いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、そうか――」二　夜詰めの近侍たちが、お次の間にしりぞいてから、もうよほどになる。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり右の事件に関連して、土地の顔役が昼夜詰めきりの有様でしたから、事の一切が、わかり過ぎるほどよくわかりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "本陣、おん大将の寝所幕のあたりにも、夜詰めの侍が警固する槍の穂が、ときおり、ピカリ、ピカリとうごいてまわる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、やがて夜が深まると、辻々四十八ヵ所にいつもは終夜詰めている篝屋（後世の辻番所）の武士が、こつねんと、みなどこかへ姿を消し去った。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
