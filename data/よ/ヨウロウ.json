[
  {
    "uuid": "b54bed2d-489a-5a4c-99af-111c8de8c177",
    "entry": "養老",
    "reading": {
      "primary": "ようろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
