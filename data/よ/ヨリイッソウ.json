    "definitions": [
      {
        "index": 1,
        "gloss": "still more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまりより一層造型的だと云へるであらう。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましては「この山は防風上はかの山より一層重大な役目をなす」なぞといふのはいよいよ以て生活である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいながら経巻や仏像の影を見ることには前より一層厭嫌の感情を増した。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで魚屋へ寄るのは、落語の権助が川狩の土産に、過って蒲鉾と目刺を買ったより一層の愚じゃ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鳥より一層もの凄い、暗闇の翼に蔽はれて、いま燈の影に息を潛める。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半月ほどたつて、また五合庵にやつて来た寺男は、前より一層びつくりした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると良寛さんは、前より一層ひどくうしろへ、そつくりかへるのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "床柱にも名があろう……壁に掛けた籠に豌豆のふっくりと咲いた真白な花、蔓を短かく投込みに活けたのが、窓明りに明く灯を点したように見えて、桃の花より一層ほんのりと部屋も暖い。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この半白の頭をした男の人は、さっきより一層｜親くなったように木之助には感じられた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの場合、作家は洋服屋より一層困難である。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は横を向いてせせら笑ったが、今度は前より一層｜酷く小田島を睨み上げた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩が散文でない限りより一層のリズムの純化を私は君に欲する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも此度は前より一層驚きました。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかういふ感じが順序を追つて起つてゐる背後に、物を盗まうといふ意志が、此等の閾の下に潜んでゐる感じより一層｜幽に潜んでゐたのである。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、変転しやすい彼の気持は次の瞬間にはたちまち苦い幻滅の底に落ち込み、ふだんより一層惨めなあじきなさの中に自らを見出すのが常である。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、以前より一層心優しく夫をもてなすようになった。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は自分と主君との名分を知ると共に、主君と将軍との名分を知り、それと同時に将軍と朝廷との間に、より一層大なる名分の存在することに気がついたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の名を聞いて奧から出て來た背の高い友の白髮は、この前逢つた時より一層ひどいものに眼についた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の更けたゝめか、或は麓近く移つて來たか、宵の口より一層澄んで聞える。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが虎膏は皮より一層むつかしい尋ね物だ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして厚い上唇は、恐悦至極といった様子で、それより一層厚い下唇の上にのっかっている。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船乗りたちがある高いものすごそうな建物の入口のところでつまずいた時、突然、興奮しているレッグズののどから前より一層鋭いわめき声が出たのだが、それに答えるように家の内から騒々しい、どっと笑うような、悪魔のような叫び声が速く続いて起った。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしもう一方で、ノートブック型からのより一層の小型化を考える者の脳裏には「はたして私の作ろうとしているものはパーソナルコンピューターなのだろうか」との問いが浮かんでくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の子供の境界は、前より一層寂しくなったのである。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「待てよ」　門野は今までより一層烈しく、掌と掌とをこすり合せながら、首を傾げて考へてゐるやうな恰好をしてゐたが、「うん、さうさな。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫らはボートやサンパンを吹き飛ばされないように、それを、より一層ほとんど、吹き出したいくらいに、頑丈に、これでは沈没した時に決して間に合わないと、証拠立てられるほど、それほど頑丈に、くどくどとデッキや煙突にまで、綱を引っぱった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、彼らはその住む地域の関係上、より一層はなはだしい程度に、その惨害を受けた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかならば、それは、セーラーの方で計画実行しなければならなかったほど、セーラーによっては、緊密な要求だが、火夫の方では、ある者にとっては、そうでないかもしれないし、より一層われわれがおそれるのは、スパイだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴覚も平生よりいっそう鈍感になる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年間、ほかの人から見たならば、私の微笑は、私の姿態は、この建築物よりいっそう汚れて見えるだろう。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
