          "literary": [
            {
              "text": "遠い所を、どうも――小母　（居間で母親と挨拶を交してゐる）これは、これはようおこしやす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母　（盆に茶椀を載せて持つて来て恵子に）ようおこしやす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤井はん、ようおこしやす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（キチンと坐つて赤井に対して辞儀をして）ようおこしやす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京は遠うて、こけてもようおこしてあげられんで」と云った男。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
