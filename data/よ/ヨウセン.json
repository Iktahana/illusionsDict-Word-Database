[
  {
    "uuid": "b2e4c13e-895f-5ad0-b165-f1392a70c64e",
    "entry": "用船",
    "reading": {
      "primary": "ようせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chartered ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等は、門司から御用船に乗る際、同様にビラを拾っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その工藤が、御用船の中で片づけられていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、安らかに婦人専用船室のベツドで眠れた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお数せきの御用船で食糧や、何千人を入れ得るテント病院を寄そうして来ました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪水を積み込む御用船に乗り込んで、黒船に近づこうとしたけれども、それも毎船｜与力が乗り込んで行くために、便乗する機会はなかった。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの従軍記者は宇品から御用船に乗り込んで、朝鮮の釜山または仁川に送られたのですが、前にもいう通り、何分にも初めての事で、従軍記者に対する規律というものが無いので、その扮装も思い思いでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この掃海船サンキス号こそ、ワーナー博士調査団の用船だった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日佐渡国丸といふ御用船に乗り込む。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父がまだ宇品で御用船の出帆を待っている間に、母に男の子が生れた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球方用船の新造、火薬の貯蓄、台場の築造、道路、河川の修繕――）　斉彬は、年が若い。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "遡江船　御用船××丸の甲板に立つて、はじめて揚子江といふものゝ存在が如何に象徴的であるかを知つた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の漁船や、番船や、また幕府の御用船なども、その大きな黒船の前では、巨人の周囲を取巻く小児のようにしか見えません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　これより先、海鹿島から伊勢路の浦へ、上陸した御用船の一行がありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御領主の御用船とあってみれば、文句はないのですが、駒井がそうして無断に仙台家の船印を濫用してよいのか、一時の策略で、それを利用してみても、あとの祟りというものはないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月上旬、青ヶ島に着き、そこから八丈島に送られ、流人御免の御用船に乗せられて、九月上旬、命｜恙く江戸の土を踏んだ。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "船極印を調べると、まぎれもない御用船。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これが、文久二年四月十七日、相模灘に起った遠島御用船、三崎丸の事件。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日の朝、鰹船が三崎の番所へ事件の顛末をうったえでると、番所からは取るものも取りあえず用船を出して取調べた上、江戸まで三崎丸を曳船してきて当時のままのありさまで船蔵におさめてある。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に一度の大島通ひの御用船が、三崎の沖で拾ひ上げて、まだ呼吸があるやうだから可哀想に捨てもなるまいと、大島へ持つて行つて、漁師に世話を頼んで江戸へ歸つたさうで御座います」　千之助の話は奇つ怪でしたが、決して拵へ事とは思はれません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地獄から來た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用船に救はれて、大島の漁師の介抱を受け、三日目に正氣付きましたが、恐ろしい負傷で身動きもならず、その手當がざつと三月。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地獄から來た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師や村人に禮を言つて、再び御用船の厄介になり、江戸へ歸つたのは半歳前。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地獄から來た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に一度の大島通いの御用船が、三崎の沖で拾い上げて、まだ呼吸があるようだから可哀想に捨てもなるまいと、大島へ持って行って、漁師に世話を頼んで江戸へ帰ったそうでございます」　千之助の話は奇っ怪でしたが、決して拵え事とは思われません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用船に救われて、大島の漁師の介抱を受け、三日目に正気付きましたが、恐ろしい負傷で身動きもならず、その手当がざっと三月。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師や村人に礼を言って、再び御用船の厄介になり、江戸へ帰ったのは半歳前。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍用船は単独で出発した。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を持って来たかというと、ヨウカンとか黒糖などの甘味品だ」　南下中の列車や軍用船で、いろいろ南方の話題が出る。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れつきですかな」　軍用船から汽車で大同に着く間、加納は無意識裡に、というより何か心がかりで、ちらちらと城介の動きに注意していた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、さらにさらに大きなかげで包んでしまうのは、いつのまにか軍用船となって、どこの海を走っているかさえ分からぬ大吉たちの父親のことである。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大学はかつておれを非難した、おれが藩の御用船で米を回漕させたといって非難したが、その一条の申しひらきを聞きたいな」　――このほかに、依怙の沙汰、違法の行跡を列挙し、吉岡どののために、領内の士民たちが困窮していること。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の芝居で、あの事がなかったら、幾ら私が無理云うたかて、丸官はんにこの祝言を承知さす事はようせんもの。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
