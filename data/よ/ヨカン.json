[
  {
    "uuid": "54971861-4cf2-5289-a875-2b0daf8069e6",
    "entry": "予感",
    "reading": {
      "primary": "よかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
