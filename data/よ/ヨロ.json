    "definitions": [
      {
        "index": 1,
        "gloss": "best regards",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春風ですよろこびやがれ凡俗！",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔甘藍の球は弾けて〕宮沢賢治甘藍の球は弾けて青ぞらに白雲の房呑屋より二人の馬丁よろめきてあらはれ出づる",
              "citation": {
                "source": "〔甘藍の球は弾けて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アポリネールは、前世紀的な最後の人と呼ばれてゐる位だから、此の場合格構な例ではないと思はれるかも知れないが、然らば寧ろ突飛な迄に斬新なピカビヤでもツァラでもブルトンでもアラゴンでもよろしい。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげよ我等の日章旗人みな愁眉をひらくの時わが戰勝を決定してよろしく萬歳を祝ふべし。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしく萬歳を叫ぶべし。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしいの時、大久保に参ります。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむ、私よろこばないです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この認識論は、多くの詩人を、よろこばせるにちがいない。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「われは横綱らしく強いところを見せようとして左の腕を大きくぶるんと振って相手を片手で投げ飛ばそうとしたが、相手は小さすぎて、われの腕はむなしく相手の頭の上を通過し、われはわが力によろめき自ら腰がくだけて敗れたのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯のよろこびだよ」ぐっと甘酒を呑みほしてから、だしぬけに碾茶の茶碗を私の方へのべてよこした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "デコブラ先生にも送ってやってよろこばせてやるか、可哀そうに。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の廊下には、べたべた推薦のビラが張られて、選擧事務所なども、ものものしく、或るものは校門の下に立つて、登校の生徒ひとりひとりに名刺を手交し、よろしくたのみます、といつて低くお辭儀をして、或るものは、中學校の先輩といふ義理のしがらみに依つて、後輩を威嚇し、饗應、金錢、などといふばかな噂さへ立つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、昨年の秋、山田君から手紙が来て、小生は呼吸器をわるくしたので、これから一箇年、故郷に於いて静養して来るつもりだ、ついては大隅氏の縁談は貴君にたのむより他は無い、先方の御住所は左記のとおりであるから、よろしく聯絡せよ、という事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、とりきんで足袋を引っぱったら、私はからだの重心を失い、醜くよろめいた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少し親しげな、ぞんざいな言葉を遣って、「よろしく願います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また媒妁人は、大学で私たちに東洋美術史を教え、大隅君の就職の世話などもして下さった瀬川先生がよろしくはないか、という私の口ごもりながらの提案を、小坂氏一族は、気軽に受けいれてくれた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしゅうございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオニングが、こんな晴れの日にお役に立ったら、うちのひとだって、よろこぶ事でございましょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは、それまではよろしい。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の者が、彼が渡り廊下に掛かるや「頼むぞ」といふ眼差を一斉にさし向けた時に、彼の頭の中では「よろしい！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶には学びたくなるのも人情だから学ぶよろしいが、本の表題だけで、大体その本が分らない位なら、芸術なぞやらぬがまあよい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るだけ多くの人に会はぬ方がよろしい。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそんなことは眼と筆の或る種の技能を巧みに操りさへすればよろしい。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、停車場の驛札等に於て見る國府津の「かふづ」は、よろしく「こうづ」または「こーづ」とすべきである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀者よろしく、卷尾の小解と參照して讀まれたい。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビオルンは斧をふるってその背を鎚にして敵の肩を打つとフンドはよろめいて倒れんとした。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……王がよろめき倒れてかたわらの石によりかかり、神の助けを祈っているところへ敵将が来て首と腹を傷つけた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
