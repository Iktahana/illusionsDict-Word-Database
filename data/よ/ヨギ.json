[
  {
    "uuid": "78e0af17-e28b-5f20-aeb0-e63ed227f7b0",
    "entry": "夜着",
    "reading": {
      "primary": "よぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
