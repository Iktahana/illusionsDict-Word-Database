  {
    "uuid": "a930b95e-e765-5559-b8e2-9ece0c67cd19",
    "entry": "ヨギ",
    "reading": {
      "primary": "ヨギ",
      "alternatives": [
        "ヨーギ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "yogi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヒトヨギリは「一節切り」に相違ないだろうが、これがヒチリキの子音転換とも見られるのがおもしろい。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマキチ　ハ　コマッテ、ボク　ハ　ヤマニ　ソダッテ　オヨギ　ハ　シラナイ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト　モウシマス　ト、サカナタチ　ハ、サモサモ　バカ　ニ　スルヨウニ、ワラッテ　オヨギ　モ　シラナイデ　ウミ　ニ　クルナンテ、キミ　ハ　オオバカサンダ　ト　イッテ　アイテ　ニ　シテ　クレマセンノデ、ヤマキチ　ハ　コンド　ハ　ナミ　ニ　ムカッテ、ボク　ヲ　オヨガセテ　クダサイ　ト　タノミマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヨーギ」と呼ぶ時も、「ヨギッ」と呼ぶ時も、まだそれ程おそれることはないが、例えば今のように、「ヨッキ」と焦げつくように言う時、もしそれに少しでも抗ったら、すぐに黒土を打付けられるのに相違ないのだ。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十八日（木曜）〔受信〕電報　ヨギハ　アスデナク　ケンジ　ペンクラブの会五月十九日（金曜）　一週間ぶりで面会。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十四日（水曜）雨〔受信〕電報　二時頃ヨギルイユーソーアレ　ケンジという電報。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤット　シマ　ヘ　オヨギ　ツキマシタ。",
              "citation": {
                "source": "ユメノリヨカウ",
                "author": "岡本歸一",
                "note": "青空文庫"
              }
            },
            {
              "text": "古歌では松にイロナグサ、オキナグサ、ハツヨグサ、トキワグサ、チエダグサ、チヨギ、ソチヨグサ、スズクレグサ、タムケグサ、メサマシグサ、コトヒキグサ、ユウカゲグサ、ミヤコグサ、クモリグサ、ヒキマグサ、モモクサなど沢山な名がある。",
              "citation": {
