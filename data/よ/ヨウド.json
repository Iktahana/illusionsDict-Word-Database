    "definitions": [
      {
        "index": 1,
        "gloss": "supplies",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "相場が分り出して来ると、用度課長に賄賂を使った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびたびのことなので用度係りへ請求するのに気兼ねして、しまいには家から持ち出した化粧クリームの空瓶を海綿入れにしていた。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊庭はすつかり大日向教にはまりこんだ人間になりきつて、いまは会計事務から、建築用度課を兼ね、金は雨霰の如く這入つて来ると豪語してゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正三年五月よさの・ひろし上海　※田丸から上陸した十余人の旅客は三井物産支店長の厚意で五台の馬車に分乗し、小崎用度課長の案内で見物して廻つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵を動かした損害は、人間をうしない、用度金を浪費したばかりではなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに市場での相場がよいからといって、まことに不適当な土地に、ひょろひょろしたような貧弱な小麦を、しかも凍寒害を蒙って禿頭病にかかったような麦畑を耕作しておりますよりも、少し極端な言い分かは存じませんが、真青に草でも繁らかしておく方がより利用度は高いわけであります。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、もうこれで行くんだから、酒でも飲んで行こう」と、三人は用度から酒を取り寄せて、大きな茶碗で飲み合った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般的題目の通俗的讀物などで、印刷した形の使用度數を器械的に統計したものは、結局無意味な語彙表である。",
              "citation": {
                "source": "ベーシック英語",
                "author": "高田力",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、皇国政府相立ち候うえは金穀の用度一日もなくんばあるべからず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし幕府御辞職なれば莫大の用度を省かれ諸侯室家帰国参勤相やめ、江戸引払いにてこれまた莫大の省減なり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて用度はまず勘定局より出だし外国交易盛行のときに至れば諸港の運上交易の商税をもってこれに当つべし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち二倍の信用度のある測定値と、一倍の信用度のものとを平均する場合は、前の値を二倍してそれに後の値を加え、その合計を三で割ったものを、平均値とする。",
              "citation": {
                "source": "小林秀雄と美",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用度は一つの測定についての誤差の分布状態から決める。",
              "citation": {
                "source": "小林秀雄と美",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに太陽光線の利用度からいうと、普通の農作物とは桁ちがいの効率を上げる。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本のように有り余る水をふんだんに棄てている国では、地熱発電よりも、この水の利用度をほんの少しばかり向上させるほうに進むのが、順路であろう。",
              "citation": {
                "source": "温泉２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九二　若し人蓄積する所なく、受用度あり、（心）空、無相、解脱に遊ぶときは、其人の行跡は尋ぬべきこと難し、猶ほ虚空に於ける鳥の跡の如し。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "志水　本社の用度課へこれを取りによこされたんだ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕様が無いなア、――又軍用金の徴発だろう」　千種十次郎は卓上電話のコードを手繰って――こいつは用度掛から厳重に禁止されていることですが、――卓の上に足を載せたまま、受話器を取上げました。",
              "citation": {
                "source": "音波の殺人",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは利用度の進むに比例して、地名は単に増加したのみならず、その性質も次第に変って来たのである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨幣の通用度はあらかた銀貨銅貨ですんでいたからである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「巡検使の権限で調べるのだ、荷駄の内容がなんであるか云ってもらいましょう」「――甲府城の、用度品です」「どういう品です」「――器具、帳簿――」「器具はどんな物です」　相手は口をつぐみ、行列のほうへ振向いて、なにか合図をした。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶解性の方は膨脹力にくらべてはるかに利用度が広い。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生諸子のそれの引用度を見ていると、いかにも、せっかくな恩恵を充分に生かしていない。",
              "citation": {
                "source": "辞典のすすめ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、社寺の使い、用度の品を搬びこむ商人、何しても雑沓だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "『延喜式』の中などにもかなりの量、数多くの機会に用度として列記せられ、一々はまだ当って見ぬが、目途はすべて式典のためであり、且つ小豆だけを、単独に指定せられることは無かったように思う。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、こうした信用度は、それだけで興ったものではない。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその水面に落ちた光線の反射はちようどピストルの載せてあつた小卓の上に強い焦點を印してゐた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老眼がひどくなつて読書するのにどうも工合が悪い、妙なもので、老眼は老眼として、近眼は近眼として悪くなる、ちようど、彼女に対して、憎悪は憎悪として、感謝は感謝として強くなるやうに。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ふるつくふうふう逢ひたうなつた　　　再録・誰かきさうな雪がちらほら・落葉ふんでは枯木をひらふあたゝかさ・雀おどるや雲かげもなし・ちようど酔のでたところが墓地で梅のさかり　二月十一日旗日も祝日もあつたものぢやない、身心の憂欝やりどころなし、終日臥床、まるで生ける屍だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちようど　とほりかゝつた　物しりを　よびとめて　たづねて　見ると、物しりは、驢馬の　體を　よく　しらべてから　いひました。",
              "citation": {
                "source": "驢馬の　びつこ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
