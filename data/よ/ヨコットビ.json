    "definitions": [
      {
        "index": 1,
        "gloss": "jumping sideways",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蟹について　阿部次郎のエッセイの中に、小さい蟹が自分のうちの台所で、横っ飛びに飛んだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "安来｜千軒、名の出たところ、　コラサッと、この時、笊を前のめりに、ひょろひょろと、横っ飛びに蹌けかかった黒んぼがある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間を粉のような灰色の雪が横っ飛びにケシ飛んでいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫んだ長崎左源太、斬り込みはしない、太刀を引き、パッと横っ飛びに逃げ出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は運転手に切符を渡すと、横っ飛びに電車から降りて、角の焼芋屋の活動ビラの蔭に佇んだ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東小路中納言だなんて、俺あ、横っ飛びに、逃げ出したよ」「あはははは、今夜、久し振りに、一席叩いてこまそ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "横っ飛びにすっとんで来たが――若旦那」　と、いって、片手で、何かを拝んで「死んだ大旦那様の御加護だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り込んで来る得物の下をかいくぐって、横っ飛びに、もういつか、五間あまり、駆け抜けていた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、狐はひらりと身をかわして、横っ飛びに森の中へ逃げていって、見えなくなってしまいました。",
              "citation": {
                "source": "ひでり狐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそではありませんな』『わしは、二枚舌は使わん』　三木は、横っ飛びに自分の選挙事務所へ飛んで帰った。",
              "citation": {
                "source": "春宵因縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るや米友は横っ飛びに飛んで、三仏堂の縁の上へ飛び上ったかと思うと、扉を押して堂の中へ身を隠し、素早く中から扉を閉して閂を締めました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ままよ――横っ飛びに飛んで、侍町の生垣の下を鼠のように走ると、御用の声を聞き伝えた家並が騒ぎ出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夢中になってこっち岸の岩を三つ四つ、横っ飛びに、下流の方へ走った。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "覗いていたのは伊集院五郎で、つんぼのお六に怒鳴られるや、横っ飛びに飛んで林へ隠れた。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　最後に残った一人の山窩、横っ飛びに逃げながら、声を嗄らして叫んだのは、仲間を呼びに行くのだろう。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄を切られてバラバラバラ、糸が紛れて目釘が外れ、刀身向こうへ飛んだ隙に、辛くも遁がれて横っ飛び、露路へ姿をくらませてしまった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者はお内儀の手をはなすと、お突きを喰らったはずみで、たじたじと二あしほど横っ飛びにすっ飛んだ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "後をも見ずにとはこのことだろう、横っ飛びに今松は車掌台まで飛んでいった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬前まで息せききって柳子が須永を追いかけまわしていた事が一目でわかる姿で、フットボールの試合でボールを追って横っ飛びしかけた選手を敵の選手がタックルした瞬間に、画面がピタリと停ったのに似ている。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言いながら、横っ飛びに、出て来た方へ小走りに立去りながら）ばさま、頼んだぞう！",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見るや本田は、いきなり、足袋はだしで、縁側から横っ飛びに飛び降りて行き、韮山にむしゃぶり附く）野郎、逃げるか！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お上にもお情けというものがあることは、町役人のお前さん、知らないはずはない」「…………」　重左衛門は横っ飛びに飛んで行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お民の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の者に呼ばせるから」　平次が部屋の外に首を出して呼ぶと、小僧の長六は、横っ飛びに入って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二服の薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今開けたばかりの裏門を押して横っ飛びに飛込むと、大地の上に尻餅をついた権助は、麩に飽きた金魚のように口をモグモグさせながらも、あまりの事に声を得立てず、両手の指を交る交るに突き出して、前方に立ち塞がる、海鼠塀の土蔵を指すのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "身寄りも知辺もない一人者で、時々ブラリと外へ出るほかは、珍糞漢糞な本ばかり読んでますよ」「しめたッ」　ガラッ八は、それだけ聞くと、横っ飛びに徳蔵稲荷へ駆け付けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鈴を慕う女",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹｜兄哥は在家かえ」「あ、銭形の親分」　磨き抜いた格子の内、柄にもなくとぐろを巻いて草双紙を見ていた子分は、横っ飛びに奥へ取次ぎました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮の浴槽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八ッ、もう一人、あの手代を捉まえろ、重三とかいった」「よしッ」　八五郎は横っ飛びに飛出しましたが、間もなく裏の方から、「親分、大変、親分」　とわめき立てます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪伝白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「相模屋という豆腐屋ですよ」　平次が眼配せするまでもなく、ガラッ八の八五郎は横っ飛びに小田原町へ飛んで行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　お勝手へ廻ると、乞食のような不気味な男が一人、下女のお友と立話をして居りましたが、平次と八五郎の姿を見ると、ひどく驚いた様子で、横っ飛びに裏通りに姿を隠してしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "生物の群がってる草の中に、昆虫の羽音の鳴り響く木陰に、クリストフは寝ころんで、じっとうちながめた、蟻の性急な活動を、歩きながら踊ってるように見える足長｜蜘蛛を、横っ飛びに跳ね回る蝗を、重々しいしかもせかせかした甲虫を、白い斑紋のある弾力性の皮膚をそなえている毛のないまっ裸の桃色の蚯蚓を。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
