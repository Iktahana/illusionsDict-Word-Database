    "definitions": [
      {
        "index": 1,
        "gloss": "Yomotsu Hirasaka (slope that leads to the land of the dead)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
