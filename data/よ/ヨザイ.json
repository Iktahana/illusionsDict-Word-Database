  {
    "uuid": "7f23306b-8726-5ba2-8111-943280f46480",
    "entry": "余財",
    "reading": {
      "primary": "よざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
