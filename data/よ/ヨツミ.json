          "literary": [
            {
              "text": "気に入ったとなるといねは同じ柄を五反も六反も織り、一つ身から四つ身までを十枚以上も作った。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の四つ身の着物を着たままで、縫目が弾けて綻びていたなどと言い伝えた。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば稚くして山に紛れ入った姉弟が、そのころの紋様ある四つ身の衣を着て、ふと親の家に還ってきたようなものである。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
