    "definitions": [
      {
        "index": 1,
        "gloss": "(Western) clothing store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "松島も父が佐倉藩の御典医であり、彼自身も抱えたちの前では帝大の医科の学生崩れのように言っていたので、銀子たちもそのつもりでいたが、ずっと後に彼の前身は洋服屋だということを言って聞かせるものもあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島は儲けの荒いところから、とかく道楽ものの多いといわれる洋服屋で、本郷通りに店をもっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は洋服屋に懲り懲りした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボタンの列の終ったところで、きゅっと細く胴を締めて、それから裾が、ぱっとひらいて短く、そこのリズムが至極軽妙を必要とするので、洋服屋に三度も縫い直しを命じました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすは洋服屋が、洋服の寸法をとりにやって来る筈だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう洋服屋さんが、寸法をとりに来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北さんは東京、品川区の洋服屋さんである。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服屋さんといっても、ただの洋服屋さんではない。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は兄貴と、それから兄貴の知人である北芳四郎という洋服屋と二人で相談してきめて呉れた、千葉県船橋の土地へ移された。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服屋がきて虎の子の十円を持って行きました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら註文を受けた作家たちは七枚、あるいは二十枚、あるいは百五十枚と、恰度洋服屋が客の註文に応ずるように、ジャアナリズムの註文通りの寸法に書かねばならない。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの場合、作家は洋服屋より一層困難である。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服屋には何｜呎でも服地はある。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても作家たちの関心事は洋服屋の関心事と同じである。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……洋服屋の宰取の、あのセルの前掛で、頭の禿げたのが、ぬかろうものか、春暖相催し申候や否や、結構なお外套、ほこり落しは今のうち、と引剥いで持って行くと、今度は蝉の方で、ジイジイ鳴噪いでも黐棹の先へも掛けないで、けろりと返さぬのがおきまりであった。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」繼母が口を挿み、「袴や洋服などを別にまたしツかりをそはりたいので――」「洋服なんか、洋服屋にならなけりやア入らないことだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧道に出て、洋服屋や、野菜店や、家具店などの小さな街を歩きながら子爵は、「南條さんは、僕の名前ご存じないでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋の洋服屋の店頭にぶら下げてある既製品だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今井君が洋服屋から探知したのである。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "手続（無試験）を済ませて、鶴巻町通りの高島屋支店といふ洋服屋に寄ると、頭髪を綺麗にわけた神経質さうな鋭い眼で、温厚さうな小柄の主人が、何科だと訊ねるので、Ｌだと答ると、早速ノートを持出して来て自作の詩を朗読し、感想を聞せて呉れと云つた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "手續（無試驗）を濟ませて、鶴卷町通りの高島屋支店といふ洋服屋に寄ると、頭髮を綺麗にわけた神經質さうな鋭い眼で、温厚さうな小柄の主人が、何科だと訊ねるので、Ｌだと答ると、早速ノートを持出して來て自作の詩を朗讀し、感想を聞せて呉れと云つた。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は居留地のほうにある外国人相手の洋服屋や小間物屋などを呼び寄せて、思いきったぜいたくな買い物をした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸善の店も隣りの洋服屋も表掛りが僅かに残ったゞけで、内部は煙が朦々と立罩めた中に焼落ちた材木が重なっていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやおや洋服屋の受取りがあるわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで私達は洋服屋の若旦那に逢はないで帰れる機運が生れた。",
              "citation": {
                "source": "鳩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
