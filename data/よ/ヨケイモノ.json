  {
    "uuid": "25d02ff4-fd37-52ca-b8f3-06e8f6472275",
    "entry": "余計者",
    "reading": {
      "primary": "よけいもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
