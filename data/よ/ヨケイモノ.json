      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person whose presence is unwelcome, unnecessary or a nuisance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どう考えたって、僕なんてのは余計者なんだからね。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "多人数の大家族の間に育った子供にありがちな、自分ひとりを余計者と思い込み、もっぱら自分を軽んじて、甲斐ない命の捨てどころを大あわてにあわてて捜しまわっているというような傾向が、この男爵と呼ばれている男の身の上にも、見受けられるのである。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の生活の苦しみはどこにもあるし、云い分のある事情もそれぞれどこにもあるであろうけれども、人を余計者、生存に堪えがたくさせる仕打は、この世の最も冷酷な、理由の立たぬ態度ではあるまいか。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶話３・９　私の故郷は瀬戸内海の海つ辺で、ヂストマと懶惰漢と国民党員の多い所だが、今度の総選挙では少し毛色の異つた人をといふので、他の県で余計者になつた男を担ぎ込み、それに先輩や知人の紹介状を附着けてさも新人のやうに見せかけてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正四（一九一五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女中は、腹立たしさうに余計者の銅鑼を睨まへる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫と四｜斗俵８・27（夕）　政治家ほど無益な者は無いが、その政治家を取り除けたら、鼠ほど無益な余計者は滅多にあるまい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間一人増えたため、この甥は二倍も気を使つてゐたが、一番余計者の彼は片隅に身を縮め、できるだけその存在を目だたないやうに努めた。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして事実またここでもまた余計者として取り扱われただけのことである。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "体操の時などは、私より背の低い子がまだ幾人もあるのに、私は「お前は余計者だ」と言わぬばかりに、一番最後に立たされた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそうでないときはたった一人、余計者としてその後にくっついて行かねばならなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに余計者にされても私は学校はいやではなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "母さんも眠ってるだろう……啓吉は、あの男と母親が、愉しそうに笑いあっているのではないかと思うと、自分が余計者のようで不図涙が出た。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗澹とした日常で、何しろ、すすんで何かやりたいと云った熱情のない娘でしたので、住居も定まらず親子三人で宿屋から宿屋を転々としながら、私は何時も母親に余計者だとののしられながら暮らしていました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の生活がりっぱにうち立てられたせいか、ここにいると、僕はなんだか余計者だって気がするよ。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の方はというと毎日どこかへ家畜の検疫に出掛けて、時によると三日も続けて家をあけることがあるので、オーレンカはサーシャが両親にすっかり打棄られて、一家の余計者扱いにされ、飢え死しかけているような気がしてならなかった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初のゲームはまだ終らなかったが、彼は早くも退屈してしまって、自分は余計者だ、邪魔なばかりだと、そんな気がしはじめた。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしね、僕たち不運な余計者というものは、こういう話でもさせて貰わなけりゃやりきれないんだよ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いのはオネーギンだ、ペチョーリンだ、薄命児だの余計者だのを発明したツルゲーネフだ、と言うんだね。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて加えて彼は薄命児だ、余計者だ、神経衰弱だ、時代の犠牲だ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆けだしの文士というものは、殊に不遇な時代がそうですが、われながら間の抜けた、不細工な余計者みたいな気のするものでしてね、神経ばかりやたらに尖らせて、ただもう文学や美術にたずさわっている人たちのまわりを、ふらふらうろつき回らずにはいられない。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "相模大進坊濡れ燕（発端篇）　せっかく盗みだしたこけ猿の壺を、チョビ安てえ余計者がとびだしたばっかりに、丹下左膳という化け物ざむらいにおさえられてしまった鼓の与吉。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を余計者扱ひにして妹ばかりを大事に育ててゐる彼等は少しは思ひ知るであらう。",
              "citation": {
                "source": "ある職工の手記",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生は学生である限り立派に特権的に食っているにも拘らず、学生は一種の可能的な失業者と見做されることになり、云わば一種の余計者で邪魔者だとさえ考えられて来る。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそ者、余計者でどこでだってじゃまになる人間なんです。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとの関係で云える伊藤整たちの登場人物（余計者の自覚によりつよく立ったあげくの積極性と平野の云っているところのもの）との関係など。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
