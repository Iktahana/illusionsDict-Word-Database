    "definitions": [
      {
        "index": 1,
        "gloss": "protection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よくよく咽喉の栓となつた生焼けの餠は、却々取り除けられさうもなかつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕の風変りな性格が、小学生時代から仲間の子供とちがって居たので、学校では一人だけ除け物にされ、いつも周囲から冷たい敵意で憎まれて居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔除鼠除けの呪文、さては唐竹割の術より小よりで箸を切る伝まで十銭のところ三銭までに勉強して教える男の武者修行めきたるなど。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日の洋画家中唯一の浅井｜忠氏を除けばいずれも根性の卑劣な※の声を打消していった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が除けて通るのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "程よい衝動は彼の苦痛に響いていくらかの慰撫となった彼は落葉の層をなるだけ除けて、堅い舗道面の露出して居る部分を殆ど、無意識に拾って歩いて居た。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地不案内に加えて、右往左往した上、乗った船もここにはやてを除け、かしこに凪ぎを待つという進み方なので山の祖神の翁の上に人間の歳月の半年以上は早くも経ってしまった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅寺では食事のとき、施餓鬼のため飯を一｜箸ずつ鉢からわきへ取除けておく。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は照れるようなこともなく言葉もそう改めず、この旅でも、ただ身のまわりの世話ぐらいは少し遠慮を除けてしてあげるぐらいなものであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれに刺され、あるいはそれを除けて行く往来の人はまだ篩にかけられていなかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも水蒸気が地上の物体に接触して生ずる露と霜と木花と、氷点下に過冷却された霧の滴が地物に触れて生ずる樹氷または「花ボロ」を除けば、あとは皆地上数百ないし数千メートルの高所から降下するものである。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は何の話にも僕等二人は除けものにされる始末で、もはや二人は全く罪あるものと黙決されてしまったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼の幼時の思い出のかかっている家具の一つでも取除けることを許さなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが都会の新文化の発展に追除けられ追除けられして竪川筋に移り、小名木川筋に移り、場末の横堀に移った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、今日苦しんでるんだ」　薫は肘で払い除けるが、小初は関わず背筋へ入れた砂をぽんぽんと平手で叩き均らして、「ちっとも苦しんでるように見えないわ」「この間、水の中で君に…………、こんなに腫れた」　薫は黒くなっている唇の角をそうっと大事に差し出して見せる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しただ一人久保田さんが纎細緻｜密な作品を書く人でありながら球突ではひどく不器用なのを除けばそれぞれに球突の中にも作品の感じが現れてくるから面白い。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしは毎年夏場になると、蝮よけ蛇除けの御符売りというものが何処からか出て来るんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、その村で、ほかの子供たちから除け者にされながら少年時代を過した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那大陸広しと雖も、我が経済的勢力の絶対に支配する地域は、満蒙を除けば山東あるのみである。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、第四、第五水兵はもぎ取られた瓦斯除けマスクをつけて死にながら横たわる）　表現派は、主観主義である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い幌のなかの乗客の眼がみな一様に前方を見詰めている事や、泥除け、それからステップの上へまで溢れた荷物を麻繩が車体へ縛りつけている恰好や――そんな一種の物ものしい特徴で、彼らが今から上り三里下り三里の峠を踰えて半島の南端の港へ十一里の道をゆく自動車であることが一目で知れるのであった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人が背負い網を負って山から帰って来る頃で、見知った顔が何度も自動車を除けた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日を除けて、一階も二階も三階も、西の窓すっかり日覆をした旅館がやや近くに見えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの道死ぬるものなら一足でも前へ進んで、世間の者が夢にも知らぬ血と泥の大沼の片端でも見ておこうと、そう覚悟がきまっては気味の悪いも何もあったものじゃない、体中｜珠数生になったのを手当次第に掻い除け※り棄て、抜き取りなどして、手を挙げ足を踏んで、まるで躍り狂う形で歩行き出した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此の按摩杖を力に、川べりの水除け堤へ来ると、杖の先へ両手をかけて、ズイと腰を伸ばし、耳欹てゝ考えて居る様子、――と言ふ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際大噐晩成先生の在学態度は、その同窓間の無邪気な、言い換れば低級でかつ無意味な飲食の交際や、活溌な、言い換れば青年的勇気の漏洩に過ぎぬ運動遊戯の交際に外れることを除けば、何人にも非難さるべきところのない立派なものであった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し虫のよい取り方をして硫黄、岩雄を Yuwo, Yuwao と見て除けば N(VC) = 4 となり R = 9 となる。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に消火山活火山をも合わせて取り扱う場合には、N'(VC) = 11 となり、R = 3.3 に減ずるが、硫黄・岩雄の頭がｙなる子音だとして、このアソ型から除けば R = 5.1 となる。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい蜘蛛の糸が二すじ三筋付いていたから、特に注意して摘み除けた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下樣の繩暖簾とはことかはりて、醉うても聞き苦しきいさかひはなけれど、苟めの物語も高聲になり、默してやみなんことも笑ひさざめき、座中自ら春を生ずる自らはよけれど、他人の閑を破るはにくし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
