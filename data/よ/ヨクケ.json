        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あんたは怠けて出来ないんだし、耕ちやんのは好い頭でないのとそれに欲気がまだ出ないんだから………。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の奴はこの邪道でコロリコロリと参る……俗物は色気や欲気で誘い出し、君子はその道を以てこれを欺くといった風に、その効果が眼の前に現われます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで江戸へ運ばれて以来、欲気の多い連中が、遮二無二そいつを奪い合ったのでござる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けちな欲気なんか少しも持っていないのが太閤だ。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、実際村の者は酔うとよくけんかをするのです、とてもよくやる。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　兄弟はだんだん大きくなって、よくけんかをしました。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "率先した横浜貿易があの旧師に祟った上に、磊落な酒癖から、松尾の子息ともよくけんかしたなぞという旧い話も残っていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、よくけんかの起こるりんごですね。",
              "citation": {
                "source": "政ちゃんと赤いりんご",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしには学校の先生のようなしんぼう気がなかったから、かれは物を読むことや音楽のけいこをするときにはよくけんかをしそうにした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ほかのアザラシとよくけんかをして、きっと勝つのだ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薙刀、剣術などの稽古にはかれらに相手を命じ、心の昂ぶっているときにはよくけがをさせた。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
