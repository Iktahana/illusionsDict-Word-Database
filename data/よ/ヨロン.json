    },
    "definitions": [
      {
        "index": 1,
        "gloss": "public opinion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「自殺しない厭世論者の言ふことなんか、當になるものか。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが自殺しない厭世論者の言ふことなんか、皆ウソにきまつてゐるよ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も僕も、どうせニセモノの厭世論者さ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ彼が反復した最後の言葉――自殺しない厭世論者の言ふことなんか、たれが本氣にするものか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寝巻姿のバルザック像がサロンに出品されると世論は沸騰して、ロダン後援会の人々でさえ呆然としてしまったのだそうです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お栄さん僕はそんな声を聴かされると何だか哀れっぽくなって堪りません』と思わず口に出しますと『小妹は何故こんな世の中に生きているのか解らないのよ』と少女がさもさも頼なさそうに言いました、僕にはこれが大哲学者の厭世論にも優って真実らしく聞えたが、その先は詳わしく言わないでも了解りましょう。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの場合では、悪漢団だとするこの『世論』なるものには、僕の抜書きの三番目のものに書いてある傍系的な事件がつけ加えられているように、僕には思われるね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、偶発的に暗示された世論が我々に信じさせようとしているのは、この驚くべき一連の暗合によってでなくてなんであろうか？",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＥＵにおける世論や政治状況は、保護期間の延長を支持していないと思われる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方吾人は、社会的にも世論を喚起する積りである。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "又経世論では無論ない。",
              "citation": {
                "source": "文壇一夕話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『浮雲』の如き世論『書生気質』以上であるが、坪内君の合著の名でなかったなら出版する事は出来なかったのだ、出版しても恐らくアレほどに評判されなかったろう。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そうした轟々たる世論を外に、荘田は結婚の準備をした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもっても世論の大勢がその当時、どんな風であったかわかるだろう。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、群集――特に近所の人たち――の世論は、どうやら、「因果応報」だと言った林の言葉を裏づけてゆくらしい傾向があった。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想は現実との矛盾衝突を意味している（かく我々の精神は衝突によりて現ずるが故に、精神には必ず苦悶がある、厭世論者が世界は苦の世界であるというのは一面の真理をふくんでいる）。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは政府の一つの機關をなすものゝ態度としても實に怠慢の至りであつて、世論が少しも之を問はない事が既に不可思議の次第である。",
              "citation": {
                "source": "維新史の資料に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、さうした轟々たる世論を外に、荘田は結婚の準備をした、春の園遊会に、十万円を投じて惜しまなかつた彼は、晴の結婚式場には、黄金の花を敷くばかりの意気込であつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう独裁者は人類の平和のために打倒して、われわれの方針である自由主義の信条に基づく新しいヨーロッパの連合体制を採ろう」というのが、英国の知識階級の世論だと言われております。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "終ると先方から、「現在の日本の財政では無理である」「無い袖は振られない」というようないろいろの抗議的説明や質問があったが、私は「私ども軍人には明治天皇から『世論に惑わず政治に拘らず只一途に己が本分』を尽すべきお諭しがある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木夫妻の死という行為に対して、初めは半信半疑であった作者が、世論の様々を耳にして、一つの情熱を身内に感じるようになって彌五右衛門が恩義によって死した心を描いたのは作者の精神の構造がそこに映っている意味からも面白いと思う。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界平和大会が「世論を毒する宣伝を無力なものにするために、真理と理性の防衛のために広汎な戦線をうちたてる」ことが必要であることを、宣言しているのは実に実際的だと思います。",
              "citation": {
                "source": "わたしたちには選ぶ権利がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世論が公正に監視をつづけなければならないかなめは、これからほぐされて来る。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の五人の名流婦人たちが、「非武装国日本女性の講和問題についての希望要項」をダレス国務省顧問に託して、アメリカの世論に平和を訴えたことは非常にいいことだった。",
              "citation": {
                "source": "平和の願いは厳粛である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の権力が、科学によって強化されるプロセスが、催涙ガスの使用とか、指紋採取とかいう面でおし出されていることについて、世論は無批判でありえないのである。",
              "citation": {
                "source": "指紋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の愚民教育に反対する世論を、全日本的な発言として組織した情熱。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で結果に於て所謂財界は大してハッキリした意志表示をしていないから、この方面からの影響で結果する部分の「世論」も亦、大して反近衛的ではないのが現状であるようだ。",
              "citation": {
                "source": "近衛内閣の常識性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやはりきよろんとしてゐて答へない兄を見ると、「兄さん」と云ふと「おい」と答へる兄をどんなに羨しく思つた事か。",
              "citation": {
                "source": "鍛冶屋の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、町の人は、こんなふうに、魂をぬかれたやうに、きよろんきよろんとあたりを見てゐたり、荷馬車にぶつかりさうになつてどなりつけられたりはしません。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この、きよろんきよろんが二人ともやめられないのでした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
