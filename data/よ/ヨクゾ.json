        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母上善くぞ歌ひしと讚め給へば、農夫どもゝジヤコモが旨さよ、と手打ち鳴してさゞめきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善くぞ歸り來玉ひし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善くぞ帰り来玉ひし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "195脚神速のアキリュウス其時二人を迎へ曰ふ、『善くぞ！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても殺生はての死の、よくぞ好きなる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、よくぞ、そこまで氣づいて呉れた。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくぞ、きょうまで喰いつかれもせず無事に過してきたものだと不思議な気さえしているのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼君御機嫌美はしく、「よくぞ心附けたる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくぞそこに心が注いた。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一文の金でも惜しいこの大みそかに、よくぞ一両、そしらぬ振りして行燈の傍に落し、短慶どのの危急を救って下された。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくぞ男に生れたる、と云う陽気でもなく、虫を聞く時節でもなく、家は古いが、壁から生えた芒も無し、絵でないから、一筆｜描きの月のあしらいも見えぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に眼を瞠目って、よくぞこのうき世の荒浪に堪うるよと思う。",
              "citation": {
                "source": "愛よ愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お差しつかえなければ、お伴致しとうござる」　と言うと、無敵は、「よくぞ言って下さった」　と、佐助の手を握って、ハラハラと落涙し、既に道場を荒された恨みなど忘れていたのは勿論である。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶寮には灯のはひり、石いくつ水うつあひだ、彼方見て、もの言ひてます物ごしのあはれ、よくぞ似る妻が母刀自、子らにもけだし。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビュロオ伯は常の服とおぼしき黒の上衣のいと寛きに着更へて、伯爵夫人とともにここにをり、かねて相識れる中なれば、大隊長と心よげに握手し、われをも引合はさせて、胸の底より出づるやうなる声にてみづから名告り、メエルハイムには「よくぞ来玉ひし、」と軽く会釈しぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビュロオ伯は常の服とおぼしき黒の上衣のいとひろきに着かえて、伯爵夫人とともにここにおり、かねて相識れるなかなれば、大隊長と心よげに握手し、われをも引き合わさせて、胸の底より出ずるようなる声にてみずから名のり、メエルハイムには「よくぞ来たまいし」と軽く会釈しぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくぞ帰り来たまいし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　シャーロック・ホームズは腰を下ろして、パイプに火をつけ、「よくぞいらっしゃいました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だこれだけと見るか、よくぞここまでと見るかは別として、ＢＴＲＯＮは確かにデビューを果たしたのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥五七　よくぞ仰せられた。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お察しなされて下されませ」「いや、よくぞ申された。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくぞ紋めの膝で諌言いたしてくれた。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくぞお出でくだされた。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてもよくぞ拙者を捕え、正雪一味へ渡されたな！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にはよくぞイスラエルのお町を、拙者から横取りなされたな」まず城之介いったものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水、米、酒、豆腐、俳句――よくぞ日本に生れたる！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋ふかしよくぞ日本に生れける」我が心は秋の水の如し！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十九日天地清明、いよ／＼本格的秋日和となつた、働らくにも遊ぶにも、山も野も海も空も、すべてによろしいシーズンだ、よくぞ日本に生れける、とはこの事だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「従者出来て、こはよくぞ来ましゝ、此日比悩み給ふと聞きつるに、み心地はいかになど問ひつつ、駕籠の戸引きあけつ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
