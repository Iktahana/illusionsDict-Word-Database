    },
    "definitions": [
      {
        "index": 1,
        "gloss": "horizontally",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
