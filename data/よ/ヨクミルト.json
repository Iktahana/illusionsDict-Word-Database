    "definitions": [
      {
        "index": 1,
        "gloss": "(on a) closer look",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
