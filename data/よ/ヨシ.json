      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かといつてどう改良したらいいかといふことになると、結局やつぱりこの儘でいいやといふやうなことになつて来て、此の事ならず一切が、実に屁下手く退屈なのが人生である。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんどは此のおもちやの此処ンところをかう改良して来い！",
              "citation": {
                "source": "玩具の賦",
                "author": "昇平に",
                "note": "青空文庫"
              }
            },
            {
              "text": "お照さんとは一ばんの仲良し。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこれを改良して近頃は符号などは用いず、言語をそのままに送るいわゆる無線電話が出来るようになった。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて何となく夫妻の間に味がない、お人良しでしかも根がしっかり者の良人の岳神が少しにやにやしながら、「働けそうな女なので、共稼ぎにはいいと思いましてね、この奥地の八溝山の岳神の妹だったのを貰って来ましたのです。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで電灯の下に反射鏡を取り付け光を天井から反射させるように改良したら、その後は眼を病む者がサッパリなくなったという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入歯を、発明し、改良して来た西洋人が、もしわれわれと同じ食物を食って生きているのだったら、そうしたら、餅を食っても、飴を食っても、故障の起らないような入歯が、今頃は出来ているのではあるまいか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして右の手には鼠色になった白木綿の小旗を持っているのだが、その小旗には「日本服を改良しましょう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか、その旗には『日本服を改良しましょう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本服を改良しましょう、すぐしましょう」と書いた旗が、どういうきっかけだったか、その瞬間に柿江の眼にまざまざと映って、それが見る間に煙のようにたなびいて消えていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の肉体の貞操を売っても、夫へ心の貞操を捧げるのを良しと認めた封建時代の女性の良心は、もう今日の女性の良心ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸事を改良して、欧米の劇場にならいたる興行法が、一般観客の反感を買い、さんざんの不評に終れり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、おれはあの青蛇団と留置場の中ですっかり仲良しになったんだよ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはね、――」兄嫁はちょっと口ごもって、「あたしの一番の仲良しをあの晩お呼び出来なかったからよ。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎はお兼の意見に従うことを良しとした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　アレキサンダー君は、さう云いながら、私達の卓子を囲んで集まった、各自国籍の異るらしい四五人の女給の中で、一番器量良しの細い眼をした、金髪の少女の頤を指でつついたものだ。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "電線の調子の良し悪しや、先方の読み方の上手下手に依っても違ったが、それでもこの予感のおかげで叔父の身代はメキメキと殖えて行った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして到るところで、村の子供達と仲良しになつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "並の金魚はたいしたこともありますまいが、改良してどしどし新種を作れば、いくらでも価格は飛躍します。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つ八つの泡によって鍋底から浮上り漂う銀杏形の片れの中で、ほど良しと思うものを彼は箸で選み上げた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊は苗の良し悪しよりも、手当の仕方ですよ。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生、結婚できなくとも、母を助け、妹を育て、それだけを生き甲斐として、妹は、私と七つちがいの、ことし二十一になりますけれど、きりょうも良し、だんだんわがままも無くなり、いい子になりかけて来ましたから、この妹に立派な養子を迎えて、そうして私は、私としての自活の道をたてよう。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅紗は良し――それ、島内といふ郡長がありましたな。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乱杭、歯くそ隠の鉄漿をつけて、どうだい、その状で、全国の女子の服装を改良しようの、音楽を古代に回すの、美術をどうのと、鼻の尖で議論をして、舌で世間を嘗めやがる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の母娘は評判の仲良しで近所の人達は彼女等が姉妹か親友のようだと言う程、何事をも共同でやっていた。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ食うに困れば、梅田へ行って無心すれば良しと考えていたのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お人良しと猜疑とのまざりあった其の眼付。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マインツの金細工師、ヨハネス・グーテンベルクは、鋳造した活字に油性のインクを塗り、ブドウ絞り機を改良したプレスで印刷するという、活字印刷の技術を確立したとして記憶されています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
