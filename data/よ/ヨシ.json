[
  {
    "uuid": "6721199c-2097-5c11-a685-a77eb4078343",
    "entry": "良し",
    "reading": {
      "primary": "よし",
      "alternatives": [
        "えし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
