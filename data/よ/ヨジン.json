          "literary": [
            {
              "text": "旧王城の遺跡と新開都市の面目とを雑然と混へたうへに、戦乱の余塵未だ消えやらぬ荒涼たる一角を残して、南京は、今、私の眼の前にやゝふて腐れ気味な姿を横へてゐる。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
