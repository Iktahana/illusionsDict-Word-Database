[
  {
    "uuid": "7f386456-1155-5d2b-9d39-f221e71d42f3",
    "entry": "幼君",
    "reading": {
      "primary": "ようくん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
