[
  {
    "uuid": "81173ee3-a429-5b79-9bab-3d249c62d661",
    "entry": "養分",
    "reading": {
      "primary": "ようぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
