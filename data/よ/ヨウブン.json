  {
    "uuid": "78b5edc9-1fa2-53f6-be13-fe48eb4db8c3",
    "entry": "洋文",
    "reading": {
      "primary": "ようぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
