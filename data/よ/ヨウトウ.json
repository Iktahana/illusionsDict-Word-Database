[
  {
    "uuid": "073a8e11-151b-55cb-8454-b142746548cd",
    "entry": "洋灯",
    "reading": {
      "primary": "ようとう",
      "alternatives": [
        "ランプ"
      ],
      "is_heteronym": false
    },
    "grammar": {
