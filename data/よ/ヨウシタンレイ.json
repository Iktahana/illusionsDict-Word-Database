    "definitions": [
      {
        "index": 1,
        "gloss": "attractive face and figure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
