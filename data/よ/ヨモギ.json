    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese mugwort (Artemisia princeps)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お祝言の時などの島臺の、れいの蓬莱山、尉姥の身邊に鶴と一緒に侍つて、鶴は千年、龜は萬年とか言はれて目出度がられてゐるのは、どうやらこの石龜のやうで、すつぽん、たいまいなどのゐる島臺はあまり見かけられない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ、繪本の畫伯もつい、（蓬莱も龍宮も、同じ樣な場所なんだから）浦島さんの案内役も、この石龜に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉の秋木も、一合五勺位から皆無になったが、虎杖は二つ塚側火山の側面まで生えている、それも乱れ髪のように、蓬々としている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬はやつれた女の髪の毛のやうに、へらへらと風にうごいてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原蓬の根がぼうぼうとひろがつてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬が雪に蔽われていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うち見には十五六と思わる、蓬なす頭髪は頸を被い、顔の長きが上に頬肉こけたれば頷の骨｜尖れり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "トシエの親爺の伊三郎の所有地は、蓬や、秣草や、苫茅が生い茂って、誰れもかえり見る者もなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんごん胡麻は老婆の蓬髪のようになってしまい、霜に美しく灼けた桜の最後の葉がなくなり、欅が風にかさかさ身を震わすごとに隠れていた風景の部分が現われて来た。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といいながら気だるそうに手を持上げてその蓬々と生えた天窓を撫でた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で干潮の時は見るも哀で、宛然洪水のあとの如く、何時棄てた世帯道具やら、欠擂鉢が黒く沈んで、蓬のような水草は波の随意靡いて居る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思見る、磐梯山の煙は、雲を染めて、暗は尚ほ蓬々しけれど、大なる猪苗代の湖に映つて、遠く若松の都が窺はれて、其の底に、東山温泉の媚いた窓々の燈の紅を流すのが遥々と覗かれる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇に向つて、髯髪も蓬に、針の如く逆立ち、あばら骨白く、吐く息も黒煙の中に、夜叉羅刹を呼んで、逆法を修する呪詛の僧の挙動には似べくもない、が、我ながら銀の鍋で、ものを煮る、仙人の徒弟ぐらゐには感ずる。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に離宮の西、汐留町との間を流れて直に海に入るの流れは、土橋難波橋○新橋蓬莱橋汐先橋の下を流るゝ水の末ともいふべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三十間堀即ち真福寺橋の流れの続きにして、豊倉橋紀国橋豊玉橋朝日橋三原橋木挽橋出雲橋等の下を流るゝ一水は、前の一水と新橋の下、蓬莱橋の上にて丁字形をなして相会す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋場のさる人の庭のいと濶きに此花のいと多く咲きたるを見しそれの年の秋の夕暮、かゝるところにてこそさる男も泣きけめと、楸楡颯々｜蓬艾蕭々として夕月の光り薄く西風の音の淋しかりしまゝ、勝れて艶なる此花を見る／＼徘徊りて想ひやりたることありき。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉どおりにぼろぼろの着物をきて、頬かぶりをした手ぬぐいの穴から一束の蓬髪が飛び出していたように思う。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎が鬼が島を征服するのがいけなければ、東海の仙境蓬莱の島を、鎚と鎌との旗じるしで征服してしまおうとする赤い桃太郎もやはりいけないであろう。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを考えながら、Ｔ君の山男のような蓬髪としわくちゃによごれやつれた開襟シャツの勇ましいいで立ちを、スマートな近代的ハイカーの颯爽たる風姿と思い比べているうちに、いつか快い眠りに落ちて行ったことであった。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呼びかけた一羽の烏は、無帽｜蓬髪の、ジャンパー姿で、痩せて背の高い青年である。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青年は蓬髪を掻き上げて笑い、「まあ、一介のデリッタンティとでも、……」「何かご用ですか？",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　無帽｜蓬髪、ジャンパー姿の痩せた青年は、水鳥の如くぱっと飛び立つ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに見すぼらしき後ろ影、蓬なす頭、色あせし衣、われはしばしこれを見送りてたたずみぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌は長い方で、鼻も高く眉毛も濃く、額は櫛を加えたこともない蓬々とした髪で半ばおおわれているが、見たところほどよく発達し、よく下品な人に見るような骨張ったむげに凸起した額ではない。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大食の純次はまだ喰いつづけていたし、父はまだ飯にしないので、母も箸を取らずにいたが、清逸は熱感があって座に堪えないので、軽く二杯だけむりに喰うと、父の自慢の蓬茶という香ばかり高くて味の悪い蓬の熱い浸液をすすりこんで中座した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤に、黄に、紫に、からからに乾いて蝕まれた野葡萄の葉と、枯｜蓬とが虫の音も絶えはてた地面の上に干からびて縦横に折り重なっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦もちょいと振向いて、（大道｜商人は、いずれも、電車を背後にしている）蓬莱を額に飾った、その石のような姿を見たが、衝と向をかえて、そこへ出した懐炉に手を触って、上手に、片手でカチンと開けて、熟と俯向いて、灰を吹きつつ、「無駄だねえ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子は被らず、頭髪を蓬々と抓み棄てたが、目鼻立の凜々しい、頬は窶れたが、屈強な壮佼。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野のどこからも眺められるその山は、朝は藍に、昼はよもぎ色に、夕は紫に色を変えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
