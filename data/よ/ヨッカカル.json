        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女は障子へ寄っかかるようにして立っていた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは一生けんめい鋤へ寄っかかる。",
              "citation": {
                "source": "イワンの馬鹿",
                "author": "SKAZKA O IVANE-DURAKE",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世子が気まぐれに時々水彩画を描く木炭紙を棚から下してそれを四つに切ったのに器用な手つきで炬燵につっぷして居る銀杏返しの女の淋しそうな姿を描いて壁に張りつけて眼ばたきを繁くしながらよっかかる様な声で云った。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろの板の羽目へ黄色い編下げの頭をくっつけ、相手によっかかるようにしてシューラがナースチャの肱を二本の指で締めつけた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、或る晩、岸本が少々酔って、帰りかけると、扉の外に「若禿」がよっかかるようにして立っていた。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは全面的に記憶にだけ訴えると、あまりにその上によっかかることになり、結局それをおしつぶしてしまう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
