[
  {
    "uuid": "341f0de8-ca2e-554d-910d-543f5db67131",
    "entry": "予定",
    "reading": {
      "primary": "よてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plans",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勧進帳の前が予定食事時間、三十分の休憩。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "資金として馬場が二百円、私が百円、そのうえほかの仲間たちから二百円ほど出させる予定である。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式は午後五時の予定である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は休暇中の自分の予定が、まだ三分の一も出来てゐないことでヂリヂリしてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは地球から見た時に太陽が天球のどこに来ているかという事を意味するだけの事であるから、太陽系に何か大きな質量の変化が起こるか、重力の方則が変わらない限り、予定のとおり進行してゆくはずである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に、よほどのぼんやりでない限りのすべての観客のおのおのの大きくみはった二つの眼が一斉にこの不幸な犯人の左の顋下の大きな痣に注がれるのはもとより予定の通りである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十九年に両親と祖母に伴われて東海道を下ったときに、途中で祖母が不時の腹痛を起こしたために予定を変えて吉浜で一泊した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも言語があるという事は知識の存在を予定する。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一つの方則を実験しようというならば、その実験を支配し得る種々の原因要素を分解して、その内から特にその方則に指定した要素のみを抽出し、他のものを除くようにしなければ予定の結果を得る事は出来ない。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理の実験である予定の結果に到達しようとするには、その結果を支配し得べきあらゆる条件要素を考えてみて、眼前の目的とする原因のみを特に作用させ他の要素は出来得る限りこれを除き、簡単にしあるいは一定にしなければならぬ。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の原稿があまり専門的であった上に予定の頁数を超過するので編輯者の方から苦情が出た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "約一年余の時日を費やす予定で、その費用として一万六千ルーブル（約一万三千円）を国庫より支出することとなったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、予定の紙数の制限に近づいたので、別の機会に譲る。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから防空演習の予行日であったので、まだ予定の消燈時刻前であったが所によっては街路の両側に並んだ照明燈が消してあった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷で乗換える時に時計を見ると、まだ少し予定の時刻より早過ぎたから、ちょっと公園へはいってみた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにある日曜の昼過ぎから家族四人連れで奥多摩の入口の辺までという予定で出かけた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂は交通線上の一つの特異点であって、歩行者の心のテンポにある加速度を与えるために自然に予定の行為への衝動を受けるのかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事が予定の計画通りに運ばれて、かれらは生きながら芝浦の海の底へ葬られてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから仕事の予定も肥料の入れようも見当がつかないのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともこんな反省すらもちゃんと予定の仕組で、今もしあの男の影があすこへあらわれたら、さあいよいよと舌を出すつもりにしていたのではなかろうか……」　生島はだんだんもつれて来る頭を振るようにして電燈を点し、寝床を延べにかかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつの間にか、これから三里の道を歩いて次の温泉までゆくことに自分を予定していた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道でとうとう私は迷ってしまい、途方に暮れて暗のなかへ蹲まっていたとき、晩い自動車が通りかかり、やっとのことでそれを呼びとめて、予定を変えてこの港の町へ来てしまったのであった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園は予定のかへられない都合があつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○万年橋はこの川の口に架れる橋にして、往時は匪徒を伊豆の諸島に流すに、この橋の畔と永代橋の畔より船を出すを例とし、かつこゝよりするものは帰期あるものと予定し、永代橋よりするものは帰期なきものと予定する習ひなりしといふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて彼の元子論に従ってすべての元子が自然方則によって直線落下をつづけるか、あるいは少なくもなんらかの確定的の方則によって支配されているならば、すべての世界の現象は全然予定的に進行するのみであって、その間になんら「自由」なる意志の現われうべき余地はないのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同様に未来の物理学進歩の経路も必ずしも単義的にただ一筋の予定の道筋を通るであろうとは考えられない。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほかにもまだいろいろあるであろうがあまりに予定の紙数を超過するからまずこのへんで筆をおく事とする。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともいわゆる、ルーティン的な仕事であって、予定の方法で、予定の機械の指示する示度を機械的に読み取って時々手帳に記入し、それ以外の現象はどんな事があっても目をふさいで見ないことにする流儀の研究ではなんの早わざもいらない、これには何も人間でなくてもロボットもしくは自記装置を使えばすむことである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊員はそれぞれの艇へいそいで引揚げなさい」「先生、いま運搬をやめては、『宇宙の女王』号はよていした燃料の三分の一くらいしか持っていないことになり、長い航空にはたえませんですよ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
