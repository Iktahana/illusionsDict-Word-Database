[
  {
    "uuid": "533e2ddb-a04d-5d80-b137-7dd7e667ec40",
    "entry": "用言",
    "reading": {
      "primary": "ようげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
