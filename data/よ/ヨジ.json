[
  {
    "uuid": "bd6c4c41-981d-54d8-990f-b6a02d8734eb",
    "entry": "４時",
    "reading": {
      "primary": "よじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
