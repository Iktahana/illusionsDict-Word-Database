    "definitions": [
      {
        "index": 1,
        "gloss": "(all) important positions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "植木鉢や、金魚鉢が、要所要所に置かれて、小ざっぱりした散髪屋である。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が覗き込む要所要所には必ず大小の食もの屋の店先があった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬狩りの群れは二、三人幾組にも分れて、川筋から里につづく要所要所に待ち伏せをしたが、月の明かるい夜にはかの嘶きが決して聞えないで、いつも暗い夜に限られているために、その正体を見届けるのが頗る困難であった。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は話の要所要所に力点をつけて、そのたびに、例の裁判官に特有の、相手の心胆をこおらせるような視線を、聴き手の顔へ投げるのであった。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "半紙いっぱいに書いた見取り図の要所要所へそういう文字を書き入れて、ここ加州家裏門としるしたその門の横の道に、長々と寝そべっている人の姿が見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこのかどに張っていた雑兵をうまいことおだてて聞き出したんだがね、あば敬大将はあの下手人をのどえぐり修業のつじ切りだとかなんだとかおっかねえ眼をつけてね、お番所詰めの小者からつじ役人にいたるまでありったけの捕り方を狩り集めて、江戸じゅうの要所要所に捕り網を張らしているというんですぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内要所要所の配備におんつきそうらえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場の周囲には、要所要所に縄を張って、交通を遮断し（これでも交通妨害にならないから不思議だ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "残る部隊は要所要所に屯ろして、逃げまどふて来るであらう敵を一匹もあまさず引つとらへて了はうと片唾をのんで居りました。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所要所へ配るのであろう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまりその、そうやれば灯火管制の方は完全でありましょうが、要所要所を固めている者達の活動が出来なくなるばかりでなく、悪性の労働者が、暗闇を幸い、どんな悪いことをはじめるかわかりません。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、その後に、「電波嬢」一名メリー・ウェルズなる人造人間を作るが、これが世にもまことに麗しい妙齢の婦人の相貌を備え、しかも機械力で二十人力の腕力があり、要所要所に六個の耳を備えて居り、時速六十｜哩の快速力で、駈け出すことができるという鬼神のお松そっちのけの人造人間である。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄甲を冠った警官隊が、要所要所を堅めているばかりで、何の事もない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその要所要所を強調した縮図だ。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所要所では拍手をやる。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつに油と食糧を積込んで、友吉親子に操縦法を仕込みながら西は大連、営口から南は巨済島、巨文島、北は元山、清津、豆満江から、露領沿海州に到るまで要所要所を視察してまわること半年余り……いかな太っ腹の佐々木知事も内心大いに心配していたというが、それはその筈だ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は、あなたが遂行された歌原未亡人惨殺事件の要所要所に、夢遊病の特徴をハッキリとあらわしておられるのです。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道は避難者で雑踏を極め、要所要所には兵士や憲兵や自警団員が監視していた。",
              "citation": {
                "source": "帰京記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、表と裏と、町の抜け路――要所要所に、人数が配置された。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本市街を過ぎる中に私の心を寒くしたのは、砲兵が野砲を挽いて行軍し、大街の要所要所に歩兵が伏射の形で銃を擬し、また各所で工兵が堅固な角材で鹿柴を組み立ててゐる事であつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならず今度は反対に長州兵が攻めて来るかも知れぬというので、海岸の要所要所へ俄造りの砲台を構えて、新古取交ぜの大砲を据え付けて、幾らかの兵を配置した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ天井から下っている、珊瑚と鋼玉と爐眼石とで、要所要所を鏤められた、朝顔型のアレジヤ龕が、朝顔型に琥珀色の光を、床の上へ一ぱいに投げていた、それの光に照らされて、幾個かの異国的の食器の類が、各自の持っている色と形とを、いよいよ美しく見せて居るのが、いちじるしい特色ということが出来る。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いつたやうな風で、互ひに即くまい即くまいと努めながら、それでゐて、要所要所は一糸乱れず呼吸が合つてゐたので、秀吉は期待した以上の面白い能を見ることができて満足したといふのである。",
              "citation": {
                "source": "演出",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間としての本質の要所要所で厳格でありたい。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより牛乳は樋を伝いて要所要所を通り、あるいは掻き乱され、あるいは試験され、各種の手数を経て、バターとなり、チースとなり、クリームとなり、あるいは日常配達の牛乳となる。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあいま一息だとばかり、係官はじめ帆村探偵も、昼夜を分かたず、蠅男の逃げ去った跡を追い、要所要所を隈なく探していったのであるが、蠅男の隠れ様がうまいのか、それとも係官たちの探し様が拙いためか、尋ねる蠅男の行方について、何の手懸りも発見されなかったのであった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはそう決心すると、船内の要所要所に電話をかけて、もしや怪しき生物が現われなかったかを問い合わせた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、要所要所に電話をかけて、入口をかたくとじるように注意をあたえた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所要所の扉をあける鍵もちゃんと持っていた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幸運というのは、ちょうどこのとき山塞の中は、机博士事件でごったがえしていて、要所要所の見張りはおろそかになっていたのだ。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
