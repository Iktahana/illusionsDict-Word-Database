        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし宜しかったら、思い浮ぶだけのことをすっかり手帳に書いて、読んでお聞かせしようじゃありませんか」　友人たちは初め承知しなかったが、結局ヴラジーミル・ペトローヴィチは自説を押し通した。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宜しかったら、別館の方はいかがでしょうか。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宜しかったら、こんど御案内しましょう。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、眼障りということもありませんでしたが、無くなってみると、へんなもので……もしお宜しかったら、わたくしの方で新たに作ろうかとも思っておりますが、如何でしょうかしら。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしでお宜しかったら、明後日から参ることに致します。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうことになっておりますので……もしお宜しかったら、また夕方にいらして頂けませんでございましょうか。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもお宜しかったら一度いらして下さいな。",
              "citation": {
                "source": "運命のままに",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "屹度ですわね……そして向うの家もよく存じないものですからついでに、お宜しかったら、失礼をお願い出来ますれば……。",
              "citation": {
                "source": "微笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御武家様、そこではお危うございます、宜しかったら――本当に宜しかったら、こちらへお出でなさいませ」　声は紛れもない足の下、真っ黒な水の中から起るではありませんか。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "乞食志願",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜しかったらいつでもお連れいたします」　もちろん私は亡霊か亡霊でないかそんなことなぞを聞きたいと思っていたわけでは毛頭もなかった。",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからそこで働いているのは、みんな老女の心やすい者ばかりなので、そんな所でも宜しかったら、内證で見せて上げましょうと云うのであった。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未熟者の拙者、迚も人にお教え申すことなどは、出来ませぬが、折角の思召しを辞するは却って失礼、宜しかったら型だけにても」「御承知下さるか、それは忝のうござる、――では追って日取などを決めたうえ」　と源左衛門は悦ばしげに云ったが、ふと奥の方を見やって、「御家内には御｜病臥でござるか」　と訊いた。",
              "citation": {
                "source": "おもかげ抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話をすると「宜しかったら私が伐りましょう」こう云って、伊助はすぐ城下まで斧を買いにいった。",
              "citation": {
                "source": "柘榴",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめにお値段を決めておいてよろしかったらお研ぎいたしましょう。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのみます」「主人もおりませんし、こんな式台でよろしかったら、どうぞ」　と私は言い、破れた座蒲団を二枚、式台に持って行ってあげました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何……」「ではねえ、ママのところへ行って、およろしかったら、応接間へいらしってと、申し上げて来てくれない……」と、祥子にいってから、兄に、「ねえ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、僕はまだ、君が、星田代二の素性をどうして看破したか、そのいきさつを聞いていないんだけれど、よろしかったらどうか――」　内心の侮辱を忍びつつ、これも、所謂『教養階級』の虚飾的な外交辞令であった。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はやがて自分のハンケチを手欄の上においたまま、「わたしの部屋へもよろしかったらいらっしゃいまし。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「容体がよろしかったら、今晩中に帰って参りますわ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何でございます、もし、およろしかったら、付き合って下さいませんか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "およろしかったら手前のところにどうぞ――」「………？",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "およろしかったら手前のところでお宿を致しまするでござります」　言うのを黙然として退屈男はじッと見守りました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "およろしかったら、わちきに酌なとさせておくんなまし……」「わはは、そうか、そうか、団十郎め、心憎い趣向をやりおった。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、それから、お気に召さないかもしれませんけれど、よろしかったら、オーデコロンもあります」　手のひらに収まる小さなビンを、ピリオドのようにのせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女に深くお辞儀すると、女主人は大したおもてなしもできませんでしたが、こんなつまらないところでよろしかったら、またお出かけ下さいませと言った。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "三畳から婆さんが、「いかがです御汁、よろしかったらおかえいたしましょう」と声をかけてよこした。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "およろしかったら持って来させますが。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうですね、あなたさえよろしかったら……。",
              "citation": {
                "source": "死の前後",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、今じゃあメチャクチャです」「よろしかったら私の宿へ来て、いかがです茶でも召しあがったら」　とうとう私はこんなことを、その青年にすすめて了いました。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お二人さんさえよろしかったら」「おい新助エー、どうしたもんだ」「改めて兄弟になるばかりよ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
