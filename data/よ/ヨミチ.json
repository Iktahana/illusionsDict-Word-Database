    "definitions": [
      {
        "index": 1,
        "gloss": "street at night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は、連れ出した男を此の世に於ける唯一の寄すがり者のやうに思へる心に浮々した足取で、そのフェルトをペタペタ夜道に打つつけながら、解雇された仲間で一番給料も多かつた男の下宿の方に歩んだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の血縁の一人は夜道で誤つて衝き當つた人と斬り合つて相手を殺し自分は切腹した。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "知恩院の前の暗い夜道をひとり帰りながら色々なことを考えた。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "田端の暗い夜道を歸つてくるとき、急に友が親しげの言葉で話しかけた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ども安の奴等もまさか此処まで追ッ掛けちゃ来めえ」　「併しお貸元、夜道は危のう御座います。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "織次は夜道をただ、夢中で本の香を嗅いで歩行いた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大きな声で言って、「お前たちには、信仰が無いから、こんな夜道にも難儀するのだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕には、信仰があるから、夜道もなお白昼の如しだね。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の血縁の一人は夜道で誤って突き当たった人と切り合って相手を殺し自分は切腹した。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い夜道を急ぎ足で歩きながら園は地面を見つめてしきりに右手を力強く振りおろした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、いかんよ、そんなにからまりついちゃ」　そんなことを言って柿江はとうとう子供たちから離れて夜道を西へ向いて急いだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……電車も無し……巡査に咎められたりなんかして、こんな時はつけが悪い、山の手の夜道だもの、無理をすると追剥が出ますよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」樹立の暗くなった時、一度｜下して、二人して、二人が夜道の用意をした、どんつくの半纏を駕籠の屋根につけたのを、敷かせて、一枚。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずほっとして歩きながら、更に考え直すと、女は何者か知れないが、暗い夜道のひとり歩きがさびしいので、恐らく私のあとに附いて来たのであろう。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "※今宵も逢おうと、闇の夜道を唯ひとり。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは夜道をかけて、今頃どうしてこんな所へお出でなすったのだね。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃあ夜道も安心だ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら月夜でも、これから夜道を追い返すわけにも行くめえ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も怖い物は出やあしめえと思うけれど、なにしろ山の中の夜道は不用心で、足を一つ踏みはずしても大変だ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説がすんで、聴衆は雪の夜道を三々五々かたまって家路に就き、クソミソに今夜の演説会の悪口を言っているのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夜道を歩いて、ひどく悲しくなり、小さい声で、　わたしゃ　売られて行くわいな　というお軽の唄をうたった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斷橋　夜道を走る汽車まで、一つの赤い燈火を示せよ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがかなしみ　夜道を歩いていると、草むらの中で、かさと音がする。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と余談的に云うと、女は急に頭を上げて勇気に充ちた面持で、小声ではあるが、「イエ、其事でございまするなら、一旦其男を出して帰らせました後、直に身づくろい致しまして、低下駄の無提灯、幸いの雪の夜道にポッツリと遠く黒く見えまする男のあとを、悟られぬようつけてまいりました。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此處から四十｜里餘り隔たつた、おなじ雪深い國に生れたので、恁うした夜道を、十｜町や十五｜町歩行くのは何でもないと思つたのであります。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、足のないやうな気持で、夜道を、まつすぐに歩いた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三町も歩くと、和太郎さんは「夜道はこうも遠いものか」と考えはじめるのです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすれば、もう夜道がどんなに遠くても、和太郎さんにはかまわないわけです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御状の景樹二十歳位とあるは必ず誤と存じ候事にて、三十年前は何か手紙の御よみちがへには無之やと存候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "○わすれて行った本　届ける　つい　そこだって○なべやきうどんを云いつけにゆく○待っている　約束のハガキのよみちがい○お菓子のこと「あら　それをみんなたべちゃっちゃ駄目よ」○気持よさそうなので　そうすると　ローソクの灯が　急にぱっと明るくなったように　くつろいで楽に居心地よくなった。",
              "citation": {
                "source": "無題（十三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
