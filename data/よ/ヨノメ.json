    "definitions": [
      {
        "index": 1,
        "gloss": "eyes of the night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五分と休む間もない位で、夜の目も合わさないで尽力したです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むむ、味方のためには眼も耳も吝んで、問わず、聞かず、敵のためには粉骨砕身をして、夜の目も合わさない、呼吸もつかないで働いた、それが事実であるか！",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「断めのつくように、断めさして下さいッて、お願い申した、あの、お返事を、夜の目も寝ないで待ッてますと、前刻下すったのが、あれ……ね。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに最早、年頃のことじゃけに、早よう何処かへ嫁に遣って一刻も早くお嬢様の足を洗わせねば、わたしゃ心配で心配で夜の目も寝られませぬという、乳母のお島どんの涙ながらの物語……」「う――むむ」　松倉十内は腕を組んで今一度太い、深い溜息を吐いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斷めのつくやうに、斷めさして下さいツて、お願ひ申した、あの、お返事を、夜の目も寢ないで待ツてますと、前刻下すつたのが、あれ……ね。",
              "citation": {
                "source": "三尺角拾遺",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り三太夫は御家の滅亡近きにあらんと、夜の目も合わず心痛なし、追放案を提出して、しばしば綾子に迫るといえども、ちと仔細ありてと、おおするのみ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事に就きましては、私は夜の目も合わないほど心を苦めまして。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "照吉さんも家業があるでしょう、だもんですから、ちょいとの隙も、夜の目も寝ないで、附っ切りに看病して、それでもちっとも快くならずに、段々｜塩梅が悪くなって、花が散る頃だったわ、お医者様もね、もうね。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、麻畑と謂ってやりゃ、即座に捕まえられて、吾も、はあ、夜の目も合わさねえで、お前様を見張るにも及ばずかい、御褒美も貰えるだ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分と休む間もない位で、夜の目も合はさないで尽力したです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むむ、味方のためには眼も耳も吝むで、問はず、聞かず、敵のためには粉骨碎身をして、夜の目も合はさない、呼吸もつかないで働いた、それが事実であるか！",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銚子に近い四日市場と云う処に貧しい漁師があって、鮭の期節になると、女房を対手にして夜の目も寝ずに鮭を獲っていた。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえ達が一年や半年、夜の目も寝ずに稼いだって、女郎なんぞを請け出して来るほどの金はできねえ筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを造り上げた上でどうして神様の御手に届けよう、というような事はもとより考えもせずに、早く造り上げてお喜ばせ申そうとのみあせって、しまいには夜の目もろくろく合わさなくなった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、夜の目にも紛れなく青年と母の瑠璃子とであったからである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、そこまでは、這うように、身体を沈ませながら辿ったが、其処に茂っている、夜の目には何とも付かない若い樹木の疎林へまで、辿り付くと、もう最後の辛抱をし尽したように、疎林の中を縫うように、母達のいる位置を、遠廻りしながら、ホテルの建物の方へと足を早めた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云う風に、幾晩となく母が気を揉んで、夜の目も寝ずに心配していた父は、とくの昔に浪士のために殺されていたのである。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の目も眠らず予の身を思うておるのに、呑気らしゅう不義の戯れに遊びほうけておるとは何のことか！",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、わるいこととは知りながら、秘伝書をたよりに夜の目も眠らず、つぼいじりを覚えこみ、これならと思って夜具ふとんまでも売ってこしらえたお鳥目を元手にやって参りましたところ、もともとがしろうとの悲しさ、かえってお絹さんたちのいんちきにかかりまして、だんだんと借金がかさむうちに――」「お黙り！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女を今のままにしておいては将来、家庭をお作りになって、満足な御生涯をお送りになる可能性が些ない事になると仰言って、御両親が夜の目も寝ずに心配してお出でになるのですよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その矢先へ今度のことがきこえたら、どのやうな大事が出來しようかと、それが案じられて此頃は、夜の目も碌に合はぬくらゐ……。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾衣　　心配で夜の目も碌にあはぬくらゐと……。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、夜の目にも紛れなく青年と母の瑠璃子とであつたからである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、そこまでは、這ふやうに、身体を沈ませながら辿つたが、其処に茂つてゐる、夜の目には何とも付かない若い樹木の疎林へまで、辿り付くと、もう最後の辛抱をし尽したやうに、疎林の中を縫ふやうに、母達のゐる位置を、遠廻りしながら、ホテルの建物の方へと足を早めた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生さえ然うだったから、況や試験となると、宛然の狂人になって、手拭を捻って向鉢巻ばかりでは間怠ッこい、氷嚢を頭へ載けて、其上から頬冠りをして、夜の目も眠ずに、例の鵜呑をやる。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大阪市長の池上四郎氏は、先日中から夜の目も寝ずに考へ込んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の目も合わさず衆が立ち働いているところへ心も体も酒に爛れたような父親が、嶮しい目を赤くして夕方帰って来ると、自分で下物を拵えながら、炉端で二人がまた迎え酒を飲みはじめる。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことを言や、病院で長いあいだ、夜の目も合わさずに看護したものはどうするでしょう。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く私たちの夜の目もろくろく眠らずにした労力は何の役にも立たなくなったのだ。",
              "citation": {
                "source": "機械",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくじやうぎんぎよのめよりをんなのへそをめがけてふきいづるふんすゐひとこそしらねてんにしてひかるはなさきぎんぎよのめあかきこつぷををどらしめ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
