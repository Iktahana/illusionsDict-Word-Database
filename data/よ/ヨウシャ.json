[
  {
    "uuid": "8f60488e-6153-5ff3-8d5a-62d1b2c7efd3",
    "entry": "容赦",
    "reading": {
      "primary": "ようしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pardon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殊にも醜惡な魯鈍なものに對しては容赦が無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺や五葉松は、制裁もなければ、保護もなく、永えに静粛に、そして厳格に、造化の大法を、寸分容赦なく行ってゆくように、この自然の王国から、定まれる寿命を召されて、根こそぎに、谷の中にたわいなく倒れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、コレラは容赦をしなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと現象の世界に眼のあきかけた若いものの頭に公式などは一切容赦してやらねばいけない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者のうちでそれらの誤謬を発見された方は容赦なく示教を惜しまれないように願いたい。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等がこんな事をして割合に仲よく面白く遊んでいるうちに夏休みは容赦もなく経って行った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の下げっぷりが悪い、生意気な者には、容赦のないリンチが行われた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひらにひらにご容赦と。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の頭へ半身を乗出して、（茫然してると、木精が攫うぜ、昼間だって容赦はねえよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの中は一廻も太ったように思われて痒さが耐らなかったが、しまいにはげっそり痩せたと感じられてずきずき痛んでならぬ、その上を容赦なく歩行く内にも入交りに襲いおった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり凝りすぎてもからだにさわるから午前だけにしたいと思ったが、午前中に一段片付けたつもりで昼飯を食いながらながめていると間違った所が目について気になりだす、もう一筆と思ううちにとうとう午後の時間が容赦なくたってしまう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと聞きたいと思うところで容赦なく歌は終わってしまう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容赦なく酷刑に処すべきである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りにこの両三日のうちにはキット下手人を探り出いてお眼にかけまする私の所存……何卒……何卒御容赦を……」　松倉十内は、何か思い直したように切柄をかけた白鞘の脇差から手を離した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って画面には写っていない人間や発音体の音が容赦なく侵入してくる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの無容赦な自己批判、その批判の奧から痛々しく沁み出て來る如何することも出來ない運命の桎梏と複雑な人間性。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾度かできるだけ冷静になって自分の気持を考えてもみ、容赦なく解剖してもみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪がこの邊に住んでゐた百姓の一人息子を容赦なく避難の小舟から奪ひ去つたのだ。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の間に於ける親子の關係に於ても、學校に於ける師弟の關係に於ても、社會生活に於ける成員としての關係に於ても、この僻見は容赦なく採用された。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの萬有を情け容赦なく鞭ち／＼つた恐ろしくも小氣味いゝ暴王は老い盡す。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開け放たれた戸口から悔恨は、風と一緒に容赦なく吹込んでゐた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともに、な、国手、お前んの生命を掻払いさえすりゃ、お孝との捩が戻って、早い話が旧々通り言うことを肯いて、女が自由になる見込さえあればですだ、それこそ、お前んが国手でも、神でも、仏でも、容赦する気は微塵も無いだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八「※、わはは、はは、」多磨太は容赦なくそのいわゆる小羊を引立てた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時も裏町の人数八九名に取占められて路地内へ遁げ込むのを、容赦なく追詰めると、滝は廂を足場にある長屋の屋根へ這上って、瓦を捲くって投出した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見得も外聞も無しに恐れ入り、「平に御容赦てッたような訳なんです。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞもうほんの村民の志だけをお汲み下されまして至らぬところ又すぎました処は平にご容赦をねがひます。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪はぐるぐる巻にして油つ気もないので後れ毛は容赦なく、骨ばつた頬のまはりに乱れて居た。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも馬子は容赦もなく責めつけて居る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挺の鉛筆削でも容赦なく留置された。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがた見えずなりたる、美人の小腕を邪慳に掴みて、身を脱れんと悶えあせるを容赦なく引出しぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
