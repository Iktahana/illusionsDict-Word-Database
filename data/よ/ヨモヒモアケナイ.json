    "definitions": [
      {
        "index": 1,
        "gloss": "cannot live even a minute without someone or something",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
