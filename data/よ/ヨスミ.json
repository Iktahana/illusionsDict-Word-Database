    "definitions": [
      {
        "index": 1,
        "gloss": "four corners",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煤けし壁の四隅は光届きかねつ心ありて見れば、人あるに似たり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅の柱をめぐって広い縁側のようなものがある。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッテルの四隅には「提倡国貨」（国産品を用いましょう）とれい／＼しく書いてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い大理石の欄干の四隅には大きな花鉢が乗っかって、それに菓物やら花がいっぱい盛り上げてあった。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも、かれ、蚊帳吊るため部屋の四隅に打ちこまれてある三寸くぎ抜かばやと、もともと四尺八寸の小女、高所の釘と背のびしながらの悪戦苦闘、ちらと拝見したこともございました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタがたみたいな立派な若い人が十何人も、お国のためとはいいながら、今から半年も経たないうちに粉ミジンになってこの地上から消えてしまうなんて……あたしシンから惜しい気がするわ」　新張家の豪華を極めた応接室の中央と四隅のシャンデリアには、数知れない切子球に屈折された、蒼白な電光が煌々と輝き満ちている。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と薄気味悪げに後を見返り、「部室の外が直ぐ森なので、風通しは宜うございますが、こんな時には、ちとどうも、と座敷の四隅に目を配りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の桟も見えずなり、天井は墨のごとく四隅は暗く物凄く、人の顔のみようよう仄めき、逢魔が時とぞなりにける。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この柱が、須弥壇の四隅にある、まことに天上の柱である。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方から逆寄せして、別宅のその産屋へ、守刀を真先に露払いで乗込めさ、と古袴の股立ちを取って、突立上りますのに勢づいて、お産婦を褥のまま、四隅と両方、六人の手で密と舁いて、釣台へ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立騒ぐのに連れて、むくむくむくむく、と畳を、貴僧、四隅から持上げますが、二隅ずつ、どん、どん、順に十畳敷を一時に十ウ、下から握拳を突出すようです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おい、おい、座蒲団の糸を切らないでくれよ」　自分は話をしながら、自分の敷いている座蒲団の綴糸というのか、くくり紐というのか、あの総のような四隅の糸の一つを無意識に指先でもてあそび、ぐいと引っぱったりなどしていたのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋詰の、あの大樹の柳の枝のすらすらと浅翠した下を通ると、樹の根に一枚、緋の毛氈を敷いて、四隅を美しい河原の石で圧えてあった。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、間の四隅を籠めて、真中処に、のッしりと大胡坐でいたが、足を向うざまに突き出すと、膳はひしゃげたように音もなく覆った。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たそがれ、部屋の四隅のくらがりに何やら蠢めき人の心も、死にたくなるころ、ぱっと灯がついて、もの皆がいきいきと、背戸の小川に放たれた金魚の如く、よみがえるから不思議です。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上には一葉の、謙三郎の写真を祭り、あたりの襖を閉切りたれば、さらでも秋の暮なるに、一室｜森とほのあかるく四隅はようよう暗くなりて、ものの音さえ聞えざるに、火鉢に懸けたる鉄瓶の湯気のみ薄く立のぼりて、湯の沸る音｜静なり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅に置いたストーヴの暖かさで三十数名の男の社員達は一様に上衣を脱いで、シャツの袖口をまくり上げ、年内の書類及び帳簿調べに忙がしかった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは十畳吊の萌黄地の近江麻で、裾は浅黄｜縮緬、四隅の大房から吊手の輪乳に至るまで、凝ったものであったから主翁は気にいった。",
              "citation": {
                "source": "沼田の蚊帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑いろの革で四角に出来てゐて、縁と蝶番の処とは勿論、四隅に附いてゐる鱗形の装飾も、表の真中に附いてゐる名の頭字の A の字も、皆銀である。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから盤に花を盛つたのを卓の四隅に置く。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいまその鉄の四隅のなかの二つが鋭角をなしているのを――したがって当然ほかの二つは鈍角をなしているのを認めた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「盜んだつち譯ぢやねえが、蓋とつて見た處なんだよ」さういつて婆さん等は風呂敷の四隅を掴んで圍爐裏の側へ持つて來た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に番組は鉢の木が濟むと板の間の四隅には荒繩を引つ張つてランプが吊された。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅に吊つたランプの光が烏帽子に輝き衣裝に輝いて美しい。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明来ると共に暗黒の悪者どもは忽ち姿を消す、そのさまあたかも絨毯の四隅を取らえてこれより塵を払い退けるが如くであるというのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『聖書』にヨハネが千年後天魔獄を破り出て、世界四隅の民を惑わすと言ったを誤解して、紀元一千年が近くなった時全欧の民大騒ぎせし事、明治十四年頃世界の終焉が迫り来たとて、わが邦までも子婦を取り戻したり、身代を飲み尽くした者あったに異ならず。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく四觀、四隅にあれば、殘る隈なく灣内を眺望するを得べし。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅が焦げたカードやルーズリーフや書類が堆かく一山になっていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗吉さんは釣手を茶の間へも附けるために、四隅へ釘を打つて下さる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
