[
  {
    "uuid": "959a8a40-4cc2-5ca4-b324-14b815a192f6",
    "entry": "拗音",
    "reading": {
      "primary": "ようおん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
