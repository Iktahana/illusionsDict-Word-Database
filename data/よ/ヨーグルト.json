        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シャボン水は凍ってヨーグルト見たいになるし、ブラシが凍るし、全く、始末に行かなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじん――うん、だけど、その前に、お隣りへ行って、パンを一片ずつと、それへヨーグルトを少し貰ってきたら？",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はレッスン９です」……空チャンネル……小さな男の子がヨーグルトを一口食べ、画面に向かってにっこり笑う……空チャンネル……。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時半に起きてしまひ、フライエッグ、ヨーグルト、抹茶二。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食は抜いて、ヨーグルト、抹茶二。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は、カステラ、ヨーグルト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、ヨーグルト、カステラ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は、ヨーグルト、抹茶二のみにして、十時から中芸の顔合せ、タクシー、十時頃出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
