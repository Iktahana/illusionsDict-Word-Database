[
  {
    "uuid": "eb98cb8d-00dc-59eb-9350-0ec4bd414bb8",
    "entry": "翌年",
    "reading": {
      "primary": "よくねん",
      "alternatives": [
        "よくとし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
