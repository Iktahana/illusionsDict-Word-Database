        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "following year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　翌年の春になつて暖かくなると、忠魂塔の下に遊びに行つたものださうだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その翌年は正月がたいそう暖かくて廻礼廃止理由の成立が少々怪しくなったようであった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七九年から翌年へかけては小作人がだんだん土地を返上して来たので、地主は自作するより外途がなくなった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集の終りの第六巻は彼の死んだ翌年に出た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年の春になつて、雪の深い北國の金澤から、君は土筆のやうに旅に出て來た。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　翌年の春（その春はもの悲しく、冷えびえと來た）、ピロヴァノ男爵の軍使がしづかにランゲナウに入つていつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は其處にもつと長く滯在して當時彼の心を捉へてゐた仕事（Duineser Elegien）をしたかつたであらうが、この地方の氣候のはげしい變化のために彼の健康はすつかり害せられ、翌年三月には空しく西班牙を立ち去らなければならなかつた。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "後出の妻クララ及びロダンに宛てられた二つの手紙は、前述のトゥリエ街の寓居で書かれたものだが、最初のルウ・アンドレアス・サロメに宛てて書かれた手紙は、その翌年羅馬から獨逸のヴォルプスヴェデに歸つてから當時を追想して書かれたものである。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は翌年の三月頃の初産を兩親のゐる私の家で濟ますために暫く上京するのであつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年は五十｜點になつた。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年は百｜點になつた。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれこれするうちに翌年の春になり、六蔵の身の上に不慮の災難が起こりました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中　佐伯の子弟が語学の師を桂港の波止場に送りし年も暮れて翌年一月の末、ある日源叔父は所用ありて昼前より城下に出でたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が亡くなった翌年の夏、郷里の家を畳んで母と長女を連れ、陸路｜琴平高松を経て岡山で一泊したその晩も暑かった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年、「海豹」といふ同人雜誌に三囘にわけて連載した。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年度の、改造新年號に發表した。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田の帰って来た翌年吉田の父はその家で死んで、しばらくして吉田の弟も兵隊に行っていたのから帰って来ていよいよ落ち着いて商売をやっていくことになり嫁をもらった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ皆朝顔のおかげといたく愛して翌年の夏に至りけるに、去年の花より多くの種残りて、さりとは数多生ひ出で、蔓の頃はさぞかしと思ひやらる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し世の中が変ろうというところへ生れあわせたので、生れた翌年は上野の戦争がある、危い中を母に負われて浅草の所有地へ立退いたというような騒ぎだったそうです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父様はその翌年お歿くなりになられ、今では私の家の客間の壁の大きな御写真のなかに、おはいりになって居られるのでございますが、私はこの御写真を見るたびごとに、あの晩のお相撲のことを必ず思い出すのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは私が弘前の高等学校にはいって、その翌年の二月のはじめ頃だったのではなかったかしら、とにかく冬の、しかも大寒の頃の筈である。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその翌年に女学校を卒業して、つまり、今は、その叔父さんの悪魔のような予言を、死ぬほど強く憎んでいながら、或いはそうかも知れぬと心の隅で、こっそり肯定しているところもあるのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もその翌年に、いまの主人を迎えました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは、この煙突が出来てから、一と冬越した翌年の春になっても、煙を吐いた形跡がなかったからであった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年、三十一年にめでたく学校を卒業し、電気部の技手として横浜の会社に給料十二円で雇われた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜翌年になり權官は或罪を以て職を剥れて了い、尋で死亡したので、僕が竊かに石を偸み出して賣りに出たのが恰も八月二日の朝であつた。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年は友人のＫと甥のＲと三人で同じ種崎のＴという未亡人の家の離れの二階を借りて一と夏を過ごした。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のそばでよくねんねしている鶏のひよこを食べようかと思いました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
