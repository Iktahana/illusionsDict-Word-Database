    "definitions": [
      {
        "index": 1,
        "gloss": "dropping in on the way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京から藤澤へ行く途中、自動車で寄り道をしたのださうである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京を立つてから山形、船川港、弘前、青森、津輕海峽を越えて室蘭と寄り道しながら、眼差す苫小牧へと着いたのが七八日頃、それから九月へかけてのまる一ヶ月ほどを妹夫婦の家に暮した。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寄り道をしちゃだめよ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寄り道しません。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をすっかり頭巾で包んで、長い手綱で遠くの方から橇を操っている馬方は、寄り道をするようにしておせいを覗きこみに来た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが丘の中腹あたりにあるライヘンバッハの滝は、多少寄り道してでも必見であると念押しされていた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、振り返ってみればわざと目をそらしていたのではないかと思いたくなるほど、私は寄り道を繰り返しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かならず間違い無しにとどけてくれ、あと金は引きかえに遣わすぞ」　しかし自分はこれから他へ寄り道をして帰るから、日が暮れてから持参してくれといった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから身支度をして愛宕下へ出かけて行ったが、その途中に少し寄り道をする用があるので、日蔭町の方へ廻ってゆくと、会津屋という刀屋の前に一人の若い武士が腰を掛けて、なにか番頭と掛け合っているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "「波田さん、菓子屋まで、まだ大分寄り道になるの」ボーイ長はフト菓子が食べたくなった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「早く帰れよ、えゝ、早く帰れよ、旅の帰りがけなどに寄り道をしてゐるなんといふことは好くないことだ。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢや僕一寸寄り道をしてゐたから大方行き違ひにでもなつたんでせう。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな月代野郎にけんつくをかまされて、すごすごと引き揚げるくれえなら、わざわざ寄り道するがまでのことはねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "このいずれにも寄り道せず、玄関から入ってまっすぐ進むと、生徒サロンにつきあたる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、わたしが最後だから、寄り道しないで、早く帰って寝なさい！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、彼は途中に寄り道があると云って、狭い横道へ切れてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しに来たのでしょう」「お熊は遠州屋に奉公していると云うから、まんざら縁のねえ事もねえが、なんでわざわざ寄り道をしやあがったかな」「今の話を聞くと、常陸屋の奴らがここへ詮議に来たと云うじゃあありませんか」と、善八は考えながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよつと寄り道をしたものですから。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寄り道つて、どちらへですか。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弘ちゃんは遅いのねえ、きっとまたどこかへ寄り道をしてくるのよ。",
              "citation": {
                "source": "鼻に基く殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――少し寄り道をしてゐたものだから」と独り言の様に説明を加へた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと寄り道してもいいでしょう。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めっから寄り道するって云わなかったじゃないか。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車にのっかってる人間が寄ると云ったら、寄り道にきまってることが分らないの？",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすでに寄り道して来たのだ。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の汽車賃をもおれが使へば、丁度眞ツ直ぐに東京までおれは歸れた勘定だが??こんなところの病院などへ寄り道しないで、ね。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の汽車賃をもおれが使へば、丁度眞ツ直ぐに東京までおれは歸れた勘定だが――こんなところの病院などへ寄り道しないで、ね。",
              "citation": {
                "source": "――泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "四条河原町の賑わいにも、タケシは寄り道する気にはなれなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋葉原通いの寄り道先が予備校から大学に変わったのを機会に、松本はかねてから胸にためてきたライターへの挑戦を実行に移そうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「賛成するもしないも、お父様の御機嫌をなおして頂くにはそれよりみちがないでしょう」　姉は云いきかせるような口振りになった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
