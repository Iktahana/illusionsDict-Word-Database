[
  {
    "uuid": "6f608536-03b3-51d3-a268-16bc284a2e46",
    "entry": "予期",
    "reading": {
      "primary": "よき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
