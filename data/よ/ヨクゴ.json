        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌麿も『婦女相学十躰』の一つとして浴後の女を描くことを忘れなかった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日汗水たらして働いた後にのみ浴後の涼味の真諦が味わわれ、義理人情で苦しんだ人にのみ自由の涼風が訪れるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方浴後の涼風を求めて神田の街路をそぞろ歩きするたびにはこの「初恋」の少女の姿を物色する五十四歳の自分を発見して微笑する。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きみの前だが、その時タオルも棄てたから一糸も掛けない、浴後の立姿だ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店モナミは、階下の普請を仕変えたばかりで、電灯の色も浴後の肌のように爽やかだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二　浴後の顔色｜冴々しく、どこに貧乏の苦があるかという容態にて男は帰り来る。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱や、寒冷や、雨雪や、飮酒や、日光直射や、異常の食物や、甚だしき飢や飽や、浴後の薄衣や、皮膚の不潔や、すべて病因たることは、盡く自己の判斷と、他の批判と、即ち一個的及び相互的の注意によつて、之を避けねばならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の精神の爽快なるを致す原因は種々あるが、其の主なる原因は血行の増進する爲に氣の暢和を致すのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて眼の前に浴後の新月のような鮮かな世界が展じ出て来る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは左手に持ち換た手ランプを翳して單衣を弄つては浴後のつやゝかな顏に微笑を含んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱・寒冷・雨雪・飲酒・日光の直射・異常な食物・甚だしい飢え・飽食や浴後の薄着・皮膚の不潔等がすべて病因となることは、尽く自分の判断と他の批判と、即ち一個的および相互的の注意によって之を避けなければならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の精神が爽快になる原因は種々あるが、その主な原因は血行が増進する為に、気が伸び伸びとするのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浴女』『浴後』が彼女を画壇上に浮彫りにしたといふことは事実である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浴女』や『浴後』は一言でいへば一般観衆にとつて取つ付き易い絵なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の『浴後』に於いては、前の『浴女』と全くちがつた作画態度をみせてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浴後』は『浴女』との連作であらうといつた簡単な批評で押しつけようとしたのであるが連作故に批評を避けることはあるまい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少くとも温泉気分の嫌ひな批評家があると仮定すれば、『浴後』の方の人物達は、着物をもう着てしまつてゐるし、作者である遊亀氏自身その作品で、湯船の上気を拭ひ去つた、冷静さで描いてゐるために、むしろ『浴後』の方に多くの問題を保留してゐると言ふ意味合から、『浴後』により好感をもつであらうと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浴後』のタイル張りの正確な図式的な配列、それによつて、曾つて『浴女』の湯の中の揺曳で効果をあげたと等しい効果を、そつと誰にも知らさぬやうに効果づけてゐる手腕は末怖ろしいものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫し浴後を涼みゐる貫一の側に、お静は習々と団扇の風を送りゐたりしが、縁柱に靠れて、物をも言はず労れたる彼の気色を左瞻右視て、「貴方、大変にお顔色がお悪いぢや御座いませんか」　貫一はこの言に力をも得たらんやうに、萎え頽れたる身を始て揺りつ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後、白粉淡く施したれば、別人の觀あり。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそさうして了ひませうか」かの女は浴後のおつくりをすませた顔を此方に見せて、のんきな調子でこんなことを言つて笑つた。",
              "citation": {
                "source": "山間の旅舎",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一浴後、飯の出る迄とて庭さきから續いた岡へ登つて行つた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一浴後直ちに床を延べて寢てしまつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一浴後、飯の出る迄とて庭さきから続いた岡へ登って行った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一浴後直ちに床を延べて寝てしまった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくご覧、使う道具は、みんな新しいものだよ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくごらん、紀元前二千二百年のことでないよ、紀元前二千二百年のころにみんなが考えていた地理と歴史というものが書いてある。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくごらん、紀元前二千二百年のことでないよ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪く言えば「要領よくごまかす」というはなはだ不祥なことが、よく言えば一つの交響楽の演奏をするということにもなりうる。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
