  {
    "uuid": "bd70e95e-e9c6-58c2-b460-81953461f140",
    "entry": "寄せ鍋",
    "reading": {
      "primary": "よせなべ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
