        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供の方が大人より上手である。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の春の桜は人の眉より上にみな咲きます。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うらア始めから、尋常を上ったら、もうそれより上へはやらん云うのに、お前が無理にやるせにこんなことになったんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより上に、彼等に魔の手が強く働いていることは、兵士達には分らなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○竹屋の渡場は牛の御前祠の下流一町ばかりのところより今戸に渡る渡場にして、吾妻橋より上流の渡船場中最もよく人の知れるところなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて神田川は上に述べし柳原橋下の一流に会するところより上○和泉橋下を経て、昌平橋、万世橋、御茶の水橋、水道橋、小石川橋を過ぎ、飯田橋手前にて西北より来り注ぐところの江戸川の一水を呑み、飯田橋上流牛込揚場に至つて尽く。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "流布本太平記巻三十六、細川｜相模守清氏叛逆の事を記した段に、「外法成就の志一上人鎌倉より上つて」云祇尼天に足利義詮を祈殺そうとの願状を奉ったのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あざむけ、あざむけ、巧みにあざむけ、神より上手にあざむけ、あざむけ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の降る形容だって、沢田先生のほうが、きっと私より上手なのでしょう。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝なお早ければ街はまだ往来少なく、朝餉の煙重く軒より軒へとたなびき、小川の末は狭霧立ちこめて紗絹のかなたより上り来る荷車の音はさびたる街に重々しき反響を起こせり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出発点から自分の力以上のものに頼むのですから、その取捌き方や始末は数倍あるいは数十百倍こちらより上だと思わねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校時代私より上級生を教えて居た高瀬由子は私の聡明な早熟な幼女の好みに一番適して居た。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐ばかりでない、快活なる武村兵曹も、其他の水兵等も、電光艇より上陸した一同は、悉く色蒼ざめ、頭を垂れて、何事をか深く考へて居る樣子。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子の中段に立ち止まって余は耳を澄ます事｜少時、ここより上に昇るべきか昇るまじきか、甲板上になお海賊おらば、余はただちに殺されん、されど甲板上の光景を見ぬうちはどうも安心できず、余はついに意を決し、殺さるる覚悟にてふたたび昇り始めぬ。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより肌襦袢、その上に襦袢を着るもの、胴より上が襦袢にて腰から下が蹴出しになる、上下合はせて長襦袢なり、これに半襟の飾を着く、さて其上に下着を着て胴着を着て合着を着て一番上が謂はずとも知れ切つて居る上着なり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年（辛未）　一八七一○一月、中村翫雀大阪より上京し、守田座における御目見得狂言の三浦之助、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○片岡我童、片岡我当の兄弟、大阪より上京して、中村座の三月興行より出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一月、中村雀右衛門、芝雀の父子、大阪より上京して、春木座に出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより上には見えません。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子は、まだほんの小さな子で、六つより上には見えませんでした。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の子供――といつて、花市君より上級の者ばかりだが――は全部、さういふことをするのである。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、生れながらに自分等のコースより上空を軽々と行く女だ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これより上へ短くは摘み取るまいよ。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿四日、己亥、晴、京都の使者参著す、去る十日より上皇御瘧病、毎日発らしめ給ふ、内外の御祈祷更に其験見えずと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神崎は滑川より下、佐原より上の利根川沿岸の地だ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケイズ釣りというのはそういうのと違いまして、その時分、江戸の前の魚はずっと大川へ奥深く入りましたものでありまして、永代橋新大橋より上流の方でも釣ったものです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "竿尻より上の一尺ばかりのところを持つと、竿は水の上に全身を凛とあらわして、あたかも名刀の鞘を払ったように美しい姿を見せた。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それよりうえ負けちゃいかんぞ、まあ、考えてもみろ、八千ルーブルと一万一千ルーブル――三千ルーブルの開きじゃないか、この三千ルーブルは全く目つけものなんだよ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
