    "definitions": [
      {
        "index": 1,
        "gloss": "if it is good",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでこの人、暇具合さえ良ければ釣に出ておりました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "良ければ、食後に馬車で行こうか。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「自分さへ良ければ他は蹂躪つても構はない」と云ふ考へは、他の其思想と衝突する。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もッきり」　収穫が終ると、百姓の金を当にして、天気さえ良ければ、毎日のように色々な商人が廻ってくる。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしオモロが如何に解し難い韻文だといっても、もともと自分らの祖先が遺した文学であって見れば、研究法さえ良ければ、解せないこともないと思って、根気よく研究を続けた。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が死んでからまだ役に立つかどうかと考えたが、彼女の気持が良ければ良いだけ、安次を世話した自分の徳が、死んだ良人の「あの世の苦しさ」まで滅ぼすように思われてありがたくなって来た。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵜の真似でも何でも、試験の成績さえ良ければ、先生方も満足せられる、内でも親達が満足するから、私は其で好い事と思っていた。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものというものは、心得さえ良ければ良いようになるものだよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日東野氏の家へ行くついでがあるので良ければ矢代にも来て貰いたいという意味であったが、用事はそれだけのことでも、千鶴子の母が前より一層彼にまた会いたいと云って困るとも書いてあって、そんなに急に変って来る婦人というものについても、ただ喜ぶばかりのことではすまされず、多少は眉の顰む不安も覚えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だから、あらゆる犯罪者はその頭が良ければいい程、この弱点を隠蔽して警戒しようと努力するのだが、その隠蔽の手段が又、十人が十人、百人が百人共通的に、最後の唯一絶対式の方法に帰着している。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし手術をして経過が良ければ助かるかもしれないが、この儘ではもう先が見えていると云われたのだ。",
              "citation": {
                "source": "雲の裂け目",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な縁で、したしくなったからは、わしが良ければそなたにもよし、そなたがよければ、わしもよいというようにやって行って貰いたい。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日天気が良ければ退室することとする。",
              "citation": {
                "source": "重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ換へれば、甲は、俳優が良ければ良いに越したことはないが、少しへたな役者でも、それほど致命的結果を見ずに済むのに反して、乙は、良い俳優が演つて、初めて効果を挙げることができるが、少しへたな役者にかかつたら、すつかりぶちこはされるといふ――さういふ違ひがあるのである。",
              "citation": {
                "source": "劇的伝統と劇的因襲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り雛鳥はまだ体質が雄は雄のように発達しておらんから去勢されても平気なもので施術の結果さえ良ければ後に弱ることがない。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかだと言うよりこの家も広いのですからあの子さえ良ければ、此方へ越して来たらどうでしょう。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分さへ良ければ、夕方からでも僕は出勤する心算なんだから。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "良ければなおいいし、悪くてもそれが現在良ければいい。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉の「こなし」方、それが良ければ彫刻は良くなってゆく。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上キリョウが良ければ越したことはないが、それは二の次だ」　不破喜兵衛はこう考えて、まだ清作が二十という若いときに、今の嫁をもたせた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう天気さえ良ければ絶対に失敗は有り得ないという確信はここではもはや確信ではなく常識となっていた。",
              "citation": {
                "source": "英国日食班の印象",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが湖水の表面に自然に張る氷は条件が良ければかなり大きい結晶に発達するもので、それらの結晶は皆六方晶系の主軸が水面に垂直になるように配列するものである。",
              "citation": {
                "source": "スポーツの科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "装置一号Ｃ　十時までに保存用結晶作成、十時スタート、十二時半結晶完成、一時電流切り無人放置、二時半検査、良ければその儘三時半まで装置内放置。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃな、俺あチョックラ出かけて来るからな、どうで夜になるだろうが、首尾が良ければ明日の朝までにゃ落窪へ行くからな。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此邊は古い江戸の地圖にも、『植木屋と百姓家多し』と書いてある位で、お天氣さへ良ければ、子供達は家の中で遊ぶといふことは無いのですが、雨が降ると、室内｜遊戲の方法も興味も持たない子供達は、一日に一度は屹度『隱れん坊』を始めるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱れん坊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルディングは五階で、大して高くはありませんが、天気さえ良ければ、富士も見られ品川の海も眺められます。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "代作恋文",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末なのでよければ田舎へ行けばあるだろうとおもっていたが、いよいよあたって見ると、都に近い田舎で電燈のない処は今時もうどこにもなかった。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斬られの仙太」を大河内が演りたがッとッたが、三好氏さえよければやッてみたい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり調子がよければ持｜點を一｜氣に突き切る事もたびたびで、自然勝が多いが、それが逆になると、どうにも當たりが惡くて、負が重なつて苛々しい、憂鬱な氣分で球突塲から歸つてくるやうな始末なのだ。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬ながら九州は暖国ゆえ、天気さえよければごく暖かで、空気は澄んでいるし、山登りにはかえって冬がよいのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
