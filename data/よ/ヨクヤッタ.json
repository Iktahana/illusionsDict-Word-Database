    "definitions": [
      {
        "index": 1,
        "gloss": "well done!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腰の弱い黐で、実際役には立たぬのであるが、よくやったものである。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おゝ、こゝに居るぞよくやったよくやった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶に便ぜんがため、自分は学校にいるうち抜き書きということをよくやった。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその九時半が来たので、私はかつてよくやったように、馬車の中に彼と隣り合って坐った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に、グレグソン、よくやった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様らにしてはよくやったもんだ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポールはよくやったわ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくやった、フランク分隊長！",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも行くとすぐ、前にも道場でよくやったように、棒の相手をさせられた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はよくやった――まさしくサムライの娘だ。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもそれだけの事を家の人に気づかれないでよくやったものねぇ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に鳥渡恩を着ている事もあるし、行方不明になっている例の女中も鳥渡知っていると云うような訳で、進んで浅田へ住込んだのだがね、危いと思っていた割合にはよくやったが、結局駄目だったよ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、最後に木戸が投げつけた謎語をめぐりながら、よくやった、最後まで気力を失わなかったのはやはり日本人だと、涙と奇靉をひろげる夢想世界のなかで、しばらく折竹は一言もいえなかった。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユートピア　いや、木戸はそれを見たのではないか※　と、最後に木戸が投げつけた謎語をめぐりながら、よくやった、最後まで気力を失わなかったのはやはり日本人だと、涙と奇靉をひろげる夢想世界のなかで、しばらく折竹は一言もいえなかった。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の子供の遊びでは、『ねッ木』といって、薪の先を削ったのを土に打込み、次の者がそれへ打当てて土にさし、前のを倒し、倒した木は分捕るという事が流行った、独楽もよくやったもので、前の独楽を、後の独楽で廻いを止める事をした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦車及び人員、異状なし、おわり」「おお、よくやった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまるで私が故郷の黒丘入江の岩のあたりでよくやったような遊び事であった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいちょい無駄あり、二重写しにするところ、夜のスケート場を、光線の遊戯で一寸よくやったのに雪の面のスケートの跡を見せたところなど。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ところが父よりの手紙で、彼も犬のようにみじめには死なず、大きく、円く、膝を叩いて笑った英男らしく、安楽椅子により、ティテーブルをおき、屏風まで立てまわして楽に居心地よくやったと云うには、自分笑った。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝った場合は「あれでよかったのか」といった様な驚きに似た気分であり、敗れた場合は寧ろ敵に対して「よくやったなあ」といった様なやはり不思議な様な驚きの気分である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、よくやった。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大竜よくやったと住田嘉久馬がいずれオレの手を押しいただいて礼を云うぜ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃はメッタに大虎にもならないが、昔はよくやった。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせんが師匠がかえってきて喜んで貰うべく報告にいけるほどの結構の寄席じゃなかったけれど、せめても師匠の留守のうち、このくらいのことはこっそりしておいて、よくやったお前といわれたかったのだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏ君はたいへんな勉強家で、よくやったのであるが、結局結果は非常に複雑なものになって、目ざす渦動はつかまらなかった。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、僕などその人によくやったと言いたいらしい。",
              "citation": {
                "source": "人生",
                "author": "竹内浩三",
                "note": "青空文庫"
              }
            },
            {
              "text": "為と寅を空地へ呼びだして、「……寅に為……よくやったな」　二人は、あっけに取られて、「よくやった……だしぬけに、なんです」　顎十郎は、へへら笑って、「駕籠がひっくり返ったはずみに、氷の箱が駕籠から飛びだして、土手下の草の中へころがりこんだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "氷献上",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の部下のライマンは北海道の地質を詳細に調査し、とくに石炭の調査をよくやった。",
              "citation": {
                "source": "『ケプロン・黒田の構想』について",
                "author": "――英文誌 This is Japan のための草稿――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
