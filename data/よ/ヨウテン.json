[
  {
    "uuid": "0d82e45c-3203-5636-a742-ba86f7b3191f",
    "entry": "要点",
    "reading": {
      "primary": "ようてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
