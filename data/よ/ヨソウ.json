[
  {
    "uuid": "ec015f53-dd0f-54cb-b6c2-9e78e9676297",
    "entry": "予想",
    "reading": {
      "primary": "よそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
