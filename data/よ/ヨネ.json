  {
    "uuid": "b6e1bd14-e4a4-5c1c-aba6-6f8dafbe2170",
    "entry": "米",
    "reading": {
      "primary": "よね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "88 years old",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "久留米絣を来てゐて、既に酔つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔洪積の台のはてなる〕宮沢賢治洪積の台のはてなる一ひらの赤き粘土地桐の群白くひかれど枝しげくたけ低ければ鍛冶町の米屋五助は今日も来て灰を与へぬ。",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事も米の飯に味噌汁、野菜の漬物や煮魚を食い、夜は二三合の日本酒を晩酌にたしなんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の日本は、文明開化の欧米心酔時代であったので、至るところ、彼はそうした不機嫌の目に逢わされた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日二三合の米の飯と、少しばかりの副食物と、二三合の日本酒とさえあれば、それで私の生活は充分であると、その訪問客に語っているヘルンは、実際に学者風の簡易生活をしていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が西洋臭くなり日本の文化や風俗やが、日々にますます欧米化して来ることは、ヘルンにとって忍びがたい悲哀であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が盆踊を禁ずるのも、国民が欧米人の真似をするのも、固有の日本文化が亡びるのも、すべて皆基督教の宣教師が宣伝するためであり、一切の悪は耶蘇教の罪に帰せられた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も、一切の係累を捨ててしまつて、遠く南米の天地に移住したいと語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子戦死の報を聞くや、つと立って台所に行き、しゃっしゃっと米をといだという母親のぶざまと共に、この男の悲しみの顛倒した表現をも、苦笑してゆるしてもらいたい。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川弥太郎、酒井米子、花井蘭子などの芝居であった。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フライイング犯した罰として、他の選手よりは一米うしろの地点から走らなければならない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレエスは百米競争では、なかったのだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千米、五千米、いやいや、もっとながい大マラソンであった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百米、二百米の短距離レエスでは、もう、この選手、全然見込みがない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十米レエスならば、まず今世紀、かれの記録を破るものはあるまい、とファン囁き、選手自身もひそかにそれを許していた、かの俊敏はやぶさの如き太宰治とやらいう若い作家の、これが再生の姿であろうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "交番へ行って応急米の手続きもして置いたのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教えてくれたのは、欧米の人たちであるが、今では、別段彼等から教えてもらう必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に生れて、米の飯を五十年も長く食っていたら、自然にそうなって来るのが本当なのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや日本に居住することなく、日本の文学を全く読まず、日本に就いて知る所の殆んどない一般の欧米人が、宮森氏の訳を通じて、芭蕉等の俳句が解り得る道理はない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の壇へ御洗米と塩とを純白な皿へ盛ったのが御焼物の鯛をはさんで正しく並べられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の字を星形にした徽章のついた制帽を冠って、紺のめくらじまの袴をはき脚絆に草鞋がけ、それに久留米絣の綿入羽織という出で立ちであったと思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍で若い女が米を磨いでいる。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富米野と云う男熊本にて見知りたるも来れり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りに坐りし静岡の商人二人しきりに関西の暴風を語り米相場を説けば向うに腰かけし文身の老人御殿場の料理屋の亭主と云えるが富士登山の景況を語る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "横山先生のところへ連れて行くと、先生は一目見ただけで、これはじきに直る、毎日上白米を何合ずつ焚いて喰わせろと云った。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この患者は生れてその日までまだ米の飯というものを喰ったことがなかったという話であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例を挙げると、庭へ一面に柿の葉を並べておいて、その上に焼酎に浸した米粒をのせておく。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃を見計らって箒で掃き集めると米俵に一俵くらいは容易に捕れるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）ダンシングホールへ行くことも禁じられるし、まるで女中代りよね、此の頃のあたしつたら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の座敷は殿方ばかりにて、ビール又は正宗の空壜を作るによねんなし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
