    "definitions": [
      {
        "index": 1,
        "gloss": "isn't that right?",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
