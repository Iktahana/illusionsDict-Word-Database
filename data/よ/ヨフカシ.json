    "definitions": [
      {
        "index": 1,
        "gloss": "staying up late",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仕事の多い日には、しばしば夜更かしをして書きつづける。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからこそ、皆が眠つてゐる田舍では、空にはありとあらゆる星がかがやき、そしてその反對に、都會の上には、星が少ししかない、何故なら都會では、澤山の人々が心配したり、泣いたり、讀書したり、笑つたり、夜更かしをしてゐるからだ、そして各々の眼を離さずにゐるからだ。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこのごろは、あまり夜更かしをすると、なおのこと腹がすくんで、少し控え気味にはしているがね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売している間は、夜更かしはする、酒は呑む、体を壊す一方だからね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "引けあとの電話は、大抵、明日の朝きいても間に合う事ばかりだからナ……しかし、あんまり夜更かしをすると身体に触るぞ」　これを聞いた時には流石の私も、どう返事をしていいか解らないまま固くなって叔父の顔を見た。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花屋」は夜中の二時過ぎまで店をあけていたので、夜更かしの好きな私には便利な店だった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう本当は退院されてもいい位に恢復しておられるのですから、一と晩ぐらい夜更かしをされても大丈夫ですよ……僕が請け合います……」「アハハハハ……イヤ。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃私は毎晩｜夜更かしをして二時三時まで仕事をするので十二時近くなると釜揚饂飩を取るのが例となっていた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜更かしをして朝寝をする習慣をもっており、たいてい十時過ぎでなければ床をはなれなかったということである。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣の置ける者はゐず、酒には弱し、直ぐもう調子よく醉つて來て、勝手な熱を吹いては夜更かしをしたものだ。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲をね……」良人改造５・１女性　会社｜官衙の昼間の勤めをすませて、夕方早く家に帰つて来べき筈の良人が、途中でぐれて外で夜更かしをするといふことは、うちで待つてゐるその妻にとつては堪へがたい苦痛に相違ない。",
              "citation": {
                "source": "茶話",
                "author": "昭和三（一九二八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寝もよからう、昼寝もわるくなからう、夜更かしもかまはない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、一、十一時以後は必ず夜更かしせぬこと。",
              "citation": {
                "source": "芸術上の心得",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄のところへ舞戻つて来てからもう一ヶ月以上になるのに、彼は何の職に就くでもなし、ただ朝寝と夜更かしをつづけてゐた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日連続してある仕事をひかえてなど居る時は、随分夜更かしもしたり、やたらにお茶をのんだりする、事はある。",
              "citation": {
                "source": "熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は恒藤の親友なりしかど、到底彼の如くに几帳面なる事能わず、人並みに寝坊をし、人並みに夜更かしをし、凡庸に日を送るを常としたり。",
              "citation": {
                "source": "恒藤恭氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに思つて居ながら、夜更かしをしたあとなので、矢張朝が起きにくい。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更かしの甚だしい三田は、平生會社に行くのに餘裕の時間が無く、起きる、顏を洗ふ、飯を喰ふ、洋服に着換る、靴を穿く――といふあわたゞしいものであつたが、朝の散歩の爲めには、特にふだんよりも早く起きた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生夜更かしで、一時二時迄机にむかつてゐる事も珍しくないのが、無理に早くから床に入つたので、いつたん目が覺めると、いくら努めても再び眠る事は出來なかつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼奴ひどく夜更かしが好きでね、毎々非常線に引っかかるそうだ。",
              "citation": {
                "source": "人を呪わば",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは夜更かし商売だから、当日もかなりおそくまで眠った。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は、たしかに丑三時、麓の若い人から頼まれた発句の点をして、今まで夜更かしをしていたが、ようやくそれを終ったから瓶子を洗って、また一陶の酒を汲もうとしている時に、この人影でしたから、老人が沈吟をはじめたのも無理はありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の社会において、普通の家庭において、朝寝、夜更かしというものは男性においてさえも決して自慢にはならない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや女性において、おそらく女性の醜辱の一つとして、朝寝、夜更かしはその最も大なるものの一つとして、数えてもよかろうと思う。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、かの女の朝寝は、当然、昨夜の夜更かしを連想する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上と松井と林とは殊に夜更かしの連中であった。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜更かしをしてるのに彼女が早くから寝てしまうこと、子供の守りや何かで私の時間が非常につぶされること、それらを不満だとは私も別に思わなかった。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり夜更かしをしないやうにね。",
              "citation": {
                "source": "ある親子の問答（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、林町へ来て、又よふかしをしたのじゃないか、と思っていらっしゃるでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰然としてね、それは正月でしたからすこしよふかしもいたしましたけれども、大体は早ねで、本よみも、すてては居りません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
