[
  {
    "uuid": "26519c83-f10a-50e3-9e88-90cae774ac5d",
    "entry": "余党",
    "reading": {
      "primary": "よとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
