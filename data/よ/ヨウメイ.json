[
  {
    "uuid": "2c6ff274-818d-5629-9b45-2a111bd2decb",
    "entry": "用命",
    "reading": {
      "primary": "ようめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "command",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕としてそんな用命にあづかつたことは生れて初めてでもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直な若崎はその後しばしば大なるご用命を蒙り、その道における名誉を馳するを得た。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六は、またも、ちっ、ちっ、ちっ、と笑って、「早速、御用命を仰せ付かりましたな。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような絵の直接御用命者には然る○○な方々もある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで父ならば、いつでも彼女の御用命に応ずるように、響いたからである）「おやおや」と、ベロヴゾーロフがやり返した。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙上に二十一年前からの御用命を果たしたと書かれてありましたが、思えば大正五年の秋、文展第十回展開催中、御用命を拝したのでございましたから、なるほど二十一年の歳月が経ったわけでございます。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の御前揮毫の節に、当時の皇后宮太夫三室戸伯爵を通じて、改めて二幅双か、三幅双の揮毫を、上納申し上げるようにという御用命を拝したのでございました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には激論をした揚句卓を叩き出したので、ボーイが用命と間違えて出て来たりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽・畿内の二个村の鶏を飼はぬのも、神の占め給うた家畜なるが故に、善い意味からは御遠慮申し、悪い意味からは不時の御用命を迷惑がつて、忌み憚つて来たものと言はれよう。",
              "citation": {
                "source": "鶏鳴と神楽と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "外ならぬ博士の御用命ですから、主人が特に倉庫を開きましてございます。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近侍の公卿はこれを畏みて、御板許に供御を命ずると、その当夜の内膳司は、思いがけなきご用命に接して、何かお肴をも奉らんと厨房を捜したが、何もない。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六に下関渡海火急の場合白石正一郎へ用命のこと、第七｜明石防備のこと、以上七条。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見受け致せば困難のご様子、心置きなく何んなりと、我らにご用命くださるよう、すぐに調え進ぜるでござろう」　こう常氏は親切に云った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昼夜、飲まず食わずに険路十五里――それというのも、左膳の用命を大事にと思うよりは与吉としては正直、泰軒先生がこわいからで――。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとかして自分方へ御用命にならぬものかと、それはいずれさまも同じ思いでございましたろうが、ことに主人将監などは、そのため、日夜神仏に祈願をこらしておりましたところ……」主水正は、そっぽを向いて、「何を言わるる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくて、伊豆屋からお油御用を取り上げて筆屋幸兵衛へ用命しようなどと、さような小事にさほどまで執着さるるはずはないと、イヤ、これは、越州一個の考えでござるが――」「私情？",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "横柄なるお声で、おいおいと、ひと声、ふた声お呼びくだされば、打てば響くというふうに、腰元どもなり、あるいはまた、三太夫とも申すべき奴らがたちどころに立現れまして、いかなる御用命にも即座にお応えするようになっておりますから、なんなりと鷹揚にお申しつけくださいますよう。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて先代中村屋店主と口論したことがあったので、爾来中村屋からは何物も買うまいと決心したものの如く、自分が代がわりとなりし後たびたび辞を低うして用向きに伺ったが、ついに一回の用命もなくはるばる十町も隔っているパン屋からパンを求めているとの事である。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある有名な富豪を得意とし、いわゆるお出入り商人の仲間となったことあり、月々数円以上の御用命は、パン店としては上等の客筋といわねばならぬのであった。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ地方で又酒盜などといふのも同じ物らしく、是は商人の廣告用命名で、現在は其類の珍らしい名が多い。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ地方でまた酒盗などというのも同じ物らしく、これは商人の広告用命名で、現在はその類の珍らしい名が多い。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩の御用命で上等の品も作られたことが判る。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚小生に為し得る事は喜んで御用命可致候間御遠慮なく仰せ付被下度候。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポートレートがご入り用の節は、私にご用命を」　ほどなく電車が来た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妃殿下、ご用命はございませんか。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜持ってきたヴェスタ・マッチだぞ」　給仕がご用命で急に席を外した。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやしきの若旦那さまには、たびたび、御用命をいただいては、よく……」「お目にかかっているというの」「はい、はい。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……時に、過日おねがいのご用命は、いかがでございましょう」「ああ、六波羅殿のご普請のことか」「それもございますし、小松殿におかれましても、伽藍のご建立があるそうで。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何かと、金沙、金泥、金箔など、たくさんにお要用でございましょうが」「あるにはあろう」「お口添えで、この吉次に、ご用命がねがえれば、こちらのお館へも莫大なお礼物をお頒けすることができますがな」　ここで吉次は幾ぶん胸の鬱をはらした。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
