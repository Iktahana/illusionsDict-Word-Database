          "literary": [
            {
              "text": "ただし容赦はなくても、ともかくも書き手と編集者はがっぷり四つに組む。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が合って四つに組むと、常陸関はすぐにつりに来ました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを、踏みこたえた泰軒、剣を棄てて四つに組む――と見せて、即に腰をひねったからたまらない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画法ではこれをやらうとしても「苦手」でやりにくかつたこと、ヨーロッパでは一旦その人の「意誠」を以つて見捨てたこと、リアリズムを、これと四つに組む捲土重来の姿勢で日本画家「放庵」は――ぼくをして敢ていはしめよ。",
              "citation": {
                "source": "小杉放庵",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相手がしゃくだが、競争となればフェアー・プレーで行こう」　照国の誠一は、悪者と四つに組む気でいるのです。",
              "citation": {
                "source": "九つの鍵",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャリアピンもクライスラーも、その点、パデレフスキーとは四つに組むことが出来ない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
