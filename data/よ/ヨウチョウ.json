[
  {
    "uuid": "e070dcd0-bb01-5f82-97ab-33463f45e43e",
    "entry": "膺懲",
    "reading": {
      "primary": "ようちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "punishment (of an enemy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初期のは市人の中の気慨のある者か或は武士の仕官の途に断念した者などが、武士の跋扈に反抗して之を膺懲し或は之に対抗する考へから起つたのであるらしいが、夫から以後、即ち天明前後から天保あたりへ懸けての侠客といふものは多くは博徒のやうな類である。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支那も昔は聖賢の教ありつる国」で、孔孟の生れた中華であったが、今は暴逆無道の野蛮国であるから、よろしく膺懲すべしという歌が流行った。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの機会に、あいつらの排他的な思想を膺懲してやろうと思っているのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は女性としての恋を捨て、優しさを捨て慎しやかさを捨てゝ、たゞ復讐と膺懲のために、狂奔する化物のような人間になろうとしているのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は、復讐と膺懲の手段として、結婚すると云う。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は女性としての恋を捨て、優しさを捨て慎しやかさを捨てゝ、たゞ復讐と膺懲のために、狂奔する化物のやうな人間にならうとしてゐるのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は、復讐と膺懲の手段として、結婚すると云ふ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の欧洲戦局を支配するものは米国の増援隊であり、その増援隊を活躍させるのは、米国造船能力の消長にあるのを思ふと独逸｜膺懲の鑰は、とりも直さず、四十年｜前の煙草屋の小僧の垢染んだ掌面に握られてゐる次第なのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体にうける苦痛を楽しむよりかも、精神上の自己膺懲に快楽を感ずると云う方が、よりも典型的なマゾヒィストだと。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父上が老練と家柄と、穏健と徳望とを基にして、老中筆頭という高官にあって、田沼の横暴を抑えたのを、私は年若と無位無官と、過激と権謀術数と、ある意味における暴力とを基とし、表面には立たず裏面にいて田沼の横暴を膺懲するのだ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其以前に佳人の父は彼等に、誰人の妻となるにせよ、若し其夫より佳人を奪ふ者あらば、協力して夫を助けて※夫を膺懲すべしとの盟を立てさせた。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という叫喚が聴衆の後ろの方から起って、道庵｜膺懲のために総立ちになった聴衆に裏切りが出たもののように、まずその声のする方からなだれを打ったのは、思いがけない出来事です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "費誓は周公の子の伯禽が徐淮の夷を征伐したことを書いたもので、當時楚の國の如き夷狄の盛になつたものに對して膺懲の意を寓したものであるから、之を以て尚書の終とすることは、恐らく孔門に於ける最初の思想を代表するものと看て可からう。",
              "citation": {
                "source": "尚書稽疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより膺懲のことは忘れてはならない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤田東湖藤森弘庵窃ニ君ニ謀ツテ曰ク幕吏因循ニシテ恐ラクハ膺懲ノ任ヲ尽スコト能ハザラン。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔悟すれども膺懲の奇策なければ淪胥与に喪ぶるの外致し方なし。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアングロサクソン、ラテン、アメリカンの三大文明国が、平和の攪乱者に対して正義人道の上より共同の責任を感じ、崇高なる犠牲の精神を発揮して、ついにチウトン文明の代表者たる独逸の民族主義を膺懲し得、ここに平和の曙光の輝き始めた事を喜ぶ。",
              "citation": {
                "source": "永久平和の先決問題",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯かる不親切な車掌は大に膺懲せざるべからずと、例に依って公憤を発した。",
              "citation": {
                "source": "青バスの女",
                "author": "辰野九紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが相撲部など運動部を中心とする右翼学生が『売国奴を膺懲し、軍事研究団を応援しろ』というビラをはり、大会をつぶしにかかった。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三万七千人の会員を擁する全国青年同志会が、露国｜膺懲の建白書を、桂首相に提出するかと思うと、非戦論者である堺利彦、内村鑑三、幸徳秋水の三人が、「万朝報」を去るというような事件が、この関門地方をも騒がしていたのである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげんか悪家主は、徹底的に膺懲してやらんと、庶民が迷惑する。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸博士を葬れ、然り、膺懲せよ、憎むべき悪徳漢！",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治をローダンしている大臣どもだけでなく、財界のボスどもにも同時に膺懲の剣を下すのである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴戻支那を徹底的に膺懲すべしと言うのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言って、俺は膺懲論に与していたのではない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんみずから業火の裡へ、平家｜膺懲のお名宣をあげて、院の政庁を武人の甲冑で埋めるような事態にでもなったならば、それこそ怖ろしいことである。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いまはもう寸分、君たち三名の義を疑ってはいない」「どういうご相談事なので」「くわしくは、その晁蓋と君たちが、義の杯を結んだうえで打合せるが、かいつまンでいえば、一世の大金儲けと、悪政府の大官を膺懲しようという快事だ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを膺懲し、それを正し、濁世に喘ぐ良民の味方たらんとするのが、ここの者どもの悲願とするところだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
