    "definitions": [
      {
        "index": 1,
        "gloss": "way of calling (something or someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの子だなんて、失敬な呼び方は、よしてくれ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご新姐――いま時、妙な呼び方で。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンス・クリスチャン・アンデルセン Hans Christian Andersen ――われわれはいつのまにかアンデルセンと呼びなれているが、これはわが国独特の呼び方であろう。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこうした呼び方は、もちろん言語上の比喩であって、具体的に適応しないのは勿論である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と牛飼は、ぞんざいな呼び方をしていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "高流といふ山の名前も、姪の説に依ると、高長根といふのが正しい呼び方で、なだらかに裾のひろがつてゐるさまが、さながら長根の感じとか何とかといふ事であつたが、これにもまた諸家の諸説があるのであらう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、今日半日のうちに、俺のことを、七通りの呼び方で呼びやがった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ氏の呼び方を眞似たのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ氏の呼び方を真似たのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "養吉は三年前に母を失って以来、父の自分を呼ぶ呼び方によって、父の気持ちを解することが出来た。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の幼少のときに彼が呼んでいたと同じ呼び方で、正勝は紀久子を呼んだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生……」　私に対して、八郎はその親しい呼び方をして、「もう晩の九時です。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに好きでもない女の人には、カクランだの、ハイチャイだの、ばかにしたような綽名をどしどしつけるが、いいひとに対しては、どんな綽名も思いつかず、ただ、竹さんだのマア坊だのという極めて平凡な呼び方しか出来ないのだからね。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後は今まで僕を呼ぶのに、そちらの先生だの、書生さんだの、小柴君だのというばかりで、ひばりさんなんて変に親しげな呼び方をした事は一度も無かったのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画の作者達は、美術批評家達を指して『職人』と呼んでゐるさうであるが、それは非常に適当した良い呼び方である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者諸君はこゝで何かしら、変な気持に捉はれないであらうか、それは日本人であつて、日本の風物人情を描いてゐるに拘はらず、その描写の方法、絵具材料が西洋から移入されたものであるといふ理由だけで、いつたい何時まで「洋画家」などといふに日本的な呼び方をつづけるのであらうかといふ疑問が起る。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "道中つつがのうございまして、祝着至極にござります」　まことにどうもこの、豆州か、というような鷹揚で、威厳があって、それでいてじゅうぶんに親しみのある呼び方なぞというものは、お三家のかたででもなくては、なかなかこんなふうに板にはつかないものですが、しかるに、そのごあいさつのさいちゅうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "正式には「フラム」というが、そんな呼び方はだれもしない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、慶一にとっては、苦い記憶しかない呼び方であることに変わりはなかったが。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十年八月九日、広島から四里あまり離れた地点で、僕は防空壕の中にゐた、あの不思議な新兵器のことは、この附近の人にも知れ渡つてゐたが、まだ何といふ呼び方をするのか判らなかつた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "という呼び方も、いまは自分だけのものではなくなったらしい。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「名前の呼び方がね、何だか変なんだよ、そこの役場の威張つた人のは……低い眠いやう声でね。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おちかはさういふ呼び方でひさを呼び慣らされてゐた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "邊鄙な山の中の村ですから、言葉のなまりも鄙びては居ますが、人の名前の呼び方からして馬籠は馬籠らしいところが有ります。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさはしい呼び方だ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "現象学の分析は言葉として用い慣らされている呼び方から出発しはするが、スコラ的概念ではない。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この呼び方は極めて便利で、恐らくこの呼び方を禁じられれば、人々は言葉に苦しむだろうと思うのだが――認識それから文化、之が思想という言葉の必要な内容を最も妥当に云い現わすだろう。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそういう呼び方で片づける位いなら、もっと実状を卒直に告げるだろう事大主義文化と民衆自発的文化と、の対立とでも呼んだ方がいいかも知れないのだが。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "春桃は、向高でさえ、年に何度としか呼ばないそういう呼び方で、誰が自分を呼ぶかと、おどろいた。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめから今にいたるまで、「太郎君」というれいぎ正しいよびかたをつづけている人が、ただひとりあった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
