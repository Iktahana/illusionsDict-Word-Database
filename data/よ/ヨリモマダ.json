    "definitions": [
      {
        "index": 1,
        "gloss": "even more than",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "徑を歩いてゆく私の影はすくすくと立つた杉の柱を※折して來る、冬の日よりもまだ弱い日向のなかにあらはれ、木立のなかに消えたり、熊笹の上を這つたりした。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもまだ小さかった頃のこと。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれよりもまだ文学の方が生命があると言った。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は多病だけれども、趙州の初発心の時よりもまだ十年も若い。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "サロンは、その戦時日本の新聞よりもまだ悪い。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄の前は弘治、弘治の前は天文だが、天文よりもまだ前の前のことだ、京畿地方は権力者の争い騒ぐところで有ったから、早くより戦乱の巷となった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやそれよりもまだ驚くことは、夫の匡衡が或時家に帰って来ると、何か浮かぬ顔をして、物かんがえをしているようだ。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしなくては一日の生命を保ちがたい男の境遇よりもまだみじめである。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代は澆季なりと時の人が嘆いたあの戦慄すべき保元平治時代よりもまだまだ今日の芸術界の一部は浅ましい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその他よりもまだもつときれいなのは、入口の石段の上に立つてゐる女の人でした。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしておまいのまへにすわつたこの心もちは、むちでぶたれるよりもまだつらいのだ。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きるな西日をうけて熱くなった埃だらけの窓の硝子よりもまだ味気ない生命がある。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもまだ派手なところが見えないでもない。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり上杉は、被害者の岸田さんなどよりもまだ背の高い男なんです。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあ、千石船よりもまだ大きいぞ。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達、前田、黒田という聞えた大藩の勲功も、越前家の功名の前には月の前の螢火よりもまだ弱い。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚ない横町の、晝猶暗き路次を這入つた突當り、豚小舍よりもまだ酷い二間間口の裏長屋であつた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚ない横町の、昼猶暗き路次を這入つた突当り、豚小舎よりもまだ酷い二間間口の裏長屋であつた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝なども彼の起きるよりもまだ早くぷいと家を出て、一日歸らないやうな日もあつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝なども彼の起きるよりもまだ早くぷいと家を出て、一日帰らないような日もあった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼山陽を硯に比べたら、あの通りの慷慨家だけに、ぷり／＼憤り出すかも知れないが、実際の事を言ふと、河合寸翁は山陽よりもまだ硯の方が好きだつたらしい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "実をいふと、東湖はやつこ豆腐よりもまだ鰹の刺身の方が好きだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "久米氏の口も大きかつたが、夏蜜柑はそれよりもまだ大きかつたので、七分がた口の中にはいりははいつたが、残りの三分がまだ歯の外にはみ出してゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもまだまだずっと遠い昔に遡って考えれば、Ａより大きくて、およそ考え得られる限りの任意の大きい値に達するであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんの小學校友達に扇屋の金太郎さんといふ子供がありましたが、その金太郎さんの家よりもまだずつと下の方でした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この写真のカールは、見なれたそれらの写真の顔よりもまだずっと若い。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文學でこそ、田村義雄君と云つたら、一方の大家であるけれど、實業にかけては僕よりもまだあんこぢや、それが一躍して、千金を握らうとしたのはそも／＼無理であつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもまだ以前のことで、丁度、憲法發布の時期が近づいて來た頃であつた、僕は政治上にも小供の時からの野心があつたので、そう云ふ方面の書物をも讀んだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
