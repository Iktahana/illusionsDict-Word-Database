[
  {
    "uuid": "554147b8-c74a-5b4a-9c8c-dd69945d9a5a",
    "entry": "漸く",
    "reading": {
      "primary": "ようやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
