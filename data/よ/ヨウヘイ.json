[
  {
    "uuid": "0140fa8d-3951-5f27-84fd-a6ae218b4fef",
    "entry": "傭兵",
    "reading": {
      "primary": "ようへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mercenary (soldier)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "丁度昔、彼が玄武門で戦争したり、夢の中で賭博をしたりした、憐れな、見すぼらしい日傭人の支那傭兵と同じように、そっくりの様子をして。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリスカスは部下をやって、その捕虜が埃及人か、どうか（というのは、埃及軍の大部分は希臘人その他の傭兵だったから）を尋ねさせた。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、今、お前はその実際の力も、虚勢も、傭兵をも動員して、殺戮本能を満足さすんだ。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那ニ於テ傭兵ト云フ者英米ニ於テ義勇兵ト名付ク。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "而モ此ノ故ヲ以テ「ヴェルサイユ」會議ニ於テ英米ガ傭兵制度ヲ日本ニ強ヒタルハ何タル迷妄ゾ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍國主義ナルカ否カハ傭兵ト徴兵トニヨリテ決セラルル者ニアラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ軍國主義ガ、單ニ自己ガ問題外ナル傭兵制ナリト云フノ理由ヲ以テ、他ノ徴兵ニヨリテ斯ル軍國主義者ノ侵害ヲ防衞セントスル者ニ己ノ冠ヲ冠セントセシハ惡ムベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "從テ傭兵ト徴兵トノ強弱ヲ論ズルコトハ無用ナル詮議ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米ノ國情ニ於テハ必ズシモ強兵ヲ意味セズシテ、日本ノ建國ト信念トニ於テハ傭兵ハ必ズ弱兵ナルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米ノ傭兵ト獨逸ノ徴兵トノ優劣ハ實戰ニヨリテ立證セラレタルモノニ非ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "只退却將軍ノ報告文トシテ古今獨歩ノ文豪「ヘーグ」元帥ニヨリテ英國傭兵ノ光榮ハ十分ニ認知セラレタルハ周知ノ如シ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "俸給ガ傭兵ノ其レト全ク別個ノ義ナルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ラバ多大ナル俸給ニヨル傭兵ヲ以テ戰ヒシ英米ヲ見ヨ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがローマ帝国の全盛時代になりますと、国民皆兵の制度が次第に破れて来て傭兵になった。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣りの支那では漢民族の最も盛んであった唐朝の中頃から、国民皆兵の制度が乱れて傭兵に堕落する。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は特に十字軍の影響を受けて地中海方面やライン方面に商業が非常に発達して、いわゆる重商主義の時代でありましたから、金が何より大事で兵制は昔の国民皆兵にかえらないで、ローマ末期の傭兵にかえったのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし戦争がありそうだから、あそこから三百人傭って来い、あっちからも百人傭って来い、なるたけ値切って傭って来いというような方式では頼りないのでありますから、国家の力が増大するにつれ、だんだん常備傭兵の時代になりました。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "常備傭兵になりますと戦術が高度に技術化するのです。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん誰もそんな考えで剣を抜いているのではありませんが、この指揮の形式は西洋の傭兵時代に生まれたものと考えます。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また歩調を取って歩くのは専制時代の傭兵に、弾雨の下を臆病心を押えつけて敵に向って前進させるための訓練方法だったのです。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに加えて、傭兵の時代とちがい、ただで兵隊を狩り集めて来るのですから、大将は国王の財政的顧慮などにしばられず、思い切った作戦をなし得ることとなったのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年戦争でも、冬になれば傭兵を永く寒い所に置くと皆逃げてしまいますから、お互に休むのです。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "１　軍隊価値の低下　文芸復興以来の傭兵は全く職業軍人である。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦争史大観」では、兵役がフランス革命までの傭兵時代に於ては「職業」であったのに、フランス革命以後「義務」となったが、最終戦争時代は更に「義務」から「義勇」に進むものと予断している（一一八頁及び付表第二）。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米の傭兵を義勇兵と訳するのは適当でない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七、八世紀の傭兵、近時支那の軍閥戦争等。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "用兵術もまた暗黒時代となれる中世を経て、ルネッサンスとともに新用兵術生まれしが、重金思想は傭兵を生み、その結果、持久戦争の時代となれり。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王歿後三年にして起れるフランス革命は、傭兵より国民皆兵に変化せしめて戦術上に大変化を来たし、ナポレオンにより殲滅戦略の運用開始せられ、決戦戦争の時代となれり。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五　戦争参加兵力の増加と国軍の編成一　職業者よりなる傭兵時代は兵力大なる能わず。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
