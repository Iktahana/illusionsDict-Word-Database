    },
    "definitions": [
      {
        "index": 1,
        "gloss": "employing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "石田は達見に往って、第二の下女の傭聘を頼んだ。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時わが國へ來た支那留學生の數は萬を超え、彼地に傭聘された日本教習の數は、五百以上もあつた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に当って朝日新聞から社員として傭聘するという話が始まって、遂に氏は意を決して大学講師の職を辞して新聞社員として立つ事になった。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏が大学を辞して朝日社員となって間もなく早稲田大学から氏を傭聘したいという申込みがあった。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
