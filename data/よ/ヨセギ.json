    "definitions": [
      {
        "index": 1,
        "gloss": "wooden mosaic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
