[
  {
    "uuid": "662de4c4-8c07-5ee6-a82b-d21cc458511c",
    "entry": "幼魚",
    "reading": {
      "primary": "ようぎょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fry (young fish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "緑蔭鮮かなるところ、小流れの清水を一區畫一區畫的に段々たゝへて、川マス、ニジマス、ブルトラウト、スチールヘッド等の各種鱒族の幼魚を養つてある。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "産卵期になって、雌鱒の腹を裂き、腹中の卵を取出し、それに雄鱒の精液を注ぎかけ、孵化場で孵化させて、幾百万という幼魚を、凡そ二寸位まで育て上げ、それを湖水に放つのである。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "放たれた幼魚は、三年ばかりのうちに完全な親魚となり、卵を孕んでくる。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二寸ばかりの幼魚の頃、孵化場から放たれた場所、その故郷の川一つだけである。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大海に放たれても、産卵期には必ず、自分が幼魚の頃甞て放たれた場所へ、殆んど洩れなく戻ってくる。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞爺湖の鱒の幼魚を、十和田湖へ運んで、十和田の孵化場から放ったとすれば、恐らく彼等は、その孵化場へ産卵に上ってくるであろう。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱈の卵が完全に艀化し、完全に幼魚が育ったならば世界の海は三年間に、鱈で一杯になるといわれているが、鯰の卵も完全に一尾残らず艀化し、生育したら日本国中鯰だらけになって、足が辷って歩けないようになるかも知れない。",
              "citation": {
                "source": "鯰",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尾の成魚の卵｜凡そ三千粒、年々この人工授精卵五億五千万粒｜乃至七億粒である、自然孵化凡そその半数と見て、計十億の幼魚が諏訪湖に出るのである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
