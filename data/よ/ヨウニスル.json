    "definitions": [
      {
        "index": 1,
        "gloss": "to see to it that ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
