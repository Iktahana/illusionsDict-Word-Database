[
  {
    "uuid": "6a5f9ac0-3d59-5723-9c25-6f98946a4963",
    "entry": "養老院",
    "reading": {
      "primary": "ようろういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
