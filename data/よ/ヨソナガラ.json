[
  {
    "uuid": "107f9588-4c89-5677-af97-45781dde9a75",
    "entry": "余所ながら",
    "reading": {
      "primary": "よそながら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
