        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四十路ばかりなるは、その叔母にや。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっちりと肥えた四十路がらみのひとだった。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどその草心尼の清楚な美しさも、年とすれば、もう四十路にとどいていたはずである。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四十路にちかいはずの准后ではあるが、蠱惑ともいえる艶な美はどこにも褪せていなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな古い手は、よそじゃア知らないけれど、この神田じゃアきかないんだよ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの医者がそんな便利な診断書をくれるんですか、と伊沢が仰天して訊ねると、仕立屋の方が呆気にとられた面持で、なんですか、よそじゃ、そうじゃないんですか、と訊いた。",
              "citation": {
                "source": "白痴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
