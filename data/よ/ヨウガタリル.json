    "definitions": [
      {
        "index": 1,
        "gloss": "to do the job",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下婢で用が足りる位なら、世間の男は誰だツてうるさい妻なんか持ちはしない。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼み手があるというなら、それを聞きゃ用が足りるんだッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言の名題と役割と、入場料と開場時間と、食堂の鮨や弁当の値段さえ判ればそれで好いというような、今日の安っぽいプログラム式の番附では、単に用が足りるというだけのことで、芝居らしい気分も、暢やかな気分もとうてい浮かみ出して来そうもない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日でも当時、普通科をやった人たちがよくこの普通科を修めたために、絵をやる方の人でもちょっと小刀が使え、木彫りをやる人の方でも、絵のことが分るというわけで、相当の用が足りるので都合が好いといっておりますが、全くそういう便利があって、これは重宝で好いと思うことであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物を遣らして見ると帳面ぐらいはつけ、算盤も遣り調法でべんちゃらの男で、百姓を武家言葉で嚇しますから用が足りる、黒の羽織なぞを貰い、一本｜帯して居る、其のうち　富「古い袴が欲しい、小前の者を制しますには是でなければ」　などとべんちゃらをいう。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、まあ、どこへ行ってもそうであるように、都会の相当なホテルにいる以上、英語ですべて用が足りることは勿論だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙の用が足りるぐらいは覚えておきなさい。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇行の室内から三文判を探しだして満足したのか、実印をさがしたが見つからなかったのか不明であるが、あれほど信用組合の時間を気にしていたところをみると、三文判で用が足りるものと満足していたのかも知れないね。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は宿屋生活をしてゐるので、一週間に一度ぐらゐ田舎の買物に出れば、どうにか用が足りるといふ話をすると、彼女は溜息をして、一軒の家を持つてゐるととても大へんだと言つた。",
              "citation": {
                "source": "軽井沢の夏と秋",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋料理や中国料理は、食品原料の持ち味に欠けるものが少なくないために、料理する際に、盛んにいろいろな補助味を使って調味し、一種の混成味による料理をつくることは得意のようだが、日本料理に至っては、真に優良美味な食品原料に恵まれているために、補助味と言えば、大部分がかつおぶしの一種で用が足りる。",
              "citation": {
                "source": "日本料理の要点",
                "author": "――新雇いの料理人を前にして――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の二畳、勝手につづく茶の間の六畳、狭い庭をひかえた奥の八畳という小体な住居だが、長火鉢、茶箪笥、鼠入らず、湯こぼしと、品よく、きちんとして、居なりで用が足りるようになっている。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大したものはなくても、何でも用が足りる。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "要るものは、みな手近にあって、なんでも居なりで用が足りるし……こういっちゃなんですが、きれいにする精もないから、お掃除なんかもしない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧机のあったところに食器棚をすえ、壁の靴摺の三叉のソケットから電気コンロを二つとってご飯蒸と味噌汁の鍋をかけ、食事の間に台所へ立たなくとも、居なりで用が足りるようにしてある。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一般のお客は特に藤村や栄太楼に行かなくても、百貨店で用が足りる事になる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、これを鼻先へついと突つければ誰だって何ぼうでも彼等を買収する事は出来る、最後に燭台のない理由は、燭台なんかはいらないからじゃ、洞窟内なんぞを照すには裸蝋燭で結構用が足りるもんじゃが」「はあ、それだけですか」ややしばらくしてフランボーがこう訊ねた。",
              "citation": {
                "source": "作男・ゴーの名誉",
                "author": "THE HONOUR OF ISRAEL GOW",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、なんにしてもお怪我がなくてようございました」「あの、早く連れの者に沙汰をして」「へえ、よろしうございます、いま使に出した野郎が、もう帰って来ますから、帰って来たらすぐに飛ばせてやりますでございます、お乗物なんぞは、ここで一声｜怒鳴れば御用が足りるんです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、現在では竹針も鋼針もほとんど和製で用が足りるようになった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生はこの土地のことを詳しく見てえって云ってたんべが」と老人が喚いた、「そんなら岡の上べえ歩きまわってもしょあんめえじゃ、根戸川のまわりだの百万坪の※だの、堀もそうだし、沖へも出てみるがいいだ、それにはこの舟さえあれば用が足りるだよ」　まあ見てくれと云って、老人は伏せてある青べかをひき起こした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、考えて見ると、無言の裡に万事用が足りる仕掛けになっている。",
              "citation": {
                "source": "変人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の側に坐って煙草を吸いながら、目で見、耳で聞きつけたところを、「おい／＼、鉄瓶が吹いているよ」　という風に口に出して大して間違いないように報告すればそれで用が足りる。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日伊賀の上野見物、余は後便にて」で充分用が足りる。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の揚げた芸者で用が足りる」　と団さんが笑った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当の橋本閣下でなくても、その弟を知っている人なら充分用が足りる。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番上に自分の荷物があり、それで二〜三日分の用が足りる。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここで用が足りるだろう。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
