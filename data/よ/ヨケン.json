[
  {
    "uuid": "f40b59c2-0dd9-57e3-a8ea-c56557c3db26",
    "entry": "予見",
    "reading": {
      "primary": "よけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
