    "definitions": [
      {
        "index": 1,
        "gloss": "grey nightjar (Caprimulgus indicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先夜鷹見の宅で、樋口の事を話した時、鷹見が突然、「樋口は何を勉強していたのかね」と二人に問いました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋焼うどんや夜鷹もまたしばしば橋の袂を選んで店を張った。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでわれわれは身を投げるか、弁慶の薙刀の※となるか、夜鷹に食われるか、それともまた鍋焼うどんに腹をこしらえて行手の旅を急ぐかである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは押し入ると、獲物を求める、夜鷹のように、屋内を、隅から隅へ突きあたり、ひっくりかえした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共の世界が旱の時、瘠せてしまった夜鷹やほととぎすなどが、それをだまって見上げて、残念そうに咽喉をくびくびさせているのを時々見ることがあるではありませんか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜鷹ふくろう、ちどり、かけす、　来よとすれども、できもせぬ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「栗の木食って　栗の木死んで　かけすが食って　子どもが死んで　夜鷹が食って　　かけすが死んで　鷹は高くへ飛んでった。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで少しずつ私にも気がついて来たのでございますが、この婆と娘は、ほんとうの親子で無いようなところもあり、何が何やら、二人とも夜鷹くらいまで落ちた事があるような気配も見え、とにかくあまり心根が悪すぎてみんなに呆れられ捨てられ、もういまでは誰からも相手にされなくなっていたようなのでございました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか夜鷹もさう云ったし、烏も云ってゐたやうだよ。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも君の友達の、夜鷹がうそを云ったらうか。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夜鷹より先に幽靈が出ます。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊暦七｜月二十一｜日ばかりの宵闇に、覺束ない提灯の灯一つ二つ、婦たちは落人が夜鷹蕎麥の荷に踞んだ形で、溝端で、のどに支へる茶漬を流した。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よひの間のホウ、ホウは、あれは、夜鷹だと思はれよ。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜鷹になるか、提重になるか、いずれにしても不器量の顔に紅や白粉を塗って、女に飢えている中間どもに媚を売るのが彼等のならわしであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手の松へは夜鷹が来る。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あがったところに夜鷹蕎麦の灯があった。",
              "citation": {
                "source": "狢",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商人は顫えあがって逃げていると夜鷹蕎麦がいた。",
              "citation": {
                "source": "怪譚小説の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気な男が、かかる折から、おのずから猟奇と好色の慾念が跳って、年の頃人の妻女か、素人ならば手で情を通わせようし、夜鷹ならば羽掻をしめて抱こうとしたろう。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程このごろは物騒だというのに、夜鷹じゃあるめえし、若い娘が五ツ過ぎに柳原の堤をうろうろしているというのがおかしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄席の帰りに腹が減って蕎麦屋に這入ると、妓夫が夜鷹を大勢連れて来ていて、僕等はその百鬼夜行の姿をランプの下に見て、覚えず戦慄したこともある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは行き暮れた旅人を泊らしては路銀を窃む悪猟師の女房、次には※いびりの猫化郷士の妻、三転して追剥の女房の女按摩となり、最後に折助の嬶となって亭主と馴れ合いに賊を働く夜鷹となり、牛裂の私刑に波瀾の多い一生の幕を閉ずる一種の変態性格である。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜鷹ですよ」「なるほどな」　はだかのままでしばらく考えていましたが、突如！",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は芳町、柳橋の芸者から松の位の太夫職、下は宿場の飯盛から湯屋女、辻君、夜鷹に到るまで、あらゆる階級の要求に応ずる設備が整っていた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代に夜鷹は黙許されていましたが、淫売はやかましい。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方では昔から夜なきうどんの名があったが、江戸は夜そば売りで、俗に風鈴そばとか夜鷹そばとか呼んでいたのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋焼うどんが東京に入り込んで来たのは明治以後のことで、黙阿弥の「嶋鵆月白浪」は明治十四年の作であるが、その招魂社鳥居前の場で、堀の内まいりの男が夜そばを食いながら、以前とちがって夜鷹そばは売り手が少なくなって、その代りに鍋焼うどんが一年増しに多くなった、と話しているのを見ても知られる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時分そんなところにうろ付いていると、夜鷹か引っ張りと間違えられる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは柳の下に荷をおろしている夜鷹蕎麦屋の燈火をみて思わず足を停めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、夜鷹だろう」　気の強いものは笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさびしいのを付け目にして、かの夜鷹という一種の淫売婦があらわれて来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
