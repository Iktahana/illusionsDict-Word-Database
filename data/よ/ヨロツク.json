          "literary": [
            {
              "text": "や、何うも案山子の飛ぶこと、ひよろつく事！",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お――起き――父ちやん――お起――きツて、ね」と、また、末の子が障子を明けて這入つて來て、ひよろつく腰をかがめて、父の顏をのぞき込むこともある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰蒲団など当てて、足がまだよろつくようであった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は廿年もすれば老ぼれてひよろつく。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
