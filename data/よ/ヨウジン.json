[
  {
    "uuid": "2d6a6eab-35e5-5493-95b8-bfa698fbc863",
    "entry": "庸人",
    "reading": {
      "primary": "ようじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
