        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "waltz　ダンス・ホールの溶暗のなかで、僕たちは縫目のない肉体のように結びついた……………。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貧しさ」「うれしさ」の視覚的代表者をどこから拾って来るか、それをいかなる距離、いかなる角度、いかなる照明で、フィルムの何メートルに撮影し、それを全編のどの部分にどう入れるか、溶明溶暗によるかそれとも絞りを使うか、あるいは重写を用いるか。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の場合に甲の場面から次の乙景に移る際にいわゆる溶暗溶明を用いることがある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（溶暗）35　長い夜。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "三中年が寮への坂道をくだっていく、俯瞰気味の引きの絵、オーケストラがＧ、Ｆとさがってくる、Ｃでドーンとフォルテシモになって、画面溶暗、テーマソングがかかって――〈イエス・アイ・ウィル〉かな――でもって、タイトルが縦スクロールをはじめる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……【溶暗】　【字幕】　九州帝国大学、法医学教室、屍体解剖室内の奇怪事……大正十五年四月二十六日夜撮影――　【説明】　あらわれましたる映画は御覧の通り隅から隅まで、どこがドコやら、何が何やらわかりませぬ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……お兄さま……どこに……」……【溶暗】……　【字幕】　正木若林両博士の会見。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハ……」――【溶暗】――　オーヤオーヤ……ナアーンのコッタイ……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に溶明時における櫂をさした立ち姿、溶暗の刹那の別れ去る姿――更に消え行く悲泣の声――久しぶりに此ほど美しい舞台の泣き声を聞いた。",
              "citation": {
                "source": "合邦と新三",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（早い溶暗）　　　　　第一幕の二明治三十八年正月の夜。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（溶暗）　　　　　第五幕の二堤家の焼け跡。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（溶暗）――　　　　　第二場　（幕間なし）竹取翁、讃岐ノ造麻呂が竹籠を編みながら唄う「竹取翁の唄」が次第に聞えて来る。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われらの顔を『黒き御座』から保護する溶暗の中で、われらをして自由意志による犠牲を捧げる用意をなさしめよ」カルクマンが太い低音で呼応した。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、溶暗――溶明。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶暗でこれ程笑ったことは珍しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、徐々に徐々に溶暗…………。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋装も本心から嫌だというなら判っているが、口さきでは、ようあんな不細工な恰好して歩きはりまっせなと非難しながら、心では切に自分もやってみたいのだが、何しろ洋服の勝手がよく飲み込めない上に、とても恥しいので、なかなか手が出せないというものが多い。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三田さん、おりかのやつ、ようあんたに顏が合はされたもんですなあ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこんな美しい妓に知っていられる覚えがないというよっに、なおもしきりに頭を傾けていると、女主人が、「お園さんと一緒にようあんたはんに招ばれて往かはりましたがな、若奴さんどすがな」といったので、私はやっと思い起した。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようあんな下卑たことを大きな聲で喋舌つて、げら／″＼笑つて居られると愛相が盡きてしまふ。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようあんな下卑たことを大きな声で喋舌ってげらげら笑っておられると愛想が尽きてしまう。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "段六　……（群集と仙太を何度も見較べて頭を振り）……仙太公、どうもはあ、しようあんめ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにようあんた、なにをリクエストしたんだよう」黄色い服の女がいった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今考えたらあんなえらい騒動して、眼エ吊り上げて見せるやなんて、役者でもないのんにようあんなことしたなあ」いいなさって、そら、あの時のことは確かに私を計略にかけた。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
