    },
    "definitions": [
      {
        "index": 1,
        "gloss": "than",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてヒステリーは現実よりも表現を名称を吟味したがるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "高きより、風のただ中に、思ひ出の破片の翻転するをみたり。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしなき、そが心母にも、……もとより友にも明さざりき。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西部劇通信」だの「ゼーロン」だのを書いた昭和五年の頃は、彼の返り咲きの観があつたし、評判がよかつたのであるが、あの頃のものよりも、それから暫く後に書いた、水車小屋の壁に凭れて月の明りで手紙を読む短篇なぞの方が、遙かに牧野さんらしいものであると思はれる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに牧野さんが酔ふと発しはじめるのなぞは、当人に自制力がないよりも、周囲が彼にとつてはあまりに不真面目に見える所から起るのであつたと考ふべき点もあるのであるから、さういふ定説が呑気に繰返されることは辛かつたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それあまあ、昔だつて一般世人は美術家より装飾美術家の方をリアリスティクだと思つてゐたものではあるらしい。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それともも少し上等になると、例へばヴィオロンの批評には、「まづ、ボーイングはと……つまりボーイングなる眼点よりしてこの提琴演奏家はと……」といつた具合らしく、発表された批評文恰かも生理衛生の答案みたいなのがあるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しその簡潔とは、原稿紙に臨んでからのことであるよりも、寧ろそれ以前の、凝集を謂つてゐるのである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言換れば、彼の詩には猶事象そのことに対個人的な興味――結局これは詩に於ては散文に於けるよりも一層散文的なものとして留るもの――があつて、それが詩性を少しく散漫にしてゐると思ふのである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればいゝ人達は、不景気にも関らず、昔日よりも元気でこそあれ落胆してゐるとは思はれぬ。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればよい人達は、不景気なれば、尚更ボヤボヤしてはゐられないといふので、景気のよい時よりも当然意志的になるのであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテリの中だけで見ても、何か考へたり、創作したりする者よりは、例へば語学が出来るので飜訳をしてゐるといつた連中の方が元気である。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、「元気でないものはどこか間違つてゐる」といふが如き常識を以て、昨今のインテリ達を見た場合、創作家よりも翻訳家の方が、「間違つてゐない」といふことにもならう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、芸術家は、昔日よりも、一層の孤独を必要とするであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその気質としては、動物よりも植物を、夏よりも冬を愛し、――『鋼青』を『苹果』を、午前のみそれを愛したのです。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その云ふ気持は分るけれど、それに、観念が稀薄であるよりは濃厚な方がよいに決つてゐるけれども、要するに、観念があるだけある上で見たり感じたりしてゐることが芸術になりもするのであるから、そこへ観念を持運んで来たつてたゞトンダお景品たるに過ぎない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ渚よりも、沖の方が想ひ出される。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、今よりも、子供の時分の方が、よつぽど海は好きだつたやうだから、してみると今よりも、あの頃の方が「こころまゝ」だつたのだらうか？",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなき浪の蕩揺に、汝はなが魂打眺む……「なーるほど…」と思ふのは、恐らくボオドレエルが私自身より意識的であることに気が付くからである。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、二、三、四行に於ても、第五、六、七、八行に於ても、海は猶深さよりも広さを感じさせたが、茲に於て海は深く、ふてぶてしくも狂暴である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚、つまり自然を何よりも大事に守つて居るからである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ山より摘みてかへれば、紫苑はなしぼみて、すでに秋の愁ひをさそふ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、やさしく胡弓を摩り、遠くよりしも光を送れ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしきものまにや、のぞみうしなひ、いつさいより靈智うしなひ。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たづきも知らに、わが喰むむぎの蒼さより、あはれはるばる、み空をながれ汽車は行く。",
              "citation": {
                "source": "旅上",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
