[
  {
    "uuid": "385d88b2-cfa5-54e0-a9e4-696c17fafbce",
    "entry": "読み取る",
    "reading": {
      "primary": "よみとる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
