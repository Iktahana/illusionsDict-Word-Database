[
  {
    "uuid": "81bb5d0e-2702-5b7c-85b1-b75f76c78fa5",
    "entry": "羊羹色",
    "reading": {
      "primary": "ようかんいろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
