        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただあの妖力ある女郎蜘蛛のように、生きていたい要求から毎日その美しい網を四つ手に張った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古狸の妖力を封じる手だてが小田原退治の勝負どころといふものだ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそるべき妖力を持つあの霊魂第十号をうち倒して、隆夫が損傷なく無事に元の肉体をとり戻すためには、どうしてもやり遂げなくてはならない仕事だった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ彼はああした魅しから、魔法から、妖力から、悪魔の誘惑から解放されたのである。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
