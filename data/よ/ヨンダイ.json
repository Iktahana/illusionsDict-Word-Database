          "standard": [],
          "literary": [
            {
              "text": "四福音書に就いては、不勉強な私でも、いくらかは知っているような気がしているのだけれども、ロマ書、コリント前・後書、ガラテヤ書など所謂パウロの四大基本書簡の研究までは、なかなか手がとどかないのである。",
              "citation": {
                "source": "パウロの混乱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声を聞かずや、無限の感激は迸しつて迅雷の如く四大を響動せんとす。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大の峻烈な意志に逆らって、雲と水と丘との間に屹然と独り目覚めてあることは！",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一大隊長　　篠原　国幹第二大隊長　　村田　新八第三大隊長　　永山弥市郎第四大隊長　　桐野　利秋第五大隊長　　池上　四郎第六大隊長　　別府　晋介　大隊長は凡て、名にし負う猛将ぞろいである。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "篤胤は、春満、真淵、宣長と共に国学の四大人と呼ばれてゐるが、その尊皇愛国主義の主張は実行的であつたために、幕府に忌憚され、天保十二年江戸を逐はれ、秋田に帰郷を命ぜられ、その著「扶桑国号考」は絶版となつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂道徳的理想の不断の発達は之れを希臘の四大徳の例に徴するも明かなるにあらずや。",
              "citation": {
                "source": "国民性と文学",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "『立世阿毘曇論』二に、この世界に人の住む四大洲のほか、更に金翅鳥洲、牛洲、羊洲、椰子洲、宝洲、神洲、猴洲、象洲、女洲ありと説く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の聖王に子千人と四大宝蔵あって中に珍宝満つ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし『仏説観弥勒菩薩｜下生経』に、この閻浮提洲、弥勒の世となって、危険な物や穢い物ことごとく消え失せ、人心均平、言辞一類となり、地は自然に香米を生じ、衣食一切の患苦なしとあるに、無数の宝を蔵めた四大倉庫自然に現出すると、守蔵人、王に白す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞に松島を見むとせば、舟をやとひて四大觀めぐりをなさざるべからず。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大觀とは、大高森、富山、扇谷、多聞山、これ也。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、四大觀めぐりのみにてもなほ足らず。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島灣口をふさげる、桂、野々、宮戸、寒風澤の四大島は、早やあとになりつ。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四天狗巖、五大堂、釋迦堂、南院の堤を山寺の四大觀と稱す。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "オセロは四大悲劇の一である。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大のあらび、忌々しかる羅刹の怒号、　ほそりゆき、雑りけち変化して苦も楽とならむとやすらむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大のあらび、忌々しかる羅刹の怒號、　ほそりゆき、雜りけち變化して苦も樂とならむとやすらむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を以て白刃に臨めば、猶し春風を斬るが如し」（四大元無主。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "四疋の毒蛇は私どもの肉体を構成する四つの元素（地、水、火、風の四大）です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港の夜景は世界の四大夜景の一つだと云うが、私は昼間の景観の方をとる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少なくともヨーロッパの四大国民の名は、いずれもみな外国の名である。",
              "citation": {
                "source": "征服の事実",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大、能用※四大、若能如是見得、便乃去住自由という。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三井、三菱、住友、安田の四大財閥が解消せられることになった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、これらの四大財閥の、中心的な機構は変化させられたし、或る企業の一部分は完全に解消させられた。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちじくの実や、やつとおちついた・ゆふべは雨ふる蓮を掘る　九月三日今朝も早かつた、四大不調は不思議に快くなつた、昨夜、樹明さんからよばれたタマゴがきいたのかも知れない、何しろ、薬とか滋養物とかいふものがきゝすぎるほどきく肉体の持主だから。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大の身を悩ます病は幻でございます。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）巻首の四大字は東久世通禧公、次は養素軒柳原大納言｜前光公、愛古堂磐渓、秋月公、大給亀崖公（即松平｜縫殿頭の事也）、跋は片桐玄理と申せし家塾に居りし御存之者、今文部の督学寮に出仕いたし居申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてここは、東都｜目貫の場所たる、銀座四丁目の交叉点である、昔はここに毎日新聞、日日新聞、その他二つの四大新聞社が相対して立っていたのを覚えているが、新聞社は皆それ／″＼銀座から影をかくし、丸の内へと移ってしまった。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            }
          ]
        }
