    "definitions": [
      {
        "index": 1,
        "gloss": "heave ho (shout used by construction workers, etc. when pulling something big)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
