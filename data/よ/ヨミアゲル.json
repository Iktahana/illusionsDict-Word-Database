    "definitions": [
      {
        "index": 1,
        "gloss": "to read out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へば安宅の関で弁慶が勧進帳とて読み上げる巻物の正体を、覗かれかゝると笑ふ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度もくり返して教えれば、二、三と十まで口で読み上げるだけのことはしますが、道ばたの石ころを拾うて三つ並べて、いくつだとききますと、考えてばかりいて返事をしないのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア初めろと自分の急き立つるので、そろそろ読み上げる事になった。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハハァ、天狗様が祀ってあるのだな、これは御挨拶を申さずばなるまい」と、そこで髯将軍は恭しく脱帽三拝し、出鱈目の祭文を真面目｜臭って読み上げる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョリーさんが羅馬綴で書いた式文みたようなものを読み上げる時には皆起立させられたが、モウ足が痺れて立てない者も居た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章会で四方太氏が自分の文章を読み上げる少しさびのある音声にも、関西なまりのある口調にも忘れ難い特色があったが、その読み方も実にきちんとした歯切れのいい読み方であった。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と読み上げる友人。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子本はディスプレイに文字を表示するほか、記載された内容を音声で読み上げる機能も備えています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "操作の扉を開いたのは、画面に表示された文字を読み上げるソフトだ。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいな男の左中弁が重々しい神さびた調子で詩を読み上げるのが感じよく思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どんなことが書いてあるのか判りませんが、折角こうして送って来たのですから、その熱心に免じて、わたくしがこれから読み上げることに致します。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時を打つぼんぼん時計、「かるた」を読み上げるらしいはしゃいだ声、何に驚いてか夜なきをする鶏……葉子はそんな響きを探り出すと、人の生きているというのが恐ろしいほど不思議に思われ出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主が、眠むそうな声をして、阿弥陀経などを読み上げるたびに、譲吉は却って自分の純な悲痛の感情が、傷けられるのを覚えた。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑吏の長　それでは、罪状を読み上げい!刑吏二　（声高く読み上げる）弦打村百姓　甚兵衛その方儀、去る十三日領内百姓一揆騒動いたし候｜砌、右一揆に加担いたし、香東川堤において上役人松野八太夫に投石殺害いたし候始末、不恐御領主を仕方、不届至極につき、磔申付くる者也。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "松さんは大きな声で一節を読み上げる。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（読み上げる）「今回当地における伊藤公とわが北京公使ならびに大蔵大臣ココフツォフとの会見につき、本社は確かなる筋より左のごとき説話を聴けり。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は法廷で判事がその告訴状を読み上げるのを聴いた時から、これはなかなかの難事件だと思いました。",
              "citation": {
                "source": "自責",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、読み上げるから、聴くがいい。",
              "citation": {
                "source": "無駄骨",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と医者は名調子で聴衆に対い、自分の原稿を立って読み上げる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今の問答を読み聞かせます」　書記の読み上げるのをじっと聞いていた彼女は黙って頭を下げた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判長ロジャアス氏は起立して、陪審員の判定を読み上げる。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂岡君と国富君とが、読み役で、籤を受取っては、いちいち大きな声で読み上げる。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜等船客一｜同大食堂に呼び集められて、事務長が変な所にアクセントをつけて船客の名を読み上げる。",
              "citation": {
                "source": "検疫と荷物検査",
                "author": "杉村楚人冠",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵解きは絵は見せるが、詞書は自分で読み上げる。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で、一冊の書物を読み上げる事が、非常な努力であつた時期がある。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間にいくらだつてゐる、あの亭主持ちの女と、一体どう違ふんだい……」（議場騒然）　かう騒がしくては本文を読み上げることができません。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンマン伯爵――議場で読み上げるくらゐなら、公演を許しても差支ないではありませんか。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想検事が「ここにおいて被告はマルクス主義思想を抱懐するにいたり」と法廷でよみあげる告発の文書の文句とは、まるでちがった本質と道ゆきとをもつことである。",
              "citation": {
                "source": "あとがき（『二つの庭』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあどうでしょう、そう云って店の鴨居に貼ってある公価目録を片はじからよみあげる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずから壇の燈明をとぼし、香を拈じ、経文一巻をよみあげる。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
