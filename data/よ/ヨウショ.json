[
  {
    "uuid": "e486671a-63a2-511b-bb5b-bf7b297e70cb",
    "entry": "洋書",
    "reading": {
      "primary": "ようしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
