    "definitions": [
      {
        "index": 1,
        "gloss": "knowing how to swim with the tide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頭のいい、要領のいい点は、そういうところもあるだろうが、そうばかりとも思われない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの生活は要領のいいものであるが生命力がない、整っているが魂が欠けている、滑らかだが深みがない。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちんとした服装、血色のいい顔、要領のいい応答。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "要領のいい奴らで、戦争を遊山と心得てかりそめにも勇み立つようなところがない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠然とした長老とはいえ、もう派手な人気もなし、大した先々も望めないと見てとって要領のいいお仙は、手廻しよく見切りをつけていってしまったものらしかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が俳句てどんなものですかと聞いたら、その時非常に要領のいい説明をされたので、感心して直ぐ馬鹿なことを聞いたものさ。",
              "citation": {
                "source": "冬彦夜話",
                "author": "――漱石先生に関する事ども――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもひどく要領のいいやつで、うしろのほうへ来て、足ぶみなんかしてしきりに下知している。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神谷は、既に千久馬から聞いたあらましの事情を、なほ腑に落ちないところがあると云つて、要領のいい質問をした挙句、「深水の奴、近頃神妙な顔をしてますよ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり要領のいい稀代の大才人と言つてもよいのかも知れない。",
              "citation": {
                "source": "管見芭蕉翁",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むやみに長時間コキ使うことは発展性のある真面目な社員を逃がして要領のいい人間しか集め得ないで、大局的に非常な不利に相違ない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、朝倉夫人が座ぶとんをすべって初対面のあいさつをしたが、くどくない、要領のいいあいさつだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "その魯迅の三篇は書題になつてゐる Ah Qui の外にわたくしの訳した Native Country の外の一篇は Con Y Ki で、魯迅を欧洲に紹介するとしたら先づ要領のいい選択であらうと思ふ。",
              "citation": {
                "source": "魯迅の「故郷」や「孤独者」を訳したころ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "要領のいい者は成り行きに任せ、在庫を提供し、涼しい顔で底をついたと言う。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、要領のいい庶民たちは、こういって見分けている。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
