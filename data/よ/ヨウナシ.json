    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unnecessary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さすれば我はこの家に用無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼邦の制、天子の屋は、葺くに黄瓦を以てす、旧瓦は用無し、まさに黄なるに易るべし、といえる道衍が一語は、時に取っての活人剣、燕王宮中の士気をして、勃然凛然、糾々然、直にまさに天下を呑まんとするの勢をなさしめぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄病院で、生まれ落ちた赤んぼを渡された時でさえ、彼女は『ふん、もう用無しだわ！",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに腕の良い６人も用無しか。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『所で、その後、貴公は何うだ』『この通りに――』　と、一学は両膝へ手を張って、『健在だ』『貴公は、酒が飲けるからよい』『酒でも参らずば、退屈で何うもならん』『御用無しか』『用のあろう筈がない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日　今日のようなしめっぽい空気には墓の匂いが籠っておるように思う。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは息もないようなしずかな寝姿であり、見る目｜憚らぬこどものように仰き踏みはだかった無邪気な寝姿でもある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体自分の求めているようなしみじみとした絵は、こういう処では始めから得られないにきまっているのかもしれない。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧民窟の掘立小屋の高粱稈の風よけのかげでは、用便をする子供が、孟子も幼年時代には、かくしたであろうと思われるようなしゃがみ方をして、出た糞を細い棒切でいじくっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁って、生でのめるようなしろものじゃなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはもう聞えないくらいの低い物言いで隣りの主人からは安心に似たようなしずかな波動がだんだんはっきりなった月あかりのなかを流れて来た。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれらのはなしが金字の厚い何｜冊もの百科辞典にあるようなしっかりしたつかまえどこのあるものかそれとも風や波といっしょに次から次と移って消えて行くものかそれも私にはわかりません。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、さし当たってそういう土民に鉄筋コンクリートの家を建ててやるわけにも行かないとすれば、なんとかして現在の土角造りの長所を保存して、その短所を補うようなしかも費用のあまりかからぬ簡便な建築法を研究してやるのが急務ではないかと思われる。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバリカンは、もう五、六年まえから、ひどく調子が悪く、ときどき、ぐわッと大きくかみついて、とることもどうすることもできなくなってしまうようなしまつでしたので、ふたりは、家でかみをかることを、あまり好んではいませんでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町はもうやがて冬になるとさびしいし、おまえのようなしなやかなきれいな鳥はいたたまれまい。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはどうかしてもっと勉強のできるようなしかたをみんなでやりたいと思う。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　栗栖は言っていたが、やっぱり呑み足りなくて、今一本取り、さっぱりしたようなしないような気持で、結婚の話を持ち出す汐を失い、銀子に爪弾きで弾かせて、歌を一つ二つ謳っているうちに時がたって行った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は聖餐のような厳かさと、ランデブウのようなしめやかさで執り行われて行く。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気をつけ遊ばせ」と、ちょっと何か払うようなしなやかな手つきをして、更に女中の持って来た果物を勧めたりした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をはいると、昨日より力のない、ひきつるようなしゃっくりの声が聞こえて来ました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がどのようなしくじりをしても、せせら笑って彼を許した。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のこのようなしぐさは、自然である。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "修理　一大事とも言いようなし。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小路は家を切開きて、山の手の通りに通ずるようなしたれば、人通いと繁く、車馬の往来｜頻なり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして花田の肩を女のようなしなをして打って行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気違いなればこそ京子が、少女のようなしなをしても、それが少しも不自然ではない。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水銀を飲まされたようなしわがれた声で、「――豚箱へはいって、面白そうに笑う人がおすか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁治郎横丁は千日前歌舞伎座横の食物路地であるが、そこにもまた忘れられたようなしもた家があって、二階の天井が低く、格子が暑くるしく掛っているのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店や料理店の軽薄なハイカラさとちがうこのようなしみじみとした、落着いた、ややこしい情緒をみると、私は現代の目まぐるしい猥雑さに魂の拠り所を失ったこれ等の若いインテリ達が、たとえ一時的にしろ、ここを魂の安息所として何もかも忘れて、舌の焼けそうな、熱い白味噌の汁に啜りついているのではないかと思った。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、チョークを取って来て、町じゅうのどの家の戸にも、みんな同じようなしるしをつけて歩きました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
