[
  {
    "uuid": "4f9b4907-6a42-5c34-a214-9f6f721c1d2d",
    "entry": "用無し",
    "reading": {
      "primary": "ようなし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
