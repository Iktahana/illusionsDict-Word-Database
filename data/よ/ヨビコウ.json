    "definitions": [
      {
        "index": 1,
        "gloss": "preparatory school (for entrance examinations)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むす子が、だいぶ経験も積んで、巴里郊外の高等学校の予備校の寄宿舎に、たった一人日本人として寄宿した経験談も出た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等予備校に通って、高等学校の受験準備をするのが目的であった。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど大学校にはいる前の予備校である。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正則英語学校予備校に入ったこの時の有三は幾何というものを知らなかった。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも、武揚学校という名古屋での陸軍予備校から来たもので、その友達が多かった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の正則予備校を始めその用意をする学校はいくらもある。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男の一彰さんという人は、予備校のどこかへ通っている十六の年、脚気になった。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大震災の年に丁度上京してゐた私を頼つて修一も上京し、新聞配達をしつゝ予備校に通つてゐたが、神田で焼き出されて本郷の私の下宿に遁れて来た。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、どこに腰を落ちつけるあてもない自分自身の事情と、両親の叱責と期待に折り合いをつけて、浪人として予備校に通うことになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校に通うと称して、祭りの夜店のようないかがわしさと勢いにあふれた裏道の店を覗き回っていた当時、秋葉原にはＩＣ電卓のジャンクが出回るようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校の帰り、小遣いの範囲で収まるジャンクを買ってきて利用できる部品を抜き取り、松本は電卓の基本的な動作を実行する回路を作ってみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋葉原通いの寄り道先が予備校から大学に変わったのを機会に、松本はかねてから胸にためてきたライターへの挑戦を実行に移そうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他にも名は覚えていないが、錦城中学に一人、普及英語に二人、正則の予備校の受験科に一人といった風に思い思いの学校を選んでいた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして徴兵検査の関係やなんかもあるので、どこかの予備校にはいって勉強した上、来年の春商科大学の入学試験を受けるつもりでいる。",
              "citation": {
                "source": "香奠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年予備校がそんなにえらいか。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの年の入学試験を受けるために、半年くらいしてから、東京へ出て予備校というものに通ってみた。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校は、某私立大学の中にあったので、私立大学の学生の生活というものも、垣間見ることが出来た。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校時代にもいろいろな収穫があったわけである。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校が大いに役に立った次第である。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学予備門のまた予備校みたいな所に入って、簡単な勉強をし、それから大学予備門にいっていたようだが、その留守中、私は井上家を一番の娯しみの場所にして出入した。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生生活はサラリーマン生活の予備校に過ぎなくなった。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが云って見れば学生のこの予備校的存在は、当然と云えば当然なようなものである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三一年に於ける大学の入学生は一五万七千名で、三二年には夫が二三万人に増加しているし、同じく三二年に於て工芸学校は四二万人、大学労働者予備校（worker's koculties）は三五万人、商・工・業学校は一〇〇万人の入学者を必要としている、云々。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分の細かい心理状態や、予備校の学生仲間にある、特殊な、彼自身の趣味とは全然合わない恋愛病的雰囲気などについて、信頼に満ちた穏やかさと、若々しい正直さとをもって話した。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大学には英語を勉強するための予備校が付属しているので、大学に入る学生は一人のこらず英語を了解していなくてはならない。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "図236と図237とは、予備校へ行っている少年たちを写生したものである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はすべて、英語の方が、より正確だといい、英語を教える、大学の予備校へ行っている少年達は、その方が容易な為に、好んでお互同志英語の手紙を書く。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "光江は陽子の幼馴染で小学校から高校までずっと一緒だったが光江の方は大学受験に失敗し、高校を出ると予備校に通うようになった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "後になって、光江の自殺の原因が予備校で知り合った男の友人との仲がうまくいかなくなったことに関係があったと分ったときも、陽子は自分を責め続けた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
