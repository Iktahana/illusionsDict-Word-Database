[
  {
    "uuid": "150f3327-f354-5386-98f4-80867cbfcdc6",
    "entry": "妖怪",
    "reading": {
      "primary": "ようかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
