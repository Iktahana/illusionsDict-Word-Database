    "definitions": [
      {
        "index": 1,
        "gloss": "late at night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｓ＝茶店内部　夜更けて――　表戸を開けて七五郎のお袋のお勘婆さんが顔を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後教師都に帰りてより幾年の月日｜経ち、ある冬の夜、夜更けて一時を過ぎしに独り小机に向かい手紙｜認めぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂をなかば偽りとみるも、この事のみは信なりと源叔父がある夜酒に呑まれて語りしを聞けば、彼の年二十八九のころ、春の夜更けて妙見の燈も消えし時、ほとほとと戸たたく者あり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「夜更けてこッそりお詣りすると」Ｔ「必ッと願いが叶うんですッて」　「そんな馬鹿な事」　伊吉は信じない。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから夜更けて湯へゆくことはその抵抗だけのエネルギーを余分に持って行かなければならないといつも考えていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは溪の上にだるま茶屋があって、そこの女が客と夜更けて湯へやって来ることがありうべきことだったのである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　どうして喬がそんなに夜更けて窓に起きているか、それは彼がそんな時刻まで寝られないからでもあった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて彼が便所へ通うと、小窓の外の屋根瓦には月光のような霜が置いている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野の冬の夜更けて星斗闌干たる時、星をも吹き落としそうな野分がすさまじく林をわたる音を、自分はしばしば日記に書いた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて山から出て来た猪が、年の若さの向う不見、この女に恋をして、座敷で逢えぬ懐中の寂しさに、夜更けて滝の家の前を可懐しげに通る、とそこに、鍋焼が居た。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　旧藩の頃にね、――謡好きのお武家が、川べりのその土塀の処を、夜更けて、松風、とかをうたって通ると、どこかそこの塀の中――中ならいいんですけど、壁が口を利くように、ウウと、つけ謡でうたうんですとさ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ山家の旅の宿りに積薪夜更けて寢ね難く、起つて簷に出づ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて、引け過ぎに歸る時も、醉つて、乘込む時も。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく病気のためだったろうが、その頃は毎夜の様に不眠に苦しめられていて、その晩も、夜更けてから宿を抜け出ると、海岸の砂浜に打ち揚げられた漁船の艫に腰を掛けて、何となく海を見ていた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて物思いにふけっていると、裏の畑で狐が鳴きます。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて氷嚢を取り更えるのにも旻は眼を大きく輝かせて、若しそれが幸子以外の者である時にはひどく機嫌が悪かった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は毎晩々々夜更けてから、血の気のない程に蒼ざめて帰って来、私にご飯を食べさせてくれた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　姉は、夜更けてから、血の気の失せた顔をして帰って来て、私にご飯をたべさせてくれた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、今夜からは夜更けて姉が帰って来る憂いはない。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠れない夜の續く枕許に、休息のない水の流れの、夜更けて淙淙といふ音をきく時、いかに多くの詩人たちが、受難者として生れたところの、自己の宿命を嘆くであらう。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子が、起きてから珈琲を沸すのが面倒な朝や、夜更けて帰りしなに立ち寄るかも知れない小さい箱のようなレストランや、時には自炊もするであろう時の八百屋、パン屋、雑貨食料品店などをむす子に案内して貰って、一々立ち寄ってみた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌晩、夜更けて私を起しますから、素よりこっちも目を開けて待った処、直ぐに支度をして、その時、帯をきりりと〆めた、引掛に、先刻言いましたね、刃を手拭でくるくると巻いた鎌一｜挺。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此を隠謀の参謀本部として、豚汁をつついては密議を凝らし、夜更けて雨でも降れば、よく二人で同じ蒲団に雑魚寝をしたもの。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けての後なり、ふとしたる事より、はしなく談音楽の上に移るや、伯林よりの土産とか云ふ秘蔵の蓄音機を取り出して、特に我がために数番の曲を撰んで聞かせられたり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ここで逢うのは、旅路｜遥な他国の廓で、夜更けて寝乱れた従妹にめぐり合って、すがり寄る、手の緋縮緬は心の通う同じ骨肉の血であるがごとく胸をそそられたのである。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けては帰るに路のほど覚束なしとて、商して露店しまえば、そのまま寝て、夜明けてのち里に帰るとか。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、帰りは夜更けて、赤電車で、日本橋一丁目で降りて、野良犬やバタ屋が芥箱をあさっているほかに人通りもなく、しーんと静まりかえった中にただ魚のはらわたの生臭い臭気が漂うている黒門市場をとぼとぼうなだれて行くのだが、雪の日などさすがに辛かった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼る所はなく一部屋貸してくれと、田村へ転がり込むのはまだいいとして、章三を見た翌日、夜更けて貴子の寝室へ忍び込んで、こっぴどくはねつけられ、田村をおん出てしまう羽目になったのは、何としてもだらしがなさすぎた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍馬が土佐で咏んだ歌に、さよふけて月をもめでし賤の男の　　　庭の小萩の露を知りけりと云ふのがあります。",
              "citation": {
                "source": "千里駒後日譚",
                "author": "楢崎龍、川田雪山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
