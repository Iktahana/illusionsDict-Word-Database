      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "assistant engineer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、蠅はわれわれの五体をワクチン製造所として奉職する技師技手の亜類であるかもしれないのである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別な家柄でもなく一介の土木技手上りに過ぎない貧乏な作家と、大地主で大金持で伯爵の名門に生れた作家と、その呟きには何か胸を打つものさへあるが、とにかくドストイェフスキイは時には境遇的にも自分の原稿を讀み返す暇さへ持てなかつた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ江藤さんは妾になったという噂が誰の口からともなく起って、朋輩の者皆んな喧噪く騒ぎ立てた、遂に係の技手の耳に入った。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで技手の平岡は田川お富に頼んで、お秀の現状を見届けた上、局を退くとも退かぬとも何とか決めて呉れろと伝言さしたのである。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一その筒の傍に立って、花火の打上げを担当している二人の技手からが、洋服に、スエター、半ズボンというハイカラな服装である。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船首の技手は筒の掃除をする。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職技手こぞりてひとを貶しつゝ、　　　わかれうたげもすさまじき、おのれこよひは暴れんぞと、　　青き瓶袴も惜しげなく、籾緑金に生えそめし、　　　　　代にひたりて田螺ひろへり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　技手農婦らに令しけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と技手云へば、種子やまくらんいこふらん、　　　　ひとらかすみにうごくともなし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すればはえはわれわれの五体をワクチン製造所として奉職する技師技手の亜類であるかもしれないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的な仕事は技師技手に任せておけばよいというようなことになったのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に関する理解のはなはだ薄い上長官からかなり無理な注文が出ても、技師技手は、それはできないなどということはできない地位におかれている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "技師一人技手一人と測量人夫六名ないし十名ぐらいの一行でテント生活をする。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡役所の技手の、乗馬ずぼんをはいた足よりまだりっぱだ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年、三十一年にめでたく学校を卒業し、電気部の技手として横浜の会社に給料十二円で雇われた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかの給料でみずから食らい、弟を養い、三年の間、辛苦に辛苦を重ねた結果は三十四年に至って現われ、五郎は技手となって今は東京芝区の某会社に雇われ、まじめに勤労しているのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡役所の技手の、乗馬ずぼんをはいた足よりまだりつぱだ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はその三年目、仕事の都合でとうとうモリーオの市を去るようになり、わたくしはそれから大学の副手にもなりましたし農事試験場の技手もしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると木村博士と気象の方の技手とがラケットをさげて出て来ていたんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はしばらく見てたねえ、どうしてもその技手の人はかなわない、まるっきり汗だらけになってよろよろしているんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絶壁下には先頃まで鉱山事務所があったのだが、轟然たる山崩れと共にその事務所はメチャメチャになり、一人の技手は逃げ損って蛙のごとくに押潰され、その片腕とか片脚とかは、かの巨巌の下に今なお取出す事が出来ず残っているという事だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度飛騨の国の山中、一小寒村の郵便局に電信の技手となって赴任する第一の午前。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "感ずる仔細がありまして、私は望んで僻境孤立の、奥｜山家の電信技手に転任されたのです。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかつかと進んで、驚いた技手の手を取って握手したのである。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
