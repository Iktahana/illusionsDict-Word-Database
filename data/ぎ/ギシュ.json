[
  {
    "uuid": "8b8091a6-82bd-55b3-bf40-8227f42c88c4",
    "entry": "技手",
    "reading": {
      "primary": "ぎしゅ",
      "alternatives": [
        "ぎて"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
