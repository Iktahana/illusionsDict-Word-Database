          "literary": [
            {
              "text": "幸いに井戸の水は良いので、七月から湯殿で行水を使うことにした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸に井戸の水は良いので、七月からは湯殿で行水を使うことにした。",
              "citation": {
                "source": "風呂を買うまで",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄や細君――女連は土台の腐れた古い湯殿で毎日行水を使うことになっていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は子供の時分からこの金盥を見て、きっと大人の行水を使うものだとばかり想像して、一人｜嬉しがっていた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は子供の時分からこの金盥を見て、きっと大人の行水を使うものだとばかり想像して、一人嬉しがっていた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この甕は夏まで水葵と称する水草が茂っていたがその後烏の勘公が来て葵を食い尽した上に行水を使う。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨があがると、気候は急に暑くなり、一日おきの入浴のほか、まいにち行水を使うことが許された。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例外はあるけれども、四季をとおしてたいがいは行水を使う。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
