    "definitions": [
      {
        "index": 1,
        "gloss": "staring (e.g. eyes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
