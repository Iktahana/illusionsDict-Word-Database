        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゴヰサギガ、下ノ　ハウノ　コホツタ　タンボデ　「キヨオ」ト　ナキマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　ヨモ、タンボデハ　ゴイサギガ　ナイテ　ヰマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコデ、ウサギガ　イタチノ　トコロヘ　ツカヒニ　ヤツテ　イキマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフ市から数十哩東にソヴェト一の大国営農場「ギガント」がある。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトは、社会主義生産の技術を高めて、やがて、一台のトラクターも外国から買い込まないようにするために、今暫く、国営農場「ギガント」に、アメリカ人技師の指導をうけているのだと。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、その夏、ウクライナの大国営農場「ギガント」を見学に行った。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギガント」事務所のわきにフォードの幌形自動車がとまって、踏段に片足かけ、パイプをほじっているのは、縞シャツのアメリカ技師だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギガント」から一時間ばかり汽車にのっかって行くと、「ウェルブリュード」という国営大耕地の真中に、農業機械専門学校がある。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフはウクライナ共和国の主都で、附近にはソヴェト第一の大国営農場「ギガント」があった。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がロストフへきていたのもその「ギガント」を見るためなのである。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギガント」で見たことはまた別のときに話すとして、その朝ドン煙草工場で見たことを、わたしはみなさんに聞いて貰いたいと思う。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏、クリミヤ及びドン地方の大国営農場「ギガント」へ見学旅行した。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目ノフシギガオコリマシタ。",
              "citation": {
                "source": "迷子ノジヤガイモ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ　イヂノワルイ　オサルサンガ、「ザウサンハ　タイヘン　オギヤウギガヨイトイッテ　ミンナガホメルケレドモ、バウシヲトルノニ　テデトラナイデ、ハナデトルデハナイカ。",
              "citation": {
                "source": "ザウサン　サルサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズヰブン　オギヤウギガワルイヤ。",
              "citation": {
                "source": "ザウサン　サルサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十五日　火　二人で ВОКС へ出かけ、ギガント〔ロストフの国営農場〕へ紹介状を書いて貰った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十一日　月　朝九時頃ギガント着。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十二日　火　ギガントよりウェルブリュードへ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが、わたしたちへの五ヵ年計画だったっていうわけね」　大国営農場ギガントの広大な美しい写真を眺めたり、富農からの没収品目を新聞でよんで、五ヵ年計画の奮闘に触れているように感じていた自分たち――少くとも自分というものを、伸子は段々自分の責任において批評し、滑稽を感じて笑えるようになって来た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シキリニ胸騒ギガシ、興奮ヲ覚エル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
