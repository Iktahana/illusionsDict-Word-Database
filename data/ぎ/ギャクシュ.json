    "definitions": [
      {
        "index": 1,
        "gloss": "holding a memorial service for oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
