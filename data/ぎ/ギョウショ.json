    "definitions": [
      {
        "index": 1,
        "gloss": "semi-cursive style (of writing Chinese characters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
