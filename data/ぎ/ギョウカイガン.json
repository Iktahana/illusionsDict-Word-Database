        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汽車はサクラメントの大河に沿うて走る、川の底には、堅い凝灰岩などが露出しているが、シャスタを距ること、五十｜哩位のところから、熔岩が、両岸に段丘を作っている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔この山は流紋凝灰岩でできています。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石英粗面岩の凝灰岩、大へん地味が悪いのです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うは安山岩の集塊岩、こっちは流紋凝灰岩です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜羽場がまた凝灰岩を拾ったな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩の温泉の為に硅化を受けたのだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩が青じろく崖と波との間に四、五｜寸続いてはいるけれどもとてもあすこは伝って行けない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この裂け目を通った温泉のために凝灰岩が変質を受けたんです。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林館開業凝灰岩もて畳み杉植ゑて、　　麗※六七なまめかし、南銀河と野の黒に、　　　　　その※々をひらきたり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂岩や凝灰岩の縞なども、やはりこれらと連関して徹底的に研究さるべき題目であろう。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔この山は流紋凝灰岩でできてゐます。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふは安山岩の集塊岩、こっちは流紋凝灰岩です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜羽場が又凝灰岩を拾ったな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩が青じろく崖と波との間に四五寸続いてはゐるけれどもとてもあすこは伝って行けない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは白い凝灰岩をきり開いた室でたしか四十坪はあると署長は見てとった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩を四角に組んだ窓は雪のある庭に向つてゐた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角に凝灰岩を組んだ窓は枯芝や池を覗かせてゐた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Le diable est mort」　凝灰岩の窓の外はいつか冷えびえと明けかかつてゐた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩を四角に組んだ窓は雪のある庭に向っていた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角に凝灰岩を組んだ窓は枯芝や池を覗かせていた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Le diable est mort」　凝灰岩の窓の外はいつか冷えびえと明けかかっていた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この熔岩流の中へ来て見ると熔岩の集団はいよいよ生々しいどころではなく、同じ安山岩であっても、角閃石に多くの黒雲母を雑えた、また構成の比較的｜脆弱なもので、殊に凝灰岩をもまじえているので、風化浸蝕作用は案外早く行われ、岩石という岩石は悉く蘚苔をつけていないものはないのである。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の三部落を統一して、凝灰岩の城壁を繞らし（その城壁の一部は今も残っていて見られる）、一つの町を造り上げた。",
              "citation": {
                "source": "パラティーノ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩に堅くて黒い礫を孕んでいる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石仏は中央に大きな薬師如来、左右に不動明王、毘沙門天のかなり大きな像が彫ってあるのだが、凝灰岩の粗質な岩に彫ってあるため左右の像は首が落ちたり磨滅したりして殆ど原形を存しないのであるが、ただ中央の薬師如来だけは、片頬に大きな傷のあるほかは、まず完全な形を存しているといって好い。",
              "citation": {
                "source": "別府温泉",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の庭という、まっ白な、凝灰岩の庭を見て、板縁づたいに、そのまま辞して外へ立ち出る。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
