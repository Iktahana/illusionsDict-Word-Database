[
  {
    "uuid": "d6db6afc-8baa-5f5c-af02-fff587686ec5",
    "entry": "擬する",
    "reading": {
      "primary": "ぎする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
