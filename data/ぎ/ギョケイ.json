[
  {
    "uuid": "971062ee-234a-59df-9746-2db32720648d",
    "entry": "御慶",
    "reading": {
      "primary": "ぎょけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(New Year's) greetings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勿論｜私に兵仗を動かした責罰｜譴誨は受けたに相違あるまいが、事情が分明して見れば、重罪に問ふには足ら無いことが認められたのに、かてゝ加へて皇室御慶事があつたので、何等罪せらるゝに至らず、承平七年四月七日一件落着して恩詔を拝した。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八拾円ニテ、マント新調、二百円ニテ衣服ト袴ト白｜足袋ト一揃イ御新調ノ由、二百八拾円ノ豪華版ノ御慶客。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間並のお世辞上手な利口者なら町内の交際ぐらいは格別｜辛くも思わないはずだが、毎年の元旦に町名主の玄関で叩頭をして御慶を陳べるのを何よりも辛がっていた、負け嫌いの意地ッ張がこんな処に現われるので、心からの頭の低い如才ない人では決してなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか新春の日も昼をすぎて、行きついたその四ツ谷ご門あたりは飄々、颯々とめでためでたの正月風が、あわただしげに行きかわす中間小者折り助たちのすそを巻いて、御慶の声をのせながら吹き通りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宮殿下の御慶事の朝のことである。",
              "citation": {
                "source": "孟宗と七面鳥",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌は、おだまきの花には桐ノ舎ガ妻ヲ迎ヘシ三年前カキテ贈リシヲダマキノ花という歌、これは一昨年の春｜東宮の御慶事があった時に予が鉢植のおだまきを写生して碧梧桐に送り、そのまさに妻を迎えんとするを賀した事があるのを思い出したのである。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新年の御慶重畳申収候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ入院のときあずけたものをもって来てかえし、御慶祥とした包みをお祝としてくれた。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんてらや師走の宿に寐つかれず酒を呼んで酔はず明けゝり今朝の春甘からぬ屠蘇や旅なる酔心地うき除夜を壁に向へば影法師　御大喪中とある故此春を御慶も言はで雪多し　一年の計は元日にありと申せば随分正月より御出精、明治三十一年の文壇に虚子あることを天下に御吹聴｜被下度希望の到りに不堪候以上。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新年の御慶目出度申納候。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、堅実なる第二国民の養成を天職とする全国二十五万の小学校教員は、三万六千余名の代表者を送って、昭和聖代の御慶事　皇太子殿下の御降誕を奉祝し併せて忠君愛国の日本精神を昂揚して教育報国の誠を示す処の小学教員精神作興大会をば、神武天皇祭（四月三日午後二時）を期して宮城二重橋前広場で持つことになった。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金が入っているらしい様子で、上に御慶祥と書いてあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、新年の御慶となつたわけだが、何がさて今日は十一月の十二日だ。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　×　　　　×　改めて、新年の御慶を申上げよう。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "改心の御慶目出度申納候。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ松の内なので、御慶の客はちらほら絶えないが、茶わん屋の奥には、妙にしいんと冴えない陰が漂っていて、主人の捨次郎もむっそり顔しているし、いつも陽気な御寮人の姿も見えない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よい初春空でございますな」　信長がそんな考えに耽っていたとき、うららかな陽ざしを背にして、佐久間｜信盛が、この高閣の一間へ御慶を述べに来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず総見寺｜毘沙門の舞台から見物し、表之門から三之門に入り、御殿主から白洲まで来て、ここで、御慶を申しあげる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、よい折に」　本丸の大書院前で、出会いがしら、こう初春らしい声で、御慶を陳べおうている諸侯があった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、義通から年頭の御慶をのべます。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのうえで、十日の御慶事なども心から共によろこび合いたい。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
