        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西銀座の「きゆぺる」の二階で会つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、月曜日には飲み過ごしの後、銀座の酒場で、乱暴を致し、その翌日は心佗しく、独りでゐるに絶えられず、而もその銀座の酒場に一緒に行つた、津濃といふ友人の所へどうも行つてゐたく、勝手なこととは承知しながら、出掛けて行つて、ぐづぐづしてゐた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は銀座の裏通りのカフェー、卓子の上で扇風器は、哀しげな唸りをつづけてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は銀座を歩いてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて彼と銀座で逢い、「なんてまあ哀しい男だろう」と思い、私も、つらくてかなわなかった。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、馬場とシゲティとは共鳴をはじめて、銀座一丁目から八丁目までのめぼしいカフエを一軒一軒、たんねんに呑んでまわった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座通りといふ賑やかな美しいまちがある。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――銀座松坂屋の屋上にて――無用の書物蒼白の人路上に書物を賣れるを見たり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へ帰ってどうすると云うあてもないので、銀座通りをぶらぶら歩き、大店のガラス窓の中を覗いてみたり雑誌屋の店先をあさってみたり、しばらくはほとんど何事も忘れていた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雨の中を頭からぬれひたって銀座通りを歩いていてもだれもとがめる人もなければ、よけいな心配をする人もない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐田太左衞門氏は、ゆゐしよある老舖の御主人にして、これまた、長者のふうあり、もののわかりのよきこと無類、三四年前、私と一緒に銀座うらを漫歩せしことありしが、私をしてまるで、鏡花、荷風などの老文士とともに在るが如き思ひを懷かしめた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○折角ハイキングに行っても、帰って来て是非銀座へ寄らねば何となく物足り無い。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕があくと舞台は銀座街頭の場面だそうで、とあるバーの前に似顔絵かきと靴磨き二人と夕刊売りの少女が居る。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の銀座の鋪道であんな大声であんな媚態を演じるものがあったら狂女としか思われないであろうが、ここは舞台である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座を追われた靴磨き両人に腹を減らさせて浜町公園のベンチへ導く。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エピローグとして最初と同じ銀座鋪道の夜景が現われる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし吾々人間にこの半分の能力があれば、銀座の四つ角で自動車電車の行き違う間を、巡査やシグナルの助けを借りずとも自由自在に通過することが出来るにちがいない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　銀座四丁目から数寄屋橋まで歩いて、それから廻れ右をして帰って来るとやはりもとの同じ銀座四丁目に帰って来る。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある店屋の主人は、銀座の十一屋にでも行ったらあるかも居〔知〕れないと云って注意してくれた。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし銀座を歩いている二人の洋装婦人のチューインガムが何を意味するかはどうしても分らない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼前に銀座まで出掛けたら諸所の店前の立看板などが吹き飛ばされ、傘を折られて困っている人も少なくなかった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は日本人の顔がだんだんに西洋人に似てくるようで、銀座などを歩いているとあちらの映画スターに似たような顔つきをした男女を見かけることも珍しくないがただ髪の毛だけは、当り前のことだが皆申し合せたように真黒である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日君と銀座へ行くにきめた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座あたりの堂々としたカフエーには、どうしてもきまりが惡く、氣が引けて這入れないのださうである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき銀座界隈へまで出掛けることもある。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ私が銀座でシルクハットのうえ、チャルストンを踊っていたころ、友達の横田は亜米利加の流行女達の間に東洋人を情夫に持つことが紐育の社交界に風靡しだすと忽ち渡米してしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット銀座の情婦、無智な妖婦から電話がかかってくる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎんざの大きなほうせきやのまどガラスが、ガチャンとわれました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人どおりのないぎんざどおりを、ロボットは、すごいはやさでにげていきます。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
