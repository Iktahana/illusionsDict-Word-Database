[
  {
    "uuid": "5c1a3d04-869f-5aca-842a-b9cb0a763ce1",
    "entry": "仰視",
    "reading": {
      "primary": "ぎょうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "looking up to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "惜しむらくは下流に立ってこれを仰視し得る機会を得なかったことである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫びて、右手に巨勢が頸を抱き、己れは項をそらせて仰視たり。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我日本の中央を横斷する梁骨を一望に仰視する壯觀である。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵は陰暗の國に困臥して盜賊の輝ける姿を仰視する。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才は下瞰して與へ、凡人は仰視して受ける。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へばお前が中に居て敲いたとする、さうすれば私はお前を外へ出してやると云ふものだらう、ね』斯う話してる間も彼は絶えず空を仰視て居るので、愛ちやんは眞個に無作法な者もあればあるものだと思ひました。",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野まき子さんは三輪田女學校に在る中から羨望仰視の中に立つてゐたが、小學校に教鞭をとるに至つてあたら天才は縮んでしまつた。",
              "citation": {
                "source": "女子文壇の人々",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの一｜刹那の仰視ではあったが、わたしの眼には今でもはっきり印象が遺っている。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄徳は、仰視していた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のブル新聞は、鮮銀と、漁業会社に肩を持って、ぎょうぎょうしげに問題を取り上げていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば書籍雑誌の広告にしたところで、おそらく日本ほど多数でぎょうぎょうしいのはどこの国にもないかもしれない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして広告のぎょうぎょうしさと書籍の内容は必ずしも伴なわない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式場のぎょうぎょうしくて派手で、それでいて実に陰惨でグロテスクな光景もよくできている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の伯母たちが何かというとぎょうぎょうしく階段や廊下を駆け回る。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その警戒の方法は時代によって多少の相違があったらしいが、ともかくも普通の獣狩とは違って、相手が飛行自在の猛鳥であるから、ぎょうぎょうしく立ち騒いで、かれらをおどろかすのは禁物である。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものものしさ、ぎょうぎょうしさ、総立ち会い総吟味の顔は並んでいるが、六十日間責めつづけて自白しないものを、証拠の合わないものをいまさら責めてみたとて、自白するはずもなければ、ないものをまた罪に落としたくも落としようがないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょうぎょうしくて、しかも愚劣であったのは「恋人の日記」である。",
              "citation": {
                "source": "映画の恋愛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の版画はその材料として都会のどぶ板に使う石版を使うからといってウィルヘルム二世から「どぶ石芸術の画家」といわれたケーテは、今やドイツの誇りとして、あらゆる方面からのぎょうぎょうしい新たな称賛と敬意とを表された。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横にその方へ向いてぎょうぎょうしく立ち停ったのだが、女が笑いながら行ってしまうので、自分の目を放して言葉でだけ追いかけさせた、「今一つお座敷があるので、な」「そう」という返事は後ろに聴えていた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子たちは、裾を四角に切った短い上衣を着て、ぎょうぎょうしい真鍮のボタンをいく列も並べ、かみの毛はだいたい当時の流行にしたがって弁髪にむすんでいたが、特にそのために鰻の皮を手に入れることができればなおのことであった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、村民各自に自警団を組織するほどのぎょうぎょうしいことはまだ木曾地方にはない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿の頬にある人参や、犬の寝床の下にある骨を私有財産と呼ぶことは、いかにもぎょうぎょうしいようで、つねに某の財産は何千万円あるとか、某の身代は幾百万円あるとかいうことのみを聞き慣れている読者の耳には、ほとんど滑稽に聞えるやもしれぬ。",
              "citation": {
                "source": "動物の私有財産",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは篶竹取りの道だと兼て教えられていたので、左に登り初めると「右すす山道、左かんこうじぎょうしよ」（官行事業所ならん）と書いた札が立ててあった。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩の味のことなどを、こうぎょうぎょうしく書きたてるのは、あまりいい趣味ではないかもしれない。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、みんなはふたたびまわりに集まって、そんななかでドードーはぎょうぎょうしく指ぬきをさしだして、こんな言葉。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリスには何から何までむちゃくちゃだと思えたけど、みんなまじめな顔をするもんだから、ふき出すわけにもいかなくて、でも何も言うことが思いつかないから、とりあえずおじぎをして、指ぬきを受け取って、できるだけぎょうぎょうしい顔をする。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭兵は気短に、給料の下渡をぎょうぎょうしく催促して、4820それを払ってしまったら、皆逃げてしまいそうにしている。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "セエラがぎょうぎょうしく教室に入って行くと、上級の少女達は肱をつきあいました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の者はぎょうぎょうしい服装をして肩を並べていたが、そのこしらえはひどく時代のついた珍らしいものであった。",
              "citation": {
                "source": "汪士秀",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし目的がドン・アントニオの生命にのみあるなら、なんのためのこのぎょうぎょうしい神秘であるのか？",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
