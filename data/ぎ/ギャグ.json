        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "各人、随分得手勝手な、無責任極まる与太を飛ばしましたが、結果に於ては出来上ったシナリオが想像以上に明るく面白く、ギャグなぞも案外垢抜けのした奴がありました。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（敬四郎のギャグを考える事）１１＝橋の上　仕出し二三人欄干から下を見て居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（敬四郎のギャグを考える事）11＝橋の上　仕出し二三人欄干から下を見て居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉七の不器用な冗談に笑ったのではなく、映画のつまらぬギャグに笑い興じていたのだ。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともまず最初に団結の力を認め、これを実行に移したものが資本家であったということは日本映画界が世界に誇るに足る珍記録であり、チャップリンといえどもとうてい企図し得ないすばらしいギャグではないか。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシャの天才もこんなギャグに思い至ることができなかった。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのすぐ直前、この人は古方家ではあるが諸人助けのために匙をとらないなど、落語家圓朝にしてはじめていい得る天晴れなギャグとおもう。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜に虎などはいかにも田舎者らしくわけが分らなくて、ギャグとしてもまた斬新である。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのギャグで茂左衛門の人柄をよろしく見せておき、のちに寺でこの男がつきっ切りでへんな画題ばかり註文するゆえ、彩色は後廻しにてまず天井の墨絵の龍から描く、それが素晴らしい怪談を生むに至るとこういう段取りになるのだから、効果は一石三鳥といっていい。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり毎晩毎晩同じ顔付けの寄席へばかり行っていたもので、とうとう一夜、誰がどんなギャグを言おうと全然笑えなくなってしまった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういっても、出てくる人出てくる人のギャグをひとつひとつ笑い得た。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、彼のギャグのおもしろさがもうこの時に立派な萌芽を示していると思う。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寝床」「らくだ」の彼の独自なギャグや扱い方についてはすでに他に書いたが、「町内の若い衆」の下層街のおかみさんの活写とその警句百出に至っては、ちょっと他に類をみない。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強情灸」で灸の熱さを説く男が、「熱いのなんのってこの間なんか、あまり熱いンでバーッと飛び上がって天井を蹴破ってそのままどこかへ行っちゃった男がある」　なども、彼のギャグのすばらしさの最たるものだろう。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ三枚目を叱る時の目が少しこわすぎること、それとこの人は時々せっかくの三枚目のギャグをムダに（表現で）してしまうことに新しく気づきました。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事のまくらが、「道灌」のギャグと同じちょっと呼吸に損な点があるが（必ず次回にこちらの註文の出し方を掴んでみます！",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔のお笑い番組のギャグですよ。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさんのコメディアンがやるギャグです」「ほんとだと、この私が言ってるじゃないですか」「信じませんね」「ナナエちゃんいますか、などと自宅に電話をしたら駄目よ」「なぜ？",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野崎村」もう少し念入りにギャグを練るんだったと後悔する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スラ／＼と運びすぎるし、ギャグも少かった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凸凹」のウインナの景、「カティンカ」のギャグが、昨日見た「花詩集」にもあったので一寸驚いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も之は白井鉄造から教はったギャグだったが。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は、中に「瀕死の猫」なるバレーを入れる等ギャグ多し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドラマティック・ギャグあれど、デッサンが確りしてないのと、所と時を得て行はれないので皆ピンと来ぬ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春は朗らか」一巻、之にアフレコで説明を入れる、いゝ仕事じゃないが、言葉のギャグを考へ／＼、三時近くまでやって、漸くチョン、労れて帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居としては、一景の氷柱のギャグが一ばん成功した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青春」の幕切のギャグ一々受ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌だけでは自信がなかったので、ギャグを用意しといた、拍手多し、三部の「歌ふ弥次喜多」は、久しぶりなのでセリフがつまって可笑しかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "引込みのギャグは大受け。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「河内山」は、日野が倒れて柏が質屋の女房を代役したので、それに気をとられ、大切なギャグを忘れた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
