    "definitions": [
      {
        "index": 1,
        "gloss": "duty and humanity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その数々の線の一つずつには、線の両端に居る人間の過去現在未来の喜怒哀楽、義理人情の電流が脈々と流れている。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば昆虫の生活といったようなものは人間の義理人情とはなんの関係もないことである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理人情の着物を脱ぎ捨て、毀誉褒貶の圏外へ飛び出せばこの世は涼しいにちがいない。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日汗水たらして働いた後にのみ浴後の涼味の真諦が味わわれ、義理人情で苦しんだ人にのみ自由の涼風が訪れるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理人情の世界、経済の世界が大阪ではない。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか殺そうとまで計画しなかったけれども、そんなに義理人情を弁えない兄夫婦であるならば、その無節操な嫂に対して敢えて不倫を行ったところで、自分の良心に恥ずべきところは些もない筈だと考えて、窃に機会を待つことにした。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり芝居にあるような義理人情に追いつめられたんじゃないか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟妹たちと映画を見にいって、これは駄作だ、愚作だと言いながら、その映画のさむらいの義理人情にまいって、まず、まっさきに泣いてしまうのは、いつも、この長兄である。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟妹たちと映画を見にいって、これは駄作だ、愚劣だと言いながら、その映画のさむらいの義理人情にまいって、まず、まっさきに泣いてしまうのは、いつも、この長兄である。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長順　ふむ、何を隠さう――徒らに俗世間の義理人情に囚へられ、新しき教の心もえ覚らぬ俗人｜原、あの老耄の痩首｜丁切り、吉利支丹宗へわが入門の手土産にな致さむ所存。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は金儲けのためには義理人情もない云々と書き立て、――それに比べると川那子丹造鑑製の薬は……と、ごたくを並べ、甚しきは医者に鬼の如き角を生やした諷刺画まで掲載し、なお、飽き足らずに「売薬業者は嘘つきの凝結」などと、同業者にまで八つ当った……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理人情に感ずること多きもの、情死の主人となること多きは、巣林子の戯曲之を証せり。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "捉ふるものは義理人情、逃ぐるに怯ならず、避くるに卑しからず、死を以て之を償ふ、滅を以て之を補ふ、情死は勇気ある卑怯者の処為なり、是を大胆なる無情漢に比すれば如何ぞや。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理人情を超越してしまうから他人の物も自分のものも区別が付かない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それは矢張形式に捉へられて、義理人情で縛られて、それから外へは一歩も出ることの出来ないやうな女である『三人妻』の才蔵のやうな女は、今では、花柳社会でも、前生紀の遺物のやうに思はれて残つて居る。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、牢名主はじめ同牢の者は、だれがやったか、どうしてやったか、匕首の隠し場所もちゃんと知っているであろうが、告げ口、耳打ちはいうまでもないこと、世間の義理人情とはまた違った義理人情を持っているこの連中が、ひととおりやふたとおりの責め方でたやすく口を割ろうとは思いもよらないことでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち自然その者は到底現世の義理人情に触着せずには終らぬ。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理人情は構わない、銭になれば何でもする。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てめえこそ他人のくせに余計な世話を焼くな」「おれは他人でも、庄五郎とはふだんから兄弟同様にしていたんだから、そのあとの世話をしてやるのが義理人情というものだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "横光利一氏など、義理人情至上性を昨今強調されるようであるが、日本固有の人情というものの中には、そういう意気地という、些かは颯爽たる分子もなくはないのである。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横光利一氏が本年一月『改造』に発表した「厨房日記」は日本的なるものとして又人間の知性の完全無欠な形として、封建時代の義理人情を随喜渇仰する小説であって、常識ある者を驚かしたが、当時にあっては、彼の復古主義も情勢の在りように従って「紋章」の中に茶道礼讚として萌芽を表しているに止った。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一家一糸も乱れざる」日常生活を自分に律したり、義理人情に溺れ込む快さに我から溺れ込むことを、人民の心のあたたかみにとけ合うことと思いちがいしたり、初老に近づく日本人の或る感情と民衆性とが危くも縺れあっていると思わせるところさえあるのである。",
              "citation": {
                "source": "文学の大衆化論について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢籍の素養や仏教教典の知識、神道乃至国学的思潮は勿論のこと、之につらなる詩歌、和歌、俳句、更に義理人情の教えとして公的解釈を与えられた※瑠璃歌舞伎までが、直接間接に教学を支配者的文化尺度としていることを、見落してはならぬ。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の半封建的義理人情は、どのように歴史のなかで、より人間性の積極な表現に向って揚棄されつつあるか、その現実の過程――「新しい人間」の成長のあとづけは、日本の歴史に典型的な絶対主義と軍国主義への人間的抗議を通じてこれもやはり社会主義リアリズムの課題である。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の感情教育、美的教育はその義理人情のムードと共に浄瑠璃によって養われたものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世相のこと、男女のこと、義理人情のこと、英雄主義のこと、もののあわれのこと、――教訓的なポーズを好まぬ、順直な父としてはそれが一番ふさわしかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つまり知性の到達出来る一種の限界まで行っている義理人情の完璧さのためにも早や知性は日本には他国のようには必要がないのだと思う」という迄に常軌を逸したのであった。",
              "citation": {
                "source": "「迷いの末は」",
                "author": "――横光氏の「厨房日記」について――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
