            {
              "text": "魚精は痩せた顔に澄んだ眼をあげ、老猿を仰いだ。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨猿の姿も、魚精のかげも幽黝の底に抹消された。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
