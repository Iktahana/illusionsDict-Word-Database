    "definitions": [
      {
        "index": 1,
        "gloss": "heavy eating and drinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
