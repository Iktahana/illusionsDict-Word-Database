          "literary": [
            {
              "text": "事実、あなたさまにこんなに大胆な銀行強盗の計画を見破っていただき、なおかつ未然に防いでいただいたのですから。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の友人と計画し、結局未遂に終った銀行強盗のこと。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして銀行強盗となると、こんな難しいことは他にないだろうな。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
