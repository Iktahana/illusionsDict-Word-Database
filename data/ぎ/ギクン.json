          "literary": [
            {
              "text": "そうして、ぎくんと飛び上がった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで――」と彼は尖った咽喉ぼとけをぎくんと動かして「きまりましたぞ」と云った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ついでに、役所にてたしかめて下さらぬか――カラフト航路の日取り、うわさによれば、あの堀何とかいうご仁、近く出発と承っていましたので」　そう云われた松岡はぎくんとしたように大野を見つめ、泣き顔になってうなずいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "山木はぎくんとした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラ十へ差し入れ、というので、私はぎくんときました。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、肝腎のいい場面を逸するであろう”　これを聞いた提督は、ぎくんとしたようであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、ぎくんと飛び上がつた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前をなのれ」　太刀川は、ぎくんとした。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、途中からであったが、「――約八十隻ノ潜水艦、約百五十隻ノ駆逐艦、ソノホカ大小ノ特務艦十数隻……」　ここまできいて、太刀川は、ぎくんとした。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野　（ぎくんとして立止る）文麻呂　どこへ行くつもりなのだ！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリョーシャは身内がぎくんと震えたように覚えた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
