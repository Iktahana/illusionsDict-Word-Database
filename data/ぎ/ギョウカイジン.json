      {
        "index": 1,
        "gloss": "person in the business (entertainment, music, film, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
