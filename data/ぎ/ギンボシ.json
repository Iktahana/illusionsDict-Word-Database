      {
        "index": 1,
        "gloss": "win over an ozeki by a rank-and-file wrestler",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
