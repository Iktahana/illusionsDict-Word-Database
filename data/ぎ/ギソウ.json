    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ceremonial equipment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "住居の中の設備も、移って来る日の儀装のことも源氏は他の夫人に劣らせなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとから言うと、救命艇など一隻も要らないのだが――実際このタイタニックが救命艇などというものを載んでいることだけで、一部の人の眼には、猫を笑わせるに足る莫迦ばかしいことに映った――タイタニックにボウトなんて不必要な用心、しかし、これも一つの習慣的儀装であろう。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の儀装の列ははなやかなものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房三十人、童女と下仕えが八人ずつ侍していたのであるが、また大将家からも儀装車十二に自邸の女房を載せて迎えに出した。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大礼の則る所は古典にあつて、中古以来、儀装・冠服皆唐制に拠つたのを廃せられた。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀装をこらした小八葉の輦は、そうして、道程にすれば実に短い――時間にすれば何万何千里にも値する歳月の遥けさをとおって、吉水禅房の前に着いた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "招かれれば、呉将軍たりと、いつでも都へ上らねばならぬ、然るときは、相府に身をかがめ、位階は一侯を出ず、車数乗、馬幾匹｜定め以上の儀装もできません。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ぜひなく幕軍も儀装をととのえ、やっと入京の運びとなったものであろう。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが看板で、小屋の正面に、鼠の嫁入に担ぎそうな小さな駕籠の中に、くたりとなって、ふんふんと鼻息を荒くするごとに、その出額に蚯蚓のような横筋を畝らせながら、きょろきょろと、込合う群集を視めて控える……口上言がその出番に、「太夫いの、太夫いの。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると狸の子はまたふしぎそうに「だってぼくのお父さんがね、ゴーシュさんはとてもいい人でこわくないから行って習えと云ったよ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年紀は二十八九、三十でもあろう、白地の手拭を姉さん被にしたのに額は隠れて、あるのか、無いのか、これで眉が見えたらたちまち五ツばかりは若やぎそうな目につく器量。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……羽織は、まだしも、世の中一般に、頭に被るものと極った麦藁の、安値なのではあるが夏帽子を、居かわり立直る客が蹴散らし、踏挫ぎそうにする……　また幕間で、人の起居は忙しくなるし、あいにく通筋の板敷に席を取ったのだから堪らない。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は母者人の乳房にもみずからすすんでしゃぶりつくようなことはなく、母者人のふところの中にいて口をたいぎそうにあけたまま乳房の口への接触をいつまででも待っていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が終ったとき、太郎は頬被りをたいぎそうにとって、三郎さんとか言ったが、あなたの気持ちはよく判る。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラットホームに呆然と立っているうちに、列車は溜息のような汽笛を鳴らして、たいぎそうにごとりと動いた。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はたいぎそうにのろのろと立ちあがった。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顔色は例によって生々と、あるいはテラテラと茶褐色にあくまで光り輝き、短い袖からは鬼をもひしぎそうな赤銅色の太い腕が逞しく出ており、円柱の如き脚の下で、靴の細く高い踵が折れそうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると王さまは、ふしぎそうな顔をなすって、「何を言ってるのかね。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちは、近づいて行って、ふしぎそうに見ていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッキリ覚えていた場所を、円タクの運転手に教えたが、そこへ行ってみると、危く通りすぎそうになって、「あ、ここ、ここ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはわたしがそれを継ぎそうに見えた間はわたしに愛を繋ぎ、正勝がそれを奪還しかけると急に正勝へ愛を移していきましたが、それは間違いです。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、王子もおつきの人たちもみんな、ひいさまのしなやかな、かるい足どりをふしぎそうに見ました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目にも玉をあざむく二人の若人の腕ののびるところ、鬼をもひしぎそうな大男の浪人姿がつぎつぎとたおれて、うしろからバラバラと、裏崩れ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと太鼓もかかえ、さるも背に負っているんですから、道々商売をかせぎそうなものなんですが、いっこうにそういうけはいはなくて、一直線にずんずんと羽生めがけてやって参りましたものでしたから、右門の秀抜きわまりなき探偵眼は、ますますさえだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが困ることが一つだけあるんでね」「なんです、お母さん」息子はふしぎそうにしてたずねた。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一匹の小鬼は老婆をうち眺めて、さもさもふしぎそうに、婆さんの内股にあるたいへん怖ろしい口はなんだかというと、老婆は、ああこれか、これはきかない小鬼でも食う口じゃといっておどかしました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "停留場を通りすぎそうなので、私はいそいでかけ出しながら片手をあげ、腰かけてから見ると、運転手は白縮のシャツに黄ズボン姿。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し行って、廊下を左に曲る、日本女が足のはずみでその前を通りすぎそうにしたごくあたり前の或る木の扉のところでとまった。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、父はどうしたわけか夜中二階の寝室でおきていたらしく、あくる日、母が私にふしぎそうに語りましたが、父は、床にもつかず、何か考え、考えてはためいきをついていたそうです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
