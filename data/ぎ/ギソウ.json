[
  {
    "uuid": "fa03146c-3fe2-56cb-a691-207cd431f9df",
    "entry": "儀装",
    "reading": {
      "primary": "ぎそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
