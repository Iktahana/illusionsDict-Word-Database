[
  {
    "uuid": "940cbe58-89dc-5f12-ae9f-443fd6fedc9d",
    "entry": "偽書",
    "reading": {
      "primary": "ぎしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spurious letter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう点からも偽書説は覆すことが出来ると思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう点から、この書は偽書でなかろうということが出来るのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の隣のその男と云うのは、私と同じような運命で、偽書罪に問われた若い男であった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに持つて生れた好古癖にまかせて、折角考証に考証を重ねて、在来のままの経籍とは違つたところのある異本を公にして、学界に寄与しようとすると、世間の人達は碌すつぽそれを読みもしないで、「あれは偽書ださうだよ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「悪戯なんですか、それぢや偽書といふ訳ですね。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽書と称せられて居る「江源武鑑」と言ふのにある話で、尠くとも「江源武鑑」の出来た時に、さうした伝説が、何かの書物か、民間の伝へにあつた事だけは信ぜられる。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝまで来れば、安倍晴明の作つたと言ふ偽書――併し江戸の初めには、既にあつた――「内伝抄」によつて、葛の葉の話が、ちよつと目鼻がつき相に見える。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世上には偽書七十二巻を作って流布し、正書は誰にも見せなかった。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもちろん問題にもならぬ偽書として措くとするも、その他の伝記の言うところが、また果して信ずべきか否かは、真宗の開祖親鸞聖人が名流日野家の公達で、九条関白の愛婿であったとの説と同様に、門徒以外にこれを強うることはかなり困難なものであろう。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文書がもし真物ならんには、散所の文字ある最古の文書として、既引『小右記』長和二年の記事や、永承三年『高野参詣記』の記事などよりも上に列すべきものではあるが、もとより後世の偽書で、延喜当時の状態を知るべき参考となるべきものではない。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば、彼の買つたものは何人かの戯れに、もしくは売らうが為に作つた偽書になるわけである。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わたくしは偽書本を閉ぢて岩田に返し、「百円もしたかね。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　岩田は再び怪夢録の偽書本をわたくしの方に向けて、テーブルの上に載せる。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは偽書本ではなくて偽作の書簡がわたくしの目に触れたからである。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに依つて偽書であることが證明せられる。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽書偽本のはなしも其後はさつぱり耳にしなくなつた。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するところ、白井と木場の二人も召集か、または徴用でもされて、偽書をつくる暇がないやうになつたのだらう。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘庵の罪状は紀伊家の用達世古格太郎に書面を送り水戸家に下賜せられた攘夷の勅諚は偽書であるが如き風説をなして人心を騒し、かつまた、評定所の尋問に対して前後相違の申開をなしたのは儒を業とし人の師となる者の為すべき所でないというにあった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "又伝教大師及び弘法大師の時代に於ける神仏習合の思想は、本地垂迹説を考へるまでに発達して居らず、伝教大師を開祖とする山王一実神道、弘法大師を創立者とする両部習合神道は、後世に於て発達形成したものを、遥に上せて両大師に附会したものであって、両大師の神道の著書と称するものは皆偽書である。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "経もあるが偽書である。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新約聖書に含まれる二十七の文書のほかに、エジプト人の福音、ヘブル人の福音、パウロ行伝、ペテロ黙示録、バルナバの書簡等があったが、これらは聖書に包含せしむべき価値なき偽書であるとして、排斥せられたのである（「偽典」と総称せられる）。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "在井堂に関する一条が『峯相記』の中にあることから、じつはこの本が偽書であろうと推定しつつもそう断定するに忍びない気持がする。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休の言行を録した『南坊録』なるものが残るが、これは学者の説だと偽書だという。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかたをいで玉ひてよりつくしへいたり給ひしまでの事どもを、菅神の筆記せさせ給ひたるを須麻の日記とて今も世にのこれり、一説に偽書といふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり偽書を作るわけで、房二郎は一字書くごとに、恥ずかしさで汗をかく思いだった。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それに反する史料が現れると理窟ぬきでそれは国史に反するもの、マチガイを書いた偽書偽作ときめつけていたものです。",
              "citation": {
                "source": "飛騨の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては呂布のために、曹操の陣へ、反間の偽書を送って、曹軍に致命的な損害を与えた土地の富豪の田氏であった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚痴な手紙などよこして子を呼ぶような母ではない」「では、偽書でしたろうか」「おそらくは然らん――。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "張允は見るやいなや、「あっ、偽書だ。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
