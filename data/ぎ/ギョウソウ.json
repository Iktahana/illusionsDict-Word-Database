[
  {
    "uuid": "10884355-44b3-595a-bec6-b434bb0ebf21",
    "entry": "形相",
    "reading": {
      "primary": "ぎょうそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
