          "literary": [
            {
              "text": "行政学会のおとうさんが「やっぱり署長に行ってたのむしかないですね」　屑やのお父さんも賛成。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時から十一時までがんばり、行政学会のおかみさんにのこれと云う、七つの男の子をつれている。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分検討したすえ、それならということで応召したが、かねて通達があったのだとみえ、入営するなり丙種学生に選抜され、占領地行政学と、謀略学を主とする、個人情報専門の短期特務教育を受けた。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
