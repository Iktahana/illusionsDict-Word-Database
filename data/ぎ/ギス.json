[
  {
    "uuid": "821336ab-4558-58ee-a20a-57bac0c1e42c",
    "entry": "擬す",
    "reading": {
      "primary": "ぎす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to imitate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翁は、時には、手を長くさし出して地平の線に指尖を擬する。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が姫君を診察するとき、心臓の鼓動をかたどるチンパニの音、脈搏を擬する弦楽器のピッチカットもそんなにわざとらしくない。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばド・ヴァレーズ伯爵がけしからぬ犯行の現場から下着のままで街頭に飛び出し、おりから通りかかったマラソン競走の中に紛れ込み、店先の値段札を胸におっつけて選手の番号に擬するような、卑猥であくどい茶番はヤンキー王国の顧客にはぜひとも必要なものであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ジュリアンを自分に擬するのは滑稽だったしジュリアンの真似をするのはあわれな猿真似にすぎなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下略）　嘯詠寒山に擬すの句は、此老の行為に照せば、矯飾の言に近きを覚ゆれども、若夫れ知己に遇わずんば、強項の人、或は呉山に老朽を甘んじて、一生｜世外の衲子たりしも、また知るべからず、未だ遽に虚高の辞を為すものと断ず可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻防いづれがいづれか不明だが、記には「爰に将門｜罷まんと欲すれども能はず、進まんと擬するに由無し、然して身を励まして勧拠し、刃を交へて合戦す」とあるに照らすと、何様も扶等が陣を張つて通路を截つて戦を挑んだのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孀母は堂に在り、子にあらずば誰か養はん、田地は数あり、我にあらずば誰か領せん、将門に睦びて云※、乃ち対面せんと擬す」とある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三篇は蓋し孫子に擬する也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝に書いてある女、新しい詞で形容すれば、死の天使を閾の外に待たせて置いて、徐かに脂粉の粧を擬すとでも云うような、美しさを性命にしているあの女が、どんなにか岡田の同情を動かしたであろう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅戯何人か半仙に擬する分明なり瓊女金蓮を散ず広寒隊裏応に相※むべし信ずるなかれ凌波便ち天に上るを　詩ができると陳はそれを口にしながら出て、はじめの径から引返して往った。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｒさんはクレテ島の沐浴婦に擬すべき美人で、かね／″＼私は尊敬の念を抱いてゐたが、惜しみてもあまりあることには、その音声が九官に酷似して、私を悲しませた。",
              "citation": {
                "source": "嘆きの谷で拾つた懐疑の花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は「困難の問屋である」といいて冷笑する者もあり、或は「国人に捨られし時」などと唱えて自分を国家的人物に擬するは片腹痛しと嘲ける者もあった。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其等にも増した何とも云えぬ感激を以て山径水涯を過ぎ行く其の心持というものは、到底比擬すべき何物も無い霊秘なものである。",
              "citation": {
                "source": "穂高岳",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れを以て今の作家に擬するは屋上屋を架するの愚を演ずるものにはあらざるか。",
              "citation": {
                "source": "国民性と文学",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはいわく、衄を塗りて血汗に擬するのだと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、今や突撃の号令の掛るのを待つてゐる兵隊のやうに、ペン先を擬すと、部屋中の空気は、ひとつになつて息を殺してゐた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如き者を以て直に神に擬することはできぬ。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "選択的意志というが如きはむしろ不完全なる我々の意識状態に伴うべきものであって、これを以て神に擬すべきものではない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは伊達に飾ってあるのではない、僕は朝夕これを執って、わが家の同人の誰でもを相手に剣術の練習をする、堪らなく気が滅入って始末のつかぬ時には、これで戦争ごっこをして気分を晴す、武者修業物語を読んで亢奮すると、これを振り廻して作中人物に想いを擬する。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く支那の記録より視たる邪馬臺國は、之を大和朝廷の所在地に擬する外、異見を出すべき餘地なし。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐とよむは、聲音に於て最も適へども、地勢隔離すれば、余は姑らく之を和名鈔の近江國伊香郡遂佐郷に擬すべし。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "因て姑らく伊聲耆、即ち掖邪狗を以て此命に擬す。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "田道間守に縁ある者としては都市を出石に擬することなり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "又投馬國につきては、近年之を備後の鞆津に擬する説あるは、余も一考すべき者と考ふ。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、俳句の古調を擬する者あれば「古し」「焼直しなり」などとて宗匠｜輩は擯斥すめり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "破鐘のような大きな声と悲しい沈んだ声とで互いに夏期学校の講壇に立って、一方を旧約のイザヤに擬するものがあれば、一方をエレミヤに擬するものがある、声望から経歴から相対立した関西の組合教会の二人の伝道者が通った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "不倫と申すこと、要は蕪村一人の什を盛唐幾多の作家と比擬すること、及び晩唐の方にはかへつて比擬すべき作家あらむと思ひ、云々。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "折釘に烏帽子かけたり宵の春春の夜に尊き御所を守る身かな春雨や同車の君がさざめ言ほととぎす平安朝を筋かひにさしぬきを足で脱ぐ夜や朧月　引例を見ても解るように、特に春の句においてそれが多いのは、平安朝の優美でエロチックな文化や風俗やが、春宵の悩ましい主観において、特にイメージを強く与えるためなのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔思ふ草の庵の夜の雨に涙なそへそ山ほととぎす」これは「盧山雨声草庵中」といふ句のある白楽天の漢詩を日本風に訳したものだと言ふ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠音に渡るかほととぎすの。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
