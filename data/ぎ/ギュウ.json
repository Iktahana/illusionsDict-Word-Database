[
  {
    "uuid": "72b60213-e5bb-58c4-8266-ca4ef3f65494",
    "entry": "妓夫",
    "reading": {
      "primary": "ぎゅう",
      "alternatives": [
        "ぎふ"
      ],
      "is_heteronym": true
    },
    "grammar": {
