      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pimp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お紺はよんどころなく商売をやめて、そこらを流れ渡っているうちに、吉原の或る女郎屋の妓夫と一緒になって、よし原の堤下の孔雀長屋に世帯を持つことになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "でつかんしよに、愉快ぶし、妓夫臺談判破裂して――進めツ――いよう、御壯、どうだい隊長と、喚き合ふ。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴫蔵竹助の妓夫が東栄を引き立てて暖簾の奥に入る。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で国五郎、米五郎、小半次、三太郎、島蔵の侍等が花道を出て、妓夫に案内せられて奥に入る。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんをお大事に……」　半七はそこを出て、更に近所で訊いてみると、むさし屋に出入りする金さんは金造といって、この品川の宿をごろ付き歩いて、女郎屋の妓夫などを相手に、小博奕などを打っている男であることが判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄席の帰りに腹が減って蕎麦屋に這入ると、妓夫が夜鷹を大勢連れて来ていて、僕等はその百鬼夜行の姿をランプの下に見て、覚えず戦慄したこともある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方が無いから、苦情やら忌味やらを言はれ／＼、三里の山道を妓夫を引張つて遣つて来て見ると家の道具はもう大方持出して叩き売つて仕舞つたので、これと言つて金目なものは一つも無い。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓夫は怒るし、仕末に困つて、何うしようと思つて居ると、裏の馬小屋で、主人が居ないので、三日間食はずに、腹を減して居つた、栗毛の三歳が、物音を聞き付けて、一声高く嘶いた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やア、まだ馬が居るア」　と言つて、平気でそれを曳出して、飯をも与ヘずに、妓夫に渡した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家には店に妓夫が二人出ていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが女郎屋の妓夫であることは一見して知られた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝次郎はよし原の妓夫で、夜は家にいない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると妓夫ではなくて此の家の亭主が側へ来て、文明な露国ではとても聞かれぬ尾陋千万な事を野蛮な日本人だから平気で陳べて遊興を勧める。",
              "citation": {
                "source": "露都雑記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖簾外の女郎屋は表口の燈火を消しているので、妓夫の声も女の声も、歩み過る客の足音と共に途絶えたまま、廓中は寝静ってタキシの響も聞えない。",
              "citation": {
                "source": "草紅葉",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓夫と口論をもして見た。",
              "citation": {
                "source": "歡樂",
                "author": "永井壯吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女郎屋に上って女郎勤をなさざれば、妓夫おばさん来ってたまには揚代を返す事あり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "見慣れたネオンサインに背中を向けて南座に沿って曲ると、女の妓夫が立っている遊女屋が並んでいた。",
              "citation": {
                "source": "幽霊を見る人を見る",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "体のいいサンドイッチマン、も一つ言葉を変えて云えば」と内しょ声になり「つまる所｜妓夫太郎なんです」　青木は紳士の云うことが余り変なので、面喰った形で、マジマジと相手の顔を眺めていた。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめさんのお父さんは京一の仙州楼の本番口の妓夫をしていた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼女と、妓夫台にうたた寝をしていてそのとき眼をさました番頭さんが、異口同音に「朴歯、朴歯。",
              "citation": {
                "source": "朴歯の下駄",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで腰に鉄鍋を当てて待構えていて、腰に触る怪物の手首をつかまえてぎゅうぎゅう捻じ上げたが、いくら捻じっても捻じっても際限なく捻じられるのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も映画などで見ると今の人はそういう場合に吸殻で錐のように灰皿の真中をぎゅうぎゅう揉んだり、また吸殻をやけくそに床に叩きつけたりするようである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はぎゅうぎゅう押えつけられている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスの用意に鵞鳥をつかまえてひざの間にはさんで首っ玉をつかまえて無理に開かせた嘴の中へ五穀をぎゅうぎゅう詰め込む。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合にはいやがる書物をぎゅうぎゅう詰め込むのもまたやむを得ないことであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少い女を真中に、漢が二人要こそあれと、総曲輪の方から来かかって歩を停め、間を置いて前屈みになって透かしたが、繻子の帯をぎゅうと押えて呑込んだという風で、立直って片蔭に忍んだのは、前夜｜榎の下で、銀流の粉を売った婦人であった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お民はそのまま、すらりと敷居へ、後手を弱腰に、引っかけの端をぎゅうと撫で、軽く衣紋を合わせながら、後姿の襟清く、振返って入ったあと、欄干の前なる障子を閉めた。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でも夜半のことだと聞きましたが、裏の鶏舎で羽搏の音が烈しく聞えたので、彌作が窃と出て見ると、暗い中に例のは鶏舎の中から一羽を握み出して、ぎゅうと頸を捻って、引抱えて何処へか行って了ったと云いますよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に持ってるわけにもいかねえ」こう言って、ポケットに、ぎゅうぎゅうつめこみました。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は苦しくなると、神においのりするものでありますが、もっと、ぎゅうぎゅう苦しくなると、悪魔にさえ狂乱の姿で取り縋りたくなるものです。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
