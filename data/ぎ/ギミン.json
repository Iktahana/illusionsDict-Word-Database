    },
    "definitions": [
      {
        "index": 1,
        "gloss": "public-spirited or self-sacrificing individual",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○三月、明治座にて「瑞西義民伝」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "村が乱れて義民があらわれた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會主義ガ私有財産ノ確立セル近代革命ノ個人主義民主主義ノ進化ヲ繼承セル者ナリトハ此ノ故ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "神ともつかず、佛ともつかず、公津の義民を祀れる所謂宗吾靈堂は、思ひしよりも大也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗吾は佐倉領の義民也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、承應二年八月三日は、日本史上、未曾有の義民、木内宗吾が磔殺せられたるの日也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一身を民にさゝげて、獄裏に半年餘の月日を送りし一大義民、今や公津の野の磔柱の上にあらはれたり。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜野橋に到る間に私は土地の義民｜磔茂左衞門の話を聞いた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ひながらこの勇敢な、氣の毒な義民のためにひどく心を動かされた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜野橋に到る間に私は土地の義民｜磔茂左衛門の話を聞いた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思いながらこの勇敢な、気の毒な義民のためにひどく心を動かされた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "澤山集ることがあると、校長先生は、手振りや、身振りまでして、「佐倉宗五郎」や「磔茂左衞門」などの義民傳を話してきかせた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "オウピアン星の惑星キリキズの軍事主義民族軍団千二百万人が襲来する。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義民甚兵衛」が、「甚兵衛様は笑って死になさった」と数万の群集に賞めたたえられつつ、領主の磔柱の上で生涯一度の愉快そうな笑いを笑う。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義民、英雄というものに向けられて来た、盲目な崇拝の皮を剥いで示そうとしているのである。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義民にしろ、英雄にしろ、それに対する封建の伝習は否定して、しかも猶民衆の要求の焦点として歴史のなかに存在するものではないだろうか。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義民甚兵衛」の作者が徐々に大衆文学に移って行ったその時代に日本の文学は質的に一変転を経過して、このような個人としての利害に行動した甚兵衛も猶当時の周囲の農民の生活のありようの中でみれば、一個の犠牲であった歴史の現実までを描き出そうという努力を自覚する時期に入った。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に、九州｜久留米出生で、上野義民というのは卒業をして後、今日私の工場に通勤して盛んに働いております。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもブルジョア民主主義、つまり資本主義民主国では、やはり女の失業も失業者の数のなかに入れております。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトというと、共産主義者の国だとか、或は赤い国だとか、今日でもなおある種の人たちは、ソヴェト同盟の社会主義民主社会のもとの人民生活について現実的な理解をもとうとしないで、いろいろな妄想を歪んだ誇張でつたえております。",
              "citation": {
                "source": "社会と人間の成長",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばこの間菊池寛は小説「義民甚兵衛」を三幕の戯曲に書直した。",
              "citation": {
                "source": "小説の戯曲化",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば菊池は「義民甚兵衛」を小説から戯曲へ書直した。",
              "citation": {
                "source": "小説の戯曲化",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、「義民甚兵衛」なるものは小説の形式に表現すべきものか、それとも亦戯曲の形式に表現すべきものかと云ふことは予め菊池の考へる、或は考へなければならぬことである。",
              "citation": {
                "source": "小説の戯曲化",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "正保の昔し佐倉の義民木内宗吾が刑死した事や、寶暦の當時八幡の暴主金森頼錦が封を失つた事や、又夫等の事件ほど人口に膾炙するに炙するに」］至らないとは云ひ、所在聞くところのかの百姓一揆と稱するものは、皆治者と被治者の爭ひで實に苦々しい話である。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "當島におひても、若哉異國船共參申候はゞ、君臣之節不相失處迄は相盡｜賦にて、政照｜抔至極之決心にて、外兩人義民｜相募、三人は必至に罷成居申候間、是等の事ども樂しみにて相暮居候事に御座候。",
              "citation": {
                "source": "遺牘",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身は義民であつた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから道庵は長沼流の「兵要録」の原本を見たり、義民多田嘉助の筆跡を見たり、臥雲震致が十四歳のとき発明した紡績機械の雛形を見たりして、あまり甚だしい脱線もなく、この展覧会を立ち出でました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "天守閣の棟が西に傾いているのは、義民多田嘉助が睨んだからだという。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面服従して、少し目をはなせば一揆を起したがるのが百姓だ――ことに近来は、一揆の無頼漢の音頭を取るものを称して「義民」だのなんのと祭り上げる輩が多いから、百姓がいよいよ増長する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面服従して、少し目をはなせば一揆を起したがるのが百姓だ――ことに近来は、一揆の無頼漢の音頭を取るものを称して「義民」だのなんのと祭り上げる輩が多いから、百姓がいよいよ増長する――云々。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
