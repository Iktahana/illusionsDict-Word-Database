        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ともかく事が過ぎ、ぼくの父があとの屋敷と銀行口座の一万四〇〇〇ポンドほどを受け継ぎました。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに私の銀行口座に、手数料無償で一万九千二百五十五ポンド払い込んでください。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は楽しかったなあ、若さも元気も、銀行口座もあり、無尽蔵だった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "地位のある紳士が銀行口座を持たないなんて妙でございます。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙も、銀行口座も、帳面もないのです。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
