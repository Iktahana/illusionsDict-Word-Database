    "definitions": [
      {
        "index": 1,
        "gloss": "Edo-period unit of silver coinage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「それ、銀目と、金目と、赤い目の奴等よ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日、知人の好意と尽力とで、金目銀目の尾の長い純白の猫を一つ手に入れた。",
              "citation": {
                "source": "猫性",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "金目銀目は実はあまり珍重したものでなく、水色に青く澄んだ眼が望ましい。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白で、そして、金目銀目で……」　太郎は、なおしっかり、チロを抱きしめました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄王の城の中に、金銀廟という宮がありまして、白い塔が建っていて、そこには、金目銀目の猫がまつってあるのです。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、金目銀目の猫、見つかった。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "チロは生きてる猫で、金目銀目だ。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まっ白な猫だ」「金目銀目だ」「金銀廟に祀ってあるのとそっくりだ」　太郎はチロを追っかけました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしもし、金目銀目の猫が、どこかへ行ってしまいました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしもし、金目銀目のネコが来ませんでしたか」「チロ、チロ、チロや……」　寝ていた匪賊達は目をさましました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしもし、金目銀目の猫が来ませんでしたか」　小さなランプのついてるきりの、うす暗い中から、二―三人の男が起きあがりました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の方に祭壇があって、金銀の厨子の中に、猫の像が金目銀目を光らしており、いろんな不思議な器物が並んでいました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、チロの国と名をつけましょうよ」　ふたりは一緒に金目銀目のチロを抱きかかえて、かたく握手をしました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
