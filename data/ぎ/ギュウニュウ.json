        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文房具と、正午にはパンと牛乳を支給してゐた校内の売店は、「学生が学生の武器である文房具を、学校に来てから整へるやうなことでは不可ない」といふ理由の許に廃された。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の玄関の左側にはちょっとした売店があって文具や、それから牛乳パンくらいを売っていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝｜一遍田を見廻って、帰ると宅の温かい牛乳がのめるし、読書に飽きたら花に水でもやってピアノでも鳴らす。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞や牛乳の配達や、船員の朝帰りが、時々、私たちと行き違った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳に入れてあげやうと思って。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お母さんの牛乳は来てゐないんだらうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく牛乳をとりながら見てくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから俄かにお母さんの牛乳のことを思ひだしてジョバンニはその店をはなれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもジョバンニは、いつかまた深く首を垂れて、そこらのにぎやかさとはまるでちがったことを考へながら、牛乳屋の方へ〔急ぐのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その牛乳屋の黒い門を入り、牛の匂のするうすくらい台所の前に立って、ジョバンニは帽子をぬいで「今晩は、」と云ひましたら、家の中はしぃんとして誰も居たやうではありませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、今日、牛乳が僕とこへ来なかったので、貰ひにあがったんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今日牛乳がぼくのところへ来なかったのですが」「あ済みませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その人はすぐ奥へ行って一本の牛乳瓶をもって来てジョバンニに渡しながらまた云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはもういろいろなことで胸がいっぱいでなんにも云へずに博士の前をはなれて早くお母さんに牛乳を持って行ってお父さんの帰ることを知らせやうと思ふともう一目散に河原を街の方へ走りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国へ渡るとなんだか急に呑気になった、巡査を見ても牛乳屋を見ても誰を見ても一様に呑気な顔をしていた。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン中に八箇所の牛乳配達店をもっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王立美術協会の絵画展覧会に彼の肖像が出品された時に、観客の一人が「三四二号、ロード・レーリー、アー、あの牛乳屋か」と云っているのを聞いた友人があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は或る日、道で牛乳屋と突き當つた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と牛乳屋が怒鳴つた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　牛乳屋はびつくりして、暫らく君の顏を見つめてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昨日の喧嘩した牛乳屋が、夜遲く復讐に來るであらうを考へ、恐怖と心配で寢られなかつたと語つた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの憑かれたやうな、小さな馬車が異樣に人々の好奇心をそそるのは、それがまるで牛乳みたいに不透明な色をした窓硝子を持つてゐる故であるのに氣づかなければならぬ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳でも脂肪を拔いて飮みます。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　　　　　　　一　牛乳色の靄が山の麓へ流れ集りだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げて行くパルチザンの姿は、牛乳色の靄に遮られて見えなかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳に入れてあげようと思って。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お母さんの牛乳は来ていないんだろうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから俄かにお母さんの牛乳のことを思いだしてジョバンニはその店をはなれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもジョバンニは、いつかまた深く首を垂れて、そこらのにぎやかさとはまるでちがったことを考えながら、牛乳屋の方へ急ぐのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かたや　フロプシーと　モプシーと　カトンテルは　ばんごはんに　パンと　ぎゅうにゅうと　クロイチゴを　たべました。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
