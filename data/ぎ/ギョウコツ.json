[
  {
    "uuid": "4f22908b-edc7-5bcc-b04f-02d26a8658b4",
    "entry": "行乞",
    "reading": {
      "primary": "ぎょうこつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going on an alms round (for food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たまには行乞にも行かなければならない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ伊予の松山の城下は富裕の評判高く行乞に便利であるところからしばらくそれを便って落着いたわけである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（阿難、鉢を持って行乞の戻りの姿、池を見て娘の傍に近づく。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本集を発送したら、久しぶりに行乞の旅に出かけるつもりです。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々行乞しないと米塩にも困りますが、それよりも人間が我儘になって困ります。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中行乞しつゝ、伊佐町へ着いたのは一時過ぎだつた、こゝでまた三時間ばかり行乞して、どうやかうやら、野宿しないで一杯ひつかけることができた、ありがたいやら情ないやらの心理を味つた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時出立、すぐ行乞をはじめる、憂欝と疲労とをチヤンポンにしたやうな気分である。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の行乞所得米一升六合　銭四十一銭途上一杯の酒、それこそまさに甘露！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は山口を行乞しよう、六時出立、九時着、行乞三時間、三時帰庵、行乞相はよかつた、所得もわるくなかつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨らしく降つたり晴れたりする、やむなく行乞は見合せる、明日の米がないけれど、明日は明日の事だ、明日の事は明日に任しておけ！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇、行乞は今日も駄目。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、伊佐町で知り合ひになつた禅海坊がひよつこりと訪ねてきた、此度は泊らないで対談二時間ばかりで帰つていつた、行乞米一升ばかりくれた、私は財布の底をはたいて五銭あげた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "――鋳銭司まで出かける、今月最初の行乞であるが、何分にも睡眠不足と※気とで苦しくてしようがない、それをこらへて二時間だけやつと行乞、それでも今日一日の生命を保つには十分すぎるほど戴いた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞は身心晴朗でなければならない、足もかろく気もかろくなければならない、そしておちつきがなければならない、すなほさがなければならない。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞はまことにむつかしい、自から省みて疚しくない境地へはなか／＼達せない、三輪空寂はその理想だけれど、せめて乞食根性を脱したい、今日の行乞相は悪くなかつたけれど、第六感が無意識にはたらくので嫌になる。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時から十一時まで大田町行乞。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "木部行乞、十一時から一時まで二時間。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊歩悠々、行乞は遊歩三昧でなければならないと思ふ、いつも行乞する場合、さう思ふのである。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日からまた行乞の旅へ出る、歩け、歩け、たゞ歩け、歩くことが一切を解決してくれる。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月廿九日　　　　　　　『行乞記』　七月三十日",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時半出立、九時から十二時まで秋穂行乞、三時半帰庵。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は二合入の空瓶を拾うて戻つた、行乞途上、般若湯を詰めて持つてあるく用意として。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十四日　七月十五日　『行乞記』　七月十六日",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は近在行乞、家から家へ歩きまわっているうちに、何だか左胸部が痛むようなので、二時間ばかりで切りあげた。",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
