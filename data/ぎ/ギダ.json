    "definitions": [
      {
        "index": 1,
        "gloss": "sacrifice (bunt or fly)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あゝ今のは、言ひ過ぎた………言ひ過ぎだ………！",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくも木からおりて、しゅっこといっしょに、向うの河原へ泳ぎだした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "騒ぎだした時、すぐに池を見たら間に合ったかもしれなかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわずかに「わが青海流は都会人の嗜みにする泳ぎだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒達の一行にさえ頓着なしに泳ぎだした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あるとも、一昨日なんか骨膜炎の手術を受けた老人がね、義太夫を唸り出す騷ぎだつたよ‥‥‥』と、水島は相變らず冷靜な顏附で云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、お互に微醺を帶びて變に彈み立つた氣分で黄包車を驅り、再び四馬路の大通へ出たのはもう夜の一｜時過ぎだつた。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大方眠りつこうとしていると、不意に土間の隅に設けてある鶏舎のミノルカがコツコツコと騒ぎだした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹が跳ね、騒ぎだしたのにつれて、小屋中の豚が悉く、それぞれ呻き騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　二週間ほどたって、或る日、健二が残飯桶をかついで丘の坂路を登っていると、彼の足音を聞きつけて、封印を附けられた宇一の小屋から二十匹ばかりが急に揃って、割れるような呻きを発して、騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と大津は投げ出してあった時計を見て、『おやもう十一時過ぎだ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくすると、再び森の樹枝が揺れ騒ぎだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、事件が突発したのが、十八日の午後十時すぎだろう。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもああいうきれいな男うなだて好ぎだべ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのあんこだて好ぎだべ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふしぎだな、なんでもこの辺で見たというものがあるんだが。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し世の中が変ろうというところへ生れあわせたので、生れた翌年は上野の戦争がある、危い中を母に負われて浅草の所有地へ立退いたというような騒ぎだったそうです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二ページはおかあさんの留守に幼少な娘のリエナが禁を犯してペチカのふたを明け、はね出した火がそれからそれと燃え移って火事になる光景、第三ページは近所が騒ぎだし、家財を持ち出す場面、さすがにサモワールを持ち出すのを忘れていない。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちでは大變な騷ぎだらう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飛騨もはしやぎだした。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前に知らせたつてなんにもならぬだらうが、うちの銀行もいま危くなつてゐるし、たいへんな騷ぎだよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべだつて、婦長室へ看護婦をおほぜいあつめて、歌留多なんかして大さわぎだつたくせに。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こんどは葉藏がはしやぎだした。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなかささぎだ」カムパネルラがまた何気なくしかるように叫びましたので、ジョバンニはまた思わず笑い、女の子はきまり悪そうにしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男たちはよろこんで手をたたき、さっきから顔色を変えて、しんとして居た女やこどもらは、にわかにはしゃぎだして、子供らはうれしまぎれに喧嘩をしたり、女たちはその子をぽかぽか撲ったりしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうみんな大さわぎだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると三郎もなんだかはじめてこわくなったと見えて、さいかちの木の下からどぼんと水へはいってみんなのほうへ泳ぎだしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくも木からおりて、しゅっこといっしょに、向ふの河原へ泳ぎだした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
