    "definitions": [
      {
        "index": 1,
        "gloss": "recitation (of a Chinese or Japanese poem)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
