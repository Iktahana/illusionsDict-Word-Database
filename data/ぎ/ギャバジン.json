        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "呉服屋の手代とはいえギャバジンの洋服をリュウと着こなして、見るからに少し足りないアプレ型である。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュウとしたギャバジンの洋服のオモカゲどこへやら。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十二歳の新調のギャバジンの背広をキチンときたサラリーマンだった。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の服装はネズミ色のオーバー、ギャバジンの白いズボン、ノーネクタイだった。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の奴がアロハを着るうちはまだいいが、ギャバジンを着やがると、いけなくなるよ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "おろしたてのギャバジンの背広をきている。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャバジンの三ツ揃いぐらいじゃア、めったなことで米の一升も売ってやらねえから覚えてやがれ。",
              "citation": {
                "source": "武者ぶるい論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に水道橋駅の手洗所から出て来たときには、ズボンが折目のとれた古い薄茶色のギャバジンに変り、靴もいやに派手な型のものに一変していた。",
              "citation": {
                "source": "薔薇夫人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
