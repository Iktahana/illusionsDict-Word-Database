[
  {
    "uuid": "67ff66dd-a970-5b7b-ae82-8bb7692d45ef",
    "entry": "業務",
    "reading": {
      "primary": "ぎょうむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
