          "literary": [
            {
              "text": "凸凹の激しいその道には豚血牛脂流れ出しほとんど小溝をなしている。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石倉もさるもので、林の中から這いだしてから、私がどういう行動をとるか見抜いて、ボートの底に仕掛けがしてあった……栓を抜いて牛脂でも押込んであったんだろう。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューブからしぼりだした白い油絵具のような、もったりとした生牛脂。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪物は、妙な手ざわりの紐で、千二の体をぎゅうぎゅうしめつけるのであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆布でつくったリュックサックを野呂は持っていますが、この間風呂から帰って来て何気なく野呂の部屋をのぞき込むと、彼はその中に猫を入れて、ぎゅうぎゅうしめ上げていたのです。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
