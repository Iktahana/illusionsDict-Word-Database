[
  {
    "uuid": "f3a18d87-0d35-5c43-91b9-43486c979251",
    "entry": "技巧的",
    "reading": {
      "primary": "ぎこうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
