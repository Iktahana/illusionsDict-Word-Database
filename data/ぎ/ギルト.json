          "literary": [
            {
              "text": "シカシ果シテソレガ雑音ナドトイワレルニ十分ナ屑電波ダトスルコトハ早計ニ過ギルト思ワレル。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ノ母屋デモ家族全部ヲ収容スルノニ狭過ギルト云ウコトハナイガ、予ガイロ／＼ト企ンデイル悪事ヲ実行スルノニハ少シ不便デアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシヤッパリ寝ラレナイノデルミナールノ注射ヲシテ貰オウトシタガ、寝過ギルト困ルト思ッテ止メタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻ハブランデーガ過ギルト時々中座シテ便所ニ隠レテイルヲ忘レナカッタ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（脚ノ力モ弱ッテイテ歩キ過ギルトジキニ疲レル）………　………今日散歩カラ戻ッテ来ルト妻ガ洋裁ノ河合女史ト茶ノ間デ話シテイル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
