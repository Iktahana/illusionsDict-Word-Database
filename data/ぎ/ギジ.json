    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pseudo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
