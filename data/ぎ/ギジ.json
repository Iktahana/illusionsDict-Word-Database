  {
    "uuid": "73c39034-d6f0-5877-894f-0a7fd8ea6377",
    "entry": "疑似",
    "reading": {
      "primary": "ぎじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
