          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "况して初めより、如何あらんと疑弐する日に出でゝ、興趣を感ずべき筈なし、徒に時間と金銭を費すに過ぎず。",
