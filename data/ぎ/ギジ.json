  {
    "uuid": "40874611-7762-5201-a8e2-7ea89bbf5ec4",
    "entry": "疑弐",
    "reading": {
      "primary": "ぎじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "doubt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
