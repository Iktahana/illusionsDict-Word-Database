        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひどいぎっちょとみえて、左にはしを持ちながら、左でがつがつ食べているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人はこのぎっちょと決まったよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎっちょは親のせいなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面から刺した傷なら、ぎっちょでねえかぎり、相手の左を突くのがあたりめえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては下手人左ききか、いいや、ぎっちょにちげえあるめえと、このおいらがにらんだになんの不思議があるかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぎっちょを見つけたくて食わしたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぎっちょの梅五郎が豊太をえぐったあの匕首なんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを左ぎっちょの梅五郎さんにこっそりと届けてくださいまし、そうしたらなんでもききます、今晩でもおいでくださいましと、とんでもねえ両替仕込みの安いあいきょうをふりまいて、おまえから色仕掛けに頼み込まれたとな、残らずしゃべったよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりは三十四、ひとりは二十八、その若いほうの手代の左ぎっちょの梅五郎のところへ、おまえの娘がこっそりドスを届けたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわなきぁ、ぎっちょの梅五郎と突き合わせてやろうよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あいつはぎっちょ、そんなことから足がつかねばよいがと、じつは内心胸を痛めていたんでございますが、なにがもとでばれましたやら、恐ろしいことでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は左ぎっちょですかね」　私が呟くのを聞いた鷲尾老人は、何を思ったのか「えらい！",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑵の凹みは、Ｙが特に、毎朝振り慣れた鉄唖鈴で以て、左りぎっちょの逞しい腕に力をこめて、Ｋの口調で云うと、「えゝ憎き奴め！",
              "citation": {
                "source": "子をつれて",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、男は小いばって、全身が剃刀のごと、殺気がみなぎっちょる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
