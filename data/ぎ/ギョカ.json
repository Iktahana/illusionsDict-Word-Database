[
  {
    "uuid": "b41ce1d9-45fe-59cb-b7b1-4d7d9dcfedd4",
    "entry": "漁火",
    "reading": {
      "primary": "ぎょか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fire lit on a boat to lure fish at night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "カンテラは闇の晩の漁火のようなものだった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖の奥は真暗で、漁火一つ見えぬ。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霎時にして海上を見渡せば、日は已に没し、海波暗くして怒濤砂を捲き、遥か沖合には漁火二、三。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖の漁火を袖に呼んで、胸毛がじりじりに仰天し、やあ、コン畜生、火の車め、まだ疾え、と鬼と組んだ横倒れ、転廻って揉消して、生命に別条はなかった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、漁火の一つが、動き出した。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、漁火の速度で浮島の大きさを割る計算を始めた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "割り出された時間が過ぎたが、漁火は姿を見せなかった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、漁火は、島の陰で止っていたのだろうが、そんなことに気が付く余裕が無かった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は沖に明滅する白魚舟の漁火も見えるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光が河の靄に溶けて朦朧として、青黒い連山は躍り上った獣の背のように見え、遠くに漁火がきらめいているかと思うとまたどこからともなく横笛の音が哀れに聞える。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時化つづき西風強く、夜は絶えて漁火すら見ね、をりをりに雨さへ走り、稲妻の青の映りに、鍵形の火の枝の棘ひりひりと鋭き光なす。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "下見れば早や塔の沢、こちごちに湯の香煙りて、ちらちらと揺るる燈の見ゆ、海見えて漁火つく見ゆ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "海見えて漁火つく見ゆ。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝になつてゐる峠の絶頂に来ると、村里の灯が沖の漁火のやうに見渡された。",
              "citation": {
                "source": "山を降る一隊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一）の二　箕輪の奥は十畳の客間と八畳の中の間とを打抜きて、広間の十個処に真鍮の燭台を据ゑ、五十｜目掛の蝋燭は沖の漁火の如く燃えたるに、間毎の天井に白銅鍍の空気ラムプを点したれば、四辺は真昼より明に、人顔も眩きまでに耀き遍れり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖のくらきに漁火も見えず、惡魔の襲ひ來るばかりに凄き暗風、面を吹いて、氣持よからざるに、三年前に一見のなじみありし風光を、雨戸の外に閑却して、一浴し來れば、洋燈の光明に、隣席のつれこみのさゝめごと、しめやかなり。",
              "citation": {
                "source": "水戸觀梅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一辺庭先に出て見ると、もう大方花見の行列も出尽してしまつて、遥かの田甫道を煉つて行く炬火や提灯の火が、海の上の漁火のやうに揺れながら遠のいて行つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾内漁火しめりて波音高かし。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ駅に着く三十分も前に完全に日が暮れて、夜釣り漁火が窓から眺められた。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜、海岸、恋している男と女とが、沖の漁火を眺めながら散歩してる。",
              "citation": {
                "source": "「処女作」より前の処女作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は白い浴衣で団扇をもち、漁火が遠く彼方にチラチラ燦いているという極めて風情のあるところで、肝心の帳面ぐるみ、小学生作家の空想は明治時代らしいモラリストである母によって中断されてしまったのである。",
              "citation": {
                "source": "行方不明の処女作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁火の点々として浮んでゐるのと、闇の中に咽ぶやうに寄る波と、橋の向ふに薄白く見えてゐる旅館の壁と、瑞西の湖畔へでも連れ出されたやうな気がした。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "○能登の海に釣する海人の漁火の光にい往く月待ちがてり　〔巻十二・三一六九〕　作者不詳　まだ月も出ず暗いので、能登の海に釣している海人の漁火の光を頼りにして歩いて行く、月の出を待ちながら、というので、やはり相聞の気持の歌であろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に入るものは、二三の漁火の星の如く、遠くちらつくと、稀に、銚子行汽船の過ぐるに当り、船燈長く波面に揺き、金蛇の隠現する如きを見るのみにして、樹林無く、屋舎無く、人語馬声無く、一刻一刻、人間界より遠ざかる。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先画面の下部に長き橋梁を斜に横はらしめよ、しかして淋しき夜駕籠と頬冠の人の往来を見せ、見晴らす水面の右の方には夜の佃島を雲の如く浮ばせ、左の方には新地の娼楼に時として燈火を点じて水上に散在する白魚船の漁火に対せしめよ。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また眼を転じて此方を見ると、ちら／＼と漁火のように、明石の沿岸の町から洩れる火影が波に映っている。",
              "citation": {
                "source": "舞子より須磨へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上に漁火星の如し。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを何ゆえかと申しますのに、おくがたのおことにあわせて三味線のひじゅつをつくし、または御しょもうの唄をおきゝに入れて御しんちゅうのうれいをやわらげ、いつも／＼おほめのおことばをいたゞいていたのでござりますから、たいこうでんかのぎょかんにあずかりましたよりもずっとほんもうでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
