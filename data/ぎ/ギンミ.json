[
  {
    "uuid": "e5396195-96ef-5233-91f0-ed027843bd24",
    "entry": "吟味",
    "reading": {
      "primary": "ぎんみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
