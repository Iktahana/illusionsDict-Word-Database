      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "close examination",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてヒステリーは現実よりも表現を名称を吟味したがるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し新短歌様式を規範的に吟味してみて、私の考へが余り間違つてゐるやうには思はれない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、新短歌の吟味を、また少しつゞけてみる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして読後そのインタレスティングを吟味してみよ。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千年の歴史によって代表された経験的基礎を無視して他所から借り集めた風土に合わぬ材料で建てた仮小屋のような新しい哲学などはよくよく吟味しないと甚だ危ないものである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしも寝ざれば勝れて一人帷子に皺のよらざるを吟味の種に仕り候」とある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれもこれもことごとく偶然の現象だとして片付ける前にともかくも何かしら合理的な方法のふるいにかけて吟味しなければならない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉と石とを区別する前には、石も一応採集して吟味しなければならない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も意外に感じた事は自分が比較的によく体験し体得しているつもりでいた専門の学問上の知識の中にもよくよく吟味してみると怪しい部分が続々発見された。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉類の中の結核　獣肉中に結核の有無を見るには従来ただこれを切開して吟味するより外に手段はなかったが、近頃ある人がＸ光線で透して見てすぐに病所の有無を知る事を発見した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はロダンさんの鑑賞力を吟味するような気持で、優美に作られた妾の小さな胸、強いカーブを持った臀、欲求に満ちた東洋女の顔にみとれながら恍惚となっていたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それらの一つ一つの各作家に於いても、あまりに重要でない作品に対して吟味を与えることは、恐らくそう必要ではなかろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本稿を草するにあたって、貧弱な、自分の過去の読書を頼りにして、それを再吟味し、纒めるよりほかなかった。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは少なくも慎重な吟味を加えた後でなければ軽率に否定し去ることのできない問題であろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉の死骸には少しも疵のあとが無いので、おそらく覚悟して身を投げたものであろうとは想像されたが、たとい自殺にしても一応はその仔細を吟味しなければならないというので、女房のお徳はきびしく取り調べられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前屋の亭主はすぐに召し捕られて吟味を受けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "為次郎は役人の吟味に対して、自分はこれまでに草履屋の藤吉と誘いあわせて岡釣りや沖釣りに出たことはあるが、御留川の江戸川などへ夜釣りに行ったことは一度もないと申し立てた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではお徳の申し口とまったく相違するので、役人はいろいろに吟味したが、かれはどうしても覚えがないと云い張った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "川春の宇三郎は死罪、富蔵は吟味中に牢死、出前持ちふたりは追放だとおぼえています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り分けて母のおちかは、自分が娘を絞め殺して置いて、わざと家を留守にしていたのではないかという疑いをうけて、そのなかでも一番厳重に吟味されたが、おちかは全くなんにも知らないと云い張った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "新編うす墨草紙を眼の前に突き付けられて、おまへの夢に見る幽靈の正體はこれかと嚴重に吟味された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにあなたの偽物がまいって居りますから、どうか御立ち会いの上で御吟味をねがいとう存じますが……」　はじめの女はいよいよ顔色を変えたが、彼女はもう度胸を据えたらしく、急ににやにや笑い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "お琴は奉公中に主人の店をぬけだして、浅草源空寺門前の善兵衛というものを家来に仕立て、例の日野家息女をふりまわして、正二位｜内侍局とかいう肩書で方々を押し廻してあるいていることが奉行所の耳へきこえたので、お琴も善兵衛も吟味をうけることになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこのたび、ひろく讀者に、再吟味を願ふ所以である。",
              "citation": {
                "source": "『猿面冠者』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原始的な知識がさらに経験によってだんだんに吟味され取捨されて個人的一時的からだんだんに普遍的なものに進化して来るとこれが科学の基礎となる事実というものになるのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作業仮説の正否を吟味しうるためには、われわれは後日を待つほかはない。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、この方法を真に有効ならしむるには、むしろあらゆる独断、偏見、臆説をも初めから排する事なく、なるべくちがったものをことごとくひとまず取り入れて、すべての可能性を一つ一つ吟味しなければならない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこういうたんねんの吟味をするにはかなりの手数と時間を要する。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラデーはしかし彼の直観を周到厳重な実験の吟味にかける事を忘れなかった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういう風に生きてゆくか」という実生活の課題を文学にもうつして、「どういう文学か」ということを追求し、ぎんみし、学んで自分からも作ってゆく民主的文学の自主的発展の能力がつよく、みずみずしくつちかわれてゆかなければならないのである。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
