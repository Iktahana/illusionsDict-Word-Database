[
  {
    "uuid": "ab56282b-229e-5235-9ee7-d522e310c7c6",
    "entry": "玉体",
    "reading": {
      "primary": "ぎょくたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
