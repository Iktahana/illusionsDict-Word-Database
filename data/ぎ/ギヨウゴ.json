        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きょうは風があって、それでも幾分しのぎようございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは風があって、すこし凌ぎようございましたね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑いけれど、ここはカラリとして凌ぎようございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、夜に入っても、いくらかはおしのぎようござろう」　伝右衛門は、満足そうに、「――わけても、大石殿はの」　と、柔和な笑顔を送った。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、『これで、夜に入っても、霙が降っても、いくらかはおしのぎようござりましょう』　と、呟いて、ちらと、上之間の正面に坐っている内蔵助のほうへ向い、『わけても、大石殿はの……』　と、彼の寒がりを慰めて笑った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
