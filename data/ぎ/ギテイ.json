[
  {
    "uuid": "4f023d48-51c7-579d-b140-ab0542b18522",
    "entry": "義弟",
    "reading": {
      "primary": "ぎてい",
      "alternatives": [
        "おとうと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
