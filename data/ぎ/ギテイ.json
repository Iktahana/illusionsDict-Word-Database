      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brother-in-law (spouse's younger brother or younger sister's husband)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "親爺はＫ市の海岸通りの船具屋である、その義弟の家へ出かけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一日も早く独立の生活を営み得るようになり、自分は大塚の家から別れ、義弟の秀輔に家督を譲りたいものと深く心に決する処があったのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が一時に發つといふ事を知つた義弟が、急に思ひ立つて私と一緒に歸るといひ出し、而して自動車を頼んでおいてくれたのだつた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細いだら／＼道の兩側にたて込んで茂つた小松から小松に、蜘蛛のかけ渡した絲にうるさく顏を撫られながら、義弟の家のある所に行つた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義弟の妻なる私の妹も、その子達も眼を覺してゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義弟は暫らく私と話し合つてゐたがやがて窮屈さうに體を曲げたなりで、うつら／＼と淺い眠りに落ちた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義弟を迎へに來てゐるべき筈の自動車は故障が出來たとかで來てゐなかつた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義弟は短氣らしくタキシーの運轉手の溜りに行つて、直ぐ一臺出せといつて見たが、生憎く一臺もあいたのはなかつた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやく自動車が出來たので義弟と私とはそれに乘つた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃丁度出來かけてゐたある事業の事を義弟は考へてゐるに違ひない。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の方に自動車の止る音がして、やがて階段の下で、義弟に当る七つの蓑吉の声がする。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことを一番不満に思ったのは政江の義弟の伝三郎だ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "内心義弟の口軽さをとがめたのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当座、いろ／＼と臆測されたが、就中政江の義弟たちは、政江がもと助産婦をしていたことが忌避されたのだと取沙汰した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "政江は、義弟の一人である千恵造の行状を破談の原因だと思い、自ら信じて疑わなかった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱心の余りいいすぎたと思った彼女は、「何も私は義弟さんのこと悪いう積りやおまへん」　と最後に附け加えた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の義弟達の上前をはねて憎まれるのも皆夫の為を想うからだ、と堅く腹をくゝっていたなればこそではないか。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫と義弟達の間に立って随分泣く想いをしたというのである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで幸子は夫の同意を得て、義弟の看護のために別荘に逗留することとなった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、たのみにならぬ男なのだから、義妹や義弟たちから、その家の事に就いて何の相談にもあずからぬのは、実に当然の事であって、また私にしても、そんな甲府の家の財産やら何やらには、さっぱり興味も持てないので、そこはお互いにいい按配の事であった。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それは、海軍の義弟の時計であったが、私が前から借りて私の机の上に置いていたものなのだ。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに立っているこの男は、この薄汚い中年の男は、はたしてわたしの義弟であろうか。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ違いの義弟と二つ違いの義姉がいて、その義姉が器量よしだと子供心にも判った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに乗り込んだ私たち一行――私と隆太郎と同伴の素峰子、その義弟のＴ少年、それにその地の「山峡」の歌人たち七、八｜子――である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方邵大尉の方では、約束の通り懸賞金五十両を出してそれを李幕事に与えたが、李幕事は義弟に苦痛を見せることによって得た金であるから、心苦しくてたまらない。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから久しい間｜経った今年の正月の末に、私は義弟のＦ学士の処に一晩泊りました。",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報は義弟のＦ学士と妹たちで、高知の病院に赴任の途中岡山で新青年を見て打ったものに違いありません。",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元の命のままに、西上の前軍を承って多くの功績を示したが、義元西上の志が粉砕された事によって、竹千代（弘治二年末義元の義弟、関口｜親長の女をめとる、後元康と称し更に家康と改む）の運命が開れようとは当人も想いつかなかったであろう。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちはめぐまれ過ぎているんだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが最後の集便時刻を過ぎていたので消印が翌日の日附になったものであろう。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
