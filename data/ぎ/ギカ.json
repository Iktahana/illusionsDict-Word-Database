[
  {
    "uuid": "c92a22c5-769a-5fa0-96b1-e1acfd5a8394",
    "entry": "偽果",
    "reading": {
      "primary": "ぎか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
