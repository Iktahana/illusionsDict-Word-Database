        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小豆色のセーターを着た助手が、水道のホーズから村山貯水池の水を惜気もなく注いで、寝台自動車に冷たい行水を使わせている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたくし、久しく行水しないから、この綺麗な水へ入って汗を流したいのよ。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上川の蛇行水路の右岸の平野に低湿の沼沢地が一面に分布しているのは不思議である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの通りに奥山の店から帰って来て、かれは台所で行水を使っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その灯に照らされた行水の湯は真っ紅に染まっていて、それが娘の喉からあふれ出る血であることを知った時に、お伊勢は腰をぬかすほどに驚いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "お作の行水をうかがっていたらしい女は、このどさくさのあいだに何処へか消え失せてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも第三のお作の場合は、見咎められたままにお紺がおとなしく立ち去ってしまえばよかったのであるが、彼女はお作が白い肌をあらわして素っ裸で行水をつかっている姿をみて、一種の残酷な興味を湧かせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏だったら行水が出来るのだが、秋も十一月の初めになっては行水どころではなかった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともあのこれから冬になりまして山がまるで氷ってしまい、川も崕も残らず雪になりましても、貴僧が行水を遊ばしたあすこばかりは水が隠れません、そうしていきりが立ちます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "政元は行水を使った。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　臺所の狹い張出しで、お媼さんは日が暮れてから自分で行水を使つた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵺が來て池で行水を使つたほどに、事大袈裟に立到る。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行水盥へ鰌が湧かうと云ふんだ、後生してくんねえ、番頭さん。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われさ行水するだら蛙飛込む古池というへ行けさ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の池の行水だね、しかし白蓮華は丈高い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上か、奈落か、山懷の大釜を其のまゝに、凄いほど色白な婦の行水する姿も見た。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人放り出して置いた處で、留守に山から猿が來て、沸湯の行水を使はせる憂慮は決してないのに、誰かついて居らねばと云ふ情から、家中野良へ出る處を、嫁を一人あとへ殘して、越中の藥賣が袋に入れて置いて行く、藥ながら、其の優しい手から飮ませるやうに計らつたのである。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行水の花の夕顏、納涼臺、縁臺の月見草。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て十何匹、行水盥に伏せたのが、一夜の中に形を消したのは現に知つて居る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つその狂か、痴か、いずれ常識無き阿房なるを聞きたれば、驚ける気色も無くて、行水に乱鬢の毛を鏡に対して撫附けいたりけり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなとこイはいって寒雀みたいに行水してたら、風邪ひいてしまうわ」そして私の方へ「あんた、よう辛抱したはりまんな。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山行水行はサンコウスヰコウとも、サンギヨウスヰギヨウとも、どちらにても読んで下さい、私にはコウがギヨウだから、――たゞ歩く、歩くために歩くのだけれど、それは自然発生的に修するのだから。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "エラがつて、おれの俳諧は眞劍だなぞと云ひながら、好い句も作れぬばかりで無く、審美眼さへまだ碌に開いてゐないやうな人※とはまるで行き方が違つてゐて、勝手に遊んでゐたといふ風なので、句も行水は其日の湯くわん哉といふやうなのが多い。",
              "citation": {
                "source": "淡島寒月氏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに一人の親仁なぞは、媽々衆が行水の間、引渡されたものと見えて、小児を一人｜胡坐の上へ抱いて、雁首を俯向けに銜え煙管。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてとよ……生肝を取って、壺に入れて、組屋敷の陪臣は、行水、嗽に、身を潔め、麻上下で、主人の邸へ持って行く。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁が、ふたふたと手を拍いて、笑い、笑い、「漁師町は行水時よの。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分飜刻物であるが、中の一枚の春信（のであつたか）の行水を使つて居る女の肉附は素敵であつた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじょうちゃんは、庭で行水をしながら、一人うたってたのです。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も那のこれから冬になりまして山が宛然氷つて了ひ、川も崖も不残雪になりましても、貴僧が行水を遊ばした彼処ばかりは水が隠れません、然うしていきりが立ちます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
