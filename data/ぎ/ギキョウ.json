[
  {
    "uuid": "79ea35c2-5a61-54cd-8717-6f22330e6baf",
    "entry": "義侠",
    "reading": {
      "primary": "ぎきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
