[
  {
    "uuid": "a11a5627-7034-5c64-a7ee-b205597375d6",
    "entry": "偽善",
    "reading": {
      "primary": "ぎぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hypocrisy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一人間を偽善にする。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意せよ、世には甚だ見分け難い偽善がある！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩らしい忠告なんて、いやらしい偽善だ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの書物を通して見た老子は妙にじじむさいばかりか、何となく偽善者らしい勿体ぶった顔をしていて、どうも親しみを感ずる訳には行かないので、ついついおしまいまで通読する機会がなく、従って老子に関する概念さえなしにこの年月を過ごして来たのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストの愛、などと言い出すのは大袈裟だが、あのひとの教える「隣人愛」ならばわかるのだが、恋愛でなく「異性を愛する」というのは、私にはどうも偽善のような気がしてならない。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人見の奴は口を拭っていやがるが貴様は偽善者だからなあ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だって貴様、俺だって貴様……とにかく貴様みたいな偽善者は千篇一律だからだめだよ……なあ西山」　牡蠣のような片目が特別に光って西山の方に飛んできた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……好男子、惜しむらくは兵法を知らず……まあいい、もう行け」「僕も人見君といっしょに君を送ろう」「酔不成歓惨欲別か……柿江、貴様ははじめから黙ったまま爪ばかり噛んでいやがるな……皆な聞け、あいつは偽善者だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が土地解放の社会的影響や私が既に充分に生活の安定を得て居り乍ら斯かる偽善的な行動をしたと云はれる非難に対して甚だ御尤もなる御説と恐縮する所であるが併し私にも多少の弁明は出来る積りです。",
              "citation": {
                "source": "狩太農場の解放",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな工合で毎日生きていながら私はビジテリアンですから牛肉はたべません、なんて、牛肉はいくら喰べたって一つの命の百分の一にもならないのだ、偽善と云おうか無智と云おうかとても話にならない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚は偽善の形式だろうか」　喫茶室からは、相変らず蓄音機の軍歌が聴えていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵姿は少しも変っていないばかりでなく、その眼は新に狡猾な色を湛え唇は偽善の皺に刻まれて一層醜く歪んでいたではないか！",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹一も、さすがに、これが偽善の悪計であることには気附かなかったようで、「お前は、きっと、女に惚れられるよ」　と自分の膝枕で寝ながら、無智なお世辞を言ったくらいでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、「女を救うため」などという男の偽善には、がまん出来ない。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はサロンの偽善と戦って来たと、せめてそれだけは言わせてくれ。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてかえって、俗物の偽善に支持を与えるのはこの人たちである。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんじら断食するとき、偽善者のごとく、悲しき面容をすな。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、ひどい偽善者なのかも知れん。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちは幼少の頃から、ただもう聖賢の言葉ばかりを暗誦させられて育って来たが、この東洋の誇りの所謂「古人の言」は、既に社交の詭辞に堕し、憎むべき偽善と愚かな迷信とのみをを知った。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽善を勘で見抜く事です。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをあの儒者先生たちは、それを末端の行儀作法の如く教えて、かえって君は臣を侮辱し、父は子を束縛する偽善の手段に堕落させてしまったのです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は儒者先生たちの見えすいた偽善の身振りにあいそが尽きたのです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ルヤ、君、断食ノ苦シキトキニハ、カノ偽善者ノ如ク悲シキ面容ヲスナ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸足になつてはひらうかとも思つたが、それはＮ君をただ恐縮させるばかりの大袈裟な偽善的な仕草に似てゐるやうにも思はれて、裸足にもなれなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉の腕は真の玉よりもよく、雪の膚は雨の結晶せるものよりもよく、太液の芙蓉の顔は、不忍の蓮よりも更に好し、これを然らずと人に語るは、俳優に似たがる若旦那と、宗教界の偽善者のみなり。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しいときに、寂しそうな面容をするのは、それは偽善者のすることなのだ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「禍害なるかな、偽善なる学者、パリサイ人よ、汝らは酒杯と皿との外を潔くす、然れども内は貪慾と放縦とにて満つるなり。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "禍害なるかな、偽善なる学者、パリサイ人よ、汝らは白く塗りたる墓に似たり、外は美しく見ゆれども、内は死人の骨とさまざまの穢とに満つ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯のごとく汝らも外は正しく見ゆれども、内は偽善と不法とにて満つるなり。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんじら祈るとき、偽善者の如くあらざれ。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
