[
  {
    "uuid": "e96badc1-cfd8-5522-bcb7-6235f83a5acd",
    "entry": "銀鈴",
    "reading": {
      "primary": "ぎんれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
