      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silver bell",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "突然、ユーストンの街路の銀鈴の響が尾をひいて、馬の踵の音が静寂な空気の中に運命的な号びをたてた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢を訪ふものは銀鈴を振るやうな河鹿の聲ばかりであつた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金泥を空にながして彩つた眞夏のその壯麗なる夕照に對してこころゆくまで、銀鈴の聲を振りしぼつて唄ひつづけた獨唱の名手、天飛ぶ鳥も翼をとどめてその耳を傾けた、ああ、これがかの夕日の森に名高く、齢若き閨秀樂師のなれの果であらうとは！",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "と転がして、発奮みかかって、ちょいと留めて、一つ撓めておいて、ゆらりと振って放す時、得も言われず銀鈴が谺に響く。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と恰も銀鈴のやうに澄み渡つた号令をかけ、ピアノが鳴り始めると、学生等は一勢に足並みそろへて、それからそれへ、様々な類ひの運動を懸命に繰り返します。",
              "citation": {
                "source": "舞踏学校見物",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜鵑、鶯、それに銀鈴のやうに澄んだ声も聞えた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "朗かな然も厳然たる音声で、恰も大理石の伝堂に反響する銀鈴の如く静に、……「汝！",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀鈴に触れるような爽かな声と共に、夫人は静かに扉をあけて入って来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "程よく焼いて用いるとき、――ピタピタと言う軽い足音が社務所の玄関口に近づいて来たかと思われるや一緒で、訪のうた声はまさしく銀鈴のような涼しい女の声です。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「裸でおられるということだ」「血衣を纒っておられるそうだ」「そうして時々経を読むそうだ」「そうして時々号泣するそうだ」「懴悔しているということだ」「銀鈴を鳴らすということだ」「滝の中に住んでいるそうだ」「娘よ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀鈴に触れるやうな爽かな声と共に、夫人は静かに扉をあけて入つて来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」頷聯に「此日雪景頗奇、銀鈴玉杖並実際所見、非倣銀海玉楼之顰」の註、頸聯に「二物客歳所得、此日始試」の註がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖気の美僧はもすそをひいてことばをなげき、うらうらとして銀鈴の魔をそよがせる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には散り雲ひとつなく、野づらには人声ひとつ聞えず、万象はさながら寂滅したかの如く、ただ頭上たかく天際にをののく雲雀の唄のみが、銀鈴を振るやうに大気のきざはしを通つて、愛慾に溺れた大地へ伝はり流れるのと、稀れに鴎の叫びか、甲高い鶉の鳴き声が、曠野にこだまするばかり。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、草がさやさやとそよぎ出して、さながら花が互ひに銀鈴を振るやうな細い細い声でささやきはじめたやうに思はれると、樹々は怒号するやうな物凄い音をたてて鳴りはためいた……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀鈴のような嬌めかしい声を出したもんだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花草の原のいづくに金の家銀の家すや月夜蟋蟀　月夜の蟋蟀の声を金鈴銀鈴と聞く心持からその栖家が「金の家銀の家」となるので、交感神経による音感と視感との交錯である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその夢心地の彼に「吉倉和歌子さん」と呼ぶ先生の声が銀鈴のように鳴り響いた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ時に耳の近くで蜩の晩涼を告ぐる銀鈴が爽かに響くと、もう堪らなく心が澄んで、名稱し難い希望と感興が湧いてくる。",
              "citation": {
                "source": "箱根の山々",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふきげんで、食慾がなく、夜はねむらないし、「小川の声は銀鈴のようにささやく。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清らかに澄み切った童子の声、銀鈴のように響き渡った。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、故人となられたが当時の主筆兼編集局長であった鳥居素川先生が「あの声を聞いただけでも若い婦人などは泣くね」と評されたほど感銘の深い、銀鈴を振るような声であった。",
              "citation": {
                "source": "印度の詩人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑畑で草雲雀が小さな銀鈴を鳴らすような涼しい声を振り立てる。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草のなかの小径に、釘づけにされたように歩を忘れた男の耳へまたしても響いてくる銀鈴の山彦――。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごしていると、女が銀鈴のような声を出した。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "海へ帰る女",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその恋人の三室銀子は、その頃漸く世に知られかけて来たソプラノ歌手で、技巧は大したもので無かったにしても、その名前の通りの銀鈴を振るような声と、伸び切ったしなやかな身体と、小娘らしい丸ぽちゃの顔が素晴らしい魅力で、その将来性は充分に約束されておりました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも清い、銀鈴の様な声をもって居る。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂うような頬、滴るような唇、精練され切った、銀鈴のような声、この女の全身は、卯の毛で突いたほどの瑕も無い、千乗の璧の如く清らかに、美しかったのです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
