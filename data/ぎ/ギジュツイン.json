        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは、アメリカの兵器会社の技師が発明した人造島で、われわれ技術員は、その耐熱試験をやっているのだ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆弾があれば、宿舎に投げつけて、技術員も、雑役夫も、みんな一気にやっつけることが出来るじゃないか。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "白堊の宿舎には、技術員も、雑役夫も、みんな正体もなく眠っている。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、兵器会社の技術員たちに、戦いを挑まねばならない。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「救けてくれい」「ああ……」技術員も、雑役夫たちも、今は全く手の下しようもなく、悲鳴をあげていたが、やがて彼等は、ぞろぞろと、博士の方へやって来た。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは創世記の方船だ」これをきくと、技術員や雑役夫たちは、「おお、方船！",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のほかに、数人の技術員が、まだ生残っているが、もう明日にも、方船から辷り落ちて、海底へ沈んでゆくかも知れない。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊船を探ってみないか」僕は、生残った技術員たちに呼びかけたが、彼等は、「いや、真ッ平だ」「あんな船に乗移ると、生命が奪われる」と、口々に呟いて、顫えている。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、老博士や、怪老人や、船に収容した生残りの技術員たちが駈けつけて来た。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人をも、船をも、一呑みにする魔の海だ」　生残りの技術員たちは、口々に叫んで、船橋から転げ落ちるように、甲板に降りて、なおも、「大渦巻だ！",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお」「おお」技術員たちは、甲板に腹匍いになり、半狂乱になって、哀叫している。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術員たちより、一日か二日｜生延びるだろうが、やがて、同じ運命に陥るのはわかり切っている。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "カコ技師が若い技術員をさしずして、発電室で電気を起させた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星技術員の機械技術は思ったより優秀だと見えて、なかなか好調だった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそこへは隣村の失業農業技術員Ｋという青年が来合せていた。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "角帽をかむる日まで、レントゲン技術員として勉強していた教室、ああ、一緒に入学試験を受け、同じく角帽の栄冠を得た親友｜蛸ちゃんはどうなったろう。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところに觀測所を建てて、多い時には二十人以上、少い時でも十人くらいの研究者と技術員とが、冬ごもりをした。",
              "citation": {
                "source": "冬ごもり",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青春の孤独一　市ノ瀬牧人はＩ市の地方事務所で開かれた農業技術員会議をたつた今おえて、自転車で目ぬきの通りを走つていた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "開所式には、米露の技術員も来臨するわけで、見苦しからぬよう諸般の整備をしておく必要があったのである。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年わたしがひっくるかえったときいたたけ、という女が、今熊谷在で産業組合の事務員をして居ります、それがきのう仲間三人もつれて来て、よっての話に、女の技術員になれとすすめられていますが、どうしましょう、というわけなの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業技術員なのです、肥料配合や何かを指導する。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校を出たりこういう程度の若い女が一ヵ月講習をうけて、技術員となり、農業指導が出来るものなのでしょうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
