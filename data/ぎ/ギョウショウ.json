[
  {
    "uuid": "3546f47f-9d4d-5c61-bcbf-f43f117c7d82",
    "entry": "行商",
    "reading": {
      "primary": "ぎょうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
