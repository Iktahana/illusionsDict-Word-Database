    "definitions": [
      {
        "index": 1,
        "gloss": "white poplar (Populus alba)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
