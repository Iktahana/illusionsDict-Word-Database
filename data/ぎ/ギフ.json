[
  {
    "uuid": "a0532440-4fb4-5af4-825f-f6c94b375e6f",
    "entry": "義父",
    "reading": {
      "primary": "ぎふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
