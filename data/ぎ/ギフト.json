          "literary": [
            {
              "text": "案内の峯君なぞはめったによりつかない証拠に、古道具屋は三軒とも、ギフト・ショップになっていた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギフト・チェックぐらいくるかもしれないわよ」と、こと欲に關しては、とつさに、よくもまあ、こう頭腦が廻轉するものである。",
              "citation": {
                "source": "字幕閑話",
                "author": "秘田余四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――老ホイットギフトである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "「箱に入れて、ギフト・ラップしてあげて」　ジョイスリンはイアリングを店員に渡した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
