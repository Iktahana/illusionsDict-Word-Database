[
  {
    "uuid": "d035e384-88e3-5298-bf11-b17b893f7c9f",
    "entry": "疑団",
    "reading": {
      "primary": "ぎだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
