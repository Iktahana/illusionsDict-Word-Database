[
  {
    "uuid": "4678061e-8b61-54c9-9a73-96b6845cc9ea",
    "entry": "暁星",
    "reading": {
      "primary": "ぎょうせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
