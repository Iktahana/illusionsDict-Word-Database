        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "卒業後彼をどこかの大学の助手にでも世話しようとする者もあったが、国籍や人種の問題が邪魔になって思わしい口が得られなかった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後長崎三菱造船所に入って実地の修業をした後、三十四年に帰京して大学院に入り、同時に母校の講師となった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後物理学科の聴講に出たり、ベルリン留学中かの地の若い学生の中に交じってブラジウス教授受持の物理実験の初歩のコースを取ったりした事実は、この特徴の由来を想像させるものである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後の就職などについても労を惜しまず面倒を見た。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の Edward Strutt が大学卒業後農事に身を入れるようになったので、一八七六年に家産全部の管理を弟に一任し、生涯再び家事には煩わされなくてもいいようになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際はやはり普通の講義や演習から非常なお蔭を蒙っていることは勿論であって、もしか当時そういう正規の教程を怠けてしまっていたらおそらく卒業後の学究生活の第一歩を踏出す力さえなかったに相違ない。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学歴は、中西女塾を卒業後、南洋大学の文科の聴講生となった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三は卒業後、両人があてにしていた程の金を儲けもしなければ、送ってくれもしなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の同窓で卒業後まもなく早世したＳ君に行き会った。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ先生にひどく楯を突いた生徒が、何かのきっかけでうって変った仲好しになり、卒業後も永く交際を続けて行く例など、案外たくさん聞くことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもの洋行はゆっくり卒業後という腹で一家はあった。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後白川は弁護士を開業し、彼は松村家へ養子となり、養家の財産を資本にして二三の事業を経営した。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後は、どこへも勤めず、固く一家を守っている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "規矩男自身と云えば、規矩男は府立×中学を出て一高の×部へ入り、卒業期に肺尖を少し傷めたので、卒業後大学へ行くのを暫く遅らして、保養かたがた今は暫く休学しているのだという。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の十一の歳から足かけ六年、今年二十二になる直助は地主であるかの女の家の土地台帳整理の見習ひとして、律儀な農家の息子の身を小学校卒業後間もなく、三里離れた山里から、都会に近いかの女の家に来て、子飼ひからの雇ひ男となつたのである。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日で云へば田舎の豪家の若者が従兄弟同士二人、共に大学に遊んで、卒業後東京の有力者間に交際を求め、出世の緒を得ようとしてゐるやうなものである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴に食わして貰うのは卒業後不可能です。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後もアグネスは何か陸軍に関係した勇ましい仕事を見付けたいと望んで居た。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の道太郎と共に早く両親を喪った彼女は、卒業後も、しばらく家で唯一の女手として兄の面倒を見ていた。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "既掲、頭山、杉山の項にも述べた通り、筑前藩の志士は維新の鴻業後、筑前閥を作る事が出来なかった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、第十代｜崇神天皇は、御肇国天皇と称せられ給ふ聖主で、神武御創業後の偉業を達成せられてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年生になると、もう卒業後の志望を決めて置く必要があるのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代に相撲が好きで得意であったような友人の大部分は卒業後陸軍へはいったが、それがほとんど残らず日露戦役で戦死してしまって生き残った一人だけが今では中将になっている。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後もそのまま研究に身を捧げまして、キングス・カレッジ病院にささやかな職を得ておりました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七〇年代に入り、時代の熱が急に冷めていく有り様を見送っていた彼は、高校卒業後、財産の私有を否定して一体の集団生活を送る山岸会に活路を求めます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに次の代にも引き継がれ、我々の卒業後もしばらくは出続けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後も、次世代の仲間は『しかし』を送ってくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校卒業後に加わった短歌の会で二、三年手ほどきを受けますが、結婚後は長く歌から離れていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
