        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母親はまず最初の試みに注意深く色と生臭の無い魚肉を選んだらしい。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく与える魚肉でも少し古ければ香をかいだままで口をつけない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四課　苦労について　料理通の話を聴きますと、「魚肉などで味の深い個所は、魚が生存中、よく使った体の部分にある。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐つた魚肉に日出雄少年が鼻を摘んだ話。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵、あふぎて見るものは天井の蜂巣蝋燭、伏して見るものは女人淫行の指、皿、魚肉、雲雀、酒盃、而して我が疾患蝕金の掌と、輝やく氷雪の飾卓晶峯とあり。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ塩気がつく、腥気がつく、魚肉が迸裂て飛んで額際にへばり着いているという始末、いやはや眼も当てられない可厭な窘めようで、叔母のする事はまるで狂気だ。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若又清鮮なる蔬菜、魚肉、鳥獸肉、果以て其の人の身體を良好にし、隨つて其の精神状態をも良好にする。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに魚肉をきらう様である。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、如何にも勿体ないという様子で魚肉を金網の上へ乗せ拡げて飯を食べ始めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "副食物は牛肉又は豚肉半斤、魚肉半斤、玉葱又はその他の野菜若干量という約束のところを、二三尾の小鰯に、十日に一度、茄子が添えられるだけであった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "副食物は牛肉又は豚肉半斤、魚肉半斤、玉葱又は其の他の野菜若干量という約束のところを、二三尾の小鰯に、十日に一度、茄子が添えられるだけであった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳か魚肉、それもいい所だけで堅い頭の骨などは食おうともしなかった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、彼は、いまだかつて食ったことのない豚肉や、魚肉やを食べさされた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまた清鮮な野菜・魚肉・鳥獣肉・果物等が潤沢に得られる土地であれば、事情はいよいよその人の身体を良好にし、その精神状態をも良好にする。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の歯はこの魚腹に葬られるかと見ていると、鱶はこんな物を呑むべく余りに大きい口をあいて、厨から投げあたえる食い残りの魚肉を猟っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の歯はこの魚腹に葬られるかと見ていると、鱶はこんな物を呑むべくあまりに大きい口をあいて、厨から投げあたえる食い残りの魚肉を猟っていた。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日のように、水に浸した乾飯や、生乾きの魚肉のあぶったものなどを口にする苦しみが、骨身にこたえてきた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは徳川氏が自分の政策上から、あんな料理法を拵へ上げたので、一体吾々の食べる魚肉といふものは、皮肉の間が膩が乗つて一番うまいものなんです。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉が馳走振に取つて呉れた新鮮な魚肉よりも、故郷の方で食べ慣れた鹽辛い鮭の方が私の口に適ひました。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚肉は好きでもありうまいと思ふけれど、食べてゐるうちにたまらなく腥いと感じることがある、獣肉はうますぎる、だからもたれ気味になる、やつぱり新鮮な野菜にしくものはない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐｜滓に魚肉をすりまぜたるなりとぞ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならばそれらの人々に当てがわるべき米の飯なり魚肉なり獣肉なりが、金持ちのためにみんな奪い取られているかと言えば、無論金持ちは金持ち相応にぜいたくな金のかかった食事をしているであろうが、しかしそれかというて、それらの金持ちが毎日一人して百人前千人前の米や肉を食べているわけではない。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフと同席の、相当年のいった男たちは、矢鱈に辛子をきかせた魚肉や牛肉を肴に、分別くさい口を叩きながら、がやがやと議論を闘わし、いつもなら彼が決して黙っていないような問題を盛んに論じあっていたが、しかしチチコフはまるで長途の旅に疲れはてて頭も働かねば何をする気力もない人間といった状態であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし飲酒は一大悪事、士君子たる者の禁ずべきものなれば、その入費を用意せざるはもちろんなれども、魚肉を喰らわざれば、人身滋養の趣旨にもとり、生涯の患をのこすことあるゆえ、おりおりは魚類獣肉を用いたきものなり。",
              "citation": {
                "source": "慶応義塾新議",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯛や鮪や、其他、鮎から鰛に至るまで、多くの魚肉の味は、如何なる調理法を以てしても、生のものには及ばない。",
              "citation": {
                "source": "「自然」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間揚州の住民は、文字通りに塗炭の苦を受け、魚肉の厄に罹つた。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人はその怨敵に對する時、よく欲噬其肉とか、食之不厭とか、將た魚肉之とかいふ文字を使用するが、こは決して誇張せる形容でなく、率直なる事實である。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ市中で食糧品は野菜から魚肉類まで大抵コムナールで買うようになっているんだ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江山棲前市場には、毎夜、百以上の屋台店が並んで、鶏肉や魚肉や豚の耳などが豊富にある。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "錫製の椀には獣肉が盛られ、南京産らしい陶器の皿には、野菜と魚肉とが盛られてある。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
