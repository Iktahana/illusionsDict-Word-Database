[
  {
    "uuid": "ed6fa886-0d61-51b7-b6f3-db425e5cdbb1",
    "entry": "伎楽",
    "reading": {
      "primary": "ぎがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
