    "definitions": [
      {
        "index": 1,
        "gloss": "imperial visit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ホオ……と僕はお道化てゐるんだがまだ見ぬ先生に意地の悪い気持を抱いてゐるんだが、煙草をまづく感じ出すと、飛行機のみならず、洋服掛にまで、異常な好奇心を覚ゆるのであつた――とにかく御幸福なお方であらせられるよ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蛸薬師の通りを西へ真っ直ぐ――御幸町を越え、麩屋町を過ぎ、富小路を二三軒西へ行くとちぎり家の別館があった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お納戸、利久、御幸鼠、鶯茶、それにはなほ青柳の色も雑つて、或は虫ばみ、或はねぢれたのもあり、斑らに濃い地面の色の上に垂れ流れるのは自らなる絵模様である。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その病後の療養に、私は小田原の御幸ヶ｜浜へ一と月ばかりほど転地していたことがあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの御幸福をお祈りします。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴代の行幸、御幸、伊勢の大廟よりはるかに多く、およそ十四帝八十三回に及べり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし京都より本宮に詣るに、九十九王子とて歴代の諸帝が行幸御幸の時、奉幣祈願されし分社あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりおりは音楽の会などを世間の評判になるほど派手にあそばして、院の陛下の御生活はきわめて御幸福なものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御幸福ばかりでなくおなりになって、深味がおできになりましたね。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢様を御幸福な方にしてお見上げしたいと、どんなに長い間祈って来たことでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宮様がおいでになったころ、私の結婚相手が悪いからって、交際するのをおきらいになったものですから、私らもついかけ離れた冷淡なふうになっていましたものの、それからもこちら様は源氏の大将さんなどと御結婚をなさるような御幸運でいらっしゃいましたから、晴れがましくてお出入りもしにくかったのです。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『五雑俎』五に、宋の張耆四十二子あり、〈諸姫妾の窓閣皆馬厩に直す、馬○○するごとに縦ってこれを観せしめ、随いて御幸するあれば孕を成さざるなし〉（『日本紀』武烈紀八年の条参照）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "定家卿の『建仁元年後鳥羽院熊野御幸記』に鹿瀬山を過ぎて暫く山中に休息小食す、この所にて上下木枝を伐り、分に随って槌を作り、榊の枝に結い付け、内ノハタノ王子に持参（ツチ分罰童子云々）し各これを結い付く。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "御幸原の稱あれど、峰脈の上の一小地に過ぎず。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという御幸運じゃ、それに比ぶれば、拙者兄弟はなんという不運でござろうぞ。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日ほど御幸ヶ浜の養生館に居ます。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日から当寺の御祭礼といふので、近所の人々がやつて来て、幟を立てたり何かしてゐる、大国旗小国旗、“御幸山大権現”の幟が何本も立てられた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡母第四十九回忌、御幸山大権現祭日、地久節、母の日週間。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――忘れるせぬ、昨年十二月十五日一洵老に連れられて此度新居へ移つて来た御幸山麓御幸寺境内の隠宅、――高台で閑静で家も土地も清らかであり市街や山野の遠望も佳い、――殊に和尚さんにその人を得た、たゝ感謝あるばかりである。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十五年二月、御幸山麓一草庵にて　山頭火）（昭和十五年四月刊）",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上の御全快と御幸福をおいのりいたします。",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、四条の御幸町角に、吉観といふ染料絵具や、いろいろの物を売つてゐた家があつて、そこへよく、東京から、芳年や、年方などの錦絵が来てゐました。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は四条御幸町に店を構え、茶舗を創めたばかりのところでした。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "四条御幸町の角に吉勘と言って錦絵の木版画や白描を売っている店がありましたが、使い走りをした時などここで絵を買うて貰うのが一番好きなお駄賃でした。",
              "citation": {
                "source": "今日になるまで",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前、高橋さん来訪、厚情に甘えて、新居へ移った、御幸山麓、御幸寺の隠宅のような家屋、私には過ぎている、勿体ないような気がする。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一洵君に連れられて新居へ移って来た、御幸山麓御幸寺境内の隠宅である、高台で閑静で、家屋も土地も清らかである、山の景観も市街や山野の遠望も佳い。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
