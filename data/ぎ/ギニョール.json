        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、結城孫三郎やダークのマリオネット、ないしはギニョールのパンチとジュデーなどに対する独特の地位を全然喪失してしまうことは明白である。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――パリのグラン・ギニョールを見たか？",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の新発明の見世物だがね……グラン・ギニョールの上手を行く興行だ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　※レリー　巴里シャン・ゼリゼェの林のなかに二つの小屋があって、今でも日曜祭日毎に昔ながらのギニョール、手套式の人形芝居が学校や家庭から解放された子供達を喜ばせて居る。",
              "citation": {
                "source": "人形芝居に関するノオト",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年ゲーテが故郷フランクフルトで旅廻りの人形芝居を見た印象から、後年あの大作「ファウスト」を書いたように、此の巴里のギニョールも沢山の仏蘭西少年の心のなかに、人類の至宝ともなるべき大きな夢を今現に育てつつあるのかも知れない。",
              "citation": {
                "source": "人形芝居に関するノオト",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮面は、能の面とは似てもつかぬ、ギニョール風の頭からかぶるグロテスクな面でした。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしが……」「ノン」「そいじゃ、これからギニョールの始まりだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、右手がギニョール、左手がキャヌウズなの。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」キャヌウズ――ギニョールさん、ギニョールさん。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギニョール――あたしはおりませんよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギニョール――したが拙者は出られないのでござる。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが声は聞えないので、まるでギニョール芝居を見ているようだ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の子供が見世物のグラン・ギニョールに熱狂するようなものであろう。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
