[
  {
    "uuid": "3eab515e-2aaa-585e-bff6-fbef14674b82",
    "entry": "技術",
    "reading": {
      "primary": "ぎじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
