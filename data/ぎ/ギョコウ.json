[
  {
    "uuid": "935eca3b-d225-5338-9406-4d4c6a7081d4",
    "entry": "漁港",
    "reading": {
      "primary": "ぎょこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fishing harbour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "入君は出勤、私は足にまかせて街をあるきまはる、やつぱりこゝもたべものやが多い、工場町、漁港町はどこでもさうだが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ薄暗い空氣の中に、私達は江角の漁港を見た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの小さな漁港なのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "北は北海道、南は九州の果にいたるまで、淋しい漁港は何々銀座という通りがあるものだ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台から北の牡鹿半島のノドクビに石の巻という漁港がある。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　この県には三陸の漁場をひかえて、塩竈、石巻という二ツの市、気仙沼、女川、渡波などという漁港がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに、金華山にちかく、牡鹿半島の尖端に鮎川という鯨専門の漁港がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象は二ツの漁港の扱う漁船の相違に、よるのだね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワシがとれないと三陸の漁港はみんな参ってしまうらしいね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁港都市の人口は加工業の労働で主として支えられているのだから、イワシがとれないと市全体が参るのだね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は現在伊東市という温泉都市に住んでいるが、ここは同時に伊豆では屈指の漁港、焼津だの三崎についで相当の人口をもつ漁師街がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は去年は早朝に魚市場へ散歩に行くのが習慣だったから、伊東の水揚げはずいぶん見たが、とても三陸の漁港とでは問題にならない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が牡鹿半島を南下したのは、鮎川という南端の漁港へ行くためだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さんは御存じかも知れませんが、私はこの地へくるまでこんなところに捕鯨専門の漁港があることを知らなかったのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに昔ながらの漁港は因習的で暗い。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "クジラ専門の鮎川には、近代的な大会社の資本がはいって漁法にも運営にも計画された設計があるから、昔ながらの漁港に見られる因習的な暗さがないね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎川はこの暗い東北でも半島の先端にとりのこされた漁港でありながら、石巻のように悲しくみじめな暗さが少いのは、漁港全体の運営に近代性があるせいだろうね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い昔ながらの漁港や農村も、思いきって運営の方法を根本的に変える時期に来ているのではないかね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも結構明るいのは、やっぱり漁港全体の運営が近代的のせいだと見る私がまちがっているのであろうか。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "言って見れば、山上一族が住む相州｜三浦の公郷村からほど遠からぬ横須賀の漁港に、そこに新しいドック修船所が幕府の手によって開き始められていたのだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルの例　次にハル（＝Kingston-upon-Hull：イングランド中東：漁港）の町について考えてみよう。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町は温泉地として有名であるにもかかわらず、実は今でも町全体の収入を見ると、温泉地としてよりも漁港としての方が多いという話である。",
              "citation": {
                "source": "雑魚図譜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋の暮、少し静養の意味で、漁港と温泉とを兼ねたここの土地へ移ってきてからもう一年に近い。",
              "citation": {
                "source": "室鰺",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英領南アフリカ喜望峰の近くに、東倫敦という小さい漁港がある。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば港湾であるが、漁港の整備費に二十三億円を使っているが、手がけている漁港の数は、何と七十七港に及ぶというのである。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の方では長崎県のある有名な漁港で、海底が浅くなって困ったことがある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁港だけに新鮮な魚がある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁港らしい灯が日和佐川に映っている。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
