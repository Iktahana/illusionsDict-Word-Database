    "definitions": [
      {
        "index": 1,
        "gloss": "propensity to put oneself in as bad a light as possible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
