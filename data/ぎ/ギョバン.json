        "index": 1,
        "gloss": "large flat wooden plank shaped like a fish, struck like a gong at temple to indicate time of day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
