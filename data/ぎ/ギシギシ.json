        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a creak",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう家に通有な、急勾配で踏めばギシギシ音のする階段であった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしくって、ギシギシいってるだろう。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、まるで澱粉の上でも歩いているように、足の下で、雪がギシギシ鳴りました。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に僕等のやうな「柔軟な頭脳」の所有者にとつては、あの幾何学公式のやうな書体で書かれた「純粋理性批判」の第一頁を読むだけでも、独逸的軍隊教育の兵式体操を課されたやうで、身体中の骨節がギシギシと痛んで来る。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床板はギシギシときしみ、壁からは紙片が、リボンのように垂れ下っているのが手に触った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それが岸に在っては堤防に、橋の上では欄杆へとギシギシと押し詰められている。",
              "citation": {
                "source": "死者を嗤う",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を動かして見ると首筋のところがギシギシと妙な音をたてた。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、イスをギシギシさせるんじゃないぞ」　また、一年生が顔をのぞかせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　廊下の板が一枚一枚しのり返っていて、歩くとギシギシいった。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "健が家へ帰って床に入り、ウトウトしかけた頃、表のギシギシする戸が開いた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちが先とも分らず目が覚めたが、そのときはもう太陽が高く上っていて、バラックの外には荷車がギシギシ音を立てて通ってゆくのが聞えた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギシギシと海底が割れてゆくのに、陸地の方では何にも知らない。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの額のなかにギシギシと厭な音がきこえた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から後からわたしを小衝いてくるもの、ギシギシギシギシ動いてゆくものに押されているうち、わたしの硬かった足のうらがふわふわと柔かくなっていた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "村道を突切り、田の小径を渡り、山路にさしかかると、棺を担ふ竹がギシギシと音をたてた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から後からわたしを小衝いてくるもの、ギシギシギシギシ動いてゆくものに押されて歩いてゐるうち、わたしの硬かつた足のうらがふはふはと柔かくなつてゐた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "物干台は雨風に腐つて黒くなり、彼の歩くたびにギシギシと音を立てる。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵は余り新しくない建て物でありますから、ギシギシ、ミシミシ、どこかしこが鳴り出します。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　長屋だてのギシギシした板の間をふんで、お君さんの御亭主が出て来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が停るたび、片栗粉のやうにギシギシした雪を踏んで、ぶらぶら歩くのですか、皆｜毛皮裏の外套を着込んで、足にはラシャ地で製つた長靴をはいてゐます。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十二日大沢玲子より　　　中林先生様　御許に　……梯子段が二度ばかりギシギシと音を立てた……玲子はハッと吾に返って立止まったが、それでもサロンに来ると、敷き詰めてある豪華な支那｜絨氈のために足音が消されてしまったので、玲子はホッと安心した。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玲子はまた急に悲しくなりながら、サルーンの電燈を消して、ギシギシと鳴る階段を手探りの足探りにして三階の方へ上って行った。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、なんという不思議な女だろう」と露わに驚嘆の色を泛べて、「自分から好んで犯人の領域に近づきたがっているんだ」「いや、被作虐者かもしれんよ」と法水は半身になって、暢気そうに廻転椅子をギシギシ鳴らせていたが、「だいたい、呵責と云うものには、得も云われぬ魅力があるそうじゃないか。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてブランコが小屋全体をギシギシとゆすって、大ぶれになって来ると、「エッ！",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
