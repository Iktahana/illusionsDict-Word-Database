[
  {
    "uuid": "52a48ee7-086d-5579-b236-26baf4156bad",
    "entry": "ギシギシ",
    "reading": {
      "primary": "ギシギシ",
      "alternatives": [
        "ぎしぎし"
      ],
      "is_heteronym": false
    },
    "grammar": {
