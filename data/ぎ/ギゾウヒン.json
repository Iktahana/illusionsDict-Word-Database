          "literary": [
            {
              "text": "これは偽造品と区別するためのミヤコ缶詰会社の隠し符号であったわけである。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォードの姿を知っている係員たちが別荘に行き、なぜこの頃発行されている全ての小切手が下手な偽造品なのかと聞いた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "消印は一体型の偽造品です。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽造品を所々汚し、シミをつけて送り返します。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
