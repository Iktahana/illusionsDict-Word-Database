      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "your will",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そは神の御意に非ず。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『桜陰比事』の「四つ五器かさねての御意」などもそうした例であると同時に、西鶴の実証主義を暗示するものと見られる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師もまた夜眠ることが出來ず、そしてもう神の御意が分らなくなつでしまつてゐるからだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては運命の神様の御意のまゝなんだからな。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうですとも、考えがあるなら言ったがいいじゃアないか、加藤さん早く言いたまえ、中倉先生の御意に逆ろうては万事休すだ。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御意、」と一同川岸に休息する。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へゝゝゝ、恐れながら御意にまかせ、早速おん対手」と按摩が云ふ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初めて御意を得ます。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやかかる手紙願わくは送りたまわざれとの御意、確かに承りぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "友の交わりを続けてよとの御意、承りぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さんまでが「まあきれいだこと」と御意遊ばした。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　番頭は一大事のごとく、固くなって、御意を得ると、夫人は何事もない風情、「まあ、何とおっしゃる方。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速お通し申しましょうかと存じましたなれども、こちら様はお一方、御婦人でいらっしゃいます事ゆえ念のために、私お伺いに出ました儀で、直ぐにという御意にござりましたで、引返して、御案内。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御意にござりまする。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、六人をずらりと見渡し、「いや、これは誰方も、はじめまして御意を得ます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はいはい、御意にござりまする。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いま一膳はいかゞ仕らむ」と伺へば、幼君「さればなり其膳は籠の中に遣はせ」との御意、役人訝しきことかなと御顏を瞻りて猶豫へり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大分、御意見とは違いますように存じますが。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と姫は四辺を見て、御意遊ばす。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御意の通りでございます。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御意の通りで」「拙者に少しく不用の金子がある。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御意の通り一応お改めいたしますでござります」　蓋を開くと中に小判が一ぱいつまり、月にぎらぎらかがやきました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と夫人とも／″＼切に勸めるので、元來無遠慮勝の私は、然らば御意の儘にと、旅亭の手荷物は當家の馬丁を取りに使はし、此處から三人打揃つて出發する事になつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が労役に行くと云ふことも、畢竟は貴方の御意思通りに従はうと云ふにすぎません。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えらいことをしやべつたな」と云つたら、真顔になつて、「だつて私は貴方の御意見に雷同したんですもの」と云つた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が勞役に行くと云ふことも、畢竟は貴方の御意思通りに從はうと云ふにすぎません。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御意で、へ、へ、へ、」　と唯今の御前のおおせに、恐入った体して、肩からずり下って、背中でお叩頭をして、ポンと浮上ったように顔を擡げて、鼻をひこひこと行った。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
