[
  {
    "uuid": "95d3905e-94aa-50cf-a40e-d077d9201c6b",
    "entry": "虐政",
    "reading": {
      "primary": "ぎゃくせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
