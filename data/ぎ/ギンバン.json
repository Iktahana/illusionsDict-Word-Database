        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "連り亘る山々の薄墨の影の消えそうなのが、霧の中に縁を繞らす、湖は、一面の大なる銀盤である。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間に近寄って来たか給仕の老人は輪切りにした牛骨の載れる皿を銀盤で捧げて立っている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春のことでいっぱいたたえた水が、月の下で銀盤のようにけぶり光っていた。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「濡れるぞ、もつとこつちへ寄り給へ、情味は薄暮れの銀盤をゆくごとしだね」　私はかう言つて彼の方に余計に洋傘をさしかけながら、雨の路面を見た。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無数の真珠を、銀盤の上に落すやうな音だ。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かく小さな真珠の粒が軽く銀盤の上に転がすかのやうに、サラ／＼と池の面に音がありました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、銀盤とか玉盤とか形容するよりも、銅盤とか銅鏡とかいう方が当っているらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、銀盤を竹の箆で摩擦する音のような、いわゆる呱々の声がきこえました。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀盤上に黒い陸影、その陸影の四方を繞つて千古無終、我が潮の響は鳴り渡つてゐるのだ。",
              "citation": {
                "source": "海潮の響",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄みきった天心に、皎々たる銀盤が一つ、ぽかッと浮び、水波渺茫と霞んでいる辺りから、すぐ眼の前までの一帯の海が、限りない縮緬皺をよせ、洋上一面に、金光が、ちろッちろッと走っているさまは、誠に、もの凄まじいばかりの景色でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして郵便物を載せた銀盤を卓の一番端の処へ、注意してそっと置いた。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銀盤は偶然だが、実際ある寺院で使っていたロオマ時代の器具であった。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやおらその手を銀盤の方へ差し伸べた。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "その銀盤は、よく見ると、内がわの曲面いっぱいに、たくさんの光った針が生えていた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の光は幾重にも重った霊廟の屋根を銀盤のように、その軒裏の彩色を不知火のように輝していた。",
              "citation": {
                "source": "霊廟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで金の指環が銀盤の中へ落ちるような音だ、と彼は住居の扉の錠をおろしながら考えた。",
              "citation": {
                "source": "衣裳戸棚",
                "author": "DER KLEIDERSCHRANK",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたいそう暑い日だったとみえ、大きな銀盤に氷が盛ってあった。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は文字通りの銀盤だが、それが海面にうつった光は、不思議にも黄金色であった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "玲瓏として銀盤上に玉を転ずるようだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀盤の上を玉あられの走るような、渓間の清水が潺湲と苔の上をしたゝるような不思議な響きは別世界の物の音のように私の耳に聞えて来る。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ、朝廷の賜餐には馴れ、街の銀盤玉杯にも飽いているから、どんな歓待とて、彼の舌や眼を驚かすには足らない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の楼台には、楽手や歌姫がならび、玻璃銀盤の卓には、珍味が盛り飾られて、朝野の貴紳があらゆる盛装を競ッていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前日から煮きこめた百珍の料理は銀盤に盛られ、酒も家蔵の吟醸を幾壺となく持ち出して、客の前において封を切るばかりに用意していた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉海呉山の珍味は玉碗銀盤に盛られ、南国の芳醇は紅酒、青酒、瑪瑙酒など七つの杯に七種つがれた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
