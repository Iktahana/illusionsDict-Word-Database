    "definitions": [
      {
        "index": 1,
        "gloss": "tightly (hold, squeeze, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
