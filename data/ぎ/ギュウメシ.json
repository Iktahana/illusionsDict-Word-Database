        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、最後の十銭の白銅を牛飯にかえて五六時間地上の生活をのばす代わりに、ついふらふらと気紛れでそれをこの動物園の入場料にかえてしまったものらしい。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ　上は精養軒の洋食から下は一膳飯、牛飯、大道の焼鳥に至るさ。",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "男爵と牛飯８・28（夕）　頃日亡くなつた岩村透｜男は、平素から自分を巴里仕立の結構な美術家だと信じてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美味い牛飯屋が一軒あるんです、御存じですか、本郷の中央会堂の横丁に。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして物の二十分と経たぬ間に会堂｜側の牛飯屋の店先に立つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十銭の牛飯も食えないなんて……。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、夜おそくなると書生と牛飯というのを食いに行き行きした。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂利や瓦や川土を積み上げた物蔭にはきまって牛飯やすいとんの露店が出ている。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂利や瓦や川土を積み上げた物蔭にはきまつて牛飯やすゐとんの露店が出てゐる。",
              "citation": {
                "source": "水　附渡船",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なんぞ本郷三丁目から通っていたんですが、本郷本富士町の警察の前に大きな牛飯食堂がありました。",
              "citation": {
                "source": "美術学校時代の岡倉先生",
                "author": "板谷波山",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦土の生計として上野の山に葭簀を持ち牛飯を売る。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
