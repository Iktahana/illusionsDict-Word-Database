[
  {
    "uuid": "65f4dfd9-284b-5adf-8205-8f4b108e8b09",
    "entry": "蟻酸",
    "reading": {
      "primary": "ぎさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "formic acid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "真珠酸と蟻酸との間に十五の酸があるのが真実であるとおり、それはまさしく確かなのだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあちらでは女の子達が米つきばったを捕えては、「ねぎさん米つけ、何とか何とか」と言いながら米をつかせている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねぎさんというのはこの土地の言葉で神主のことを言うのである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　不意に驚き得三は今や下枝を突かんとしたる刀を控えて、耳傾くれば、「あかァぎさん、とくぞうさん。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はようよう遥になり、北の台にて哀げに、「あかァぎさん、とくぞうさん。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、もう、靴ぬぎさんと婚約しているんですもの」「婚約しているって！",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「済まなかったね、みつぎさん、お前さん、貢さんて言うの？",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、いちばんあとからお通りかかりになった、お供の大国主神がそれをご覧になって、「おいおいうさぎさん、どうしてそんなに泣いているの」とやさしく聞いてくださいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわいい、めやぎさん、おはようございます。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おつぎさん能く來たつけな」列を離れた踊子が汗の胸を少し開いて、袂で頻りに煽ぎながら樅の木の側に立つていひ掛けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おゝ暑いやまあ、咽つ返る樣だ」と、袂の端で汗を拭きながら「おつぎさん、踊んねえか」と他の一人がいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨あがりの暖い日に、私は井戸端で水汲をしておりますと、おつぎさん――矢張柏木の者で、小諸へ奉公に来ておりますのが通りかかりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おつぎさん、どちらへ」　と声を掛ると、おつぎさんは酸漿を鳴しながら、小｜肥りな身体を一寸｜揺って、「これ」と袖に隠した酒の罎を出して見せる。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お使かね」「ああ」「御苦労さま」「なあ、お定さん、お前許の奥様は……あの御盲目さんだって言うが、真実かい」「まあ、おつぎさんの言うこと」「ホホホホホホホホホ、だって評判だよ。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎさんはお尻を叩いて笑いながら、「好御主人を持って御仕合」　と言捨て逃げる拍子に、泥濘ヘ足を突込む、容易に下駄の歯が抜けない様子。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の子守が「菊屋に奉公していた下女」と言えば、一人が「柏木から来たおつぎさんよ」と言う。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸を担いだ人々が坂を上って来るにつれて、おつぎさんということは確に成りました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎさん――ホラ、春雨あがりの日に井戸端で行逢って、私に調戯って通った女が有ましたろう。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "白く降埋んだ往来には、人や馬の通る痕が一条赤く染いている――その泥交りの雪道を、おつぎさんの凍った身体は藁蓆の上に載せられて、巡査｜小吏なぞに取囲まれて、静に担がれて行きました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘盛に思いつめたおつぎさんこそ不運な人。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か小一年ばかりの間に、おつぎさんのこの変りようはどうでしょう。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎさんばかりでは有りません。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎさんはお尻を叩いて笑いながら、「好御主人を持って御仕合」　と言捨て逃げる拍子に、泥濘へ足を突込む、容易に下駄の歯が抜けない様子。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
