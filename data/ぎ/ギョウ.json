[
  {
    "uuid": "2b079050-d7e2-5a92-b540-63148ae0bb9e",
    "entry": "行",
    "reading": {
      "primary": "ぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
