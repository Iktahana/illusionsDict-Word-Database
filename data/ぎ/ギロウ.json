    "definitions": [
      {
        "index": 1,
        "gloss": "brothel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "窓という窓には眼隠しの板が張ってあって、何軒となく立ちならんでいる妓楼は、ただ真黒なものの高低の連なりにすぎないけれども、そのどの家からも、女のはしゃぎきった、すさんだ声が手に取るように聞こえていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はおそらく其金を分配して、新宿の妓楼に足を入れたであらうと鑑定したのである。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを出ると、妓楼が軒をならべている芝居裏の横丁であったが、何か胸に痛い様な薄暗さと思われた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉を換えると、虚子は小坊主の運命がどう変ったとか、どうなって行くとか云う問題よりも妓楼一夕の光景に深い興味を有って、其光景を思い浮べて恋々たるのである。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに竜池は劇場に往き、妓楼に往った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓楼は深川、吉原を始とし、品川へも内藤新宿へも往った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また未だかつて妓楼に宿泊したことがなかった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之助は天保九年に十七歳になった頃から、料理屋、船宿に出入し、芸者に馴染が出来、次で内藤新宿、品川の妓楼に遊んだ。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保十三年三月の頃から五｜分月題の子之助は丁稚兼吉を連れて、鳥羽屋を出で、手習の師匠松本、狂歌の宗匠梅屋鶴寿等を訪うことになったが、その帰途には兼吉を先に還らせて、自分は劇場妓楼に立ち寄った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓楼は主に品川の島崎｜湊屋、土蔵相摸で、引手茶屋は大野屋万治方であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "香以の通った妓楼は初め吉原江戸町一丁目玉屋山三郎方で、後｜角町稲本楼である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "香以のこの頃往った妓楼は稲本、相方は二代目小稲であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や数百金にもなりつらむと思ふ頃、その中より数枚を取り出し、丸山の妓楼に上り、心利きたる幇間に頼みて、彼の香煙の器械一具と薬の数箱を価貴く買入れぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の長崎にて切支丹の御検分ことのほか厳しくなり、丸山の妓楼の花魁衆にまで御奉行、水尾様御工夫の踏絵の御調べあるべしとなり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には新地の妓楼に上つて豪遊をするさうだといふゴシップもあつたが、それが仮令事実であつても悪い感じはしない程に先生の行動は周囲から切り離されたものゝやうに見えたのであつた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川の妓楼へ一泊した広巳は、家へかえるのが厭だから、朝帰りの客を待っている小料亭へあがって、旨くもない酒を喫んで気もちをまぎらし、飯も喫わないで帰っているので、喫いだしてみるとひどく旨かった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊ちゃん、叔父さんは、お疲れになってるのですよ」「疲れるものかい、叔父さんは、昨夜、品川のお妓楼へ往ったのだい」　お町は口がふさがった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか、そうか、叔父さん、品川へ往ったのか」「往ってたのだあい、品川のお妓楼へ往ってたのだあい」「何人がそんなことを云ったのだ」「お母さんが云ってたのだあい」「なに、お母さんが」「云ったのだあい、云ったのだあい」　同時に広巳は腰をあげた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の夜桜というのは、茶屋の店先や妓楼の庭などへ勝手に植えられたもので、それが年中行事の一つとなって、仲の町に青竹の垣を結い廻して春ごとに幾百株の桜を植え、芝居の「鞘当」の背景に見るような廓の春を描き出すことになったのは、この物語の主人公が亡びてから二十年余の後であった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の下の仲の町には妓楼や茶屋の男どもが真っ黒に集まっていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州一円に廃娼を実行したのは明治二十三年の春で、その当時妙義の町には八戸の妓楼と四十七人の娼妓があった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓楼の多くは取り毀されて桑畑となってしまった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ふところの夕暮れに歩み疲れた若い旅人が青黒い杉の木立のあいだから、妓楼の赤い格子を仰ぎ視た時には、沙漠でオアシスを見いだしたように、かれらは忙がわしくその軒下に駈け込んで、色の白い山の女に草鞋の紐を解かせたでしょう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の昔には、吉原の妓楼や引手茶屋の主人にもなかなか風流人がございまして、俳諧をやったり書画をいじくったりして、いわゆる文人墨客というような人たちとお附合いをしたものでございます。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの父なぞは、いっそもう商売をやめてしまおうかなぞと言ったくらいでしたが、母や同商売の人にも意見されて、もう少し世の成行きを見ていようといううちに、京橋のまん中に遊廓なぞを置くのはよくないというので、新島原は間もなくお取潰しになりまして、妓楼はみんな吉原へ移されることになりました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い通りへ出ると、両側の妓楼の二階や三階に薄暗い瓦斯燈が点れて、人影がちらほら見えた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の音などの聞える船着きの町の遊郭には、入口の薄暗い土間に水浅黄色の暖簾のかかった、古びた大きい妓楼が、幾十軒となく立ちならんでいた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴蘭で雑炊を食べてから、妓楼へ押し上つたのだつたが、花魁の部屋で、身のうへ話をきいてゐるうちにいつか夜が更けて、晴代は朝方ちかい三時頃に、そつと其処を脱け出し引手茶屋のお辰を呼びおこし、そこに泊めてもらつたことから、彼女のカフヱ勤めも、母に知れてしまつたのだつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は、その池をたらいにすがって、南から北に横ぎろうというのでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、少女ははいて出かけたのですが、通りをいそいで横ぎろうとしたとき、二台の馬車がおそろしい勢いで走ってきたので、あわててよけようとした拍子に、なくしてしまったのです。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
