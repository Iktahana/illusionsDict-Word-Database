        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つくづくと首｜延し見れば、こちごちの濃霧のなびき、渓の森、端山の小襞、黒ぐろとまだ気ぶかきに、びようびようと猛ける遠吠、をりからの暁闇を続け射つ速弾の音。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくづくと首｜延し見れば、こちごちの濃霧のなびき、渓の森、端山の小襞黒ぐろとまだ気ぶかきに、びようびようと猛ける遠吠、をりからの暁闇を続け射つ速弾の音。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁闇を、物々しく立ち騒ぐ風と波との中に、海面低く火花を散らしながら青い炎を放って、燃え上がり燃えかすれるその光は、幾百人の漁夫たちの命を勝手に支配する運命の手だ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の下には夢で見たとおりのルフィノ寺院が暁闇の中に厳かな姿を見せていた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夜明けとなれば既に暁闇と旭光の織り出す絢爛は消え、一気に一音の合図と一緒かのように、視界は隅なき明るさに明け放たれるのであった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ後方には、水雷戦隊が暁闇の波浪をのりきって驀進しつつある。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色の蚊帳ばかりではない、暁闇ばかりではない。",
              "citation": {
                "source": "紫式部",
                "author": "――忙しき目覚めに",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁闇が萩のしずれに漂っていた。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、もう一ぱい引っかけて行きな」　名残りの茶わん酒を汲みかわして、いつか、露が深くなって、それが薄霜のようにも見える暁闇の浅草田圃を、二人はまた辿って行った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、屋外で、深夜、暁闇のしずけさを破って、　――ドン、ドン、ドン、ドン！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大火災の煌々たる明るみの後に、暫し暁闇がたゆたい、それから、煙と灰に空を蔽われてる盲いたような一日となりました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「クリストレロの諷刺詩」一五九八年、Ｔ・Ｂ作　秋も更けて、暁闇がすぐに黄昏となり、暮れてゆく年に憂愁をなげかけるころの、おだやかな、むしろ物さびしいある日、わたしはウェストミンスター寺院を逍遥して数時間すごしたことがある。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか石の稽古なんかそっちのけに、ここを先途と暁闇の川中島さして上杉謙信入道を、堂々と進軍させていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け方の闇は、夜中の闇よりもいっそう深沈として――その暁闇につつまれた左膳、源三郎、萩乃の三人は、それぞれの立場で、凝然と考えこんだままだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "思う源三郎には、自分よりさきに、あんなにあの方をしたっているこの萩乃とやらいう美しいお嬢様がある……と知って、彼女の心は暁闇にとざされたのでした。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人四様に黒い霧のような心の暁闇。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方子川尻の漁師、六兵衛の家に、萩乃と源三郎をそのままにして、心の暁闇をいだいてたちさった左膳。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "源十郎が、灯心を摘んで油をくれると、ジジジジイと新しい光に、濃い暁闇が部屋の四隅へ退く。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、岸の石垣を洗って砕ける暁闇の水面。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが嫌なら、娘をお屋敷へ呼返した上、下手人に縄付けて来い」　源太郎は暁闇の中を引揚げて行く覆面武士の一隊を見送って、氷のような冷罵を浴びせました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺まで泥棒の仲間にされちゃ、売り込んだ顔に関わる、――縄を付けて突き出さないのが、せめても親の慈悲だ」　彦兵衛は言うだけのことを言うと、娘と徳之助を暁闇の中に残したまま、没義道に戸をピシリと――　が、その戸は半分閉めかけたまま、銭形平次に押えられました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巾着切りの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、私が」　お国は障子を押し倒して這い出すと、跣足のまま格子の外へ、母親の本能の導くままに、暁闇を縫ってバタバタと伜の後を追って行くのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日にのこる朴の　白花山岸は　うまら　うの花咲き乱れ、白じろけぶる雨となりゆく足柄は　遠嶺の奥になほ晴れて、夕霧　すでに巓に　くだりぬ春一日　曇りとほせる夕｜海面に、臥してしづけき初｜島を　見つもはろ／″＼に　山西の奥ゆ還り来し人を思へど、逢ひがたく居り青き起伏暁闇に　いまだ月ある霧の空。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁闇に　銃座を掘るも。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……じゃ、お寝み」　閉めると、暁闇の頭上に、星だけが白かった。",
              "citation": {
                "source": "脚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地響きとともに凄じい爆音が暁闇をつんざいて轟いた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく作者も寐起のところで、そういう暁闇の中に咲く梅花を認めたのであろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずかな暁闇を破って、朗かな鴬の声を聞く毎に、「鶯の暁寒し」という其角の句を、今更のように思い出す。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁闇の空で、大きく鴉が啼く。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは、一声も聴かれなかった千鳥が、今になって、暁闇の空をかすめながら、海苔柴朶の洲へ、啼いて落ちた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
