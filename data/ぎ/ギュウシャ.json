[
  {
    "uuid": "7e264609-87c8-5c6b-af97-01d539f75a62",
    "entry": "牛舎",
    "reading": {
      "primary": "ぎゅうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
