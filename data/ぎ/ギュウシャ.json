      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cow shed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "濠に隣った牧牛舎の柵の中には親牛と小牛が四、五頭、愉快そうにからだを横にゆすってはねている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんどん黒い松の林の中を通ってそれからほの白い牧場の〔柵〕をまはってさっきの入口から暗い牛舎の前へまた来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少し前に巡査がきまして牛舎を見廻りました。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はすぐ其の足で牛舎へはいって虎毛を見た。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつを下駄にはきかえて牛舎を見廻った。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛舎で常と変った叫ごえがする。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が牛舎の流しを出て台所へあがり奥へ通ったうちに梅子とお手伝いは夕食のしたくにせわしく、雪子もお児もうろうろ遊んでいた、民子も秋子もぶらんこに遊んでいた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんどん黒い松の林の中を通ってそれからほの白い牧場の柵をまわってさっきの入口から暗い牛舎の前へまた来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんどん黒い松の林の中を通って、それからほの白い牧場の柵をまわって、さっきの入口から暗い牛舎の前へまた来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」後はひつそり、牛舎です。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は牛舎であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "養狐場を出たところで、私はまた牛舎の白い狭霧を、厩舎や豚舎の小雨を見た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家つづきに牛舎があり、中庭を隔てて、一層古びて頽れかけた茅舎の穀物納屋もあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、主家の外に牛舎か何かの建増しをしている露人の一戸があった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずかずかとその主家にはいり込み、納屋をのぞき、牛舎へ廻り、ほとんど傍若無人の限りを尽していた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "トダ人水牛を失う時は、術士｜私かに石三つ拾い夜分牛舎の前に往き、祖神に虎の歯牙を縛りまた熊｜豪猪等をも制せん事を祈り、かの三石を布片に裹み舎の屋裏に匿すと、水牛必ず翌日自ら還る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛舎へも水が入りましたと若い衆も訴えて来た。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも畳を上げられる用意さえして置けば、住居の方は差当り心配はないとしても、もう捨てて置けないのは牛舎だ。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪雨は牛舎の屋根に鳴音烈しく、ちょっとした会話が聞取れない。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五寸｜角の土台数十丁一寸｜厚みの松板数十枚は時を移さず、牛舎に運ばれた。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の男共を指揮して、数時間豪雨の音も忘れるまで活動した結果、牛舎には床上更に五寸の仮床を造り得た。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "若衆は牛舎の仕事を終わって朝飯にはいってくる。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はひとり言ながらさっそく牛舎に行ってみた。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "消毒の人夫は、飼料の残品から、その他牛舎にある器物のいっさいを運び出し、三カ所に分かって火をかけた。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛舎はむろん大々的消毒をせねばならぬ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで雑然騒然、動物の温気に満ちていた牛舎が、たちまちしんとして寂莫たるように変じたのを見て、僕は自分もそれに引き入れられるような気分がして、もはや一時もここにいるにたえられなくなった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は用意してきたあらたな衣服を着がえ、牛舎にはいった時着た衣服は、区役所の消毒係りの人にたくしてここを出た。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛舎のほうでは親牛と子牛とを引き分けて運動場にだしたから、親牛も子牛もともによびあって鳴いてる。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて主人は奥に客があるというので牛舎をでた。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに規則的にしかも仕事は熟練してるから、花前がきてから二か月にして、牛舎は一｜変した観がある、主人はもはやじゅうぶんに花前の変人なりをのみこんでるから、すべてつごうよくはこぶのであった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
