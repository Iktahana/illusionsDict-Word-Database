    "definitions": [
      {
        "index": 1,
        "gloss": "self-sacrificing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして私はそういう学者の犠牲的精神に尊敬を払う事を忘れないつもりである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによって、これを見るに、只今の病苦も何らか犠牲的、利他的の意味があるものと思いこれを忍ばねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど犠牲的なことをしてくれる病いであるが故に、あらゆる文化的の手を尽して早くその苦悩を取り除けてやろう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛や、戦争や、犠牲的行為やは詩的であって、結婚や、所帯暮しや、単調な日常生活やはプロゼックだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君には犠牲的精神があるといふのだらう。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事は故翁から習ったに過ぎない一教授佐藤文次郎氏の謝恩の一念から起り、全くの赤の他人である彫塑家津上昌平氏の感激から来た犠牲的熱意によって完成された事業である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物の非利己的な自己犠牲的な愛のなかには、単なる人間のさもしい友情や薄っぺらな信義をしばしば嘗めたことのある人の心をじかに打つなにものかがある。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれたちを月給｜盗棒みたいに考えることは、まるで違ってるってことをハッキリ思い知らせた方がいいだろうよ」彼は、何だかほんとうに、人間として、労働者として、貴い犠牲的な、偉大な事業に、初めて携わりうるという晴れがましい誇りと、自信とを感じないわけには行かなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も聰明な者は犠牲的精神に満ちた月日を送るが、仔細に観察すればその日常は高貴でこそあれ、貧乏人が富を得んとして働くのよりも中々楽で無いもので無ければならぬ。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに河野は、ぐたぐたとなってしまった許ではなく、令嬢の愛が自分にないと知ると、自分の身を犠牲にして、恋の敵手と云ってもよい高田と、自分の恋人とを、仲介しようとするような、自己犠牲的な行動に出ようとした。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺は、青木の罪を引き受けてやろう、そうすれば、青木も俺の犠牲的行動に感服して、その恐るべき盗癖から永久に救われるに違いないと雄吉は思った。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、主人は雄吉の潔白とその犠牲的行動とに感激する。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは霊験あらたかな神の前に捧げられた人身御供のように、純な犠牲的な感情をもって忠直卿に対していた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼等幾多の犠牲的青年によって、遂に成功するに至った延々何百｜哩の鉄道は、長蛇の如く野を走り、山を貫き、昨日までの蛮地は、かくして国富と変ったのであります」　重役の娘と、何時の間にか紳士のようになった工夫が相抱くところで幕だった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "時あってこれらの動機が非常なる力を現わし来り、人をして思わず悲惨なる犠牲的行為を敢てせしむることも少くない。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論快楽論者もこれらの事実を認めないのではないが、人間がこれらの欲望を有しこれが為に犠牲的行為を敢てするのも、つまり自己の欲望を満足せんとするので、裏面より見ればやはり自己の快楽を求むるにすぎないと考えているのである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といつて、須磨子が自分の女優生活を意義のあるものとするには、また自分と自分の芸術とに犠牲的な愛を傾けてくれた抱月氏の短い生命を延長させるには、多くの意味において二人の合作であるその芸術に奉仕し、貞実を尽すより外に術がなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つらい世間の前に立つて、自分をあれ程までに労はり羽含んでくれた亡き人の犠牲的な愛を思ふと、須磨子は堪へ難い思ひがしたに相違ない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "特定の個人や、少数の権力者たちへの隷属や、犠牲的奉仕に道徳の基礎を置いたふるい理念をくつがえして、人類の最多数のため、すなわち、我々と同じ一般の人たちの幸福のために、自分たちの仲間のために奉仕すること、いいかえれば広い意味の自利をこそ道徳理念の根幹としなければならないのである。",
              "citation": {
                "source": "政治に関する随想",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島は新調の夏のコオトなどを着て、パナマを冠った小野田と一緒に、浮いたような気持で、毎日のように父親をつれて歩いたが、親に甘過ぎる男の無反省な態度が、時々彼女の犠牲的な心持を、裏切らないではいなかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで年の暮れに猶太人の莫大小屋が、一｜弗の股引を九十九｜仙に「思い切り値下げ」して、「犠牲的大廉売」、「自殺か奉仕かこの英断！",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のイデアで、人と人との相互の要求を自主的な犠牲的精神によって、エゴイズムの仮定なしに説明しようとする方針（あなたの付記の意味に従って）は私もたしかに一つの道理ある考え方として注意させられました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "首都の新聞各社もニュースを受取ったが、皮肉屋の新聞記者たちはあらぬことを想像してこの種の犠牲的行為によくありそうな動機、たとえば人に言えないような不面目とか家庭内の不幸とか失恋などといったものをあら探ししようとした。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝道師達が、さも六ヶしさうに説く、他人に対する寛大さや、愛他的な気持や犠牲的行為は、彼女には、何んでもない事でありました。",
              "citation": {
                "source": "背負ひ切れぬ重荷",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の聖者が現われて、犠牲的の行動をしたからである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼女の結婚は果して妹の想像通り、全然犠牲的なそれであらうか。",
              "citation": {
                "source": "秋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
