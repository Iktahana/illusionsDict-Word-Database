    "definitions": [
      {
        "index": 1,
        "gloss": "Gilyak (old name for the Nivkh ethnic minority group of Russia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
