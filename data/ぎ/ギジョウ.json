    "definitions": [
      {
        "index": 1,
        "gloss": "ceremonial weapon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "儀仗兵の旗槍もちらちらつづく。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉卒の際とて、儀仗を整える暇もなく、車駕幕府に入らんとした。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原の左大臣の例で童形の儀仗の人を源氏は賜わっているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時のバスで山口へ行く、一張羅を質入して、やうやく小遣をこしらへて、――理髪する、温泉にはいる、一杯ひつかける、――山口駅は儀仗兵やら遺族やら、大衆やらが炎天の下にたたずんで待つてゐる、私もその一人となる、暑い暑い、ばら／＼雨が天の涙のやうに落ちる！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍を迎えた儀仗兵の馬が万歳の声に驚ろいて前足を高くあげて人込の中にそれようとするのが見えた。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔡家溝駅長オグネフ、同駅駐在中隊長オルダコフ大尉、同隊付セミン軍曹、チチハル・ホテル主人ヤアフネンコ、露国蔵相ココフツォフ、随行員、東清鉄道関係者、露支顕官、各国新聞記者団、写真班、ボウイ、日本人警部、日露支出迎人、露支両国儀仗兵、軍楽隊、露国憲兵、駅員。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のすぐ外、改札口の右側に露国儀仗兵、左側に清国儀仗兵が、こっちに背中を向けて一列に並んでいるのが、硝子越しに見える。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "号令の声が聞こえて、露支両国の儀仗兵が一斉に捧げ銃する。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學校の兒童は課業を休み、儀仗兵のやうに列を組んで會葬した。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの御儀に日本綿布の外衣をそろえた、儀仗兵も休ませなくてはならない。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「儀仗に用い」「白木糸裏は？",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は衝突｜儀仗の条をもって論じ、情を酌量して五等を減じ、懲役五十日のところ、過誤につき贖罪金三円七十五銭申し付くる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "……槍の穂先をきらめかす儀仗の小隊。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一発の銃声がひびきわたり、儀仗兵の拳銃の弾丸が、その胸の真ん中を射ぬく。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺の頭の左右に、赤軍の兵士が一人ずつ儀仗の姿勢で侍立している。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、後ろから揉み出された人波の凸出に、先駆の儀仗兵の馬が刎ねたりして、御馬車が行き淀んだりするのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄光に包まれた一体の亡き骸があり、日夜、儀仗兵が守っている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀仗兵の片列、その背後に男が二人忍び込んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺台まで群衆が押し寄せたので、あちこちにいる赤色・金色服の儀仗兵だけが、喪服の群れにひときわ目立った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年（一八〇九年）五月三十一日、ハイドンの魂はついに天に還り、質素な――が立派な葬列には、敵国フランスの儀仗兵まで付けられた。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀仗兵の紅白の槍旗が群鳥のはばたくように見えだした。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "其王朝會必陳設儀仗、奏其國樂。",
              "citation": {
                "source": "隋書倭國傳",
                "author": "魏徴",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭王遣小徳阿輩臺、從數百人、設儀仗、鳴鼓角來迎。",
              "citation": {
                "source": "隋書倭國傳",
                "author": "魏徴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに儀仗の旗手もできあがり、献納｜燈籠を入れた螺鈿の塗り箱をかつぐ仕丁の役割もすべてきまる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――勅使旗やら内府の官服、献納物の儀仗、だれひとりこれを疑って見るものはない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は大分｜流行ったなというのであるが、是なども種痘が普及してしまうと、もうこの句によらなければ思い浮べられぬ光景であり、またその祭の行列の一番後には、殿様から附けられた多くの槍持ち、今なら儀仗兵に当るものが行くというので、それを見物に出て来たあばたの少年少女の姿が、一層活躍するのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子の儀仗さえ、尚父の出入の耀かしさには、見劣りがされた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――見れば、太師｜董卓の車は、戟を持った数百名の衛兵にかこまれ、行装の絢爛は、天子の儀仗もあざむくばかりで、車簾を出ると、たちまち、侍臣、秘書、幕側の力者などに、左右前後を護られて、佩環のひびき玉沓の音、簇擁して門内へ入った。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、儀仗をととのえ、きのうに勝る行装をこらして、朝霧のうすく流れている宮門へ向って進んでゆくと、一｜旒の白旗をかついで青い袍を着た道士が、ひょこり道を曲ってかくれた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
