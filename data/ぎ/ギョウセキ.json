[
  {
    "uuid": "a0e29373-952b-5825-b98d-03ea94df7a28",
    "entry": "業績",
    "reading": {
      "primary": "ぎょうせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
