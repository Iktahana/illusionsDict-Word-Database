[
  {
    "uuid": "17f134c2-e30d-5805-96e4-7b18c3ce7d8e",
    "entry": "限り限り",
    "reading": {
      "primary": "ぎりぎり",
      "alternatives": [
        "ギリギリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
        "名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "just barely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぎりぎりのところまでは、気まずい衝突を避けるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤取り、浦島さん、カチカチ山、その次に、桃太郎と、舌切雀を書いて、一應この「お伽草紙」を完結させようと私は思つてゐたのであるが、桃太郎のお話は、あれはもう、ぎりぎりに單純化せられて、日本男兒の象徴のやうになつてゐて、物語といふよりは詩や歌の趣きさへ呈してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みれば、ですくの上に突つ伏した大人の額を、いつのまにか蛇がぎりぎりとまきつけてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後からも前からもぎりぎりに生活の現実に詰め寄られている、その間をぽっと外ずして気分を転換したい。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は薫の後を追って薫の腕へぎりぎりと自分の腕を捲きつけた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うものが運命なら運命のぎりぎりの根元のところへ、向うものが事情なら、これ以上割り切れない種子のところに詰め寄って、掛値なしの一騎打の勝負をしよう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方の買直がぎりぎりの処なら買戻すとする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は抽象的なものの言いかたを能う限り、ぎりぎりにつつしまなければいけない。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教のぎりぎり結着の話は実はこれだけであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぎりぎりと靴を寄せつつ、「川の中へ放棄し込んだ、……確に、新聞紙に包んだ可なり重量の有るものは、あれは何ですか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤取り、浦島さん、カチカチ山、その次に、桃太郎と、舌切雀を書いて、一応この「お伽草紙」を完結させようと私は思つてゐたのであるが、桃太郎のお話は、あれはもう、ぎりぎりに単純化せられて、日本男児の象徴のやうになつてゐて、物語といふよりは詩や歌の趣きさへ呈してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットボールが好きで、ＹＭＣＡへ行って、お夕飯ぎりぎりでなきゃ帰って来ないの、ほほほ」　子供のように夫を見做しているような彼女の口振りに、夫を愛していないとも受取れない判断を下すことは、復一に取ってとても苦痛だった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、茶具の数も、定めの数の二十具を減して十六にし、また、十二具にし、やぶれた都籠から取出したのはぎりぎり間に合せの茶瓶、茶盞、茶罌ぐらゐの数に過ぎなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりぎりの最後の切札ではないか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　日本浪曼派の一週年記念号に、私は、以上のいつわらざる、ぎりぎりの告白を書きしるす。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人として、能うかぎり、ぎりぎりの仕事を為した。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間というものは、ふだんどんなに考えかたがちがっているわけのわからないやつでも、最後のぎりぎりのところでは、だれも同じ考えかたなのだ。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの岬は、それこそ、ぎりぎりの本州の北端である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そこでじゃがや、姉めが乳の下の鳩落な、蝮指の蒼い爪で、ぎりぎりと錐を揉んで、白い手足をもがもがと、黒髪を煽って悶えるのを見て、鳥ならば活きながら、羽毛を※った処よの。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑誌は、三月十日前後に発売されるらしいのだから、きょうあたりは、それこそぎりぎりの締切日なのであろう。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりぎりに困惑したら、一言だけ、あなたのお指図をいただきたいと、二十年間、私は、ひそかに、頼みにして生きて来ました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりぎりに行きづまって、くるしまなければ、いつまで経っても青空を見る事が出来ないのだ、いまは、かえって、きのう迄の行きづまりに感謝だ、などと甘い感慨にふけっている形なのです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕には、ぎりぎりに苛酷の秩序が欲しいのだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり、豹一はぎりぎり歯軋りし、その絵を破ってしまった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでももう締切にぎりぎりとかで二等の最後の切符がやっとしか手に入らなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここばかりは譲れないというぎりぎり結著の所が。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものに真正面からぶつかって行く勇気も根気も無い――ただ結局の所、ぎりぎり結著の所だけを聞きたいと思うのであった。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友子は、苦しそうに、うん、うん、うなっていたが、たまりかねたのか、豆絞の手拭をぎりぎりと噛み出した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三日あとのときは、世話係とこの子を裏から何とか逃がして、あなたが表から飛び込んでくるのとぎりぎりだった。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "背が高く、帽子が入り口の鴨居すれすれで、肩幅もぎりぎりであった。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
