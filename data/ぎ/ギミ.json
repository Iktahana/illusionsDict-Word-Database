[
  {
    "uuid": "dab03140-0a65-5185-b5fa-54cace750a62",
    "entry": "気味",
    "reading": {
      "primary": "ぎみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞"
      ],
