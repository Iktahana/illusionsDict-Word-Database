        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "結婚のお祝いには、一度きりという意味を込めて、ほどけない結び切りの熨斗袋を使います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "快気祝いだったので、二度と病を繰り返さないよう結び切りの水引を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「御祝ですが、結び切りでよろしいですか？」と文房具屋の店員さんに確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "黒い長いネクタイを大きく結び切りにして垂れてゐられた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて喪中に使う帳簿は紙を縦にふたつ折りにして、その口のほうを上に向けてとじ、帳の綴り糸も、結び切りにするのが、古来の法で、普通とは逆に、奥から書きはじめて初めにかえるのである。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "贈り物の水引きは結び切りにして返さざるもまた、帰るを避くるなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
