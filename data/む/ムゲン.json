[
  {
    "uuid": "bae0cfed-0895-5446-9678-b81598af05dd",
    "entry": "夢幻",
    "reading": {
      "primary": "むげん",
      "alternatives": [
        "ゆめまぼろし"
      ],
      "is_heteronym": false
    },
    "grammar": {
