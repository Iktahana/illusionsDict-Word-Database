        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女がつぎに撰んだ職業は北西川路のムーン・パレスの踊子であった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そのあとはもう、キース・ムーンが悪鬼のように暴れまくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどＬＰ買ったら、またかける」「キース・ムーンて、最高じゃん」　といって、服部は「ＣＯＭ」をテーブルに投げだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キース・ムーンのファンなんだ？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キース・ムーンはさ、ハイハット使わないんだぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは、たんにキース・ムーンが好きというだけではなく、そうとう叩ける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "）もやりたいけど、キース・ムーンのまねなんか、だれにもできそうにない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョニー＆ザ・ムーンドグズのファンと、ポール＆ザ・ビートルズのファンだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーンドグズ・ファンクラブの入会資格は、一九六六年以前のジョンをリアルタイムで愛したことだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "安い白粉と、女の汗臭い匂ひがムーンと鼻に來た。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スプリング・ムーンが、別れた恋人のかたちに似てゐるといふセンチメントをうたつたエレヂイである。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時から十二時の間だ、好い朧夜だよ、たしか見事なハーフ・ムーンだつた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩この手紙を書く前にムーンライト・ソナタや、葬送曲をききました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前のところに、――即今無――とある、無意味だ、といふよりも缺陥そのものだ、無無無といつた方がよいかも知れない、とにかくムーンだから！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じくリースバックの機器のショップとして生まれた横浜のバイトショップ・ソーゴー、そしてムーンベース、コンピュータラブといった秋葉原のショップが、アルテアや続いて登場してきたＩＭＳＡＩ、ＫＩＭ―１などを並べ、雑誌類を取りそろえてマイコンショップの走りとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろムーンの訓盲文字に、十七年間も馴らされているんですからね。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、ヴィデの大言壮語の中に、ムーンの訓盲字という言葉があったっけね。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、ムーンの文字なんだよ。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はパデレフスキーの偉大さをしみじみと感じ、また彼の「ムーンライトソナタ」の素晴らしさに感動し、この時の印象をこわすことが恐くなり、それ以来他のどんな名人の演奏でも「月光奏鳴曲」は聴かないことにしております。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦「ムーン然う吝嗇な奴だ……ぢやア宅のを出して使へ。",
              "citation": {
                "source": "吝嗇家",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、音の効果で、通俗性をカクトクするために、ダニューヴの流れだか、もう一つ、ムーンライト・ソナタだか、何だかもう一つを使っているのは、下手でないと思った。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻と、口を手拭でしっかと結えてもムーンと鼻の穴から、頭へ突きぬけるような臭気が、噎せるようだった。",
              "citation": {
                "source": "工場新聞",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あ国でいつか姉さんの子を抱かされた時にね、あのムーンとする匂ひがたまらなく良くなつちやつて――。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かがわたしに善をほどこそうという、意識的なもくろみをもってわたしの家に来ようということが確実にわかったら、わたしは、あの、口や鼻や耳や眼を砂でみたして窒息にいたらすシムーンと呼ばれるアフリカの沙漠の乾いた熱風からのがれるようにいっしょけんめいに逃げだすであろう。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "２人に１か月の休暇をやって、ハネムーンに送り出した。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悪事はとうとう大佐殿には知れずにすみ、美人は私の退院をまたず、一陸軍士官のお目にかない、手に手を携えてヒマラヤの山の奥へハネムーンの旅に上ってしまった。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻のベッシーは子供らと一しよにヴァレー・オヴ・ザ・ムーン（月の谷）のグレン・エレンという避暑地に丸太小屋を借りて住んでいたので、ジャックはその妻子の住居と船の間を往来していたが、或る晩山越えの途中、馬車が谷間におちてジャックは脚にひどい怪我を負つた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネムーンはポートグィンの廃屋でしょうね」　ルースの言葉が段々うわずり、盆地中に響いた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み物は紅茶であり、花嫁に対する新郎の精一杯の贅沢品であり、ハネムーンの終わりが近づくころ頻繁に飲むものである。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ムーンライト・ソナタ』でお月様の出を強調したり、『アパショナタ・ソナタ』で、ピアノを叩き潰すような感情の大荒れを見せられたり、そんな馬鹿げた芝居気の演奏に我々は馴らされて来たのである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
