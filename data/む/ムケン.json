    "definitions": [
      {
        "index": 1,
        "gloss": "ceaselessness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "身の毛もよだつ無間奈落だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「無有入於無間」を「個体性のないものは連続的物質中に侵入する」と訳しているが、これは、何となく古典物理学のエーテルを云っているようで面白い。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の机上の空論、中途半端な観念が何等の用もなさぬ真実の無間地獄……と聞いてはいるが、まだ実際に見た事はない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺には彼の無間の鐘がある。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "無間地獄の底に堕ちながら死のうとして死に得ぬ魂魄のなげき……八万奈落の涯をさまよいつつ浮ぼうとして浮び得ぬ幽鬼の声……これが恋に破れたものの呪いの声でなくて何であろう。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の池や、針の山や、無間奈落といふ白い煙のたちこめた底知れぬ深い穴や、到るところで、蒼白く痩せたひとたちが口を小さくあけて泣き叫んでゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無間奈落　押せども、ひけども、うごかぬ扉が、この世の中にある。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "底のない墜落、無間奈落を知って居るか、加速度、加速度、流星と同じくらいのはやさで、落下しながらも、少年は背丈のび、暗黒の洞穴、どんどん落下しながら手さぐりの恋をして、落下の中途にて分娩、母乳、病い、老衰、いまわのきわの命、いっさい落下、死亡、不思議やかなしみの嗚咽、かすかに、いちどあれは鴎の声か。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とヒラリと素裸になって、寝衣に着かえてしまって、　　やぼならこうした　うきめはせまじ、と無間の鐘のめりやすを、どこで聞きかじってか中音に唸り出す。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は沈みぬ、無間の海の底。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "真直に一里半ばかり北へ上ると、俗に云う無間山こと倶利ヶ｜岳の中腹に、無間山、井遷寺という梵刹がある。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無間山井遷寺は聞きしにまさる雄大な荒廃寺であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も二人の首の中に『一足｜無間』と云う、誓文を含んでいたと云う。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて兩親にほんとうに腹を立たせるやうな無間をやる眞奈ではない。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏典にも『阿毘達磨大毘婆沙論』一一九に、人が父母を殺さば無間地獄に落ちるが、畜生が双親を殺さばどうだと問うに答えて、聡慧なるものは落ちれどしからざるものは落ちずとありて、その釈に、〈かつて聞く一聡慧竜馬、人その種を貪り、母と合せしむ、馬のち暁り知り、勢を断ちて死す〉と見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "前項に引いた通り、仏書に、人が父母を殺さば無間地獄に堕ちるが、畜生が双親を殺したらどうだとの問いに答えて、聡慧なる者は落つれどしからざる者は落ちずとあるごとく、馬に取っては迷惑千万だろうが、その忠勤諸他の動物に挺んでたるを見込み、特別の思し召しもて、主人に殉し殺さるるのだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧陽修のある大官のことを記した文章の中に『願為尋常無間之人又不可得』と書いてあるのを覚えてゐるが、実際伊藤公や桂公は、豪い人になつたことを、悔いてゐたかも知れないのである。",
              "citation": {
                "source": "生滅の心理",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑屈なあきらめと低級な同化作用とに伴なはれて無間地獄に墜ちて了ふことを恐れるのである。",
              "citation": {
                "source": "作者の言葉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地獄絵巻の実在を、自分の死によって裏書きして、小生等を仏教の所謂、永劫の戦慄、恐怖の無間地獄に突き落すべく……。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「会おうと思えばいつでも会える」と言った私の言葉が、彼女にドレ程の深刻な不安を与えたか……彼女をドンナに恐ろしい脅迫観念の無間地獄に突き落したかを、その時に察し得たであろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と校長先生とは二人きりでこの秘密を固く固く抱き合って、底も涯てしもない無間地獄の底へ、何処までも何処までも真逆様に落ちて行かなければならないのだ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど涙や笑声の惑を脱し、万象の流転の相を忘ぜむと、心の渇いと切に、現身の世を赦しえず、はた咀ひえぬ観念の眼放ちて、幽遠の大歓楽を念じなば、来れ、此地の天日にこよなき法の言葉あり、親み難き炎上の無間に沈め、なが思、かくての後は、濁世の都をさして行くもよし、物の七たび涅槃に浸りて澄みし心もて。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど涙や笑聲の惑を脱し、萬象の流轉の相を忘ぜむと、心の渇いと切に、現身の世を赦しえず、はた詛ひえぬ觀念の眼放ちて、幽遠の大歡樂を念じなば、來れ、此地の天日にこよなき法の言葉あり、親み難き炎上の無間に沈め、なが思、かくての後は、濁世の都をさして行くもよし、物の七たび涅槃に浸りて澄みし心もて。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に来るものは、無間地獄のような悲歎と寂寥とであった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのジレッタサもどかしさ、モジモジしながらトウトウ二時間ばかりというもの無間断に受けさせられた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見園を横に見て登る、登る程に、海地獄、八幡地獄、無間地獄、等々と地獄の連続だ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "口だけですむけんかはまあござりませぬ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートへのりこむけんりが、あるのです」　そういって、いやにいばった外国人があった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
