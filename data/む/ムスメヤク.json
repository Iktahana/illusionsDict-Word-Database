    "definitions": [
      {
        "index": 1,
        "gloss": "female part or role (drama, kabuki, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
