    },
    "definitions": [
      {
        "index": 1,
        "gloss": "innocence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」妹は、無心のようでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は父の机の前に足と投出したままで無心に華車な浴衣の後姿から白い衿頸を見上げた時、女は肩越しにチラと振り向いたと思う間に戸をはたとしめた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノックは、無心に、つづけられる。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとかして、無心に書ける境地まで行きたい。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處で畫架を立てゝ二時間餘りを無心に過した。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星の抒情詩は、あの無心な小學一年生が舌で鉛筆の心を嘗めつけながら、紙の上にごしごしと書いてゐるところの、あの片假名の作文を思ひ出させる。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この淵の無心な気持ちになっていれば世間がどう変りこっちにどう仕向けようと、余悠綽々なのだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無我無心でぼんやりしていた。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃次第に露骨になりつつある都会のある階級の女のコケトリーについて、人から色々の話を聞かされていた私は、この無心の子供のこの非凡な註説を無意味には聞き逃す事が出来なかった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午すぎにお道が貸本屋から借りた草雙紙を讀んでゐると、お春は母の膝に取附きながらその※ 繪を無心に覗いてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "無心の幼兒がお文の名を呼びつゞけるのを利用して、かれは俄に怪談の作者となつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午すぎにお道が貸本屋から借りた草雙紙を讀んでゐると、お春は母の膝に取附きながらその挿繪を無心に覗いてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "というように無心に訴えていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝ」と母は無心に云った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民が逃げて、主人がなくなった黒い豚は、無心に、そこらの餌をあさっていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　無心の子供を母親がたしなめていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員は現在おのが身のいかに危険なる断崖の端に臨みつつあるかを、心着かざるもののごとく、無心――否むしろ無邪気――の体にて、「すべてこれが事実であるのです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "望雲楼　東坡が望雲楼の詩に、陰晴朝暮幾回新、已向虚空付此身、出本無心帰亦好、白雲還似望雲人、といへる、さすがにをかしからぬにはあらねど、なほ下の心のあるやうにて、白雲点頭すべきや否や覚束無し。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時電車で子供を一人連れた夫婦の向かい側に座を占めて無心にその二人の顔をながめていたが、もとより夫婦の顔は全くちがった顔で、普通の意味で少しも似たところはなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの通りの銅色の顔をして無心に藻草の中をあさっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮大なこの場の自然の光景を背景に、この無心の熊さんを置いて見た刹那に自分の心に湧いた感じは筆にもかけず詞にも表わされぬ。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのような空の光の下に無心の母なき子を抱いてうつ向いている自分自身の姿をはっきり客観した、その瞬間に思いもかけず熱い涙がわくように流れ出した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白くふっくりふくれた丸ぽちゃの顔、おとがい二重、まつげ長くて、眠っているときの他には、いつもくるくるお道化ものらしく微笑んでいる真黒い目、眼鏡とってぱしぱし瞬きながら嗅ぐようにして雑誌を読んでいる顔、熊の子のように無心に見えて、愛くるしく思いました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんどこそ、飲まないからね」「なにさ」娘は、無心に笑っていた。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの老人にさしはさまれて、無心らしく、しゃがんでいる。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、あのように街路で無心のふうを装い、とるに足らぬもののごとくみずから卑下して、芥箱を覗きまわったりなどしてみせているが、もともと馬を斃すほどの猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "にこにこ卑しい追従笑いを浮べて、無心そうに首を振り、ゆっくり、ゆっくり、内心、背中に毛虫が十匹｜這っているような窒息せんばかりの悪寒にやられながらも、ゆっくりゆっくり通るのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の少しまえに、私はすぐ近くの四十九聯隊の練兵場へ散歩に出て、二、三の犬が私のあとについてきて、いまにも踵をがぶりとやられはせぬかと生きた気もせず、けれども毎度のことであり、観念して無心平生を装い、ぱっと脱兎のごとく逃げたい衝動を懸命に抑え、抑え、ぶらりぶらり歩いた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "また相方｜黛のむしんをも、折々は聴いて遣らなくてはならなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吉は、砂地の上に寝そべつたまま、むしんに、口笛を吹いてゐました。",
              "citation": {
                "source": "さがしもの",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
