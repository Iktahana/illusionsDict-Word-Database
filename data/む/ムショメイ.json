        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "必ずしも女房に限らざるは、『乱脛三本鑓』に「下女を篠山に下し心に懸る山の神なく」とあると無署名で書いたは卓説だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "無署名ながらおそらく同誌の編集を取り仕切っていたジム・ウォーレンのまとめたと思われる短い記事が、「ホームブルー・コンピューター・クラブの五月二十六日の集会で、ジェフ・ラスキンがフローという教育用の言語に関して発言し、非常に多くのメンバーの興味を引いた」ことを報告している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『戦旗』一九二八年五月創刊号に無署名・無題で発表）",
              "citation": {
                "source": "『戦旗』創刊号巻頭詩",
                "author": "佐藤武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ書は『心学五倫書』という題名のもとに無署名で刊行されていた。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つはフィラデルフィア発の無署名の手紙で、負けず劣らず深く考え込ませる内容であった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
