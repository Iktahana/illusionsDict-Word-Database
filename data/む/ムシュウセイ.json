        "examples": {
          "standard": [
            {
              "text": "この映画は、オリジナルのストーリーを無修正で公開することを決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故現場の写真は、事実を伝えるために無修正のまま新聞に掲載された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自身の作品を、一切の修正を加えない無修正の形で発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "相談は安易にすぎるほど、すらすらとはこび、ほとんど無修正だった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の品川は真面目顔、もう一つの方はニヤリと笑って、無修正の、ボタボタと斑紋をなした陰影が、暗闇の二人に向って、ニューッと迫って来る感じだった。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
