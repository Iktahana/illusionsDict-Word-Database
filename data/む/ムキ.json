[
  {
    "uuid": "3938ce7d-a06c-5d66-8af0-4826ce207ab7",
    "entry": "向き",
    "reading": {
      "primary": "むき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "direction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こつちはイライラするけれど、彼方は親切に何やかと訊ねなさるから、牧代（姉娘）はどうしたか、生れた子供は丈夫かと訊ねなさつて……」とニコニコしながら呼吸をつきながら、仰向き勝なその顔の、アザヤかな色の唇がさういふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ペンを擱いて向き直る）女　恰度よかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の猛っている時には、映画なぞ見向きもしない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり向き直って、おのれのヴァニティと対談してみるがいい。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、振り向きもせず、さうかな、惡くなつたかな。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの六疊である。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末筆ながら、おからだを大事にして、阿片などには見向きもせぬように、とまたしても要らざる忠告を一言つけ加えた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しナフタリン臭くなっているかも知れませんけど、ね、」と私のほうに向き直って言って、「うちのひとには、もう、なんにも要らないのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐは蒲団の上に仰向きになれなくて、暫くは枕に肘を突いてゐたが、つらいことだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女が部屋に行つて見ると、お祖母さんは彼女の方を見向きもしないで、壁の傍で良子の袴を畳んでゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾よく一匹はそこに仰向きに転んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろこれは、此の詩観が大体の結着をみた当時、即ち今より十三年ばかり前に書けばよかつたのであるが、当時は青春で一杯であつて、論文を纏めるなぞといふ気持には不向きであつた。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急に耕二の方に向き直つて笑をつくつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして母が髪を結つてたのでその傍にゴロンと仰向きに寝転んだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴロンと横向きになつて、書棚に並んだ本を手で横撫でしながら、私は私の前途がいかにもいらだたしいもののやうな感じを懐いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの高い四つの窓から、東京の空の光がいっぱいに流れ込む。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椀を流し口の穴の上に俯向きに当てて、押したり放したり押したりまた放したりする。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時鼠骨氏が色々面白い話をした中に、ある新聞記者が失敗の挙句吾妻橋から投身しようと思って、欄干から飛んだら、後向きに飛んで橋の上に落ちたという挿話があった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は無言で、くるりとうしろを向き、そろそろと歩き出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と兎は平然と手きびしい引導を渡して、それから、ふいと別の何か素晴らしい事でも思ひついたらしく急に眼を輝かせ、笑ひを噛み殺してゐるやうな顏つきで狸のはうに向き直り、「それぢやあね、こんど一ぺんだけ、ゆるしてあげる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウダンツツジの葉と、背向きになって、翠い地紙に、赭っちゃけた斑が交ったようだ、何枚も、何枚も、描き捨てられた反古のような落葉が、下に腐って、半ば黒土に化けている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、白峰山脈からいえば、農鳥山の支峰の下で、河原から、赤石山脈の間の岳とは、真面に向き合っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその花は、一つのこずえの尖端に、十数個から二十ぐらい、鈴生りに群って、波頭のせり上るように、噴水のたぎるように、おどっているところは、一個｜大湊合の自然の花束とも見られよう、その花盛りの中に、どうかすると、北向きに固く結んだつぼみが見える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "西風が強いかして、傾斜の土に疎ら生えしている、丈の短い唐松や、富士薊が、東に向いて俯向きに手を突いている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の構えで、その家がどんな暮し向きであるかを知った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェンロッカー（錨室）の蓋の上には、安田が仰向きに臥ていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄妹は五尺にも足らぬ胡桃の木の下に、二尺角位に乾し草の屋根を葺いて、その下に雫で背中を濡らしながら、木の幹を抱き、向き合つて跼んでゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は亭主と正面に向き合つて、「論告」を下してゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの家もどの家もみんな同じように大体東向きに傾きまたずれているのを見ると揺れ方が簡単であった事が分る。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
