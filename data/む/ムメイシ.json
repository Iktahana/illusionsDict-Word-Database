[
  {
    "uuid": "cb379ffd-50ff-5b96-bb40-896ade0cd945",
    "entry": "無名氏",
    "reading": {
      "primary": "むめいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
