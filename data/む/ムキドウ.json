  {
    "uuid": "101c157d-5c07-5aff-9057-5678dac6da4b",
    "entry": "無軌道",
    "reading": {
      "primary": "むきどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
