[
  {
    "uuid": "bd88af0b-6eba-5b5e-bfdd-4ecfbde5b999",
    "entry": "無償",
    "reading": {
      "primary": "むしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
