      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "without compensation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へば『無償の行為』。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活は破産し切つて、ただしようことのない生存の一日一日が続き、如何なる行為らしい行為も最早見られないとしても猶、『無償の行為』は在つて存するのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて、自分への興味のために、父の旧式水泳場をこの材木堀に無償で置いてくれ、生徒を世話してくれたり、見張りの船を漕いでくれたりして遠巻きに自分に絡まっている材木屋の五十男貝原を見直して来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は母や弟妹に私の心持ちを打ち明けた上、その了解を得て、この土地全部を無償で諸君の所有に移すことになったのです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい以上の理由のもとに、私はこの土地の全体を諸君全体に無償で譲り渡します。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし正確にいうと、私の徴集した小作料のうち過剰の分をも諸君に返済せねば無償ということができぬのですが、それはこの際勘弁していただくことにしたいと思います。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私は私のやつたことが画餅に帰するほど、現代の資本主義組織が何の程度まで頑固なものであるか、何の程度まで悪い結果を生むものであるか、そればかりではなく、折角私が無償で土地を寄附しても、それですら尚農民達は幸福になれないのだといふことが、人々にはつきり分つていゝのぢやないかと思ふのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、報酬はあてにせず、いわば孤児の感情のさびしさがさせる無償の献身であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは、現代の無償教育・百科事典においてさえ、いくぶん稀にしか為しえない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "無償の再利用を自由とすることには意見の相違は見られなかったが、「手間をかけて自分で作ったファイルを、権利が切れているからといって断りもなく商品にはしてほしくない。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、現実世界に青空文庫が存在するなら後者が当然選ばれるだろうけれど、電脳空間というまったく新しい環境に作られた図書館であるなら、ファイル末に作業者の名前を残すというそれだけを求めて、〈「愛と崇高さ」に応える無償の行為が、巨大な知識と文化の宝庫を立派に維持できることを証明してほしいと思うのです。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "私有財産限度超過額ハ凡テ無償ヲ以テ國家ニ納付セシム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "無償ヲ以テ徴集スル所以ハ、現時大資本家大地主等ノ富ハ其實社會共同ノ進歩ト共同ノ生産ニヨル富が惡制度ノ爲メ彼等少數者ニ停滯シ蓄積セラレタル者ニ係ハルヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時この北海道の土地は財産を投じて経営する大規模の農場には五百町歩まで無償貸附し小規模の農場には五町歩を無償貸附したのでした。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――淫乱なら無償でやらせらアねえ！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "道庁で「その六割を開墾した時には、全土地を無償で交付する」と云っている土地は、停車場から二十里も三十里も離れていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何千町歩もの払下げをうけた地主は、開墾した暁にはその土地の半分を無償でくれる約束で、小作人を入地させながら、いざとなると、その約束をごまかしたり、履行しなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路や灌漑溝の修繕工事をすると云って、日雇賃を地主から出さして置いて、小作人を無償で働かし、それをマンマと自分のものにしてしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だから※は他人の金を右から左へ持って行っただけで、三分にして年三割六分、全く無償で二割六分（二割六分！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの街では、彫刻家の集団に無償で家を与えている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からの三ケ月間のはげしい労働がまるで無償労働のような気がして、重くるしい気分に引ずりこまれるのだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期には必らず何日間か、差配松本の持田に勞力を提供しに行かなければならなかつたが、昔からのしきたりでそれはほとんど無償勞働だつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "落書無用12・６（夕）　むかし王献之の書が世間に評判が出るに連れて、何とかして無償でそれを手に入れようといふ、虫の善い事を考へる向が多く出来て来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで幾度か無償の原稿を書かされた身には、それだけは訊いておきたかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉の中には、仕事というものは無償では得られないものだ、ということに対するこの工学者の堅い信念が現われているのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、一切の地主、皇室及び社寺の所有土地の無償没収、農民への交付。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ見たこともない男の妻となり、その一家に新しく加った一人の無償労働者として耕地を這ずりまわらなければならなかった。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは無償の行為に似た美徳でもある。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言いますと、あの時分は私も朝早くから起きて寝るまで、学校の課業のほかに、やたらむしょうに読書したものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで食堂でごはんをたべていると、やたらむしょうに旅行に出たい。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
