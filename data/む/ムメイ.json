[
  {
    "uuid": "6faa95d0-7416-575b-8c44-80f75ca6c6bb",
    "entry": "無名",
    "reading": {
      "primary": "むめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
