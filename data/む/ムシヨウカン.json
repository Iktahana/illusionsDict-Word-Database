        "examples": {
          "standard": [
            {
              "text": "お茶請けに出された蒸し羊羹は、甘さ控えめで上品な味わいだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "京都の老舗で、栗がたっぷり入った蒸し羊羹をお土産に買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "練り羊羹よりも、もっちりとした食感の蒸し羊羹の方が好みです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「鯨羊羹」は、元は「鯨餅」といって、黒と白の二層の蒸し羊羹として江戸時代の記録に残っております。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎは蒸し羊羹専門の豊倉屋。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
