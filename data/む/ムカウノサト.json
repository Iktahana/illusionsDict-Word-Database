          "literary": [
            {
              "text": "……沸々として涌き出づる泉の微温が潺湲と胸に滾れたかと思ふと、愚かな五体は徐ろに無何有の郷に溶けて行つた。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神思殆ど無何有の郷にあるに似たり。",
              "citation": {
                "source": "わが家の古玩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "老子は時々｜無何有の郷に仏陀と挨拶をかはせてゐる。",
              "citation": {
                "source": "西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもかの夢想兵衛が飄飄然として紙鳶にまたがり、天外万里｜無何有の郷に漂着したるの想いをなすならん。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の山辺の遊びかや、ほの暖かき無何有の郷。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
