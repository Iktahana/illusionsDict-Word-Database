        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「無念さうな顔をしてかァ」。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際さういはれてみれば自分は無念さうな顔をしてゐたもんだと三造は思つた。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、自分の心の中は、無念さうなのではないのだがなあ。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無念さうな顔をしてかァ」とまたしても人はいふであらう所の顔は現出するのである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無念さうな顔をしてかァ」といつた男は、自分の言つたことは正しかつたのであつたと思つてしまふ。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術は扨措いて、生活の中ででもそのやうな手合は困るのであつて、それらの人が朝目覚めた時の無念無想、即ち瞑想状態が、精神にも物質にも有益であつて、其処にこそ現実があり欣怡のあることに想到されるやう、私一介の馬鹿は希つてゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいかにも無念な事だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアブに気がついたほど、まだ余裕があったが、アブの方では、人間などに傍目も触れず、無念無想に花の蜜の甘美に酔っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が事象に対した時に、吾人の感官が刺戟されても、無念無想の渾沌たる状態においては自分もなければ世界もない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "定めし私に云われたことが無念でたまらなかったからでしょう」　民子はここで私はそうでありませんと泣声でいうたけれど、母は耳にもかけずに、「なるほど私の小言も少し云い過ぎかも知れないが、民子だって何もそれほど口惜しがってくれなくてもよさそうなものじゃないか。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに色々御無念な処もありましょうけれど、どうぞ政夫さん、過ぎ去った事と諦めて、御勘弁を願います。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしろ」　無念の石松、叫ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎倒れ乍ら無念の涙。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送って無念がる主膳。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "強弱の火華を消して無念無想の境地をもとめて人々が四散した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に一時間半餘に及ぶ珍しき力戰、梅原さんの無念の色は深かつたが、かういふ一戰は負けても勝つても寧ろ憾みなしと言ふべきか？",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無念の涙で立ち上り、とぼとぼと帰る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間私は、私が幼い時經驗した無念さや恐怖を、やはりそんなに迫害されてゐる私の姿を憶ひ浮べた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く寄れ、喰さきなむと思うのみ、歯がみして睨まえたる、眼の色こそ怪しくなりたれ、逆つりたる眦は憑きもののわざよとて、寄りたかりて口々にののしるぞ無念なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく彼も我も無念になって竿先を見守ったが、魚の中りはちょっと途断えた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに気附かず、作者は、汗水流し、妻子を犠牲にしてまで、そのような読者たちに奉仕しているのではあるまいか、と思えば、泣くにも泣けないほどの残念無念の情が胸にこみ上げて来るのだ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犬が、私を特に好んで、尾を振って親愛の情を表明してくるに及んでは、狼狽とも、無念とも、なんとも、いいようがない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、無念無想の結果を見よ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御家老様、大目付殿、お納戸頭などと十分に御打合わせを願うた上で、お指図を受けねばならぬが……しかし……」　と十内は無念そうに唾液を嚥み込んで、眼をギョロリと光らした。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、どうしても見られなくなった無念さをドコにどうして訴えたらいいだろう。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯る時、人は往々無念無想の裡に入るものである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもかれには言うに言われぬ無念がまだ折り折り古い打傷のようにかれの髄を悩ますかと思うとたまらなくなってくる。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは特にそういう人たちはこの時間を利用して庭にでもおり、高い大空を仰いで白雲でもながめながら無念無想の数分間を過ごす事ができたらその効果は肉体的にも精神的にも意外に大きなものになるかもしれない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくすると彼れの眼の中に無念の涙が熱くたまつて來た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "云々と書いたら、百點滿點笑止の沙汰、まさしく佐藤家の寶物だ、と殘念むねん、へそを噛むが如き思ひであつた。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
