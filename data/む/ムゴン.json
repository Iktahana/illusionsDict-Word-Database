    "definitions": [
      {
        "index": 1,
        "gloss": "silence (not speaking)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでも彼は沈默し、無言の中に傘をさしかけて、夜の雨中を田端の停車場まで送つてくれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗憺として錨をおろしみな重砲の城の如く無言に沈鬱して見ゆるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半時間ほども両人無言にて美人も通りそうにもなし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」精は無言でニコニコしている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬢やはと聞くと、さっきから昼寝と答えたきり、元の無言に帰る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は氷袋を気にして時々さわってみるが、始終無言である。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やくざな私を、無言のうちに叩きあげて下さるのも、すべて兄上のちからである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さかなたちは、靜かに無言で左右に散る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は無言で、くるりとうしろを向き、そろそろと歩き出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この突然の暇乞ひもまた、無言の微笑でもつて許された。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、けふの兎は、何か内證の思惑でもあるのか、いつものやうに狸に向つて侮辱の言葉も吐かず、先刻から無言で、ただ技巧的な微笑を口邊に漂はせてせつせと柴を刈つてゐるばかりで、お調子に乘つた狸のいろいろな狂態をも、知らん振りして見のがしてやつてゐるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて追ひ、お爺さんは無言で立つて懷紙でその縁側の糞をていねいに拭き取る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは、無言で雀の行方を眺めてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代と二人でよこせばよかったと思いながら、無言で歩調を早める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の利いたタキシーがすぐ側へ乗りつけて来て無言で扉をあける。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山は害敵とそれを免れるものと両方を備え無言にして生命それ自ら護るべき慧智を啓発した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく虚々実々、無言にして、天体の日月星辰を運行る中に、新生の惑星が新しく軌道を探すと同じ叡智が二人の中に駈け廻った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計なお饒舌や※言を云う時には口では云わずになるたけきつい顔して無言のいましめをしてやります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るより美登利の顏は赤う成りて、何のやうの大事にでも逢ひしやうに、胸の動悸の早くうつを、人の見るかと背後の見られて、恐る／＼門の傍へ寄れば、信如もふつと振返りて、此れも無言の脇を流るゝ冷汗、跣足に成りて逃げ出したき思ひなり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るより美登利の顔は赤う成りて、どのやうの大事にでも逢ひしやうに、胸の動悸の早くうつを、人の見るかと背後の見られて、恐る恐る門の傍へ寄れば、信如もふつと振返りて、これも無言に脇を流るる冷汗、跣足に成りて逃げ出したき思ひなり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」であるためには、なお眼が過去の潤いを想起させるだけの一種の光沢を帯び、瞳はかろらかな諦めと凛乎とした張りとを無言のうちに有力に語っていなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はしばらく無言で歩く。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは無言でぼんやり時間を過ごすうちに、一列の雁が二人を促すかの様に空近く鳴いて通る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は山から採ってきた、あけびや野葡萄やを沢山座敷｜中へ並べ立てて、暗に僕がこんな事をして居たから遅くなったのだとの意を示し無言の弁解をやっても何のききめもない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が前に坐ってもただ無言でいる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくに上って御飯をたべて……」　僕は上りもせず腰もかけず、しばらく無言で立っていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るより美登利の顏は赤う成りて、何のやうの大事にでも逢ひしやうに、胸の動悸の早くうつを、人の見るかと背後の見られて、恐る／＼門の侍へ寄れば、信如もふつと振返りて、此れも無言に脇を流るゝ冷汗、跣足になりて逃げ出したき思ひなり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "良さん今朝の指輪はめて下さいましたかと云ふ声の細さよ答へは胸にせまりて口にのぼらず無言にさし出す左の手を引き寄せてじつとばかり眺めしが。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人もかれが腰にはさみたるわらを見て行者なる事をしり、むごんなれば言語をかけず人々つゝしむ事也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨富の所得はいちおう延期になったが、これで八百助さえおい出せば五千両は鐚一文返さなくとも済むごんえむ殿はむしろ欣然として（しかしできるだけ安直に）野辺の送りをしてやったのであった。",
              "citation": {
                "source": "艶妖記",
                "author": "忍術千一夜　第一話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
