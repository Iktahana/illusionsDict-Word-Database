    "definitions": [
      {
        "index": 1,
        "gloss": "unconditional surrender",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
