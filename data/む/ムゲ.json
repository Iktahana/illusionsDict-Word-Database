[
  {
    "uuid": "c7d9ceea-8cd8-5c82-adb2-381c3345cc79",
    "entry": "無碍",
    "reading": {
      "primary": "むげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
