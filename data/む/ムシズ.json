[
  {
    "uuid": "a2f16f56-0ace-5a51-9e23-71b5c8b8607f",
    "entry": "虫酸",
    "reading": {
      "primary": "むしず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
