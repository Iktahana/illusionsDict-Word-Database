    "definitions": [
      {
        "index": 1,
        "gloss": "village community (esp. hierarchical, conservative and exclusive)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "閉鎖的な村社会では、よそ者がコミュニティに馴染むまでにかなりの時間が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "同調圧力が強い村社会の構造は、現代のSNS上の集団心理にも通じるところがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は村社会特有のしがらみを嫌い、若くして故郷を飛び出し都会へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ソヴェト生産拡張五ヵ年計画は、複雑な農村社会主義化の実践へ根強い組織力で迫って来た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に〔資本〕主義的破壊から全国民社会経済組織と全社会を解放せんと欲するならば何より先に農村社会を救わねばならんのである」（四三頁）、という農村学の「根本主張」が出て来る。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "――都市社会は知的結合だが、農村社会は霊的結合だそうで、崇祖の情や自然崇拝や庶物崇拝が農村の大切な特色だということである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "土屋氏の本は手元になく、本庄氏の『農村社会史』という方は大観堂目録にない様子です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "ring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
