        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブフアラモードとは赤ワインでマリネした牛肉の蒸し煮。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむしに、ならないだらうか？",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私はむしになるのだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "網は時々風にやぶれたりごろつきのかぶとむしにこはされたりしましたけれどもくもはすぐすうすう糸をはいて修繕しました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網は時々風にやぶれたりごろつきのかぶとむしにこわされたりしましたけれどもくもはすぐすうすう糸をはいて修繕しました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえの取った、のこりなんかうじむしにでもくれてやらあ。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は或時海から上り、「なんだかインキンたむしになりさうだ」と言つた。",
              "citation": {
                "source": "僕の友だち二三人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし背むしに生まれついたのは如何にも残念と言はなければならぬ。",
              "citation": {
                "source": "結婚難並びに恋愛難",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊ちゃんは毒むしにさされて、チン／＼の先がピセみたいになって医者へ行ったりして、二日休学。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぶとむしには、このはこが御殿ではなくて、牢屋なのよ。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊虫というのは日露戦争のすぐあとに一度現われて暴れたものだそうで、長さ三センチばかりの、いもむしに似た、黒いからだの両側に黄色の線が一条ずつ入った、ちょうど日露戦争時代の兵隊のズボンみたいな虫だった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "まむしじゃない、ほんとはまぶしで、東京とちがって御飯の中へ鰻の切れッぱしをまぶしてあるだからまぶしと言うんだそうだが、まむしにも青大将にも蟒にも、あの悪く砂糖の利きすぎた脂気のない鰻はどうだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに　まいごに　なった　はむしに　でくわしますと、「しっ！",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その先はどうした」「二日の間縛られて、布團むしにされただけのことで、小便を堪へるのが精一杯」「馬鹿野郎」「だつて、垂れ流しちや、親分の顏にも拘はるでせう」「よし、その話はいづれ春永に、小便を堪へる法といふことにして承はらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども人を螫むしにはあらず、顕微鏡にて視たる所をこゝに図して物産家の説を俟つ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　佃は、蒲団から出して聖書をもっている手の拇指がまむしになるほど力を入れてそれを持ちなおした。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たむしにアルコールの話や、一つ蚊帳の中に寢てゐて、二人とも布團をころがりだしたから、額と額をぶつつけて目がさめて、同時にごめんごめんといつてゐた話は、芥川がなにかに紹介をしてゐるが、今日からみればあの頃の時代はよかつたと思ふ。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "着ているのも継ぎのあたった青梅縞の古袷で、帯はよれよれだし、はいている下駄はちびたおとな物で、それもすっかり鼻緒がのびているから、泥のはねた足指をまむしにしていた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、むしにしては、大きすぎます。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "せむしに向って「まあいい姿だこと」とほめてごらん。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
