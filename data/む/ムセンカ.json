        "examples": {
          "standard": [
            {
              "text": "ベテランの無線家である彼は、自作のアンテナを使って世界中の愛好家と交信している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元の無線家たちが集まり、非常時の通信訓練を定期的に行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無線家にとって、珍しい国や地域からの電波を受信できた時の喜びは格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "発売日を待ちかねて雑誌を書店の店先で開くと、目次にはなかったが、ハム随想と題した各地のアマチュア無線家からの手紙の欄に自分の名前があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
