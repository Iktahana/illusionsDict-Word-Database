    "definitions": [
      {
        "index": 1,
        "gloss": "Indian soapberry (Sapindus mukorossi)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
