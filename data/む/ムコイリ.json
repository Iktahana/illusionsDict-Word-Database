[
  {
    "uuid": "24457a71-34e3-58f3-aa2e-32a30d55e0d0",
    "entry": "婿入り",
    "reading": {
      "primary": "むこいり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
