[
  {
    "uuid": "d1816324-85f6-5731-b19c-362cd6729e6e",
    "entry": "難しい",
    "reading": {
      "primary": "むずかしい",
      "alternatives": [
        "むつかしい",
        "むづかしい"
      ],
      "is_heteronym": false
    },
    "grammar": {
