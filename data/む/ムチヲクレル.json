        "examples": {
          "standard": [
            {
              "text": "マラソンランナーは、疲労困憊の体に鞭をくれ、ラストスパートをかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの締め切りが迫り、私たちは自分たちに鞭をくれ、夜遅くまで作業した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な状況でも、彼は決して諦めず、自身に鞭をくれながら前進した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
