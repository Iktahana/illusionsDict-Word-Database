        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ジョバンニは窓のところからトマトの皿をとってパンといっしょにしばらくむしゃむしゃたべました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから散々玩具にした揚句に、空腹だとむしゃむしゃと喰ってしまうのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　コーリヤは、その場で、汁につかったパン切れをむしゃむしゃ頬張っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの子供達も、或はパンを、或は汁づけの飯を手に掴んでむしゃむしゃ食っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしゃむしゃと向うの入口の方で、こちらの話には気がつかず、鑵肉をつついている厚唇の衣笠は、本当に、ぬれマラという感じだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六モチをむしゃむしゃ喰い乍ら話している。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食時に桂浜へ上がって、豆腐を二三丁買って来て醤油をかけてむしゃむしゃ食った。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紫がかった黒いのを、若々しい口を尖らし、むしゃむしゃと噛んで、「二頭がのは売ってしもうたですが、まだ一頭、脳味噌もあるですが。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂女に食ものッてね、むしゃむしゃ食散らかされて堪るものかな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　襟の辺を引掻くと、爪を銜える子供のように、含羞む体に、ニヤリとした、が、そのまま、何を噛むか、むしゃむしゃと口舐ずる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムは飛んで行ってそれをむしゃむしゃたべました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ブドリはもうやけになって、だまってその男のよこした蒸しパンをむしゃむしゃたべて、またまりを十ばかり投げました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主思のお婢はお稲荷様へお百度を踏みにと飛出して、裏町へ回り焼芋を二銭買い、袂へ納れて御堂に赴き、お百度をいいまえに歩行きながらそれをむしゃむしゃ、またと得難き忠臣なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は群がる蠅と虻との中に優々と水飲み、奴は木蔭の床几に大の字なりに僵れて、むしゃむしゃと菓子を吃らえり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、次男は蒲団をはねのけ、くるりと腹這いになり、お膳を引き寄せて箸をとり、寝たまま、むしゃむしゃと食事をはじめた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまた或日来た青年の手紙は強請的な哀願にしおれて、むしろかの女の未練やら逡巡やらのむしゃむしゃした感情を一まとめにかき集めて、あわや根こそぎ持ち去って行きそうな切迫をかの女に感じさせた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに感謝してむしゃむしゃ喰べながら、またゴルフをつづける。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」僕は、むしゃむしゃたべた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べにかかると握り飯も御馳走もすばらしく美味いので、女中のことなどそっちのけにしてむしゃむしゃ頬張った。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪物はまた火をたいて張に肉をあぶってくれ、己は生の肉をむしゃむしゃとたべました。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くしてやっと気がつきかけた餅屋が顫えながら見ると、白い衣を着た幽霊がその傍に蹲んで己の餅箱らしい箱を前に置いて何かむしゃむしゃと喫っていた。",
              "citation": {
                "source": "餅を喫う",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃、栗、柿、大得意で、烏や鳶は、むしゃむしゃと裂いて鱠だし、蝸牛虫やなめくじは刺身に扱う。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓はそれを手で掴んでむしゃむしゃと喫いはじめた。",
              "citation": {
                "source": "雀の宮物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを釣りあげて、手早く針からはずしたかと思うと、ちょっとあたりを見かえって、たちまちに生きたままでむしゃむしゃと食べてしまったのです。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は遠慮もなくむしゃむしゃやっている。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣人愛の教説者として有名な無腸公子の講筵に列したときは、説教半ばにしてこの聖僧が突然｜饑えに駆られて、自分の実の子（もっとも彼は蟹の妖精ゆえ、一度に無数の子供を卵からかえすのだが）を二、三人、むしゃむしゃ喰べてしまったのを見て、仰天した。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はそのへんを泳いでいた魚類を五、六尾｜手掴みにしてむしゃむしゃ頬張り、さて、腰に提げた瓢の酒を喇叭飲みにした。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
