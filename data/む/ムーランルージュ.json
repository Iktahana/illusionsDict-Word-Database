        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パリを訪れたら、一度はムーランルージュのショーを観てみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ムーランルージュは、フレンチカンカンの発祥の地として有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ムーランルージュの華やかなポスターが街中に貼られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夜は、兄さんに引っぱられて、ムーランルージュを見に行った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "エノケンと緑波の台頭、ムーランルージュの出現も、まだまだ数年ののちだった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "モダン雑文家でムーランルージュの女優高輪芳子と心中未遂を諷われ、のちに眠剤をのみ過ぎて死んだ中村進治郎君も私とともに御同様のつたない一席を申し上げていた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里のムーランルージュという劇場は廊下で食事もできる。",
              "citation": {
                "source": "裸体談義",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日は戸塚へ行っていろいろ話し、新宿のムーランルージュへつれられて行った。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿ムーランルージュで一時間半ばかり見る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時半頃、木村千疋男来訪、二階へ案内し、紅茶などのみ、三時頃ムーランルージュを覗かうとて行ってみると椅子席満員となってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからムーランルージュをのぞく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーランルージュも一年一度や二度は見る価値がある、然し妙なお先走りの学生などゐなくては存在出来ない存在ではあるまいか。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
