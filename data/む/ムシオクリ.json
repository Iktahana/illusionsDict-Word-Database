    "definitions": [
      {
        "index": 1,
        "gloss": "torch procession to drive away crop-eating insects",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五　夏の盛りに虫送りという行事が行なわれる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして田舎で不用になっている虫送りの鐘太鼓を借り集めて来てだれでもにそれをたたかせる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の農夫等が年中大人しく真面目に働いているのが、鎮守の祭とか、虫送りとか、盆踊りとか、そういう機会に平生の箍をはずして、はしゃいだり怠け遊んだりした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……流灌頂――虫送り、虫追、風邪の神のおくりあと、どれも気味のいいものではない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人達は相変らず黒く湿った土を耕すために薄暗いうちから野へ出て、堅い土を耕し、田植の賑やかな忙しさを送ればすぐに水廻りや、草※りや、虫送りを迎え、さて秋の激烈な取り入れという風に、一年を通じて日の出から日の入りまでの労働に骨身を惜まなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆前から行はれるのに虫送りと言ふ行事がある。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ事は、虫送りの人形に於ても言へる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　虫送り人形虫送りの人形は、多く禾本科の植物を束ねたもので作るのだから、畢竟｜藁人形であるが、此に於ても、やはり手を問題にして、足を言はない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫送りの人形が、お迎へ人形に対して、送り人形であるのも面白い。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫送りの人形は、凶悪な精霊の様にも見えるが、同時に、凶悪を一身に背負つて、遠国に去つてくれる主神でもあつた。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外には、さなぶりの時に作る田の精霊、或は巫女を形どつた――苗を組んで作る――さなぶり人形の形式が、虫送りの時にも、まなばれた為だと言ふ事も、考へて見る必要がある様だ。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに出て来るのが、虫送りの草人形である。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒジリは「聖」で、普通には念仏行者の称であるが、ここではその聖が首領となって、恙虫送りの行事をするのだ。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にもう一つ虫送りの話が出たそうである。",
              "citation": {
                "source": "露伴先生と科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、寅彦の幼時の夢を破った虫送りの太鼓の音が、今は消えている。",
              "citation": {
                "source": "寅彦の遺跡",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の虫送りに旗を立て夜は炬火を焚いて、ここまで送って来たのだからたいていは村堺であったろう。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲鐘という地名なども文字は宛字で、やはり山中の虫送り場だと思う。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲への旅行をいう他の地方の神送りとちがうのは、ここでは一ヵ月過ぎての神迎えの祭というものが全くないことと、その神送りの式がよそでする虫送りや、病い神送りの行事とあまりにも近いことであった。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしなどの故郷では、夏のなかばの真暗な晩に、この炬火の長い行列をながめるのは、虫送りとともに美しい見ものであった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの二つのちがうのは、虫送りは田の中だけを廻って早くかえってくるが、雨乞いのほうはだんだんに高くへ登り、また隣の村々の火も遠くから見える。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのしみは長かったかわりに、虫送りのように、毎年ひんぴんとは実行せられなかった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄の方でも近い頃まで、一匹の鼠を捕えて麦藁の舟に載せ、それを代表的に海へ流すという行事、ちょうどこちらの虫送りと似た風習があった。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
