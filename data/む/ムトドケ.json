        "examples": {
          "standard": [
            {
              "text": "会社に無届けのまま副業をしていたことが発覚し、厳しい処分を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無届けのデモ行進が行われ、警察が出動して一時周辺は騒然となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「旅行に行くなら、無届けじゃなくて、ちゃんと連絡先を残していきなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は、その翌日から登校する気になれず、二三日無届けで家にごろごろしていたが、学校から調べが来るという情報が生徒よりはいったので、一週間欠席届を出して親達のいる小さな島へ旅立つことにした。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし罪があるとすれば、無届け営業ぐらいのものだとおもいますがね」「たぶん、たいした罪にはならないだろう。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もちろん無届けであろう」　――糺しましょうか。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の律も、かれら供の者たちも、江戸へ着いて以来五日、無届け出府のため、甲斐のおもわくを案じて、ずっと湯島の家から出ずにいたのである。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            }
          ]
        }
