    "definitions": [
      {
        "index": 1,
        "gloss": "to go out to meet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やっと車の音が玄関へ飛び込んで来ると思うと番頭や女中の出迎える物音がしてそうして急に世の中が賑やかに明るくなった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年を迎える用意もしなければならぬが、何を買ってどうするものやらわからぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生涯、山に親しみ山に冥通する何ものかを得たこどもたちは、老年に及び死を迎えるまえに生命を自然の現象に置き換える術を学び得ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が何度も青春を迎えるといった言葉が思い出される。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いてそれらしいものを娘の言葉の中から捕捉するなら娘がいったいくたたびか迎える辛くも新鮮な青春、かくて遂に老ゆることを知らずして苦しくも無限に華やぎ光るいのち。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の姿を見ると目出度いと言って急いで羽織袴で恭しく出迎えるような商家の主人もあった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年の目出度き春を迎えるに際しましてキネマ旬報誌に折入って懇願致したい事があります。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあー」とお光をかえり見て、Ｔ「お光ちゃん　仲蔵さんよ」　「まあ、仲蔵さん」とお光いそいそと出迎える。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………をつけたアンナの……、いそ／＼と私を迎えると※々として私の唇に接吻して、心にもない。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って曙色になった頬に微笑を浮べて私を迎える。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "落つきを失った新聞記者のＹの見たマダム・ハヤミの地平線、吊ランプ下げた海峡の船が下関に着くと、僕はサンヨウ・ホテルの踊場にマダム・ハヤミを迎える。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の同棲者が微笑しながら二人を迎えると、三人が食卓をかこんだ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集を好む動物があり一方にはまた孤独を楽しむ動物があるかと思うと、また一方ではある時期には群集を選ぶが他の時期、特に営巣生殖の時期には群れを離れて自分だけの領地を占領割拠し、それを結婚の予備行為とした上で歌を歌って領域占領のプロパガンダを叫び、そうして花嫁を呼び迎える鳥類もある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポーリンさんにシマノフさん、いらっしゃい」　ウエイトレスの顔は彼らを迎える大仰な表情でにわかに生き生きし出した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とまた店口へ取って返して、女房は立迎える。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "精霊棚を設けて亡魂を迎える人はやはり今でもあるのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡児が父の「のんきなトーさん」と「隣の大将」とを上野駅で迎える場面は、どうも少し灰汁が強すぎてあまり愉快でない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雁来紅」という奇妙な映画で、台湾の物産会社の東京支店の支配人が、上京した社長をこれから迎えるというので事務室で事務成績報告の予行演習をやるところがある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥釣りを迎える家に勇猛な女中でもいると少し怪しいと思われるようなのをいきなりつかまえて面を引きはごうとして大騒ぎになるようなこともあったような気がする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして著者とともに貴重な残り少ない生の一日一日を迎えるのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にこの行列の帰還を迎える場面でも行列はやはりわれわれ観客の前を横に通過するのであるが、ここでは前と反対にヒロインがその行列の向こう側に見え隠れにあわただしく行ったり来たりしてカメラはこの女の行動と表情を子細に追跡する。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園を星野以上に喜んで迎えるわけがおぬいさんにはあるはずがない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜというと新井田氏がはいってきた瞬間に、その眼は思わず鋭くなって、奥さんが良人をどういう態度で迎えるかを観察するのを忘れなかったからだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中は綺麗に片づいていて、客を迎えるのに少しの手落ちもなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらなんにも知らないおせいにも、自分のような貧乏な、無学な、知り合いもないような人間を正妻に迎えるわけがないのは分りきっているのに、しらじらしい顔つきをして、自分の娘をごまかそうとするらしい父が邪慳の鬼のようにも思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ朝明けの雪を楽しみつつ客を迎える温恭な気持ちでありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の姿を見ると目出度いと言って急いで羽織｜袴で恭しく出迎えるような商家の主人もあった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは大学のすぐ近くのホテルからの客を迎える自動車へほかの五六人といっしょに乗りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずうっと積まれた黒い枕木の向こうに、あの立派な本線のシグナル柱が、今はるかの南から、かがやく白けむりをあげてやって来る列車を迎えるために、その上の硬い腕を下げたところでした。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シグナレスはしくしく泣きながら、ちょうどやって来る二時の汽車を迎えるためにしょんぼりと腕をさげ、そのいじらしいなで肩はかすかにかすかにふるえておりました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
