          "standard": [
            {
              "text": "ソクラテスは「無知の知」を説き、真の知恵とは何かを人々に問いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "哲学を学ぶ中で、私は自分の「無知の知」を深く感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "無知の知を自覚することこそが、学問の出発点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは認識を絶した直觀をもつて、いはゆる無知の知（docta ignorantia）による神祕的な直觀をもつてのみ、理解され得るものである。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
