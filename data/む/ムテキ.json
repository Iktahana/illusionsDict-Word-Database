[
  {
    "uuid": "79176085-503e-5386-a54f-6cdedf38b9e5",
    "entry": "無敵",
    "reading": {
      "primary": "むてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
