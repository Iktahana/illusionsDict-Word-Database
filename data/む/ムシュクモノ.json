    "definitions": [
      {
        "index": 1,
        "gloss": "homeless person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし堅気の商人や寺の坊主ばかりでは、万事が不便であるので、かれらは浅草下谷をごろ付きあるいている無宿者の熊吉と源助とを味方に抱き込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が故郷を立ち退いて、今は一種の無宿者同様になっていることを知ったあかつきに、八橋はどんな態度を取るか。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう長いこと労咳でわしがめんどうみていた無宿者の老人が、急にゆうべ変が来たというて呼び迎いに参ったのでな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "死因はたしかに病気じゃったし、ほかに不審とも思われた節はないが、身寄りもない無宿者に、だれがそんな手回しのいいことをしたものか、棺にして運び出したようでござりましたよ」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げた奴はみんな無宿者で、京都無宿の藤吉、二本松無宿の惣吉、丹後村無宿の兼吉、川下村無宿の松之助、本石町無宿の金蔵、矢場村無宿の勝五郎の六人で、そのなかで藤吉、兼吉、松之助は入墨者です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "金蔵は本石町の鐘撞堂の近所の裏店に住んでいた屋根屋職人で、酒と女の道楽からとうとう無宿者になってしまって、江戸の隅々をころげ廻っているうちに、人殺しこそしませんが、大抵の悪い事は仕尽くして、今度挙げられたら先ず遠島ぐらいを申し渡されそうな兇状持ちになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿こそ、われわれを盗人か無宿者同様に心得てござる。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜夜中人を叩き起しやがって」　ぴしゃりと窓を締めきって、「無宿者奴、碌でもねえ野郎だ」　この邪慳な声と仕方にびっくりして、乞食はそこに立ちすくんだまま考えた。",
              "citation": {
                "source": "乞食",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "無宿者なんか盗みでもするより芸がありやしない。",
              "citation": {
                "source": "乞食",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "無宿者の歩みつく道一面の広野と化した巷の風ああ無情の風と歎く我身なり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞「へい／＼有難う存じます……（泣きながら伜に向つて）まア八百膳の御料理なぞを戴きますといふのは、是はお前なんぞはのう、喫べ初めの喫べ納めだ、斯ういふお慈悲深い旦那様がおありなさるから、八百膳の料理を無宿者に下されるのだ、お礼を申して戴けよ、お膳で戴くことは、最う汝生涯出来ないぞ。",
              "citation": {
                "source": "大仏餅。袴着の祝。新まへの盲目乞食",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代には、無宿者・無職者・無職渡世などいふ言葉で表されてゐるが、最早其頃になつては、大体表面から消えてしまうたと言へるのである。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "駈落者・無宿者・亡命の徒などが彼等の中へ飛び込めば、政治家も、其をどうする事も出来なかつた。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松の耳に入ったいろいろの噂は、破牢者のうちの無宿者の一隊は、どうやら山を越えて秩父の方へ逃げたものと、信濃路へ向ったものとがあるらしいということのほかに、その主謀者と見做されるものは、どうしてもこの市中に潜伏していなければならないということでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも一癖ありそうな旅の無宿者の風体です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良猫は無宿者のくせに肥り返って毛並もつやつやしい。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女　　ほんとうにそうだよ、わたしがまごつき歩いてるのも長いことさ、初めて無宿者になったときから。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "軌道の有る星ならば、天文学者の計算違いと云う事もあろうが、既に軌道を踏み外した狼藉者、無宿者で、盲滅法に天界から落ちて来るのだから、太陽へ落ち込むに決まっている。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "村内のものでも長脇差を帯びるか、または無宿者を隠し泊めるかするものがあればきびしく取り締まるようになって、毎月五日には各村民が陣屋に参集するという。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫　　（また読み始める）「上州無宿者の名草の伊太郎が暗きを選つて、そつと歩いてゐる。",
              "citation": {
                "source": "世帯休業",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "板敷きに手枕して鼻唄まじり、あれほど獄吏をてこずらせていると聞いた無宿者が、いま見れば閉房の中央に粛然と端坐して、何やら深い瞑想にふけっているようす。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもなら、そうはいっても、無宿者の一人や二人、いくら気は立っていても斬りはすまい。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は浪人や無宿者の取締りがやかましく、足腰の達者な男は、何か活計の立つやうな名目だけでも持つてゐなければならなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他ぢやないが、近頃浪人と無宿者の取締りがやかましくなつて、他國者は皆んな身許を書き上げなきやならない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は浪人や無宿者の取締りがやかましく、足腰の達者な男は、何か活計の立つような名目だけでも持っていなければならなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他じゃないが、近ごろ浪人と無宿者の取締りがやかましくなって、他国者はみんな身許を書き上げなきゃならない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「無宿者、薊の三之助、これはちょいと良い男ですよ、何んだって、あんな野郎がまた、尋常な眼鼻立を持って居るんでしょう」「無駄が多いな、第三番は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「無宿者、薊の三之助、これはちよいと好い男ですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "戀患ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれど私たちは無宿者を泊める譯にや行かないよ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし彼が既にロンドンに巣くったとしたら、彼はウィンブルドンの公有地に住む丈の高い無宿者から、メトロポール・ホテルにいる丈の高い宴会の主人公に至るまで、あらゆる人間になりすましているに違いない。",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
