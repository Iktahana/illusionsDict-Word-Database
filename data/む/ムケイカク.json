    "definitions": [
      {
        "index": 1,
        "gloss": "lacking a plan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで姉の帰るのを待っていようという気持ちが、無計画ながら伸子のなかには動いていた。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストライクは発作的に無計画に起これば、必ず失敗するものだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、これは無計画な癲狂戦争の必然の結果として、国民同士が相互に苦しめ合うことなしには生きて行けない状態に追い込まれてしまつたためにほかならぬのである。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "加世子は自分が生き残るつもりで庸三の死んだ後のことばかり心配していたのだったが、庸三も健康に自信がもてないので、大体そのつもりでいたが、無計画に初まったこの家庭生活はどこまでも無成算で、不安な心と心とが寄り合ってどうにかその日その日を生きていたものであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパから最近帰って来たある日本人が、今日の日本をみて、みんなの生活が無計画で、食えないといいながらたかいタバコをプカプカふかしている、政府はから約束をして、内閣がかわればそのまますっぽかしている。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、あなたがたが、ことしの新卒業生として、無計画でしょうか。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年間の労作に堪ゆる人間が、枯淡であろうとも思わないし、無計画であるとも思わない。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、私が成り行きしだいに無計画にジャン・クリストフの中にふみこんだと想像する、浅見な批評家の説が、いかに不当なものであるかは明らかであろう。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ情熱の幻想に溺れ、根柢的に無計画、無方針であつた。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のやうにその日その日でたとこまかせ、気まぐれに、全く無計画に生きてゐる人間は、特別の理由がなければ、とても日記をつける気持にならない。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケタの違う工業力でまともに戦える筈はないので、追いつめられて窮余の策でやるような無計画なことをせず、戦争の始めから、航空工業を特攻専門にきりかえ、重爆などは作らぬやり方で片道飛行機専門に組織を立てて立案すれば、工業力の劣勢を相当おぎなうことが出来たと思う。",
              "citation": {
                "source": "特攻隊に捧ぐ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ無計画に筆をつけはじめ、勢いに駆られてめくら滅法に書き了せたというに過ぎない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のようにその日その日でたとこまかせ、気まぐれに、全く無計画に生きている人間は、特別の理由がなければ、とても日記をつける気持にならない。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども修士たちは無計画に孤児を引き入れた。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時中の学生動員のやうな無計画なやり方でなく、工場は一種の理科教室になります。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "七千六百億円の金を無計画に使っておいて、三百億円足らずの防衛分担金の削減に、あの騒ぎをするのでは、話にもならない。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、今日の行き詰まり状態に陥ったのは、初めに科学者の意見をよく聞かないで、無計画にことを始めたからではないか。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無計画性……空想的な娘って、たいてい、そうしたことになるものよ。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "無計画な伐採、根っこほり、もう何年もなげやりのままの地方治水工事は、僅か数日の豪雨が山から水を押し出すのだが、高い丈夫な軍用新道が出来たおかげで、部落は何のてだてもなく、溝の底へ縦におかれたかたちになってしまった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　無計画の計画（※）「大丈夫かい、次郎君。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからが、いよいよ無計画の計画だよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「考えてみると、やはりそれも無計画の計画だったんだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうだからって、無計画の計画ばかりでもいけないだろう。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いくらか冗談のように、「君がそんなことを言い出すようになったのも、やはり無計画の計画の一つだろう。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　無計画の計画（※）　それからどのくらいの時間がたったのか、次郎は、小屋のそとから誰かしきりにどなっているような声をきいて、はっと眼をさました。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は、それから、その日とその翌日とを、やはり無計画のまま、やたらに歩きまわった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無計画の計画も、こううまく行くと、かえって恐ろしい気がするね。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無計画の計画ってこと、僕も少しわかったような気がするよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無計画の計画」というのは、最初大沢が半ば冗談めいて言い出したことだったが、それは、次郎にとっては、彼がこれまで子供ながら抱いて来たおぼろげな運命観や人生観に、ある拠りどころを与えることになった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無計画の計画」という言葉をとおして、いくらか形を与えられかけていた彼の人生観も、そうなると、もう何の役にも立たなかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
