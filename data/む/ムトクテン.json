        "examples": {
          "standard": [
            {
              "text": "相手投手の完璧なピッチングの前に、我がチームは無得点のまま完敗した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "チャンスを何度も作りながらも、あと一本が出ず無得点で試合を終えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前半戦を無得点で折り返したサッカー日本代表は、後半に勝負をかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、陸上競技で支那が依然無得点であることを彼の口から確かめると、我が意を得たというような調子で、「こういうような事でも、やはり支那人は徹底的に懲して置く必要がある」と呟いた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
