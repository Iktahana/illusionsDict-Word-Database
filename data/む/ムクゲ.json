[
  {
    "uuid": "cd4bd690-4dbb-5d16-983b-948b956b12b8",
    "entry": "むく毛",
    "reading": {
      "primary": "むくげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shaggy hair (of an animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……ちょうど、ほら、むく毛が生えて、※子の撮食をしたようだ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "香も日本の菊程無いし、葉にもむく毛が無い。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔い、むく毛の生えた頬や、包ましげな目が見えます。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "――川崎を越す時分には、だらりと、むく毛の生えた頸を垂れて、白襯衣君の肩へ眉毛まで押着けて、坐睡をはじめたのですが、俯向けじゃあ寝勝手が悪いと見えて、ぐらぐら首を揺るうちに、男の肩へ、斜に仰向け状にぐたりとなった。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕に唾をなすり付けて、むく毛を剃る真似をしたりした。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆく春くれゆく春のかなしさは白髪頭の蒲公英のむく毛がついついとんでゆく風がふくたびとんでゆき若い身そらで禿頭。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "南禪寺の松林の木の間に咲いてゐた櫻の美しさ岡崎公園の空いちめんに飛んでゐた、たんぽゝのむく毛。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの馬は、むく毛の若い黒馬で、脚も丈夫だし、悍も相当つよかった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップの水に浸って居る葉にこまかいむく毛がある故か、小さい水玉が見える。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイの「戦争と平和」の中のボルコンスキー公爵夫人の上唇やそのむく毛は、つよく吾々の目を惹きつける。",
              "citation": {
                "source": "形態について",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルコンスキー公爵夫人の上唇やそのむく毛の域にまで出てゆくことにある。",
              "citation": {
                "source": "形態について",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペーチャのむく毛の生えた唇の隅は泣く前みたいにふるえだした。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細く削った竹の目から暖かいむく毛が、白く飛ぶほどに翼を鳴らした。",
              "citation": {
                "source": "文鳥",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（やあ、むくさん、むく毛の猟犬先生――いつも相変らずのおめかしですね。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽根が「むく毛の猟犬」と仇名をつけたのもこの辺から思いついたことである。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体中にはむく毛が渦を巻いてい、長い尾の先はよれよれになって赤茶け、足には草鞋をはき、首を前方につき出し、光りの失せた眼を地面に落し、口からは泡を垂れながら、重い荷を引いてことりことりと、淋しい街道を辿っていた。",
              "citation": {
                "source": "愚かな一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "花が散ってあとに残る、むく毛を束ねた様に透明な球をとってふっと吹く。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黒いむく毛の若いハイカラさんは、ゼルビノ侯ですが、これは優美という意味で、よく様子をご覧なさい、いかにもその名前のとおりだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ第一がむく毛だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "むく毛とブラシユは取り入れに、籠は持ち運びに使はれるのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のむく毛の上に散ばつた花粉の粒は、そのブラシユで集められて小さな球になる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処にある小さな花粉の球は、粉だらけになつたむく毛の上を大急ぎで刷き集めて堆み上げたものなのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして草を拾うためにかがんだ時、半ば開いたシャツの襟から、頸筋と背筋との金色のむく毛が彼の眼にとまった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………怖い夢だったの」「怖い夢だった」　彼女の頬は、入日時の山脈の様に、くっきりと蔭と日向に別れて、その分れ目を、白髪の様な長いむく毛が、銀色に縁取っていた。",
              "citation": {
                "source": "火星の運河",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊次さんの小さい家は、雲華寺の門前の、むくげの木にかこまれた畠の中にありました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者は字引に「むくげ」とあるはたしかならねど「よし」にあらざるは勿論なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
