          "literary": [
            {
              "text": "無味無臭、無色透明の世界に住みたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "燻精は、わしのところから出ていくとき、特設の通路内で無味無臭無色無反応の持久性神経瓦斯を吸って戻ったのだ。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をして思わず鼻孔をふくらませる、無味無臭の香である。",
              "citation": {
                "source": "梅花の気品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な毒物なんだが溶かすと無味無臭で、誰も毒物が入っていると気がつかない。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは五十粒ぐらい飲んでも眠くならないし、無味無臭で、酒の肴としても、うまくはないが、まずいこともない。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
