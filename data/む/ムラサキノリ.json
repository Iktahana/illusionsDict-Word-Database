        "examples": {
          "standard": [
            {
              "text": "磯の香りが豊かな紫海苔を、軽く炙ってからおにぎりに巻く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらの製法で作られた紫海苔は、口の中でとろけるような食感だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寒空の下、漁師たちが紫海苔を丁寧に摘み取る作業が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ハマナ　庄内地方で、海苔を濱菜といふとあるが（山形縣方言集）、是も紫海苔だけには限つて居なかつたものと思ふ。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハマナ　庄内地方で、海苔を浜菜というとあるが（山形県方言集）、これも紫海苔だけには限っていなかったものと思う。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
