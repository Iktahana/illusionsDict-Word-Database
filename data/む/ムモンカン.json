    "definitions": [
      {
        "index": 1,
        "gloss": "The Gateless Barrier (13th century collection of koans, compiled by Chinese monk Wumen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それかと思うと、その頃｜碧巌を見たり無門関を見たりしていたので、禅定めいた contemplatif な観念になっている時もある。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これさえ切れば光風｜霽月、手をとってともに山中を行く、これを切るには不動智をもってすべし』などと一応もっともらしく、その実あいまいな屁理窟をつらね一刀両断に切ったのを、柳生｜三巌という御用剣術家、無門関あたりから引っ張り出し、三学の説をあみ出したそうだの。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟道７・23（夕）　近頃｜碧巌録とか、無門関とかいつたやうな禅家の書物に、所謂悟道を商売にしない、素人の学者、求道者が飛び込んで往つて新しい解釈を試みようとしてゐるのは面白い現象である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、無門関第一則――趙州狗子。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "無門関第二則、百丈野狐。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "不眠、明方ちかくまで睡れなかつた、無門関を読んだ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩も早寝が出来ないので無門関を読む。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ふけるまで不眠、無門関第五則「香巌上樹」、初めて読む公案である。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "無門関、第七則、趙州洗鉢。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "無門関、第十二則、巌喚主人。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶道未沾唇」（無門関第十則　清悦孤貧頌）――来た来た、来ました来ました、ありがたう、ありがたう、さつそく街へ局へ、そして方々へ、――払へるだけ払ひ、買へるだけ買つた。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心沈静、無門関第十一則十二則。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女と別れて放浪中、偶然、古本屋で買った、「無門関」を愛誦していた。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近は又、碧巌、無門関等について日夕坐禅に心掛け、いささか非心非仏の境地をのぞいた。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は一切無門関、勝手に屋敷の中を通る小学校通いの子供の草履ばた／＼で驚いて朝寝の眠をさましたもので、乞食物貰い話客千客万来であったが、今は屋敷中ぐるりと竹の四ツ目籬や、※、萩ドウダンの生牆をめぐらし、外から手をさし入れて明けられる様な形ばかりのものだが、大小六つの門や枝折戸が出入口を固めて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの活手段はあの『無門関』などにもちょっとなかったようである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "無門関か碧巌録の公案からでも取材したのかナ。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中の文部大臣が、生理学と『無門関』とを「融合」して、日本的な科学を創り出した例は、まだわれわれの記憶に新しい。",
              "citation": {
                "source": "身辺雑記",
                "author": "――『日本のこころ』を囲って――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理学の教科書と『無門関』釈義とを、それぞればらばらにして、一枚ずつ入れまぜて製本したような「日本的科学」の出現に、一つの温床を与える懼れがある。",
              "citation": {
                "source": "身辺雑記",
                "author": "――『日本のこころ』を囲って――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
