        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "巾着袋の結び紐をキュッと締めて、祭りの半纏の帯にしっかりとぶら下げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神社で授かったお守りには、魔除けの意味を持つとされる美しい赤色の結び紐がついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ギフトボックスに添えられた絹の結び紐が、贈り物にさりげない和の趣を演出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「待っとれや」　父は、袴の結び紐の上に手を組んで、教員室の白い門の中へはいって行った。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――白い頭巾の結び紐は、背のあたりに垂れ下って、胸に掛けた小さな黄金の十字架が、しんとした空気の裡に輝きを放っていた。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、結び紐がとけ、紙片が飛び散り、従僕たちはすべてをふたたび整理するために大いに骨を折らなければならなかった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
