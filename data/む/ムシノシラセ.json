    "definitions": [
      {
        "index": 1,
        "gloss": "feeling in one's bones",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
