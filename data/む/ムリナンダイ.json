    "definitions": [
      {
        "index": 1,
        "gloss": "unreasonable demand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
