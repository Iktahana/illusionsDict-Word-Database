[
  {
    "uuid": "dd23dc1e-96b7-5f37-b6f9-39a386743533",
    "entry": "昔ながら",
    "reading": {
      "primary": "むかしながら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
