    "definitions": [
      {
        "index": 1,
        "gloss": "thoughtlessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
