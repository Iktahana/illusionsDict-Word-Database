    "definitions": [
      {
        "index": 1,
        "gloss": "(another's) daughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
