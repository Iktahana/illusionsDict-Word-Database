[
  {
    "uuid": "11c9bb99-4330-5d50-bc11-37142c40d453",
    "entry": "無教養",
    "reading": {
      "primary": "むきょうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
