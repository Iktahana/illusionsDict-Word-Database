        "examples": {
          "standard": [
            {
              "text": "絶滅危惧種の狢藻を守るため、地元住民が池の清掃活動を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狢藻はムジナの尻尾に似た形をしており、水中で虫を捕らえる食虫植物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "牧野富太郎博士が発見したことで知られる狢藻を、植物園で観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「暗くなつて、むじなもさみしからうな。",
              "citation": {
                "source": "海坊主の話",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は日本ではじめて「むじなも」を発見していたが、その研究を大学でやる事が不可能になったので、困惑していたが、池野成一郎君の厚意で、ともかくも駒場の農科大学の研究室でこの研究を続行する事ができた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "むじなもいるが、これはなかなかとれないものだそうである。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
