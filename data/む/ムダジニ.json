          "literary": [
            {
              "text": "五百賊を討つに独り進んで戦い百人を射、余りの四百人に向い、汝ら前んで無駄死にをするな、傷ついた者の矢を抜いて死ぬるか生きるかを見よと言うた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子屋　そうして時間どのを無駄死にさせて以後、頼み事を聞いてくれんようになった。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の死んだな無駄死にだもん、東京の大臣さんたちゃ、どうた量見か聞いて見てえよう、まったく。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
