        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死体は行儀よく顔と顔とをつき合わするようにして並びながら倒れているのに、受けているふたりの傷は向こう傷でなく、うしろからやられたうしろ袈裟とは、いかにも奇怪至極です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬっと姿を現わしたのは、向こう傷のある兇相の武士。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "活き傀儡　巴御殿から出て来たのは、築土新吾と向こう傷のある武士――長崎左源太という武士であった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上額に向こう傷がある。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外娑婆と同じだなあ」向こう傷のあるのがこんな事を云った。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
