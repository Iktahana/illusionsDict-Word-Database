        "examples": {
          "standard": [
            {
              "text": "彼は大学で無線工学を専攻し、次世代の通信インフラについての研究に没頭している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無線工学の知識を活かして、より効率的に電波を飛ばすための新しい回路を設計した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "難解な数式が並ぶ無線工学の教科書を前に、学生たちは頭を抱えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一九三七年に生まれ、メイン大学で無線工学を学んだペドルは、ゼネラルエレクトリックでコンピューターに携わっていたが、同社の電算機事業からの撤退に伴って一九七〇年に解雇された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線工学に関して卓越した専門知識を持ってるじゃないか。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
