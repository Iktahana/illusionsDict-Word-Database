    "definitions": [
      {
        "index": 1,
        "gloss": "unprincipled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし手首の柔らかいということは無節操でもなければ卑屈な盲従でもない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実感織田作之助　文子は十七の歳から温泉小町といわれたが、「日本の男はみんな嘘つきで無節操だ。",
              "citation": {
                "source": "実感",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか殺そうとまで計画しなかったけれども、そんなに義理人情を弁えない兄夫婦であるならば、その無節操な嫂に対して敢えて不倫を行ったところで、自分の良心に恥ずべきところは些もない筈だと考えて、窃に機会を待つことにした。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥満人新居格氏よ、身をもつて思想上では無節操と自由とを混同することをもつて一生を終れ、あなたは真の貧者の求めてゐる自由の思想に対しては撫でるか引つ掻くかの二つより選んだためしがない。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも誰もかの女の心の変遷を、無操持を、場合によつては無節操を咎めるものはなかつた。",
              "citation": {
                "source": "百合子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "善いもわるいもなければ節操も無節操もなかつた。",
              "citation": {
                "source": "百合子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "つゞいてデカダンや、無節操や、小反抗や、似非不道徳をわざとやつて歩いた時代があつた。",
              "citation": {
                "source": "娟々細々",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "無良心、無節操なる暴力とか策略とか言うものを平気で、巧みに行ない得る男性が勝者となり、支配者となりまして、そんな事の出来ない善人たちが、劣敗者、弱者となり下って行く証拠が、日常到る処に眼に余るほど満ち満ちているのであります。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無気力、無節操なぞいう亡国的人民の資格をすっかり備えていることになるのである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「矛盾でもなんでも為方がない、その矛盾、その無節操、これが事実だから為方がない、事実！",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻としては辰子は無節操で、放縱で、我儘で淫奔で、彼のやうな臆病な小心な良人を軈て自滅さす種類の女であつたが、普通の女としてみたとき彼女は善良で快活で子供のやうに無邪氣であつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの理窟が十分にわからないものだから映画ジャーナリストたちはいたずらに会社のプロパガンダにあやつられてともすれば引き抜かれた監督俳優を不徳義、無節操呼ばわりをする。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して表面には立たず、裏面に隠れて策謀を事とし、変貌に変貌を重ね、裏切りに裏切りを重ね、ロベスピエールを陥れ、ナポレオンに悲鳴をあげさせた、この冷血で無節操で無性格な男は、常に疑惧と嫌悪との対象となり得る。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は白痴で無節操でロマンチックの生地無しだ！",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴のように無節操な人間にとっては、セラダが八千代サンを奪ってその処女をも奪ったというようなことは問題ではなかったのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日野の無節操、ヘツライ、乞食根性、タカリ、ケチ、助平根性、それはみんなセラダのものでもあったわけです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "無節操、ヘツライ、乞食根性、タカリ、ケチ、助平根性、ハキダメのような悪臭フンプンたる人柄です。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "進歩黨を去て政友會に赴いた時は、世間から變節だとか無節操だとかいはれたが、實は變節でも何んでもない。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "進歩党を去て政友会に赴いた時は、世間から変節だとか無節操だとかいはれたが、実は変節でも何んでもない。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "不道徳なことを申上げてまことに恐縮ですが、私自身も左近倉平に好意を持っておらず、反対にこの｜恋の狩人の左近倉平の、悲惨な最後をお話し申上げて、世の無節操な男共の反省に備えようという婆心ですから、暫くの間御勘弁を願います。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、真木に無節操な批評が加えられるとなると、ついに我慢がならなかった。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、孔子が事実それほど無節操で、自他を欺く人であつたとしたら、その教えが今日まで生命を持続する道理はないだろう。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは必ずしも無節操を意味するものではない。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーシェは大革命の当時からナポレオン時代を通じて活躍した男ですが、彼の特長は全くの無節操無徳義であり白昼公然の裏切りであり、しかも実行力にとんでいて人心の帰趨を観るに敏であった男であります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザックがこの人間をその無節操の力のおどろくべき点から描いている由、それからツワイクの興味は目ざまされたのだそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切ったが、自分のために、ツワイクの云い方ですればバクチの情熱のために冷血なので、自分が安穏にはした金で飼われるのが目的ではなく、同じ無節操の標本であるナポレオン時代の外務大臣タレイランが享楽を窮局の目的としたのとは又違う姿がよく描かれています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗み取った金と無節操な女とを争って享楽せんとする、疲れたる道楽者や冒険者などという一握りの人々のみだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずからおのれを統御することにおける大多数者の無能力、金銭に左右される無節操、不甲斐ない無気力、あらゆる優秀にたいする卑しい怯懦な反発、圧倒的な卑劣などは、反抗を惹起せしめていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "心外も心外、無知無節操の甚だしいものと、夜来、その眼の赤くなっているのを見ても、彼の憤りのただならざるものが分る。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ二日も無節操なバカ騒ぎがあり、木曜夜オペラハウスの仮装舞踏会で頂点に達する。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
