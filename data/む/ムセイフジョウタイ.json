[
  {
    "uuid": "ddab9786-12a7-5bcb-ad82-feb2c00b1ee6",
    "entry": "無政府状態",
    "reading": {
      "primary": "むせいふじょうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
