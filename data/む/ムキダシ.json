        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "門の鉄扉の外側に子守が二、三人立って門内の露人の幼児と何か言葉のやりとりをしていると、玄関から逞しいロシア婦人が出て来て、逞しいむき出しの腕でその幼児を軽々と引っかかえて引込んで行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の中でなく風のある部屋でむき出しの振子を振らせても同様である。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田君の小品ではこの東洋人がむき出しに顔を出している訳である。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹ならば珍らしくない、しかも二十匹が一度に喉を鳴らし、牙をむき出して、めいめいの餌食を忙がしそうに啖っているありさまは、決して愉快な感じを与えるものではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "その恐ろしいものは頬をぴくぴく動かし歯をむき出して咆えるやうに叫んで一郎の方に登って来ました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片すみに小さくなっているむき出しの安っぽい棚の中に窮屈そうにこの叢書が置かれている。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、作家は、おのれのすがたをむき出しにしてはいけない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の目で自分の前のむき出しの天然を観察しなければならない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓子があっという間にホールを出て行ってしまうと、小郷は軽い当身をくらったような、すかされた気持になったが、すぐまた背中をむき出しにしたダンサーをつかまえて、踊り狂うて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキを張った天井裏が頭につかえそうで、むき出しの装飾電燈が客席を見下ろしている。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木ばちには、人間の頭の骨が植わっていて、歯をむき出しています。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもロマンスにならない程、むき出しに懸命だ。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牙をむき出した感情にまで注意せよ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつともつと自分の醜惡をむき出しにしなければならないのだ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここぞと思ふやうなところになると、和尚さんは、台を手でぱんぱんと叩き、二つの目をかにのやうにむき出して、台のすぐ下にゐる老人達を喰ひつかんばかりに大口でしやべりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わははと従妹がむき出しに笑い出した。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋だか初冬の夕だかに斯んな田圃から町の方へ、黄ろい大きな前歯をむき出したお婆さんが一人白髪頭をふりさばいて黙つて歩いて行く――こんなことが凄いやうに描いてありはしませんでした？",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々が此所へ来ると野性と出鱈目をむき出しにして、もっと／＼と興味を漁るために揉み合う。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジャネットは此の人混みにあおられるとすっかり田舎女の野性をむき出しにしてロアール地方の訛りで臆面もなく、すれ違う男達の冗談に酬いた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "池のはたの杉の木が、すっかり伐り払われて、何かこれから工事でもはじめられる土地みたいに、へんにむき出しの寒々した感じで、昔とすっかり変っていました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗だとて何で一旦関白面前に出た上で、復今更に牙をむき出し毛を逆立てて咆哮しようやである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい眼をむき出して父を見つめるばかりで、言葉が出なかった。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼なんかとは話もしないで、先輩ばかり相手にしているロシア女の、黒く太い植え睫毛や、緑色に深くとった眼のくまや、腋臭くさい肩から、むき出しになっている女の腕の、銀緑色の生毛などを、如何に少年らしい興奮を以て、彼は眺めたことであったろう。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と穴から渡すように、丼をのせるとともに、その炬燵へ、緋の襦袢むき出しの膝で、のめり込んだのは、絶えて久しい、お妻さん。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子が親も財産も男も失くして気違いになってから、俄かに加奈子の心がむき出しに京子に向った。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むき出した膝から下も、むっちりと弾んで、若くから体を濡らして男の触感に磨かれて来た女の、アクを洗いとったなめらかな白さに、すくっと伸びていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は眼を細め、薄あかい歯茎をむき出し、顫わせながら、さも擽ばゆそうに笑った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に白い歯をむき出して僕に飛びかかってくるようなことがないとも限らないと思ったが、今さら逃げ出すことも出来ないので、僕はよほど警戒しながら一緒にあるいた。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士のようなむきだしの石山で、しかも懐の深くない山ですら、道路の変遷と盛衰はこのように烈しい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士はもう森林や砂礫をかなぐり捨てて熔岩の滑らかな岩盤をむきだしにしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
