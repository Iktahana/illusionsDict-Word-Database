    "definitions": [
      {
        "index": 1,
        "gloss": "unglazed (e.g. pottery)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔は所謂新羅燒なる無釉の瓦器があつたが、一躍して高麗青磁の尤品を出し、世界的にいゝものを造つた。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず無釉陶にえも言われぬ立体美の数々が見られる。",
              "citation": {
                "source": "瀬戸黒の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "無釉陶の中でも、群を抜いて美しいのが、この備前焼である。",
              "citation": {
                "source": "備前焼",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――古来、有名なる陶器は、いずれもこの土の仕事が立派に、芸術的要素を具える上に、さらに良き模様が良き筆者に描かれ、またその上に美しい釉薬が掛かり、適当の施薬、適宜の無釉、あるいは彫紋が施される。",
              "citation": {
                "source": "私の陶器製作について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "南蛮は無釉のもので主として泡盛の甕を作ります。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼物を日本人はいたく愛するが、無釉またはこれに近い焼物を熱愛する習慣は西洋には見られぬ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶※を愛する人は習慣的にすぐ裏返して高台を見るが、そこは多く無釉で地肌が露れている荒々しい部分である。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南蛮の方は無釉のもので、主に泡盛壺や水甕を作る。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには無釉のもの釉掛けしたもの両方ある。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の各地に残る無釉の陶器や、緑釉のものや、また、この磁州の鉄絵のものなどを見ますと、漢、唐、宋の古代が、今もなお息を有っていることを知るのであります。",
              "citation": {
                "source": "北支の民藝（放送講演）",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作陶に例をとつてみるならば、無釉時代の技能と精神とに着目すべきである。",
              "citation": {
                "source": "青年よ師を無数に択べ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
