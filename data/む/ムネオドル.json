    "definitions": [
      {
        "index": 1,
        "gloss": "heart-pounding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遊園地の入り口が見えてくると、子供たちの胸躍る冒険が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "これから発表される新製品のデモンストレーションに、胸躍る期待を寄せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "胸躍るようなリズムに合わせて、若者たちがダンスを楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "で、次から次へと加速度的に面白さや好奇的な感じが集積して、胸躍ると云つた工合に惹きつけられて行く。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレモ、オオトシヤツタア、ソルントンシヤツタア、フオルカルプレンシヤツタア、カアルツアイス、百分の一、千分の一、テツサア、アナスチグマツト――さういふ寫眞用語がいかに歴亂として私の腦裡を動き、いかに胸躍るやうな空想を描かせ、いかに儚ない慰樂を與へたことか？",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇夜のなかの胸躍るような仕事のなかでは、燈火を持った者に出逢うのは嫌なことだ。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の国粋主義は、何十年も長い狐疑と準備の後、硝煙晴れた海の上に敵の無敵艦隊が撃破されてあるのを見た瞬間にイギリスが獲得した、不屈の剛気と華麗な自信と胸躍る挙国一致の感激の表現だった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to have one's heart pound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初めての海外旅行を前に、パンフレットを眺めているだけで胸躍る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "明日の試合を想像すると、自然と胸躍るような高揚感に包まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "憧れのアーティストとの対面を控え、彼女は胸躍る思いで待機した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
