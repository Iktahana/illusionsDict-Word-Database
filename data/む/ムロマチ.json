    "definitions": [
      {
        "index": 1,
        "gloss": "Muromachi period (1336-1573)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
