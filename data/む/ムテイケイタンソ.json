        "examples": {
          "standard": [
            {
              "text": "木炭や煤は、炭素原子が不規則に並んだ無定形炭素の一種である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この研究室では、無定形炭素を用いた次世代の電極材料を開発している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無定形炭素はダイヤモンドのような結晶構造を持たず、加工の自由度が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "厄介なのは木炭類の無定形炭素である。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都帝大の吉田卯三郎教授が、炭の粉の比重を測定された結果では、焼き方によって、同じ無定形炭素でもいろいろ性質のちがったものが出来ることがわかった。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
