    },
    "definitions": [
      {
        "index": 1,
        "gloss": "odorless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "准南子のは山澤の精神髓氣の力といふやうな意で、其の氣たる無形無臭のものを指して居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『准南子』のは山沢の精神随気の力というような意味でその気が無形無臭のものを指している。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱鹽類泉とかいふのださうで、無色無臭、實によく澄んでゐます。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色無臭、温泉もよく、いゝ湯であつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色無臭、温度もよく、いい湯であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれと手足を伸ばしてうち浸った温泉は無色無臭、まったく清水の様に澄んでいた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、万一の用にもと肌身はなさずつけていた、ある無色無臭の毒瓦斯を室内に放ったのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無味無臭、無色透明の世界に住みたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその本位とするところは、我が味うところの愛という情操で、この無形無臭の情操に相応するような非我の事相を創設するのであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色無臭の気体で、極めて激しい毒性がある。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのポンスケ探偵も、今頃はさぞおどろいているでしょうね」「ふふン、まさか毒｜瓦斯で呉越同舟の無理心中をやらかすとは気がつかなかったろう」　碇が掌の中で壊した硝子のアンプルの中には、無臭の麻痺瓦斯が入っていたのである。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう呪わしき境遇に追込まれた者の常として、平面無臭の生活ができないことは首肯されるであろう。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無臭瓦斯よりもこの方がいい。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "燻精は、わしのところから出ていくとき、特設の通路内で無味無臭無色無反応の持久性神経瓦斯を吸って戻ったのだ。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず大体の上においてこの命題は確然たる根拠のあるものと御考えになっても差支はなかろうと思います）早い話しが無臭無形の神の事でもかこうとすると何か感覚的なものを借りて来ないと文章にも絵にもなりません。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をして思わず鼻孔をふくらませる、無味無臭の香である。",
              "citation": {
                "source": "梅花の気品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土からヘナ、ヘナから砂利と、一｜丈余も掘って、無色透明無臭而して無味の水が出た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かに気がついて身の周囲を見廻してみると、それがみんな手探りも出来ない無色無臭の中央であつたりする。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な毒物なんだが溶かすと無味無臭で、誰も毒物が入っていると気がつかない。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは五十粒ぐらい飲んでも眠くならないし、無味無臭で、酒の肴としても、うまくはないが、まずいこともない。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも易の易象、易數の理など、中庸の中和の理、上天無聲無臭贊歎の理など、皆高妙なる理の説き法也。",
              "citation": {
                "source": "尚白箚記",
                "author": "西周",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土からヘナ、ヘナから砂利、と一丈余も掘つて、無色透明無臭而して無味の水が出た。",
              "citation": {
                "source": "水汲み",
                "author": "徳冨盧花",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る者は私かに無臭の珠に鼻を当てて見た。",
              "citation": {
                "source": "津軽の虫の巣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫安は黄色いものとばかり思っていたが、白色無臭ということも、このとき初めて知った。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちのいわゆる第三階級というものは、無味、無色、無臭、無形だ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色無臭無味であることも、魅力のひとつだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色無臭、濛気は見えない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
