[
  {
    "uuid": "bec6b49b-133a-5939-9ad0-c1e4c62485da",
    "entry": "無臭",
    "reading": {
      "primary": "むしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
