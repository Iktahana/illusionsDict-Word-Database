    "definitions": [
      {
        "index": 1,
        "gloss": "bluntly (refusing, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
