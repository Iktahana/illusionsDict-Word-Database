    "definitions": [
      {
        "index": 1,
        "gloss": "to experience chest pain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "胸が痛むほどほしくなってしまったのです。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は見ていて胸が痛む。",
              "citation": {
                "source": "馬地獄",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気の吹き出た白い体にサッと水が咆り掛って、弾み切った肢体がすくっと立つ――そのなまめかしさを安二郎はたびたびうっとりと愉しむのだったが、やはり、消費される水のことを想えば胸が痛むのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ通訳のお姉ちゃんはアラン・ケイのあまりに翔んだお言葉に何が言いたいのかさっぱり訳分からないようで、白と言ったのが黒になったりグレーになったりと、かつてのオレの「幸せなら手をたたこう」の演奏もかくやと思わせる迷調子（ああ、お姉ちゃんの悪口言うと胸が痛む）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ思いだすと、今でも胸が痛む。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はその子の事を思うとどうしたわけか定子の事を胸が痛むほどきびしくおもい出してしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（午後三時書き次ぐ）また少し胸が痛む……あの變な、何ともいへぬ不氣味なうづき、けれどもそれに心を假してゐると、また氣が滅入つて仕樣がないから、構はず先を書いて行きませう。",
              "citation": {
                "source": "道",
                "author": "――ある妻の手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「陛下、お寒いのでございますか」「余は胸が痛むのだ」「侍医をお呼びいたしましょうか」「いや、余は暫くお前と一緒に眠れば良い」　ナポレオンはルイザの肩に手をかけた。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と云う呪わしいことか、と云うような激情が起って、身動きしても胸が痛むようであった。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は胸が痛むほど、すくむほど、悲しいほど、うれしいやうな気がしたのだ。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "産科の医者がもう起す時分だと思ふ頃、その産婦は胸が痛むと云ひ出した。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに胸が痛む。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考えるほど胸が痛む。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのたびごとに、自分でも胸が痛むような気がして、二階から降りてゆくのであった。",
              "citation": {
                "source": "音楽時計",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から胸が痛むのでポッケットから、粉薬を出して飲もうとするがあいにく水がない。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親の欲目かもしれないけれども、顔半分は非常に美しい顔立ちで、女の子であるからいっそう胸が痛む点はありますけれども」と言う手紙を私によこした。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は女としてその文章をよんだとき、本能的ないとわしさを感じ、胸が痛む思いがした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出すも胸が痛むが、光秀殿などは殊さらに厭う事である。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのあげくの果は四國にお流されになつた崇徳上皇といふやうな、身、皇室の御一方と生れながら、非業な最期をとげられたといふ有樣で、實にあゝいふことは、私自身、書きながら胸が痛むんでありますけれども、そのたびに私は自分にムチ打つやうな氣持で、あへてこれを書き通してきたのであります。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が痛む、仕様のないやつだな」「いやどうぞその儘」「我儘者でござる、どうか御容赦を」　言葉の端々に滲み出る妻への愛情、六兵衛は心の裡に羨ましさを感じながら別れを告げて出た、――と表に待っていた吉公が「隠居さんちょいと」　声をひそめて手招きをする。",
              "citation": {
                "source": "おもかげ抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくば、ここの樹に私を荒縄で縛り付けて、叡山の狼どもに、この体を与えて下さい」「……もう遅い」善信は、自分の胸が痛むように、熱い息をついていった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、ずきずき胸が痛むのだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「了現、あと幾日の糧をのこしておるか」「十日とて保てませぬ」「いや、木の芽や草もある」　それを思うと正成は胸が痛む。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
