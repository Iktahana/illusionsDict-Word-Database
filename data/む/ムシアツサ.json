    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heat and humidity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――花柑子咲く野も近み、月白ろむ葡萄畑の夜の靄に、土蜂の羽音、香の甘さ、青葉の吐息、情慾の誘惑深く燃え爛れ、仰げば空の七つ星紅く煌めき、南国の風さへ光る蒸し暑さ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉が鳴いて蒸し暑さはいっそうはげしい。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲勞は其癇癪を促した上に焙爐の蒸し暑さは一層親爺の腹をむか／＼させたのである。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐く息が、そのまま固まりになってすぐ次の息に吸い込まれるような、胸の悪い蒸し暑さであった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの風が凪いでから、気温は急に夏らしい蒸し暑さに返って、横浜の市街は、疫病にかかって弱りきった労働者が、そぼふる雨の中にぐったりとあえいでいるように見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目の朝電燈が百合の花のしぼむように消えるころ葉子はふと深い眠りから蒸し暑さを覚えて目をさました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船室にゐてさへ蒸風呂のやうであるが、この浴室の中の蒸し暑さ加減といつたらまるでトルコ風呂だ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蒸し暑さは一層人の神経をいらだたせて、暴風雨の物凄さを拡大した。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに漆喰塗りの大仏の胎内は一層の蒸し暑さでありますから、わざわざそういう苦しい中へ這入ってうでられる物数寄もないといったような風で、客はがらりと減りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と言っても蒸し暑さは地獄でした――私は熱いのは好きなんですが、熱さと愚かな習慣とが一体となったものは、もはや我慢の限界を超えています。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降る、汗が蒸し暑さに腐るように匂う――、事の起りはそういう晩だったのです。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、この蒸し暑さときたら死んじまいたいくらいだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、二つの変貌と人瘤　八月十六日――その日は、早朝からこの地峡の上層を、真白な薄雲が一面に覆うているので、空気は少しも微がうとはせず、それは肢体に浸み渡らんばかりの蒸し暑さだった。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいいようのない蒸し暑さの中で、滝人は、とうてい人間の記録とは思われないような、一連のものを語りはじめた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血を騒がす異様な蒸し暑さが充ちる夜であった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "たえがたいほどの蒸し暑さの密林の中に、人間を恐ろしいとも思わぬ蠅や蚊や蟻の群とたたかいながら、二時間のあまり、同じところにじっとしていることは、それだけでもたえがたいことだった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に気温は騰るわ、雪は融けるわ、その水蒸気のせいで湿度百パーセント、なんという蒸し暑さでしょう」「なるほどなるほど、宰相閣下が氷の塊を心臓の上におのせになるのも無理ではない」　といっているとき、部屋の中からは、一人の役人が、頭から湯気を立てて、まるで茹で蛸のような真赤な顔で飛び出してきた。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっとうしい蒸し暑さが夕立の大騒ぎで、きれいさっぱり吹き飛んでしまうようなものだ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "デッキ・チェアーに長々と寝転んで、頸筋へ斜に落ちる日光を久々で楽しんでゐると、昨日までの蒸し暑さが嘘のやうである。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の空気が彼には次第にうっとうしくなってきたが、もうこれまでに何回か不思議に思いながら、部屋の隅にある小さな、疑いもなく火のはいっていない鉄ストーヴを見ていたので、部屋の中のこの蒸し暑さは解しかねた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃まで電気を点けることも忘れ珈琲の一杯、麪包の一片を取ることすらも忘れ、閉め切った部屋の蒸し暑さも忘れて、私は凝乎と机に凭れていた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ今夜は大の男が二人も余計｜殖えたのですから、尚更たまらない人いきれがして、密閉された壁の中は、何だか地震でもありそうな、息の詰まるような蒸し暑さでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺の左近と、龍泉の正季も、彼のさしずを待ちかねるふうだが、それに黙したまま、寝床まで抱き入れた迷いは、寝ぐるしい蒸し暑さを、よけい幾たびもの寝がえりにさせていた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "“SORI-BATTEN!”麹室の長い冬のむしあつさ、そのなかに黒い小猫を抱いて忍び込み、皆して骨牌をひく、黄色い女王の感じ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "無駄な一本の畦幅さえそこには見られない、きっちりとすき間もなく一望果ない田圃になっていて、盆地特有のむしあつさの中に、ぞっくりと稲の葉なみをそろえて立っているのである。",
              "citation": {
                "source": "青田は果なし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また炭坑の中のむしあつさを思い出す。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持の悪いむしあつさが、街上によどんでいた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはむしあつさが食欲をさまたげるし、それに食物が伝染病菌で毒されているという観念が、おさえがたく起こってくるからであった。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十五日　〔巣鴨拘置所の顕治宛　目白より（封書）〕　十月二十五日　　第七十三信　きょうのむしあつさ、いかがでしょう、そしてこんな風！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか雨はやんだらしいが、やんだ後のむしあつさはよけいであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
