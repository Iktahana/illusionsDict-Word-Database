        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その武者振りの見事さに、相手は感に堪えて見惚れさせられた。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に武者振りついても、飽くまで詰責しようと待構えていた母も、これですっかり気先を挫かれて、苦笑するより仕方ありませんでした。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいきり立ち武者振りついて行く。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその爺さんがおかあさんの武者振りには他には類の無い裏にデリケートな処がある。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんに武者振りつきたかった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きで好きで武者振りつきたいくらいだったわ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "どさんと屋根から下へ飛び降りる音が聞える）（数枝）（あさに武者振りついて）お母さん！",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "（また馳せかえり、野中の死体に武者振りついて泣く）すみません、すみません。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の主従は左右より屍に取りつき、言葉も無くただ武者振りついて慟哭して、さすがの荒くれた漁師たちも興覚める思いで眼をそむけた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いって笑いながら、武者振りついて来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお半が長助に武者振り付いたというのは、ちっと理窟に合わないようですが、長助は確かにむしり付かれたと云っていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは勿論眼なんてあいてゐられやしなかつたから、えゝもう為るやうに為れつと、つまり観念の眼を閉ぢて、でも難破船の中の人のやうに力一杯武者振りついてゐたの。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なるほどその言葉の通り、皮膚のいろも、爪のいろまでが光沢を失って、ほんの昔、真紅の胴に白いろずくめのしぶきを切り乍ら、武者振りも勇しくこの大川を乗り切ったときの、あの目のさめるようなみずみずしさは、どこにも見えなかった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太十や五郎達が云ふ通り、正しく彼女も私達の武者振りに信を置いて、深甚の好意を抱いてゐる者と認められた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の境内から、水を渉り河原を横切り、桑畑を飛び越えて、径もなく、山中の谿谷に踏み込んでも、決してゼーロンの勢ひは鈍らなかつたが、その間に漸く私の進歩はその臀部から背筋を逼つて首根に達し、鬣に武者振りついてゐた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言つて、重右衛門は立上つたが、其儘その若者に武者振り付いた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、夢中になつて、いきなり寝台から飛び降りると、生きた鳥でもつかむやうに時計に武者振りつく、自分の騒ぎで目醒されてしまふこともあつた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄吉が母親の髪の毛に武者振りついて喚いてゐるのを彼等は、態ア見ろと云はんばかりに冷たく見返りました。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "初こそ悔しがって武者振り付いても見たが、勘ちゃんは喧嘩の名人だ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これもまたあまり不意の出来事だが私の後ろにいた品子が急に泣いている菊江の襟もとへ武者振りついて歯をきりきり鳴らせ出した。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山姥がいきなりかやのたばに武者振りつきますと、はずみですべって、ころころと谷そこにころがりました。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "美智子さんは夢中になつて、何の分別もなく眼醒時計に武者振りついて、慌てゝベルを止めました。",
              "citation": {
                "source": "眼醒時計の憤慨",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、突撃の陣太鼓のように乱脈にその腹を蹴り、鬣に武者振りついて、進め、進め……と連呼した。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼は猛々しく武者振りついて来る女房を避けながら、心の中で呟やいた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "三平は帯を引っぱって武者振り付いた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帯に手をかけて万平は武者振り付いた。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするか見やがれ」　彼は洋服男に武者振りついた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お篠は浅田に武者振りつきながら泣声を振絞るのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩太郎の武者振りは壮観であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせいは胸倉を取つて、上から武者振りついて來た。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
