[
  {
    "uuid": "04d7d683-7358-529b-8e88-f2fdee08abea",
    "entry": "ムース",
    "reading": {
      "primary": "ムース",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mousse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実際の電子本作りに挑戦してみると、マニュアルの流れ、ソフトウエアの仕立てに、誰にとっても初めてとなる作業をスムースに進めさせようとする配慮が行き届いているのがわかる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きなノイズが入らないようにはできるけど、あんまりスムースには聴こえないからね」「気にすんなって、どうせ、みんな眠ってるから、わかんないさ」　高志は、六小節しかないイントロを、テープ編集で四倍にしろと要求している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、こんなことをスムースにやる、じぶんたちの年齢を思わずにはいられなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "礙なし」という所は「ひっかかりなしに動き得る」とありますが、何物にも拘束されず、囚われず、スムースに、自由に働き得ることが、すなわち「礙なしというわけにはゆきません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の先であるいはいろいろ印刷物の表面では民主化、民主化といって、日本の民主化は進行している、きわめてスムースに進行しているというようなことをいいながら、その半面で露骨にファシズムを植えつけて行くことが可能なような社会意識に日本を止めておくことは私ども日本の人民にとって非常に恐ろしいことです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとした小道具だけれど、これでインターネットとのやり取りが少しスムースになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時点でできることを一覧表にまとめておき、その中から選ぶ形をとることで、交流はスムースなものになると期待できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キンキナトゥス（縮毛）の異名あり〔デーチ〕父子三代に亘りて（その名をいづれもプブリウス・デキクス・ムースといへり）祖國の爲敵手に死せる（前四―三世紀）ローマ人（『デ・モナルキア』二、五・一二八―三〇參照）〔ファービ〕ローマの名門。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一の牛酪製氷菓（ムース　オー　フレイズ）は菓物入の菓子なり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に又、スリバチ型の頂上へのぼりつめて、自然に速力が停止すると、もしペダルから足が放せるなら、当然片足をヒョイと降して、支えて止まる状態でもあり、それが出来ないから、ころがるだけの、きわめてスムースに、かつ、やわらかく、ころがりうる状態であることを知る必要もあろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、それやまあ、誰かがゐて、万事スムースに運んでいく必要はある。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムースというのは、米洲では一番大きい獣で、肩のところで六フィート以上もあるそうである。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一年にムースが一匹食えますか」ときくと「犬に大部分やるさ。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎は独身で呑気者で、無慾で、純情家で、そして天成のユーモリストだ、それが銭形平次の物語のスムースな展開を助けてくれたことを、作者の私が一番よく知っている。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物帖談義",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷河の幾つかは風によって裸にされた山道へと異常な程スムースに続いており、辿り着いてみれば我々が選んだ飛行経路もその例外ではなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは平凡に叙したからこそその感情がスムースに読者に伝わるのであって、むつかしく叙したのではその深い内部のものを伝えることが出来ない、という種類のものである。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッキー・ミリンダー、アイヴォリー・ジョー・ハンター、ブルムース・ジャクスン、ザ・ドミノスのクライド・マクファター、あとでツイストのスタートをつくった、ミッドナイターズのリーダー、ハンク・バラード。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから日劇へ行く、渡辺篤のこと、スムースに行かぬらしく、半ばあきらめる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スムースにいってくれればいいけど……。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
