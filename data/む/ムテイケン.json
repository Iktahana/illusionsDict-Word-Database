    "definitions": [
      {
        "index": 1,
        "gloss": "lacking fixed principles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかも無定見ではあるが近く彼等は解禁をなすであろう。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "予審判事、検事が、極端に被告の自供を強要するの悪習は、この調書に絶対の証拠力を附すと云ふ公判判事の無識、無定見から由来して居ると云つてもいゝ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの無定見は、じつは、今日自然主義という名を口にするほとんどすべての人の無定見なのである。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の中ッ腹は無知、無定見の辛棒無し……つまり無鉄砲の異名となった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "心安立の友達が、鉛筆もまんざら悪くはないが、いつもあれでは余り無定見ぢやないかといふと、支配人は砂糖臭い大きな欠伸を一つした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、あなたの無定見な恋――盲目的な憧憬を意味するのぢやありません。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "顕微鏡下に置かれた微生物と同様の無自覚、無定見のまま恍惚として、大勢に引かれながら大勢が行く。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通にいう世渡りの上手だというのは、ただ無主義で無定見で無思想で、流るるままに浮かんでゆくを称するのであるが、いやしくもいずれかの主義を抱いた者は、一時調子よいことがあっても、浮き沈みのあることは覚悟せねばならない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "根こぎにされた人々の無定見と、粉飾を事とする思想感情の淫蕩と、病的な個人主義とであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "無定見な讀者の一人なる私は、偶に月評家の意見を聽いて、駿馬を相しようと言ふ無駄骨折りを助からうとする。",
              "citation": {
                "source": "詩と散文との間を行く發想法",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、これが為めに、芸術そのものゝ「偉大さ」、芸術そのものゝ価値を疑ふ無定見に陥つてはならない。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（４）、批評家の不親切よりも、その無定見は非難さるべきである。",
              "citation": {
                "source": "なんとかせねばならぬ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方法は単に、営利劇場の「悪趣味」に対して必要であるのみならず、所謂「新劇」と称する独りよがりの舞台に対しても、同様、その「無定見」と「退屈さ」の度合を知らしめるために役立つであらう。",
              "citation": {
                "source": "芝居と見物",
                "author": "売笑的舞台への攻撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時劇評家の無定見は寒心に堪へないものであるが、かかる「雰囲気」は、自然、新劇ファンの大多数に影響し、「素直に」芝居を観賞する習慣を奪ふことになる。",
              "citation": {
                "source": "演劇当面の問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家の無定見もさることながら、やはり、民衆の演劇に対する理解が薄いところから来るともいえる。",
              "citation": {
                "source": "演劇への入口",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "優れた教養と正しい演技能力と、必要な年齢と、社会的責任の自覚とを併せもつた俳優がゐないといふことは、勿論演劇映画を純然たる企業化した資本家の責任であるが、これを商業主義の利用に一任した国民全体の無定見にも罪があることはいふまでもない。",
              "citation": {
                "source": "官立演劇映画学校の提唱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛り場を縄張りとする愚連隊が、無政府状態の敗戦直後に先ず縄張りの復興にのりだしたのは自然であるが、これを正規の復興に利用し、政党費までこの連中の新円に依存しようという量見を起した政党の無定見、一時しのぎのさもしい根性、未来の設計に対する確たる見透しや理想の欠如というものは、ひどすぎた。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公表もひどかったが、ジャーナリズムの無定見、軽薄さは、さらにヒドイものだと私は思った。",
              "citation": {
                "source": "切捨御免",
                "author": "――貞操なきジャーナリズム――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、砂糖の乱用と化学調味料を無定見に用いることは、充分慎むべきことであろう。",
              "citation": {
                "source": "味を知るもの鮮し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖や「味の素」類品の跋扈に拍車をかけているのは、料理する者の無定見である。",
              "citation": {
                "source": "持ち味を生かす",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この無定見が、味覚を無神経にし、天然自然によって与えられている個々の美しき「味」に盲目となり、「味」を心に楽しむ世界から葬り去っている。",
              "citation": {
                "source": "持ち味を生かす",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もって無知なる当局の取締方針など、このまま無責任に放置せず、あり余るこの魚族を有毒との理由から、むやみと放棄し来った過去の無定見を反省し、さらにさらに研究して、ふぐの存在を充分有意義ならしめたいと私は望んでいる。",
              "citation": {
                "source": "河豚は毒魚か",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家を以て任じていた彼女の父は、教育に関して殆んど無定見であった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日も経たないうちに朝廷の方針は、百八十度も転回するほど、余りにも頼りない、無定見なやり方だと、批判の声は大きかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて人々によればジャーナリズムは全く無定見な日和見に時を費すものであるかのようである。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて現代に於けるジャーナリズムは元々それが持っていた無定見性の可能性を実現し、センセーショナルでトリビアルなものとなる。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が読者大衆自身は、云って見れば読まされるものを何でも読むような、無定見者に過ぎない。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてジャーナリズムは日和見的な無定見に見えて来るのである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
