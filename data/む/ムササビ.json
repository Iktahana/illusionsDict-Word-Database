    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese giant flying squirrel (Petaurista leucogenys)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "落葉が朽ちるのか、根が水を吸うのか、巻き葉が拡がるのか、虫がささやくのか、風が渡るのか、その静かな音、音ある静かさの間に啄木鳥とむささびがかっかっと聞こえ、ちちと聞こえる声を立てる。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰々だって、そういいましたら、伊豆の伊八、四丁艪の甚太夫、鯰の勘七、縄抜の正太郎、飛乗の音吉、秋刀魚の竹蔵、むささびの三次、――あのこの人の声だったんです、私に奥様のことを教えましたのは、」　夫人はお鶴の記憶の可いのと、耳の敏い、利発さと、そのかくのごとき運命とに、ただ何となく慄然とした。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、筋向うの格子戸の鼠鳴に、ハッと、むささびが吠えたほど驚いて引返して、蔦屋の門を逆に戻る。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大熊、羆、山猫、とらはんみょう、むささび、麝香鹿、馴鹿。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、仲間で木鼠ともむささびとも仇名をとっていた。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むささびが、梢から梢へ身を移す如く進退が敏捷であったからである。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いつつむささびのように身を翻えすと、もう姿が闇の中に吸い込まれていったあとでした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ツざきにしても飽き足りぬのは、オロシャの陸軍少佐と称したデフレ何とかウイッチの、むささびのような面構えであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎が草むらから飛び出したり、野猫がむささびを食っていたりしていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは蜜や、むささび、袋鼠のような小動物を求めて、非常に高い木に登らざるをえない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから考えてみると、江戸で「むささび」のことをモモングヮ、それから一転して一般に野獣の肉をモモンジーなどといったかも知れぬ。",
              "citation": {
                "source": "おばけの声",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、食用にはならぬが、栗鼠やむささびなどがとれる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根を廻った亀井滝の上に、伐採の小屋があって、土間に大きな榾火がいぶり、天井にむささびの皮などつるしてある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師は別に獲物も無かったらしく、月が出たら森へ行ってむささびをぶってくれる――などと言って、しきりに銕砲をひねくり廻している。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むささびは夜行性で、木から木へとび移る所を射ち落すのだという。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし背すじに迫る寒さにたじろいだか、口ほどにもなく火にかじりついて、夜がふけても出かけるけはいはなく、ひそかにむささびの肩を持っていた私を微笑ませた。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――むささびの六となのる男は、鼻唄をうたいながら歩いてゆき、井戸端から三軒めにある蝶太夫の住居の格子を、声もかけずにあけて、さっさとはいっていった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むささびの六は大あぐらをかき、左手に持った飯茶碗の酒を、ちゅうちゅうと音をさせて、さもうまそうに啜りながら話していた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むささびの六の嘲笑するような声が、耳の奥のほうで聞えた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、しっかりしろ」と彼は云った、「生娘だから遠慮をしていたんだ、それだけのこった、こんどこそ、力ずくでもものにしてみせるから見ていやあがれ」　むささびの六は姿をみせなかった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紛れもなくむささびの六の声で、彼は慌てておりうに手を振った。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むささびの六助というならず者も伴れて来て、腕を折ったのは蝶太夫に頼まれたからだと云い、深川の門前仲町にある「岡田」という料理茶屋を教えられた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここがわからない」と千之助は呟いた、「そのあとで蝶太夫をあやめたんだが、どうしてそのまえに仲次郎を呼んだのか、むささびの六とどんな関係があるのか、なんのために五十両という大枚な金を仲次郎に遣ったのか、そのところがまるでわからない」　次の医者のときもそうだ、と彼は思った。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――むささびの巣があって。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手長猿一　むささびでも逃げるように、木の葉を騒めかせて崖を辷ってきた者がある。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはまた、一杯飲める」松林を駈けぬけると、近衛坂の崖へつかまって、むささびのように迅こく登って行った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野猪の子でも兎でもむささびでも愛すことが出来たが、狐だけは憎かった、また、怖かった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……※だな」　伊織は、野葡萄の実へよく来るむささびの顔を覚えている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
