        "examples": {
          "standard": [
            {
              "text": "クラゲやタコは、背骨を持たない無脊椎動物の仲間である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海洋生物の大部分は無脊椎動物であり、その生態は多種多様だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちは理科の授業で、昆虫などの無脊椎動物を観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "広島文理大の平岩馨邦氏の無脊椎動物の性に関する研究も亦有名だ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "このものの有機組織は皮革に類似した劣化せずほとんど破壊し難い性質を本来的に有しており、我々の力では到底推測できない太古に於ける無脊椎動物の進化サイクルに附随している。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルムホルツは無脊椎動物の神経系の構造についての卒業論文を書いて1842年に学位を取得しシャリテ病院の外科医助手となり次いでポツダムの軍外科医となった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
