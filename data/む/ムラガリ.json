[
  {
    "uuid": "7892b8a0-18d3-5980-91af-206fbfbde327",
    "entry": "群がり",
    "reading": {
      "primary": "むらがり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
