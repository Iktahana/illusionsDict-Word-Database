    "definitions": [
      {
        "index": 1,
        "gloss": "crowding together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女等群がりて卓を圍み我れの醉態を見て憫みしがたちまち罵りて財布を奪ひ殘りなく錢を數へて盜み去れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、地平線の隅々からすべての烏が集って来たかと思われる程、無数に群がり、夕立雲のように空を蔽わぬばかりだった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　山の麓のさびれた高い鐘楼と教会堂の下に麓から谷間へかけて、五六十戸ばかりの家が所々群がり、また時には、二三戸だけとびはなれて散在していた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫は洞窟の周囲に、だにのように群がりついて作業をつゞけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今、清逸の頭の中には表現すべきものが群がり集まって、はけ口を求めながら眼まぐるしく渦を巻いているのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難、甲斐々々しき姿にて、群がり来る人々に忙がしげに餅を与えて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹慎なる聴衆を容れたる法廷は、室内の空気｜些も熱せずして、渠らは幽谷の木立ちのごとく群がりたり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君助がゆつくり空やまはりの景色を見廻した眼を再び芍薬に戻すと、いつの間にか紫紅の焔のやうな花の群がりの向う側に一人の少女が立つて居た。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月末頃から咲き出した紅椿の上枝の花は、少し萎れかかって花弁の縁が褐色に褪せているが、中部の枝には満開の生き生きした花が群がり、四月下旬の午後になったばかりの精悍な太陽の光線が、斜めにその花の群りの一部を截ち切っている。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのどっさりおりますことと申しますと、群がり集まった足はちょうどすすきの原のすすきのようでございますし、群がった角は、ちょうど枯木の林のようでございます」と韓袋は申しあげました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その群がりかさなってたおれた人の一ばん下になっていたために、からくもたすかって息をふきかえし、上部の人がすっかり黒やけになったのち、やっともぐり出たという人が二、三十人ばかりあります。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、電燈が付いたかと思ふと、いつの間にかふけて行つて、夜明けの庭鳥の聲や、朝がらすが寺の山の高い檜の木に群がり啼くのを聽く。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ見よやつ」　と叫ぶとひとしく名作、直江志津の大小の斬れ味鮮やかに、群がり立つたる槍襖を戞矢々々と斬り払ひ、手向ふ捕手役人を当るに任せて擲り斬り、或は海へ逐ひ込み、又は竹｜矢来へ突込みつゝ、海水を朱に染めて闘へば、四面数万の見物人は鯨波を作つて動揺めき渡る。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "廟の傍の林には数百の鴉が棲んでいて、その前を往来する舟を数里の前まで迎えに往って、舟の上に群がり飛ぶので、舟から肉を投げてやると一いち啄でうけて、下に墜すようなことはなかった。",
              "citation": {
                "source": "竹青",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の脊の高い痩せた色眼鏡の男が、――私はてっきり私服の刑事巡査に相違ないと思ったが、――いろいろと自分の観察を云っているのに、人々は群がり集って傾聴していた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はみな群がり、ながめ回した。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなおも注意深く前へ歩きつづけているあいだに、今度はトレードの恐怖についてのいろいろの漠然とした噂が、私の記憶に群がりながら浮んできた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、とりわけ、過ぎし日の多くの群がりよる記憶を呼び起し、私の魂に電流に触れたような衝撃を与えた、あの短い、単純な、よく聞きなれた、しかもささやくような声の性質、音色、調子であったのだ。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた私は、もの思いに沈んでいるとき自分に群がりよってくる影のようないろいろの妄想にうち勝つこともできなかった。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを訛ったものか、昔人この蛇毒を以て他動物を殺さんとする時、口に尾を銜みて、箍状になり、電ほど迅く追い走ると言ったが、全く啌で少しも毒なし、しかし今も黒人など、この蛇時に数百万広野に群がり、眼から火花を散らして躍り舞う、人その中に入れば躍り囲まれて脱し得ず、暈倒に及ぶと信ずる由。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜にも増して見るものにつけて連想の群がり起こる光景、それから来る強い刺激……葉子は宿から回された人力車の上から銀座通りの夜のありさまを見やりながら、危うく幾度も泣き出そうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "群がり集まって来た子供たちは遠巻きにその一人の子供を取り巻いた。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して此等の木々の根がたには篠や虎杖が生え、まんりやう藪柑子が群がり、所によつては羊歯が密生してをる。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "興照寺より届けいでこれあり候とあったその永代橋へたどりついてみると、名人の出馬いまかいまかとかたずをのんで、寺社奉行ご支配の小者たちが群がり集まる群衆を制しつつ、その到着を待ちあぐんでいるさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "角を曲ると同時に、なるほど目を射ぬいたものは、そこの千種屋の前一帯に群がりたかる捕り方の大群でした。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりひとり呼び出して、一枚ずつ手渡しでもするだろうと思われたのに、小判の山を鷲掴みにすると、群がり集る人山を目がけて、惜しげもなくバラバラと投げ棄てました。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔一〕谷権現の祭りとて、　　　　　麓に白き幟たち、むらがり続く丘丘に、　　　　鼓の音の数のしどろなる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老農火雲むらがり翔べば、　　そのまなこはばみてうつろ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜すがら温き春雨に、　　　　　風信子華の十六は、黒き葡萄と噴きいでて、　　　　雫かゞやきむらがりぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに紫苑の花びらが羽虫のやうにむらがり飛びかすかに光って渦を巻いた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
