[
  {
    "uuid": "6ad757b0-c67c-5790-9fca-ffac830cdd1b",
    "entry": "向ける",
    "reading": {
      "primary": "むける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
