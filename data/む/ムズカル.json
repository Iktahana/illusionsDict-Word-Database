    "definitions": [
      {
        "index": 1,
        "gloss": "to fret (esp. of a young child)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　祖母が憤る様に言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、お前が無茶云うから、船長だって憤るんだ」　セコンドメイトは、栗のきんとん見たいな調子で云った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤ると頬つぺたを膨らませるんでね。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前だつて憤ると頬つぺたを膨らせやしないかい」「とつても膨らませるんだよ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気のぬるきに人たちて、　　故なく憤る身は暗し。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人は声はり上げて『わが心高原にあり』をうたい、『いざ去らば雪をいただく高峰』の句に至りて、その声ひときわ高く、その目は遠く連山の方を見やりて恋うるがごとく、憤るがごとく、肩に垂るる黒髪風にゆらぎ昇る旭に全身かがやけば、蒼空をかざして立てる彼が姿はさながら自由の化身とも見えにき。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのかわり、今ね、憤るなよ……お転婆な、きみが嬉しがる、ぐっとつかえが下って胸の透く事をしてお目に掛ける。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、麥稈をぬいで風を入れた、頭の禿を憤る。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼児は正直者ですから、他から嫌疑を受けて家捜しをされたなどと聞くと、必然憤るに相違ありませんから……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そんなに憤るもんじゃないわ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方の兄さんたちは憤るまいことか、「さては弟のリイは泥棒の名人になったと見える。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "巍は燕王に書を上りしも効無かりしを歎ずれば、鉉は忠臣の節に死する少きを憤る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王｜憤ること甚しけれども、計の出づるところ無し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間見着けた時には、腹は立たないで涙が出たぞ」と切歯をなして憤る。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　青二才の無礼を憤る心は充分あつた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つなり、憤るもの。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは之を憤るほどの未練な世界に最早や住してゐないつもりである。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤る、憤るもの、力なり、ためらはず。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "罵らるれば怒り、撃たるれば憤る、而して、其の怒ること、其の憤ること、即坐に情を洩らすこと、野獣の如くにして而して止むを得ば、恐らく復讐といふものゝ要は無かるべし。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ心理で、幼児もあまりに幼くちやほやされると憤る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼を蔑み、彼はこれを憤る。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生を焦躁と憤懣との中に送った伯父の遺言が、皮肉にも、憤る勿れ、となっていたのである。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　翁は甚だしく憤ると、「ホラホラホラホラッ」　と怒鳴って立上りがけに上の総義歯を舞台に吹き落すことがあった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方にこうして女性に図星を指された場合、男性はその面目上｜憤るのが十中八、九のように見受けられます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は病的に落ち窪んだ眼で、息子を認めると、扉の外の巡査に聞えるのもかまわず、むずかる子供のように「快上快」を求めた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちは、父親の背でむずかる眼の赤い子供を見て、始めてそれを思い出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から手持ちぶさたそうにただ立って成り行きを見ていた五十川女史は思いきって近寄って来て、若者を葉子から引き離そうとしたが、若者はむずかる子供のように地だんだを踏んでますます葉子に寄り添うばかりだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうかするとむずかるらしく、剪刀を投げられたりするから、あれは直さなければと葉子は笑いながら庸三に話すのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十七　ある朝お銀がむずかる正一を背へ載せて縁側をぶらぶらしていると、笹村は机の前に坐って、苦い顔をして莨ばかり喫していた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は母を求めて、そこにむずかる独り子の自分を揺すって起こす慈母の愛を求めて無意識に手を伸ばしたが、手答がなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
