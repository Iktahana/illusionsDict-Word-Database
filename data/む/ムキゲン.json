        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちやんと契約が出來とつてね、借賃は期限づきは五錢、無期限……といふのは本屋が元へ返すまでですがそれだと十五錢なんです。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内板には宴会や歌舞音曲は無期限に延期するという張り紙がある。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代でさへ重罪人の妻子や、妹など、または關所破りの女たちなどは、本籍を剥がれ、無籍者、女奴として吉原へ無期限でおとされたといふ、奴とはいまはしい名なのだ。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "県下に木材工場をもっているお高の伯父が、その工場を拡張するにあたって、あぶらやから一万円無期限無利子で借りたことがある。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は帰国後、当分の間はという殆んど無期限の有様で、ぶらぶら遊んでいた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もしもあなたが宮廷の不興を蒙ってお出でではなく、またここ何年間もあのように面白からぬ形勢になってお出でではなかったならば、一枚の拘禁令状★で私はどこかの城牢へ無期限に送り込まれていたろう、と私は信じているのです。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育の市中でも竣工無期限と云ふ寺院の足場がコロンビヤ大學の傍に立つて居る位だ。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭労は十三、四日にわたる四十八時間ストについで、十七日から大手筋十六社二十四万人が一せいに無期限ストに突入した。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭労茶志内支部を結成している全九百人の坑夫が無期限ゼネストにはいって五日めのひるまえに着いた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年たちは無期限ストの第一日から、アルバイトのため山を去っていた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日になるか明後日になるか、ことに由ったら一週間も掛るか、まかり間違えば無期限に延ばしても差支ないと高を括っていたせいかも知れない。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王は頑として動かず、チャンドオズ夫人の夜会は無期限に延期された。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月初め、ウィレットはウォード夫人に、保養のためアトランティック・シティへに行き無期限に滞在するよう命じた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠れた海は大変深かったらしく、地球内部の熱のお陰で居住可能な環境が無期限に保証されていたのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、高湿、川ぞい、曇天、暗鬱な天候によって無期限に抑制されてしまう。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀式を無期限に延期して、全部ぶちこわすこともできますよ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時小野組は政府の御用金や各府県の為替御用を扱っていて、殖産興業という名目で貸下げられた無利息無抵当無期限の金を広くいろいろの事業に注ぎこんでいた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
