        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "親方も、むかっ腹を立てて云いました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかっ腹がたってくるじゃござんせんか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "話を聞いただけでもむかっ腹がたたあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門のだんなの一の子分の伝六様は江戸っ子だってことをあっしも聞いちゃいたんですが、ほんとうにだんなが江戸っ子だったら、あっしの話を聞いただけでもきっとむかっ腹をおたてになるんだろうと思って、じつあこうしておねげえに参ったんでござんす」「こいつあおもしれえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼みとありゃ、いかにもむかっ腹をたててやろうじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかっ腹をたてておくんなさいというのは、ここのところなんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "重大な試運転の真最中に、誰か副官の声色をつかって、俺を一ぱいくわせたのかとむかっ腹をたててここへ帰ってくると、ほら、そこにいる怪しい東洋人が眼にうつったではないか」「あ、なーるほど。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、この戦争の虚偽が、今ではすべての人間の精神を破壊してゆくのではないかしら」と、正三が云いだすと「ふん、そんなまわりくどいことではない、だんだん栄耀の種が尽きてゆくので、嫂はむかっ腹たてだしたのだ」と清二はわらう。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＴＳから法外な値段で売り出されているベーシックの書き手であるゲイツの抗議に対し、クラブの仲間たちの大半はむかっ腹を立てていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが折角の友達との間を裂かれて、むかっ腹を立てたのか、それともただの我儘からか、先方の馬どもは、どんなに馭者が鞭打っても、まるで根でも生えたように頑としてその場を動かなかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体検査をされている当人がむかっ腹を立て、堪忍袋の緒を切らして、この税関吏の、いかにも気持のよさそうな顔をした横っ面をぶんなぐってくれようと、うずうず苛立ってくるような時でも、彼は顔の筋ひとつ動かさず、例の慇懃な態度も失わないで、ただこんな風にいうだけであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と裁判所長は、むかっ腹を立てて言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は相手の男を眺めると、これはまた私の知人の、いつでも顔はむかっ腹立てながら心中では巫山戯ている人物をしのばせた。",
              "citation": {
                "source": "西南北東",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともあなたは、そんなに高い所へは昇れないとおっしゃるのですか」　気の短い雷の神は、それを聞いてもうむかっ腹を立てて、いきなり立ち上がりました。",
              "citation": {
                "source": "コーカサスの禿鷹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう観察した敬太郎は、この一句を前置に、今までの成行を残らず話そうと力めにかかったが、時々相手から「そうでございますとも」とか、「本当にまあ、間の悪い時にはね」とか、どっちにも同情したような間投詞が出るので、自分がむかっ腹を立てて悪体を吐いた事などは話のうちから綺麗に抜いてしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の狐は、憤慨してむかっ腹を立てた途端にわれを忘れ、先刻の自制心を失い、裳の間から素早く手を出して上の狐の持っている餅を奪って、股座の奥の横に割れた己の口へ、ねぢ込んだ。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、灰色をかいて発表して、自分には、技巧の訓練がまるでないのだということを知り、何だか自分に、おそろしくむかっ腹をたてて、ＶＩＫＩＮＧを脱退してしまった。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはこの日頃自分に対する仕打ちのことも入り乱れて考えられて、無闇に、むかっ腹が立ってくるのだった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへでも攀じ登り、新鮮な日光の下で踊り、むかっ腹を立て、からだじゅうを掻き、なんでも摘みあげ、そしていかにも原始的な風情で水を飲む。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に中谷はむかっ腹を立て、彼を遊廓に伴ったという。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその翌年には、『オブローモフ』にむかっ腹を立てて、あんな「別に複雑でも何でもない、ダース幾らの小っぽけな性格を、社会的タイプにまで引上げてやるのは勿体なさすぎる」とさえ言い放っている。",
              "citation": {
                "source": "チェーホフの短篇に就いて",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの道路からも、植木屋はやって来ないで、彼のむかっ腹は我慢のならないものになった。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "男がよくて、腕がたって、気性が単純で、むかっ腹がつよくて、かなり不良で、やせぎすで、背が高くて、しじゅう蒼み走った顔をしていて、すこし吃りで、女なんど洟もひっかけないで、すぐ人をブッタ斬る青年……こういう男には、女は片っ端から恋したものです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、「おっと、待ってくれたまえ、ブランブルハースト駅にある、ぼくの荷物をとりよせるようにたのんでくれたかね」「配達屋にたのんでおきましたから、あすの朝早くとどきます」「あすの朝……こん夜のうちに、とってくるわけにはゆかないかね」「ええ、だめでございますよ」　おかみさんは、むかっ腹をたてていた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぱいかついだだけですよ」　トーマスが苦しそうにこたえると、船員はむかっ腹をたてたらしく、「新聞にだってのっているんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "話もなにもあるものか、ふんづかまえてやるぞ」「だまれ、おれがおまえなんかにつかまるものか……」　透明人間は、むかっ腹をたてたらしく、とうとう、博士の足をえいっとすくい、ベッドの上にほうりだし、大声をあげて助けをよびそうにしている口の中へ、シーツのはしをぐっとねじこんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上彼はどんな時にでもむかっ腹を立てる男ではなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が何ぞと云うと、むかっ腹をたててぷんぷんするのでも這裏の消息は会得できる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　素子は、同じようにむかっ腹を立てているような口調で云った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もうそんなことに、むかっ腹をたてるようなかれではなかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
