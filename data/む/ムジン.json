    "definitions": [
      {
        "index": 1,
        "gloss": "unmanned",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべての恋する人々は、自分等以外に全く人影のない離れ小島の無人島で、心行くまで二人だけの生活をし、二人だけの会話をしたいと願うのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方と思つた彌次連は、先刻から傍若無人の暴言を小面憎く思つて居た、敵であつたのだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜に村の煮売屋などの二階から、大勢兵隊が赤い顔を出して、近辺の娘でも下を通りかかると、好的好的などと冷かしたり、グズグズに酔って二、三人も手を引き合うて狭い田舎道を傍若無人に歩いたりするのが、非常に不愉快な感じを起させた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が日本アルプスでも、上高地は、私が明治三十五年に、白骨温泉から梓川を渉って、霞沢岳を踰え、この峡谷に下りて、槍ヶ岳へ登ったときは、夏とはいえ、寂寥無人、太古の如き感があって、温泉の湧出はあっても、今日のような宿屋は、まだ建っていなかった。",
              "citation": {
                "source": "上高地風景保護論",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど十九世紀に著しく勃興した探検事業は、科学的研究心と合体して、未知数に向い、無人境に向った結果、山岳研究ということが、欧洲より米国に、また日本に伝わって来て、諸々の文明国は、山岳会を有するに至った。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、瀬戸内海を傍若無人に通り抜けた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば大勢の中にきっと一人くらいは「豪傑」がいて、わざと傍若無人に振舞って仲間や傍観者を笑わせたりはらはらさせるものである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集からこぼれ出て路端に傍若無人に立小便をしている男も見逃してやりたい。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて私の或る知人が、シベリヤ鉄道の旅行について話したことは、あの満目｜荒寥たる無人の曠野を、汽車で幾日も幾日も走った後、漸く停車した沿線の一小駅が、世にも賑わしく繁華な都会に見えるということだった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし共二人は、遠い遠い無人島で、何年も何年も暮しましたのでございますわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう無人島から帰って来たのでございますもの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "無人島でない事はその山よりも高い空で雲雀が啼いているのが微かに聞こえるのでわかる。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて彼が心は人々の知らぬ間に亡び、人々は彼と朝日照り炊煙棚引き親子あり夫婦あり兄弟あり朋友あり涙ある世界に同居せりと思える間、彼はいつしか無人の島にその淋しき巣を移しここにその心を葬りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座二丁目辺の東側に店があって、赤塗壁の軒の上に大きな天狗の面がその傍若無人の鼻を往来の上に突出していたように思う。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日本人の威張り方は傍若無人だ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石沙無人の境の、家となり、水となり、田となり、村となつた、いま不思議な境にのぞみながら、古間木よりして僅に五｜里、あとなほ十｜里をひかへた――前途の天候のみ憂慮はれて、同伴に、孫引のもの知り顔の出来なかつたのを遺憾とする。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無人では叶わぬところだから、六郎の父の讃岐守は、六郎に三好筑前守之長と高畠与三の二人を付随わせた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで鉄の鶴は無人の境を行くようにどこまでも単調な挙動を繰返しながら一直線に進んで行くのである。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "境界面を示さない人間は不可視人間であり、それは結局、非人間であり無人間であるとも言われるかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん恐ろしかったのは奄美大島の中の無人の離れ島で台風に襲われたときであった。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に、あるいは佇み、あるいはながながと寝そべり、あるいは疾駆し、あるいは牙を光らせて吠えたて、ちょっとした空地でもあるとかならずそこは野犬の巣のごとく、組んずほぐれつ格闘の稽古にふけり、夜など無人の街路を風のごとく、野盗のごとくぞろぞろ大群をなして縦横に駈け廻っている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の影一つ、犬コロ一匹通っていない真の寂莫無人の厳粛な地獄絵図としか見えなかった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は無人の地にいて、我を忘れ世界を忘れ、身も魂も、今そのなしつつある仕事に打ちこんでいる。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれ等が皆な消え失せて山上に樹っている一本松のように、ただ一人、無人島の荒磯に住んでいたらどうだろう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ千年の深林を滅し、人力を以て自然に打克んが為めに、殊更に無人の境を撰んで作られたのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが食堂で夜ふけまで長時間続いていた傍若無人の高話がようやく少し静まりかけるころに始まるのが通例であった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "糜爛する浅ましい姿　記者はこうして、九月初めから十月｜半までの東京市中を、縦横むじんにあるきまわった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の馬は、よく僕を乗せて、広い練兵場を縦横むじんに駈け廻ってくれた。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれのもちもの（文学的伝統をふくんで）を生かして、その上での前進を、共通の重点をとおして見てゆくという複雑さをおそれない方法がとられないと、それはゆたかに縦横むじんに育たない。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
