[
  {
    "uuid": "95f55d6c-44a9-5105-9ee6-37b7867c91e0",
    "entry": "無人",
    "reading": {
      "primary": "むじん",
      "alternatives": [
        "ぶにん",
        "むにん"
      ],
      "is_heteronym": false
    },
    "grammar": {
