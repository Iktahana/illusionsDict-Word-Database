        "examples": {
          "standard": [
            {
              "text": "特殊な航空機を急降下させることで、地上付近でも擬似的に無重力を体験できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無重力の空間を自由に泳ぎ回る、宇宙飛行士たちの映像に見入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物理の実験で、無重力下における炎の形状の変化を調査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "陽子の奏でるポリフォニックシンセサイザーから透明な無重力感を帯びた音色のメロディーが流れ、カメラのシャッターを思わせる不思議な効果音がそれに和した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中にほうりあげられたときの無重力に近い不思議な状態は、サーフボードの下に海と波のエネルギーのありったけを受けとめる、きわめて重い状態へと急変する。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの短い時間だが、無重力のように自分が軽くなる瞬間がある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "波がそのパワーの限度ぎりぎりまでのびあがったとき、無重力に酷似した世界が始まる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーヴァーハングになりかかる波の、ほんのわずかしか水量のない頂上に、無重力のまま僕はいる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
