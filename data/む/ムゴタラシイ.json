    "definitions": [
      {
        "index": 1,
        "gloss": "(incredibly) cruel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この世に於てさえ、こんな惨たらしい災害を避けることが出来ない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ世の中に、家の為に、女の児を親勝手に縁附けるほど惨たらしい事はねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左かと云へば右、右かと云へば後ろ――といふ母の惨たらしい命令に狼狽してゐる弥三郎の表情は、今にも泣出しさうに見えた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼にこそ見えませんが、この世間には男性に弄ばれた女性の生きた惨たらしい死骸が、幾つ転がっているかも分りません。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし血は惨たらしい程に噴いていても、傷は皆浅い。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼にこそ見えませんが、この世間には男性に弄ばれた女性の生きた惨たらしい死骸が、幾つ転がつてゐるかも分りません。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのポーランドに惨たらしい破壊が加えられている。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この惨たらしい死態を見て気の毒とは思わんか。",
              "citation": {
                "source": "青蠅",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "その惨たらしい死相を、ユラユラと動くランタンの光越しに覗いていると、何だか嬉しそうに笑っているかのように見えた。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼石のごろごろして居る河原は見るも惨たらしいが、それは実はわが心が同じ様に乾いてゐるので、それが反映して痛ましく感ぜられるのではないか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの煙に咽んで仰向けた顔の白さ、焔を掃つてふり乱れた髪の長さ、それから又見る間に火と変つて行く、桜の唐衣の美しさ、――何と云ふ惨たらしい景色でございましたらう。",
              "citation": {
                "source": "地獄変",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんという惨たらしい殺し方だ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "流産して殺すなんてそんな惨たらしいことがどうして出来ようか。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私どもに向って身上噺をせいと仰ッしゃるのは、言わば辛うじて治りかけた心の古疵を再び抉り出すような、随分惨たらしい仕打なのでございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部の情景を一目見せられた私は、想わずあっと愕きの叫びを立てましたが、俄に体中が慄え出し、奥歯のかちかち触れ合うのが止みません……何という惨たらしい出来ごとでしょう。",
              "citation": {
                "source": "流転",
                "author": "山下利三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この惨たらしい光景を、詳しくお話するのは私の主旨ではありません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第四夜　恋の不在証明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰があんな惨たらしいことをしたかわかりませんが、どうか、敵を討って下さい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄でも屍体を蒲葵の縄で縛り埋めたが、硬直せる屍体の膝を折ることなどもあって、実に惨たらしいものであったと聴いている。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの惨たらしい習俗はアイヌのウフイが残存したものである。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝の松原で、惨たらしい殺され方を見た時、その遺書を繰返して見た時、不貞の女の当然の報いを眼前に見せられても、なおその女が憎いとは兵馬には思えないで、やっぱり親切な姉の気持が離れないのでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "竜神の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという惨たらしい報いであろうと、お君は、どうしてもそのお嬢様のために心から同情しないわけにはゆきませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに向って、お角さんがたずねました、「どうしたのです、これはまあ、惨たらしいねえ、どうして早く取片づけてあげないの」「へへえ」と番太が、おぞましい声で返事をしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "君太郎に勧められるまでもなくそうでもしなければ、今の私にも到底このままでは、この惨たらしい記憶に幕が降ろせそうもないのであった。",
              "citation": {
                "source": "生不動",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の殺し方は、なか／＼むごたらしい。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍から見るとむごたらしいほどに手厳しく仕込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも其の場でぶち殺された犬は仕合わせで、生き残っていた方は飛んだむごたらしいお仕置をうけて可哀そうでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "疵のあとには血がにじんで、見るからむごたらしいのに驚かされて、手真似でその子細を聞きただしたが、何分にも要領を得なかった。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし源吉の場合とは違って、おせんは養父にも可愛がられ、自分もおとなしく働いているのに、なんでこんなむごたらしい復讐を受けたのか、その子細は判らなかった。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不遇ななかから漸く育ったわが子の血が結核などに汚されて、それがまたわが子の手に截れたむごたらしい傷口から現在わが家の畳の上へこぼされたのが悲しくもいまいましい。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わいが日の丸湯の大将によう頼んどいて来たったさかい」　びっくりするような、きびしいいいつけで、聴きつけた〆団治が、「他あやん、お前なんちゅうむごたらしいこと言うネや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
