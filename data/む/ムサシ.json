    "definitions": [
      {
        "index": 1,
        "gloss": "Musashi (former province located in parts of present-day Tokyo, Kanagawa and Saitama prefectures)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表面には「駒込｜西片町十番地いノ十六　寺田寅彦殿　上根岸八十二　正岡｜常規」とあり、消印は「武蔵東京｜下谷　卅三年七月二十四日イ便」となっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流された残り湯が湯気となつて立ち、　　昔ながらの真つ黒い武蔵野の夜です。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の人たちは、遅塚麗水、大町桂月、江見水蔭、田山花袋、久保天随、坪谷水哉などであるが、花袋が紀行文家と言われた時分は、自然派文学勃興以前のことで、文章に感傷癖はあったが、淡泊清新、ことに武蔵野あたりの原野や雑木林の寂しさを、淡彩的に点描するのに巧みであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野といえば、ただちに独歩の名作が連想されるが、花袋も紀行文家として「野の人」であった、武蔵野の人であった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野に見るような黒土を踏んで、うら若いひのきの植林が、一と塊まりに寄り添っている、私たちの足許には釣鐘草、萩、擬宝珠、木楡が咲く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "名もない一遊子ではあるけれど、私も幼い時から、富士の影を浴びて、武蔵相模で育った一児童として、永い間の外国生活から、故国へ放還された一旅人として、親友と、子供と、忠実なる案内者とに囲まれて、今富士の膝下へ来て亡き母の顔に見えまつるが如く、しみじみと見ているのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は富士山という一つの題材を、幾十百部に切り刻んで、相模野からかけて、武蔵野辺に住む人たちに朝となく、夕となく、種々の相を示してくれる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛飾の真間の磯辺から、武蔵野の小岫がほとり、入間路の大家が原、埼玉の津、廻って常陸の国に入った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天孫民族が渡って来た頃の本土のさま、また朝鮮の一民族が移って来た頃の武蔵野のさまを想像する参考になりそうである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の上になってるので、利根川は勿論中川までもかすかに見え、武蔵一えんが見渡される。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（文字少し大きく）　宮本武蔵、両刀を抜いて毅然と立つ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（少し大きく）　紫羽織の一人、怒って武蔵に斬って掛かる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足退いて武蔵、其奴を叩ッ斬る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　兎も角　当時、宮本武蔵の名は　津々浦々に響き渡っていたＳ＝道場の表　念流剣道指南、森脇左十郎の門外である。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「拙者、天下の浪人　宮本武蔵政名と　申す者」　「ソーラ来た」と取次の侍早顔色が無い。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎声張り上げて、Ｔ「拙者天下の浪人　宮本武蔵政名と申す」　で取次の侍、例の如く驚いた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥後熊本浪人　宮本武蔵政名、とある。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階から下りて来た女中の報告で、　番頭や女中が、Ｔ「宮本武蔵？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に泊って居るのが、本当の宮本武蔵である。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、亭主から宿帳を受け取った。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宮本武蔵」と独り言し乍ら、　亭主に「宮本武蔵どのと言うのは？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主が聞かれて「よくお訊ね下さいました」　実は、Ｔ「隣りの室のお客様が　宮本武蔵先生」　これには武蔵、ばからしゅうて暫時言葉も出なかった。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、Ｔ「御亭主　折入って　御頼みがある」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しそうで独り言、Ｔ「どうやら　宮本武蔵って先生に　遭えるらしい」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝団九郎の室　武蔵を伴って亭主が団九郎の前に、　平伏して、頼み込んで居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　武蔵が、Ｔ「先生の門人として　道中御供　致し度う御座る」　ウンウンと団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　さて　翌る日――Ｓ＝街道　早水団九郎、荷物を全部、宮本武蔵に持たせて威張り返って歩いて行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むさしや」といふ家のはなれを借りて根合せならねど、あやめの歌合といふを試みけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが下駄を片手にぶらさげて跣足で田の畦を逃げ廻るのを、村のアマゾン達が巧妙な戦陣を張ってあらゆる遁げ路を遮断しながらだんだんに十六むさしの罫線のような畦を伝って攻め寄せて行った。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば露計りも愛矜なく、しかも身もちむさむさしたる出女の、油垢に汚れ朽ばみしゆふべの寝まきながら、発出でたる心地ぞする。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
