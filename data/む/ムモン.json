    "definitions": [
      {
        "index": 1,
        "gloss": "unpatterned (e.g. clothes, pottery)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひとり文界の浪士のみ之を占むるにあらず、無名の詩人、無文の歌客、こゝやかしこにさまよふめり。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "故律無文（『讀例存疑』卷卅七）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "無文字の婆さんは、直覚的に、適当な時機と場所とを選んで、適当な種を蒔く。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時の師学｜倶に生死岸頭に於て遊戯し、荊棘林中に大自在を得る等と、当土なしの虚言を吐て、又傍には不立文字不在言句上、無義無味無文無句、公案は参ずるのみ、義解して講ずべからず、と云ふ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無文の太刀　重盛は、未来を予見する不思議な能力を持っていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、小烏どころか大臣葬のとき使われる無文の太刀だったからである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私の心遣いなのじゃ、そなたも一目でおわかりのはずじゃが、これは大臣葬の時用いる無文の太刀じゃ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "無文字、唯刻木結繩、敬佛法、於百濟求得佛經、始有文字、知卜筮、尤信巫覡。",
              "citation": {
                "source": "隋書倭國傳",
                "author": "魏徴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなものを、読むもんじゃない。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、うな、医者だなんて、人がら銭まで取ってで、人の稲枯らして済むもんだが。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は何かてえと、お酒お酒ツてお謂ひだけれども、私が幾ら飮むもんじやない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一「……そういったわけだもの、ね、……そんなに怨むもんじゃない。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、私が引込むもんだから、お京さん、引取った切籠燈をツイと出すと、――この春、身を投げた、お嬢さんに。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が飲むもんか、と僕は歯を喰ひしばつて力んだが、「虫の為だよ」と云つた祖母の言葉が急に気になり出して堪らなくなつた。",
              "citation": {
                "source": "疳の虫",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それぎりでとうとう十月ほどして返して来た時、余り拗過ぎて我慢にも読通す気になれない、やはり外道の喜ぶもので江戸ッ子の読むもんじゃアないといった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんか、飲むもんないのかさ」「おれも後悔してるんだ」　デッキチェアに深く沈みこんだまま、高志がこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は、あの病人が、とても回復の見込みはないから、この世の思い出に好きな酒を一杯だけ飲ましてくれとせがむもんですから、ブランデーを一杯のましてやったのです。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは、三度三度、おれが手をとって食事をさせてやる」「誰が飲むもんですか」「飲まなきゃ、滋養浣腸をしよう。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「抛っといてそれで済むもんならええわさ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには疲れて来たんだから、君、疲れたときには、人は一番親しい所へ転がり込むもんだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、拾うものを片端から自分の生活に関係なく読むもんだから文化的な水準は一等高いけれど、どうしても文学少女みたいになっちゃうんです。",
              "citation": {
                "source": "個性というもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車がそりゃこむもんだから。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ俺ア不幸だよ、――由坊みたいに綺麗じゃないからな……」「まア黒ちゃん、ソンナこというもんじゃないわよ、あんた、あたしを疑ぐってんの、そんなに僻むもんじゃないわよ」　由子も、自分の言葉に我れしらず亢奮して眼を見張った。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはね、日本の女が飲むもんじや無いと思ツてたの、きつい、きついお酒だと思ツてね。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつかしく考え出せばきりのない話だが、なんでもないと思えばそれはそれで済むもんですよ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余り一つことをくよくよ考え込むもんじゃねえよ。",
              "citation": {
                "source": "土地",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい蜂矢君、君が幽霊なんか引っぱりこむもんだから、たいへんなさわぎになったよ。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、かえるがしつっこくたのむもんだから、じゃあお友だちにしてあげるって、あたしかえるに約束してしまいました。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の方で変にとるといけないから、勤めなんかよして、しばらくお父さんのそばにゐてくれつて、その人、あたしに頼むもんだから、さうすることにしたの。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅子　　だつて、わざわざ、喧嘩しないだつて、穏やかに済むもんなら済ませたらいゝぢやないの。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
