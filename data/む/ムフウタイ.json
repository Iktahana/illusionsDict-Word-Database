    "definitions": [
      {
        "index": 1,
        "gloss": "calm belt (e.g. doldrums)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
