[
  {
    "uuid": "2c90121a-20e2-5af4-b936-7b1f45524e75",
    "entry": "無我の境",
    "reading": {
      "primary": "むがのきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "state of complete self-effacement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちなみに太郎の仙術の奥義は、懐手して柱か塀によりかかりぼんやり立ったままで、面白くない、面白くない、面白くない、面白くない、面白くないという呪文を何十ぺん何百ぺんとなくくりかえしくりかえし低音でとなえ、ついに無我の境地にはいりこむことにあったという。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は顔容に於て、思想に於て、性格に於て各々異なれども、一度其霊性の天地に入るや、俄然として茲に無我の境に達す。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二人の勝負師が無我の境地のままに血みどろになっている瞬間であった。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのような場合にでも、その仕事の中に自分の天与の嗜好に逢着して、いつのまにかそれが仕事であるという事を忘れ、無我の境に入りうる機会も少なくないようである。",
              "citation": {
                "source": "科学者と芸術家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お千は絶対無我の境地にあるような姿勢をしていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを行ふには、靈媒を無我の境に陷し入れるもう一人の術者が要るのが普通である。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその靈媒が修行を積んだ人ならば、自分で無我の境に入つて行くから、術者は要らない。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈媒が無我の境に入ると呻り聲を發する。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "指導者の手を借りてでないと、彼女は無我の境に入ることが出來なかつた。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に述べた愛妻家の友人は七十何囘もこの靈媒女を通じて亡妻と語り合つたが、その後半に至つては、靈媒女は指導者を必要とせず自分で無我の境にはいれた。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、もし一度興起り、想｜漲り来って、無我の境に筆をとる時の、瞳は輝き、青白い頬に紅潮のぼれば、それこそ他の模倣をゆるさない。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、影のような過去の夢の中になおさまよいながらも、やわらかい霊光の無我の境地に浸って、渺茫たるかなたに横たわる自由をあこがれる新たに目ざめた心境をおこそうと思った。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "真は批判の規準であって、善悪美醜を超越して無私無我の境地に身を置くことは、その批判的態度であった。",
              "citation": {
                "source": "性格批判の問題",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして彼は無我の境地に（多田君は私にさう言つた）没入し、死ぬこともみえのことも忘れ果てた時、高く差し上げた指先にひやりとしたものを感じた。",
              "citation": {
                "source": "戯画",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によると、生涯に一度も無我の境界に点頭し、恍惚の域に逍遥する事のないものがあります。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品が無心に作られたものであり、無我の境において作られたものであれば心打たれる。",
              "citation": {
                "source": "魂を刳る美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがなかなか無我の境地にはなれない。",
              "citation": {
                "source": "魂を刳る美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "平地では夢想だもしなかった、登山者の前にのみ次から次へと展開する新しい驚異は、知らず知らずの間に山にあこがれ、山に徹底し、これと融合して無我の境地に到達しなければ止まない衝動を与える。",
              "citation": {
                "source": "山の魅力",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴉片を喫って恍惚として、無我の境地で抱擁し合う、この極度の快感は、日本にいる誰も知らないだろうよ。",
              "citation": {
                "source": "鴉片を喫む美少年",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぐる夜桂子の高殿で、ほとんど無我の境の中で、桂子と契った小次郎であった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎之介の話をきき終り、海舟は悠々自在、無我の境に遊ぶようにナイフを逆手に、後クビの悪血をしぼっていた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川が行きはじめたころは、主事の指導がないと無我の境に入ることができなかったが、しばらくすると、白川が手を握っているだけで、ひとりでやれるようになり、霊の来かたも、ずっと早くなった。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊媒は無我の境に没入しているので、意識はなく、香世子と二人だけの世界だから、遠慮も気兼ねもない。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "上気した頬のいろが、見る間にスーッと引いて、たちまち蒼白に澄んだお藤は、無我の境に入ってゆくようです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "練習不足はてきめんにこたえたけれども、次第に、一音が一音をひとりでに呼びさます、あの無我の境にひきいれられる。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ瀑布の音に溶け込むようにして、心を鎮めて坐って居たまでで、そうすると何ともいえぬ無我の境に誘れて行き、雑念などは少しもきざしませぬ。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも科学と芸術の領域が異なり、科学者がみずからピアノを弾いて無我の境地に入ろうとも、歌舞伎を見て涙を流そうともおかしくないように、科学者が宗教的信仰によって人生の意義を見出すとしても、何もおかしくはない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう私は暫くそこにじっと坐り込んでその風致を眺め、うっとりとその境涯に見惚れて茫然無我の境に入りました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "余程長時間を経て始めて無我の境に入ることが出来て、その後判断が出来ました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな話を聞いていると、ぼくは数千年前の太古の昔にいるようで時代を忘れ、大きな原始林の中にただ一人、世俗を離れ、いっさいを忘れて、しばし無我の境。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
