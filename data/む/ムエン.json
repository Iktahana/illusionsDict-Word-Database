[
  {
    "uuid": "557d510a-63ef-51bd-ad97-c6d24caf5b6e",
    "entry": "無縁",
    "reading": {
      "primary": "むえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
