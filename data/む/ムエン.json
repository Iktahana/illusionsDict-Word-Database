  {
    "uuid": "1decf5ce-d923-5cfe-b35f-73cb1fa25c4d",
    "entry": "無援",
    "reading": {
      "primary": "むえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
