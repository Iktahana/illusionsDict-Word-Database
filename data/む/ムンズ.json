        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして床の上へやっと起きかえったかと思うと、寝床の上に丸くなって寝ている猫をむんずと掴まえた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛はまるできちがひのやうに、枝のかげから駆け出してむんずとあぶに食ひついた。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛はまるできちがいのように、葉のかげから飛び出してむんずと蚊に食いつきました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらかげろうの胴中にむんずと噛みつきました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、なおも、こんな事を考えながら、丸の内××省前の銅像のまわりのマロニエの木をよく見定め度い気持で、外套の袖で、バスの窓硝子の曇りを拭っていると、車体はむんずと乗客を揺り上げながら、急角度に曲った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は外国織物と思わるる稍堅い茵の上にむんずと坐った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、王冠をかぶって、王しゃくをかまえて、にくらしい顔で、王さまのいすにじいさんの魔法つかいが、むんずと座をかまえていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば元々私も意見が一致するので、ちよつとでも膝を乗り出すと彼は、忽ち戦国時代の勇士が決死の誓ひを立てるかの如くに亢奮して、「よしや村人の一揆と戦つても、先づ君と僕とがこの提携の上に立つて同志を糾合しようぜ――」　と、胸を叩き相手の肩先をむんずと掴むのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで小判の顔が拝まれますかね――」　出したところをむんずと見舞ったものは、おなじみのむっつり右門が十八番中の一つなる草香流やわらの逆腕の一手です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "にじり寄ってむんずとその手をでも取ったらしい気勢がきこえると共に、あからさまな言葉がはっきりときこえました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようがす、あっしがだんなの代わりに、料ってやりましょう」　飛びかかろうとした伝六のきき腕をむんずと捕えて、どうしたことか、右門が突然ぽろりと栃のような涙を落としながら、やや悲しげにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伝はむんずとマルの尻尾を掴んで、回転のかぢをとつた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、むんずと彼の腕を取った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "むんずとした手で捕まりそうになると、一太は本当にはっとし、目をつぶりそうにこわかった。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人さ見るでねえか」　爺はむんずと腕を組んだ。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、有力者は誰かにむんずとばかり襟髪を掴まれたように感じた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その力強い広袤がわたしをむんずと鷲掴みにして、怖ろしい威力をわたしの魂に反映させているのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とばかりに、村長はむんずとその襟髪を掴んだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さういつて彼は、こつそり片手をうしろへ迴すなり――むんずと悪魔の尻尾を掴んだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、鍛冶屋は、逃げ出さうとする悪魔の尻尾を、むんずと掴んで呶鳴りつけた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」銭占屋が横合からむんずと万年屋の利腕を抑えた。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思った時、もう格子が開き、こちらを向いて家の中にむんずと立ちはだかっているのは、真黒い顔をした警視庁の山口であった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひくい唸り声を絶れ絶れにたてながら、今にもかくれた野性がむんずと起きそうな、カークでさえハッと手をひくような有様だった。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗削りに平げたる樫の頸筋を、太い藤蔓に捲いて、余る一尺に丸味を持たせたのは、両の手にむんずと握る便りである。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "町「あいたゝ／＼」　蟠「さアこれでもか、何うだ／＼」　と無理｜強談、折柄暮方の木蔭よりむっくり黒山の如き大熊が現われ出でゝ、蟠龍軒が振上げた手首をむんずと引ッ掴み、どうと傍に引倒しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自らの笑声のみ妖しく耳にたつことを知つたとき、むんずと組みついた者のために、旅人はすんでに捩ぢ伏せられるところであつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして荒れ狂う猛牛の間へ分け入り、むんずと両獣の角を、右手と左手に掴んで、えいとばかりに引き分けてしまったその剛力。",
              "citation": {
                "source": "越後の闘牛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
