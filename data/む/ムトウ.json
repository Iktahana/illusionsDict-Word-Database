    "definitions": [
      {
        "index": 1,
        "gloss": "without lights",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太い杉の参道はまったくの無灯で長かった。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "くらやみの海面から、いつ、どのような無灯の船がぬっと現れ、行手を横断しないとはかぎらないのであった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから全然無灯で闇の中を電車は走る。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無灯で通っているじゃないか。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき彼は檣のうえから探照灯で洋上をさがしたところ、附近海上に一艘の貨物船らし無灯の船を発見した。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風浪あらし　船腹が青白く光る無灯の怪汽船は、闇にまぎれてどこかへいってしまった。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからボートにのって洋上を漂っていると、そこへあの恐しい無灯の汽船だ。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の硝子窓に蠅がとまつて、いつでもぶむぶむとうなつてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の硝子窓に蠅がとまつて、いつまでもぶむぶむとうなつてゐる。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はほんとうに懐しいように、うむうむとうなずきながら胡弓に耳を傾けていたが、時々苦しそうな咳が続いて、胡弓の声の邪魔をした。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、他所へこんなのを頼むとうるさいから。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぎり沸くいで湯のたぎりしづめむと病人つどひ揉めりその湯を湯を揉むとうたへる唄は病人がいのちをかけしひとすぢの唄上野の草津に來り誰も聞く湯揉の唄を聞けばかなしも　十月十九日　降れば馬を雇つて澤渡温泉まで行かうと決めてゐた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぎり沸くいで湯のたぎりしづめむと病人つどひ揉めりその湯を湯を揉むとうたへる唄は病人がいのちをかけしひとすぢの唄上野の草津に来り誰も聞く湯揉の唄を聞けばかなしも十月十九日。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、長谷部大尉も、ふーむとうならないわけにゆかなかった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがその電文です」「そうか――どれ」　加賀大佐は副長の手から紙片をうけとると、その上に忙しく眼を走らせ、うーむとうなった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　岩濱は、ふむ、ふむとうなづきながら話を聞き、見せられるものを見てゐたが、「いや、じつに結構な計畫です。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此寒いのにビールでもないでせうと守一が云ふと、ビールを燗をして飮むとうまいのだと、一本のビールを土瓶にあけて火鉢へかけた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それをきいて、役人は感心して、ううむとうなりました。",
              "citation": {
                "source": "木曾の一平",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく体をぶつつけて、いきをつめてこらへてゐると、そばで、うーむとうなる声がします。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、分かったでしょう、娘さん」　このことばに、山形警部は、うむとうめいてかえすことばを知らなかった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをするために、そんなことをしてあるのかと、彼はその方にあるいていったが、とちゅうで彼は、うむとうなって立ちどまった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――黄色ノ眼ヨリ」　スミス警部はうーむとうなった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、たいへん真剣な顔になって、一々、ふむふむとうなずきながら、新田先生の話に耳をかたむけた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎船長は、うむとうなって、「用談とは何の事だ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様、えらいことを考えだしたな、ううむ」　さすがの勇猛兵曹長も、若い青江三空曹の考えだしたおどろくべき怪塔占領の計画にはびっくりして、ううむとうなりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「屏風へかけるがよいよ、か、……うむとうとうそこまで行ったか」――で、じっと耳を澄ませた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは夕食の仕度にかかりますから、ほんとうに眠るつもりになってちょうだい」　フサは眠るつもりになったらしく、うむとうなずいた。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが相慕い、たがいに求めあう運命のきずなじゃ――という、思いがけなくも委細を知るらしい越前守忠相のことばに、泰軒は、ううむとうなって忠相を見た眼を盤へおとして、ガッシと腕を組んだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうものをよむとうれしい気がいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら木賃宿だとしても普通ならもう少しはましであろうが、それは伝通院裏という、あまり泊り客もなさそうな場所がらによるのだろう、いかにもさむざむとうらぶれたけしきにみえた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
