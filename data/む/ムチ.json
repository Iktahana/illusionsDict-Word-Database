[
  {
    "uuid": "474bedbb-437a-5d59-afdc-74a8220a3dba",
    "entry": "無知",
    "reading": {
      "primary": "むち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
