[
  {
    "uuid": "08c7e4e8-e506-54b2-ad01-9026d1b9e391",
    "entry": "虫の声",
    "reading": {
      "primary": "むしのこえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
