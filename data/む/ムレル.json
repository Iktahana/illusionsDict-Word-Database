    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to crowd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "將に沒せんとする日は熾なる火の如く、天をば黄金色ならしめ、海をば藍碧色ならしめ、海の上なる群れる島嶼をば淡青なる雲にまがはせたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眞鳥の、左の方遠く海上に群れるを漁夫指して、『鰹か鮪かが押寄せたるなり』といふ。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "今彼處に群れるは、鰯が下なる鰹鮪と、上なる眞鳥との包圍攻撃に遭へるなり』といふ。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　大船へ二十何町かあると同じくらい海岸からも引込んでいるから、私どもの生活は、八月の海辺風物――碧い海、やける砂、その上に拡げられた大きな縞帆のような日除け傘、濃い影を落して群れる派手なベイジング・スウトの人々などという色彩の濃い雰囲気からは全く遠い。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵞鳥が遊ぶ碧い湖、羊の群れる緑の草原、赤い屋根、白い家々。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "将に没せんとする日は熾なる火の如く、天をば黄金色ならしめ、海をば藍碧色ならしめ、海の上なる群れる島嶼をば淡青なる雲にまがはせたり。",
              "citation": {
                "source": "ヴエスヴイオ山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊と獅子が広い高い平原の空間に対して、ただひたすらに怖れて所々に群れる景色は、明るい、実に明るい。",
              "citation": {
                "source": "「壇」の解体",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女、花、波、絹、黄金、また色｜斑らなる石の光、高き橋、春の渓谷、その水晶なす泉のほとりには金髪のニンフの群れる――また人の唯夢にのみ見るを得るもの、またわれわれを取囲む醒めた現実、それ等は凡て彼の心中に浸透して後、初めてその美を得来ったのだ。",
              "citation": {
                "source": "チチアンの死",
                "author": "ホーフマンスタール　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭亭たる松の梢にある飼箱に群れる小鳥の声がするばかりであつた。",
              "citation": {
                "source": "名園の落水",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "同種の奇人や偏執狂たちは互いに群れる傾向があることを知っていたからで、単にチャールズないしアレンが、海外にお相手を――恐らく、オーンの筆跡を見たことがあり、故人の生まれ変わりの振りをしようとする誰かを――見出したのだと信じていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂュウスの寵兒メネラオス、斯くも汝の光る目は、ネストールの子、なほ生きてあるや否やを知らんとし、多くの同志群れる中を普く見渡して、　680忽ち認む全軍の左端にありて勇將の、其同僚を勵まして戰場めがけ進むるを。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行かねえと、仕舞いになるぞ」　そんな話を行く先々、人間の群れる所で、彼は聞いた。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さく群れる学生の姿や、スーツケースを転がしたり、自転車を押す観光客の姿が現れ、夕食用の買い物帰りの人々と、朝、会社へ向かう人々の流れがすれ違う。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "果物をつつきに群れる鳥を追うため、空鉄砲を放つことは、許されているのである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どんな小僧か」　と、血相の恐い男たちが、捜しまわっていたのも一瞬のことで、程なく、編笠すがたや伊達すがたして、灯に群れる虫のように、ぞろぞろと、ぞめきに流れ込んで来た買手どもは、もう紅燈の下に、そんな事件が、半刻前に行われたという噂すら知らなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕は城中の冬木立へ群れる鵙だの雀だのという小禽が、何よりもよい食物と兵に狙われて捕られたため、近頃は鳥も知ってきたか、少しも城内の木には集まって来ない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いさぎよく御首級をさずけ給え」　と呼ばわり呼ばわり、そこの欄の直下へ或いは橋廊下へ攀じのぼって彼の側面から、必死と迫って来る甲冑の敵は、ちょうど此寺のさいかちの木に朝晩群れる鴉のようであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子椅子の下にねむれるひとは、おほいなる家をつくれるひとの子供らか。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「がまんも何もないよ、おれたちがすきでむれるんじゃないんだ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「がまんも何もないよ、おれたちがすきでむれるんぢやないんだ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　このおほきな都會の夜にねむれるものはただ一疋の青い猫のかげだかなしい人類の歴史を語る猫のかげだわれの求めてやまざる幸福の青い影だ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　このおほきな都會の夜にねむれるものはただ一匹の青い猫のかげだかなしい人類の歴史を語る猫のかげだわれらの求めてやまざる幸福の青い影だ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぶきにけむれる岬岬の島かげからふしぎな病院船のかたちが現はれそれが沈沒した錨の纜をずるずると曳いてゐるではないか。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家は、賑やかな事がお好きでございましたから、何かにつけて宴をおひらきなされて、皆の遊びたはむれる様をしんから楽しさうに、にこにこ笑つて眺めて居られます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もなきねむれる都、しじまりの大いなる声ありて、霧のまにまにただよひぬ、ひろごりぬ、黒潮のそのどよみと。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぎようによってはむれるような厭な匂いであるが、生生の気の溢れている青葉の匂いが漂うていて、読書に疲れた頭を休めるには適している晩であったが、なんだか不安で厭で、歩くと左の痃癖のあたりが張るように痛くて歩くのが苦しかった。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには藻のむれるような海岸特有の匂があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一山に寺々を構えた、その一谷を町口へ出はずれの窮路、陋巷といった細小路で、むれるような湿気のかびの一杯に臭う中に、芬と白檀の薫が立った。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊柳にたわむれる風も長閑に、岬の白い灯台のまはりを飛んでゐる鴎の群も、誘蛾灯にあつまる昆虫のやうにちいさく、こんな明るい昼日中から夜の舞踏会を待ち焦れてゐるやうに浮れて見える。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその蛇の首をつかんで穴からずるずるとひき出すと、蛇は二つに裂けた紅い舌を火焔のようにへらへらと吐き出しながら、お絹の痩せた手首へたわむれるように絡みついた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
