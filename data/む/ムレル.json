[
  {
    "uuid": "4610f067-b2cf-5fc0-a4a6-851ee0bf17b9",
    "entry": "群れる",
    "reading": {
      "primary": "むれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
