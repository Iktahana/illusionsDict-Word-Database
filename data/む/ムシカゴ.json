        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少し網が届きかねたがようよう首尾よく捕れたので、腰につけていた虫かごに急いで入れて、包みきれぬ喜びをいだいて森を出た。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のさげていた虫かごを見つけると母親の手を離れてのぞきに来たが、目を丸くして母親のほうへ駆けて行って、袖をぐいぐい引っぱっていると思うと、また虫かごをのぞきに来た。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその時虫かごのふたをあけてかぶと虫を引き出し道ばたの相撲取草を一本抜いて虫の角をしっかり縛った。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はなんだかきまりが悪くなったから、黙ってからになった虫かごを打ちふりながら駆け出したが、うれしいような、惜しいような、かつて覚えない心持ちがした。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫かごにはまだ少し早いが、そのかわり軒端の先には涼しい回りとうろうがつるされて、いずこの縁台も今を繁盛に浮き世話のさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さい虫かごのようなものが一つおいてあった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
