[
  {
    "uuid": "58363231-3bad-5d0f-a04a-d8313c681b44",
    "entry": "向こう",
    "reading": {
      "primary": "むこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "opposite side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向こうところに敵なくして剣の力で信仰と権勢を植え付けて行った半生の歴史はそれほど私の頭に今残っていないが、全盛の頂上から一時に墜落してロシアに逃げ延び、再びわずかな烏合の衆を引き連れてノルウェーへ攻め込むあたりからがなんとなく心にしみている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行ったかと見回すと、はるか向こうの東屋のベンチへ力なさそうにもたれたまま、こっちを見て笑っていた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余も一つ二つ拾って向こうの便所の屋根へ投げると、カラカラところがって向こう側へ落ちる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音が観客の正面の向こうのほうで響いたと思われるのに、ピストルを持った男がずっと横手のほうから現われて来ると思われるのではちょっと理屈に合わないわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの空に花火がぱっと開く。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、ガラス窓の向こうで男女が何か小声で話しているのをこっちから見ているという種類のは、光を透過して音を遮断した場合である。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子供は頭をかしげて向こうを見ていますから考えているのだと私は思って待っていました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一人の子供が夕べごとにさびしい湖水のほとりに立って、両手の指を組み合わして、梟の鳴くまねをすると、湖水の向こうの山の梟がこれに返事をする、これをその童は楽しみにしていましたが、ついに死にまして、静かな墓に葬られ、その霊は自然のふところに返ったというこころを詠じたものであります。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　ある地下食堂で昼食を食っていると、向こう隣の食卓に腰をおろした四十男がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐竜、化石の向こうから。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こう岸には闇よりも濃い樹の闇、山の闇がもくもくと空へ押しのぼっていた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに酒を飲むにしても、どこか川っぷちのレストランみたいなところで、橋の上からだとか向こう岸からだとか見ている人があって飲んでいるのならどんなに楽しいでしょう。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の田舎の家の前を通っている街道に一つ見窄らしい商人宿があって、その二階の手摺の向こうに、よく朝など出立の前の朝餉を食べていたりする旅人の姿が街道から見えるのだった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は金毛の兎が遊んでいるように見える谿向こうの枯萱山が、夜になると黒ぐろとした畏怖に変わった。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手には溪の向こうを夜空を劃って爬虫の背のような尾根が蜿蜒と匍っている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと十時頃溪向こうの山に堰きとめられていた日光が閃々と私の窓を射はじめる。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪の向こう側には杉林が山腹を蔽っている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は谿向こうの尾根へ沈んだところであった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車はやがて谿襞を廻った向こうの道へ姿をあらわした。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主の抱え車じゃあるめえし、ふむ、よけいなおせっかいよ、なあ爺さん、向こうから謂わねえたって、この寒いのに股引きはこっちで穿きてえや、そこがめいめいの内証で穿けねえから、穿けねえのだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして九月上旬にもう一度行ったときに、温泉前の渓流の向こう側の林間軌道を歩いていたらそこの道ばたにこの花がたくさん咲き乱れているのを発見した。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内の渓谷に渡した釣り橋を渡って行くとき向こうから来た浴衣姿の青年の片手にさげていたのも、どうもやはり「千曲川のスケッチ」らしい。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、科学の世界は国境の向こうから文学の世界に話しかける、その話はわれわれにいろいろのことを考えさせる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池を隔てた本館前の広場で盆踊りが行なわれて、それがまさにたけなわなころ、私の二人の子供がベランダの籐椅子に腰かけて、池の向こうの植え込みのすきから見える踊りの輪の運動を注視していた。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダから池の向こうの踊り場を正視していたときに、正面から左方約四十五度の方向で仰角約四十度ぐらいの高さの所を一つの火の玉が水平に飛行したというのである。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この茶わんを、縁側の日向へ持ち出して、日光を湯げにあて、向こう側に黒い布でもおいてすかして見ると、滴の、粒の大きいのはちらちらと目に見えます。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷河の向こう側はモーヴェ・パーという険路で、高山植物が山の間に花をつづり、ところどころに滝があります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏庭の向こう側の窓はもうよその家で、職人が何か細工をしていたようです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとシュエスターが立って行って、頭をパタパタとたたいて向こうむきにすわらせる。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川のむこうにいた女よりさきに菊ちゃんを見て知っていたような気もするのです」「まあ、いい」馬場はそう呟いて微笑んでみせたが、いきなり左手で顔をひたと覆って、嗚咽をはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
