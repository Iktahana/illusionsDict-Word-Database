    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to covet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "尤も、そうすることによって結局は奉公の第一義にかなうことが出来るという自分勝手な考えもありはしたが、とにかく興味の向くことなら何でも構わず貪るように意地汚くかじり散らした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは大膿盆に置かれた肺臟に手をかけながら、貪るものゝやうに死體の頭部に眼をやつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、濱島氏は决して虚名を貪る人でない、此名は彼が求めた名では無いのです、すべて本國政府の任意に定めた事で、軍艦命名式の嚴肅なる順序を經て下されたのが「日の出」の三｜字です。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その覚悟が出来たのちも彼は尚口舌の慾を貪ることを忘れはしなかつたのである。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入満と唸るといえども、常住の寡慾に肖もやらで、慈善の慾は極り無く、貪るばかりに取込みても人に施すにはいまだ足らずと、身を粉にし、骨を折る、賢媛、閨秀の難有さよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慾望をほしいまゝにするなかれ、貪る心を放下せよ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつの日か君帰ります」ANNA CROISSANT-RUST　一群の鴎が丁度足許から立って、鋭い、貪るような声で鳴きながら、忙しく湖水を超えて、よろめくように飛んで行った。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五燭の灯の下にぼんやり照し出される憐れな狼藉の有様は、何か動物が生命を繋ぐことのために僅かなものを必死と食い貪る途中を闖入者のために追い退けられた跡とも見える。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに較べると中背ではあるが異常に強壮な身体を持っている鼈四郎はあらゆる官能慾を貪るに堪えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正常な教養を持つ世間の知識階級に対し、脅威を感ずるが故に、睥睨しようとする職人上りで頭が高い壮年者と青年は自らの孤独な階級に立籠って脅威し来るものを罵る快を貪るには一あって二無き相手だった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の貧乏時代は、茶屋の掛行燈など引受け、がむしやらに雑用稼ぎをして、見られたざまではなかつたのを、この頃はすつかり高くとまり、方外の画料を貪る。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、夫れ持重して而して廉なる者は多く得、軽易にして而して貪る者は多く喪ふ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妲己や褒※のような妖怪くさい恐ろしい美人を譬えに引くのも大袈裟だが、色を貪るという語に縁の有るところがら、楚王が陳を討破って後に夏姫を納れんとした時、申公巫臣が諫めた、「色を貪るを淫と為す、淫を大罰と為す」と云ったのを思い出して、色を貪るのを愚なことだと云いもしたろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んで一歩前に出た署長を制しながら、暫く貪るやうに耳を傾けてゐたソオルはやがてがちやんと受話器を降すと、聲ひそめて、「ヂレツト・ホテルへ急行だ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とフレデリックはその脇に佇んで、微笑しながら暫く妻を見降してゐたが、やがて體をかがめるとその美しい顏をぐいと引き寄せて貪るやうに接吻した。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学にあらざる哲学は吾人の尤も多く敬服する所なり、吾人も亦た詩人哲学者小説家等が妄に真理を貪るを悪む者なり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら実際的の国民なる英人に取りては、兎ても花の下に終日浮かれぞめくの興を貪ることは覚束なしと。",
              "citation": {
                "source": "漫言一則",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "廉恥を棄てて金銭を貪るものと歯するは、その敢てせざる所である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級といい習慣といい社会道徳という、我が作れる縄に縛られ、我が作れる狭き獄室に惰眠を貪る徒輩は、ここにおいて狼狽し、奮激し、あらん限りの手段をもって、血眼になって、我が勇敢なる侵略者を迫害する。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯冷水を貪るならば熱い湯を飮むがよい。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "色に耽り財を貪ること、またいずれかはなはだしき？",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色を貪るを淫となす。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は功利、卑屈な世間の風潮にカブレ、良い加減な幇間的な稽古と取持で弟子の機嫌を取って謝礼を貪る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪るように啜っていると、社長が褌一つの裸で二階から降りて来て、「こない日が射し込んで来よったら、毛利君かなわんやろ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は心に陶が金を貪るのを厭うて絶交しようと思ったが、しかしまたひそかに佳い木をかくしているのが恨めしくもあって、とうとう逢って誚めてやろうと思って扉を叩いた。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪るようにして噛んでみた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく疲れきっていたので、私はこの事がらを十分考えてみることもなく、がつがつと貪るように食ったり飲んだりした。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、一夜中、親爺のその煙草の臭いをむさぼるように嗅いだ。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸入につきものの暴利をむさぼるだけではなかった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、自分の恍惚状態を夢のようにむさぼるばかりだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
