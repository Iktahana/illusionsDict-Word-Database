    "definitions": [
      {
        "index": 1,
        "gloss": "(feeling of) tightness in the chest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
