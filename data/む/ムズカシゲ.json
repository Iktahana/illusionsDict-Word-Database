        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "直行は可難しげに眉を寄せ、唇を引結びて、「何者か知らんて、一向｜心当と謂うては無い。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、気をつけてさり気なく、気難しげに佇んでいる少女の傍に近寄った。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "てれてか眉間へ気難しげに縦皺をきざんだ兄の顔はふと紀久子にいつかの父を思い出させた。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と難しげに頷いたが、「いよいよ困った土産だ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "韃靼人は気難しげに眉を顰めて、片手を振った。",
              "citation": {
                "source": "追放されて",
                "author": "В　ССЫЛКЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭に軍刀なんていう事はたしかに類の無い事です」「樹の枝をな」と坊さんは気難しげに云った、そして兇行の現場の見える窓の方に向いた。",
              "citation": {
                "source": "秘密の庭",
                "author": "THE SECRET GARDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる高士の風でもございましょうか」「そちは、ひどく心酔だな」「楠木家の御兄弟――正成、正季どのも師事され、奥河内の若い郷党輩からも、お師として、慕われておるのを見ても」「山家に住んで、ちと小難しげな書物など飾りたてておれば、田舎武者には、さも、めずらしかろう。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿見は何か、むずかしげな学問的なことを訊ねた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "広瀬、大麻生、明戸などいえる村々が稲田桑圃の間を過ぎて行くうち、日はやや傾きて雨持つ雲のむずかしげに片曇りせる天のさま、そぞろに人をして暑さを厭う暇もなく心忙しく進ましむ。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥からは子供がひょこひょこ出て来たが、父親のむずかしげな顔色を気取ると、じきに顔を赧らめて出て行った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その知らせで母が驚いて起きて来、祖母に挨拶がすむと、「一寸電報でも前もって下さればようございましたのに、いつも不意でお迎えも出ません」とやや気むずかしげにいう。",
              "citation": {
                "source": "百銭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉をつり上げて、気むずかしげに主人が訊いた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶらぶらと歩いている連中も気むずかしげに巨大なビルディングの下で、小さくごみっぽく見える。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの小座敷でひろげた花莚の上へ、気むずかしげなのろい動作で、瑛子が帯止めを解きすて、帯あげをほどき、帯をたぐめて置いている。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を大きくして、「どうで――ぬくうなったで安気なやろ」　庄平は、猫背になって首を前へつき出し、造作の大きな顔の中で眼玉を気むずかしげに左右に動かしている。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　私はその老人が何も言わずに気むずかしげに仕事をしつづけているのに気がねしながら、縁側に倚りかかって、緒方の出してきた袋の中から自分のもらうベイを選んでいる間も、絶えず隣りの家に気をとられていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお進んではこの精神が文学にもなり科学にもなりまたは哲学にもなるので、ちょっと見るとはなはだむずかしげなものも皆道楽の発現に過ぎないのであります。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いい加減の年だのにまるで桃色の靴下）始めてでまだ馴れず、気むずかしげな顔で、ゆっくり部屋掃除をして行った。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七面鳥の連隊は庭で鳴きあるき、ほろほろ鳥は、その鳴き声にぷりぷりして、不機嫌な女房連のように気むずかしげに不満の叫びをあげていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "……世間の事だって、人間の身体にしたって、へえ、そんな小むずかしげな物であろかい。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここへよって行くって――誰が案内するんだい」　電話をかけて帰って来た伸子の顔を椅子の上から素子が見あげて、気むずかしげにいった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気むずかしげに角ばった老齢の大作家トルストイ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の夕刻、おきまりの講義に来たとき、蜂谷良作は、いつもよりいくらか自分自身に対して気むずかしげな表情だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、せいぜい高校生ていどの年令のようで、私たちの想像していた気むずかしげなオールド・ミスとは、まるっきりイメージが違っていた。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はアリョーシャのはいって来るのを、気むずかしげに眺めた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと氣むずかしげな、のろくさした態度を身につけてはいたものの、彼の物腰はいまだに濶達で、きびきびしているばかりか、優美でさえあった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時々じろりと上目を使って、氣むずかしげな狡るそうな薄笑いを浮かべて、相手を見やった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『これはつまり、おれがひどい病気にかかっているせいだ』とうとう彼は気むずかしげに断定した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やっと思い出した……」長い気むずかしげな物思いの後に、ラスコーリニコフはこう言った。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなら、もっと気をつけなくちゃだめだよ」ラズーミヒンは気むずかしげに注意した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
