    "definitions": [
      {
        "index": 1,
        "gloss": "to choke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いったいに、この季節には、べとべと、噎せるほどの体臭がある。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い、新しい花穂の聚団が暗い裂けた葉の陰影から噎せる如に光る。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの芽立に噎せる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもみなお前のお蔭だ、よく来て呉れた、難有かつたと、しみじみ、私は煙に噎せる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "噎せる程強いシトロンの香の立ちこめる熱い空気の中で、会衆は静かに頭を垂れた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも噎せるような焼死体の異臭に鼻を撲たれてペッペッと唾液を吐いた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻はあっても見る限り、咲く花も無い広い野の、　埃に噎せるばかりでは、却て邪魔にしかならぬ、　糞の役にも立たないと、これも千切って打ち付けた。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で、取散かった物を片付けますと、御部屋の内は煙草の烟ですこし噎せる位。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のように特別に暑くなった時でなくても、執務時間がやや進んでから、便所に行った帰りに、廊下から這入ると、悪い烟草の匂と汗の香とで噎せるような心持がする。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこの時、あなたの一杯に毛の生えた脚の、女らしい体臭に噎せると、ぼくはぞっとしていたたまれず、「熊本さんは肥りましたね」とかなんとか、あなたの萎れを気づかっていたつい最前の自分も忘れ、お座なり文句もそこそこに、立ちあがると逃げだしてしまいました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "噎せるような匂いに包まれた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噎せるような空気のなかに、もとの藩主はもとの家臣を忍耐づよく眺めていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　日は高く上つて、噎せるやうな温かい空気が、時々、風の工合で河原の方からやつて来た。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに空はあくまで晴れ、雲切れ一つなく、彼等の歩いてゐる田舎路は右手にきらめく河を見下して、白くはつきりと浮び上り、ふり注ぐ日ざしと温かさで噎せるほどだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い、噎せるような煙は煤けた台所の壁から高い草屋根の裏を這って、炉辺の方へ遠慮なく侵入して行った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻と、口を手拭でしっかと結えてもムーンと鼻の穴から、頭へ突きぬけるような臭気が、噎せるようだった。",
              "citation": {
                "source": "工場新聞",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "公爵夫人でさへも、坊ッちやんと殆んど交る／″＼嚏をして、噎せる苦しさに互に頻切なしに泣いたり喚いたりして居ました。",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子は噎せるし、お袋らはじける。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ああ、丁字でございますね」　窓へ寄って見ると、早春の暖かい夜気が面をなで、噎せるほど丁字の花の香が匂って来た。",
              "citation": {
                "source": "彩虹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そのとき茶席へ通ずる猿戸が閉るのを彼は見た）ゆきをはそこに小掻巻を掛け、箱枕をして横になっていたが、その部屋は女の躰臭と香料との濃厚な匂いで、噎せるように感じられた。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広さは六帖、夜具を隠すように枕屏風が立ててあり、香のかおりが噎せるほど強く匂っていた。",
              "citation": {
                "source": "古今集巻之五",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また村の人たちはこの家を菊屋敷と呼んでいるが、それも菊のみごとさを云うのではなく、亡き主人の大切にする気持から出たものであった、……どの株も今が咲きざかりで、あたりの空気は噎せるほども高雅な香りに満ちていた。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日の黄昏で、座敷の中はすでに暗く、香を※くかおりが噎せるほど強く匂っていた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの心の皮膚はかなり鋭い冷湿の触感を感じ、われわれの心の鼻はかびや煤の臭気にむせる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な、蟇のような靴をぬいで、むせる足を空気にあてるひまもなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちを見るといきなり駆けよって来て、三人を胸のところに抱きしめて、顔をぼくたちの顔にすりつけてむせるように泣きはじめた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついてみると、小さな部屋の中はむせるような瓦斯でいっぱいになっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼬が覘くやうな、鼠が匍匐つたやうな、切つて填めた菱の實が、ト、べつかつこをして、ぺろりと黒い舌を吐くやうな、いや、念の入つた、雜多な隙間、破れ穴が、寒さにきり／＼と齒を噛んで、呼吸を詰めて、うむと堪へて凍着くが、古家の煤にむせると、時々遣切れなく成つて、潛めた嚔、ハツと噴出しさうで不氣味な眞夜中。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の音で、寂寞する、と雲にむせるように息が詰った。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真珠の簾を垂れた窓からは薫物や香油の匂いがむせるようにもれてきた。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
