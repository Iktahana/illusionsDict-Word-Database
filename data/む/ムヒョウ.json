          "literary": [
            {
              "text": "実際その天幕は無標であった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い眼で、しげしげと無標の天幕を瞰渡した。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
