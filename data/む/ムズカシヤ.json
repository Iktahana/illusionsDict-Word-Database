[
  {
    "uuid": "7b4a7e6c-8347-5429-9366-b94124988070",
    "entry": "むずかし屋",
    "reading": {
      "primary": "むずかしや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
