        "examples": {
          "standard": [
            {
              "text": "法華経の開経とされる無量義経を読んだが、難解な内容だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "無量義経は、無限の教えを説くという点で重要な経典だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "仏教学者は、無量義経の思想について深く研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大覚世尊（釈迦）が年七十二の時、法機｜漸く熟して法華｜爾前に於ける権実両教の起尽を明かにするため無量義経を説き「四十余年｜未顕真実」と喝破して静かに禅定に入つた話は仏者の間に有名であり、わが弘法大師は現にまだ禅定のうちにありとさへ或る一部の人々に信ぜられて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無量義経」によれば、「四十余ニハ未だ真実ヲ顕ハサズ」とある。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
