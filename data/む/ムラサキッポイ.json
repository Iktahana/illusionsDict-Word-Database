        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乞食が食いものにかけたらそりゃ誰でも凄くなるぜ」　花田が撫で下げている紫っぽい翼に啓司は手を与えながら、「そんなにうまいかね、これがね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋全体に紫っぽい光線が差し込んで前幕と同じ日の夕方近くの様子。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫っぽい細い煙りは絶えず立ちのぼって王の頭の上に舞う。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "譲原さんというと、わたしにはＮＨＫで会ったとき、あの人の着ていた紫っぽいちりめんの羽織を想い出す。",
              "citation": {
                "source": "譲原昌子さんについて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青草に横わって池を眺めると、今は樹間をこめる紫っぽい夕暮の陰翳まで漣とともにひろがり、白鳥ばかり真白に、白樺の投影の裡に伸びた。",
              "citation": {
                "source": "わが五月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの戸をあけたら、医員の白い上っぱりも一時に紫っぽい色に変った――すっかり窓が着色ガラスで張られているのだ。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫っぽい着物がぱっと目に映えて、硝子越し、小松の生えた丘に浮かんで花が咲いたように見えた。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラチナの細い上へ、大きく紫っぽいダイヤが、総彫刻の金指輪のとなりにあって、そぐわない手の上で、迷惑そうに光っていた。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかなと思って私はつくづく眺めて見たが、遠方はなるほど多少紫っぽいが、人間の髪の毛や、近くの樹木の幹の影などは皆が、素直に紫に見る如く紫では決してなかった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉藻の前の伝説などからは紫っぽい暗示をうけますが、わたくしの知る那須野の野の風は白うございます。",
              "citation": {
                "source": "平塚明子（らいてう）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサ子は紫っぽい事務服を着てタイプライタアをうっている。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井からさす燈火の工合で、瑛子の手が動くたびに、右の中指から大きいダイヤモンドの、厚みのある、重い、焔のような紫っぽい閃きが発した。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきの小窓にかかっている紫っぽいところに茶の細い格子のある毛織地のカーテンと原稿紙の字とは大変美しく釣合って、稲子にさすがだといってほめられました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの様に紫っぽいお羽織を召していらっしった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、名刺に自分の写真をつけて居る女の人らし（エスペラントを話す電信局に働いて居る女、紫っぽい帽子から、黒いベールを下げて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○廊下をスエの室に向い歩いて行ったら向うから赤紫っぽいコートを着て来る女のリンカク（肩の辺）いかにも久に似ていたのでそう思ったら、片春であった。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階を下りて一寸茶の間をのぞきかけたら、ガラス戸の外に紫っぽい色が映っている。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "立木の陰、家の陰などは濃くたちこめた靄そのままの紫っぽい色がただようて、枯木の梢の太陽が四方に放散する。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころきれいなのは水きわの崖などに、ショウジョウバカマという山の草が紫っぽいあかい花をつけ、又カタクリのかわいい紫の花が、厚手の葉にかこまれて一草一花、谷地にさき、時として足のふみ場もないほどの群落をなして、みごとなこともある。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子はなく、基台の上には本や書類や筆記用具らしきものが散乱していた――紫っぽい金属でできた奇異な形の壺や先端に色がついた棒だ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらは姉さんなんだそうです、浪子さん」　その娘は、紫っぽい絹服をつけていて、内気そうに伸子たちと挨拶した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫っぽい灰色の厚い唇が、黒人のフランス語をほとばしらせた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今いねと肩を組んでいる八重は、紫っぽい大柄の着物を着、娘らしく桃色に頬を染めてはいるが八重は二十四になっている。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
