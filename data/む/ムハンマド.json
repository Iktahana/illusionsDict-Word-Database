        "examples": {
          "standard": [
            {
              "text": "イスラム教の預言者ムハンマドは、イスラム教を創始した人物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ムハンマドの教えは、世界中の人々に影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はイスラム文化について学ぶため、ムハンマドの生涯に関する本を読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "野蛮人によってローマ帝国が侵入されるようになった頃、東ではムハンマドが生まれた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いでムハンマドの後継者たちである最初のカリフたちに率いられアラビアの軍隊は国境を越え始めた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムハンマドがメッカからメディナに移ったヒジュラ（＊ヘジラ：回教歴の起点）から110年以内のことである。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "西のムハンマド科学の首都がキリスト教徒によって奪い取られた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の不足はアラビアの部族たちをムハンマドおよびその後継者の指導のもとに連合させ征服の原動力となった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "571年にムハンマドがメッカに生まれた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
