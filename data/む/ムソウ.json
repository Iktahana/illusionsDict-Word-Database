[
  {
    "uuid": "83ac8c17-e0b0-52b0-b443-7c30fbdb4307",
    "entry": "夢想",
    "reading": {
      "primary": "むそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
