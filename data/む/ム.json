  {
    "uuid": "fbfb3d60-29ca-538e-ba57-759ca768d38a",
    "entry": "む",
    "reading": {
      "primary": "む",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家族旅行と木箱との過剰は最早、世界をして理知にて笑はしめ、感情にて判断せしむるなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のもと林の中に、たゆけくも　仰ざまに眼をつむり、白き雲、汝が胸の上を流れもゆけば、　はてもなき平和の、汝がものとなるにあらずや",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "５向ふに、水車が、見えてゐます、　　苔むした、小屋の傍、ではもう、此処からお帰りなさい、お帰りなさい　　僕は一人で、行けます、行けます、僕は、何を云つてるのでせう　　いいえ、僕とて文明人らしくもつと、他の話も、すれば出来た　　いいえ、やつぱり、出来ません出来ません。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "造花作りは花屋を恨む、さて、花は造花程口がきけない。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西部劇通信」だの「ゼーロン」だのを書いた昭和五年の頃は、彼の返り咲きの観があつたし、評判がよかつたのであるが、あの頃のものよりも、それから暫く後に書いた、水車小屋の壁に凭れて月の明りで手紙を読む短篇なぞの方が、遙かに牧野さんらしいものであると思はれる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなむしろ邪魔されて欲しいくらゐのところへ、この挨拶は、一寸ツカないものであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺を読むと、しきりにまたガツテンガツテンをしながら私の顔をみて、それからタモトに入れたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはこれら彼の作品が、大正十三年頃、つまり「春と修羅」が出た頃に認められなかつたといふことは、むしろ不思議である。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには概念を出来るだけ遠ざけて、なるべく生の印象、新鮮な現識を、それが頭に浮ぶまゝを、――つまり書いてゐる時その時の命の流れをも、むげに退けてはならないのでした。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "海はなが身の鏡にて、はてなき浪の蕩揺に、汝はなが魂打眺む　海は汝が身の鏡にて、と云はれるとなんだか罪でも犯した気持になる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、猫の瞳孔が紋むやうに、海は急劇に曇つて来て、今にも時化でもやつて来さうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなき浪の蕩揺に、汝はなが魂打眺む……「なーるほど…」と思ふのは、恐らくボオドレエルが私自身より意識的であることに気が付くからである。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれは喜ぶなが影の、すがたの海に跳び入りて、眼に腕にかい抱き、それな固有のざはめきに、なれがこゝろはなごむなり、抑へがたなきはた荒き、浪の歎きのかの響き　もはや眺めてはゐられなくなつた、跳び込んで、眼に腕にかい抱き、それな固有のざわめきに、なれがこころはなごむのだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、その作品はうまく行つた時もまづく行つた時も、決して読む者をして厭憎を抱かしめることがない。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等利根川の岸邊に立てば、さらさらと洋紙は水にすべり落ち、いろあかき魚のひとむれ、しねりつつ友が手に泳ぐを見たり。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よやわが十指は晶結し背にくりいむは瀧とながるるごとししきりに掌をもつて金屬の女を研ぎ胴體をもつてちひさなる十字を追へば樹木はいつさいに※轉し都は左にはげしく傾倒す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たづきも知らに、わが喰むむぎの蒼さより、あはれはるばる、み空をながれ汽車は行く。",
              "citation": {
                "source": "旅上",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、するどき薄刃をさげ、左手をもつて敵手に揖す、はや東雲あくる楢の林に、小鳥うたうたひ、きよらにわれの血はながれ、ましろき朝餉をうみなむとす。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いまするどく鋭刃を合せ、手はしろがねとなり、われの額きずつき、劍術は青らみつひにらじうむとなる。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに哀しく、きのふきみのくちびる吸ひてきずつけ、かへれば琥珀の石もて魚をかこひ、かの風景をして水盤に泳がしむるの日、遠望の魚鳥ゆゑなきに消え、塔をきづくの額は研がれて、はや秋は晶玉の死を窓にかけたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ空にまぼろしの島うかびて、樹木いつさいに峯にかがやき、憂愁の瀑ながれもやまず、われけふのおとろへし手を伸べ、しきりに齒がみをなし、光る無禮の風景をにくむ。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよわが光は空にあり、空は白金、ふきあげのみづちりこぼれて、わが賽は魚となり、卓上の手はみどりをくむ。",
              "citation": {
                "source": "純銀の賽",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
