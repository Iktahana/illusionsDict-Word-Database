        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この謙斎坊さんは、座敷は暖かだし、精を張って、つかまったから、十月の末だと云うのに、むき身｜絞の襦袢、大肌脱になっていて、綿八丈の襟の左右へ開けた毛だらけの胸の下から、紐のついた大蝦蟇口を溢出させて、揉んでいる。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "達引かれたむき身をじわじわ、とやって、（阿魔、やい、注いでくりゃ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとこは、秩父銘仙の両肌をぬいで、友禅の胴へむき身絞りの袖をつけた、派手な襦袢を出している。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの採りたての栄螺を岩の上に叩きつけて割り、むき身を潮水で洗って生のまま喰べると、柔かく甘味があってうまかった。",
              "citation": {
                "source": "栄螺",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "できたお粥の中に水を切ったかきのむき身を入れ、五分ぐらいたって、火からおろし、せりがあれば微塵に切って振りかければ、それでかき雑炊は完成したわけである。",
              "citation": {
                "source": "夜寒に火を囲んで懐しい雑炊",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳を切るやうな外の寒さを思ふと、つい億劫になつて、三四日行かずにゐたからと、お芳は夜のことゝてむきみやさんを着たまゝ手拭を持つて表に出た。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃東京に出る人は、『川口に行けば、むきみ汁が食へる』かう言つて誰も楽しみにして来た。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家族の人々は船から上つて、暗いランプのついた狭い汚い間で、兼ねて噂に聞いて居る生魚とむきみ汁とを食つた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、樹明君を通して敬治君から呼び出し、すぐ出かける、第一窟から宿直室へ、――酒、むきみ貝、樹、敬、山の三重奏、ぢやない、キミチヤンを加へて四重奏。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に、初めて来た若い魚屋が置いて行ったバカのむきみに家中の者があたって、吐きくだしをする。",
              "citation": {
                "source": "芝、麻布",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むきみやの老爺で、店はお喋りな上さんに任せてある、定七と云ふ、今年五十六になる。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十銭、ひどいひどい麦うどんのまざり飯少々にむきみがのっている。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "襷がけ姉さま冠りの女房何やら貝のむきみを燒きて賣りゐたり。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アサリのむきみ」、「ゴカイ」、「サナギ」、「新粉」、「カボチャ」、「たにし」なども使う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
