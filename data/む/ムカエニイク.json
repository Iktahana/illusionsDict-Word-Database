    "definitions": [
      {
        "index": 1,
        "gloss": "to go to meet (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今分れても首尾さえつけば、直ぐこちらから迎えに行く。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮の花街に残して来たというお千鶴のことをきけば、どうにも不憫で、ここでお前に一儲けさせてやれば、お前もお千鶴を迎えに行くだろう――という気持は無論あった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしびれを切らせて、彼が降りる筈の駅まで迎えに行くと、半時間ほどして、真っ青な顔でやって来た。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時のボーが鳴ったら俺が迎えに行く。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宮様のほうから、にわかに明日迎えに行くと言っておよこしになりましたので、取り込んでおります。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざとわからなくするのですか」　と言い切らぬうちに、もう女房たちが起き出して女御を迎えに行く者、あちらから下がって来る者などが廊下を通るので、落ち着いていられずに扇だけをあとのしるしに取り替えて源氏はその室を出てしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもわたしとしてはそんな結果も考えてみてからお頼みするんでしたのに……」　こういう押し問答の末に岡はとうとう愛子の迎えに行く事になってしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、実は妻が行っているのを迎えに行くのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ女がひとりいるはずだが、おいでがなくば迎えに行くぞ」「出ますよ、出ますよ、どうせ一度は納めなくっちゃならねえお年貢ですからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、少し……」と言って、「昨日は帰りは遅かったですか」「いいえ、お友達を新橋に迎えに行くんだって、四時過に出かけて、八時頃に帰って来ましたよ」　時雄の顔を見て、「どうかしたのですの？",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど夜ひとり若い女を出して遣る訳に行かぬので、新橋へ迎えに行くことは許さなかった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新七から来た手紙には浦和まで母を迎えに行くとあって、ともかくもお三輪は伜の来るのを待つことにしていた。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今、庸三は別にそれを当てにしているわけではなかったけれど、葉子と別れるには、そうした遊び相手のできた今が時機だという気もしていたので、葉子を迎えに行くのを怠けようとして、そのまま蚊帳のなかへ入って、疲れた体を横たえた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根　（懸命に）ほんとに家族を迎えに行くんです。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちも同じ思いでひと月も前から噂をし、その日になると私も姉妹も皆そろって、店の者が提灯を持って、村境から一里あまりも迎えに行くのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気の毒だからな、これから遺骨を迎えに行くときいては見捨ててはおけない」と彼は独言を云った。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が直ぐに迎えに行く。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミツ子を迎えに行く金も送る金も出来る見当はつかない。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母さんや叔父さんや、みんなで迎えに行くよ。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそこへ迎えに行く」　という。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻、父上の迎えに行く道に、牛込まで送って貰う。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれから先、どんな目に遭おうとも、黙って我慢していて、後にわれわれが迎えに行くまで待っているのだ、いいか」　地上におろされる？",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事を知って、菜穂子が玄関まで迎えに行くと、丁度其処では一人の若い患者が他の患者や看護婦に見送られながら退院して行くところだった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人兄弟なのだが、その真ん中の子が村の小学校からまだ帰らぬので峠の下まで迎えに行くのだと言っていた。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日出迎えに行くのが億劫で、一度、卵のからに、墨で顔をかき、五つ並べて玄関に置いていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲はその翌日から、瑞巌寺へ日参して絵を描くことになったのは幸い――そうしてその夕暮、お松は絵の先生を迎えに行くふりをして、臥竜梅のうつろの使命の第一日を首尾よく果しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月十三日の夢に、来る十五日｜午の刻には迎えに行くといって法然が告げる夢を見て、こんどこそはといって喜びの涙を流した。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリヂット　　マイケル、お前が迎えに行くのはこの人の友だちじゃないよ、お前はここの家へ来ようとする娘を迎えに行かなくっちゃならないよ。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでお出かけ……こちらが先に着いていないとまずいから、約束の時間より早いけど、かまわず迎えに行くと、木津さん、ひょんな顔をしていたけど、それでもすぐ出てきたわ……ええ、そう。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今から清助さんに頼んで置くが、わたしも中津川まで岩倉様のお迎えに行くつもりだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
