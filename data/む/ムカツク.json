    "definitions": [
      {
        "index": 1,
        "gloss": "to feel irritated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ジロリと、進藤等の方一睨して又群衆に向って、Ｔ「むかつく奴　居ないのか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石に胸もとがむかつくらしく白いハンケチを鼻にあてながら酸味の荒い葡萄酒を啜って居たベッシェール夫人も、少し慣れて来たと見えて、思い切ってハンケチをとった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒のめば胸のむかつく癖を知りつつ。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "評論家には、このような謂わば「半可通」が多いので、胸がむかつく。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吸へば滓でも殘りさうな、胸のむかつく、腐つた溝水のやうな空氣だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚が重い、けだるい、胸がむかつく。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、こうやって、制し難くこみあげて来る苛立たしいような、腹立たしいような、泣くに泣かれずむかつく激情は何だろう。",
              "citation": {
                "source": "文字のある紙片",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「流されたツラン人の血は」という一言をきくと、ルスタムは、むかつく嫌な衝動を感じた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつたこの間まで儂もよく知つてゐるピイピイの小僧子がひよつくり儂に声をかけて云ふことには、この頃はお蔭で大きな商売やつてます、何しろ月五千円からかかりますつてな、笑はしやあがるが、まあまあ人間万事からくり一つさ」　その赭ら顔のむかつくやうな表情の男を、彼は茫然と傍から眺めてゐた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一間ばかりの所を一朝かかって居去って、旧の処へ辛うじて辿着きは着いたが、さて新鮮の空気を呼吸し得たは束の間、尤も形の徐々壊出した死骸を六歩と離れぬ所で新鮮の空気の沙汰も可笑しいかも知れぬが――束の間で、風が変って今度は正面に此方へ吹付ける、その臭さに胸がむかつく。",
              "citation": {
                "source": "四日間",
                "author": "ガールシン",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「あら皮」より　エミールの言p.52「僕には　まるで汽車の線路のように坦々たるわれらが文明という奴の青白き生活が胸のむかつくほど堪らないんだ！",
              "citation": {
                "source": "バルザック",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸のむかつくのも癒りそうじゃない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙にがさがさな声を出したりいやに光る眼をもって居たり、あれを見ると私はむかつく様になってしまいます。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸でもむかつくんですか。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸がむかつくようだ。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸がむかつくようなら、もっと酒でも飲め。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は例の男を一目見た時からむかつくほど嫌いでした。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、窓から身を投げるわよ」――とカテリーナ・リヴォーヴナは、名状すべからざる恐怖の、むかつくような厭らしい魔力が、ぐいぐい上から伸しかかってくるのを感じながら、そう言い放つと、さっと窓かまちに片手をかけた。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいや、大阪の落語家がですがな、ほんまにほんまに話せん奴らばかりで俺らむかつくことばかりや。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "小文枝没して数年の今日この頃、その得意とせる「三十石」レコードを聞けば、冒頭、船頭のぼやきわめける一節に曰く、「この頃は岡蒸気にばかり、我も我もと乗りゃあがってこつとらは風呂屋の煙突を見たかてむかつくのや。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今まで何の気もなしに眺めていた彼等の顔つきが、胸のむかつくほど憎らしくなった。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が地を離れます瞬間に、何者かが顔をすり寄せたのでございましょう、むかつくような酒気が鼻をついたのを覚えているだけでございます。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が地を離れます瞬間に、何者かが顔をすり寄せたのでございませう、むかつくやうな酒気が鼻をついたのを覚えてゐるだけでございます。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランシスはむかつく思ひをしながらその一片を口にした。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時にまた、胸のむかつくやうな、あくどい冷笑があつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "（全）それが結論　それでもむかつくのなら　　　自分の首を切ればどう？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが結論　それでもむかつくのなら　　　自分の首を切ればどう？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚のむかつくようなカンバスにはビーコン・ヒルの大きな断面図が描かれているようだった。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆がしわがれ声で胸のむかつく応唱を唱える間、牙のある毛皮野郎はクスクス笑いながら未知の儀式の続きを待っていた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
