  {
    "uuid": "0eab8cde-dca4-56a8-9d19-014cd5810731",
    "entry": "無冠",
    "reading": {
      "primary": "むかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "uncrowned",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無冠の太夫……私共のような学問の無いものにゃ勤まりまっせん。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅虫にいでゆあるよしなれど、みちなかなればいらずありき、途中帽子を失いたれど購うべき余裕なければ、洋服には「うつり」あしけれど手拭にて頬冠りしけるに、犬の吠ゆること甚しければ自ら無冠の太夫と洒落ぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十餘年間支那に居つたスミスといふ米國の宣教師は、曾て支那の教師は無冠の帝王であると評したことがある。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その「無冠の帝王」説を回顧するときは、記者自身大なる誇を感ぜざるを得ない。",
              "citation": {
                "source": "科学的新聞記者",
                "author": "桐生悠々",
                "note": "青空文庫"
              }
            },
            {
              "text": "無位無冠でも一人前の独立した人間だ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今年幾歳になるか知らぬが、十六の時から詩を作り、二十の頃初めて「無冠の帝王」といふ戯曲を書いた。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無冠の帝王」は千九百六年に上演されてゐる。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは実に無冠の王なりき。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "二氏のごときは実に宇内の大恩人にして無冠の皇帝といわざるべからず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、実際この作品で \"petit prince\" に付くのは定冠詞のときもあれば、不定冠詞になることもあり、また無冠詞にもなります。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯は實に無冠の外務大臣として外人と應接するものにあらずや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯は実に無冠の外務大臣として外人と応接するものにあらずや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた美しさや才気のある娘は、映画スターやギブスンガール（米国の美術家ギブスンの描いた、理想的なアメリカ女）の典型でなくても、一種の無冠の女王になれる。",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "故時衣横幅、結束相連而無縫、頭亦無冠、但垂髮於兩耳上。",
              "citation": {
                "source": "隋書倭國傳",
                "author": "魏徴",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の木鐸、無冠の帝王という言葉が流行したのもこの頃で、それ等の卒業生の数が増大するにつれて、政権からはなれた大隈に対する民間の人気はいよいよ抜くべからざるものになってきた。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このわしが、役目にむかんというのか。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝死後、頼家、実朝が相次いで非命に斃れ、鎌倉幕府の命運｜将に傾むかんとするが如き情勢を示した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬ほどもあろうと思われるまっくろな黒ねこが、女の首を、いや、首ではない、女の髪の毛を、それも島田に結ったままの髪の毛を、あんぐりと、その口にくわえながら、牙をむかんばかりのものすごい形相で、らんらんと両眼を光らしていたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　牙をむかんばかりにしてほえたてている伝六の横から、名人は射すくめるような目をむいて、じっとお駒の顔をにらみすえました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをやろふと思へバ先つねのシンゴンしうのよむかんをんきよふイツカヲしうのよむあみだきよふ、これハちとふしがありてむかしけれど、どこの国ももんとがはやり申候あいだ、ぜひよまねバいかんぞよ。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはやはり、この島がアメリカ大陸に、近いと信ずる、チリー、もしくはペリコウにおもむかんとして、ホルン岬をすぐるところの汽船はきっと、航路をこの島の東方にとって、この沖をすぎなければならないと思うのだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "×玉葱の香を嗅がせても青い蛙はむかんかく。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君らに売りつけてやろうというのは杉材だが、これはオレの今やっとる仕事にむかん。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百万円つんだとて、気のむかん時には、してはやらぬ。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余答ていふ、銕炮を以てするは論なし、香餌を以てするは、かれ人の欺くを知れども慾を捨て慎む事あたはず、それとは知りながらこれを喰ひて反て人をあざむかんとして捕へらるゝならんか。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、かしこい泥棒は、そのだれもふりむかんようなところへ、もっともたいせつなものをかくしておく。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
