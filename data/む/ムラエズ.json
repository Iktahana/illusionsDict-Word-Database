        "examples": {
          "standard": [
            {
              "text": "古文書蔵から、江戸時代中期に描かれた鮮やかな村絵図が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史民俗資料館で、当時の境界争いの証拠となった村絵図を閲覧した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "村絵図を詳しく読み解くと、当時の水利システムの工夫が見えてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明治初年の村絵図作成の際なども同じであるが、地名の必要はたいていに一時にどっと現われて来る。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "村絵図はあまりに大き過ぎるところから、複本を切絵図として出し入れに便にし、今でも役場では盛んにこれを使用している。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年肥後の天草下島の大江村において古い村絵図を見たことがある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
