    "definitions": [
      {
        "index": 1,
        "gloss": "being angry (suddenly)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
