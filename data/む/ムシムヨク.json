        "examples": {
          "standard": [
            {
              "text": "彼は困っている人を助けるために、無私無欲で活動している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高僧は無私無欲の精神で修行に励み、悟りを開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "無私無欲な生き方は、多くの人から尊敬される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "芸術のうちに快楽の道具をしか求めていないような著作家らが、無私無欲な宗教の牧師らしいふりを装うのを見るくらい、彼の気色を害するものはなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、それが全然見もしらぬ人であっても無私無欲な態度をとりたいと希う。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
