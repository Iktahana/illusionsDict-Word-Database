    "definitions": [
      {
        "index": 1,
        "gloss": "to come to meet (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "途中まで来ると下男が迎えに来るのに逢いましたが、家に帰ると叔母と母とに叱られて、籠を井戸ばたに投げ出したまま、衣服を着更えすぐ物置のような二階の一室に入り小さくなって、源平盛衰記の古本を出して画を見たものです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その失敗者が同じ失敗者のあなたをお迎えに来るなんて妙なわけですが、おかあさまがお気の毒なので、お頼みをそのまま引受けてお迎えに参りました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朝、お迎えに来るわ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、庄亮の主宰する橄欖社の小樽支部の人たちや、此処で出している『原始林』の同人たちが五、六人で迎えに来る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の食事時にはこの娘が駒下駄の音をさせて迎えに来る。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし私が帰って来たら迎えに来るように云いつけてあったのです。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はあそこに行っていて、僕が帰りでもしたら迎えに来るよう言いつけてあったのです。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの座敷へ抱いて行って女をおろして、それから襖子をしめて、「夜明けにお迎えに来るがいい」　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたことに、彼らは同情してくれて、早朝三時に私を迎えに来るという手筈が整いました。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして母さんや今のお父さんの言うことをよくきいて温和しく待っていておくれ、そしたらお父さんが迎えに来る。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと迎えに来る……」　父は歩くのをやめていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕もあなたのこうして帰られるとき、出迎えに来るんだったなア。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて迎えに来るクル、クルリと。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "里の方から迎えに来るのを。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずかにそれをぬきとり、ひろ子はそれをいじりながら、夕方子供の迎えに来る親たちで、そのまま会合を持つ方針を立てた。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間に評判を立てて置いて、迎えに来るのを待っている！",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕も出席するようだったら、君を迎えに来るから、「いやとにかく僕は出席したくないから、そうしないでくれたまえ」と、私は言った。",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヴジー先生が或る日の午後遅く父を診に来て、母の出したちょっとした夕食をとり、「ベンボー屋」には厩舎がなかったので、村から馬が迎えに来るまで一服やろうと談話室へ入って行った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥に大食堂があって、卓子の準備が出来るとボーイさんが広間まで迎えに来る。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいお医者さまを連れて、お迎えに来るまでぜひ生きていて下さーい」　進少年は窓から、動く大地に祈った。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一娘は忿って食事をしないで、毎日寝ていたが、婿が迎えに来る前晩になって、不意に起きて、鏡を見て化粧をした。",
              "citation": {
                "source": "封三娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日は、私を海岸の散歩に誘い、汀をピシャピシャ歩くほど気持のよいものはない、明日夕方の五時に迎えに来るから、と、私が何度イヤだと云っても、二人のカケアイ漫才で、そのシツコサたらない。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかえ、わたしはこれから甲府へ行って、お前を引取るような家を探して直ぐにまた迎えに来るから、それまで一人で待っておいで。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "心得て、ボートが迎えに来る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尾張領分の村々からは、人足が二千人も出て、福島詰め野尻詰めで殿様を迎えに来ると言いますから、継立てにはそう困りますまいが。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵らはその入り口のところで、迎えに来る下男の佐吉にもあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに彼が唯一の保護者とも申すべき称徳天皇崩御後までも、彼は自衛の道を講ずる事なく、晏然陵下に廬を結んでこれに仕え奉り、今に諸臣が皇嗣として自分を迎えに来るであろうかと、その僥倖を冀うてボンヤリしていたというに至っては、いかに彼が時勢に暗かったとは言え、むしろ滑稽千万な事ではあるまいか。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少し腹工合を損じたので、お許しを得て此処でお待ち申上げることとし、早昼飯を済して野呂川に下り行く人夫に、今夜の野営地の位置を知らせ、支度が出来たら途中までお迎えに来る様に申渡して先発させた。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この報告書を持って、事務所テントへ行くと、本部へ電話で申告し、死亡者のある場合には、その日の中にトラックが迎えに来る。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き届いた彼の事であるから、必ず自身車をもって出迎えに来るだろう、と、予想していたのに――。",
              "citation": {
                "source": "深夜の客",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
