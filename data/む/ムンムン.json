        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やれ、やれ、今日も朝つぱらからむんむんするだぞ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青臭い草の匂がむんむんして、暑い。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして現実は、過去の習慣と、伝統と、それから本能とだけの重圧で、息もつけないほど、むんむんしている。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝宴に列席していた村人たちは、何か不吉なものを感じたが、それでも、めいめい気持を引きたて、狭い家の中で、むんむん蒸し暑いのも怺え、陽気に歌をうたい、手を拍った。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし……」　目を閉じていた半平の顔のあたりに、若い女の体臭がむんむん匂ってきた。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の下が、こんなにりっぱにこしらえてあるのは、この地方は暑いから、こうしておかないと床の下からむんむんと熱気があがってきて、部屋の中にいられないそうな。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら服を脱いで上はシャツ一枚になつてみても、長い冬のズボン下があるので、下からむんむん蒸す。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は外から帰つてこのアパートに入ると、入口のところでむんむんする人間の異臭のかたまりと出あふ。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "じめじめした路地に家々は芥箱のようにいがみ合い、下水には灰やきたないものを捨てたり流したりしているので、悪臭がむんむんとむれ上り、激しい風に灰や埃が吹き飛んでいた。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独防共協定のことなぞが、すべての乗客がだらしなく、口をあけ、むんむんとスチームにむされ脂汗を浮べて眠り込むと、思ひにのぼつて来た。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が腐る、黒人の膚からは白髪のような菌がでる――そういう、雨期特有のおそろしい湿熱が、いまモザンビイクをむんむんと覆いつつんでいる。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあいいとして、この有尾人からは、山羊くさいといわれる黒人の臭いの、おそらく数倍かと思われるような堪らない体臭が、むんむん湿熱にむれて発散されてくる。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚くしかれた河原の青葦は、むんむんと水気を蒸発させ、葦が乾いて段々枯れてゆくきつい香りを放散させ、わたしは目がくらみそうだった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第二巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白粉の匂いと、体臭のむんむんする臭いが、彼自身に眩暈をさえ伴った、陶酔感を与えるのだ。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の海はむんむんと熱して来た。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理的な不快さが、さか立った毛穴からむんむんと放出しているのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺幅のところ横に散らばって、一鍬々々、踏みにじるように進んでいる彼らの身体は、流れるような汗に濡れ、照りつける陽にむんむんとむれていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高倉祐吉は、草の香のむんむんするその出来たての小屋のなかで、測量隊の帰りを待っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪油のにおいがむんむんと酔わすように嗅っているのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり病室へ帰る方がいちばん良いように思われて来て、再び踵を返したのだったが、するともうむんむんと膿の臭いが鼻を圧して来て、そこへ立ち停るより仕方がなかった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは密林の中は、もうれつにむんむんとむし暑かった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "むんむんと熱気がたちこめ、全身はねっとりと汗にまみれ、息をするのが苦しい。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンをひくと消毒薬でむんむんする室内のにごった空気が外へ出ていって、入れかわりに、サイダーのようにうまい朝の外の空気が入ってきた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに、機微にふれることは除いて、常識的な眼で見ても、耳には耳垢をためてるし、鼻には鼻糞をつまらしてるし、靴の中でむんむんむれてる足を、家に帰っても洗わず、そのまま寝床にはいるし……とにかく、不潔だよ。",
              "citation": {
                "source": "失われた半身",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかすかするような、それでいて馬鹿に甘ったるい乾藁の蒸れる匂いがいつもむんむん籠っていた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして芥溜のようにつもって、むんむん温気を立てている。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、すこし冷えるようだね」　三十人ばかりのアメリカ陸軍の将兵が、スチームのむんむんする部屋で、トランプにうち興じているのであった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
