[
  {
    "uuid": "6ba1f2da-5930-5432-b040-fe0c0d769e3c",
    "entry": "無地",
    "reading": {
      "primary": "むじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
