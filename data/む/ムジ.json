      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヒワ色、褪紅色の無地ちりめん兵古帯など小学校から女学校時代袴下にしめました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「無地表、裏模様」の渋味、すなわち趣味としての渋味は、甘味を止揚したもので、第三段たる「合」の段階を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "無地より模様入が好き。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒無地の紬の重ねを着てハンチングを被り、ステッキを持って旅に出かけたのである。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚無地獄、人生の何物にも張合いが持てなくなり虚無的な気持ちばかりに襲われる地獄であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄無地の古い紬の袷に、同じ様な色の幅のせまい博多の丸帯を、盛り上った様な肉附の宜い腰の辺に恰好よく結んで居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿らしいが、銘仙縞の羽織を、なよなよとある肩に細く着て、同じ縞物の膝を薄く、無地ほどに細い縞の、これだけはお召らしいが、透切れのした前垂を〆めて、昼夜帯の胸ばかり、浅葱の鹿子の下〆なりに、乳の下あたり膨りとしたのは、鼻紙も財布も一所に突込んだものらしい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑くるしいね、絣の、大島か何かでせう、襟垢の着いた袷に、白縮緬の兵子帶を腸のやうに卷いて、近頃誰も着て居ます、鐵無地の羽織を着て、此の温氣に、めりやすの襯衣です。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏目がふつくりとする……而して、緋無地の背負上げを通して、めりんすの打合はせの帶の間に、これは又よそゆきな、紫鹽瀬の紙入の中から、横に振つて、出して、翁に與へた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無地かと思ふ紺の透綾に、緋縮緬の長襦袢、小柳繻子の帶しめて、褄の堅きまで愼ましきにも、姿のなよやかさ立ちまさり、打微笑みたる口紅さへ、常夏の花の化身に似たるかな。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無地お納戸で螢を見よう。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "池がある、この毛越寺へ詣でた時も、本堂わきの事務所と言った処に、小机を囲んで、僧とは見えない、鼠だの、茶だの、無地の袴はいた、閑らしいのが三人控えたのを見ると、その中に火鉢はないか、赫と火の気の立つ……とそう思って差覗いたほどであった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒絽の五つ紋に、おなじく鉄無地のべんべらもの、くたぶれた帯などですが、足袋まで身なりが出来ました。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、この方は山高帽子で――おやおや忘れた――鉄無地の旦那に被せる帽子を。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生びらの帷子に引手のごとき漆紋の着いたるに、白き襟をかさね、同一色の無地の袴、折目高に穿いたのが、襖一杯にぬっくと立った。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は話題が変ったので先刻からの不愉快な気持ちが一寸くつろいで「あの方には無地でこの色（小豆色）だけなのが好いでしょうね。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直助はいつも丹念な山里の実家の母から届けて寄越す純無地木綿の筒袖を着て居た。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の川魚探しに直助の母の手造りの紺無地の薄綿の肩の藍が陽やけしたのか少し剥げてゐた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒斜子に丁子巴の三つ紋の羽織、紺の無地献上博多の帯腰すっきりと、片手を懐に、裄短な袖を投げた風采は、丈高く痩せぎすな肌に粋である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時きりりと、銀の無地の扇子を開いて、かざした袖の手のしないに、ひらひらと池を招く、と澄透る水に映って、ちらちらと揺めいたが、波を浮いたか、霞を落ちたか、その大さ、やがて扇ばかりな真白な一羽の胡蝶、ふわふわと船の上に顕われて、つかず、離れず、豌豆の花に舞う。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装も汚くはないんだね、折目の附いたと言いたいが、それよりか、皺の無いと言った方が適い、坊さんか、尼のような、無地の、ぬべりとしたのでいた。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶がかった鼠色の、何ですか無地もので、皺のないのを着てでした。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "須々木｜乙彦は古着屋へはいって、君のところに黒の無地の羽織はないか、と言った。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もっともっとお寒くなりましてからでも、黒の無地なら、おかしいことはございませぬ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠いろのこまかい縞目の袷に、黒無地のセルの羽織を着て立っていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "須々木乙彦は古着屋へはひつて、君のところに黒の無地の羽織はないか、と言つた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もつともつとお寒くなりましてからでも、黒の無地なら、をかしいことはございませぬ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠いろのこまかい縞目の袷に、黒無地のセルの羽織を着て立つてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外を歩いてゐると、いつの間にか曇り出し小さいつむじ風が舗道の散らしビラを漏斗型に捲き上げる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し見え出したつむじの白髪が弾ねて光る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
