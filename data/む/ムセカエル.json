        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第三、第四、夫れも去つたと思ふ間もなく、彼れはとう／＼むせ返るやうな寒い白さの中に包まれてしまつた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コティの香水の匂がハンカチからむせ返る程ふりまかれた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンガンと響く会場の大工の金槌の音がいやに聞こえ出すのだ、むせ返る濁った空気が堪らなく咽喉を痛めることを考えるのだ、逃げ出したくなるのだ。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の周囲には新緑の茂みが、むせ返るような明るい色に盛上っていたが、低い水の面は薄すらと黒ずんで、ひょろ長い四五本の松をのせた小島が、夢のように浮んでいた。",
              "citation": {
                "source": "鯉",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "椎の花のむせ返るような匂いが濃く漂っていた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひでりつづきの後なので、坂道を上ると、土のいきれが顔をあおって、むせ返るように感じました。",
              "citation": {
                "source": "僕はこれからだ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "純然たる支那市場であって、昼は大道芸人などが出ていろいろの芸当をやり、むせ返る程に人出がし、雑沓するということであったが、夜の此処は、恰度東京に於ける玉ノ井のような最下等の支那娼婦の張店街を現出していた。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせ返るような前夜の幻に酔っていた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせ返るようなみずみずしい黒髪のあぶらと、化粧した肌のにおい、――その女が、さんざんいやがらせを毒づいたあとで「あなた、おこった？",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が一代に溜めた身代だが、娘が死んでは讓る子もなく、後へ遺す張合もない」　主人の清右衞門は娘の死骸をかき抱き乍ら、此時始めて滿面の涙にむせ返るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "寳掘りの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の側にはお妾のお峰が、たった一人泣き濡れて居り、無闇矢鱈に燻べるらしい線香の煙が、部屋一杯にこめて、いきなり入るとむせ返るような心持になりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり涙で洗われた顔は、新鮮な李のように紅くなって、十九娘のむせ返るような魅力が何んとも言いようの無い匂いを蒔き散らします。",
              "citation": {
                "source": "黄金を浴びる女",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋のむせ返るような妖艶なとりなしもさることながら、本所番場町の浪宅に、淋しく留守をしておる筈の許婚、――若くて気高くて、賢い鹿の子の、清らかさを思い出していたのです。",
              "citation": {
                "source": "十字架観音",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に何らかの物質を燃やし、あまりの刺激臭に家中がむせ返るようだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせ返るように、佃に対する憎悪と自己嫌悪がこみあげて来た。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田平治は、最初この船へ乗せられた時から、異様の情調に堪えられなかったのですが、この船長室へ入れられて、船長その人に当面に面会させられてみると、むっとしてむせ返るような気持に迫られました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と交錯し、地下室はむせ返る熱狂の極点に達し、ある婦人たちは、いまにも失神せんばかりのありさまであった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけしきからは、むせ返るような脂粉の香が立ちのぼっていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中にはなま暖かく甘い芳香が、むせ返るように漂っていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時は、むせ返る酒場の喧噪の中に、妖女は透き通るからだを酔いの桃色に染めて嬌笑するであろう。",
              "citation": {
                "source": "「悪霊物語」自作解説",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山道にはうらうらと陽炎がゆらぎ、若葉の薫りはむせ返る様。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせ返る様な香気の中を、底知れぬ泥沼へ、果てしも知らず沈んで行く気持だった。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い土蔵の二階には（むせ返る死臭と、おびただしい蛆虫の中に）二つの死骸が転っていた。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度それは晩春の頃であったが、私達は、初代が家に帰って母親と顔を合わすことを避けたがるので、会社がひけてから、長い時間、美しく燈の入った大通りや、若葉の匂のむせ返る公園などを、肩を並べて歩いたものである。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、間もなくそれが鼻をすする音に変り、そして、不意にククククククククククと、むせ返る様な声が起った。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "パノラマ島の旅人は、この広漠たる原野から突然そこへ這入って、見渡す限り打続く人間と植物との不自然なる彫刻群に接し、むせ返る様な生命力の圧迫を感じるだろう。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとはなく、それらの一つ一つの世界を夜毎の夢の様に見尽して、旅人は、最後に渦巻くオーロラと、むせ返る香気と、万花鏡の花園と、華麗な鳥類と、嬉戯する人間との夢幻の世界に這入るのだ。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五歳の恋人達は、子供の様に無邪気に、あらゆる思慮を忘れて、桃色の靄と、むせ返る甘い薫の世界へ引き込まれて行った。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、むせ返る菊の薫りだ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア、そういう内にも、火は既に棺の底を焼抜いて、真赤な焔がチョロチョロと倭文子の着物の裾をなめ、むせ返る煙に、母も子も早や叫ぶ力さえなくなってしまった。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
