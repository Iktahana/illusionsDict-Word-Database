    "definitions": [
      {
        "index": 1,
        "gloss": "untitled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無題太宰治　大井廣介といふのは、實にわがままな人である。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無題（18頁）及び無題（27頁）の夢魘。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、有りふれた「無題」とか「断片」とかいう種類のものにすればいちばん無難ではあるが、それもなんだかあまり卑怯なような気がする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して然らばこの無題の小説は「縷紅新草」以前のものと見るを至當とすべし。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく此の無題の小説は今年のはじめに起稿されしものにはあらざるか。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜誌社としては無題を迷惑がる事察するにあまりあれど、さりとて他人がみだりに命題すべき筋合にあらざるを以て、強て其のまゝ掲出すべきことを希望せり。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "無題札幌は一昨日以来ひき続きいと天気よし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年九月二十三日　　　　　　　　　　　　　札幌にて　啄木拝並木兄　御侍史　　無題一年ばかりの間、いや一と月でも一週間でも、三日でもいい。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月、「病中雜咏（一）」を無題で「アララギ」に発表。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、ほんの二、三ではあるが、「無題」「曙町より」とは別の欄に載せた短文や書信がある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年ごろの「無題」に、ページの空白を埋めるために自画のカットを入れたのがある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは拿破里に來てよりの近業にて、獄中のタツソオ、托鉢僧など題せる短篇の外、無題一首ありき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して然らばこの無題の小説は「縷紅新草」以前のものと見るを至当とすべし。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくこの無題の小説は今年のはじめに起稿されしものにはあらざるか。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌社としては無題を迷惑がる事察するにあまりあれど、さりとて他人がみだりに命題すべき筋合にあらざるを以て、強てそのまま掲出すべきことを希望せり。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕牧野信一　そのとき、たしか、永井龍男君と井伏鱒二君と堀辰雄君と小林秀雄君とに私は誘はれて、恰度うらうらとするこのごろのやうな長閑な日の夕暮時に銀座の方から、須田町の万惣にあつまつた。",
              "citation": {
                "source": "〔無題〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−無題　一人の上京学生がゐた彼はＡ炭礦所有主の息子であつたＡ炭礦では炭礦夫達の生活の合理化のために共同炊事や、共同購買組合風のものを設けてゐると、二人の左翼学生にむかつて自分の父親の政策の自由主義的なことを誇りながら語つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『二人の裸婦』は画面の裸婦を明るさ、つまり白で締めて効果を出してゐるに反して今一方の裸婦『無題』の方は暗さで画面を締めてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの作家に不明瞭なものゝ解決を『二人の裸婦』のやうな明瞭さに到達し解決しないで『無題』から一歩前進してほしい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口軌外　の四点の出品のうち、「貝殻」だけは沈着いてみることができ、其他の「無題」「花」「鸚鵡と少女」何れも線のうるささと、色彩は美しいといふよりも、通俗的美観を呈してゐた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "△藤岡一氏――『マンドリン』『花甘藍』と題をつけるのはあまりにシャバ気がある、無題とまで徹底できなかつたら、かうしたコラージュ的な仕事を廃した方がいい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二十四日）〔無題〕　全くこの目醒しい大活動をフヰルムにでも収めて読者諸君にお目にかけたく思ふ。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕　△今度は「美智子と日曜日の朝の話」を出しました。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝時代の詩文の集は凌雲集、經國集、文華秀麗集、本朝無題詩、本朝文粹、朝野群載等であるが、此の頃唐では詩風の變遷があつたのを日本人は如何に受け入れたかと云ふ事を述べて見よう。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多緒生氏も精進を欠き「街角の文字」「無題」その他、短いものしか書きませんでしたが、今や同氏はその文章に於て、革命期に立って居りますので、却って今後が期待されます。",
              "citation": {
                "source": "探偵文壇鳥瞰",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無題　憂悶の涯に辿りつく睡りはまるで祈りのやうであつた。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三八・一）（八七号、一九三八・一・一五）無題――回想・五カ年有半　一九三八年二月十二日、唯物論研究会はいよいよ解散になった。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "情景のまざまざととらえられ感情化されている作品として、「橋梁架設工事」「生活の脈動」「町工場」「シベッチャの山峡」「下水工事場」「三河島町風景」「無題」などの中に、いくつか印象のつよい作がありました。",
              "citation": {
                "source": "歌集『集団行進』に寄せて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無題（四）宮本百合子-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）蝙蝠：入力者注　主に外字の説明や、傍点の位置の指定（例）「彼は美徳を信じて居る。",
              "citation": {
                "source": "無題（四）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
