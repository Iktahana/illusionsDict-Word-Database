    "definitions": [
      {
        "index": 1,
        "gloss": "incompetent (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
