[
  {
    "uuid": "55f33702-5f5c-527a-9308-51c9c7d678ad",
    "entry": "向い",
    "reading": {
      "primary": "むかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "facing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」小坂氏は、ふり向いてその写真をちらと見て、「長女の婿でございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、そっぽを向いて、暫く黙って考えて居られたが、やがて、しぶしぶ首肯せられた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもし、音楽よりも文学にだとか、文学よりも絵画に関心は向いてゐるといふやうなことならば、此の場合私には分らない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度彼女は頭をのぞけて、「ばかァ」と云つたが、魚屋はお祖母さんの方を向いたツきりだつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えなくならうとする前に彼は一寸振向いて、「お嬢さんさよなら」と、高い声で巫戯けて云つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林の言葉で云へば、私の「生理の秘密」が、詩に向いてゐたのである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――耕二はそのガシヤガシヤの手を襖の把手に手を掛けた儘、此方を向いて口をムツチリさせてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私も庭の方を向いて眺めるともなしに躑躅の根本の所を眺めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十の弟が下を向いて黙つてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が仰向いて長火鉢の上の柱時計をみながら飛び出した喉豆に掛けた声で「七時かあ」と云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあね………」と妻君は俯向いて揃へた指を伸ばして、女優的しなを作つたりしてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「御大事になさい……」　まるで遠くへ行く人への別辞だ、――Ｓ子はさういふなり下向いた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は父の机の前に足と投出したままで無心に華車な浴衣の後姿から白い衿頸を見上げた時、女は肩越しにチラと振り向いたと思う間に戸をはたとしめた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬が容捨もなく迫って来て木枯しが吹き募るある夜、散歩の帰り途に暗闇阪近くなった時、自分の数間前を肩をすぼめて俯向いて行く銀杏返しの女がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマンの教室を出て右を見ると河向いにウィルヘルム一世記念碑のうしろの胸壁の裏側が見える。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また向うからただ一人、洋紅色のコートを着た若い令嬢が俯向いたまま白いショールで口を蔽うて、ゆっくりゆっくり歩いて来る。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機今｜音羽屋の弁天小僧にして向いの壮士腕をまくって耶蘇教を攻撃するあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も陳列所前の砂道を横切って向いの杉林に這入るとパノラマ館の前でやっている楽隊が面白そうに聞えたからつい其方へ足が向いたが丁度その前まで行くと一切り済んだのであろうぴたりと止めてしまって楽手は煙草などふかしてじろ／＼見物の顔を見ている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の庭に向いた方の鴨居に水彩画が一葉隣室に油画が一枚掛っている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すじ向いに座を構えたまうを帽の庇よりうかゞい奉れば、花の御かんばせすこし痩せたまいて時々小声に何をか物語りたまう双頬に薄紅さして面はゆげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に兜の鉢を伏せたらんがごとき山見え隠れするを向いの商人｜体の男に問う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして河向いの高い塀の曲り角のところの内側に塔のような絞首台の建物の屋根が少し見えて、その上には巨杉に蔽われた城山の真暗なシルエットが銀砂を散らした星空に高く聳えていたのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時われは裏道を西向いてヨボヨボと行く一人の老翁を認めた。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向いに坐った目の赤いじいさんと相撲の話をしている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体が西を向いて行くのであるから、椎茸は車の右脇へ頭を出したり左へ出したり。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも自分の好いた方、気に向いた事をやるが得策だ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでも、あなたの氣の向いたやうに、とはじめから何度も言つてるぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兎は輕蔑し果てたといふやうに、つんとわきを向いてしまつて、「助平の上に、また、食ひ意地がきたないつたらありやしない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお爺さんは、はじめてお照さんのはうを向いて話かける。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも手むかいせずに、こっちの殴った手へべっとりくっついて来る」急に真剣そうに声をひそめて、「あいつ、菊の手を平気で握りしめたんだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
