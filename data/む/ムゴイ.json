        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ程｜辛い思を女がするだらうと思つてるのに、そのつらさうな顔を見に行くのは、私はあまり惨い為打であると思つた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから言わないことか、あんなに惨いことをなさるなと。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうかしましたか」それは決して惨いとか冷淡とかいう声の響ではなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかれらを恐れさせたのは、その旅人の背負っている重い罪の影か、あるいは殺された女の凄惨い姿か、確かには判断がつかない。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術をすれば、たぶん癒るであろうが、青木の親たちは、手術は惨いから忍びないと言って、成行に委すことにしたのであった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほどの大手柄をたてた艦に、なんと惨い御褒美でしょう。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山小町と迄うたわれた娘を、こんな惨い目に遇わしやがった奴を、おめおめ生かしておくもんじゃねえ。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わけても晩は、電燈のあかりの中にさらされた身体が、芸人でありながらも余りにあざやかで、あまりに惨いものの美しさを剥き立てていた。",
              "citation": {
                "source": "ヒッポドロム",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「商家の手代風の者でございますが、この肩さきから斜めに――いやもう、ふた目と見られませぬ惨い傷で……」「長屋で手当をしてつかわしておりますが、所詮助かりはすまいと存じまする」　言うまも、剣を中に気押し合うけはいが、はちきれそうに伝わってくる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやまって、とんだ惨いことをいたした……」　悄然たる丹波の言葉も、誰の耳にもはいらないらしく、一同、刀をさげ、頭をたれて、黙々とその無残きわまる同志の死体を、見おろすばかり、頓みには声も出ません。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は気の荒らい、惨い人間が大嫌いでございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした場合、人間というものはさてさて惨いことをするものじゃと、俺はどんなに歎いたことであろう……。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前九州の田舎をがた馬車で走らせて居た時に、御老が小ひどく鞭を打つのを見て、あんな語りのならぬ者に惨いことをすると謂ったのが、十六七の同車の貧しげな小娘であった。",
              "citation": {
                "source": "夢と文芸",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは惨いと言うより、恐ろしい。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然ドーブレクは古塔の一室に惨い拷問の憂き目を見ていた。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「手にかけて殺した」「なんという惨いこと……」「芝の増上寺の松原で、松の樹へ縛っておいて、この刀で胸を突き透した」　武蔵太郎を取り上げた机竜之助は、やにわに立ち上って、眼が吊り上る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "親にも見せられないこの姿……この衰え切った敗残の弟を、こんな無情な世の中に生かして置くほど惨いことがあるだろうか。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それほど極端の悲觀論を稱へずとも、或ひは、貴人といふものは、しばしば、むごい嘲弄を平氣でするものであるから、乙姫もまつたく無邪氣の惡戲のつもりで、こんなひとのわるい冗談をやらかしたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とむごい宣告をする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間つて、あんな工合ひに出し拔けにむごい事をするものなのね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弟の変声期を想像するのがなにかむごい気がするときがあります。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅墓な、つめたい、むごい、エゴイズムさ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに、たよりにされて、何一つ期待に添わぬというのも、むごい話だ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半病人に、配給のお米を背負わせるのは、むごいとも思ったが、しかし、私自身であの配給の列の中にはいるのも、頗るたいぎなのである。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お前はずいぶんむごいやつだ、お前の傷めたり殺したりするものが、一体どんなものだかわかっているか、どんなものでもいのちは悲しいものなのだぞ。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むごい――という言葉があてはまる。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それほど極端の悲観論を称へずとも、或いは、貴人といふものは、しばしば、むごい嘲弄を平気でするものであるから、乙姫もまつたく無邪気の悪戯のつもりで、こんなひとのわるい冗談をやらかしたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間つて、あんな工合ひに出し抜けにむごい事をするものなのね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代に不勉強だった人は、社会に出てからも、かならずむごいエゴイストだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むごいことをする奴だ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
