    "definitions": [
      {
        "index": 1,
        "gloss": "absence of permission",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある夜、主人はヴァイオリン弾きの老爺が、突然無断で邸内から抜け出し、何処とも知らず、逃げ失せたのを知りました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無断で病院から出て行って、三日間、露人の家に泊ってきた男があった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ついにおしかには無断で、二里ばかり向うの町へ入学試験を受けに行った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出ると、再び殆んど無断で、高商へ学校からの推薦で入学してしまった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、無断で私物箱を調べられるというような屈辱には馴れていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ、荒療治で、あっさりと無断で失敬して行っちまおうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無断で借りて帰った分のことをどうしようかと心で迷う。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いままで、どの女も、彼に無断で勝手な買い物などはしなかった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱歩氏の分は私信を無断で公表させて貰った。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、主人はヴァイオリン弾きの老爺が、突然無断で邸内から抜け出し、どことも知らず、逃げ失せたのを知りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、知れりゃ華族だ、無断に品物を取って来た、代価は幾干だ、好な程払ってやるまでの事じゃあねえか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではあなたは無断で家から逃げておいでになりましたね。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは怪しからん奴じゃ、他の領分の扉を無断で閉ざす奴があるものかと、吾輩は用捨なくすぐに開けると、暫時してまたノコノコ手を伸ばして閉める。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無断で、いけませんでしたかね。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十月、深川座にて黙阿弥作の「弁天小僧」を無断上演して、作者の遺子吉村いと女より告訴せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで広言を吐いていただけに、近所の手前面目ないと思ったのかも知れません、浅井さんは誰にも無断で、その晩のうちに何処へか立ち去りました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「用ってわけではないが、隣に泊っているよしみで、一寸顔を出したわけですよ」「無断で、女ひとりの部屋へはいって来ていいんですか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブルの洋服が泣きますよ」「しかし、無断でひとの懐中を掏るひともいますからね、赤いブラウスが泣きますよ」　弓子ははっとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今や、今や、手エ入れるんやったら、今や」　と、いたずらに頭の中で叫んでいたが、しかし、いくら掏摸になるんだとやぶれかぶれの覚悟をきめても、はじめての経験では、他人の袂に無断で手を突っ込むということは、よほど魔がささねば出来なかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも自作を無断で改訂されたことでとっくに傷ついている自尊心だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴けば、新坊が昨夜工場に無断で帰つて来たのだ。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一知は間もなく両親に無断で、小作人と直接談判をして、麦を蒔いた畠を一町歩近くも引上げて、ドシドシ肥料を遣り始めた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、私が人名辞典やら、「葛原勾当日記」の諸家の序やら跋やら、または編者の筆になるところの年譜、逸話集、写真説明の文など、諸処方々から少しずつ無断盗用して、あやうく、纏めた故葛原勾当の極めて大ざっぱな略伝である。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の室に無断で入って来たのに違いない。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の物を無断で盗んだだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（山に来て二十日経ぬれどあたたかくわれをいたはる一樹だになし――娘時代のかの女の歌より）精神から見放しにされたまま、物足りなさに啜り泣いていた豊饒な肉体――かの女が規矩男のその肉体をまざまざ感じたその日、かの女は武蔵野へ規矩男を無断で置いて来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は数学を、もっと勉強したかったから、父に無断で高等学校に受けて、はいったんだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、さっき僕に無断で借用したのに、ちがいありません。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは笑ひ声に巧みなといふ評判の西洋音楽師が吹き込むだんださうで今試みにこの歌を想像して見ると、鴉が五、六羽飛んで来て、権兵衛の頭に糞かけた。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家一｜門の運命も、いよいよきわまり、安徳天皇をいただいた二位尼が水底ふかく沈むだんになると、いままで水をうつたようにしんとしていた広間には、いっせいに悲しげな苦しげな声が上がりました。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
