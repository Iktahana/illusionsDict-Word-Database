        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時の彼の眼には、もう家来なんぞは虫けらのやうに見えて、しやうがなかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈々どん詰りまで行けゃあ、俺だって虫けらた違うんだからな。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸を吸い込むと胸の中に枯枝か屑のようなものがつかえ、咽喉はいらいらと虫けらが這うように痒い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の実体かずかぎりもしれぬ虫けらの卵にて、春がみつちりとふくれてしまつた、げにげに眺めみわたせば、どこもかしこもこの類の卵にてぎつちりだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいつかも、私は高い山の上へ登つて行つた、けはしい坂路をあふぎながら、虫けらのやうにあこがれて登つて行つた、山の絶頂に立つたとき、虫けらはさびしい涙をながした。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにある日とんぼが来て今度蜘蛛を虫けら会の副会長にするといふみんなの決議をつたへました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今度は虫けら会の副会長になるんだぞ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはいまに虫けら会の会長になってきっときさまにおじぎをさせて見せるぞ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかへって蜘蛛からあざけられて、熱病を起して、毎日毎日、ようし、おれも大きくなるくらゐ大きくなったらこんどはきっと虫けら院の名誉議員になってくもが何か云ったときふうと息だけついて返事してやらうと云ってゐた。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海から騰る泡で太陽を消せ、生き残りの象から虫けらのはてまで灰を吸はせろ、えい、畜生ども、何をぐづぐづしてるんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにある日とんぼが来て今度蜘蛛を虫けら会の相談役にするというみんなの決議をつたえました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今度は虫けら会の相談役になるんだぞ。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海から騰る泡で太陽を消せ、生き残りの象から虫けらのはてまで灰を吸わせろ、えい、畜生ども、何をぐずぐずしてるんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫けら一疋でも自信を以て自分の爲めに犧牲にする事の出來た人を彼れは同情と尊敬とを以て思ひやつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高利貸の老婆は、ラスコリニコフの意見では、もはや生きている必要のない虫けらの如き存在である。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才と、そして虫けらである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才はもはや人間以上であり、虫けらは人間以下である。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才は彼が生きて行くためには、多数の虫けらを犠牲にしても構わないのだ」　ラスコリニコフは自分を天才に擬している。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、自分が生きて行くためには、虫けらの如き高利貸の老婆を殺してもいいと思う。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、だいいち天才が虫けらの人間共を犠牲にしてもいいという考え方は無茶だ」　そう呟いて、活字から眼を離した時、鈴子の声が聴えて来たのだ……。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――つまりは、あいつは虫けらなんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂のない、埃のやうに小さな一匹の虫けらさへが、さうなのだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、私の愛情は、私の盲目的な虫けらの愛情は、なんということだ、そっくり我執の形である。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大演説なぞと、いきり立ち、天地もゆらぐ程の空想に、ひとりで胸を轟かせ、はっと醒めては自身の虫けらを知り、頸をちぢめて消えも入りたく思うのだが、またむくむくと、せめて袴くらいは、と思う。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々たたき斬って呉れたい虫けらども。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其虫けらにそれがしがなろうや。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、虫けらだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "住むにも、食うにも――昨夜は城のここかしこで、早い蛙がもう鳴いた、歌を唄ってる虫けらが、およそ羨しい、と云った場合。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
