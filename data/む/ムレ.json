[
  {
    "uuid": "6934a881-c675-581e-91c9-802482893886",
    "entry": "群れ",
    "reading": {
      "primary": "むれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
