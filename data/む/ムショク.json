[
  {
    "uuid": "8e0d2228-a3bb-5c12-826e-59b0a38b6702",
    "entry": "無職",
    "reading": {
      "primary": "むしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
