    "definitions": [
      {
        "index": 1,
        "gloss": "movement (political, social, artistic, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのムーブメントは、社会に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生たちが新しい政治ムーブメントを立ち上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は環境保護ムーブメントの熱心な支持者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また雇手があるなら、ドウセ当分は公然のムーブメントできまいから、運動をしないという条件で雇人にもなろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六四年九月、学生運動規制の方針を示したカリフォルニア大学バークレー校当局に対し、学内の諸団体は各々の自主性を尊重する緩やかな共闘態勢を組み、フリー・スピーチ・ムーブメントを組織した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニア大学バークレー校がフリー・スピーチ・ムーブメントで揺れている時期、数値解析実験に嬉々として取り組んでいたピットマンは、政治的な人間ではなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのムーブメントの中に飛び込んで行って、力一杯に手ごたえのある事をして見たいと思うのだった。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
