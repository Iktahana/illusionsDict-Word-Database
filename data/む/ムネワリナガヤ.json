    "definitions": [
      {
        "index": 1,
        "gloss": "terraced or partitioned housing structure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
