        "examples": {
          "standard": [
            {
              "text": "国境付近の山岳地帯はどの国の統治も及ばない、麻薬密売組織の無法地帯だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この公園は夜になると無法地帯になるから、一人で歩いてはいけないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無法地帯と化した廃墟の中で、サバイバルゲームを楽しむ若者たちが集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我々は無法地帯じゃよそ者だし、無鉄砲な乱暴者どもに囲まれている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時あそこは無法地帯だった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
