    "definitions": [
      {
        "index": 1,
        "gloss": "way of tying a knot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨嫌いな私は、鰍沢で、万一の用心にと、買って置いた饅頭笠を冠り、紐の結び方で苦心をしているうちに、意地の悪い雨は、ひとまず切り上げてしまって、下界を覗く空の瞳がいまいましいまでに冷たい。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の着かたや、髪の結び方や、断片的な方言まじりの話しっ振りの中に、まだ、内地の匂いが多分に匂っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理の指でどんな結び方でも出来る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネクタイには結び方があるが、眼鏡なんか阿呆でも掛けられる。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中形の浴衣を着てゐたが、帯の結び方、頭髪、思切ツて世話に碎けてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子の紐の結び方は、女結びではなくて、引き結びといわれる水兵結びであった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、この結び方は船乗り以外の者にはめったに結わえないものだし、またマルタ人独得のものなんだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "起臥の、徒然に、水引の結び方、熨斗の折り方、押絵など、中にも唯今の菊細工――人形のつくり方を、見真似に覚えもし、教えもされましたのが、……かく持参のこの手遊品で。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七百余人のお嬢さんに一定の制服を着せて、頭髪の結び方まで八釜しく云っている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジミィのネクタイの結び方をおぼえようとしながら、フロント係は快く情報を提供した。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――紐の結び方もひとつの鍵にはなり得るが、この場合そう問題になるとは思わない。",
              "citation": {
                "source": "探偵会話　下駄を探せ",
                "author": "――芝公園　女の殺人事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帶の結び方も知らないらしい。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年｜芭蕉が新に俳諧を興せしも寂は「庵を並べん」などより悟入し季の結び方は「冬の山里」などより悟入したるに非ざるかと被思候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い武士の長い髪がトンボの形をした結び方で結ばれていたからであるという。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも岸本には見知越しの連中で、襟飾の結び方からして美術家らしく若々しかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな形、しかし美しい心の結び方！",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年芭蕉が新に俳諧を興せしも寂は「庵を並べん」などより悟入し、季の結び方は「冬の山里」などより悟入したるに非ざるかと被思候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年芭蕉が新に俳諧を興せしも寂は「庵を並べん」などより悟入し季の結び方は「冬の山里」などより悟入したるに非ざるかと被思候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪の結び方と顔の化粧振りとに対して、余りに扮装が粗末なので、全く調和が取れなかった。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "服の着方、釦のはめ方、ネクタイの結び方、片手で乱れ髪をかきあげる癖まで……そして和服の時には、襟を合せる様子から、帯を結ぶ手付まで……其他無数の細かい事柄。",
              "citation": {
                "source": "女人禁制",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服はネクタイの結び方も知らなかったのであった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが、｜猫の前肢と云う、猶太人犯罪者特有の結び方なんだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで熊城君、この結び方一つに、廻転椅子に矛盾を現わした筋識喪失――あの蝋質撓拗性に似た状態を作り出したものがあったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、お化け結びと云う結び方を知ってるだろう――一方の糸は喰い込む一方だが、片方のを引くと、スルリと解けてしまうのを。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れに、倫糸のテグスの結び方一つ、鈎の選み方一つ、或は沈子、又は竿の調子、餌のさし方、それぞれ微細なところで、失敗したり、成功したり、潮の見方とか、天候の様子によつて場所の違ひとか、魚の出来如何とか、いろいろの臆測や期待があるので、ますます一切を自分で試みることが愉快になる。",
              "citation": {
                "source": "釣心魚心",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネクタイの結び方がなんだかとても難かしい。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰一人解き方知らぬ神秘の結び方で、その布を結び固め、神となる御躬の霊結びを奉仕する巫女があった。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひもは「あわ緒」など言うに近い結び方をしたものではないか。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば憂鬱を宿す額、懐疑そのもののやうな瞼、触角の如く動く小鼻、それから、口の結び方――これこそ、凡ゆる教養と性格の閃きである。",
              "citation": {
                "source": "俳優の素質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術が哲学と結び、宗教と結び、科学と結び、政治と結び、社会運動と結び、それはその結び方次第で、芸術としての存在が許されるだけである。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
