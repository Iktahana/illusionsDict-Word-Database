        "examples": {
          "standard": [
            {
              "text": "不正を平然と行う組織の隠蔽体質を目の当たりにして、実に胸糞が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人の不幸を陰で笑いものにするような連中を見るのは、非常に胸糞が悪いものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嘘八百を並べて保身を図る彼のスピーチを聞かされるのは、胸糞が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それが俺は胸糞が悪いんだ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るのも胸糞が悪いって風に綺麗サッパリと縁を切ってやる。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "面を見ても胸糞が悪いから」「アッハッハッ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧の六弥は、胸糞が悪いと云つて栄一の前で大に憤慨して居た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルの仲間にのめのめとリン病をなおして貰ったとあっては、胸糞が悪いと俺は歯軋りをした。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
