[
  {
    "uuid": "24402a2f-3aa1-5594-9afa-1ad4c13e5afd",
    "entry": "無学文盲",
    "reading": {
      "primary": "むがくもんもう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
