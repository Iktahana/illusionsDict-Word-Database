        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（ペンを擱いて向き直る）女　恰度よかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家の方へ向き直る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはわずかに十度か二十度ぐらい回転するだけで、すっかり元の方向まで向き直るようなことはない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が向き直ると、ヤコフ・イリイッチは一寸苦がい顔をして、汗ばんだだぶだぶな印度藍のズボンを摘まんで、膝頭を撥きながら、突然こう云い出した。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その※腫は、と医者は席を立たうと思つたかして、私の方に向き直ると云ふのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女改めて阿難の方に向き直る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊代、戸口のところに立ち上り、野中教師のほうにくるりと向き直る。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文公――、バカ――」「そんなに河のまん中へ出ちゃ、洲から外れて深いところへ落っこっちゃうぞ」　川の中の人は欄干の方を振り向いて、愛想らしく麦藁帽子を冠った首を上下に揺り、また、前へ向き直るとゆさり／＼裾を水にひき拡げながら一間ほど進み出ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば父者』（西に向き直る。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして向き直ると、両足をブランブランさした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、そのすぐあと私の方へ向き直ると、その面差しは心から心配しているように見えたからだ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と友人は、呆気にとられて顔を見つめていたロス大佐に向き直る。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と係長が後ろへ向き直ると、傍らにいた事務員が口を入れた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は正面に向き直るとともに、その男のひとみの下で、悒鬱な険しい色を引きしめた口のあたりにみなぎらした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北へ向き直ると、まともに顔へ当る。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は經を讀み終りて、こなたへ向き直る。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田はクルリとその友達の方に向き直ると、いたずら小僧のように片っ方の目をパチパチとした。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この源蔵がゆうべ変なことを見たと云うんです」「なにを見たね」　吉五郎は職人の方へ向き直ると、源蔵も小声で話し出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして身軽にこちら向きに向き直ると、またしても腑におちなささうに小首を傾げてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の方に向き直ると、屹つとして背骨を伸した。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、幾度かこんな事を重ねて、高木氏の最後の駁論が済むと、氏はくるりと蓄音機の方へ向き直る。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「右へ九〇」とすると、九〇度右に向き直る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉は父の方へ向き直ると、突然険しい目つきを見せた。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に知られては困ることにちがいなかったが、自分の丹精こめて愛したものが、愛しただけ自ら別の姿となって自分に現れ分るだけのことであり、そのどこに不思議なことがあるものかと、向き直る度胸も出るのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢代は向き直るように千鶴子に云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "心持ち蒼い顔に、黒い瞳を凝然と据えたまま静かに部屋の入口を振返った……が、やがて又おもむろに私の方へ向き直ると、やおら椅子の上に居住居を正した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままくるりと向き直ると、疾風のように外へ飛び出そうとした。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その堤の上に最前から突立って見下していたらしい小さな、黒い人影が見えたが、彼の顔がその方向に向き直ると間もなく、その小さい影はモウ一度、一生懸命の甲高い声で呼びかけた。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を打たれて度を失った恰好で、クルリとこっちに向き直ると、まだ締まったままの扉を小楯に取るかのように、ピッタリと身体を寄せかけて突っ立った。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんください」「ごめんください」「ハイ」　老人は松女を膝からおろしてちょっとむきなおる。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
