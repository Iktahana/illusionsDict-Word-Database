    "definitions": [
      {
        "index": 1,
        "gloss": "first month of the lunar calendar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遠山は霜月祭、新野にては睦月、西浦は田楽、北設楽は花祭とよの。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨の花青し　圓朝の墓どころ昭和癸未睦月下浣於　巣鴨烟花街龍安居　　　作者第一話　初一念　　　　　一「……」　クリッとした利巧そうな目で小圓太の次郎吉は、縹いろに暮れようとしている十一月の夕空の一角を悲し気に見つめていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "動揺み打つ群衆、　睦月の風はサッと腥く吹いて過ぎます。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            },
            {
              "text": "睦月明るき庭土の面戦地よりとくかへり来し若者を　春の客とし、なごみて対す睦月立つ　四日のしづけさ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ晴るゝ空の深きに、息づかむとす睦月の海山たゝかへる春のしづけさ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらめきて没りし日を　思ふなり日の没りの暗き海面に　対きてゐて、睦月しみ／″＼　旅のかそけさ夜をふかしゐつゝ、おちつくことのよさ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "睦月八日の海遠く凪ぐ磯山に　凍て土乾くあはれさよ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人馬　とらつく　明るくとほる修善寺冬水の湛へに深く　棲む鯉の　浮き出で来るを、まもりゐにけり霜凍ての屋庭を　いくつのぼり来て、こゝにひそけき　範頼の墓湯の村の睦月の道の　ものげなさ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "睦月ついたちたまさかに　靴音たちて、水に浮く霰の色の　さびしかりけりさ夜ふかく　暗き厩の風とほる土間に立ちゐて、報告を受く坐らせて　家のたつきを言はしめて、この若き兵を　いかにすべけむ雪朝の明け昏れ　冴ゆる窓のした。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぞのもみぢの低く残れりあたゝかき睦月の道に、白じろと　毛ばかり散れる※の　かげ顕つ舞人の　四つの立て鉾。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬山を来てひたくだりに　根雪の道をふみ下り、谷に澄み来るせきれいの声冬山の斑雪かゞやく朝の間を、たちまち過ぐる風の　きびしさ睦月空　山の起き伏しつばらかに　ひたしづけくて、朝はれにけり朝じめり深くおよびて　日さし来ぬ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、　　すむつきの。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『混効験集』に「さしぼ（またはむつき）はくでの事、またくでとは託女の事也、今神人と云是也」ということがあります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親のお清は、再び暗い、むつき臭い部屋へみのえを閉じ込めるであろう。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであわてておじいさんがお湯をわかすやら、おばあさんがむつきをそろえるやら、大さわぎをして、赤さんを抱き上げて、うぶ湯をつかわせました。",
              "citation": {
                "source": "桃太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお訊ねに対する返辞なら、かう申し上げるだけで沢山でせう――あつしやあね、もう疾の昔からむつきの厄介にはなつてゐませんよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの生れたての、玄米パンよりもホヤホヤな赤ん坊達に、絹のむつきと、木綿のむつきと一たいどれだけの差をつけなければならないのだろう！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつきの世話から、着物のつくろひまで信一は一人でしなければならなかつた。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの生れたての、玄米パンよりもホヤホヤの赤ん坊達に、絹のむつきと、木綿のむつきと一たいどれ丈の差をつけなければならないのだ！",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を片手に抱きあげ、むつきを代えていたマルーシャが、むこうを見ながら、　――あら、見なアグーシャ！",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　山人の杖――むつきの起り此山人が持つて来るものゝ中で、最考へねばならぬものは、山人がついて来る杖であります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつき・うづきは、そんな事に関係のある語ではないかと、私は考へてゐます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつきに就いては色々な説明がされてゐますが、月を聯想するから訣らない事になるので、きさらぎ・やよひなどにはつきがついて居ません。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此なども意味の訣らない語だと思ひますが、結局、月のつかない、意味の訣らない語の方が古いので、むつきなども、さうした語だつたのが、つきとあるので、月の運行を聯想する様になつて、月名となつたのではないでせうか。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其つく様になつた初めは、恐らくむつきなどが最初ではなかつたかと考へられます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月のうづきも、やはりむつきと同じ意味だと思ひます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけなや、何と、それは、やッと当歳か、それとも生れて年を重ねたばかりのむつき児なのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎兵衛、ようも、子飼いの恩を忘れ、土部奉行や、浜川、横山、これなる広海屋と腹を合せ、わが松浦屋を亡ぼしたな――ようもようも、むつきの上から拾い上げ、手塩にかけて育てたわしの恩を忘れ、編笠一蓋、累代の家から追い出したな！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその巻十五の歌は「わたつみのおきつなはのりくるときと、いもがまつらむつきはへにつつ」（和多都美能於伎都奈波能里久流等伎登、伊毛我麻都良牟月者倍爾都追）である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の後ろからすこしはなれて、フランスの百姓女のようなふうをした婦人が、白いむつき（おむつ）に包まれた赤子をだいてついて来た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
