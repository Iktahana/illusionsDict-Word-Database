    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese beautyberry (Callicarpa japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
