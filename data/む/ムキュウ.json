[
  {
    "uuid": "e3b7b1fb-5fa4-59af-bcb7-92c9bad5d117",
    "entry": "無休",
    "reading": {
      "primary": "むきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "without a holiday",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サポートに関しては「電話のコール三回以内でつながる」を謳い文句に、アシストは年中無休、午前九時から午後九時までの十二時間体制を組んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は無休刊の新聞はないので、どの新聞も月曜は休刊である。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処だけは年中無休であった。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの代表部には、この博愛事業に従事しているものが千人近く居り、みな無休で奉仕している。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "女事務員二人、年中無休のおしやべり。",
              "citation": {
                "source": "銀座街頭",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレベータアにのるものは、あけっぱなし無休止の箱が自分たちの前へゆるくのぼって来たり下って行ったりした瞬間をとらえて、せわしくその中へ自分をいれるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
