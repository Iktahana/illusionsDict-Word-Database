        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "荒浪の天うつ波の逆まきのとどろきが上、あああはれ、また、向き向きに、稲妻の青の脅えに連れ連れ乱る、啼き連れ乱る。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒浪の天うつ波の逆まきのとどろきが上、あああはれ、また向き向きに、稲妻の青の脅えに連れ連れ乱る。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "多勢でしたらおもしろかろうと思って二軒いっしょにお互いこの稲刈りをしたのだが、なんだかみんなの心がてんでん向き向きのようで、格別おもしろくなかった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、渦巻いているホールの賑やかさの中から、バンドの喇叭手がただ一人、濡れた唇に輪形をつけしきりと梶の方を向き向き、喇叭を吹いたり止めたりした。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、彼も、その向き向きで儲けようとしている、と猛之介は考えた。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやや赤みの褪せた花には、永い昼過ぎの日の光が、さし交した枝の向き向きに、複雑な影を投げ合つてゐる。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の身は然らず、己が心の向き向きに寄る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か善き、何か悪しき、知らず、唯だ人は向き向き。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床屋　　後ろを向き向き走つて来る。",
              "citation": {
                "source": "取引にあらず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄熟した稻の穗は、空しく收穫の時期を逸して、風に打たれて既に向き向きに仆れてゐる。",
              "citation": {
                "source": "艸千里",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼跡の穴倉から出た二万両の金は、尾州を始め斑組に荒らされた向き向きへ適当に返しましたが、不思議なことに、お栄を始めお栄の手下と思われた新まだら組の一味は、それっきり何処へ行ったかわかりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間、ツラがちがつているように一人一人向き向きがありますからね。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんの留守中に書斎へ忍込んで机の中を探すなぞと聞くと、僕を不良少年と思い込む向き向きがあるかも知れない。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘えん坊の文六ちゃんは、それでも、いつも親切な義則君だけは、こちらへ来てくれるだろうと思って、うしろをむきむき、水車のかげになってゆきました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠数かけ鳩唐画珠数かけ鳩はむきむきに落ちし杏をつつくなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、むきむきな心で帰って来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むきむきの諸芸をしこんで出したので、あっぱれ紅葉館は時代に応じた、明るい華やかな、一種の交際場となったのだった。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
