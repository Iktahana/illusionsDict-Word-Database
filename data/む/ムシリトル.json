[
  {
    "uuid": "a4fac0db-1ff1-5160-81c0-20770277590a",
    "entry": "むしり取る",
    "reading": {
      "primary": "むしりとる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
