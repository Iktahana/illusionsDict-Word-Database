    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to tear off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "せっかくはえたものをむざむざむしり取るのが惜しいと思われた。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外のものは兎に角と致して日本一お江戸の名物と唐天竺まで名の響いた錦絵まで御差止めに成るなぞは、折角天下太平のお祝いを申しに出て来た鳳凰の頸をしめて毛をむしり取るようなものじゃ御座いますまいか。",
              "citation": {
                "source": "三月三十日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は右の手を疊に突いて、少しにじり出した膝の當たりの褄を左りの手の指さきでむしり取るやうな眞似――これは此の間もしほらしいと見たことで、かの女の癖だと義雄は思つた――をして、多少締まりがないと思はれる笑ひ方をしてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなんだかそれを引き抜いてしまうのが惜しいような気がするのでそのままにしておくと、いつのまにか母や下女がむしり取るのであった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに枝を傷つけないで袋だけをむしり取る事ができたのである。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭からこんなふうに二、三十本の髪の毛だって一緒にむしり取るには大した力のいることは君も知っているだろう。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾衣はそのひと枝を押し戴いてとって、重なり合った花びらをしずかにむしり取ると、匂いのある白い花は彼女の袖に触れてほろほろとこぼれて、うす暗い畳の上に雪を敷いた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その草の葉を肌守のなかに入れておくと、大蛇に出逢わないとか、魅まれないとかいうので、女子供は争ってむしり取る。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は僕から妹をむしり取るやうに奪つて行かうとするからだ。",
              "citation": {
                "source": "書翰",
                "author": "大正十一年九月（推定）　小島勗宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、誰が、他家の女性を愛し取らうとする場合、むしり取るやうにしないものがあるだらうか。",
              "citation": {
                "source": "書翰",
                "author": "大正十一年九月（推定）　小島勗宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると暑くもないのに体中にじりじり汗が出て頭に血が上り、腹が立って来て一日に十度も十一度も眼帯をむしり取る。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしり取るたびに強い光線がはいり、瞼の下が痛むので、いけない、と自分を叱ってまた掛けるのだった。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "数本の蔓をむしり取ると、その根本の土を棒切れで掘り返して、根まで引き抜こうとしました。",
              "citation": {
                "source": "白藤",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "外のものはとにかくと致して日本一お江戸の名物と唐天竺まで名の響いた錦絵まで御差止めになるなぞは、折角天下太平のお祝いを申しに出て来た鳳凰の頸をしめて毛をむしり取るようなものじゃ御座いますまいか。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるむところへ飛込んだ八五郎が、吉彌の身體をむしり取るのと、平次が怪人を押へるのと一緒だつたことは言ふ迄もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貫六と鉢合せをしたんで、へエ、何分暗かつたもので」「鉢合せなら、お前の額にも傷があるだらう、どれ」　八五郎の手は延びて、貫六の額から、むしり取るやうに鉢卷を取りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し下脹れの可愛らしい顏が涙に濡れて、紅い唇のワナワナと顫ふいぢらしさは、何んな剛情な平次も、折れるだらうと思はれましたが、頑固に眼を閉ぢた平次は、それをむしり取るやうにもぎ離して、「八、ガラツ八は居ないか」　縁側の方へ聲を掛けるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるむところへ飛込んだ八五郎が、吉弥の身体をむしり取るのと、平次が怪人を押えるのと一緒だったことは言うまでもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し下脹れの可愛らしい顔が涙に濡れて、紅い唇のワナワナと顫ういじらしさは、どんな剛情な平次も、折れるだろうと思われましたが、頑固に眼を閉じた平次は、それをむしり取るようにもぎ離して、「八、ガラッ八は居ないか」　縁側の方へ声を掛けるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは無慈悲な指先で、空想のバラ色の楼閣を、こなごなにむしり取るのだった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベリベリと、肩のへんも、むしり取るのです。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はただ本能から他意もなくその花をもてあそんでいたのであって、雛菊の花弁をむしり取ることはすなわち愛情を摘むことだなどとは、夢にも思っていなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれって、べつに名前は言わないけどね、この中に、自分をきれいにみせようとして、わざわざ、自分の羽をむしりとるメンドリが、一羽いるのよ。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "小心な伊助は気味わるく、もう浄瑠璃どころではなかったが、おまけにその客たちは部屋や道具をよごすことを何とも思っていず、談論風発すると畳の眼をむしりとる癖の者もいた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　真紀子は無理に久慈の襟から薔薇をむしりとると、捨て所を索すようにあたりを見廻していてから寝台の枕の傍へぽいと投げた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後――雨に濡れた青紫蘇をいっぱいに積み上げた中で、清江はその葉を一枚ずつむしりとる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらあたりから屑鉄屋、鋳物工場、機械工場といろんな下請工場がどっさりあって、その金網つきの真黒によごれた窓の下で日中働いている若い男たちの青春を撫でながらむしりとる触手のように、カフェー街が刺戟的な色をぶちまけて並んでいるのであった。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、唯一人の旅人として、村から村へ、木馬の道や、桟道を踏み越え、禰宜からみようど、宿老・老女の居る屋敷と言へば、新百姓の一軒家までも尋ね入つて、重い鈍い口から、答へをむしりとる様な情熱が、組織を生んだのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、爆薬で黒くよごれた花片をむしりとると、器用な手つきで、それを顕微鏡にかけて、のぞきこんだのであった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（頭の包帯をむしりとる）あんたがた古い殻をかぶった連中が、芸術の王座にのしあがって、自分たちのすることだけが正しい、本物だと極めこんで、あとのものを迫害し窒息させるんだ！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
