        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きのふ山より摘みてかへれば、紫苑はなしぼみて、すでに秋の愁ひをさそふ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男、コーヒーを啜つて天井の隅を凝視したまゝ――右手の指に挟まれた葉巻から、冷い空気の中を薄紫の煙が細く細く立ちのぼる。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はるかに紫禁城を眺めている横顔の写真。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮屈さうに、紫檀の卓に頬肘を突いて、今まで其処に自分のゐた庭に、障子の中硝子を透して集中しない視線を遣つてゐた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の肘の前にある灰皿の中の、喫ひ終つたばかりの喫殻から登る紫色の煙と、他の古い喫殻にそれが燃え移つて出る茶褐色の毒々しい煙とが、やゝもすれば彼の顔に打つ衝かつたが、そんなことには元来頓着ない彼であつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の淡紫に湿つた土の上で、独楽はチリチリヽヽといふ微かな音を立ててシンミリ廻つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓上の鮓に目寒し観魚亭「卓」という言葉、また「観魚亭」という言葉によって、それが紫檀か何かで出来た、支那風の角ばった、冷たい感じのする食卓であることを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の窓は田園の遙けきながめにて、垣根に近き駒紫蘇の花、今ぞ日光をうけて、くれなゐの色滴らむばかりなる。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の處、年の頃十八九と見える色白の、艶然とした中形單衣、夜目にも透いて見える襟脚の確乎白きに、烏羽玉色の黒髮を潰し島田に結んだ初初しさ、濃紫の帶を太鼓に結んだ端が二寸許り、たれてその先が地に着かんとして觸れ合つて居る。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは君｜逸品古色ありと抱いて歸れば有情なりや味よきしづくの淺紫なるにけ高き千古の春を知りぬ。",
              "citation": {
                "source": "古盃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルトの空には玉子色の綿雲が流れて、遠景の広野の果の丘陵に紫の影を落す。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後二十年たってドイツのエナでツァイスの工場を見学したとき、紫外線顕微鏡でこの同じ珪藻の見事な像を蛍光板の上に示されたとき、この幼い記憶が突然甦って来るのを感じたのであった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟らかい緑の茎に紫色の隈取りがあって美しい。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、黒檀で彫刻した鬼の面とでも云ったような感じのする外殻を噛み破ると中には真白な果肉があって、その周囲にはほのかな紫色がにじんでいたように覚えている。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人はやがて紫の布に包んだ祝の品を恭しく差し出した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、なに、」と浦島は狼狽して、「この花は、この紫の花は綺麗だね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、朝な朝な、東の空の紫の雲の中に、此のお家があるといふことは確かで、皆さんが、やがて大きくなつて、皆さんのお父さんも亡くなり、お婆さんは云ふに及ばず、お母さんも亡くなつて、皆さんが今度はお父さんになつた時には、それがほんとだと分るのです。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟体動物のしやがれ声にも気をとめないで、紫の蹲んだ影して公園で、乳児は口に砂を入れる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も横浜通の紫紅兄（山崎）の批評で凹んでいるとあるのも、横浜付近の誤謬記事を指摘されたことを、付随して言ったのだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ノ池は一ノ他の半分ほどしかないが、木が茂って松蘿が、どの枝からも腐った錨綱のようにぶら下っている、こればかりではない、葛、山紫藤、山葡萄などの蔓は、木々の裾から纏繞いて翠の葉を母木の胸に翳し、いつまでもここにいてと言わぬばかりに取り縋っている。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびは霧がなかった、紫の花咲くクカイ草、蘭に似た黄色の花を垂れるミヤマオダマキが、肉皮脱落して白く立っている樅の木を、遠く見て、路傍にしなやかに俯向いている、熊笹が路には多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という寛濶な衣であろう、それをまた……おそらく、谷初まって以来であろう、燃えるような、紫の風呂敷に包ませて、出かける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "深いところは紫を浅いところは藍を流している。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰に括ってある紫の風呂敷が、揺れると、強烈な色彩の波動が、流水の震動と一つになって、寂しい谷が、ぱっとなる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう時刻だから、紫の風呂敷を開ける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕が霧の中に、小さくぼんやり見える、四ツ柱に、油紙がぺらぺらとして、田舎の卵塔場のようだ、今まで、あそこに寝ていたのか知ら……この霧と雨の中を、たった紙一枚の下に……火光がパッとさす、霧の水球が、美しい紫陽花色に輝いたかとおもうと、消えた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚味の雲の奥で、日が茜さしたのか、東の空が一面に古代紫のように燻んだ色になった……富士の鼠色は爛れた……淡赭色の光輝を帯びたが、ほんの瞬く間でもとの沈欝に返って、ひッそりと静まった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩は鋼鉄のように硬くなりながらも、イワベンケイ、ミヤマダイコンソウ、ムカゴトラノオなど、黄紫のやさしい花を、点々とその窪洞に填めながら、ギザギザに尖っている輪廓を、無数に空に投げ掛けている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
