        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしよく解った後では、全く子供のように正直一途で、子供のように純情無比の人であったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、彼のあの容貌がさうである如く、どこかに子供らしい、元氣の好い、何でも新しいものや舶來のものに憧憬をもつ、鮮新無比の感覺がをどつてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物としての室生君は、だれも言ふ如く眞に純情無比の人である。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に「思ひ出」の驚くべきはその至る所の頁をあけても芳烈無比な詩的靈魂が高調されてゐる事である。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常｜素面で居る時には、謹嚴無比な徳望家である先生たちが、醉中では始末におへない好色家になり、卑猥な本能獸に變つたりする。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは、もう出ては来ず、奥の方で琵琶を掻きならし、その子供のない太つちよの、快活無比の奥さんが鳴らす琵琶の音は少々ぞんざいで、嘲弄されてゐるやうな気持もされるのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、そのためには強烈無比、高潔至極の大生命の光照を享け、その自由暢達な働きによって自己の全能率を総動員して行くのでありますが、この妙用はまた自己一心の性能にも備わっているのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右顧左眄、雄大無比なるこの高原の絶勝を眺めながら湯本へ着いたのが、もう日が暮れて大分間が経ってからである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰れも勇気｜凛々、今日を限りにこの痛快無比の旅行と別るるのが残多いようにも思われ、またこの行を了ったという得意の念もあった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "電光艇の活動の原因となるべき十二｜種の藥液は、何時までかゝつても、此樣な孤島では製造の出來るものでなく、また、他から供給を仰ぐ事も恊はねば、吾等は爾後十｜年生存るか、二十｜年生存るか知れぬが、朝夕、世界無比の海底戰鬪艇を目前に眺めつゝも、終には、此絶島の鬼とならねばならぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と突然大檣の影から現はれて來たのは、色の黒々とした、筋骨の逞ましい年少少尉、此人は海軍兵學校の生活中、大食黨の巨魁で、肺量五千二百、握力七十八、竿飛は一｜丈三｜尺まで飛んで、徒競走六百ヤードを八十六｜秒に走つたといふ男、三｜年の在學中、常に分隊の第一｜番漕手として、漕力天下無比と云はれた腕前。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻、微醉の面、妖艷無比、令史を見て更に驚かず、そんなものはお打棄りよと。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖艷無比で、猶且つ婦人の背を抱いて居る。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、かえって無比の精鋭を思わせて、颯と掉ると、従って冷い風が吹きそうである。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は湿気が多く、蒸暑いことで世界無比といわれているし、春は空が低く憂鬱であり、冬は紙の家の設備に対して、寒さがすこしひどすぎる。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　生活 Life という言語が、日本に於てそうした卑近の意味に解されるのは、日本人そのものが非常に――おそらくは世界無比に――現実的の国民であって、日常起臥の身辺生活以外に、いかなる他の Life をも考え得ないからである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公平に考えて、日本の美術は世界無比のように思われる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば我が王朝の歌人｜在原業平は、日本無比な情熱的な恋愛詩人で、かつ藤原氏の専横に鬱憤しつつ、常に燃ゆる反感を抱いていた志士であり、あたかも独逸の詩人ハイネに比すべき人であったが、彼の和歌はそれ程でなく、人麿や西行に比し、二流であることを免かれない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説に於ける日本の自然派が、世界無比にレアリスチックの文学である如く、日本の俳句もまた、世界無比にレアリスチックの韻文である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして支那の詩の多くのものが、沈痛無比な響を以て人生を慷慨悲憤していることぞ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精悍無比の表情を装い、斬人斬馬の身ぶりを示して居るペテロは誰。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に思ひ切つたる豪胆無比の御裁決、三浦さまほどの御大身も何もかも、いつさい、御眼中に無く、謂はば天理の指示のままに、さらりと御申渡しなさる御有様は、毎度の事とは申しながら、ただもう瞠若、感嘆のほかございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、高潔無比のお心をあてにしながら、ひと思ひに私の運を、あなたのお手にゆだねます。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、高潔無比のお心をあてにしながら、ひと思いに私の運を、あなたのお手にゆだねます。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵を伏せて敵を誘ひ、奇を以て勝を制し、重囲を突破して、千里に横行する、痛快無比の状を叙せり。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "世にいふ神風もさることながら、尽すべきことを尽して蒙古勢を撃破し得た執権時宗の胆と、皇軍の忠勇無比とがこの篇の眼目となるのである。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本流と可児川の合するところ、急奔し衝突し、抱合し、反撥する余勢は、一旦、一大｜鉄城のごとく峭立し突出する黒褐の岩石層の絶壁に殺到し、遮断されて水は水と撃ち、力は力と抗い、波は岩を、岩は波を噛んで、ここに囂々、淙々の音を成しつつ、再び変圧し、転廻し、捲騰し、擾乱する豪快無比の壮観を現出する。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その淫蕩無比の臭気、その狂熱、その豊満、将に此の樹木の放つ動物的精液の激臭は下ゆく人をして殆ど昏倒せしめずんばやまなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ今朝いつもの肉汁を、呑むひまもなく来てしまった。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにあれがみんな星だと、いつか雑誌で読んだのでしたが、このごろはジョバンニはまるで毎日教室でもねむく、本を読むひまも読む本もないので、なんだかどんなこともよくわからないといふ気持ちがするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
