  {
    "uuid": "6ce32158-7ce1-5211-9afd-fdc3dc73b426",
    "entry": "斑",
    "reading": {
      "primary": "むら",
      "alternatives": [
        "ムラ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unevenness (of colour, paint, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黒点誰でも太陽をジツと視た者は目の前を、自分の周囲を空気の中を鉛色の斑点が飛ぶのをみる。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤煙くもる裏街の貧しき家の窓にさへ斑黄葵の花は咲きたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎なり昇降機械の往復する東京市中繁華の屋根に琥珀の斑なる毛皮をきて曠野の如くに寂しむもの。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、寒月の冴えた夜などに友達の家から帰って来る途中で川沿いの道の真中をすかして見ると土の表面にちょうど飛石を並べたようにかすかに白っぽい色をした斑点が規則正しく一列に並んでいる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しくなって眼を庭の草へ移すと大きな黄色の斑点がいくつも見える。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウダンツツジの葉と、背向きになって、翠い地紙に、赭っちゃけた斑が交ったようだ、何枚も、何枚も、描き捨てられた反古のような落葉が、下に腐って、半ば黒土に化けている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻に敷いた褥は、可愛らしい高山植物で、チングルマの小さい白花、アカノツカサクラの赤い花などが、絨氈の斑紋になって、浮き上る、焚火の影に、鮮やかな織目を見せる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前には、雁木の凹みのように、小さな峰が分れて、そこから日本アルプスの禿げた頭が、ぐいと出ている、雪の線が二筋三筋ほど、芒に白い斑が入ったように、細く刻まれて、荒ららかな膚に、美しい白紐を引き締めている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ戻って、友人にハガキを書いていると、富士の雲が引いて取ったように幕を明け、銀磨きの万年雪が、巨獣の斑紋のように二筋三筋キラリと光って、夏の富士にして始めて見るところの、威嚇的な紫色が、抜打に稲妻でもひらめかしそうに、うつぼつと眉に迫って来る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は言うまでもないとして、三月四月頃、試みに郊外に出て見給え、遠くに碧い山か、斑らな雪の縞を入れて、菜の花の末、または青葉若葉の上に、浮ぶように横たわっている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬い岩石は、例えば、甲州アルプスで金峰山（二五五一米突）の五丈石、鳳凰山（二七七九米突）の地蔵仏は、結晶岩なる花崗石で、飛騨山脈の槍ヶ岳（三一八〇米突）は石英斑岩の硬石である。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く裾野には稻田の黄色い斑の縞模樣が擴がり、其の遙かな向うには名を知らぬ山脈が盛上がつて、其の山腹に刻まれた褶襞の影日向が深い色調で鮮かに畫き出されて居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此邊迄來ると紅葉がもうところ斑に色付いて居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は濃緑に朱の斑点のはいった草の葉をいじっているから「オイよせ、毒かもしれない」と言ったら、あわてて放して、いやな顔をして指先を見つめてちょっとかいでみる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その痰の斑には濃い緑色のところと、黄緑色のところと、粘り白いところとある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の島の岸杭がちょっと虫ばんだように腐ったところへ渡り鳥のふんらしい斑がぽっつり光る。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに黒い斑々がある。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の白い斑が終りにちらっと見えました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼自身の筆によらない限りその一斑をも窺う事はおそらく不可能な事に相違ない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "背のあたりに白斑二つ三つある赤毛のめす子である。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて二十箇月後に階段から転がり落ちて、頭に青や黒の斑点が出来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば眼の辺には紺青色と真珠色の光を放ち、腹部にはルビー色、雪白色および空色の光斑を具えている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女達のＣの字に曲った衿元の黒い皮膚から噴火した火山灰が、流浪する女の生活の斑点となっているのを見るのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "斑なシュミーズをつけたレムブルグの女弟子が部屋に飛込むと陳子文がバルコニで自殺したことを告げた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は尻のところに縫模様のある緑色の部屋で踊子のベッドに寝ころんで天井に口汚く附着したシャンパンの斑点をみつめながら、病み果てた病人のように透徹した頭脳であわただしく過ぎて行った赤い歴史をめくるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "首からぶらさげた三角のナフキンに、茶褐色の斑点をつけてミサコが云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして穴がすつかり埋められてしまふと、蜂は暫く穴のまはりを歩きまはつてゐたが、やがてぷうんと翅音を立てながら、黒黄斑の弧線を清澄な秋の空間に描きつつどこともなく飛び去つて行つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ白猫の母は宅の飼猫で白に雉毛の斑点を多分にもっていたが、ことによると前の白猫と今度の「白」とは父親がおなじであるか、ことによると「白」が「ボーヤ」の子であるかもしれないと思われた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地宮沢賢治焦ぎ木のむらはなほあれば山の畑の雪消えて〔以下なし〕　――――――――青年団が総出にてしだれ桜を截りしなり",
              "citation": {
                "source": "開墾地",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいそうな虫』と寂しげに言い、この頃の暖かい日に、そっと草むらの中に放してやれ、と家人に言いつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
