    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gathering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ十字疾行する街路のうへそのするどさに日輪もさけびくるめき群集をこえて落しきたるを感じいのり齒をくひしめ受難の日のひくれがたわれつひに蛇のごとくなりて絶息す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔洪積の台のはてなる〕宮沢賢治洪積の台のはてなる一ひらの赤き粘土地桐の群白くひかれど枝しげくたけ低ければ鍛冶町の米屋五助は今日も来て灰を与へぬ。",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雲ふかく　山裳を曳けば〕宮沢賢治雲ふかく山裳を曳けばきみ遠く去るにかも似ん丘群に日射し萌ゆればきみ来り訪ふにも似たり",
              "citation": {
                "source": "〔雲ふかく　山裳を曳けば〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私はといへば、まもなくすれば行く手の空に吸はれて了ふのだといふふうな気持で、群集といふ伴奏附きで泳いでゐるやうなものなのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚤ガ群ッテ集マルノデ眠ルノハ少シムツカシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それから妻子や家庭やの一切を捨て、自由な漂浪者の群に入りたいこと。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして眞黒の群衆が、何十萬とも數知れずに押し合ひながら、お玉杓子のやうに行列して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られぬ或る日、或る一隅に於ける諸君の美しい行為は、かならず一群の作者たちに依って、あやまたず、のこりくまなく、子々孫々に語り伝えられるであろう。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハータ、ターコ、コーマ、ハート……」そこまで読むと彼女は、ほんの今まで見てゐた、群から一寸外れて歩いてゐた蟻は、もうどのへんに行つただらうと思ひながら柿の樹の根元を見る。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、達沢が教頭席に腰を下した儘、前方のゴタゴタした一群れ――それは何か分らぬ――に向つて、その太い腕を得意気に振廻してゐる光景のみが、彼の目に見えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年同人雑誌「白痴群」を出す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立や草葉を掴む群雀　急の夕立に打たれて、翼を濡らした雀たちが、飛ぼうとして飛び得ず、麦の穂や草の葉を掴んでまごついているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にこの師走の市へ行く鴉　年暮れて冬寒く、群鴉何の行く所ぞ！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで clouds of flowers は、さうした西洋草花の群生してゐる花壇か、もしくは花輪や花束の集団をイメーヂさせる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今、この訳詩を読んだ西洋人の心象には、耶蘇教寺院のベルが鳴つてる町の通りを、美しい花輪や花束の群が、雲のやうに行列して行く光景、即ち葬式のイメーヂが浮んだのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊園地にて遊園地の午後なりき樂隊は空に轟き※轉木馬の目まぐるしく艶めく紅のごむ風船群集の上を飛び行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るき四月の外光の中嬉嬉たる群集の中に混りてふたり模擬飛行機の座席に乘れど君の圓舞曲は遠くして側へに思惟するものは寂しきなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女等群がりて卓を圍み我れの醉態を見て憫みしがたちまち罵りて財布を奪ひ殘りなく錢を數へて盜み去れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇天暗く埠頭に觀衆の群も散りたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は孤独で居れば居るほど、夜毎に宴会の夢を見るようになり、日毎に群集の中を歩きたくなる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を打たれて芳は危く昏倒せんとして、僅に身を支へた、其處を、勝に乘じた群衆はなほ、執念強く、取り包んで、凡そ息のある限り、滅多無性に打ちすゑんとする、刹那の急。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芳……芳ちやん』群集を振り返た時にはおろおろ聲で眼が血走つて居る。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥萩原朔太郎夕ぐれてほの痒くなる指のさき坂をくだれば一群の鳥は高きをすぎ行けり。",
              "citation": {
                "source": "鳥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の往来が織るような街の両側の人道の並木の下には手を組んだ男女の群が楽しそうに通っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の御座船「長蛇」のまわりには敵の小船が蝗のごとく群がって、投げ槍や矢が飛びちがい、青い刃がひらめいた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷像の方へ行きたれども書生の群多くてうるさければ引きかえしパノラマ館裏手の坂を下る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾り気一点なきも樸訥のさま気に入りてさま／″＼話しなどするうち京都々々と呼ぶ車掌の声にあわたゞしく下りたるが群集の中にかくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
