        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "電車通で息子さんを連れた大宮春枝夫人に會ふ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの自分ならあれほど息子さんのために心を碎いてゐる春枝夫人のために進んで家へ戻つたに違ひなかつたから。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月御命日に欠かさず拝みにお出でなさるのは、あの経師職の息子さんばかりで……」「経師職の息子さんは毎月来るかね」「はい、お若いのに御奇特なお方で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの息子さんが十日ばかりも前から、どこへ行ってしまったか判らないんですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「息子さんは不埒が分って勘当かい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その息子さんが新しい法学士なんですって……そこからね、是非、お嫁さんに欲いって言ったんですとさ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その関係で息子さんの米斎君が、舞台装置をやったり、背景を画いたりなすったのです。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたに、そんな大事な息子さんを。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは金魚屋さんの息子さんの癖に、ほんとに金魚の値打ちをご承知ないのよ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、ひとり息子さんだからな、それも無理はない」　かの女は他人のことばかりに思いやりが良くて、自分の息子には一向無関心らしい老紳士が、粗っぽく思えて興醒めた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたんとこの息子さんを、モンパルナスのキャフェでよく見かけますよ」と、薄い旅費で行脚的に世界一周を企て巴里まで来て、まだ虚勢とひがみを捨て切らない或る老教育家が、かの女等の親子批判にいどみ込んで来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっそり洋室にのがれて来て、ひとりで泣いて、あっぱれ母親思いの心やさしい息子さん。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母車をおして来たのは爺さんの息子さんだった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは息子さんに、町までつれていって鐘に一目あわせてくれ、と頼んだが、息子さんは、仕事をしなきゃならないからもうごめんだ、といって、お爺さんののった乳母車をおして、門を出ていった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちはお爺さんの息子さんにわけを話して、お爺さんをこちらへ受けとった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出ようとすると、老人の息子さんが、海蔵さんのあとを追ってきて、「うちの親父は、がんこでしようがないのですよ。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、出て来た息子さんがいいました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、わしはここから帰るとき、息子さんから、あなたが死ねば息子さんが井戸を許してくれるときいて、悪い心になりました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご両親はああ見えていても油断なく、立木のような高いところから息子さんのあなたさまを見張っていらっしゃるんですぞ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、お料理店の息子さん？",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――どんな息子さんだったの？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこの息子さん感じわるいのん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「蝙蝠傘の骨を修繕したはった人の息子さんや」　君枝はくすんと笑った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "松浦王の息子さんですもんな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "多代子さんの郷里の実家は両親ともに死んでしまって、総領の息子さんが――台湾で死んだ透さんの兄です。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの家は息子さんでは持つて行けますまいよ」と云う風評を耳にした妻は、ます／＼躍起となつて、所天の名譽を恥かしめまいといふ働きをやつてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのむすこさんは、もうきっとどこかの書記になってるんでしょう。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少佐は、その会社の、かなり上役になり、むすこさんもりっぱな青年になりました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、今の大だんなの七郎兵衛さんと、ご沈落しなさっている兄の八郎兵衛さんと、このおふたりが成人なすったときにも、先代の親ごさんていうのがさっそく言い伝えどおり、それぞれむすこさんにお嫁をめとらしたんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ふたりのむすめをよんで、どちらがむすこさんのおよめになるかきいてみよう」といって、まず姉のむすめをよび出しました。",
              "citation": {
                "source": "たにしの出世",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
