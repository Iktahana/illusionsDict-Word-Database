  {
    "uuid": "55842aea-dd87-516f-ac7c-b51e55116660",
    "entry": "無教会",
    "reading": {
      "primary": "むきょうかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
      "ctype": null,
