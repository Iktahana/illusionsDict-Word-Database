    "definitions": [
      {
        "index": 1,
        "gloss": "one's son and his wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
