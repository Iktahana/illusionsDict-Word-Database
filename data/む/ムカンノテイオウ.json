    "definitions": [
      {
        "index": 1,
        "gloss": "person who has not won any major awards or titles despite being the best in a particular field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三十餘年間支那に居つたスミスといふ米國の宣教師は、曾て支那の教師は無冠の帝王であると評したことがある。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その「無冠の帝王」説を回顧するときは、記者自身大なる誇を感ぜざるを得ない。",
              "citation": {
                "source": "科学的新聞記者",
                "author": "桐生悠々",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今年幾歳になるか知らぬが、十六の時から詩を作り、二十の頃初めて「無冠の帝王」といふ戯曲を書いた。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無冠の帝王」は千九百六年に上演されてゐる。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の木鐸、無冠の帝王という言葉が流行したのもこの頃で、それ等の卒業生の数が増大するにつれて、政権からはなれた大隈に対する民間の人気はいよいよ抜くべからざるものになってきた。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
