        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白いハンカチが胸ポケットからはみ出ている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　万年筆だのエヴァシャープだのを胸ポケットにさしている年配のが、落着いたような声で云った。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出する時は、上衣の胸ポケットから絹麻のハンカチを覗かせ、籐のステッキを携えた。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は上衣の胸ポケットのハンカチで、決して使わないつもりだったハンカチで、汚れた手を丁寧に拭き、そのハンカチをズボンのポケットにつっこんで、しっかり立ち直った。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛の歯跡が目立たぬほどに髪をふわりと梳かし、空色の縁取りのあるハンカチの耳を上衣の胸ポケットから覗かしていた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪をきれいにポマードで光らせ、格子柄の茶色の背広をきっちりまとい、胸ポケットから真白なハンカチをのぞかしてる、三十歳前後の好男子なのだ。",
              "citation": {
                "source": "朝やけ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大した会社でもないらしいがその社長で、商工省の何かの囑託をしてる彼は、機嫌のよい時には、チョッキの胸ポケットに親指をつっこむ癖がある。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は、私の胸ポケットに持っている物だと思うのです。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――胸ポケットを大威張りで叩いた。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、私はここに」――彼はここで胸ポケットをたたいた――「旧司令官のこの装置に関する図面をもっております」「司令官みずからの図面ですか」と、旅行者はたずねた。",
              "citation": {
                "source": "流刑地で",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "コードバンの靴にスフ入りの背広で、万年筆はチョッキの胸ポケットへさすものと初めて会得して、颯爽と出発いたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸ポケットの紙きれを見つけ、多少無頓着に調べ始めた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの手でやろう」　ディレクターは陽子たちの方へ歩み寄りながらサングラスをはずして胸ポケットにしまった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はすぐにはあがろうとせず、モーニングの胸ポケットから、一枚の大きな名刺を出して島さんに渡した。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のシャツの胸ポケットに、金平糖の入った小さな紙の箱をひとつ、おばさんは入れてくれた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "達者だよ」「妹も」「あれはいつだって元気だ」「ぼくが会って来た人たちも、元気だったよ」　シャツの胸ポケットから、ぼくは写真を二枚、取り出した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャツの胸ポケットには、黒いビニールのケースにおさめた眼鏡が入っている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服のままで、シャツの左胸ポケットには、名札もつけたままだ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着古したデニムのショート・ジャケットの胸ポケットから、皮の名刺入れのようなものを、ひっぱり出した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミ、この原稿の小切手が今必要か」「ああ、すぐ現金でもいいよ」　シンプソン編集長が小切手に当該金額を書いてフィリックスに渡すと、桃色の紙を折り畳んで胸ポケットに入れ、それから話は別な方面に移っていった。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクスウェルが横から覗くと、手紙を胸ポケットに入れるのが見えた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物といこう」　もしサトーリスが警部補の胸ポケットにある逮捕状を知ったら、こころ穏やかじゃなかったろう。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、二晩前、自宅前でぶち当たった冷静なあの男、いま胸ポケットに持っている本を落としたあの男と同一人物だもの。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランペンが左の胸ポケットに手を突っ込み、分厚い銀時計を取り出した。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと胸ポケットから絹布を取り出し、両目を拭き、明かりがまぶしいかのようにした。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
