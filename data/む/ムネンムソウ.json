[
  {
    "uuid": "5a8af9cf-442b-5e8f-8e25-d73de0ffd7a5",
    "entry": "無念無想",
    "reading": {
      "primary": "むねんむそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
