    "definitions": [
      {
        "index": 1,
        "gloss": "sense of helplessness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
