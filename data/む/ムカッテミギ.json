    "definitions": [
      {
        "index": 1,
        "gloss": "on the right as one faces (it)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
