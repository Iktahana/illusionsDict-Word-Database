    "definitions": [
      {
        "index": 1,
        "gloss": "wheat sheaf",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして麦束はポンポン叩かれたと思うと、もうみんな粒が落ちていました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂先へ火のついた麦束を片手に翳して燃やしながら、片手に別の束をとつて其燃やして居る穂先から火を移す。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "短くなつた燃えさしの麦束はぽつと傍へ投げ棄てる。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふと燃えさしの麦束の散らばつたあたりに地にひつゝいて白い花の簇がつて居るのを見た。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃やして棄てた麦束は此の間の儘ぐつしよりと湿つて居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯呑の一つに赤旗を背景に麦束をかこんだ鎌と鎚の模様がついていて、黒い文字で「万国のプロレタリアート、結合せよ！",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっしりとした門にソヴェト同盟の国標、鎚と鎌をぶっちがえにしたものを麦束でとりかこんだ標がかかげてあり、その上に、ドン国立煙草工場と金字で書いてある。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰好のいい向日葵のいつぱい咲き乱れた菜園の上には、翠玉石いろ、黄玉石いろ、青玉石いろ等、色さまざまな、微細な羽虫が翔び交ひ、野づらには灰いろの乾草の堆積や黄金いろの麦束が、野営を布いたやうに、果しもなく遠近に散らばつてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにソヴェトの国標、槌と鎌とのブッ違えを麦束で囲んだ標とソコリニチェスキー区第二人民裁判所という字が書いてある。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腹が痛えって、何時から――」　おさよが近づいて説明するには、その朝言いつけられたとおり、まだ扱かない小麦の束を庭へひろげて乾していると、おちえと二人で小麦束の中へ入って歌などうたっていたが、急に黙ってしまって、縁側へ戻るなりそこへ突っ伏して、しくしく泣きだした。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　庭先に干した小麦束を片づけていたおさよは、言われるなり裏の家へ行って、軒下に乗りすててあった自転車をひっぱり出した。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」それは前の日、干しならべた小麦束の中でおちえから教えられた一節だった。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "山と積んだ麦束のそばに懐をあけて、幼い嬰児に乳を飲ませている女もある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生命をつなぐために、沢山な麦束の中から、僅かな一穂をとったからとて、決して罪になるものでない。",
              "citation": {
                "source": "文化線の低下",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈取った麦の束を両わきに抱え込み、ムシロの方へ行き、積んである麦束の上に麦をおろす。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓　ハハ、出しぬけだもんで、へえ――（クスクス笑いながら仕事場の方へ行き、麦束を置く）青年　（これも笑いながら、それについて五六歩行く）……麦ですか。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（相手がマジマジ見ていることなどにとんちゃくなく、拭き終った手拭いを今度は姉さまかぶりにして、さあてと言った顔になり、黒い両手にペッペッとつばきをくれて、麦束の方へ）青年　……（フッと笑えて来る）百姓　んだが、この辺じゃ、別に見るようなとこも無え。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちを見ても此方を見ても、へえ、唐松林と山ばっかりでな、（麦束を取って、片足でシッカリと千歯の踏板を踏んで、麦の穂をこき落しはじめる）青年　はあ、……（おかしさが止らず、声を出してクスクス笑う）……百姓　珍らしいもんなんぞ、何一つ無えづら。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と千歯の歯に引っかかった麦束の穂を力まかせに引き抜く）青年　……近頃は、しかし、増産々々で、やかましいようで――百姓　……うむ……増産かい。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（困って、手持ぶさたで、積んである麦束に近づき、なんとなく、麦束を取り上げ、それをこく真似をする。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に麦束を握ったまま）青年　……借りて来たリュックですからね……そいつが、また、なかなかやかましい山男で……ほころびをさせたりしていると、説教だ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年　ハハハ……（立ちあがって、黙って麦束を掴んで千歯に寄る。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言いながら千歯の方へ）女　へえ……（そこらに落ち散っている小枝を掻き集めにかかる）百姓　……（自然な動作で、麦束を中年男から受取って、こき始める。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも――（言っている所へ、奥の麦畑の方から刈り取った麦束のかさばったのを、荒縄で引っかけて背負いにした百姓が、前こごみになってユサユサと戻って来る。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……百姓は千歯の傍の所で、荷物ごと仰向けにひっくり返るような具合にして麦束をおろす）百姓　どっこいしょと！",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓　……（それには返事もせず、麦束を一つ取って千歯にかけながら、いきなり話し出す）へえ、昔なあ、板橋の下の宿に五兵衛と言う半百姓の猟師がいた。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦焼きの煙が、青く活き活きした大空に立ちのぼり、輝かしい焔の上を飛び交う麦束や、赤く火照った幾つもの顔が、畑地のあちらこちらに眺められた。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ今度は麦束の中へ入って腐らしてやれ。",
              "citation": {
                "source": "イワンの馬鹿",
                "author": "SKAZKA O IVANE-DURAKE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで小悪魔はライ麦の畑へ行って、麦束の中に入り込みました。",
              "citation": {
                "source": "イワンの馬鹿",
                "author": "SKAZKA O IVANE-DURAKE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
