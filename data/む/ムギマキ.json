[
  {
    "uuid": "72e1be03-9ea0-57b7-82ab-2b153469c4f0",
    "entry": "麦蒔",
    "reading": {
      "primary": "むぎまき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wheat planting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして直ぐに麦蒔きである。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ばあさんは麦蒔きに、畑へ出かけしなに、じいさんにそう云って、「紋」を細紐で柱につないでおいた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、十一月に麦蒔きが始まった頃である。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿取、麦蒔、大根取などに、多くの男共や女共と一しよに野良に働いた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日には広い畑に出てなれぬ仕事、稲こぎや麦蒔きなどの手伝いなどもできるくらいになりましたから、あまり心配しないで下さい。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かゝる悪事を為すかと云ふに、若し麦蒔を為したる地なれバ其種物及肥料代価、手間代の払渡をせざる可らざるが故に、極力農事を妨げて買収価格の低減を計らんとする猾策に外ならず。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "村民之を見て大に驚き、堤防出来ざれバ麦を蒔くも収獲の見込なしとて麦を蒔かず、有志ハ其季節を失はんことを恐れ日夜奔走して麦蒔を勧誘せり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶麦蒔を為すものある時は間牒の徒之を嘲笑して暗に妨害を試み、可憐なる良民を惑乱して明年の食料たるべき麦の蒔付を為さゞらしめ為めに豊沃の畑地ニ多くの空地を生ぜり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に有志の勧誘によりて麦蒔を為すものも仕方なくして蒔付をすることなれバ、肥料を用ひざるものあり耕さずして蒔くものあり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の俳句にも接木とか麦蒔とか人事句は沢山あるが、夫等は人間を配合した季題の面白味を主としたもので、之に反し近代的な日常生活を中心におき、其真を把握する事に努力して、季感は副の感がある。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "また其れよりも農家の一大事、月の下旬から来月初旬にかけて、最早麦蒔きがはじまる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋の麦蒔に馬糞を基肥に使った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月は麦蒔の畑打ちに忙しい。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の卯之吉が小麦蒔くのがツマラヌでも無い。",
              "citation": {
                "source": "地蔵尊",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東が白むと万作一家三人｜直と起きて、霞が浦の水掬いあげて顔を洗って、日輪さまを拝んで、それから鳥屋を明けて鶩を出してやるのがお光の役で、万作は時節相応鯉鮒鰻などの釣に出掛けることもあれば、網曳に雇われて行くこともあり、時々はまた鴨を猟りに行くこともあり、さもなければ裏の畑に麦蒔き大根作ることもある。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もはや陽暦の三月、四月頃から畑を耕してぼつぼつ麦蒔にかかる。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦蒔やいつまで休む老一人しまひまで見ずに廻状年の暮十一月十七日　大崎会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦蒔に夕日を配した句は、この外にもなお「麦蒔のうしろ淋しき入日かな　支庸」「麦蒔の影法師長き夕日かな　蕪村」の如きものがある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日の暮れやすいことも固よりではあるが、麦蒔頃の野良の寒さが、何となく夕日の名残を惜しませるのではないかと思う。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦まきの寒さや宿はねぶか汁　　　　鼠弾　蕭条たる冬枯の野に出て麦蒔をする。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句はそういう麦蒔の人の寒さと、その人たちがやがて帰る家で、葱汁を拵えて待っているという事実を描いたのである。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦蒔をおえて寒い野良から帰って来る。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
