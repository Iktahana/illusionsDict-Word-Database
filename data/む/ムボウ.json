[
  {
    "uuid": "7e9356d8-9ef1-5419-a962-380c3a56cf2e",
    "entry": "無帽",
    "reading": {
      "primary": "むぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
