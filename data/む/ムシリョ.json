    "definitions": [
      {
        "index": 1,
        "gloss": "thoughtlessness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
