    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come to nothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の意志や感情やを、真によく対手に呑み込んでもらうためには、対手が自分の親友｜知己であり、自分の心持ちや性格やを、充分によく知っているものでない限り百万言を費して無駄になる場合が多い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一五課　無駄「自分がいくら骨を折って行っても、することなすことみな無駄になる」　苦学をして勉強していた一青年が、こう歎じました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、そうしないと、鳥も無駄になるだけでしたので。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「時間が無駄になる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論注視した時の方が、目に受ける光線は量は多いが、それを感ずることが鈍いから無駄になる。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日の奔走が無駄になると、父はもう自棄を起したのであろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも一反づゝ買へば、やつぱり当り前に四幅に五幅の大きさにしなければ布が無駄になる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日の奔走が無駄になると、父はもう自棄を起したのであらう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからまた転載した罪をもつて傍杖でも食ふやうな事になると折角私が骨折つて働いたのが無駄になるから止めて置く。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "當てができさへすれば、無論、それを横取りして置くと云ふそんなさもしい不人情な考へは少しもなかつたけれども、できない場合には、もう、何としてもできないのだらうから、今どんな約束をして置いても無駄になることが分つてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで、そちが、ここにおっては、大事の書状が無駄になる。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じきになおるから、一日分ずつでいい、二日分もらっても無駄になるから」　これはいかにも道理ある言葉であった、どういうわけか医者は二日分ずつの薬をくれる、それも一つはかならず胃の薬である、金持ちの家は薬代にも困らぬが、まずしき家では一日分の薬価は一日分の米代に相当する。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ死んでしまえば用のない品物だから、この自分が「相続」して金に換えるんでもなければ無駄になると考えたのだろう。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを過ごすと無駄になる。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かくれんぼなんぞ止しちまへ、と思つて、机の下から這ひ出ようとしましたが、あひるさんに見付かると、せつかく、今まで辛抱したのが、無駄になるので我慢しました。",
              "citation": {
                "source": "かくれんぼ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、今夜行ったら、又明朝が無駄になると思い、明かに我が心を励して、片づけを仕舞う。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "でないとこの十枚の短冊が無駄になるのはかまわないとしても、愚図々々していると胃袋の虫が承知しなくなる』　居候関係は、高崎をたつと同時に一応解消して、三人は平等の人間になったようなものの、玉汗の言葉は依然として重きをなしていた。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角買つたお弁当が無駄になるけど……。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの掘りかけの穴に費やした労働が無駄になるんだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はビスケットもチーズもチョコレートも、とても二度や三度では食べ切れぬ位持っていたが、もし晩飯が出来ているんだと無駄になると思い、折から通りかかったＢ中尉に「晩飯はどうしたものでしょうか」と聞いて見た。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし赤格子が殺されたら、俺の使命は無駄になる。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを探すのに使う時間くらい、無駄になる時間はない。",
              "citation": {
                "source": "自由と進歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分再製されているのであろうが、無駄になる部分が、相当多いことであろうと想像される。",
              "citation": {
                "source": "紙の洪水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして上手に錫を被せないと貴方の仕事はすべて無駄になる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あってはせっかくの旅が無駄になる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙を受け取らない前にお延が病院へ来てはせっかくの努力も無駄になるだけであった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間が早いか遅いかだとその巣はからつぽで、その遠足は無駄になるかも知れないのです。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局差引商売だけの経費が無駄になるわけである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お辨當がむだになるぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お弁当がむだになるぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
