[
  {
    "uuid": "3e99b4c5-fdfc-584a-ba67-334c3f19f14e",
    "entry": "無二",
    "reading": {
      "primary": "むに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "peerless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「でも予想してみてもつまらない」、で、私は遮二無二読み始めたが、殆んど頭には這入つて来なかつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術は、いやなので無二膏といふ膏藥を患部に貼り、それだけでも心細いので、いま流行してゐるらしい、れいの「二筒のズルフオンアミド基」を有する高價の藥品を内服してみました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのレールの上を、今、円筒形の、途方もなく大きい列車が、まるで星に向つて放たれたロケットのやうに、遮二無二走つて行くのでした。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩地氏は田中氏とは生前無二の親友であつたのみならず、その芸術上の信念を共にすることに於て田中氏とは唯一の知己であつたからである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六「これッ何を申す」と言っても団九郎、　無二無三と斬って来る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒は、誰れの手先に使われているか、何故こんな馬鹿馬鹿しいことをしなければならないか、そんなことは、思い出す余裕なしに遮二無二に、相手を突き殺したり殺されたりするのだ。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山は雲の中、僕は雲に登る積りで遮二無二登つた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒は無い力まで搾って遮二無二にロシア人をめがけて突撃した。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の俥から、三十がらみの纏足の女がころげるように跳びおりると、無二無三に群集の垣に突き入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、遮二無二、娘を奪い出そうと考えていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "危く、蒙古犬に喰われそうになっていた浜田たちは、嬉しげに、仲間が現れた、その方へ遮二無二に馳せよった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると猫は大胆にも枕の上へあがって来てまた別の隙間へ遮二無二首を突っ込もうとした。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、科学者の考え方は唯一無二のものではない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたここに少しちがった立場に立つものの見方からすると、このような区別は必ずしも唯一無二ではないのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて上記の考え方では、連句の長句一つ、短句一つを、それぞれの一つの音に比較するという前提のもとに考えを進めたのであるが、これは多くの中の一つの考え方であって、唯一無二の考え方ではない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に余儀なくされたばかりでなく、それにたよることを最上無二の方法であるとさえ信じていた。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも軽く意表の外に姿を閃かすお涌の姿を柳の葉の間から見て、皆三はとても自分と一しょに遊べるような少女とは思えなかった……だが、そういう少女のお涌が持って歩き出したあの黄昏時の蝙蝠が、何故ともなく遮二無二皆三には欲しくて堪らなくなったのだ。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は、そうなると、却って猛勇を奮い起し、遮二無二翼を早めて、太陽を目がけて、飛びつこうとしました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　無二の味方で頼母しく慰めた。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から一天俄に掻曇りて、※と吹下す風は海原を揉立つれば、船は一支も支えず矢を射るばかりに突進して、無二無三に沖合へ流されたり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈の雨中突進、遮二無二登りつめれば中禅寺の八丁平なり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は未だ此大佐とは甞て面會した事は無いが、兼て聞く櫻木海軍大佐とは無二の親友で、また、私の爲には終世忘るゝ事の出來ない、かの春枝夫人の令兄――日出雄少年の爲には叔父君に當つて居る人。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の様な調書が存在して居て、それが裁判所の証拠資料の唯一無二なるものであるとすれば、被告はどこにも逃るゝ途はない。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というをも聞かず、無二無三に推込めば、「ええ、此奴等。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子が夫、在世のみぎりは伯のために無二の忠臣なりければ、それが死去せし後も未亡人に目を懸けたまい、深川家一切の後見をせり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一刻も早く東京へ――唯その憧憬に、山も見ず、雲も見ず、無二無三に道を急いで、忘れもしない、村の名の虎杖に着いた時は、杖という字に縋りたい思がした。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて町はずれの狭く急なる曲がりかどを争うと見えたりしが、人力車は無二無三に突進して、ついに一歩を抽きけり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "み佛は恩怨無二と説かせられた。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱　　恩怨無二……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも本道から西へ入ると聞き伝えているので、心の急く彼は遮二無二西へと進んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
