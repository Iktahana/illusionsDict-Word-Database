    "definitions": [
      {
        "index": 1,
        "gloss": "to show in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "池上は番頭の嘉六を座敷へ迎え入れると、座につく途端に、「この人はこれで鰥暮しが好きなんだというから変ってるだろう」　と、自分と一緒に座敷へ伴い入れたわたくしに向って言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ背後に在る真鍮鋲の扉を押して開いて、私を迎え入れるべくニッコリと愛嬌笑いをした。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このため、妻とも相談の上、また古い慣例に従って、家に見知らぬ女を迎え入れることにした。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たち二人を迎え入れると、彼は戸に鍵をかけた後、黙々として傍に置いてある大きな犬小屋の中に姿を隠した。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪之丞が、障子をあけて迎え入れる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝子は古い女中のお花さんと一緒に、彼を迎え入れる支度にまごつき、次いで、玄関では、彼の荷物の少いのに却ってまごついた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一屋の隠居は半蔵らを宿へ迎え入れるたびに言った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪帰り十三人の美濃衆と同じように、陣笠割羽織に立附を着用し、帯刀までして、まだ総督を案内したままの服装も解かずにいる親しい友人を家に迎え入れることは、なんとはなしに半蔵をほほえませた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その塵埃を払って家に迎え入れる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは用心深く私を迎え入れる。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と母は子供の体に塩まいてから、それを迎え入れるのだった。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何にしてもおりんから云えば、自分がいろいろ細工をしてやっと我が家へ迎え入れる迄に漕ぎ付けた、持参金附きの嫁御寮であるから、尻の軽い彼女に逃げられないように、忰と二人で精々｜機嫌を取らなければならない訳で、猫のことなどは勿論始めから問題でなかった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様がお帰りになると、いつも子供達はそうして迎え入れるのでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、奥方の思召しを無にして、土佐守様が卑しい女を召出されるのを、そのままにもならず、柴田様とお二人が、お菊を見出し橋渡しまでなすった形なので、悉く閉口されたことでしょう」「…………」「この上は、下屋敷へ迎え入れる前に、お菊を殺す外はない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "玉の輿の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度のは、鎌鼬や自害じゃないぜ」　嫌味を言いながらも、金六は二人を現場に迎え入れる外はなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "御苦労さまで……（立って行って迎え入れる。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久美子に求婚し、家庭へ迎え入れる。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし栄介は幸太郎を、家に迎え入れるつもりは毛頭なかった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三、四歳のシューマンは、いつの世にも絶えない俗楽者流を退け、楽界に新鮮な空気と正論を迎え入れるために、同志と共に音楽雑誌を創めた。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺の僧も、彼らを悪魔視し、彼らのためにこの不幸が起ったと考えている人で、寺に迎え入れることは喜ばなかったのであるが、檀那を怖れてか、或は案内の僧の頼み方が好かったためか、結局彼らを寺の一室にかくまった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからたとい日本人の大半がキリスト教化するという如き情勢が実現されたとしても、教会によって焚殺されたブルーノの思想や、宗教裁判にかけられたガリレイの学説を、喜んで迎え入れる日本人の数は、ヨーロッパにおいてよりも多かったであろう。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、まずもって君たちをそこに迎え入れる用意をしなさい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この六十日ほど、彼らを迎え入れるための準備に、僕は走りまわった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方よく分かるでしょ、帝政下で二人のお婿さんにとって、この九十三年時代[32]の老人を迎え入れることは、そんなに嫌でもなかったのよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "お吟も出て来て迎え入れる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲、火薬、望遠鏡、医薬品、皮革、染織類、日用｜器玩の類、何でも信長は迎え入れるに吝でない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守居の面々は、城門、玄関、その他へ走り出て、主の秀吉を、歓呼のうちに迎え入れると、そこにも此処にも、「先ずまず、おつつがもなく――」「真ッ黒にはおなりなされたが、お元気はいちばいのようにお見うけ申された」「なんと、御武運のめでたさ」　と、ほっとしたような声が全城に聞かれた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は洩れ雨は漏るなという古歌にもある通り、かがやく青空の光ばかりを、差別して内に迎え入れる方法は、以前にはなかったのである。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにを好んで、餓狼の将を迎え入れる必要がありましょう」　側にいた関羽も張飛も、「その意見は正しい」と、いわんばかりの顔してうなずいた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや城中では、心ならず、情を抑えておりましたが、さてもその後は、お恙もなく」　と孔明は、兄の手をとって、室へ迎え入れると、懐かしさ、うれしさ、また幼時の思い出などに、ただ涙が先立ってしまった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
