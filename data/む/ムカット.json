          "literary": [
            {
              "text": "」　健は、初めて、ムカッムカッと云った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤る場合でないと思ってもついムカムカッと来て前後を忘却したりするのは、やはり一時的の精神の偏りを、自分で持ち直す事が出来ないという、アタマの弱点を曝露しているのではないか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムカムカッと吐き気を催すわよ。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……」　突嗟に圓朝はムカッとしたが、強いて聞こえないような振りをしていると、「へっ、一帳羅の縮緬浴衣を着ちらして、水でもはねたらどうする気でしょう。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴー　（ムカッとして）そうか。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市五郎にとっては容易ならぬ侮辱ですから、ムカッと怒って、ポカリと一つ木戸番の横面を撲りつけました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度、ドアのところまで出かけたんですが、あんまりあっけなく『そうか、だめだ』といわれたんで、ちょっとムカッとしたんで、もう一ぺん戻った。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯ができましたから……ね、相良さん」　と、今度はほんとに肩を抱いて起しかけましたが、それを聞くとどこかでまた、笑うらしい濁み声がして、「おやおや、朝ッぱらから……は、は、は、は、どうもお安くないことですな」　襟すじへスウと風が来たので、お粂はムカッとしてうしろの櫺子窓を見ました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
