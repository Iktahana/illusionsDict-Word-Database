    "definitions": [
      {
        "index": 1,
        "gloss": "Muraji (hereditary title; orig. one of the two highest such titles, later demoted to seventh highest of eight)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
