[
  {
    "uuid": "74c9fac9-9e0c-5a6c-95a7-bdcfb35e02c3",
    "entry": "群々",
    "reading": {
      "primary": "ムラムラ",
      "alternatives": [
        "むらむら"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
