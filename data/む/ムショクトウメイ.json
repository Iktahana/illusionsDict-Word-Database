    "definitions": [
      {
        "index": 1,
        "gloss": "colorless and transparent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（と言いながら一升瓶を目の高さまで持ち上げ、電燈の光にすかして見て）無色透明なるサントリイウイスキイ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、かくのごとく無色透明、しかも、この匂い。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "この昼の暑さに無色透明なウオツカが小さなリキユグラスを透かして冷たい漣を立てる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はゴム人形のやうに溌剌と無色透明な心臓を有って彼と並んで舗道を行った。",
              "citation": {
                "source": "玩具",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験第八日目には、ガラス管の中のガスは、無色透明になってしまった。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無味無臭、無色透明の世界に住みたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の高畠子爵が夫人に向って、「あれは幾つになっても無色透明だな。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらの馴染みの一行を乗せた荷馬車は、ちやうどこの時、橋に差しかかつて、彼等の眼前には、限りなく麗はしく、さながら無色透明な玻璃板のやうな、雄大な流れが展開したのである。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に若林博士は、今一度ステトスコープを取り出して、少女の心音を念入りに聴き直した上で、向うの薬棚から小さな茶色の瓶を取って参りまして、その中の無色透明な液体を、心持ち顔を反けながら、脱脂綿の一片の上にポトポトと滴しました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると全身の神経の作用が次第に求心的に凝り集まって、あるかないかわからない無色透明の結晶体みたようになってしまう。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の胸を掻き開いて、肋骨の並んだ乳の上に無色透明の液二筒と茶褐色の液一筒と都合三筒ほど、慣れた手付で注射をした。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "内側からガッチリと掛金をかけると、青年ボーイがポケットから注射器を出して、無色透明の液を一筒、寝台の上の老人の腕に消毒も何もしないまま注射した。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸くにして波静まると思えば倒影は立ち去って無色透明であったりした。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、こういった無色透明の態度や、鋭ど過ぎる頭は、往々余裕を欠くもので、そういった嫌いは若干浜尾君にもあったようである。",
              "citation": {
                "source": "徹底的な浜尾君",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来｜黴毒菌は無色透明の菌なので、そのまま普通の透視法を用いたのでは、顕微鏡下で実体を見ることは出来ません。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉は雲仙の白濁色に引かえて、無色透明、浴場も清潔なので入り心地がよい。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コンコドスって無色透明なのかい」　私は変な酒を飲まされてはかなわんと思って念のために訊ねた。",
              "citation": {
                "source": "地獄街道",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、そのとおり……」と彼は私の前の無色透明の酒を指した。",
              "citation": {
                "source": "地獄街道",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土からヘナ、ヘナから砂利と、一｜丈余も掘って、無色透明無臭而して無味の水が出た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この玉だけは黄金ではなく、無色透明なものでした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色透明で閃光を放つ玉はダイヤモンド。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し抛げられたものが、無色透明の物体だったとしたらどうでしょうか。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、そんな大きい無色透明の物体なんて在るのでしょうか。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによつても、この時分からすでに色がらすがつくられたことがよくわかりますが、無色透明の板がらすはまだ世界中どこにもありませんでした。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生は水の如くに無色透明なものがあるだけで、まことにハリアイもなく、生きガイもない。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "この湯槽は石灰分がくッついているせいか、どれも白くおぞんでいて、湯の水も白いように見えるが、流れ出す湯口を見ると無色透明で入浴の度毎に飲むと利き目があるということだから、お雪も今、それを少しばかり飲んでみました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その針のように細く巻かれた萌芽を擁護しているものが、無色透明の、弾力のある、ところてんのような、玉子の白味のような付着物である。",
              "citation": {
                "source": "洛北深泥池の蓴菜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは特別な優品で、他に類例を見ないくらい無色透明なところてん袋が多く付着している。",
              "citation": {
                "source": "洛北深泥池の蓴菜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "出たか出ないかはちょっと汁を吸ってみれば、無色透明でも、うま味が出ているのがわかる。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
