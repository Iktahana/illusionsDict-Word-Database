        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陽もやがて疲れて、叢雲の血煙を自分の身にも受けて燃え爛れた銅のやうになつた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "円かなる望月ながら、生蒼く隈する月の飛び雲の叢雲が間、ふと洩れて時をり急に明るかと思ふ時なり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "円かなる望月ながら生蒼く隈する月の飛び雲の叢雲が間、ふと洩れて時をり急に明るかと思ふ時なり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄じい風に押されて、彼方に一団此方に一団とかたまった電光を含む叢雲が、揺れ動き崩れかかる、その隙間にちらり、ちらりヴィンダーブラの大三叉を握った姿、ミーダの鞭を振る姿、カラがおどろにふり乱した髪を吹きなびかせて怒号する姿、黒い影絵のように見える。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば空一面に、すっかり叢雲がたちこめて、埃っぽい駅路は大粒の雨滴に叩かれていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山顛で駒が足を停めると、騎士はひときは深い眠りに沈んだが、見る見る叢雲が降りて彼の姿をつつんでしまつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、叢雲がぱつと吹き払はれて、彼の目の前には、くだんの騎士が、いとも荘重に姿を現はした……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしありて見ればまたその人は欄干に倚り仰いで明月は看ずして水のみ見入れるは、もしくは我が疑われたる投身の人か、我未ださる者を救いたる事なし、面白き事こそ起りたれと折しもかかる叢雲に月の光りのうすれたるを幸い、足音を忍びて近づきて見れば男ならで女なり。",
              "citation": {
                "source": "良夜",
                "author": "饗庭篁村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四―三六夜の始めに澄渡る空を裂き、または日の落つるころ葉月の叢雲を裂く光といふとも、そのはやさ　三七―三九かなたに歸りゆきし彼等には及ばじ、さてかしこに着くや彼等は殘れる者とともに恰も力のかぎり走る群の如く足をこなたに轉らせり　四〇―四二詩人曰ふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "オウィディウスの『メタモルフォセス』（三・一八三以下）に、衣を脱ぎしディアナの姿を敍して「對へる日の光に染みし叢雲の色、または紅の朝の色」云々とあるに據れり三一―三三〔淑女〕身に恥づることなけれど、他人の罪を聞くに恥ぢてその顏を赤くす三四―三六〔此類なき威能〕キリスト。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども有限なる人生において、事実は叢雲が待ちかまえているのは避けられないことを知る以上、対人関係はつつましく運命を畏む心で行なわれねばならないのであって、かりそめな軽忽な態度であってはならない。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼コーカサス峯高く千重の叢雲むらだちて下界のひゞきやむところ天上の火を奪ひ來し彼のたぐひか青ぐもの　大空翔くる鷲一羽　あらしははげし道遠し。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世慕ふて宵々に寄する光のかひやなに叢雲厚く布き滿てば戀はあだなり月姫よ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、風つよし、白い叢雲が吹きちらされていく空に、月が冷たく、寧ろさむく、照って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ガタガタ鳴るガラス戸　○叢雲だって　険しい空暗い鼠灰色の雲そういう空の前に　高いアンテナを張った線のセミのような丸い形のものが　際立って目にうつる　空に一羽鳶が風にさからい、流されつつ舞っている。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その東夷征伐に際して、尊の携えし天叢雲の宝剣は、甞て素盞嗚尊の出雲に出て、大蛇の腹中より得たる者にして、後に至りて、三種の神器の一となれり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅の柄に叢雲の彫りがある。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面が断続して、百の岡をなしている上を、叢雲が広がって渡るのを御覧なさい。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三箇年の海外留学と、かち得べき学位、それ等は、まるで、今までは、絢爛たる光彩を放ちながらも彼方にあった、名誉、栄達、幸福という叢雲の中から、特に彼のために下された、縒金の繩｜楷子のように見えた。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の小説には何と月の感銘がどっさりあるでしょう、「鏡の中の月」という題があるし、「杉垣」には月空に叢雲がとんで妻と歩いている良人の顔の上にそのかげがうごくところをかいているし、更にこの「杉垣」は火の見の見える二階の白い蚊帳の裾にさす月があるの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆け抜けて迎え討たんと雪蹴り立てて、必死に馬追って敵陣に割り入ったが、そこは硝煙｜叢雲のごとく立ち昇り、馬撃たれて為す術失ってしまった。",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと叢雲の劒という。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金属の表面には、赤黒い液体が、恐ろしい叢雲の様に漂っていた。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ憾むらくもわたくしは徒にこれらの諸家を煩わしたに過ぎなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳癈いて狂死せる朝寝房むらくも、酔いどれの噺は一種いいがたきおかし味あり、ことにはかの折々『ふあーッ』と絶叫せる奇声妙音、また大正末年の寄席風物詩に一異彩たりしが、このむらくも『らくだ』は得意の演題にて、この人のはむしろ後段におもしろき箇所、数多ありたり。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昔、地雷火の厄に斬罪となりし江戸末年の落語家｜朝寝房むらくも、かゝる雪の夜、席ハネてよりかゝる酒盃に親しみしならむか。",
              "citation": {
                "source": "滝野川貧寒",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
