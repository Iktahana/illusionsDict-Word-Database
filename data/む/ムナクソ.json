        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが俺は胸糞が悪いんだ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るのも胸糞が悪いって風に綺麗サッパリと縁を切ってやる。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはそれを見ると、「これで太田の時の胸糞が晴れた！",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちげえねえや、胸糞のわるくなる話だ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は何か胸糞の悪いような感じで、この家の気分もおよそ解るような気がした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉の仕向けは、まるで掌の裏を翻したようになって、顔を見るのも胸糞が悪そうであった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達ももうこれでこことはおさらばだから、最後の胸糞おさめに、丁寧な釣銭を貰ってよ。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが僕の方は、君、」と、ノズドゥリョフが言うには、「夜っぴて、話をするのも胸糞の悪い、いやな夢を見たんだよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "面を見ても胸糞が悪いから」「アッハッハッ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十年も前から彼等が住んでる部屋を見ると、私は胸糞がわるくなり腹が立つ。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　胸糞がわるいとしか云いようのない心持だ。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気のはやいことで」「一日に何十回と見るたびに胸糞が悪くなるから、無い方がせいせいするよ」「しかし、どうも、ちと気がお早すぎましたね。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこんな腐つた了見の奴等と談判するのは胸糞が悪るいから、「そんなに云はれなきや、聞かなくつていゝ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこんな腐った了見の奴等と談判するのは胸糞が悪るいから、「そんなに云われなきゃ、聞かなくっていい。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "変に胸糞の悪くなるような髪油の匂いが、気のせいか、いつまでも鼻についていた。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　彼は、胸糞がわるくなって、ぺっと、床に唾を吐いた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へただけでも胸糞がわるい。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場面が必ず与へる衝撃は、彼にとつてどんな残忍な描写にも劣らず「胸糞のわるい」ものに違ひない。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやがらせはその本来の性質として厭味の直接の表現でなく、間接的なものであるが、由子のやりかたは間接的ですらないやうな胸糞わるい思ひがねつとり残るのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨物列車はいつも汽笛を鳴らさないで来るので、初めはそれが電車かと思っているうち、次第に近づくにつれてそうでないことが分ると、胸糞が悪くなるような温気を残して走り去る汽関車に対して私は妙に腹が立ってきた。",
              "citation": {
                "source": "微笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は胸糞が悪くならざるを得なかった。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸糞の悪い頭痛がする。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして右の仮定は、初めの二つが余りに苦々しいものであると共に、後の一つは余りに自惚れすぎた胸糞のわるいものだった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、この世の中で、もっと胸糞の悪くなるようなものを、いくらも呑み込んでいるんだ。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそんな人を見ると胸糞が惡くなるような人も澤山いるのである。",
              "citation": {
                "source": "心理學",
                "author": "矢田部達郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ警察から年貢を取り立てられるのなら私の方から警察の御厄介になる考へで御座りますから、そのお積りで」と落ち付き払つて、こちらが女許りぢやと思うて調子を降ろして云ふで無いで、私は胸糞が悪うなつて来たでよ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸糞が悪くなつたから新聞を寸々に引き裂かうとしたが、まア／＼と一頁を返して見ると初め気が付かなかつた新刊紹介と云ふ欄がある。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧の六弥は、胸糞が悪いと云つて栄一の前で大に憤慨して居た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わしは、君ン処の隣の、吉田と云ふ餓鬼ぢや、頼む……頼む……少しな胸糞が悪うて飲んだんぢや……頼むぜ、大将』と云ふ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に君は、生活の必要から、妻子を養ふ必要から、止むなくその方に這入つて行つた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
