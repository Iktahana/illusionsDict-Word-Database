        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "林の中はたゞむせび泣く声ばかり、風も出て来て、木はみなぐらぐらゆれましたが、仲々｜誰も泣きやみませんでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中はただむせび泣く声ばかり、風も出て来て、木はみなぐらぐらゆれましたが、仲々｜誰も泣きやみませんでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房、俄かに上気し、その筋書を縷々と述べ、自らの説明に感激しむせび泣く。",
              "citation": {
                "source": "小説の面白さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか池の底でむせび泣くような悲しい声で、それを聞くと一種｜悽愴の感をおぼえるそうだ。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕映が一日を終らせようと　するときに――星が　力なく　空にみちかすかに囁きはじめるときにそして　高まつて　むせび泣く絃のやうに　おまへ　優しい歌よ私のうちの　どこに　住む？",
              "citation": {
                "source": "優しき歌",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い兩親は、そしていま寫した我子の寫眞が唯一のものとして胸に抱きしめられ、むせび泣く日のことを考へた。",
              "citation": {
                "source": "珠",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間にクララは錠のおりた堂母の入口に身を投げかけて、犬のようにまろびながら、悔恨の涙にむせび泣く若いフランシスを見た。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせび泣く声がすぐもれはじめた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ私を堪忍してくださいよ」という声がわたしの耳へむせび泣くように響いたかと思うと、すぐにまた、「みんな思い違いです。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢が杖をもって撃ち叩くと、幽鬼のむせび泣くような声がして、したたる水はみな黒い血のしずくでした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急にむせび泣く）わしはどんなに待ったろう。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い人妻はむせび泣くように見えるのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけをきかなければなかなかわけの分らない名でありながら私はこの名を低く口に繰返して不思議にむせび泣く様な気持になる。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のなかは死のように静まり、むせび泣くような風の音だけが聞えました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせび泣くのもある。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりはそれを待ち兼ねたように、たがいにぱっと頸に抱きつき、人に聞かれぬように声を忍んで、静かにむせび泣く。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "快天王の音声が、時に百歳の老翁の如く、時に荒れ叫ぶ野獣の如く、又、美女の威ある如くむせび泣く如く、幼女の母を恋うるが如く、常に変幻ただならぬことは先に述べたが、主として美女の音声であることが多い。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニーナは頭を彼の胸におし当て、忍び音にむせび泣く。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "（むせび泣く）トレープレフ　ニーナ、君はまた……ニーナ！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、私の涙のお願い、きいて下さいね」と云って、婦人はむせび泣くのだった。",
              "citation": {
                "source": "あの顔",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "離ればなれの乾雲丸と坤竜丸が、家の檐も三寸下がるという丑満のころになると、啾々としてむせび泣く。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "離ればなれの乾雲丸と坤竜丸とが、家の檐も三寸さがるという丑満のころになると、啾啾とむせび泣く。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が出たとみえて、庭の立樹がゴウッ――潮騒のように鳴り渡って、古い家である、頭のうえで、家棟の震動がむせび泣くように聞えてくる。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、十七年目で、父娘の名乗合いをするまで、隠せるものなら隠しおおせようと、こう思い定めたのでございます」「…………」　老巡礼の百松は、平次の裾に縋り付いて、無い歯を噛みしめながらむせび泣くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お染の歎き",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙ぐんで、とぎれがちなむせび泣くような声で、彼は早口に叫んだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせび泣く魂　もちろん、いくらひろい屋敷といっても、これだけのさわぎが起って、きこえぬというはずはありません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の友人のいうところによれば――「その手紙を受け取って両手を合わせ、喜びと感謝のあまりむせび泣くベートーヴェンの姿には、見るものの心を引き裂くような痛切なものがあった。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」マリユスのむせび泣く声が聞こえた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時をまわってから、それがちょっと途絶えたので、香をあげようと思って立っていったが、襖のそとまでゆくと、部屋のなかで人々のむせび泣く声がしていた。",
              "citation": {
                "source": "日本婦道記",
                "author": "松の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
