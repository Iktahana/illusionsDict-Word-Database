    "definitions": [
      {
        "index": 1,
        "gloss": "outdoor concert hall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
