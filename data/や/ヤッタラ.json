        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まとめてやったら、どうですか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて男共は料理して盛にやったらしかった。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "長塚へ梅の歌を詠めと云うてやったら三月上旬に出京して実際を見てから作ると云うてきた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "政夫さん歌とか俳句とかいうものをやったら、こんなときに面白いことが云えるでしょうね。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "北太平洋のもあるいはこの仲間でないとも限らぬから罎の写真でも撮って知らしてやったらよかろうと思う。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が胸を躍らせながら俺と毎晩あるいたあの眼鏡屋の通りを偶然今歩いてると書いてやったらどう思うだろう。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓が、鍬や鎌をかついで列を作って示威運動をやったらどんなもんだろう。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は藤二のことを思い出すたびに、「あの時、角力を見にやったらよかったんじゃ！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時Ｕ公園にＳ軒付属のホテルがあったので、そこならば市中よりはいくらか閑静でいいだろうと思ってそのことを知らせてやったら、さっそく引き移って来て、幸いに存外気に入ったらしい様子であった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いをやって元の古い捲線を返してくれと云ってやったら、「あれは捨ててしまった」と云って、そうして何故かひどく不機嫌であったそうで、使いの者はほうほうの体で帰って来た。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度持合せていたＭＣＣかなんかを進呈してマッチをかしてやったら、「や、こりゃあ有難う有難う」と何遍もふり返っては繰返しながら行過ぎた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ってやったら、しっかり、あっちの連中と手を握って来い！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一度、中津は正式に嫁に貰って、孫のように可愛がってやったら！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれを今、学校をやめさして、働きに出しても、そんなに銭はとれず、そうすりゃ、あれの代になっても、また一生頭が上がらずに、貧乏たれで暮さにゃならんせに、今、ちいと物入れて学校へでもやっといてやったら、また何ぞになろうと思うていない。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本にある通りの比重でやったら亀の尾は半分も残らなかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ返して追い駆けてやったら、とは思いながら自分の両足はやはり惰性的に歩行を続けて行った。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の勘定も佐吉さんの口利きで特別に安くして貰い、私の貧しい懐中からでも十分に支払うことが出来ましたけれど、友人達に帰りの切符を買ってやったら、あと、五十銭も残りませんでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と教えてやったら、女房は真面目に、「はあ、これが浮浪者ですか。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は行って穂吉にそっと教へてやったらよからう、もうこの上は決してばたばたもがいたり、怒って人に噛み付いたりしてはいけない。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は行って穂吉にそっと教えてやったらよかろう、もうこの上は決してばたばたもがいたり、怒って人に噛み付いたりしてはいけない。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本気でやったら、ぼく、もう、息で、石もなげとばせるよ」　オツベルはまたどきっとしたが、気を落ち付けてわらっていた。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マゴマゴしているうちに粕を絞らせられるような事になっては堪らぬと気が付いたので、すぐに一通の偽筆、匿名の手紙を書いて、面会の時日を東都日報、中央夕刊の二つに広告しろと云ってやったら、その翌る朝、まだアパートで寝ているうちに、東都日報から……という電話がかかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そんならこちらでも水車をやったらどうだろう、』と先生に似合わないことをある時まじめで言いだした。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあんまりかわいそうなので、こわごわ遠くから頭をなでてやったら、鼻の先をふるわしながら、目をつぶって頭をもち上げた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーロはいつでも上手に帽子をこしらえているんだから、仕事にやったらもっと上手にできるだろう。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者さんもあんまり、がおれなぃで、折角みっしりやったらいがべ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに本間の死んだことも聞かしてやったら、十に九つはこっちの物だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまり、無理をお謂やったら、姫を連れて来て見せるがいいの。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「防空壕やったら、あんた、誰に気兼遠慮もいらんし、夜空襲がはいっても、身体｜動かす世話はいらんし、燈火管制もいらんし、ほんま気楽で宜しあっせ」　そして、わては最後までこの大阪に踏み止って頑張りまんねんと、他アやんは言い、「メリ助が怖うてシャツは着られまっかいな。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
