[
  {
    "uuid": "405a3d7c-4615-50dc-9901-c8bd9e02bc66",
    "entry": "やる方ない",
    "reading": {
      "primary": "やるかたない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
