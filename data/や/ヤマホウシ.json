[
  {
    "uuid": "7957b5ff-6210-5b64-8b63-fce82487d55e",
    "entry": "山法師",
    "reading": {
      "primary": "やまほうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
