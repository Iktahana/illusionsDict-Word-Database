        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人跡絶えた山道には、人力車の通う術もなかったので、二人の若い男女は、互に助け合いながら、蔦葛の這う細道を、幾時間となくさまよい歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷に沿つた林の中などは、道さへつければ可成の遊歩地ができるし、附近の山道なども、ちよつとした手入れと設備でどうにでもなるから。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと隣って、一段高く梯子段を上ったところに、浅間神社を勧請した離屋が、一屋建ててあり、紀伊殿御祈願所の木札や、文化年間にあげたという、太々神楽の額や、天保四年と記した中山道深谷宿、近江屋某の青銭をちりばめた奉納額などがあった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大宮口こそ、富士のあらゆる登山道で、もっとも古くから開けた旧道むしろ古道であることだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは見晴しの好い峠の山道を、ひとりでゆっくり歩きたかったからであった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした思惟に耽りながら、私はひとり秋の山道を歩いていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細い山道は、径路に沿うて林の奥へ消えて行った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、漸く人馬の足跡のはっきりついた、一つの細い山道を発見した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝山道――夜　葛籠を担いで村人が上って行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝山道――暁　武蔵と団九郎がお絹を伴って、　下りて行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから吉浜まで海岸の雨の山道を、験潮器を背負って、苫をかぶってあるいていると、ホトトギスが啼いた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎もそのうしろからはあはあ息をついて「よう、坂道、よう、山道」なんて云ひながら進んで行きました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてその時分じゃからというて、めったに人通のない山道、朝顔の咲いてる内に煙が立つ道理もなし。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "随筆の方は、奥州会津に諏訪越中と云ふ大力の人ありて、これは宙外さんの猪苗代から、山道三｜里だから面白い。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、だれか一人のパイオニアーがその現象に着眼して山開きのつるはしをふるって登山道がつき始めると、そうすると、始めて我れも我れもとそのふもとに押しかけるようになるのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山道のトロッコにうっかり乗った子供が遠くまではこばれた後に車から降ろされただ一人取り残されて急に心細くなり、夢中になって家路をさしていっさんに駆け出す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時別に四人連れの登山者が登山道を上りかけていたが、爆発しても平気でのぼって行ったそうである。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの旅人は、よっぴて山道をあるいてゆくだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早縄をかけたまま横の山道へ担ぎ込んで、懐中物を取上げてみると案の定、蔵元屋の身上調べと、黒田藩のお納戸の乱脈を細かに調べ書きにしたものが、貸付証文と一緒に在ったわい」「あっ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうですな、山道で岐路が多いから矢張り案内が入るでしやう、宅の倅を連れて行つしやい。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くいし（山名）へ行くにはどっちですか」「神社」「アツマコート」「小女山道」「昼飯」「牛を追う翁」「みかん」「いこいつつ水の流れをながめおれば、せきれい鳴いて日暮れんとす」など、とり止めもない遠足の途中のいたずら書きらしいものもある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また重いものをかついで山道を登る夢が情婦とのめんどうな交渉の影像として現われることもある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと」　と妹は、さびしい山道に立ちすくんで泣きだしそうな声を出した。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、山道で久しぶりに慶四郎の傍にいて、何か易々とした安心にゆるんで来て千歳は子供のときのように、うっかり慶四郎にもたれかかったりするのであった。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近間に大な建築の並んだ道は、崖の下行く山道である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏づたいの山道を森へ通ったに相違はござりますまい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名にし負う神通二百八間の橋を、真中頃から吹断って、隣国の方へ山道をかけて深々と包んだ朝靄は、高く揚って旭を遮り、低く垂れて水を隠した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ふ内に、車は自分の前、ものの二三｜間隔たる處から、左の山道の方へ曲つた。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の下へ行くには、來て、自分と摺れ違つて後方へ通り拔けねばならないのに、と怪みながら見ると、ぼやけた色で、夜の色よりも少し白く見えた、車も、人も、山道の半あたりでツイ目のさきにあるやうな、大きな、鮮な形で、ありのまゝ衝と消えた。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新以前、会津侯が江戸登城の折は四千余尺のこの山道を通られたということで、路傍の叢中には一基の古碑、その面に「右塩原あら湯｜道、左会津道」と刻されてあるのが蘚苔に覆われて読める。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
