    "definitions": [
      {
        "index": 1,
        "gloss": "landlocked masu salmon (Oncorhynchus masou masou)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "コメススキや白山女郎花の花咲く砂原の上に大きな豌豆ぐらいの粒が十ぐらいずつかたまってころがっている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と頸をすくめて、頭を撫で）……近頃、此方衆の前ながら、館、剣ヶ峰千蛇ヶ池へ――熊に乗って、黒髪を洗いに来た山女の年増がござった。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、蛇のように、再び舌が畝って舐め廻すと、ぐしゃぐしゃと顔一面、山女を潰して真赤になった。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ其他に山姥といい、山女郎と云う者もある。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お前ならば山女郎の方が可かろうと云おうとしたが、戯っていると長くなる。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿から釣竿を借りて、渓流の山女釣りを試みる時もある。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でっかい山女がいるぞ」と、一人が云うと一人は団子を呑み込みながら云った。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは山女であった。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山女と岩魚を十尾ばかり捕ると一行はその淵を捨てて下の淵へ往った。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山女や岩魚がまた七八尾｜半死になって浮いて来た。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から山女が一つ浮いて来た。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この川の上の方へ行きますと、岩の上で釣っている人を時々に見かけますが、山女を釣るんだそうですな。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まったく以前は山女がたくさんに棲んでいたようでしたが、川の両側へ人家が建ちつづいてきたので、このごろはさっぱり捕れなくなったそうです。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山女のほかに、大きい鰻もずいぶん捕れましたが、それもこのごろは捕れないそうです。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷もたいてい全快したので、このごろは外出を許されて、退屈しのぎに山女を釣りに出るという話を、松島さんから聞かされているので、この人たちもやはりそのお仲間であろうと想像しながら、わたくし共も暫く立ちどまって眺めていますと、やがてその一人が振り返って岸の方を見あげました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり山女でしょうか。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山女と鰻ぐらいのものだ。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野はその時｜長沢在仲と云う医師を紹介者として、山女を持って面会を求めた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書、はじめをその地勢に起し、神の始、里の神、家の神等より、天狗、山男、山女、塚と森、魂の行方、まぼろし、雪女。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きには草履屋だが、ほんとうの商売は山女衒で、ふだんから評判のよくねえ野郎だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもお節の死骸が見付からないうちは、詮議の手のゆるまない虞れがあるので、山女衒の半介、これも花鳥の識っている奴ですから、その半介を語らって、例の品川の夜釣りの怪談をこしらえて、形見の片袖を鍋久に持ち込ませました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひと足おそいと、お直はどこかの山女衒の手に渡されて、たとい取り返すにしても面倒でしたが、いい塩梅にすぐに取り返してしまいました」　お直が無事に戻って来たので、甲州屋では世間の手前をはばかって万事を内分にしたいと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃の山女魚の魅力葉山嘉樹　私が今住っている処は、東に南アルプス山系の仙丈ヶ岳や、白根山系の山々、など、殆んど年中雪を頂いている、一万尺内外の高山の屏風を遠望し、西には、僅か数里の距離を置いて、西駒山脈、詰り中央アルプスが亙っている。",
              "citation": {
                "source": "信濃の山女魚の魅力",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この河からは鯉、鮎、鰻、赤魚、山女魚、等々が釣れる。",
              "citation": {
                "source": "信濃の山女魚の魅力",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處で僕は昨日チエホフの『ブラツクモンク』を讀さして思はずボズさんの事を考へ出し、其以前二人が溪流の奧深く泝つて「やまめ」を釣つた事など、それからそれへと考へると堪らなくなつて來た。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎、いはな、やまめなどあらばこの上なし。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で釣竿を持つて、四國三郎の上流にやまめを釣りに行つたりした。",
              "citation": {
                "source": "旅人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午からは各種の露店が出る、銀流し、矢場、賭博がある、大道講釈やまめ蔵が出る――という有様で、その上狭い処に溢れかかった小便桶が並んであるなど、乱暴なものだ。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまめや、かじかすらあまり喰わしてくれる処がなかった。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○八汐路を輙くわたるもろこしの海の城てふなくてやまめや　（吉田松陰）　この歌は、安政元年（？",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
