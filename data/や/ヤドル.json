    "definitions": [
      {
        "index": 1,
        "gloss": "to dwell (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "著者は「永遠の漂泊者」であり、何所に宿るべき家郷も持たない。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の権現は信濃の国｜浅間大神と、一神両座の垂迹と信ぜられていたところから、浅間菩薩ともいい、富士｜浅間菩薩とも呼んだりしたが、本元の浅間山の方は、一の鳥居があるだけで、御神体は、山そのものに宿るとしてあるから、神社の鎮座がない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "此夜も山田屋に宿る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの「抒情小曲集」にある心根のしをらしさも、「忘春詩集」等に描かれてゐる寂しげな宿命觀も、皆その一の氣質的な情操に屬してゐるので、至純の心にのみ宿る純情の美しさが、ひしひしと人の心に迫つてくる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し人の心に宿る所の戀をすら笑ふべく信ずべからざる者ならば、人生遂に何の價ぞ、人の心ほど嘘僞な者は無いではないか。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の心に宿る歡喜にして若し歌ふべくんば、自然の心にさゝやく悲哀も亦た歌ふべきであらう。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の歌志内の渓谷に着いた時は、雨全く止みて日は将に暮れんとする時で、余は宿るべき家のあてもなく停車場を出ると、流石に幾千の鉱夫を養ひ、幾百の人家の狭き渓に簇集して居る場所だけありて、宿引なるものが二三人待ち受けて居た。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の心に宿る歓喜にしてもし歌うべくんば、自然の心にささやく悲哀もまた歌うべきであろう。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頭に宿る幾千年間の人智の蓄積にすがらうとしたのだ。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處へ花籠から、一本白百合がはらりと仰向けに溢れて落ちた……ちよろ／＼流れに影も宿る……百合はまた鹿の子も、姫も、ばら／＼と續いて溢れた。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況して鳥類は廣大無邊の天地を家とし、山を翔けり、海を横ぎり、自在に虚空を往來して、心のまゝに食を啄み、赴く處の塒に宿る。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と振返って、「ですかい、」と言いつつ一目見たのは、頭禿に歯豁なるものではなく、日の光｜射す紫のかげを籠めた俤は、几帳に宿る月の影、雲の鬢、簪の星、丹花の唇、芙蓉の眦、柳の腰を草に縋って、鼓草の花に浮べる状、虚空にかかった装である。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速宿ることとして旅装をとく。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍と吾輩は駐在所へ行って、巡査に依頼してようやく、一井という旅館へ宿ることとなった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々の空の瑠璃色は、玲瓏たる影と成りて、玉章の手函の裡、櫛笥の奧、紅猪口の底にも宿る。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一処、大池があって、朱塗の船の、漣に、浮いた汀に、盛装した妙齢の派手な女が、番の鴛鴦の宿るように目に留った。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――紫玉は、中高な顔に、深く月影に透かして差覗いて、千尋の淵の水底に、いま落ちた玉の緑に似た、門と柱と、欄干と、あれ、森の梢の白鷺の影さえ宿る、櫓と、窓と、楼と、美しい住家を視た。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋杭ももう痩せて――潮入りの小川の、なだらかにのんびりと薄墨色して、瀬は愚か、流れるほどは揺れもしないのに、水に映る影は弱って、倒に宿る蘆の葉とともに蹌踉する。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　明治｜廿三年の二月、父と共に信州軽井沢に宿る。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『本当にするもしないも――君……』　と、云いかけたが西村はこの時始めて清水の眼に宿る満更芝居でもなさ相な、ただならぬ暗いかげに気がついてハッとした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も師走に想像を逞しくしてはならぬと申し渡された次第でないから、節季に正月らしい振をして何か書いて置けば、年内に餅を搗いといて、一夜明けるや否や雑煮として頬張る位のものには違ないが、御目出たい実景の乏しい今日、御目出たい想像などは容易に新聞社の頭に宿るものではない。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内の者は、もとより、軒端に宿る小鳥たち、天井裏に巣くう鼠、のこらずぐっすり眠って居ります。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "健全な肉体に健全な精神が宿るという諺があるけれど、あれには、ギリシャ原文では、健全な肉体に健全な精神が宿ったならば！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪に宿る山雀、と言う謡がある。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪に宿る山雀、胡桃にふける友鳥……「いまはじめて相分った。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木賃の夜寒の枕にも、雨の夜の苫船からも、夢はこの処に宿るであろう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女五　……時得て咲くや江戸の花、浪｜静なる品川や、やがて越来る川崎の、軒端ならぶる神奈川は、早や程ヶ谷に程もなく、暮れて戸塚に宿るらむ。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいのは、シャクの方でも（あるいは、シャクに宿る霊共の方でも）多くの聞き手を期待するようになったことである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "をかしいのは、シャクの方でも（或ひは、シャクに宿る靈共の方でも）多くの聞き手を期待するやうになつたことである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人の内に宿る射道の神が主人公の睡つてゐる間に體内を脱け出し、妖魔を拂ふべく徹宵守護に當つてゐるのだといふ。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
