          "literary": [
            {
              "text": "諺にも「病は気から」というくらいです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病は気から」ともいうように、私どもは健康な精神によって、身体の病気を克服してゆかねばなりません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄鶯院は何事か思いついたように、「守人殿」「はい」「ちと戸外へ出られてはどうじゃな」「――」「下世話にも病は気からと申す。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病は気から」ということさえもある。",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
