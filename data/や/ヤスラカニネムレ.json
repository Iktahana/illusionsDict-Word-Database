        "examples": {
          "standard": [
            {
              "text": "戦場で倒れた友の墓標に、彼はナイフで「安らかに眠れ」と深く刻んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「復讐は私が引き受ける。お前はただ、安らかに眠れ」と彼は亡き弟に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「安らかに眠れ、わが友よ」と言って、彼は静かに病室を後にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東雲ちかい汽車の寢臺で友よ　安らかに眠れ。",
              "citation": {
                "source": "別れ",
                "author": "旅の記念として、室生犀星に",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの事件について何かの疑いをかけられている杉田二等水兵は、今宵はたして安らかに眠れるであろうか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくは墓のなかで安らかに眠れないだろう」彼はこの最後の言葉をことさらおごそかに繰りかえした。",
              "citation": {
                "source": "幽霊花婿",
                "author": "ある旅人の話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
