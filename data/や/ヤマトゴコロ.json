    "definitions": [
      {
        "index": 1,
        "gloss": "the Japanese spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
