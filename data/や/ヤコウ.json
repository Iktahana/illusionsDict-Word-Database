[
  {
    "uuid": "573ee396-738f-5b38-a356-30a565fff6e0",
    "entry": "冶工",
    "reading": {
      "primary": "やこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
