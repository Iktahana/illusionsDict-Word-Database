    "definitions": [
      {
        "index": 1,
        "gloss": "Yamagata Prefecture (Tōhoku area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "火防話では同郡宮守村字塚沢の多田某という家のゴンゲンサマはこの家が失火したときに真っ赤になって座敷中を飛び回り火を食っておったと言い、また先年の山形県米沢市の大火のときにも焼け跡の真ん中にふしぎにもたった一軒焼けずに立った家があったが、この家にはオシシ頭があったという。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父は山形県の米沢に生れて、少年時代をそこで暮した。",
              "citation": {
                "source": "故郷の話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤作吉君は、山形県鶴岡の出身で私の門下で彫刻を学び後美術学校鋳金科へ入学し、優等で卒業し後朝鮮李王家の嘱托を受けて渡鮮し、帰国後銅像その他鋳造を専門にやっております。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国の人は一体納豆を好むようですが、わたくしは、福島県の生れですし、父祖の生れは山形県ですし、それに父も母も納豆が嫌いではないのですが、わたくしはどうも駄目です。",
              "citation": {
                "source": "身辺打明けの記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母なぞは「お前は国の納豆をたべないからだよ、たべず嫌いなんだよ」と申しますけれど、わたくしも、その国の納豆――山形県の――を見て知っていますが。",
              "citation": {
                "source": "身辺打明けの記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は、山形県は勿論、仙台へ行つたこともなければ、況んや針久旅館などに泊つたこともない。",
              "citation": {
                "source": "偽者二題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国から帰って来たとき、下関から上陸して、ずっと本州を汽車で縦断し、東京から上越線で新潟県を通過して、山形県の庄内平野へ這入って来たが、初めて私は、ああここが一番日本らしい風景だと思ったことがある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暫く人人の話は、この山形県下へ顕れた聯合軍の噂に花が咲いたが、どういうものか、それら持ちよりの噂はどれも良い方面のことが多い。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悪い方面のことを一つもまだ聞かないが、日本でもっとも両者の間の善く廻っているのは、この山形県下だということも、警察の人から聞いたことがある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また山形県｜酒田の富豪｜本間氏がその子弟の教育を小学程度に止めてそれ以上を学ばしめざるのみか、氏一家の反対に由って今なお中学の設置を酒田町に見ざる類の、非文明的な父兄も各地に多いのである。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支倉の本籍山形県へ照会すると、果して彼は窃盗の前科三犯を重ねた曲者だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "問　姓名は如何　　　　答　支倉　喜平　　年齢は　　　　　　　　四十三年　　職業は　　　　　　　　聖書販売業　　生地は　　　　　　　　山形県置賜郡　筆者は何故こんな分り切った事をこゝに書くか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇吉を迎えに行ったあの朝、やはり上野へ着いた山形県からの小学卒業生たちが一団で撮られていて、東北も雪の深い奥から来た少年たちは絣の筒っぽを着て、大きい行李を持っている。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで何や彼や未だ苦労の多かつたときに、故郷の山形県｜金瓶村で僕の父が歿した。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は二月一たび山形県｜上山町に行き、弟が経営してゐる旅館山城屋に泊つて、疎開の相談をしたのであつた。",
              "citation": {
                "source": "三年",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫の生れた昭和二十一年四月は、私が山形県の大石田といふところにゐた。",
              "citation": {
                "source": "孫",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は終戦の年に山形県の生れ故郷に疎開したが、そのときも先ず夏季の蚤を恐れた。",
              "citation": {
                "source": "蚤",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座が組織立っていたせいか、今でも一番名が残っているのは山形県の斎藤女相撲団であろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "山形県の最上川も覗いた。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後岩船郡は新潟県の東北にあり、越後山脈を中に挟んで、山形県と境を接している。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から奥利根へは、出羽の熊捕り専門猟師が、越後の駒ヶ岳、八海山、牛ヶ岳などをへて入り込んできたのであるから、私は山形県や秋田県の山々が、熊の本場であろうと考えて、一度本場の熊の肉を賞味したいと希望していたところ、今回はからずも友人からの贈りものを得て出羽と越後の国境でとれた熊の肉を、たんのうした。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "山形県にあるのです。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山形県とは言ひながら、県境に近いせゐもあつて、新潟の人達が自分達の温泉のやうに遊びに行きます。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子ばかりでも七種類だ」　この異様な一群の中に山形県師範学校長和田兼三郎氏のいるとは知らぬ人の想像もつかぬことに違いない。",
              "citation": {
                "source": "平泉紀行",
                "author": "──専攻科第一類歴史部──",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは出羽奥州との意味か、出羽と今日の陸奥とを並称したものか、あるいは出羽の奥地との意味か、その命名の真意はこれを諒解するに苦しむが、事実は青森県を主なる地方として、秋田県、岩手県の地方に及んでいるもので、山形県、宮城県あたりまで南下すると、よほど様子が変って来るのである。",
              "citation": {
                "source": "奥羽北部の石器時代文化における古代シナ文化の影響について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　庄内地方のオクナイ様　佐々木君の報告の中に、黒川友恭著「荘内方言考」を引いて、山形県荘内地方では、他の地方ではオシラ神というものを、オコナイ様というとの事が見えていた。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々木君に従えば同じ山形県でも酒井家の領分を離れた山形地方では、オクメナイ様といっているという。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山形県庄内の阿部正己君が、わざわざ震災見舞に東京へ来られたとて立ち寄られた（市内の方々の御来訪は一々ここに書き留めぬ）。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山形県の史蹟調査について　今日いよいよ議事堂で山形県史蹟名勝天然紀念物の調査会が開かれた。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
