    "definitions": [
      {
        "index": 1,
        "gloss": "stew prepared from ingredients contributed by members of a party, and eaten in the dark for fun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「闇汁会」や「柚味噌会」の奇抜な記事などもなかなか面白いものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、闇汁の催しに群議一決して、客も主も各物買ひに出づ。",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬば玉の闇汁會はいよ／＼幕あきとなりぬ。",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、四方太闇汁十句の作あり。",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内芋買うて歸れば露月既に在り　　四方太闇汁の南瓜におくれ里の芋　　同芋五合大汁鍋の底に在り　　同里芋を二つの鍋に分ちけり　　同芋入れて汁が煮えくりかへるかな　　同芋買うて臺所から上りけり　　同",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが他の同人仲間にも伝わって、その頃はよく諸方で闇汁会を開いたものである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな野蛮な事も出来ないがやはりその名を取って、それに似た事をしたのが、即ち我々の闇汁会であった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くこの二席の空高く浮く昼月の美しさに比べ見て、なんと他のことごとくの闇汁のゴッタ煮の鵺料理の、ただいたずらに持って廻り、捏ねっ返して、下らなくでき過ぎていることよ。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は曾て旗本の悪童共、水野十郎左衛門、加賀爪甲斐が試みた闇汁のように、無気味な昆蟲や蛇や、あらゆる悪食に箸をつけました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "食魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇汁の杓子を逃げしものや何大正五年十二月二十八日　高商俳句会闇汁会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから若い時はあったかも知れぬが「どこそこで闇汁をやった」とか「河豚を食った」とか云う様な話はきいた事がなかった。",
              "citation": {
                "source": "解説　趣味を通じての先生",
                "author": "額田六福",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
