    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rural beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしこれもまた前時代の歌曲に比すれば、その品位のないことに於て、野趣的に卑俗化したことに於て、時代の文化的低落を語る一実証と見るべきだつた。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方がのんびりして野趣がある。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると、いくら野趣が減殺されようが何様しようが、今日は今日で、何も今を難じ古を尚ぶにも当らないから、矢張り文明の利益は使うだけ使った方が宜さそうな事です。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし旅行を仕て真実に自然に接したり野趣の中に身を※いたり、幾分かにしろ修業的に得益しようと思ったなら、普通の旅行をしても左程面白い事は有りますまい。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムソンというんだ」　綺麗な疳高い、少し野趣を帯びた笑声が弾けるように響いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきり（よし原すゞめ、行々子）は、麥の蒼空の雲雀より、野趣横溢して親しみがある。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰道の優雅な野趣が眼に浮んで來た。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」蟹といふものは、どうも野趣がありすぎて上品のお膳をいやしくする傾きがあるので私はちよつと躊躇した。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは帝室關係のもので、野趣は少い代り堂々たる設備で、養魚池もひろく、鱒も二尺位になつてゐるのが數多く見えた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧くは俳人の嵐雪が住み、歌人の加茂真淵が住みまして、真淵などは、その周囲の野趣のあるさまから家の号を懸居と称えたということを池上はいつか話していました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は山荘の住人で、平生竹や草や昆虫ばかりの中に立ち交っているので、身のまわりなぞは清潔にはしているが、少くとも野趣そのままにちがいなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "左は楊と稚松と雑木の緑と鬱した青とで野趣そのままであるが、遊園地側の白い道路は直立した細い赤松の並木が続いて、一、二の氷店や西洋料理亭の煩雑な色彩が畸形な三角の旅館と白い大鉄橋風景の右｜袂に仕切られる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい一、二時間前に見た白く輝く三角洲、分流の早瀬、船大工のとんとん、水車船の野趣、何だか遠い日の向うの煙霞と隔たってしまったような気がする。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は貴族の風格を尚び、彼は却て純樸なる野趣を恋ふ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣をつけて見れば野趣のある花である。",
              "citation": {
                "source": "庭さきの森の春",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋の村芝居とおなじ野趣に対して、私も少からず興味を感ずる。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしろ君そんなによくば沢山やってくれ給え」「野趣というがえいか、仙味とでも云うか。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時にこの動物画の描き手にふさはしい、素朴な、朴訥な、田舎めいた、野趣に富んだ、動きのにぶい、社交下手な、土壌臭い、内省的な華楊といふ作家の人柄といふものを、あの作品の限りで想ひ出されて来るであらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猿の親子は如何にも野趣に富んだものであつて、すぐに尻に手をやつて掻いたり、叫び出したりする態の猿であつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこゝで華楊はその描くところの猿を、関雪風に、磨きのかゝつたインテリゲンチャのやうな猿を描くことができないかどうか、さうしたことの不可能なほどに、作者華楊自身が野趣的であるかどうか、前にも「洋犬画」の個所で述べてあるやうに、華楊は結構ハイカラな猿も描くことができるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂梅林的ならずして、野趣愛すべし。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁れる崖下の瀧野川に浮びても、錦とは見えざるが、掛茶屋一面に敷きつめたる赤手布の上に散亂しては、さすがに野趣なしとせず。",
              "citation": {
                "source": "近藤重藏の富士山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、このやうなる野趣もあらむ。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なかなか、野趣でしょ」と看護婦さんが云うので、私も親切に答えて早速花瓶に挿しましょうと云った。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "左は楊と稚松と雑木の緑と鬱とした青とで野趣そのままであるが、遊園地側の白い道路は直立した細い赤松の竝木が続いて、一二の氷店や西洋料理亭の煩雑な色彩が畸形な三角の旅館と白い大鉄橋風景の右袂に仕切られる。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家のあき地にも唐もろこしを栽えてあって、このごろはよほど伸びた長い葉があさ風に青く乱れているのも、又おのずからなる野趣がないでもない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしゅうおざんす」　彼女は張りつめた胸をせつなそうに抱えて、蒲団の上に又うつ伏してしまった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さま、くやしゅうございます」　また何か仕出来したのかと栄之丞もうんざりした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さま……私にはもう何がなんだかちっともわかりませんが、私はただもうくやしゅうございます。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ様、私は今まで貞ちゃんにもいわないでいましたけれども……みんなが聞こえよがしにねえ様の事をかれこれいいますのに、たまに悪いと思って貞ちゃんと叔母さんの所に行ったりなんぞすると、それはほんとうにひどい……ひどい事をおっしゃるので、どっちに行ってもくやしゅうございましたわ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
