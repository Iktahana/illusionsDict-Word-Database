    "definitions": [
      {
        "index": 1,
        "gloss": "overdoing (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あんまり肥育をやり過ぎて、一度病気にかかってもまたあとまわりになるだけだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、二十日ばかりぼんやり過ぎましたら、ある日戸口で、「今日は、だれかいるかね。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これも桑子のやり過ぎた仕業の一つとして、椽側の金魚の硝子箱は綺麗に掃除され、折角青みどろの溜つた水は、截りたての晒木綿のやうな生の水に代へられてあつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りやり過ぎたか、一人位息あるやつはないか。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丸多の主人がちっと道楽をやり過ぎましてね」「主人は幾つだ」「主人は多左衛門といって、ことし四十六だそうです」「四十六……」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大胆にやり過ぎれば娘を脅やかして了う。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーリーの所でつい歌留多をやり過ぎちゃったからね――それじゃいけないかい？",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は顔をいろいろ歪めて彼女を笑わせたり、やり過ぎるほど菓子をやったりしたあとで、もういいだろうと思って恐わ恐わ「御身よ御身よ。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども昨日からちよい／＼見るところでは、あれを扱つてゐる人が串にしては少し丁寧にやり過ぎてゐると思つて、私は不審の首を傾げてゐた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああでもなく、こうでもなく、結局あまり細工をやり過ぎて妙な、嫌味な、不自然なごたごたしたものを製造してしまう。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兎に角荷物を見せて貰おうじゃないか」　石子はさっきから渡辺が少しやり過ぎると思っていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは少しくやり過ぎたな」　咄嗟にこのように思いました。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを受継いで、明治以後の国語、国文学者が一所懸命やり過ぎました結果、新しい国文学者から排斥せられてゐました。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、家の中の仕事といえども、やり過ぎるなと注意あり、返事を認めて、そのことよく守りましょうと申し送った。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは最もいい条件で丸鑿を使って居り、丸鑿でしゃくってあるけれども非常に謹んで使っていて決してやり過ぎていない。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをいうと、道庵先生の人格に関するようなものだが、実は先生、旅へ出て、調子づいて脱線をやり過ぎることがあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、はやり過ぎる馬の方も、どうやら押えが届いたようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんがやり過ぎたことについては、わしも多少責任は感じてゐるし、さうでなくつても、学校事業は、これからは企業として成り立つ見込がない。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も僕は近頃少し自己肯定をやり過ぎた氣がしてゐる。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり過ぎましたでございましょうか」「火事は、放け火であるぞ」「はっ」「放け火は重罪。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎にキャベツをやり過ぎて、あぶなく殺すところだつたのを忘れてやしないだらう」「あれだけは、知らんぢやつたもんで……」「あれだけぢやない。",
              "citation": {
                "source": "それができたら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "こやしをやり過ぎて、根が煮えるとイモチが出る。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つになる若樣はなか／＼撫め切れない、現にその前の日は、日頃仲好しの荒物屋の伜をつれ出して當分若樣のお相手をさせる氣になつた――これは少しやり過ぎでした」「――」「このいきさつを嗅ぎ出した若黨の三次は多分奧方を強請つたことでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "神隱し",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父子はもう一度この離屋へ取つて返し、お半の胸から匕首を拔いて、その右手に持たせる恰好にし蝋燭を吹き消して――こいつはやり過ぎだつたが、家持の町人はどんな場合でも火の用心は忘れない――」「――」「父親は先へ出た。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "尼が紅",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父子はもう一度この離屋へ取って返し、お半の胸から匕首を抜いて、その右手に持たせる恰好にし蝋燭を吹き消して――こいつはやり過ぎだったが、家持の町人はどんな場合でも火の用心は忘れない――」「…………」「父親は先へ出た。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "尼が紅",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川幕府も天下を取つた當時などは、權力を確立することに急で、創業早々大小名を取り立て過ぎ、秩祿をやり過ぎました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蹄の跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平次はそれとなく、僭上沙汰の凉み船のことに觸れると、「今から考へると私共風情にしてはやり過ぎでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凉み船",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を斬られたかどうかして片輪になり、それから娘を仕込んで世過ぎの小泥棒を働かせて居たが、近頃圖に乘つて大きくやり過ぎたのだらう」「へエ、驚きましたね」「その娘がまた綺麗で、八五郎まで夢中になつたんだから大笑ひさ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            },
            {
              "text": "――額に古傷を描いて、番頭の太兵衞に道を訊き、ちよいと馬から遲らせたのは旦那の前だが、大した働きだ」「默れツ、無禮者ツ」「だが、三次を殺したのはやり過ぎですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "結納の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "お竹の透明な心には、内儀のお杉を殺したのは、自分を庇ってくれる気で、ツイやり過ぎた金助で、金助を殺したのは、それを知った伊太郎の仕業ではないかと思ったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
