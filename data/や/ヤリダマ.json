    "definitions": [
      {
        "index": 1,
        "gloss": "skilled control of a spear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでも頑強に応じないと、あとから立つ人の演説の中で槍玉にあげられる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌詞の中には、先生の名も他の多くの先生がたと一度に槍玉にあげられていた。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にも落第生たちは、おのれの不勉強を棚に上げ、進級生たちに何かと難癖をつけて見たいだろうし、その進級生全部の犠牲になって槍玉にあげられたのは清国留学生の周さんだ、と言えない事もない状態であったのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、ただ、レッド・テエプにすぎざる責任、規約の槍玉にあげられた鼻のまるいキリスト。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春隆もその槍玉に挙げられた一人だが、もともと鈍感なのか、大して参りもせず、むろんその雑誌の買い占めに走りまわったりせず、そんな金があればと、せっせとチケットを買って、十番館へ通っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから思うさま暴れ狂って、人間の五人、三人を槍玉にあげなければ気が済まないように思っていた播磨は、忽ちに失望させられた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで早速、君子がまず槍玉にあがった。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやはり、黙々として、心の中で「今に見ろ」という覚悟で暮しましたが、復讐すべき人間があまりに多くなってしまいには誰を槍玉にあげてよいか迷うようになりました。",
              "citation": {
                "source": "痴人の復讐",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は下宿屋の主婦を槍玉にあげようかと思ったが、あんな人間を殺しても、なんだか物足りないような気がした。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍ子への遺書」はいわゆる文壇の内幕をあばき、私行を改め、代作横行を暴露し、それぞれの作家を本名で槍玉にあげたことを、文学的意味ではなく、文壇的意味において物議をかもし出したのであった。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがもし君の上官だったら、第一番に槍玉にあげてやるところだよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「断然、槍玉にあげてやるんだがなあ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ペトローヴィッチは機会あるごとに、好んでドイツ人を槍玉にあげた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間というやつは変なもので、日頃いっこう尊敬もせず、その服装やこせこせした態度を槍玉にあげて、さんざんに自分が貶している相手から冷遇されるのをひどく気にやむものである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てはノズドゥリョフの家系までがつぶさに調べられて、親や先祖にさかのぼってまで、こっぴどく槍玉にあげられたものである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず第一にコローボチカが槍玉にあげられたが、彼女からは大して得るところがなかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この着物がどうもさつきから、散々槍玉に挙げられてゐるらしい。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓矢出入り尚更結構……塙代与九郎を槍玉に挙げて、薩州のオロシャ交易を発き立てたなら、関ヶ原以来睨まれている島津の百万石じゃ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御家を傷つけずと、老生のみを槍玉に挙げようとする策略。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "内務大臣ルイ・マルヴィ―― Louis Malvy ――を槍玉にあげた。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの会社でも既にそれに着手しているし、われわれの室では堀田が槍玉にあがることは、暗黙のうちに分っていた。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "諷刺の槍玉にあがつてゐるその当人は、痛くも痒くもないといふのでは、なんにもならず、万一、辛辣に過ぎるやうなことがあれば、忽ち、物騒な目に遭ふ前に、原稿は活字にならぬといふ不便が控えてゐる。",
              "citation": {
                "source": "続言葉言葉言葉（その一）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単にいふことを聴くものから槍玉にあげるのは、自信と勇気のない証拠である。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）諷刺の槍玉に上つてゐる主人公は、痛くも痒くもないといふのでは、なんにもならず、万一辛辣に過ぎるやうなことがあれば、忽ち物騒な目に遭ふ前に、原稿は活字にならぬといふ不便が控へてゐる。",
              "citation": {
                "source": "「風俗時評」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近は、都会といふものが、事毎に槍玉にあげられ、都会そのものが国家のため無用の長物であるかの如き印象を受けます。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう改まらなくてもいゝのに改まりすぎたり、小人数の会合で大声を張りあげたり、人の喋る時間がなくなるほど長談議をしたり、罪もない参会者の一人を序でに槍玉にあげたり、可笑しくもない洒落をひとりで悦に入つたりといふ図は、いかにもその人の「嗜み」のほどが察せられるのであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "他からよけいな誤解を受けるばかりでなく、君はよい気になって喋舌っていても、ついどんな不用意から、あの恐ろしい糾弾の槍玉にあげられるかもしれないぞ」と。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガ氏の声　　やや混乱の体でありますから、この辺で打ち切り、最後に、みなさんのお許しを得て、此のドラマの作者――名前はおわかりでせう――これを槍玉にあげることに致します。",
              "citation": {
                "source": "ガンバハル氏の実験（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "長文の手紙に何が書いてあるかというと、私の作品（主として堕落論）の批評が主であるが、中には私の作品の半数ぐらい読んでいて、一々槍玉にあげているのもある。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、維新の廃仏毀釈に、この寺が特に手痛く町民の槍玉にあげられたが、それは住職の三休が呑む打つ買うの大ナマグサのせいであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
