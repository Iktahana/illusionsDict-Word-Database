          "literary": [
            {
              "text": "焼け石に水というやつだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の寄付から一月経とうと、二月が経とうと、鯨羊羹プロジェクトは一向に話題にならず、寄付額も学生の小遣い程度増えただけで、これでは焼け石に水もいいところだった。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの一円紙幣も、もちろんすぐ焼け石に水だった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しぐらい勉強したところで焼け石に水だ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「て言うか彼がやったことは焼け石に水でね。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
