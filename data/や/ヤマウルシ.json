        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山漆の木は、紅葉の季節には鮮やかな赤色に染まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統工芸品を作るために、山漆から漆を採取する作業は大変だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "山漆の葉には、独特の模様があり、栞としても使われることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なんでも山漆、鶴虱のことが詠じてあった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の小屋は山漆を掻いて黒土と砂利で固めたのだ。",
              "citation": {
                "source": "捕われ人",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方の谷に赤々と、山漆の木が繁っていた。",
              "citation": {
                "source": "捕われ人",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "山漆の肉付の皮にて巻かたむ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちがった場所での生活の観察もよく、私は「上林からの手紙」というのと「山漆」というのと二つ随筆をかき、猶書きたい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺、楓が割合いに少く、かつひと所にかたまっていないけれども、紅葉は今が真っ盛りで、蔦、櫨、山漆などが、杉の木の多い峰のここかしこに点々として、最も濃い紅から最も薄い黄に至る色とりどりな葉を見せている。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山へはいりかかった、赤い日が、今日の見収めにとおもって、半分顔を出して高原を照らすと、そこには、いつのまにか真紅に色づいた、やまうるしや、ななかまどの葉が火のように点々としていました。",
              "citation": {
                "source": "手風琴",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
