        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで我勇敢なる大原隊は来るべき（八尋不二　宛）　（四）　戦に備えて日毎演習を行ッている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化九年、備後国深安郡八尋村に生まれた。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるのこくにいでて、いぬのこくに、やいろ（八尋）へもどる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、また二十丁ばかりも往くと三次殿の塚と云う五輪の塔があって、其の背後には俗に天狗杉と云う七尋か八尋位もある大杉が、塚を覆うように枝葉を張っていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなぞこゆ八尋の柱。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、君長の面前から下がって来た一人の宿禰が、八尋殿を通って贄殿の方へ来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長羅は剣をひっ下げたまま、蒸被を押し開けて、八尋殿の君長の前へ馳けていった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、玉簾の後に今まで身を潜めていた訶和郎は、八尋殿の廻廊から洩れくる松明の光に照されて、突然に浮き出た不弥の女の顔を目にとめた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者の呼び声は、長羅の部屋の前を通り越して、八尋殿へ突きあたり、そうして、再び彼の方へ戻って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紀・続日本紀を見ると、八尋桙根と言ふのが国々から奉られて居る。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八尋桙根は、柊の棒で作つたもので、立ち木のまゝで地を胴突くと花が咲くといふのである。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、とよたまひめの「ことゞわたし」にも、いはながひめ等の「とこひ」にも、八尋鰐や、木の花の様な族霊崇拝（とうてみずむ）の俤が、ちらついて居るのだと思ふ。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした意味から考へると、日本紀天孫降臨章にある、天孫又問曰、其於秀起浪穂之上、起八尋殿而、手玉玲瓏織※之｜少女者、是誰｜之女子耶。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある八尋殿は、構への上からは殿であるが、様式からいへば、階上に造り出したかけづくりであつた、と見て異論はない筈である。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天孫又問ひて曰はく、「其秀起たる浪の穂の上に、八尋殿起てゝ、手玉もゆらに織※る少女は、是誰が子女ぞ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "比々良木八尋桙根底不附国（播磨風土記逸文）とあるのから見ても、此桙は人を斬るものでなく、地に樹てゝ、神を祈る物なる事は訣る。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八尋桙根などをすたんだぁどに比べて見ると、幾分の似よりは見える。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紀を見ると、いざなぎ・いざなみの二神が、天御柱をみたてゝ、八尋殿を造られたとある。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八尋殿をお建てになつて、天御柱を廻つて、夫婦の契りをなさつたと言ふ。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまとたけるの白鳥――又は八尋白千鳥に化したと言ふのも霊魂の姿と考へた為であつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨風土記逸文ににほつひめの命が、自分を祀つたら善き験を出さうと言うて、「ひゝらぎの八尋桙ね底つかぬ国。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "是によりて、独り八尋屋を馳せ越えて遊行し、既に多日を経て面言することを得ず。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に歎くのみ……（履仲紀）同時に、ふるの呪術から導かれたふるやなる語が、更に一方には、八尋屋といふ風に誇張せられてゐた事が察せられる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまとたける等の八尋桙・丈部の杖からまといに至る間に、歴史の表に顕れずして過ぎた年月があまりに長く、又可なり縁遠く見える。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此話に出産の悩みをとり込んだのが、海神の娘とよたま媛が八尋鰐或は、龍になつたと言ふ物語である。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このはなさくや姫のうつむろは、戸なき八尋殿を、更に土もて塗り塞いだとあるから、すつかりものに包まれた、窓のない室の意で、空の室を言つたのではないと思ふ。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天孫又問ひて曰はく、「其秀起たる浪の穂の上に、八尋殿｜起てゝ、手玉もゆらに織※る少女は、是誰が女子ぞ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城の大沼は水深八十｜尋、凄い紺碧を湛えて温度が低過ぎるため、舌触りに荒い感じを持つが、榛名湖は水深十七、八尋で深い方ではなく、明るい淡青色で味がやわらかい。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、七、八月の三ヶ月間の鯛は、磯に近い七、八尋から十五、六尋の浅い岩礁まで遊びに出て来るのである。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "中鯛は、海底から三尋から八尋くらいのところであるが、深くなるほど次第に棚が高くなって、百尋以上になると底から、上方二十尋に及ぶことがある。",
              "citation": {
                "source": "鯛釣り素人咄",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
