          "literary": [
            {
              "text": "仕事をやり終えると急いで逃げて、玄関は共犯者に内側から閂をかけてもらった、というわけです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」だんなさんも、ぜひにということで、その夜、仕事をやり終えると、裁ち切った皮のかわりに、心づくしのおくりものを、つくえにそろえておいて、小人たちがどうふるまうのか、見とどけることにしました。",
              "citation": {
                "source": "小人のくつ屋さん",
                "author": "グリム兄弟",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親はただ二、三杯のバケツの水を使うことだけでその掃除をやり終えることができた。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "回転をやり終えると、すぐにまっすぐにはいもどり始めた。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にとってやりおえるまでの時間は、あらゆる縮約形を用いたとして……少なくとも一五分。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
