    "definitions": [
      {
        "index": 1,
        "gloss": "outlet (for one's anger, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上にまた老年が迫って来ては、心の孤独のやり場所もないであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだのやり場がございません。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "爽快な朝だった、とは今にして想うことであって、その瞬間、ぼくは身体のやり場に困るほどみじめな気持だった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり場のない憂愁が胸一杯に塞がっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べると、銀子には親を見る目もようやく開けかけており、感傷のゆえに親に尽くすのとは違って、かかる醜悪な職業に従事する女の恥辱の、心のやり場をそこに求めているのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい」　と呼ぶと、ぴくっとして、もう眼のやり場に困っている様子です。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "力のやり場に困って身もだえの果、とうとうやけくそな悪戯心を起し背中いっぱいに刺青をした。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの、やり場に窮したのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しは私にも、作家としての誇りもあったのでしょう、その誇りのやり場に窮して、うろうろあのお葉書を持ち廻っていたのに違いありません。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり場がなかったんですのに、導びきと一所に、お諭しなんです。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、こちとらは胸の前に掲げて拍手した手のやり場に困って実に肩身が狭い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく似たことなどを近ごろは初めほど感ぜずにいた源氏は、今さらのように驚くべく酷似した二女性であると思って、苦しい片恋のやり場所を自分は持っているのだという気が少しした。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "新ドンキホーテ若い跳ねまわる仔馬、青春時代の勇気、それを誰が引継いでくれるだらうか、勇気のやり場は街にはない、若いくせにノラリクラリとした思索がある、街の若い仔馬は精力のやり場にこまつてゐる女馬は強い匂ひハッカ草をたてがみにさして跳ねてゆく男馬がちかづくと女馬はうるさいといつて後脚で蹴る。",
              "citation": {
                "source": "小熊秀雄全集-9",
                "author": "詩集（８）流民詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の、身體の、やり場のない寂しみがそれである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ということもなく睨みつけて、やり場に困るお怒りをじりじりと押えつけていられたが、さッと褥を蹴って立ち上がると、荒々しげにおすだれ屏風のうしろへ消えました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、よくよく御憤懣のやり場がなかったとみえるのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにもかうにも仕様のないこの心のやり場は、やつぱりあの人の胸でなければならない。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、起きてたのかさ」　一歩だけ室内に踏みこみ、慶一は手足のやり場に困ったように、そこで立ちどまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "独りになった弟子は、いきなり師匠の絵の具箱の所へ飛んで行って、林檎の赤い色を表すために使ったギャランスフォンセと云う絵の具のチューブを握り締めてね、中の絵の具を二寸も押し出して、やり場に困ったものだから、自分の口の中へとナスリつけて了ったんです。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり場にこまる拳をもて、お前は誰を打つか。",
              "citation": {
                "source": "心の姿の研究",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然したとい先生の御取り出しになったのが、胎児でなかったとしても、Ｔ先生が誤診なさったことは事実でありますしなお又、先生が、その疑問の組織のやり場に困って、最も安全な隠し場所として、御自分の胃袋を御選びになったことも、やはりたしかであると思って居るので御座います。",
              "citation": {
                "source": "手術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　参木は手丸にとられてやり場のなくなった自分の顔を感じると、この思いがけない悲惨な醜さが、どこから襲って来たのであろうかと考えた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の目的もなく海外を渡るものは、見たいものを見てしまうと、後にはやり場のない退屈だけが残って来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は空虚な心のやり場をどこに求めようかと考えるまでもなく、いつも行きつけの同じ大川ぞいの小夜子の家へタキシイを駆るのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時は彼も心のやり場を求めて、川ぞいの家へ遊びに行くのが習慣になっていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は僕に包を渡してからは、自分の手のやりばに困って胸を撫でたり襟を撫でたりして、下ばかり向いている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいさして優美に腰を浮かせると、新子が眼のやりばにこまったほど、色っぽい眼差しで、夫君を見おろして、「じゃ、貴君、私は行って参りますから。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗けてくやしいと思う年よりの感情、せめて勝ったのならばと、自分の良人や息子を死なせた悲しさのやりばのない女性の思い。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の心のやりばにして、私はウォルター・ペイターを読んでいます。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑ひかけた微笑の眼のやりばに困つて、直吉は前よりも不機嫌で木柵に凭れてゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
