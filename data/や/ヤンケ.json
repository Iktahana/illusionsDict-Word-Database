        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "じやんけんをして、良寛さんが一番初めにつき出した。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一層、一刻も早く使者として遺すための一名のジヨーカーを抜き出すべく、一同の者は輪をつくつて、じやんけんの声をそろへた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪江が戻つて来た時一同は車座になつて、割れるやうな声を張り挙げて、じやんけんに熱中してゐるところだつた。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鍋と　お皿が　じやんけんをして、まけたはうが　のぼつてゆくことに　しました。",
              "citation": {
                "source": "お鍋とお皿とカーテン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時やんけえ、びっくりしたあ」「びっくりするこたあ、なあじゃろ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
