[
  {
    "uuid": "3d3bf57e-716d-5270-85e8-ee4ccf86af3c",
    "entry": "夜盗",
    "reading": {
      "primary": "やとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "night burglar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぼくはまるで権十が甘藍の夜盗虫みたいな気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手も足も膨れているからぼくはまるで権十が夜盗虫みたいな気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬治君に教へられて、大根の芽を噛み切る夜盗虫なるものを退治してやつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は柳橋の小雛で、男は秩父の熊吉、この熊吉は巾着切から仕上げて、夜盗や家尻切まで働いた奴、小雛はそれと深くなってしまって、土地にもいられないような始末になる。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまことは、かゝる山中に潜み隠れ居る山賊夜盗の首領なりしかと今更に肝を消しつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その夜盗がです。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして真夜中でさえ水蒸気の多い悪臭のある大気から発散するあのものすごい光によって、略奪の犯行をやっている最中に疫病の手にとっつかまれた多くの夜盗どもの死骸が、路地や横通りに横たわっていたり、窓のない家の中で腐っていたりしているのが見えるのであった。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "この謡に猩々が霊泉を酒肆の孝子に授けた由を作ってより、猩々は日本で無性に目出たがられ、桜井秀君は『蔭涼軒日録』に、延徳三年泉堺の富家へ猩々に化けて入り込み財宝を取り尽した夜盗の記事を見出された。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、昨夜と今宵と、倭文子に会う少しの機会でもないかと、別荘の周囲を、夜盗のようにうろつきまわっていたのだろう。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る理由で、夜盗が私であるといふことが解つてゐる限りは、現行を差押へて腕力沙汰に訴へぬ限り、その縁家先では所置を施す術がなかつたので、私はその所行は私であるといふ一札を残して、首尾好く或る仕事を遂行した。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だから何も頭ばかりが先に格構がつくといふわけではないので――と続けようとしたのだつたが、頭と云へば近頃また今は再び正しくも専門の夜盗としてのみの働きにだけしか動いてゐないそんな頭に思ひ及べば、たゞ斯うして「頭」といふ言葉を口にするのさへ辟易したのである。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四五日来あれこれと計画した夜盗の手段に関して、此度のモデルの仕事中に決断をつけようとさへ考へてゐたのである。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、これからは当分こゝろおきなく「私」の方に専念することが出来るとよろこんで、相変らず「夜盗の夢」にばかり耽つてゐるあはれなモデルを相手に仕事をつゞけた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……浅間しい「夜盗の夢」が少しづゝ薄らいで来たかと思ふと、私はいつの間にかゝらりら子のまぼろしを切りと追ひつゞけてゐる自分に驚いた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或る街では橋と生れて八十年の間多くの人の足に踏まれ、或ひは夜盗が所有する鍵束の中の一個の鍵であつたこともある。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその画を見、その文章を読みながら、せめてこの身も男と生れた甲斐性には、たとへ海賊の末輩であらうが夜盗の弟子とならうが悔いもない、あのやうな美女の肩へなりと腕でも載せて見たきものよ――と希つた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは既に幾度目かの夜盗の仕事である。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上また滝本に就いては、それらのものに至るまでの所有権云々に関して堀口剛太が邪な監視の眼を輝かせてゐるので、何うしても彼等は夜盗の手段を執るより他に道がなかつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾好しとばかりに躍りあがつて乗り込んで行つた夜盗達を、眼下に、百合子が廊下の窓から雪洞を翳して乗り出しながら囁いた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと思ふと、斯んな金目にならぬガラクタには眼も呉れずに踏み越へて行く夜盗達が、懐中電灯をピカ／＼と振り回しながら脚元を照らしたり、隅々を見とゞけたりする毎に、それらの動物が闇の中から稲妻を浴びて飛び出すかのやうに映つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とか、蜜柑畑が太十の名前に書き換へられたのを知つてからといふもの彼等は夜盗の練習をはぢめたといふことだ、物騒だぞ！",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺達が夜盗に変つたら、それこそ鬼に金棒と、奴等が震へてゐる有様を想像すると痛快ぢやないか！",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る高価な彫像が今夜盗まれたのだが――ウッドワード氏は日曜版を印刷に廻わしてから可なり遅くなって帰宅した。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」道もない竹籔などを抜けて、夜盗ぢやあるまいし！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の××宝石商は、東京でも屈指の大店で、時価八十万円の首飾りが、一夜盗賊のために盗み去られたのであります。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれからというもの夜盗のように家人の隙を狙うと同時にリカ子と結婚する準備ばかりに急ぎ出した。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等はよくそこへ、煙草がなくなると、夜盗みに行った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年の間にわずか一、二円の金を払うて政府の保護を被り、夜盗押込みの患いもなく、ひとり旅行に山賊の恐れもなくして、安穏にこの世を渡るは大なる便利ならずや。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月の鉛の雲さびに〕月の鉛の雲さびに、　　　　　みたりあやつり行き過ぎし、魚や積みけんトラックを、　　青かりしやとうたがへば、松の梢のほのびかり、　　　　霰にはかにそゝぎくる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆の十六日なので鉱山も休んで給料は呉れ畑の仕事も一段落ついて今日こそ一日そこらの木やとうもろこしを吹く風も家のなかの煙に射す青い光の棒もみんな二人のものだった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
