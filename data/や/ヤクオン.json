        "examples": {
          "standard": [
            {
              "text": "「さようなら」が「さいなら」になるのは、典型的な約音の一例である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現代の若者言葉でも、面倒な発音を避けるために約音が生じることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "方言の研究において、語中の母音がどのように約音化するかを分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ケは喰への約音である。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく、御奉公人の端にたたれ、お上さまの御用、ようやくおん大事の身となりつる折へ、わが身や夫や、たくさんの同胞たち、お許の身にかかり候ては、朝夕は楽しかるびょうとも、何ぞにつけ、御奉公の足でまといにこそ候わめ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
