[
  {
    "uuid": "bf4bb2eb-b597-5985-a7f5-303489d86194",
    "entry": "ヤクザ",
    "reading": {
      "primary": "ヤクザ",
      "alternatives": [
        "やくざ"
      ],
      "is_heteronym": false
    },
    "grammar": {
