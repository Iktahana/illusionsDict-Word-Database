    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(member of the) yakuza",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「……あなたって人は……ほんとに仕様のない人ね」「……ウーン……どうせヤクザモノさ」「だけど……」「何だい……」　私は追いかけるようにこう云いながら心もち冷笑を含んで彼女を見上げた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御名物のお殿様でごぜえますから、直に申しまするが、名前は人好し長次、まとまった金がころがりこむと、じきにうれしくなって人にバラ撒いちまいますんで、この通り年がら年中文なしのヤクザ野郎でごぜえます」「わはは。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "読まない奴はヤクザ者だ』そういう態度で書かれた物が、世に謂う所の純文芸です。",
              "citation": {
                "source": "大衆文芸問答",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違いや出鱈目を報告するので、法螺熊という異名のある、ヤクザの手先もあることはあったが、松吉という手先などは優秀な腕を持っている。",
              "citation": {
                "source": "半七雑感",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このヤクザな大衆作家を、チェホフやモーパッサンと同じように、評価して下すったのは名誉です。",
              "citation": {
                "source": "又復与太話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　ウェルシーニンの「死の爆弾」を、喝采謳歌しないような、探偵小説家はヤクザである。",
              "citation": {
                "source": "マイクロフォン―雑感―",
                "author": "「新青年」一九二五年一二月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤクザだね、この世界は、隅から隅までむだばっかりだ」「なぜだい？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが築土にわからぬとは、ヤクザ者だな、このべら棒！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、賊ではなさそうだな」「ヤクザ者ではございますが、コソコソ泥棒ではございません」忠三ヒョコリと辞儀をした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともおれにカマをかけられ、チョロッカにねぐらを明かすようじゃア、よくよくヤクザな人間だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいがいのヤクザはあんな場合にはきまって斬り込んでくるものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤクザだなあ、え、唐津。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節の祭礼は過ぎたのに――花の盛は過ぎたのに、――古ぼけた思想を後生大事に、守っているヤクザな思想家のように、どうして何時迄も過去を夢見て――あった日の貧弱な全盛に縋がって、獅噛みついてなんかいるのだろう？",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが明けると、一年の礼奉公――それを勤め上げないものは碌でなしで、取るにも足らぬヤクザ者として町内でも擯斥されたものでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "私の子供の時のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はもうこの世の中に用の無いような人間だ、青木君なればこそ自分のようなヤクザなものを捨てないでこうして三度の飯を分けてくれるんだッて――ね。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫂はそれを引取って、「ヤクザなものだ、ヤクザなものだッて、父さんは節のことを悪くばかり言って――九円でも十円でも取ろうと思えば取れるものを」　そう言って涙ぐんだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酔生夢死」は自分のようなヤクザ者には至極嬉しい言葉である。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酔生夢死」は屡々軽侮の意をもって僕のようなヤクザ者の形容詞に用いられてきた。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生むにしても自分のようなヤクザ者をわざわざ生みつけようとは思わなかったにちがいない。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程、自分が今迄生きてこられたのは、少なくとも自分のような蒲柳の質の生活力の弱いヤクザ人間が生きておられたのはまったく自分以外の人々のお蔭だということは一応わかりはするが、僕は別段、これを自分の意志からお願いした覚えは毛頭ないのである。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭でスッカリ身体をヤクザにした上に、今の十字丸に乗ってから一年目に、瀬戸内海で推進機を振り落した。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ」「しっかりして……」「あァ……」かわいた唇をなめて微かに「わかってるヨ」　二人の若者は、きっちり坐っている膝頭に両手を突っぱり、「俺たちのような、ヤクザとは違うんだから全く気の毒です」と云った。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ」と叫んだは小一郎で、微塵に下頤を叩っ壊され、上下の歯を吹き飛ばし、舌を噛み切り血嘔吐を吐き、グ――ッ背後態にへたばったなら、ヤクザな武士と云わなければならない。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう甲斐｜撫でに盗まれるような、そんな永生の蝶でもなく、それにまた蝶を盗まれるような、ヤクザな館主でもない筈だ！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七福神組が怪盗でもまた行動が敏捷でも、なんのそれらにムザムザと、捕えられるようなヤクザではない。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の兄ながら弁太という男は、どうしてヤクザの破戸漢だよ。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セチ辛い浮世だ、そうでもないヤクザが、僅の餬口にあり付こうと、柄にもない芝居を打つこともある。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤクザ者なら叩っ切る。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
