        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家中をほっつき回って、やりたい放題だ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけやりたい放題やって、被害者はないぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おれはもう一生涯、やりたい放題のことをやって、出たら目に送ってやるぞ」「それが汝が身の悪い気質じゃ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やりたい放題やったが、結局これでよかった。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりたい放題の男だった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る限り、今ならやりたい放題だ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中はやりたい放題ですからな。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵のコプリは強力、やりたい放題だ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはやりたい放題をやった身だから、おまえが去っても決して恨みには思わない。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに彼は、豊田郡の本拠を、占領して、狼藉、掠奪、破壊、やりたい放題なことはやった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりたい放題、都の秩序を乱している。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるときに、できることを、やりたい放題やっておけ」という浅見を深い諦観みたいにみな持ちだした。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなったら　ネズミたちも　やりたいほうだい　――　おやゆびトムの　ひどいことと　いったら！",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
