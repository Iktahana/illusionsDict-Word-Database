        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ハンガリーの夏は 〔nya'r〕（ニヤール）。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集が一度にプロージット・ノイヤール、プロージット・ノイヤールと叫ぶ。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れて来る人々もあちこちの横町からプロージット・ノイヤールと口々に叫ぶ。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って寝ようと思ったら窓の下でだれかプロージット・ノイヤールと大きな声がして、向こうの家からプロージットプロージットとそれに答えているのが聞こえました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺々の鐘が鳴り渡ると爆竹がとどろいてプロージット、プロージットノイヤールという声々が空からも地からも沸き上がる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつからこの店に出たの」「今日から……タッタ今……」「今まで何をしていたの」「妹のマヤールと一緒に日本の言葉習っておりましたの」「どこに居るの、そのマヤールさんは……」「二階のお母さんの処に居ります」「フウン……お父さんはどこに居りますか」　私の言葉が自然と叮嚀になった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル・ロアイヤールというのの馬車でハース氏の親子三人といっしょに宿へ着いた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてマリーが二十二歳になるまで過ぎていったが、そのとき彼女のすばらしい美貌が、パレ・ロワイヤールの地階に店を持っていて、その付近に巣くっているごろつき投機師どもをお得意にしているある香水商の眼にとまった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三年半ばかり以前（６）、この同じマリー・ロジェエがパレ・ロワイヤールのル・ブラン氏の香水店から姿を消して、今回のとたいへんよく似た騒ぎを起したことがある。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜のこと、我々はパレ・ロワイヤール付近の、長い、きたない街をぶらぶら歩いていた。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いではチヤールス・ダーヰン、リップシュタットのヘルマン・ミユラー博士、ヒルデブランド、伊太利人デルピノオ、ウヰリアム・フーカー卿、ロバート・ブラウン等の著書を御薦めする。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然してこれらの花の霊に於ける最も英雄的努力の驚嘆すべき伝記を述べた書はチヤールス・ダーヰンの「蘭と昆虫」である。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉饅頭８・29（夕）　近頃チヤールス・シユワツブといふ男が、カアネギーと他の富豪との比較をした事がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優と監督９・11（夕）　以前何かの折に一寸引合に出した事のある米国の劇場監督チヤールズ・フロオマンは、恐ろしい厳し屋で、相手が誰であらうと、自分の指図に従はないものは手厳しく遣つ付けるので名高い男だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『シエーキスピア物語』で日本人にもよく知られてゐるチヤールス・ラムが、ある時多くの知合と一緒に誰かの晩餐に饗ばれた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人こそ誰あらう、ベスレム製鋼会社の社長から螽斯のやうに一飛びして米国管船局総裁の位置に上つたチヤールズ・シユワツプ氏である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通、服地とか袖口とか裾よけとかになるレース地は、絹物、ジョーゼット、木綿、人絹などいろいろあって、機械にかける前、十ヤールに縫合せる。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、わざわざ秤にかけたり、物指ではかってみたりするまでもなく、ちょっと品質を見ただけで、羅紗なり他の織物なりが何ヤールあるかということを一目で見抜いたり、小包みを手に持って見ただけで、即座にその目方が何百匁あるかを言いあてたりすることが出来た。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのもと町で染物工場をもっていたニキフォーロフの家が、集団農場組織についての調べから家宅捜索をくって、銀のサモワール三つ、絹地総体で三百五十ヤール。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつんところじゃ、その三百五十ヤールの絹の布の、九十ヤール腐っていたそうだよ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百五十ヤールの絹が何だ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おら絹三百ヤールより、耕地で働く手がもう四、五本欲しいわ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、白い、いい歯をキラキラさせて笑いながら、　――おいらの村のどっかでも、大方二ヤール位の絹は腐ってるべえ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その所々に、ヌーシャテル甲冑やマキシミリアン型、それにファルネスやバイヤール型などの中世甲冑が陳列されていて、銃器と云えば、わずかに初期の手砲を二つ三つ見るにすぎなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Y〔a:〕'lu（ヤールー）【固名】鴨緑江。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "Y〔a:〕rd（ヤー※ド）【名】（一）ヤール（三呎）。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンガポールから入る英国、インド産綿布は香港で一ヤール一円五十銭ヤスになった。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
