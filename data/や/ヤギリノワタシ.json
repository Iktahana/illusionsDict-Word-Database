        "examples": {
          "standard": [
            {
              "text": "柴又から江戸川を渡る「矢切の渡し」に乗り、のどかな風景を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "船頭さんが櫓を漕ぐ音だけが響く矢切の渡しは、まるで時間が止まったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歌謡曲の舞台としても有名な矢切の渡しは、今も観光客に親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近所の釣り場所は大抵あさり尽くしているので、柴又の帝釈堂から二町ほど離れた下矢切の渡し場の近所まで出かけたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方に絞められてしまったそうですよ」「鳥亀の亭主というのは、矢切の渡し場の近所へ釣りに行って、沈んでしまったというじゃあねえか」「よく知っていなさるね」と、庄太は眼を丸くした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            }
          ]
        }
