        "examples": {
          "standard": [
            {
              "text": "春の庭園では、鮮やかな青色の矢車菊が風に揺れ、訪れる人の目を楽しませている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女が好んで描く水彩画には、繊細なタッチで表現された矢車菊がよく登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "花壇の一角に矢車菊の種をまいたら、数週間後にかわいらしい芽が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どうぞ、ウォツカは矢車菊を浸けたのにしませうか、それとも、＊トゥロヒーモフのにしませうか？",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は先刻旦那の仰しゃったことを聞いたかね」「ああ聞いたよ」「そんなら、何でぐずぐずしているだ」「今行くよ」　かがんだままに、乱れた後れ毛を掻きあげてから、両手を腰へあてて、派手な裾着の下でくるっと胴体をひねると、彼女は矢車菊を一本｜唇に啣えて、畦づたいにすたすた歩きだした。",
              "citation": {
                "source": "麦畑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢車菊や雛罌粟が我々の腕にはみ出してゐた。",
              "citation": {
                "source": "〔翻訳〕ステファヌ・マラルメ",
                "author": "ヴァレリイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
