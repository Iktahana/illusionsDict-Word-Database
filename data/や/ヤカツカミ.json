        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "併し恐らくは、火の神の為に、建て物を構へたのは一つもなく、建て物あつて後に、火の神を祀る事になつたので、某々の家の宅つ神、と考へて来たのに違ひない。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、自分ののろ殿内の宅つ神なる火の神に事へる。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "のろ殿内に祀るのは、表面は、火の神であるが、此は単に、宅つ神としてに過ぎない事は既に述べた。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
