        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奥の正面、及び右なる廻廊の半ばより厚き壁にて、広き矢狭間、狭間を設く。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女郎花　矢狭間も、物見も、お目触りな、泥や、鉄の、重くるしい、外囲は、ちょっと取払っておきました。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すッと向うに浮いて行って、遠くの、あの、城の壁の、矢狭間とも思う窓から、顔を出して、こっちを覗いた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の帆柱、船首の戦楼矢狭間が諸所に設けられている。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしく立派な船であって、しかも普通の客船でもなく、また普通の荷船でもなく、軍船型と遊覧船型とを、折衷加味した特殊の船で、矢狭間がしつらえてあるかと思うと、管絃の宴を催すによい、朱塗りの舞台などが出来ていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月六日のくだりを記録によつて調べると、原城では十二月朔日に立籠つた一揆軍が矢狭間を明け堀をほり、この工事が完成して妻子を城内へ引入れた日であり、その翌日には天草甚兵衛が手兵二千七百をひきつれて入城してゐる。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つとも同じような建て方で、その特色とするところは、矢狭間づくりの窓のあることと、四筋の長い廻廊をもって、本邸と通じていることとであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出邸には全く人気がなく、矢狭間造りの窓から覗くと、内部は整然と片付けられていた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港には二千石積、三本帆柱の大船が五艘ももやいあい、向うの岸には足場を高く組んでさかんに船作りをし、山の中腹には天主閣のついた城のようなものがあって矢狭間にはずらりと大砲の口が並んでいる。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "古畳が一帖あるだけで、あとは板敷だし、階段口と矢狭間から風がはいるからひどく寒い。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広さは十六帖、西に面して板敷の押廻しがあり、妻戸も遣戸もあけてあるので、小砂利を敷いた広場が、矢狭間のある白い土塀まで、初秋の午後の陽をあびて、眼にしみるほど明るく見えていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　まぶしいような七月の日光が、矢狭間からさしこんでいた。",
              "citation": {
                "source": "日本婦道記",
                "author": "笄堀",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、結構の中心をなす天守閣はというに、城中の最も高い位置に、数十間の楼台を築き、さらに巍々たる層々の五重が設計されてあり、総塗り籠め、大矢狭間を開き、頂上の瓦は、悉く消金をもって箔るとある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このようなうちに住むは、もういっ刻もいやざます。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
