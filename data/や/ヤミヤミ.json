    "definitions": [
      {
        "index": 1,
        "gloss": "without one's knowledge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
