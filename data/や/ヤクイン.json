[
  {
    "uuid": "56c14c12-c7fb-5096-bb62-745020100ee2",
    "entry": "役員",
    "reading": {
      "primary": "やくいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
