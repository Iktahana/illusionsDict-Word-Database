        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしろ、という八つ当りの気持だった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の代表的な思想家という説明文が附いていて、その友人は、八つ手の傍で胸を張って堂々と構えていた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景な下宿の庭に鬱陶しく生いくすぶった八つ手の葉蔭に、夕闇の蟇が出る頃にはますます悪くなるばかりである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とつひに八つ當りの論法に變じた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の代表的な思想家といふ説明文が附いてゐて、その友人は、八つ手の傍で胸を張つて堂々と構へてゐた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペイドオフ（馘首）の食いたてなんだ」　浚渫船のデッキから、八つの目が私に向いた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つ八つの童女の容貌を持ち、ただその儘で身体は大きい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "消ゆるかに見えて、また立つ漣……」　岳麓にできた八つの湖、その一つ一つを見まもる八人の河神の若い瞳。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て常陸の山に在って旅人から聞いた話の、八つの湖に女神の姿を待ち侘ぶ河神たちの姿も眼の前に見た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い瞳がうち看守る八つの湖、春を敷妙の床の花原。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心は七八つの幼ないものだが年齢はもう十六七の青年に達していた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は藤川から出発し岡崎で藤吉郎の矢矧の橋を見物し、池鯉鮒の町はずれに在る八つ橋の古趾を探ねようというのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふ岸の暗いどてにも火が七つ八つうごいてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八個の趣味を八つの頂点に置く。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つ切りくらいのスケッチブックへ鉛筆で簡単なスケッチをしたが、それは普通の意味の似顔としてはあまりよく似てはいなかった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、Ｔ「伝八つあんと仰しゃるんでしょう」　棚倉さてはと思って門弟に合図する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が出て行った後、膳の後仕末をして、子供の正月の晴着に手をつけている間に、お八つの時刻が来たが、彼等は帰って来なかった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びに気がとられていても、お八つの時には必らず「なにか」を貰いに帰って来る子供が常になく帰って来ないのは、彼女の心に漠とした不安の錘を投げ込んだ。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つの橋をモルダウ河に渡して両岸に跨がっているプラハの都府で、幾百年かの旧慣に縛られている貴族の家に、千八百七十五年十二月の九日に生れたということです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、其處に八つ並んだ窓の一つ一つの中には寢てゐる病人の黒い頭や、氷嚢を換へたりなどしてゐる看護婦の顏がちらちらと見えた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、その向うの八つの窓にはぱつと電氣が點いた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その暗さの中に向う側の八つ並んだ病室の窓の明りがくつきりと見え出した。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人間の「本家」がまき歩くビラの「ホンケ」は、鼻紙を八つ切りにしたのに粗末な木版で赤く印刷したものであったが、その木版の絵がやはり蝙蝠傘をさして尻端折った薬売りの「ホンケ」の姿を写したものであった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大小さまざまのが少なくも七つ八つは居るらしい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々に雨戸を撫でる庭の八つ手の大きい葉に、雨の音がぴしやぴしやときこえるのも、外の暗さを想はせるやうな夜であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話の濟む頃には夜の雨もだんだんに小降りになつて、庭の八つ手の葉のざわめきも眠つたやうに鎮まつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その余威を駆って、と言っては不穏かもしれないが、自然派以外の作者たちは、たいていこの一派でやっつけられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俎上に載せられたのは、麗水、桂月、天随、花袋、孤雁及び私であったが、一番ほめられたのが花袋と桂月で、当たらずさわらずのところが麗水、孤雁、最も手ひどくやっつけられたのが天随と私で、ことに私はひどく攻撃せられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっつけてやる、俺だけの苦しみじゃない、何十、何百、何万、何億の苦しみだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
