          "literary": [
            {
              "text": "一刻もはやくどうにか始末をつけて貰いたい。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさ、さめないうちに、おはやくどうぞ。",
              "citation": {
                "source": "にいさんと妹",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでずいぶんあたまをつかったけど、ようやくどういうことなのかなっとくできた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくどこかへかくしてくだせえ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "王九媽達は面倒臭くなり、終いにはむっとして、棺桶の側から彼女を一思いに引剥がしたから、そのお蔭でようやくどたばたと蓋することが出来た。",
              "citation": {
                "source": "明日",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お喜乃をはやくどうかしろ」「よほど、お気に召したとみえますね」「ちょっといいぞ」「ちょっとですか」「うるさい。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は目をとじたままでそのせつない、頼りない、奇怪な悩みをどうぞして皆にわからせてはやくどうにかしてもらいたいというように苦しいなかに言葉に力をいれてくりかえしくりかえしこんなことをいった。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、屋敷のなかでは、かえりのおそい博士の身をあんじて、頼子をはじめ看護婦の平松や笠井、女中のおもとや車夫の吉蔵たちが、どんなに博士のかえりをまちわびていたかは、もはやくどくどと、申しあげるまでもありますまい。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにもう城太郎のすがたは、すぐ眼の前へ来てしまったので、伊織はいかんともする術がなく、栗鼠のようにすばやくどこかへ隠れこんでしまったらしかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくどこか探して良人を連れておいで。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居候のクセにして」「ぬかしたな」　婆はすばやくどこかへ隠れた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
