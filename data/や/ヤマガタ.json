    "definitions": [
      {
        "index": 1,
        "gloss": "Yamagata (city, prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
