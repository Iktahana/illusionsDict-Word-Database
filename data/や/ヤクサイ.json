[
  {
    "uuid": "9be3eb24-df2b-596b-95e3-58f2930ef33b",
    "entry": "厄災",
    "reading": {
      "primary": "やくさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "calamity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この戦役は多くの者に論功行賞をもたらす形となったが、私にはただ不運厄災あるのみだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし送られたら、多分そのまますててしまうだろうと思うけれども、立ちどころに厄災来る、というようなことが書かれていたら、やっぱりいい心持はしないであろう。",
              "citation": {
                "source": "幸運の手紙のよりどころ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前線に愛する誰彼を出しているような人にとって、厄災と云う字は笑いすてきれないかげを投げるだろう。",
              "citation": {
                "source": "幸運の手紙のよりどころ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、午年生れは山にて跳るべからず、厄災あり。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瘠せこけた、沈んだ顔色をした青年は、どういうゆえんによってか、石亭先生の馬鹿げた自尊心を害うことのない、もっとも聡明な方法で、当然、先生にひどい厄災を齎すであろう危険な地区から、それとなく追い立ててくれたのだった。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄坂の石段下には、薬師本願経一千部を一字一石にして納め、男女の厄災を払ふ効験がある。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体の苦痛にさらに別の厄災がつけ加わった。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
