    "definitions": [
      {
        "index": 1,
        "gloss": "bitter seeded cardamon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
