    "definitions": [
      {
        "index": 1,
        "gloss": "yard (unit of distance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北京停車場の一号プラット・ホームに南京発列車が到着すると、奇襲弾薬が破裂して数十名の死傷ができると時刻を同じくして碼頭苦力が暴動に参加した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、もと、上海の碼頭苦力だったという話である。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然彼等の前方二十｜碼程のところの草むらが揺れたかと思うと、一匹の黒い耳の兎が飛び出した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれを、その翌々日、酒山碼頭を日本へ向って解纜しかけた船の中で知りました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで許宣は白娘子と二人で碼頭の傍へ手ごろの家を借りて薬舗をはじめた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで許宣は碼頭の家を畳んで、再び李克用の家へ移ったが、十日と経たないうちに朝廷から恩赦の命がくだって、十悪大罪を除く他の者はみな赦された。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな黒牝豚が五百｜碼も泳いだのを、私は確かに見た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更のアピアの街のこととて何処も彼処も真暗だが、此の高い塀は、其処から二十｜碼ばかり行くと切れていて、その向うには、どうやら薄黄色い光が流れているらしい。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで許宣は白娘子と二人で、碼頭の傍へ手ごろの家を借りて薬舗をはじめた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、許宣は碼頭の家を畳んで再び李克用の家へうつったが、十日と経たないうちに朝廷から恩赦の命がくだって、十悪大罪を除く他の者は皆赦された。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお更にこのレーヌ公園と云うのは、大変人通りのある処である上に、更にその家から百｜碼もないくらいの処に、車の立場もあるのであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう吾々の直前三｜碼のところである。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがちょうど二週間前でございますが、私がちょうどそこを通っている時に、ふと肩越しに後を振り返ってみましたら、やはり自転車に乗った一人の男が、私の後方二百｜碼くらいのところをついて来るのに目が止まりました。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男もすぐに止まって、二百｜碼ばかりの間隔を保った。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとまたその男も引き返して、やはり二百｜碼ばかりの間隔で、二人の姿はその先の曲り角から、私には見えなくなってしまった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も何百｜碼と云うものを離れて見たので、あの娘さんのスミス嬢以下の報告っきり出来ないじゃないか、あの女は自分が知らない者だろうと云っていたが、しかし僕の見るところでは、あの女が知っている者に相違ないと思うのだ。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の跳ね返るような歩調は、決して衰えなかったが、私から百｜碼ばかりも先んじて行った彼は、ふと立ち止まった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その流れの驚嘆すべき烈しさは種子をば生れた樹から四五碼もの向ふへはぢき飛すのである。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……五六月の候、いとも勇敢に、路傍に南方の山中に、或時は高さ三碼にも達する巨大な総づきの毬を形つくり、純金の壮麗な箒でもつて蔽はれ、その香芬は、灼熱した太陽の威烈のもとに謂ひ知れぬ歓喜を漲らすのである。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "身には袖の広い裾の長い白絹の着物を着て、上に黒狐の皮の外套を重ね、頭に碼瑙の冠を戴いて、手に黄薔薇の籠を持ちました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――因みにバラルダの大きさは、直径凡そ五碼とあるから、私達の水車の大きさであり、六頭の牛をもつて曳かれ、二十人の使丁に後おしされて、はね吊籠型の投石機仕掛になつた大撥で打たれるとの事であつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動では六百｜碼の全校一の選手だった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、再び潜行し、今度は入江の鼻――距離約二千｜碼とおぼしいあたりから、とどめの二矢を火焔めがけて射ち出したのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、四十｜碼スクラムからスリークォーター・パスになって、それを、私がカットして好｜蹴をタッチに蹴出す。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挙これじゃ、三十｜碼挽回ね」「分りませんね。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面積が六万坪あることや、延長が三千｜碼におよぶことなどは、私にはどうでもいい。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙「あなたの方では現在どこの碼頭を占めていますか」甲「只今△△碼頭です」　乙は尚暗号のことなどを尋ねるが、それが一通り終ると今度は甲が乙に対し同じようなことを尋ねる。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風に彼等は沢山の費用を要する場合がよくあるので、どこか一つ大きな碼頭を管領して置かないとその方の自由がきかぬ。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叫ぶので、愕いて頭を上げると、今しも一個の端艇が前方十四五ヤードの距離に泛んで居る、之は先刻多人數が乘つた爲に、轉覆した中の一艘であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等も喫驚して其方を振向くと、此時、吾等の立てる處より、大約二百ヤード許離れた森の中から、突然現はれて來た二個の人がある。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
