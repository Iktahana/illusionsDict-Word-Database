    "definitions": [
      {
        "index": 1,
        "gloss": "to suffer damage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やはり※祇尼法であったろうことは思遣られるが、他の者に祈られて狐が二匹室町御所から飛出したなどというところを見ると、将軍長病で治らなかった余りに、人に狐を憑けるなどという事が一般に信ぜられていたに乗じて、他の者から仕組まれて被せられた冤罪だったかも知れない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一度口へ出して、ピシリと遣られる、二度とは面は向けられまい、お鹿も今夜ぎりと思うと何となく胸が迫って卓子台の上が暗かった……」　お孝はポンと楊枝をくべた、すうッと帯を揺って焦れったそうに、「ちょいと、まあ、待って頂戴よ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "處を惣領が甚六で、三男が、三代目の此の唐やうと來た日には、今はじまつた事ではなけれど、親たちの迷惑が、憚りながら思遣られる。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはともかく、あの悪智慧のほどが可恐しい、行末が思い遣られると、見るもの聞くもの舌を巻いた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "意気張ずくで死んで見せように到っては、益々悩乱のほどが思い遣られる。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "異香室内に滿つ――で、尊さが思遣られる。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※き騒いで呼立てない、非凡の見識おのずから顕れて、裡の面白さが思遣られる。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の西北方から勢を起しながら、山の手の高台に阻まれ、北上し東行し、まるで反対の方へ押し遣られるような迂曲の道を辿りながら、しかもその間に頼りない細流を引取り育み、強力な流れはそれを馴致し、より強力で偉大な川には潔く没我合鞣して、南の海に入る初志を遂げる。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南岸には石楠花が簇生してゐて、今は花はすがれてゐるが、花時の美しさは思ひ遣られる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に絲川老人の宿つた夜は恰も樹木挫折れ、屋根廂の摧飛ばむとする大風雨であつた、宿の主とても老夫婦で、客とゝもに搖れ撓む柱を抱き、僅に板形の殘つた天井下の三疊ばかりに立籠つた、と聞くさへ、……わけて熊野の僻村らしい……其の佗しさが思遣られる。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の形相の凄じさは、ま、どの位であったろうと、自分でも思い遣られるよ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位な事を遣られるのは無理はない。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで誰にも云わずにおりましたが……懲役に遣られるかも知れませんので……。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は目が覚めつつも、まだ、その俤が室の中に朦朧として残ったが、吻と吐く呼吸にでも吹遣られるように、棚の隅へ、すっと引いて、はっと留まって、衝と失くなる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのその羅を透くと聞きましただけでも美しさが思い遣られる。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に糸川老人の宿った夜は恰も樹木｜挫折れ、屋根｜廂の摧飛ばんとする大風雨であった、宿の主とても老夫婦で、客とともに揺れ撓む柱を抱き、僅に板形の残った天井下の三畳ばかりに立籠った、と聞くさえ、……わけて熊野の僻村らしい…その佗しさが思遣られる。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹込む呼吸が強くなるためだといって抱主が、君、朝御飯も食べさせない、耐るもんか、寒い処を、笛を習ってる中に呼吸が続かぬから気絶するのが、毎朝のようだ、水を吹かけて生返らして、それから握飯の針のようなのを二ツずつ貰って食べる、帰ると三味線のお温習をして、そのまま下方の稽古に遣られる。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "息苦しいほどで、この日中が思遣られる。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八郎の顔色が思い遣られる。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「色々の事を聞くやうだが、お前が今度島へ遣られるのは、人をあやめたからだと云ふ事だ。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「色々の事を聞くやうだが、お前が今度嶋へ遣られるのは、人をあやめたからだと云ふ事だ。",
              "citation": {
                "source": "高瀬舟",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様が、倅も卒業すれば、是非洋行をさせねばならないが、卒業試験の点数次第で、官費で遣られるか、どうだか知れないと話すと、わたくしがお金を持っていれば、有るだけ出して学資にして戴きとうございますなどという。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな捫懌最中に、狭山さんの方が騒擾に成りましたんで、私の事はまあどうでも、ここに三千円と云ふお金が無い日には、訴へられて懲役に遣られると云ふんですから、私は吃驚して了つて、唯もう途方に昧れて、これは一処に死ぬより外は無いと、その時｜直にさう念つたんで御座います。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、夜半、美人と弗旦らしいのを乗せる光栄を有した場合に、郊外の人跡｜稀な処でよく買い物に遣られる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間苦を知らぬ哀れ　浅草公園内のチンピラは、よく不良少年の手先になって手紙なぞのお使いに遣られる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、こんな事実を見たり聞いたりして来ると、東京の前途が思い遣られる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえに自治制の本当のうま味がわかって、あした懲役に遣られることがわかっていても、やめる気にならぬものだそうである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様のような奴に鐚一文でも余分なものが遣られると思うか。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）六郎　どうして無暗に遣られるものか。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯かる時芸術家が、否応なしに逐ひやられるのは風物の方へであり、世間がセチ辛くなればなる程、詩の方は却て浮世離れがして来るなぞといふことも、ありさうでないことではない。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
