        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ガタツ、ピシヤーン。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "キヤーンといふ犬の悲鳴が起つたかと見ると、「畜生、引つ掻きやがつたぞ！",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ位の儲けは此の二年の間にチヤーンとさせてありますがな！",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わてにはチヤーンとわかつてゐますがな！",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それはな、わてのお母はんがチヤーンと教へはつたから間違ひおまへん。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……んでも、昔、わてのお母はんが居やはつた事は、チヤーンとわてが知つてますがな！",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヤーンと確かな、たとへ世の中がデングリ返つても、間違ひのない事どす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そん時には、今わてはチヤーンとかうして奥さんを可愛がつて看病してあげたのどすよつて、こんどめ生れ代つて来たら、わての方が奥さんにターンと可愛がつて貰ひまつせ！",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母　（美緒の声が低いので聞えず、その仕草だけを受取つて）さうどす、奥さんに見せようと思うて描きに行かはつてゐるのどすえ、チヤーンと知つてゐますがな。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と肩越しに振向くお妙の顔を、ヤーンとまた激しく泣き出したお咲が小さい平手で撲る）……おおよしよし、食べたくない、咲ちゃは食べたくないの。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、安心できるのだ」２　ヤーン・ウエナー「ナッシュヴィル・スカイラインについての批評は読んだでしょ？",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "38　ヤーン・ウエナー「あなたがつくった歌を誰かほかのアーティストがうたう場合、特にこの人にうたってもらいたい、と思うような特定のアーティストがいますか？",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤーン」と赤ん坊のやうに蒲団にしがみついてみたが、仕方がない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
