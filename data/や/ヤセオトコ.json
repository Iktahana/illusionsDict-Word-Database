          "literary": [
            {
              "text": "痩せ男や吝嗇漢の渾名に使われる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一番末席に、妙な痩せ男のゐるのが見えた。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、痩せ男は苦笑したぎり、やはり黙然と坐つてゐる。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せ男は頭を掻きながら、匆々この座敷を退却した。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せ男はこの着物の中に、傲慢不遜なあぐらを掻くと、恬然と煙草をふかし始めた。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの死体を見てから、顔面血だらけの痩せ男を見上げた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その気になれば、ここで、この痩せ男を締め殺すくらい、わけはない。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに先の徐寧は、ばッと、逃げかけた痩せ男の襟がみをつかんでいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
