[
  {
    "uuid": "9d058ae9-7ec8-5278-a658-757f46550765",
    "entry": "夜気",
    "reading": {
      "primary": "やき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
