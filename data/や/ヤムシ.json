        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぐいとその石油罐ぐらゐの大きさのお辨當箱に鼻先を突込んで、むしやむしや、がつがつ、ぺつぺつ、といふ騷々しい音を立てながら、それこそ一心不亂に食べてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本里長森を出で、　　　　　　小手をかざして刻を見る、鬚むしやむしやと物喰むや、　　麻布も青くけぶるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ些細なことだからむつかしいかもしれない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジヨバンニは窓のところからトマトの皿をとつてパンといつしよにしばらくむしやむしやたべました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ自作の影像が歪められているのを見るに堪え難い気持すら味っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐいとその石油鑵ぐらゐの大きさのお弁当箱に鼻先を突込んで、むしやむしや、がつがつ、ぺつぺつ、といふ騒々しい音を立てながら、それこそ一心不乱に食べてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おつしやりながら、器用に甲羅をむいてむしやむしや食べはじめて、ほとんど蟹に夢中になつていらつしやるやうに見えながら、ふいと、「死なうかと思つてゐるんだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」別の蟹の甲羅をむいて、むしやむしや食べて、「叔父上は私の山師を見抜いてゐる。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は髪も頬髭もむしやむしや生えた童顔の太つた男で一人は背のひよろ長い神経質らしい顔をして長い髪の毛を綺麗に撫でつけた若い男であつた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろない方がよいのだ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろそれはこういった方がいい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええとそれだから奥村氏には、ちと不向きでございますなあ」「ははあさようでございますかな」――だが正雪にはわからないらしい「いやむしろこれはこういった方がよろしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、本質的には、あのとき科学小説が一段と栄えてしかるべきであったと思う。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、そんなものは希としては持っているだけで、成功などということはあろうとは思えないのである。",
              "citation": {
                "source": "作家の生活",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕あ、めしはすんだよ」「そうかい、じや僕だけトーストを食うとしようか」　藤枝は、トーストを片手に取りながら、ミルクをやけにたくさん紅茶に入れると、むしやむしや遠慮なく朝めしをやり出した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、犯人は家庭内にありと信じた方が正しい位だ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、ＴＫ―80を買い求めたアマチュアの多くは、胸をときめかせてプラモデルめいたキットを持ち帰り、目を輝かせてはんだごて片手に組み立て、それから絶望を味わって八万八五〇〇円のむだ遣いを悔いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、日本電気のような巨大な組織では新しいアイディアは上に伝えられていくうちにつぶされてしまう傾向が強いだけに、渡辺の示した一種の勢いは貴重というべきだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをむしやむしや食つてしまふと、彼はまた口を開けた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "おべんとうはおにぎり一つ、それから、むしパン一つ、それから、小さいおみかん一つ、僕は麻布へ行くまでにおにぎりやむしパンがつぶれないといいと思いました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は林檎をむいて、むしやむしや食べながら、男達の話のなかに割り込んで、賑やかに喋つてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は退屈もしないで、よく、むしやむしやと、食ひ散らかしてゐるゆき子に呆れてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも飽きると袋から何かとり出してはむしやむしや食べる。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に、おふくろに食べろと云ふでもなく、一切をむしやむしやと食べはじめた。",
              "citation": {
                "source": "暗い花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ彼の中にあるある物は、その事実である事を、祈りさえした。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時これ等の名篇は創作探偵小説界に於ける空谷の跫音として、何人も一読三嘆したものだが、Ｏ君の伝える所によると、作者は相当の年配いやむしろ老人だということだった。",
              "citation": {
                "source": "キビキビした青年紳士",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、わたしは以上の話を単なる想像のように申しましたが、実は、かように想像すべき事情、いやむしろ証拠というべきものがあったのです。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、そのような反抗や感性などを、根こそぎ奪われてしまっている世界があるとすれば、かえってその力に、真実の闇があるのではないだろうか。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
