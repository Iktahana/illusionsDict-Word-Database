    "definitions": [
      {
        "index": 1,
        "gloss": "arrow worm (any worm of phylum Chaetognatha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
