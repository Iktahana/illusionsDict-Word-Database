        "examples": {
          "standard": [
            {
              "text": "動物園のサル山で、非常に細長い手足が特徴の痩猿が軽やかに枝から枝へと飛び移っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熱帯雨林の奥深くにひっそりと生息する痩猿の詳しい生態については、まだ謎が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "痩猿の群れが、熟した木の実を求めて森の上層部を静かに、かつ素早く移動していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "木立の中には、海軍服を着た痩猿の綱渡などが、多くの人を集めていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の真似する痩猿さん！",
              "citation": {
                "source": "猿",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
