        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畳屋も来ている、八百屋の顔も見える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋が、大きな玉菜とオレンジを運んで来た。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中老の男は私には丁寧に「自分も絵の端くれを描きますが、いや、その他、何やかや八百屋でして」　男はちょっと軒端から空を見上げたが「どうだ、日もまだ丁度ぐらいだ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋お七は家を焼いたらば、再度思う人に逢われることと工夫をしたのであるが、吾々二人は妻戸一枚を忍んで開けるほどの智慧も出なかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう／＼おぼえて居る八百屋お七の機関が見たいと云つたんだツけ。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中から駒込までぶらぶら歩いて帰る道すがら、八百屋の店先の果物や野菜などの美しい色が今日はいつもよりは特別に眼についた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の側を八百屋が荷を担いで通り過ぎる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その八百屋の荷、片方が山盛で片方が少ない。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上八百屋は新米と見えて……　見るからに担ぎにくそうに去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「釣り合はねえ」　川端を去って行く八百屋。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が其の店といふのも見すぼらしくはないまでもただあたりまへの八百屋に過ぎなかつたので、それまであまり見かけたことはなかつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菊お新の二人も、母を助けて飯もたけば八百屋へ使いにも行く。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二十五六のころ、八百屋を始めたが、まもなくよして、売卜者になった。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば大評定の場でもただくわいを並べた八百屋の店先のような印象しかない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚屋も八百屋も出入りするんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "お亀の家は浜町河岸に近い路地の奥で、入口の八百屋にも薄や枝豆がたくさん積んであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "新鮮な八百屋があつた。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは、それらをもらった八百屋が取りに来る明日の朝まで、空家の中に残されている。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がその店というのも見すぼらしくはないまでもただあたりまえの八百屋に過ぎなかったので、それまであまり見かけたことはなかった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいじゃ、先へ帰ります」　買物があるという姑を八百屋の店に残して、彼は暗い星の冴えた小路へ急ぎ足で入った。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩行にも内端で、俯向き勝で、豆腐屋も、八百屋も黙って通る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りの片側には八百屋物を載せた小車が並んでいます。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかにも、あれあの八百屋お七の物語を聞いたときの感激は私は今でもしみじみ味うことができるのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、八百屋さんの前に、ラジオニュウスを書き上げた紙が貼られているだけ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お菊さんて踏切の八百屋の娘だろうか。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と大きな声で言うのは『踏切の八百屋』である。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜八時過ぎでもあろうか、雨はしとしと降っている、踏切の八百屋では早く店をしまい、主人は長火鉢の前で大あぐらをかいて、いつもの四合の薬をぐびりぐびり飲っている、女房はその手つきを見ている、娘のお菊はそばで針仕事をしながら時々頭を上げて店の戸の方を見る。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切の八百屋で顔が売れてるのを引っ越してどこへ行くんだイ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "出入りの八百屋が言い出してからみんなジューちゃんというようになったそうである。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋などが来ると自分で台所へ出かけてやかましく値切り小切りをする。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
