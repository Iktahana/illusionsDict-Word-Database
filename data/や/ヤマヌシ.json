    "definitions": [
      {
        "index": 1,
        "gloss": "owner of a mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
