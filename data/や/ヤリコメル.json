[
  {
    "uuid": "3928a724-1275-5170-9c07-318fb0d35bd9",
    "entry": "やり込める",
    "reading": {
      "primary": "やりこめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
