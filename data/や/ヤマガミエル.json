    "definitions": [
      {
        "index": 1,
        "gloss": "to have the end in sight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "振り返れば、間の岳（赤石山脈）や、悪沢岳の間から、赤石山が見える、そうして千枚沢の一支脈は、兀々した石の翼をひろげて、自分たちの一行を、遥かに包もうとしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（若しも遠州森町から富士山が見えるものならば、この場面なぞに遠く富士が見えているとよろし）　七五郎、話す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水港に程近いと見え、カメラ、パンすると富士山が見える。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原の温泉を過ぎて吾妻川の峡谷を遡れば、前面に方りて何となく物凄き一大魔形の山が見える。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山が見える媾曳　エミ子は不安な予感にかられました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの山へのぼつても、おなじ富士山が見えるだけで、それを思ふと、気が重くなります。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は「あすこに山が見える」という場合に、向うを指して山の形を両手で描いて見せたのが昔の表現であったとする。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも「ああ山が見える」という心で静かにシカケ、ヒラキの型を演じた方が充実した舞台印象を観客にあたえつつ、自己の表現慾を最高度に満たす事が出来る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "準之助氏は、英国紳士のように、優雅で親切に思えたから……霧が、だんだん晴れて窓から近く離山が見える。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかめしくとがった岩山が見える。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し身體を前屈みにすると眞白な櫻木立の間に香貫山が見える。",
              "citation": {
                "source": "樹木とその葉",
                "author": "或る日の晝餐",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の向こうには、かすかだが今日も富士山が見える。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄霧の中に越後の彌彦山が眞向に見えてそれから南へ下つて稍遠く米山が見える。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そら、そこに、向ふに、山が見えるでせう、あれが、内海の秋葉山です。",
              "citation": {
                "source": "知多の野間で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを隔てて遠くに秩父の山が見える。",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "六『それ、金山が見える。",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜に出ると正面に鋸山が見える。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河なる沼津より見れば富士が嶺の前に垣なせる愛鷹の山愛鷹の真黒き峰にまき立てる天雲の奥に富士は籠りつ　先づ愛鷹の山が見える。",
              "citation": {
                "source": "村住居の秋",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠次　おい、赤城山が見えるじゃねえか。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　京の街はどんな小路を歩いてゐても、きつと路のつきる所には山が見える。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "○来たらよく見な鈴蘭燈籠小花四つで親一つ　　　○夜の前橋ア鈴蘭燈籠お月ヤ出なくも闇はない榛名と赤城の連山　西には榛名の連山が見え、北には赤城の連山が見える。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると愕いたことには、今の今まで、そこにあった地上五十尺の高さを持った大倉庫は跡片もなく崩れ落ちて、そのかわりに思いがけなく野毛の山が見えるのであった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたに水の枯れた川原がつづき、背景に冬枯れた山が見える。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のメッシナの横にエトナ火山が見える筈だのに雲の中に隠れている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が見える、青い山が見える。",
              "citation": {
                "source": "病",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "県道の右手に当つて低いけれど山が見える。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この※を嗅いだだけでも、壁を塞いだ書棚の向うに星月夜の山山が見えるやうである。",
              "citation": {
                "source": "わが散文詩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この最高点から雄山神社を越して薬師岳が見えるし、大汝の上には黒部谷下流の白馬側の山が見える。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それでも、暴風になる時には、いつでも白山が見えるもの。",
              "citation": {
                "source": "少年と海",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
