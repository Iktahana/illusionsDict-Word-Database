    "definitions": [
      {
        "index": 1,
        "gloss": "handling things without making waves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
