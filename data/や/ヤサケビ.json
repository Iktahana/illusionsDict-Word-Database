    "definitions": [
      {
        "index": 1,
        "gloss": "yell made by archers when firing a volley of arrows",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
