        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "難しいパズルに挑戦したが、結局「もう、やんぴ！」と諦めてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友達と鬼ごっこをしていて、捕まりそうになった時「やんぴ！」と叫んでセーフになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「こんな面倒な仕事、やんぴだ！」と彼は投げやりに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "nth person to quit a game",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
