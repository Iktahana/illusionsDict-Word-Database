      {
        "index": 1,
        "gloss": "eight-headed, eight-tailed serpent (in Japanese mythology)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
