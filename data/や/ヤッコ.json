        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの新人、やる気はあるんだが、どうも抜けてる奴だな」と先輩が苦笑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お前、あの奴のこと、どう思う？」と友人が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あいつ、またサボってるのか。困った奴だよ。」と同僚がため息をついた。",
