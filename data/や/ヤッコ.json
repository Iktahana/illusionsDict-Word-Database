[
  {
    "uuid": "b69c4209-11b8-5a79-8813-fb385129a7e7",
    "entry": "奴",
    "reading": {
      "primary": "やっこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
