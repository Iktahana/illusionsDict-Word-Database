        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから約束を守るのはわるい事だ」　とある人が言いました。",
              "citation": {
                "source": "約束",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大体、約束を守ると言う事は馬鹿な事なんだ」　するとも一人の人がこう言いました。",
              "citation": {
                "source": "約束",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ人間に対しては、もう約束を守るよりほかに何一つしてやるものがないのだと思った。",
              "citation": {
                "source": "蚊帳",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇に浮かぶ船長の大きい朦朧とした姿をながめ、さらに彼があたかも媾曳きの約束を守る人がぼんやりと物を考えているような姿で立っているのを見たとき、私は全身にさっと不気味な寒さを感じたことを白状する。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分から先刻の約束を守るために、瑠璃子夫人を探し求めるほど大胆ではなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども約束を守るなぞという事は大嫌いになった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分から先刻の約束を守るために、瑠璃子夫人を探し求めるほど大胆ではなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束さへ守つてやれば、若しくはこの約束を守ることを誰れでも代つて引き受けて呉れる者があらば、もう、自分はかの女との最後の關係もなくなるのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月一日という約束を破つてなぜ犯人は四月二十日をえらんだのだろう」「君は殺人犯人から紳士の約束を期待するのかい」「必ずしも然らずだ、が、この犯人のような奴はきつと約束を守るものだよ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は「日本人は約束を守る誠実な国民だ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「約束を守ることです。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「約束を守らなければ、説明が要ります」「約束を守ると大変な事になるから、小野さんはやめたんだよ」と宗近君が云う。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "意志なんかは……約束を守る意志さえも……少しもありませんでした。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、ハイタが約束を守る青年だとわかっているハスターは都市を救い、水を海に戻しました。",
              "citation": {
                "source": "羊飼いハイタ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは約束を守るぞ」「ありがとう――ボジャック、早く光源を……」「おお」　ボジャックは、再び台の上の機械にとりついた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし気がついてみると、相手がジコーサマだけに、呉清源には約束を守る自由すらも許してもらえないだろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束を守る心はその時からもはや影もなかつたのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その約束を守る気持は微塵も心になかつたのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かならず、約束を守るから、君も守ってくれ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カントによれば、之は理性が経験乃至感性的直観との協定を必要とするという認識手続の上の約束を無視するから起るので、この約束を守る以上、元来今云ったような宇宙論的な観念は抑々認識なるものの内容となり得るものではない、そういう意味に於てこうした宇宙論的諸観念はイデーに他ならない、という。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束を守る程度に正比例してその人はえらい、立派な人間です。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用できるように、私達が人とした約束を守ることだわ！",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が約束を守ることを確信していたのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の三　家の中へ入ると、久右衛門は改めて、「だがおゆき、おまえ御家中の士にあれほどさからったのは、ただ約束を守るというだけなのか、ほかに何か考えがあってしたことなのか」「――父さま」　おゆきはまだ涙にぬれている眼をあげて、けれど唇には静かな微笑を見せながらいった。",
              "citation": {
                "source": "峠の手毬唄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党が確実に約束を守るのであれば、金を払わねばならないだろうが、常に失敗する可能性はある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トリガーセンは約束を守る」　とトリタイアがつぶやいた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、金五郎さんが、立派な男で、約束を守る人だということを、信用するわ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス王への条件はあまりにも厳しかったので、彼がこの約束を守ることをカール５世のような目先の利く専制君主が期待していたと歴史家たちは理解するのが困難なほどであった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
