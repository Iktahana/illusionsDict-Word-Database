    "definitions": [
      {
        "index": 1,
        "gloss": "last night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "御やすみになっているところを御起しして済みませんが、夜前からの雨があの通り甚くなりまして、渓が俄に膨れてまいりました。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御やすみになつてゐるところを御起しして済みませんが、夜前からの雨が彼の通り甚くなりまして、渓が俄に膨れてまゐりました。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何か彼の足跡にでも逢着することもあるまいかと、水夫の一隊を伴って、終夜前方の氷山を歩きまわったが、それは徒労に終わった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜前伏羲を断わった隣の富家の婦聞いて大いに羨むと、数月の後伏羲また村へ来た、かの婦｜強いて自宅へ迎え取り食を供し、夜中自室へ蝋燭｜点し通夜仕事すると見せ掛け、翌朝｜予て拵え置いた襦袢を呈し、食を供えて送り出すと、伏羲前度のごとく祝した。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "一兩夜前に、漂泊者の一家族が、近くの森に泊つてゐた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八夜前後の月高く空にかかり、そこらの草木はしつとりと夜露にぬれてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一人で、夜前庭のベンチに腰をかけて、しくしく泣いているようなこともしばしばあった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜前は飛んだり跳ねたりして居たのに、アア爾だ今朝食物の差し入れの時、更に繋ぎ直されたのだ、誰が此の様な事をするか、是も医学士だ、シテ見ると医学士が今朝茲へ這入って来たのだ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが恭子などは、闇の話にのぼせ日夜前途の不安に脅えてべちやくちやと僕の傍で喋べくるのですからかなひません。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜前の襦袢もたせ上申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、夜前たいてい、食堂で少々酒類もつぎこんでいようし、寝すごしてもボーイが起してくれるという安心もある。",
              "citation": {
                "source": "女人禁制",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜前、神明町辺の博士の家とかに強盗が入ったのがつかまった。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さア、そこへ坐るんだ」　何でも夜前つかまった強盗を入れるために、一房をあけたらしい。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち各地に於て日夜前条の御趣旨を演説し、また諸藩の重臣と会して朝旨を誤解せざると共に王事に奮励すべきことを勧めしが、加賀国大聖寺に到る間に於て、寺院及び民家より軍資を献納したるもの参万金に達せり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜前、稀有な事が、ございましてな。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜前、戌時ばかりに、奥方が俄に、人心地をお失ひなされましてな。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私のお話し申す一と通お聞きなすつて下さいまし、これまでもあなた様へこそ御無心を申せ、つひに人様の物、箸かたし、いがめたことは御座りませぬに、不孝の罰か、夜前私やあ、大盗人にあひました」といふ。",
              "citation": {
                "source": "いがみの権太",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜前の雇婆さんの話によると老人は身体の工合が悪くて臥ている筈である。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "急々一書を裁し候昨夜は数々の御厚遇大謝大謝｜然るに今朝｜承及候えばかの舞妓春どの夜前小石川南海寺にて変死を遂げ候趣き驚き入り候右御伝聞未だしきやと存じ候えばお知らせ申候……。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲んで、世間話をして――いやらしいことなどは一言も云わず、初夜前に別れたのである。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸をあけて内へ入って見ると、家の中はまだ暗いけれども、夜前と別に変ったこともありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕許の刀架を見ると、夜前見ておいたところよりはこころもち前へ進んでいるかと思われるだけで、大小一腰は少しの変りもなく、米友は昨日の朝したように、強いてその刀を取って調べてみようでもありませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう書き出してくると、夜前、ああいう光景を描き出した場所柄、またもや一層の妖気魔気が影を追うて来なければならないのですが、事がらはそれに反対で、妖気魔気どころか、気の利いた化け物は、面をそむけて引込むが当然なのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に山の端も輝いて、紅い雲が淡黄に変る頃は、夜前真黒であった落葉松の林も見えて来た。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "此夜前日に比して又更に暖なり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の中秋、枕山は遠山雲如、石川｜艇斎、鷲津毅堂、鈴木松塘、秋場桂園、横山湖山の六人と同遊の約をなしたが、その当夜前約を履んで来り会したものは横山湖山一人のみであった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月初旬の八十八夜前後には、季節の変り目を知らせる雷雨が赤城方面に発生して、雹などを降らすことがある。",
              "citation": {
                "source": "山と村",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい一昼夜前まで、このあたりにめずらしい、数寄をこらした寮の建物のあったあたり、焼け木が横たわり、水と灰によごれた畳、建具がちらばり……まだ焼け跡の整理もついていない。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ前にキネマ館が白い壁を聳ててゐるので、夜前の雨に拭はれ切つた空が、狭く細い一部分しか見えない。",
              "citation": {
                "source": "手品師",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜前にくみ込んだ水甕へ、それほどの毒を入れたのに、戸締りが少しも變つて居ないところを見ると、これは外の者の仕事ではない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "南蠻祕法箋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
