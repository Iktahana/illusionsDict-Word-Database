        "index": 1,
        "gloss": "holiday granted to servants on the 16th of the first and seventh months",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
