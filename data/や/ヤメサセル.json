    "definitions": [
      {
        "index": 1,
        "gloss": "to fire (from job)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうなったらクリストフは辞めさせるよ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科学生になるための予備試験などは止めた方がいいが、しかし将来教師になろうという人で、見込のないようなのは早く験出してやめさせる方がいいと云っている。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "首狩の風をやめさせるのは容易なことではない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はルグラン家の零落する前に解放されていたのだが、若い「ウィル旦那」のあとについて歩くことを自分の権利と考えて、おどかしても、すかしても、それをやめさせることができなかった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若しお前達の親や兄弟で、あんな悪いことをするものがあったら、やめさせるように一生ケン命お願いしなければならない。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の前に勤めていた方はどういう方でした」「あの方はもう年を取ったからやめさせるという噂が前からあったんです。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでない限りは、たつた六人が、互に、乾燥の釣り込みに、一番いい場所を占領しようと爭ふやうなことをやめさせるわけにはいかないだらう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばお父つあんの病氣を根治させようと思へば、百姓をやめさせるしか仕方がないんだから。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為に、病気を知れば母がスケッチのための外出さえやめさせるであろう。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物は、だらしなく、ワアハハハと笑うきりで手助けはしないし、火より先にけんかをやめさせる必要がある。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、あれの持たない、そして持つことの出来ないものが、ハフに学校をやめさせるのだ」　ロザリーが「それは何ですの？",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また学校も早くやめさせるつもりなのだそうです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々不評だった下條文相をやめさせるきっかけに、吉田首相は法隆寺失火責任を負わせ、火事は政治漫画をくりひろげた。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宍戸、宿直の日、小使部屋に居た　そこへ女のひとが来て、喋って居るところへ、ひょっくり竹内入って来て、翌日やめさせるとか何とか云う、やはり臆病からなり。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人を思う心も縷々と言われるのに中の君は困っていて、恋の心をやめさせる禊をさせたい気にもなったか、人型の話をしだして、「このごろはあの人、そっとこの家に来ています」　とほのめかすと、男もそれをただごととして聞かれなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしてやめさせる工夫はないものか知らん。",
              "citation": {
                "source": "しっぺい太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、一家の経済はかつ子の月給で切り廻す結果になるので、今のところをやめさせるわけには行かない。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生たちにはそういう葛藤が日頃から不合理で不愉快に思われているのに、やめさせる理由としてリンゼイの説を三田が学生に説明したことがあげられたという一事が感情の激昂をつのらせた。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで学校やめさせるような卑劣なことをやるならやればいい」「なんて生憎なんだろう……」　歎息するゆき子の悄然とした雀斑のある顔を見ると、瀧子はその弱腰を非難する気も失せるのである。",
              "citation": {
                "source": "鏡の中の月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は、彼女に勤めをやめさせる日。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり叔父の考えにすりゃ、あたしは主婦と云うよりも、従兄の遊蕩をやめさせる道具に使われるだけなんですもの。",
              "citation": {
                "source": "文放古",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一他人の聞きたがっている音楽を銭ずくでやめさせるのは悪趣味じゃないか？",
              "citation": {
                "source": "彼　第二",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一更になお、彼を説服してその所謂研究をやめさせることは、到底僕の力では出来そうもなかった。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェートでは曲芸の極めて非衛生的なものをやめさせる必要がある。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし姉さんが気が向かなけりゃ咲枝たち開成山にゆくのをやめさせる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは、とてもお勝手の方がやりきれないのですが、何とかあれをやめさせる工夫はございませんか。",
              "citation": {
                "source": "うむどん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私はうどんと麺包をやめさせる工夫を考えてみた。",
              "citation": {
                "source": "うむどん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この子に糸くりをやめさせることができないものでございますから。",
              "citation": {
                "source": "三人の糸くり女",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんとかして江戸攻撃をやめさせることはできないものか。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、彼に急に酒をやめさせると却っていけないかも知れないんだ。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
