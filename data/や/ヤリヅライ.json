        "examples": {
          "standard": [
            {
              "text": "人前で失敗するのは、やり辛いことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の前では、なぜか本音を話しづらい、やり辛い雰囲気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このやり辛い仕事も、今日で終わりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "座へ出て、すぐ「二つのネクタイ」をやる、一々セリフが気に入らないのでやり辛いこと。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼や彼女の性格の型、家庭の型のようなものは推察できるかも知れないが、型の分析に終始するのは、やりがいがない気がして、なんとも、やりづらい。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
