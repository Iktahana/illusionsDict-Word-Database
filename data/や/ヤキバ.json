      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tempered blade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "附け焼刃と云うものは何にもならぬものである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は附け焼刃はせぬ／＼と思いながら、ついに独り子に附け焼刃の政治科を修めさせた事になる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稀に書物からの知識もあるが、それはいかにも附焼刃のようで直接の読書によるものと思われないのが多い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの絵はみんな附焼刃でない本当に自分の中にあるものを真正面に打出したものとしか思われない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "附焼刃にしろ、教養のある女優といわれていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり僕は内から促されてしたのでなくて、入智慧でしたので、附焼刃でしたのだから、だめであったと見える。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それは半分は、いや、六十パーセントは、哀れな附け焼刃でした。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは僕の下品は、たとい六十パーセントは人工の附け焼刃でも、しかし、あとの四十パーセントは、ほんものの下品になっているのです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は水のように美しく澄んでいる焼刃を惚れぼれと眺めているうちに、今までにこの刀を幾たび抜いたかということを考えた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をつかまへて、『時勢につれて』とか、『附焼刃でないやうに心から祈る』とか言ふことは、随分人を馬鹿にした話ではないか。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "益々社会主義的感情が、自然に若い時代の人々の附焼刃でない感情になっている、従って若い人々が自分の働く場所、生活する場所の文化的設備増大に対する関心は、注目すべきものがある。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実相主義を人道主義に結びつけようとすれば、それはつけ焼刃になってしまう。",
              "citation": {
                "source": "念仏と生活",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに科学にもなかなか精しいようだし……」　と、僕があけすけな質問をすると、「なアに付け焼刃さ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みだれとか、焼刃の匂いとかいうものを教えてもらったのもそのころだ。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして直ぐ附焼刃だと意識して冷汗が出る思がした。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論あの七色は、詩でも観想でもなく、実は、兇悪無残な焼刃の輝きだったのです。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、それで解るにしても……」と検事が合槌を打った時に、青白い光が焼刃のように閃いて雷鳴が始まった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは人が悪いのは附焼刃で、実は存外正直な感傷主義者が正体かも知れない。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤心報国真荒男が朝廷思ひの忠実心　眼を血に染めて、焼刃見澄ます国のため念ひ痩せつる腸を　筆にそむとて、吾が世ふかしつ仇に向き　※たゝきけむ古人に　ならひてこそは、国に仕へめ正宗の大刀の刃よりも、国のため　するどき筆の鉾｜揮ひみむ国を思ひ寝られざる夜の　霜の色。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の刀くれけるとき抜くからに　身をさむくする秋の霜　こゝろにしみて、うれしかりけり間十次郎光興血つきたる槍ひきさげて、落ちくさの柴のかくれが　我ぞさぐりし近松勘六行重母剣大刀　焼刃に　我と身をふれて、励ましやりつ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を血に染めて　焼刃見澄ます※国汚す奴あらばと　大刀抜きて、仇にもあらぬ　壁に物いふ※ひとりごとに歌よみて、遊ぶ外なし。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でもその時の事を考えますと、まるで磨ぎすました焼刃の※いを嗅ぐような、身にしみてひやりとする、と同時にまた何となく頼もしい、妙な心もちが致した事は、先刻もう御耳に入れて置きました。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛嬌が附焼刃で不安が本体だと思うのは偽哲学者である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの客観的状況はいろいろに変化しておりますけれども、絶対的権威の立場から活動するときに、はじめてそのものは付け焼刃でなく、ほんとうの心からなる活動ができると思うのであります。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども大きなものを生ずるところの根は個人の心持である、個人の心持を離れて社会的、経済的というものは付け焼刃である。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "付け焼刃というようなものも嘘でありますが、自分で気がつかないで嘘になっているという嘘。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋流の学問をして実証精神の型が分るとかういふ一見フザけたことはすぐ気がつくが、つけ焼刃で、根柢的に日本の幽霊を退治したわけではなく、むしろ年と共に反動的な大幽霊と自ら化して、サビだの幽玄だの益々執念を深めてしまふ。",
              "citation": {
                "source": "デカダン文学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても「品位」は附焼刃でないことだけはたしかであります。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう環境にとりまかれて平然たる神経が、国民道徳を論じたって、ツケ焼刃にきまってらア。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ何の物音もなく眠つた街に、住む人は因循で、ただ柔順しく僅に Gonshan（良家の娘、方言）のあの情の深さうな、そして流暢な軟かみのある語韻の九州には珍しいほど京都風なのに阿蘭陀訛の熔け込んだ夕暮のささやきばかりがなつかしい。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
