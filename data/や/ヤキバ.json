[
  {
    "uuid": "4a7b5fb0-2c85-530e-a82e-5e39174966ba",
    "entry": "焼刃",
    "reading": {
      "primary": "やきば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
