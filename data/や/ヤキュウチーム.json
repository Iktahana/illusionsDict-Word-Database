          "standard": [],
          "literary": [
            {
              "text": "またＡとＢとは同じ野球チームの選手だが、春のシーズンには二人とも同じ打撃率だったものが、秋のシーズンになってＡは安打数が増え、Ｂは相変らず凡打、三振を続けている。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は、済して「ゲーは、ジー・エイ・ワイだ、即ち Merry, lively, jolly, sportive」「…………」「うむ、さう云へはそのやうな名前の野球チームがある。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文人の間に組織されてゐる野球チームなのである。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大神経科の野球チームは内村投手、千谷捕手という凄いバッテリーであるが、実のところは、各科の対抗で最も弱い方のチームだそうである。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目みて、いくらかそれに近いかなと思つたのは、野球チームの監督だつたといふ牧師さんだつたので、彼女は自分の鑑識に自信を失つた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの高校の野球チームで投げたら、打てない奴はいっぱいいると思う」「ピッチャーは面白いわね」「キャッチャーもいいよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "素敵」　メジャー・リーグの野球チームのマークとチーム名をプリントした、アメリカ製のＴシャツだった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小泉君は学校の野球チームの選手だものですから、その練習のために、こんなに帰りがおそくなったのです。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
