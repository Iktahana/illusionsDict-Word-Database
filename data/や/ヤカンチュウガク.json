        "examples": {
          "standard": [
            {
              "text": "義務教育を終えられなかった人々が、夜間中学で基礎学力を身につける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "外国籍の労働者のために、夜間中学での日本語教育が提供されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "社会の多様なニーズに応えるため、夜間中学の拡充が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」　釜石夜間中学校の報告によると、地震の二十分ぐらい後に、湾口から光を発し海岸の山々に反映した。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業学校夜間中学に通学。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間中学の簿記、算術など苦痛にて、夜は伊勢佐木町のみ歩く。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど小島の小母さんは、すぐぼくに夜学をすすめ、あちこちの夜間中学校から規則書を取り寄せてくれたりした。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間中学の副読本なんかの詩でよく邂逅ふ、―― CUCKOO といふ禽、（あのこゑは　いまや初夏のひかりを浴びる）わたしは截る　淡茶いろの竹針それに一円半の CUCKOO WALTZ を唄はせよう。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
