        "examples": {
          "standard": [
            {
              "text": "デッサン用のスケッチブックは、八つ切りのサイズが使いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、八つ切りの画用紙に絵をたくさん描いた思い出がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "配布資料は、八つ切りで印刷すると読みやすいと好評だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "八つ切りくらいのスケッチブックへ鉛筆で簡単なスケッチをしたが、それは普通の意味の似顔としてはあまりよく似てはいなかった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人間の「本家」がまき歩くビラの「ホンケ」は、鼻紙を八つ切りにしたのに粗末な木版で赤く印刷したものであったが、その木版の絵がやはり蝙蝠傘をさして尻端折った薬売りの「ホンケ」の姿を写したものであった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎角するうちに半紙八つ切りの料の紙、小さく折られたるが雲形塗のお盆の上に堆たかくなりぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
