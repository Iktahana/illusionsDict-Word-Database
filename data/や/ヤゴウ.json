[
  {
    "uuid": "7a43f9a9-fe4a-51cc-87b4-36639ca471c0",
    "entry": "屋号",
    "reading": {
      "primary": "やごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
