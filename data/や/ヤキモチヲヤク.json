          "literary": [
            {
              "text": "」「やきもちを焼くなんてそんな下品な事をするおれではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、あんな人に対して、やきもちを焼くほど、自分をみじめたらしく考えたくないんですの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、素直に、正面からやきもちを焼くなどということは、彼女の誇が絶対にさせないことである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやですわ、まさか、あたくしが……小間使風情を相手に、やきもちを焼くなんて……考へて御覧になればわかりますわ。",
              "citation": {
                "source": "秘密の代償",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "世迷いごとを書く、ぼそぼそ苦情をいう、やきもちを焼く、それだけのことさ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっちゃんの話をきいてやきもちをやくわけでもありませんですが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂のたねはそのおみちで、参吉とあやしいから茂兵衛がやきもちをやくとか、参吉がおみちを追い出そうとしているとか、まったく反対な陰口が弘まっていた。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
