          "standard": [
            {
              "text": "彼はトレードマークの野球帽を深く被り、周囲に気づかれないように街を歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "応援しているチームのロゴが入った野球帽を被って、全力で声援を送る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "運動会の赤白帽子を、野球帽のようにツバを後ろにして被るのが流行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「横須賀でさ、野球帽みたいなのに刺繍してくれる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れしなに、鶴石は田原町の洋品屋で留吉にネーム入りの野球帽子を買つてくれたりした。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い野球帽子の赤いネームのがかはいかつた。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
