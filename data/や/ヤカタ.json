        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔館は台地のはななれば〕宮沢賢治館は台地のはななれば鳥は岬の火とも見つ香魚釣る人は藪と瀬を低くすかしてわきまへぬ鳥をまがへる赤き蛾は鱗粉きらとうちながし緑の蝦を僭しつゝ浮塵子あかりをめぐりけり",
              "citation": {
                "source": "〔館は台地のはななれば〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「門司の旅館で船を待つ間、船の汽笛が鳴るたびに、火のつくやうに泣き出すのには閉口させられた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても私の境涯の、その最初の門出は「門司の旅館で船を待つ間、船の汽笛が鳴るたびに火のつくやうに泣き出」したのであり、「その日はそれに、吹く降るの日で」あつたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夢遊病者のやうに立ちあがり、半ば馳足で川上にある旅館をたづねた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旅館（湯本館）には尾崎士郎君の夫妻が居た。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にしても、心の弱っている時に、ふらと映画館に吸い込まれる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をしても不安でならぬ時には、映画館へ飛び込むと、少しホッとする。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館の一隅に坐っている数刻だけは、全く世間と離れている。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年前、千葉県船橋の映画館で「新佐渡情話」という時代劇を見たが、ひどく泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が映画館へ行く時は、よっぽど疲れている時である。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国技館の角力を見物して、まじめくさり、「何事も、芸の極致は同じであります。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化のガイドたちは、またまた図書館通いを始めなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一巡して、職員たちに見送られ、人力車に乘つて悠々、御歸館。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都立命館中学に転校す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仝年五月、「朝の歌」及「臨終」諸井三郎の作曲にて日本青年館にて発表さる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅から旅館までの俥の上で自分の息が見知らぬ町の暗闇の中に、白く立昇つたことを夢のやうに覚えてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日ばかりして家が決まると旅館を出てその方へ越した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神明館（字は違ふかも知れない）といふ映画館があつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時神明館の横の空地に、軽業が掛かつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父に連れられて行つたのだが、父が切符を求めてゐる時、ヒヨイと僕の前に例の弁士の息子が立現れて、神明館と軽業とどつちがよいと思ふかと云ふのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽業の方は明るい上に楽隊は盛んに鳴らしてゐる、所で神明館の方は仄暗く、例の昔の映写機が、憂鬱な音を立てゝ廻つてゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こつちの方だ」といつて僕が軽業を指すと、「ちがふ、フイルムだけでも神明館の方が百倍も値打がある」といふのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それぢやあ図書館に行つて来ますよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程必要な本があれば図書館に行かなくつたつて、私が買つてやると言つてるぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこの休暇中旅行だつてしたことはないのですもの図書館位行きますよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちばなの昧爽時や古館　五月雨頃の、仄暗く陰湿な黄昏などに、水辺に建てられた古館があり、橘の花が侘しげに咲いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンとピエールとを除いた町じゅうの病人やかたわ者は人間なみになれるよろこびの日が来たので、有頂天になって、聖マルティンのお着きを待ちうけています。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方は自分の顔やかたちのいやなことをいいことにして、一つ一銭のマッチを十円ずつに家ごと押しつけてあるく。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは賢い人たちは、その語のつりあいで、ほんとうかうそかすぐわかり、またその音ですぐわかり、それからそれを云うものの顔やかたちですぐわかります。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
