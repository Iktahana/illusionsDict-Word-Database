    "definitions": [
      {
        "index": 1,
        "gloss": "cool evening air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おおよそは何かしらに拠って、手製の万八を無遠慮に加えず、斯様も有ったろうというだけを評釈的に述べて、夜涼の縁側に団扇を揮って放談するという格で語ろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃内を過ぐる頃、馬上にて、　　きていたるものまで脱いで売りはてぬ　　　いで試みむはだか道中　小樽に名高きキトに宿りて、夜涼に乗じ市街を散歩するに、七夕祭とやらにて人々おのおの自己が故郷の風に従い、さまざまの形なしたる大行燈小行燈に火を点じ歌い囃して巷閭を引廻わせり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜涼をたずねる市中の人は、往来の少ない幽暗の地を選ばないで、却って燈火のあかるい雑沓の巷へ迷ってゆく。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜涼が頬を舐めて、吉野は何がなしに一人居る嬉しさを感じた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一）　夜涼疑有雨、院静似無僧。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ふ、夜涼疑有雨、院静似無僧と。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩は便宜上仮名まじりにすると、「絶頂の新秋、夜涼を生ず。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの燈籠はまたその夜涼台の上に吊されました。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動へ行くな、夜涼みに出るなと云って居ながら、平気で倍も倍も悪い様な事をしなければならない様に、云う者からして仕向けて居る。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神代帚葉翁が生きていた頃には毎夜欠かさぬ銀座の夜涼みも、一夜ごとに興味の加るほどであったのが、其人も既に世を去り、街頭の夜色にも、わたくしはもう飽果てたような心持になっている。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜涼を俟ちて机に凭る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "種彦は遠くもあらぬ堀田原の住居まで、是非にもお供せねばという門人たちの深切をも無理に断り、夜涼の茶屋々々｜賑う並木の大通を横断って、唯一人薄暗い町家つづきの小道をば三島門前の方へとぼとぼ老体の歩を運ばせたのである。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔流水山前寒碧長シ／遺居｜何ニ在リヤ草荒涼タリ／一橋ノ風月人ノ詠ム無ク／漁唱商歌夜涼ヲ占ム〕　枕山は明治十一年に刊行した『江戸名勝詩』にも赤羽橋を詠じて「想見当年詩道盛。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　一夜涼風を銀座に追う。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕照入波波亦紅、望中得句嘯長風、南溟今夜涼如水、万里檣頭月一弓。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜涼みであるが風はソヨともしない。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩を返へして、木蔭を過ぐるに、灯火のかげ木の間を漏れて、人の夜涼に語るあり。",
              "citation": {
                "source": "良夜",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは夜涼みなどをして終に人の寝る位までの間、即ち夕暮から十時｜乃至十二時位までの間をいうので、次はどことなく白みかけて早や明けかけたという時分、即ち三時から四、五時頃の間、彼の「明け易」というのはこの場合である。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊り客あるも亦よし夜の秋　肌が冷えびえと夜涼を覚えるようになって、やれやれと打ち寛ろいで居る心持。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊り客などがあると気づまりであるのが普通であるが、しかしその夜は泊り客のあるのもまたいい、共にこの夜涼を味わおう、というのである。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら「人の音」といっても同じようなものであるが、「人の音」では夜涼を背景にした町の空気が、全然現れぬ憾がある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま走る夜駕の灯も絶えて、初更を過ぎかけたこの街道は、刻一刻と、夜涼の静寂に澄み切って、時折、空には飛ぶ星、地には撩乱の露草に啼きすだく虫の音があるばかり。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにして杯は廻り燭は夜涼にさやぎ、人々はこの二日間に初めての歓語とくつろぎの中に各※酔いを覚えていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "神主へ断ってきた言葉のように、妨げのない額堂の席を、夜涼の山嵐をほしいままにして、連歌の競詠を試みているのかと思うと、闇の中に、眼ばかり光らしている武士たちの顔には、みじんもそんな風流気は見えず、一人として筆をかみ句を案じているような者はない。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
