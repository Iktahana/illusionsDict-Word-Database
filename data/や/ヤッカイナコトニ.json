    "definitions": [
      {
        "index": 1,
        "gloss": "the trouble is ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
