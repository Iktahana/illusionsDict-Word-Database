        "examples": {
          "standard": [
            {
              "text": "すき焼きのタレをたっぷり吸った焼き麩は、肉に負けない美味しさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お吸い物に焼き麩を浮かべると、見た目が一気に華やかになりますね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "離乳食の時期、お湯で戻した焼き麩は柔らかくて重宝した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しどけなき、なれが頸は虹にしてちからなき、嬰児ごとき腕して絃うたあはせはやきふし、なれの踊れば、海原はなみだぐましき金にして夕陽をたたへ沖つ瀬は、いよとほく、かしこしづかにうるほへる空になん、汝の息絶ゆるとわれはながめぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
