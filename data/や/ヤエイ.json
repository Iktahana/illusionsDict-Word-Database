    },
    "definitions": [
      {
        "index": 1,
        "gloss": "encamping at night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜になって空に星はあったが、電光が白い柱を、谷の中に投げては、夜営の人々をおどろかした、夜半には、秋雨が音なく注いだ、川縁に転がっている流材を焚火にして、寒さを凌いだ、針葉樹の切崖で囲んだ、瓶のように窄い谷底からは、天も谷川ほどの細さで流れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊が行軍している途中からこの歌の魂がピーターパンの幽霊のような姿に移って横にけし飛んだと思うと、やがて流浪の民の夜営のたき火のかたわらにかなでられるヴァイオリンの弦のしらべに変わる。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の大隊は、ライ麦の黄色く実った丘の上に、夜営を張った。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その切々たる哀調は、馬倒れ、鎧切れた敗将の、曠野の夜営空しく月を仰ぐがごとくである。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夥しい兵と、数百の乗馬、荷驢馬の長いうねうねした列は、彼方此方で夜営のかがりを燃き、平和に、寧ろ巡礼旅行者のように進行した、イランの国境に迫る迄、多くの者は、甲冑さえ正式にはつけなかった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり気が沈むから二三杯ひつかける、そして人が懐かしうなつて、街をぶらつき、最後にＳのところで夜明け近くまで話した（今夜は商店はたいがい徹夜営業である）、酔うて饒舌つて、年忘れしたが、自分自身をも忘れてしまつた。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "――エレメンタルスの描写は兎も角も、夜営の所は器用に書いてあります。",
              "citation": {
                "source": "近頃の幽霊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはその日、まだ太陽の輝いている中から河原の芒の中で夜営の準備にとりかかった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、第一日の夜営地になる、うつくしい沢地があらわれたのだった。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は終夜営業していた。",
              "citation": {
                "source": "或る夜の武田麟太郎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時すぎに烏帽子沢が右手から雪の坂をなして落ちあうところを夜営地とした。",
              "citation": {
                "source": "春の上河内へ",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前八時に夜営地を出発した。",
              "citation": {
                "source": "春の上河内へ",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫を連れていれば夜営は、そんなに早く着かないでも間にあう。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに登山服を取り出して、いつの夜営の記念だろう、偃松の烟の染み込んだのを頬にあてると、遠のいていた華やかな日を呼び帰したように生き生きする。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は山田さんにあやまり、その晩の夜営地を最初の予定地より二里ばかり手前にしてもらって、弁当も食わずに大町まで飛んで帰る。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前六時十五分、劒沢の夜営地出発。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭沫若という作家の紀行に、夜営して第一の日、柔かい草をよろこんで眠ったら翌日体がきかないほど湿気をうけ、石の堅いところに臥た老兵は体がしゃんとしていた、とありました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいに癖になり、夜営などでは、悠々それを楽しんだ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南進してスバリ岳の夜営の時だ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "惚太郎のおやじ自身も、応召の時にトコトンのおッつぁんに、感謝しますって言われた口なんですがね」　私たちは言問通りにあるメシ屋で、自動車の運転手相手に終夜営業をしている店に入っていた。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "終夜営業の店へ四時三十分頃にでかけていって朝食を食べるのも、悪くない。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また川岸には多くの酒場があり、船員相手の終夜営業をしている。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "終夜営業運転はまだだ。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、諜報によると、将門の軍勢は、およそ四、五里も先に兵馬を止めて、どうやらそれ以上には前進して来るもようなく、夜営の準備までしているという。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう分宿しても、夜営しても、収まりきれないほどだったろうし、夜は、酒や女を漁る将兵の影が、うす暗い、しかし、俄に激増した人家の灯を、あちこち覗き歩いて、夜もすがら、怪しい嬌笑や、悲鳴に似た悪ふざけや、酔っぱらいの濁み歌などが、寒さも知らずに沸いていたかと思われる。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭部隊は、なお行軍をつづけ、夜のうちに、二里余の先、脇本まで進出すべしと命ぜられ、後方部隊は、中軍からほぼ同距離の板取に駐まったから、首尾およそ四、五里にわたる夜営陣であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚内の率いる小勢は、平野街道から龍田へ出、その夜は、郡山で夜営した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡山の国主、筒井順慶の家臣は、彼らが夜営している処へ来て、こう咎めた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、岐阜城を発して、ひる鵜沼につき、ただちに木曾川に船橋を架けさせて、夜営した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう今日きりやめさせて了えやえい」と彼女は同じことを繰り返した。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
