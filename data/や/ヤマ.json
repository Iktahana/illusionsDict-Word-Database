    "definitions": [
      {
        "index": 1,
        "gloss": "mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夏としなれば、高山に、真ツ白い嘆きを見たり。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃ゆる山路を、登りゆきて頂上の風に吹かれたり。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中は暗くつて、顔には蜘蛛の巣が一杯かかつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本へ出張して一と晩久しぶりで旅人の気分で歩いたが、熊本といふ所はいい所です　火山地方特有の落付がありますとも書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し僕はどれを出すかに迷ふし、一つの詩の一部を抜出すといふやり方は高森の詩には適当でないし、結局沢山出さなければならないやうに思はれるから茲には割愛しなければならぬが、どうぞ此の落付いた稀特な詩集が、一冊でも沢山に売れるやう希望するものである。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま初夏きたる、野に山に、榮光榮光、榮光いんよくの主とその僕にあれ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ山より摘みてかへれば、紫苑はなしぼみて、すでに秋の愁ひをさそふ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしや空はひねもす白金、はやわが手かたく合掌し、瞳はめしひ、腦ずゐは山路をくだる。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――吾妻山中にて――",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは利根川、その氾濫のながめいちじるく、青空に桑の葉光り、さんらんとして遠き山里に愁をひたす、あはれ、あはれ、われの故郷にあなれば、この眺望のいたましさ。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いゆき萩原朔太郎青いぞ、ゆきはまつさを、もも、さくらぎに花咲かず、青いこなゆき、光る山路に泣きくらす。",
              "citation": {
                "source": "青いゆき",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈智萩原朔太郎ふるへる、微光のよるに、いつぱつ、ぴすとるを撃つ、遠方に、金の山脈、かすかな、黒曜石の發光。",
              "citation": {
                "source": "靈智",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、その空さへもうすくもり、かみつけの山に雪くれば、魚らひそかに針をのみ、ま芝は霜にいろづけど、ひとり岸邊に針を垂れ、來らむとする冬を待つ。",
              "citation": {
                "source": "冬を待つひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ尾ばな藤ばかますでに色あせ、手にも料紙はおもたくさげられ、夏はやおとろへ、山頂は風に光る。",
              "citation": {
                "source": "山頂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地宮沢賢治焦ぎ木のむらはなほあれば山の畑の雪消えて〔以下なし〕　――――――――青年団が総出にてしだれ桜を截りしなり",
              "citation": {
                "source": "開墾地",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにてきらめく川やさてはまた遠山の雪その枝にからすとまればざんざんと実はうちゆるゝこのときに教諭白藤灰いろのイムバネス着ていぶかしく五助をながめ粘土地をよこぎりてくる",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雲ふかく　山裳を曳けば〕宮沢賢治雲ふかく山裳を曳けばきみ遠く去るにかも似ん丘群に日射し萌ゆればきみ来り訪ふにも似たり",
              "citation": {
                "source": "〔雲ふかく　山裳を曳けば〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔このみちの醸すがごとく〕宮沢賢治このみちの醸すがごとく粟葉などひかりいでしはひがしなる山彙の上に黄なる月いざよへるなり夏の草山とになひてやうやくに人ら帰るをなにをかもわがかなしまんすゝきの葉露をおとせり",
              "citation": {
                "source": "〔このみちの醸すがごとく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山やハイキングなぞの流行といふこともそんな風なことかも知れぬ。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、手紙が書きたくなるたびに、沢山書くことがあるやうな気持なのですが、さて書き出してみると、何もないのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "金鉱を発掘する人は、親や妻子より遠く、山中に分け入るのだ。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな熱病的なことがあんまり沢山だものだから、文学志望者をだけ読者に持つやうな、浅間しいことにもなるのだ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ金性の肉のおとろへ、みやま瀧ながれ、青らみいよいよおとろふ、いのれば銀の血となり、肉やぶれ谷間をはしる。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ空にまぼろしの島うかびて、樹木いつさいに峯にかがやき、憂愁の瀑ながれもやまず、われけふのおとろへし手を伸べ、しきりに齒がみをなし、光る無禮の風景をにくむ。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
