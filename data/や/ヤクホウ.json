    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prescription",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべて賓国を乗っ取った話（『民俗』二年一報、予の「話俗随筆」に類話多く出づ）、また柳田君の『山島民譚集』に蒐めた、河童が接骨方を伝えた諸説の原話らしい、『幽明録』の河伯女が夫とせし人に薬方三巻を授けた話などを取り雑ぜた作と見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラックの『俚薬方篇』五九頁に、英国サセックスの俗頸｜腫れた時、蛇を頸の上に挽きずり、罎に封じ固く栓して埋めると、蛇腐るに随って腫れ減ずと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か薬方でもご存じか」「いや。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "胞衣を乞うのは、癲癇の薬方として用いんがためであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書名中に「薬方分量考」がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本医学史の医書目録に「続薬方分量考、岡田静宅撰、一巻、文化十年」がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」薬方は原本に註してあるが、今総て省略する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は解剖、二は薬方の酷烈、三は種痘である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒の蘭医薬方の酷烈を非難し、又種痘を非難したことは、下に抄する如くである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）御医師に逢うて御容態を申し、御薬方を相談し、御菓子御茶二汁五菜の御膳を被下、白銀十枚を被賜。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柏軒は又人の病を治して薬方の適応を知るに苦み、神に祈祷して決することがあつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる病を直す薬方を工夫している。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明開化の今日、武家の内職として先祖の始めた時勢おくれの製薬なぞが明日の役に立とうかと言い、もっと気のきいたことをやって見せると言って家を飛び出して行った弓夫にも、とうとう辛抱強い薬方の前に兜を脱ぐ時がやって来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ商用で美濃路まで行くという薬方の手代に途中を見送ってもらうことにした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は嘉助同格の支配人が三人も詰切って、それを薬方と称えて、先祖から伝わった仕事は言うに及ばず、経済から、交際まで、一切そういう人達でこの橋本の家を堅めていた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ大旦那が失敗したから、若旦那には学問は無用だことの、やれ単独で都会に置くのは危いことの、種々な故障が薬方の衆から出た。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "正太を始め、薬方の若衆も皆な遊びに出た。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "往時は橋本の家の経済まで薬方の衆が預って、お種は奥を守りさえすれば好い人であった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で、小泉の家が東京へ引越したばかりの頃、一度彼女は母と一緒に成ったことや、その時も夫がある女に関係して、その為に長年薬方を勤めた大番頭の一人が怒って暇を取ったことや、その時こそは夫婦別をしようかとまで彼女も悲しく思ったことや、それからその時ぎり母にも逢えなかったことなどを胸に浮べて行った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "大番頭の嘉助が存命の頃は、手代としてその下に働いていたが、今はこの人が薬方を預って、一切のことを切盛している。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、席の末にかしこまって食う薬方の番頭も、手代も、最早昔のような主従の関係では無かった。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉辺には、お種をはじめ、お仙、幸作夫婦、薬方の衆まで集って、一緒に別離の茶を飲んだ。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫の前にしゃがんで、ほうせきばこをもどすときに、すばやくほうせきだけをぬき取って、うちポケットに入れてしまったのさ」　黒いお化けのポケット小ぞうがせつめいしました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
