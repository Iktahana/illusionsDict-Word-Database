    "definitions": [
      {
        "index": 1,
        "gloss": "foot of a mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
