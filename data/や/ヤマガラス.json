    "definitions": [
      {
        "index": 1,
        "gloss": "crow in the mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「戦闘艦隊長のはなしでは、おれはあした山烏を追いに行くのだそうだ。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、山烏は強いのでしょう。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いではねをひろげ姿勢を直し、大尉の居る方を見ましたが、またいつかうとうとしますと、こんどは山烏が鼻眼鏡などをかけてふたりの前にやって来て、大尉に握手しようとします。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉が、いかんいかん、と云って手をふりますと、山烏はピカピカする拳銃を出していきなりずどんと大尉を射殺し、大尉はなめらかな黒い胸を張って倒れかかります。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その梢にとまって空を見あげているものは、たしかに敵の山烏です。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏はあわてて枝をけ立てました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏は仕方なく足をぐらぐらしながら上の方へ飛びあがりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏はよろよろっとなって地面に落ちかかりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏は灰いろのまぶたをとじ、あけ方の峠の雪の上につめたく横わりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　烏の新らしい少佐は、お腹が空いて山から出て来て、十九隻に囲まれて殺された、あの山烏を思い出して、あたらしい泪をこぼしました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「戦闘艦隊長のはなしでは、おれはあした山烏を追ひに行くのださうだ。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、山烏は強いのでせう。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いではねをひろげ姿勢を直し、大尉の居る方を見ましたが、またいつかうとうとしますと、こんどは山烏が鼻眼鏡などをかけてふたりの前にやつて来て、大尉に握手しようとします。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉が、いかんいかん、と云つて手をふりますと、山烏はピカピカする拳銃を出していきなりずどんと大尉を射殺し、大尉はなめらかな黒い胸を張つて倒れかゝります。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その梢にとまつて空を見あげてゐるものは、たしかに敵の山烏です。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏はよろよろつとなつて地面に落ちかゝりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏は灰いろのまぶたをとぢ、あけ方の峠の雪の上につめたく横はりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　烏の新らしい少佐は、お腹が空いて山から出て来て、十九隻に囲まれて殺された、あの山烏を思ひ出して、あたらしい泪をこぼしました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほんとうに食える烏かい」「大丈夫、確に山烏だ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会の高いゴシック式の尖塔はこの木のうえにすっくりと聳えたち、いつも深山烏や烏がそのあたりを舞っていた。",
              "citation": {
                "source": "寡婦とその子",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに数世紀のあいだ巣をつくっていた深山烏を邪魔するといけないからである。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "水源、本村正東皇開山烏帽子岳ノ中央ヨリ発シ、片品川ニ入ル。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山烏よくこれをしりてむらがりきたり、袋をやぶりて食を喰尽す。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
