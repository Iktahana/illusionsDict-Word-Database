        "examples": {
          "standard": [
            {
              "text": "磯の香りがするパリパリの焼き海苔は、温かいご飯のお供に最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おにぎりには、香ばしい焼き海苔を巻くと一層美味しくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焼き海苔を細かく刻んで、ラーメンやうどんのトッピングにするのもおすすめだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "焼き海苔、柚味噌、それに牡蠣の三杯酢ぐらいの箸休めで、盃のやりとりもはじまった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨酷な冗談　Ａ、やきのりの罐をいじって居る。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
