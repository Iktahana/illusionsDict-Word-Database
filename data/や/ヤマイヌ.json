      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese wolf (Canis lupus hodophilax, extinct)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なお慧鶴が気をつけて見ると、走り動いている小塊は悉く動物であって野猿と覚しきもの、山犬と思しきもの、鹿の群と思しきもの、種々雑多である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だか、昔の道中に、山犬が出たと云う時のやうですが。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「否、山犬ならまだしもでございます……そんな人……氣味の惡い、私、何うしませう。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禰宜　（解きつつ）山犬か、野狐か、いや、この包みました皮は、狢らしうござります。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "口も比較的に小さい方で、黄い口唇から不規則に露出している幾本の長い牙は、山犬よりも鋭く見えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は山犬のやうな感情がこみあげてきて、部屋の方にむかつてワン／＼と吠え、また後悔をした。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の先祖は狼だといふが、之は間違で、「ドール」といふ山犬の一種だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、演壇または青天井の下で山犬のように吠立って憲政擁護を叫ぶ熱弁、若くは建板に水を流すようにあるいは油紙に火を点けたようにペラペラ喋べり立てる達弁ではなかったが、丁度甲州流の戦法のように隙間なく槍の穂尖を揃えてジリジリと平押しに押寄せるというような論鋒は頗る目鮮ましかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの男ばかりが――」　と僕は馬上のミツキイを指差して山犬の伝に訊ねた。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は、山犬の何某が、そんなことを呟きながらにや／＼と笑つたかと思ふと、ごろりと横になつて、ミツキイの膝に頭を載せようとした。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗賊や鬼はおろか、山犬に出逢っても果たして十分に警護の役目を勤めおおせるかどうだか、よそ目には頗る不安に思われたが、藻に取っては世にも頼もしい、心丈夫な道連れであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんはこの好きな老人から、畠よりあらはれた狸や狢の話、山で飛び出した雉の話、それから奧山の方に住むといふ恐ろしい狼や山犬の話なぞを聞きましたが、そのうちに眠くなつて、爺やの話を聞きながら爐邊でよく寢てしまひました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女小供は度々さう云ふ書生に逢ふと、『また山犬が來たナ、噛附きさうだから避けよう』と思つて避ける。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "女小供は度々そういう書生に逢うと、「また山犬が来たナ、噛附きそうだから避けよう」と思って避ける。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく鳥山犬千代――秋作――は、家橘生れてはじめての大役であつた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の啼く音や猿の叫び声や豹の吠え声や山犬の声などが、林の四方で騒がしくひっきりなしに聞こえていたが、それはどうやら遠征隊の傍若無人の振る舞いを怒っているようにも聞きなされた。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "房吉は深山村の医者の次男坊であったが、小さい時に山中で大きな山犬に襲われた。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東は出羽奥州、北は越中越後遠くは飛騨の山々から、中国辺に至る二、三百年来手広く取引をなし、山の猟師が熊、鹿、狸、狐、羚羊、猿、山猫、山犬などの毛皮を携えて遙々前橋まで集まってきたが、明治になってからはこれを神戸の商館へ持ち込んで外国へ輸出している。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "本と埃でいつぱいのこの男の部屋へはいると、糸のやうに痩せた若者が真黒の仕事着をつけて、然し精悍な山犬か狂人のやうな眼を光らせて一睨みづつ貴女方の顔を射るのに会ふ筈です。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い乱雑な部屋の中に、果して精悍な山犬の眼を光らせた哲学者がゐた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブンさん、強いなア」　と、寺小屋の小僧どもは感服して、「蜂でも山犬でもブンさんを見ると逃げてしもうぞ」「バカ言うな。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫も山犬も、みんなオレの仲よしだ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "段九郎は配下の非人二十人と山犬十匹をつれて宵宮の前夜に山を降りてくるが、配下と山犬は河原へ小屋がけして祭礼のあいだ住んでいるが、村や祭礼へは遠慮して出てこない慣例になっている。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちも知っての通り、段九郎の山犬は狼の一族だ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの山犬の遠吠えをきくと、村や町の飼い犬は小屋へ隠れてふるえているということだ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は四年目の大祭であるし、何十年来の豊作だから、特にさし許す、と称して、段九郎の配下と山犬をお諏訪様の裏の藪へ小屋がけさせる」「それは大ごとら。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ」　ちょうちんに照らしてみると、まぎれもなきジャッカル（やまいぬの属）の屍体であった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地でいふおほかみはやまいぬのことです。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
