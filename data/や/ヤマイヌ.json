[
  {
    "uuid": "cae4667a-794f-5260-9d77-a07f87bc9a73",
    "entry": "山犬",
    "reading": {
      "primary": "やまいぬ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
