[
  {
    "uuid": "53bf1d5a-f19e-5a47-87a3-0f0c8ffd8b3e",
    "entry": "養う",
    "reading": {
      "primary": "やしなう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
