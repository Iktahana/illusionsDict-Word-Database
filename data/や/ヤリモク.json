        "examples": {
          "standard": [
            {
              "text": "合コンにはヤリ目の男が多いから気をつけろ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はヤリ目の男には興味がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の誘いは、どうもヤリ目に見えてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女の母はあんまり父が冷酷でワガママなので、神経衰弱になり、一日に一皮ずつ痩せたあげく、ハヤリ目とカッケにかかって死んだそうだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、墓場にこれ程の財宝が隠してあるとは、何とも合点の行かぬことだが……と、ボンヤリ目を動かしていると、ふと注意を惹いたものがある。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をうなされていらっしゃるの」　ボンヤリ目を開くと、異様に大きな恋人の顔が、私の鼻先に動いていた。",
              "citation": {
                "source": "火星の運河",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "右眼、ハヤリ目といふのでこれは数日かゝると言はれる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
