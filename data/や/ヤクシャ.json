[
  {
    "uuid": "0e11f858-fb35-5c93-87ad-7928feb60b7a",
    "entry": "役者",
    "reading": {
      "primary": "やくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "actor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからすぐまたなんだか役者の話なぞベチヤクチヤ喋舌り散らしてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る教養深い婦人は、「大谷日出夫という役者は、たのもしくていいわ。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大体その現在の世の中といふものは………いや我々役者社会は却々、却々さう一本や二本の調子で渡れるところぢやありませんよ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝いただいて居る東奧日報に據れば、私の兄は、いま、縣會に於いてたいへん割のわるい役をして居るやうである、私、いま、兄上に叱咤されるのを覺悟のうへで申してゐるのであるが、勘平役者が黒衣にまはつたやうで氣持がよくない。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙臺地方には昔から、雀が多かつたのか、仙臺笹とかいふ紋所には、雀が二羽圖案化されてゐるし、また、芝居の先代萩には雀が千兩役者以上の重要な役として登場するのは誰しもご存じの事と思ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長、機関長、を初めとして、水夫長、火夫長、から、便所掃除人、｜石炭運び、に至るまで、彼女はその最後の活動を試みるためには、外の船と同様にそれ等の役者を、必要とするのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の立役者Ｈの子供の初舞台の披露があるためらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者でも舞台の一方から一方へただ黙って通りぬけるだけの役があるらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはなかなかこの娘役者の骨の折れるところであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者が劇中人物に成り切るまでにはやはり相当な時間がかかるからである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の法廷で先ず最初に呼出された証人の警察医はこれは役者でなくて本物である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客中の本職の素人が臨時に頼まれて出て来たのかと思うほど役者ばなれがして見えた。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一座には立役者以外の端役になかなか芸のうまい人が多いようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "証人社長も真に迫るがこの人のはやはり役者の芸としての写実の巧みである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舞台に出ている役者が勝手次第に働けば場面は分裂して統一がなくなってしまうのである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者も裏方も心配そうな顔付。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生意気な役者が（与市兵衛でも、勘平でも何でも結構）吐き出す様に、独り言。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝楽屋の中では　定九郎の仲蔵や座長らしい大石役者や、其他がペコペコ謝っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「役者が、舞台で死ねたら　本望……」　勇ましや、恋人の言葉！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからヂックを勤めたカアソンという役者が、批評家に智恵を附けられて、ジックは牧師の妻を愛しているので、それで牧師の身がわりに立ったということにした。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が口にしてゐるのは、まだ普通の文句なのか、それともまた、火事になつた劇場から、見物人も俳優も、聽衆も立役者も、何もかも一しよくたになつて飛び出してくるやうに、何もかもがごつちやになつて彼等の口から出てくるのでせうか？",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると女のような外交員が、もみ手をしながらおきまりの讃辞を役者のようにしゃべりだした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある酷暑の日にその役者が「今日はだいぶ暑いと見える、観客席で扇の動き方が劇しいようだ」と云ったというのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかしその役者の頭の悪い証拠でなくて良い方の破格の一例として取扱わるべきものであるかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い日の舞台の上は自然的の通風で案外涼しいかもしれないし、それでなくても、その役者が真面目に芝居をやっている限りその日が特に暑い日であるかないか分るはずがないのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしおそらくこれはすべての役者に昔からよく知られたきわめて平凡な事実であるかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽迎いも偽上使もいいが、役者の好い割にゃあ舞台がちっとも栄えねえじゃあねえか」「どうも恐れ入りました」と、女は頭をすこし下げた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明治八年の春、はじめて守田座で上演されたもので、彦三郎の越前守、左団次の伊賀之助、菊五郎の天一坊、いずれも役者ぞろいの大出来であったなどと話した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の役者を通じてゞある。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
