    "definitions": [
      {
        "index": 1,
        "gloss": "Yamaguchi Prefecture (Chūgoku area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
