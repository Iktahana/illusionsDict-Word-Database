    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fielder's choice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帰りに追分辺でミルクの缶やせんべい、ビスケットなど買った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、えいことにして一年せんど行くやこし云い出して……親の苦労はこっちから先も思いやせんとから！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの神戸で頼んだ行李は盗まれやせんのじゃろうかな？",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道に迷やせんじゃろうかの。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺等のためなんど思っても呉れやせんのだ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ゃ、また銃を持てえ云うたって、どうしろ云うたって、動けやせん！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや行き過ぎて若者の一人、いつもながら源叔父の今宵の様はいかに、若き女あの顔を見なばそのまま気絶やせんと囁けば相手は、明朝あの松が枝に翁の足のさがれるを見出さんもしれずという、二人は身の毛のよだつを覚えて振向けば翁が門にはもはや燈火見えざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんなことしよったら、田や畠も旦那に取り上げられて、作らして呉れやせんぞイ。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古鉄砲の張宗昌が、新しい独逸銃に負けるっていう胸算用だな……」「なに、張大人が勝ったって負けたって、何もかまいやせんじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに歎いたって死んだものが生きかえれやせん」　老人は女をなだめた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れゃ、君がどう云ったって、この決心は、やめられやせん。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、あしこにゃ、子供を学校へやった借金はあるし、年貢は、小作が、きちん／＼と納めやせんし、くやんどるとい。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って泣寝入りは出来やせん！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は何も云いやせんぜ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、まあえいが、中学校を上ったって、えらい者になれやせんぜ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小田原の町を放れ、函嶺の湯本近に一軒、茶店の娘、窶れ姿のいと美しきが、路傍の筧、前なる山凡そ三四百間遠き處に千歳久しき靈水を引いたりといふ、清らかなる樋の口に冷たき其の土を洗ふを見て、山の芋は鰻になる、此の牛蒡恁くて石清水に身を灌がば、あはれ白魚に化しやせんと、そゞろ胸に手を置きしが。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前が何しますにつけて、これもまた、学校に縁遠い方だったものでえすから、暑さ寒さの御見舞だけと申すのが、書けないものには、飛んだどうも、実印を捺しますより、事も大層になります処から、何とも申訳がございやせん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれ伯父さん」　と声ふるえて、後ろの巡査に聞こえやせんと、心を置きて振り返れる、眼に映ずるその人は、……夜目にもいかで見紛うべき。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦笛を吹くような声でピーピーと鳴き立ててはベランダの前へ寄って来て、飯の余りやせんべいの欠けらをねだるのである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に嬶が出来たり餓鬼が出来たり何かしてマゴマゴしている中にコンナに頭が禿げちゃっちゃあモウ取返しが付きやせん。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも宙へ、足が枕を離れやせん。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、投銭、お手の内は頂きやせん、材あかしの本を売るのでげす、お求め下さいやし。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「毛頭、お掛値はございやせん。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、諸君、言ったって無駄だ、どうせ買いはしまい、僕も売る気は無い、こんな処じゃ分るものは無いのだから、売りやせん、売りやせんから木製の蛇の活動を見て行きたまえ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人にゃあ出来やせん。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "強き光に打たれなば、消えもやせんと見えけるが、今泰助等を見たりし時、物をも言わで莞爾と白歯を見せて笑める様は、身の毛も弥立つばかりなり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少年は打笑いつつ、「何、突出しやせん。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御念には及びやせん。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と肩を聳かし、眼を据え、「この様だから済せやせん、そのかわりにゃ姉御、俺あ死にます。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
