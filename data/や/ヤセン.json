[
  {
    "uuid": "c6aa0721-db9c-5c69-becf-39999e7c96e2",
    "entry": "夜戦",
    "reading": {
      "primary": "やせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "night warfare",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渡海以来の某は日夜戦陣に屍を暴すをもって本意として来た。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏康は川越の夜戦に十倍の敵を破り勇名を轟かした名将で、向う創のことを氏康創と云われた位の男である。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国時代の戦争の中で、頼山陽は三大戦として桶狹間の戦、厳島の戦、川越の夜戦の三つを挙げてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "川越の夜戦は、北條氏康が寡兵を以て両上杉八万の大軍を撃破した快戦だが、その古戦場が直ぐ東京の近くにありながら、殆んど世人に忘れられてゐるのは、北條氏が亡んでしまつた為めかも知れない。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、橋本で退却して、夜戦に、いくらか戦ったが、誰も鉄砲の音がすると、出て行か無くなってしまった。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は唐の王昌齢の従軍行にある「前軍夜戦※河北、已報生擒吐谷渾」と云ふ詩の句を思ひ出し、昔遼東の鮮卑の胡王である吐呑渾が、漢兵とこの辺で戦つて生擒されたのであらうと想像すると、二千年前の史蹟に来てゐることを不思議に感じた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保の念流一党はこれを知って夜戦の符号や合図を定め山林中に鉄砲を構えて敵を待つ。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリッピン陥ち、沖縄また玉砕したとなると、いよ／＼今度はわれわれの番だと市民は日夜戦々兢々としていたのであった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……除村では門をいっぱいに開き、青竹のそいだもので矢来を結いまわして、門内には水を張った手桶が、幾十となく並べてあり、また夜戦に備えるためだろう、ところどころに松明を組んで立ててあるのが見えた。",
              "citation": {
                "source": "初夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの多くは泣きながら、竹矢来を除き、水手桶や夜戦の支度を片づけた。",
              "citation": {
                "source": "初夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその剣が今手もとにあったならば、もしその剣を死せる父の枕辺から手に取って、街路におけるフランス人同志の夜戦のために、あえて持ち出していたならば、確かにそれは自分の手を焼きつくし、天使の剣のごとく、自分の前に炎を発し始めたであろう！",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう中断は夜戦にありがちなことで、更に激しい襲撃が続いて起こるのが常である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩の暗夜戦には、秀吉方もかなり手痛い損害をこうむった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに追分辺でミルクの缶やせんべい、ビスケットなど買った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、えいことにして一年せんど行くやこし云い出して……親の苦労はこっちから先も思いやせんとから！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの神戸で頼んだ行李は盗まれやせんのじゃろうかな？",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道に迷やせんじゃろうかの。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺等のためなんど思っても呉れやせんのだ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ゃ、また銃を持てえ云うたって、どうしろ云うたって、動けやせん！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや行き過ぎて若者の一人、いつもながら源叔父の今宵の様はいかに、若き女あの顔を見なばそのまま気絶やせんと囁けば相手は、明朝あの松が枝に翁の足のさがれるを見出さんもしれずという、二人は身の毛のよだつを覚えて振向けば翁が門にはもはや燈火見えざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんなことしよったら、田や畠も旦那に取り上げられて、作らして呉れやせんぞイ。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古鉄砲の張宗昌が、新しい独逸銃に負けるっていう胸算用だな……」「なに、張大人が勝ったって負けたって、何もかまいやせんじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに歎いたって死んだものが生きかえれやせん」　老人は女をなだめた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れゃ、君がどう云ったって、この決心は、やめられやせん。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、あしこにゃ、子供を学校へやった借金はあるし、年貢は、小作が、きちん／＼と納めやせんし、くやんどるとい。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って泣寝入りは出来やせん！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は何も云いやせんぜ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、まあえいが、中学校を上ったって、えらい者になれやせんぜ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小田原の町を放れ、函嶺の湯本近に一軒、茶店の娘、窶れ姿のいと美しきが、路傍の筧、前なる山凡そ三四百間遠き處に千歳久しき靈水を引いたりといふ、清らかなる樋の口に冷たき其の土を洗ふを見て、山の芋は鰻になる、此の牛蒡恁くて石清水に身を灌がば、あはれ白魚に化しやせんと、そゞろ胸に手を置きしが。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前が何しますにつけて、これもまた、学校に縁遠い方だったものでえすから、暑さ寒さの御見舞だけと申すのが、書けないものには、飛んだどうも、実印を捺しますより、事も大層になります処から、何とも申訳がございやせん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
