    "definitions": [
      {
        "index": 1,
        "gloss": "to stay in a hotel (inn, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "銀子はここを通過して、上諏訪で宿を取ることにしてあったので、均平は独りで青嵐荘へと車を命じた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "長旅は抱へたり、前に峠を望んだれば、夜を籠めてなど思ひも寄らず、柳屋といふに宿を取る。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ大異の困ったのは、目的地がまだなかなかこないのに日が暮れかかって、宿を取るような人家のないことであった。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵二月の二十五日ごろに江戸に着いて、三月上旬に登城するのが習いで、オランダ人は日本橋｜石町三丁目の長崎屋源右衛門方に宿を取ることに決まっていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は宿を取ると、すぐ港を警衛している役人たちに会って、それとなく黒船の様子をきいてみた。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならば川崎あたりで泊まって、あしたの朝のうちに江戸入りというのであるが、江戸を前に見て宿を取るには及ぶまい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで各自勝手に、木の下に宿を取る者もあれば、小屋掛けをする者もある。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠の懷中は宿を取るさへ心細いくらゐになつてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもこの文無しで宿を取る人間に限って、大きな顔をして威張り散らして、散々大尽風をお吹かせの上、いざ御勘定となると、実は、とお出でなさいます。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へ着くには着いても、今夜からもう宿を取るべき宿銭もない。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山形屋と云ふのに宿を取る。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃では私の父位の身分の一行であっても、宿を取ることになればその宿は一行で借切ったもので『相宿は許さぬ』と告げ、宿屋もそれを承知したものである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が時々宿を取る某ホテルでは、今年の正月、年賀状をよこした。",
              "citation": {
                "source": "続言葉言葉言葉（その一）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦切れてしまえば、あなたと私とはもう赤の他人ですから、どこか他へ宿を取るなり、友達のところに行くなり、よそへいって泊って下さい」「…………」「ねえ、そうして下さい。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "財嚢のはなはだ乏しいジョヴァンニは、ある古い屋敷の上の方の陰気な部屋に下宿を取ることにした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかり早くはござりますが、旅宿を取ることにいたしましょう」――四十歳あまりでたくましくて、忠実らしい下僕はいったが、「お咲殿そのほうがよろしかろうな」乳母らしい老女へ顔を向けた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅宿を取ることにいたしましょう」――乳母のお咲はこういうようにいった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実をいうと彼らは自分のよそに行って宿を取る事を許さなかったのである。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "里に出て宿を取るときには、逃亡を怖れて老夫婦に磨り臼を背負わせた。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿を取るにも、見物するにも、一向勝手が分らないところから、東京の松内さんに戴いた紹介状を持つて、早速大阪毎日支局の春秋さんを訪ねる。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎が歸つたのは、其晩の夜中、「泊つて歸らうと思つたが、調べも何んにも無いところで、便々と宿を取るのも馬鹿々々しいと思つて夜道をかけ戻つて來ましたよ、――寅藏の家は直ぐ解りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お此お糸",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸に宿を取るつもりだったからである。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹子峠を下って来た客もこの黒野田で宿を取る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三笠山雲井の月はすみながら　　　変り行く身の果てぞ悲しきその夜は奈良中坊井上源五に宿を取る。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
