      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cheap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぜこんな所を選んだのかと言へば、宿泊料が安いだらうと思つたからである。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして元来が飽き安い人間の本能を征服｜出来て同棲を続ける者同志の因縁の深さを痛感します。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにジェームス・スチュアルト教授の器械工場の援助を得て、簡単で安いガルヴァなどを沢山作らせることが出来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董品というほどでなくても、三越等の陳列棚で見る新出来の品などから比較して考えてみても、六円というのはおそらく多くの蒐集者にとっては安いかもしれない。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "値段が安いのと表紙の色刷の模様が面白いのとで何の気なしにそれを買って電車に乗った。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の新聞では日本向カワセ相場は九六｜両四分の三、千の寝床を得るのはお安いとこが経済ってものだわ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時から體が弱くて始終病床に臥せつたり、入院生活を送つたりした私は、十三四の頃から、病氣のなほりがけの徒然の時に、冒險小説などと一緒に、あの妙に好奇心を刺戟するやうな石版刷の毒々しい挿繪のある、外國の飜案物や花井お梅だの、五寸釘の虎吉だのと云つた實説物の安い探偵本を讀みふけつた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、乳母｜車なんてお安い御用さ。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外米は、内地米あるいは混合米よりもいくらか値段が安いのでそこを見こんで買うのである。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、樽屋になると、又賃銀が安い。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植民地の労働者をベラ棒に安い、牛か馬かを使うような調子に働かせるために、威嚇し、弾圧する。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、漁業会社は、普通相場の五分の一にあたる安いルーブル紙幣を借区料としてサヴエート同盟へ納めるのだった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒な理窟や計算は抜きにしても少なくも病院にはいるより安いことだけはたしかである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車屋や労働者の吸うもっと安い葉巻で、吸口の方に藁切れが飛び出したようなのがあったがその方は試した事がない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツからパリへ行ったら葡萄酒が安い代りに煙草が高いので驚いた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分たちが迂濶に釣ったり、網を入れたりすると、商売柄だけにすぐに眼につくという懸念から、ふだんから心安い藤吉を抱き込んで、こいつにそっと釣らせていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、阿片の代りに、もっと割が安い、利き目が遙かにきつい三号含有物がここでは用いられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈な日貨排斥運動に、皆目売れ口がない神戸マッチを輸入して、関税や、賦金や、附加税を取られるよりは、労働賃銀が安い支那人を使って、全く支那の製品と違わない「国産品」を、支那でこしらえ支那で売る方がどれだけ合理的なやり方か知れない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと利子の安い勧業銀行へ人を頼んであたってみたりした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪五円にゃ、安いとて売れるせに、やっぱし、二束三文で、買えるだけ買うといて、うまいことをやった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――米も安いし、雑用もかゝらねえし、それに家賃は只だから、これで東京あたりの一円五十銭も二円もにかけ合うべ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭に買うと安いのだ。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに一番安い文芸雑誌を買う。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう目的ならば、ざらにある安い職業的料理書を見て、完全なる総菜料理を捜したほうがいいのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この棚の前には安い小さい美術書を並べた台がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持ちらしい客は「フム、これは安いねえ」「安いんだねえ」と繰り返しながらしきりに感心している。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、注射代などけっして安いものではなく、そのような余分の貯えは失礼ながら友人にあるはずもなく、いずれは苦しい算段をしたにちがいないので、とにかくこれは、ひどい災難である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、もっと安いウイスキイを買って来るべきであった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はこの悲哀を感ずることで、何人よりも深酷であり、他のすべての俳人らより、ずっと本質的に感じやすい詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の若い時代の青年らに、蕪村が最も親しく理解しやすいのはこのためであるが、同時にまた一方で、伝統的の俳味を愛する俳人らから、ややもすれば蕪村が嫌われる所以でもある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
