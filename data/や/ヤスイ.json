[
  {
    "uuid": "e0746f2e-4a4d-5057-a7cb-86902efeaba6",
    "entry": "安い",
    "reading": {
      "primary": "やすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
