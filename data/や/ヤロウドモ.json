        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この龍宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この竜宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎ども、あわてるな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、野郎ども、手を借しなッ」　言いざまに頭がまずまっさきにもろはだぬぎになりましたから、勇みと侠気と伝法はおよそ江戸鳶の誇りです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎どもはなわにするんでしょうね」「決まってらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに上役だからって、あんまりあばたのだんなもくやしいことをするじゃござんせんか」「どんなまねやりゃがった」「お尋ねの非人はすぐめっかりましたからね、出すぎたこととも思いましたが、ちっとばかりあっしも里心出して、野郎どもにかまをかけてみたんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎ども、くせえですぜ」「ウフフ、さてのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎どもを締めあげりゃ、頼み手はいうまでもないこと、何もかもなぞなぞの正体がわかるというんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎どもはあっしが締めあげますぜ」「いいとも、やってみな」　ぱっとおどり入ったそのけはいを聞きつけたとみえて、ばらばらと奥のへやから駆けだしながら行く手をさえぎったのは、七、八人の子分どもです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎どもッ、人足たち！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホシだッ、野郎どものあとをつけろッ」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎ども、だんなのおっしゃるとおり、手を引きな」　だんだら団兵衛とは名のるにもおこがましいような名まえだが、とにかくひざの下のやつも一人まえの親分とみえて、しかりつけたところを、得意の伝六がかたっぱしから数珠つなぎ――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけな、あけな、女の子は近寄ってもさしつかえねえが、ろくでもねえ野郎ども雁首を引っこめな」　肩をふりふり通っていったあとから、名人は秀麗かぎりない面に、ほのかな笑みをたたえながら、静かに通っていくと、案内も請わずずかずかとはいっていって、ずばりと宿の者にいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもよ、見ろ、下さ行けば、漁場の金持の野郎ども、たんまりとりやがるんだ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體、家の兄貴だの、隣の權三だのといふ野郎どもを、無事に歸してよこすといふ、お奉行樣の氣が知れねえ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにも、さっきの子供たちがばらばらと垣根をくぐり出て芋畑を八方に逃げ出して来たかと見ると、おいてゆけおいてゆけ野郎ども、たしかに顔は知れてるぞなどと叫びながら、どっちを追って好いのやらと戸惑うた万豊が八方に向って夢中で虚空を掴みながら暴れ出た。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……籠手すね当てのかずを調べ、野郎どもに渡して置け。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヤイ野郎ども、さあ手をかせ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ野郎ども、急いでゆけ」――で一隊動きだしたが、突然その時広太郎が、「杉窪の里、銅兵衛殿、必ず君尾殿をお助け致す！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ野郎ども介抱せい！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖じ気のついた野郎どもが、よく幽霊を見て本当の人間が飛びこんだと早合点することがあるのでネ」「ほう、幽霊……。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太々しい野郎どもだ」　血迷った高村は、すかさず第三の男に襲い掛ろうとした。",
              "citation": {
                "source": "シベリヤに近く",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はッ、野郎どもは始末におえない横着者なのです」　彼は血走った眼を無念そうに瞬いた。",
              "citation": {
                "source": "シベリヤに近く",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "』それから今度は、三頭全体に向って、『えい、この野郎ども！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "露助という奴は、いざという時になると、お先きまっくらに何でもさっさとやっつけてしまうものだが、セリファンも次ぎの四つ角へ来ると、いきなり右へ曲って、『えい、野郎ども、しっかり頼むぜ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……やいやい野郎ども声を上げろ！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花車は手頃の杉の樹をモリ／＼／＼と拗り切って取直し、満面朱を灌ぎ、掴み殺さんず勢いにて、　花「此の野郎ども」　といいながら杉の幹を振上げた勇気に恐れ、皆近寄る事が出来ません。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、黙れ、野郎ども！",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ずるけ野郎ども、二三人で奴の体を調べるんだ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、下にいる野郎ども、ビルの体についてやしねえか？",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
