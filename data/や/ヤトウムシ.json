        "examples": {
          "standard": [
            {
              "text": "夜盗虫の被害から作物を守るため、農家は様々な対策を講じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜盗虫は夜間に活動し、植物の根元を食い荒らす害虫だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "畑で夜盗虫を見つけたら、すぐに駆除しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ぼくはまるで権十が甘藍の夜盗虫みたいな気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手も足も膨れているからぼくはまるで権十が夜盗虫みたいな気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬治君に教へられて、大根の芽を噛み切る夜盗虫なるものを退治してやつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            }
          ]
        }
