    "definitions": [
      {
        "index": 1,
        "gloss": "copper pheasant (Syrmaticus soemmerringii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
