        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうせ遣っ付けるなら塊めて、うんと遣っ付ける方がいゝ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵を目付けた其上に、助太刀ぐらいはしてやるから、俺の云うことを聞くがいいとな」「成程、大きに可いかも知れねえ」「逆応用という奴さ」「今夜あたり遣っ付けるか」「ところで何うだ、稼業の方は？",
              "citation": {
                "source": "隠亡堀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼一流の方法で、やっつけるだけであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、メリケン兵をやっつけるとあとからもんちゃくが起る。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾をやっつける気があるなら、屋敷の中でやっつけるか、帰る途中をやっつけるか、何もわざわざ当人の家まで押し掛けて行くには及ばねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実際、俺等にゃ、支那人をやっつけることばかりしかやらせやしないじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達はすきこのんで、あいつ等をやっつける身分かい！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎むべき独逸軍をやっつけるべきか、軍国主義に反対すべきか！",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっつけるばかりでなく、恐らくそのシャアシャアした婦人を暗く不幸にせずにはおかないように思えました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番やっつけるかな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の趣意は、新子を思うさま、やっつけることであり、新子が、今までの家庭教師に比して、ずっと秀れていることを、心の内では認めているだけに、これを機会に追い出そうという肚ではなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、今まで、わがまま一杯に育ち、人を権柄ずくにやっつけることには、巧みでも、一度相手から逆撃されてみるとたちまち勝手が違い、カッとのぼせ上って来、気の遠くなるほど、美和子が憎らしくなりながら、口の方はかえって辛辣さを無くしていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくなら、徹底テロリズムを持ち出して、親父の奴をまず真っ先にやっつけるだろうね」　賢三郎はそう言って微笑んだ。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、敬二郎をやっつける機会を安全に持つことのできるような方法は……）　正勝は考えるのだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乃公は、警察へ往くのだ、邪魔しやがると、ついでにやっつけるぞ」　夜になって雨が降りだして珍らしい暴風雨になったが、その暴風雨の中で山田家のあの中央の蟻の塔のある土蔵が潰れた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、なぜ長太郎をやっつける気になった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を連れて来た男をやっつける義務を感じて来た。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長も、今は強圧的に、頭ごなしにやっつけるわけに行かなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、船長は、一撃の下にやっつけるはずであって、交渉などをする気はテンデなかったのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　京子が、やっつけるようにいう。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪く片附けていやあがると引殴くぞ」　などと勇敢にやっつけるのであった。",
              "citation": {
                "source": "半七雑感",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレ　　やっつける？",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三〇年以来赤をやっつけることは一般の事になっているが、それはほんの一部のものにすぎないようだけれど、進歩的な分子をオミットすることであの戦争だってみちびき出されて来た。",
              "citation": {
                "source": "東宝争議について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな金の力によって、政治を動かすこともできるし、新聞や映画などでわれわれの敵をやっつけることもできるし、もちろん軍隊を動かして戦争をさせることもできる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本をやっつけるために、われわれはもっともっと空軍を強くし、戦車や潜水艦をうんと造り、また日本国民の心がぐにゃぐにゃになるような宣伝や、それからだらしのない遊びなどを日本に流行らせなければならん――とまあ、そんな風に考えでいるのです」　ハバノフ氏はそういって、大きな口を結んだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを狙って、こっちは爆弾と砲弾とでもって、どどどどっとやっつける」「おい大丈夫かね。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よォし、いま日本人をやっつける……」　そういって彼は拳銃の口を下に向けた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちナポレオンは当時の用兵術を無視して、要点に兵力を集めて敵線を突破し、突破が成功すれば逃げる敵をどこまでも追っかけて行って徹底的にやっつける。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
