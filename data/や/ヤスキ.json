  {
    "uuid": "e7a274a4-bc8f-53fc-a59f-398f2bb00f18",
    "entry": "安き",
    "reading": {
      "primary": "やすき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四辺の林もしばしはこの青年に安き眠りを借さばやと、枝頭そよがず、寂として音なし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟はそういうものをいかにして取り扱ってよいかという見当がつかなかったせいもあろうが、一つにはまた物理学がその「伝統の岩窟」にはまり込んで安きを偸んでいたためとも言われうる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に夜深く、加ふるに當夜は浪穩にして、船に些の動搖もなければ、船客の多數は既に安き夢に入つたのであらう、たゞ蒸※機關の響のかまびすしきと、折々當番の船員が靴音高く甲板に往來するのが聽ゆるのみである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り合いは前後に俯仰し、左右に頽れて、片時も安き心はなく、今にもこの車｜顛覆るか、ただしはその身投げ落とさるるか。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊丹の城主、荒木村重につかえて横目役を勤め、年久しく主家を泰山の安きに置いた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、吾等此より安きを獲んと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の中はいざ知らず、袈裟に枯木の身を包みて、山水に白雲の跡を逐い、或は草庵、或は茅店に、閑坐し漫遊したまえるが、燕王今は皇帝なり、万乗の尊に居りて、一身の安き無し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "予をして爾く速かに入院の決心をなすべく誘つたものは、夜寢てさへも安き眠りを許さぬ程に壓迫するその腹でも、また青柳學士の口から出た予の生命に對する脅迫の言葉でもなく、實に予をして僅かに一日の休養さへも意に任せさせぬ忙がしい生活そのものであつた。",
              "citation": {
                "source": "第十八號室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾いた、壁も戸も無い私の庵室に支柱をして、兎に角私たちは辛うじて安きを得た。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にここの家でも三年前、ちょうど今夜のような吹雪の夜に、十三になる姉娘を誘い出された怖ろしい経験をもっているので、おとといの晩もゆうべも、一家内は安き心もなかった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八代の義政は、権臣や諸将の勢力から身を避けるために、風流の道に逃避し、下剋上の当時に、やつと一身の安きを保ち得た将軍である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶太をとめ　許をも受けで校外に出で、士官と倶に酒店に入りしは、輕からぬ罪なれば、若し事｜露れなば奈何にすべきと、安き心もあらざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪我せし人やあると、人々しばしは安き心あらざりしが、こたびは聖母やさしき手を信者の頭の上に擴げ給ひて、一人をだに傷け給はざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "發送せし後は心やゝ安きに似たれど、或は姫を失はんをりの苦痛を想ひ遣りて、プロメテウスの鷲の嘴に刺さるゝ如き念をなし、或は姫に許されて戲場を雙棲のところとなさん日の樂｜奈何なるべきと思ひ浮べて、獨り微笑を催すなど、ほとほど心亂れたる人に殊ならざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンタ夫人は徐に友を顧みて、好き處に來給ひたり、アントニオ君は熱を患へ給ふにやあらん、心地惡しとのたまひつゝ、忽ち青くなり又赤くなり給ふ故、安き心はあらざりきなど云ひ、又我に向ひて、いかに、今は前の如くにはあらざるならんと云ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど尼寺の心安きには似ず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二　もとより自ら進んでも、かくはなるべき運命であったろうけれども、さまでとはさすがに思い懸けなかった、積年の憂苦辛酸、一｜日の安き暇もないので、お絹は身も心も疲れ果てて、その一月ばかり前から煩い出し、床に就いて足腰の自由が利かなくなると、夫｜狂犬源兵衛は屋外にこれを追出した。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手古奈は吾思ひの一切を括つて、成行きに從ふの外なき身の境遇より、眞奈が戀の却て無邪氣に心安きを羨むらしい。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら彼らは明白に神の真理に背いて、果して安きを得るであろうか。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、無いのか、有るのかよ」　肩に懸けたる手をば放さで連に揺るるを、宮は銕の槌もて撃懲さるるやうに覚えて、安き心もあらず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "言つたら貴様の呼吸が止るぞ」　貫一は苦しさに堪へで振釈かんと※けども、嘉納流の覚ある蒲田が力に敵しかねて、なかなかその為すに信せたる幾分の安きを頼むのみなりけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲田弁理公使が宜く樽爼の間に折衝して、遊佐家を泰山の安きに置いて見せる。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に例の不断の痛苦は彼を撻つやうに募ることありて、心も消々に悩まさるる毎に、齷※利を趁ふ力も失せて、彼はなかなか死の安きを懐はざるにあらず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその日のその夜に会ふ毎に、果して月の曇るか、あらぬかを試しに、曾てその人の余所に泣ける徴もあらざりければ、さすがに恨は忘られしかと、それには心安きにつけて、諸共に今は我をも思はでや、さては何処に如何にしてなど、更に打歎かるるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋も有らず、怨も有らず、金銭も有らず、権勢も有らず、名誉も有らず、野心も有らず、栄達も有らず、堕落も有らず、競争も有らず、執着も有らず、得意も有らず、失望も有らず、止だ天然の無垢にして、形骸を安きのみなるこの里、我思を埋むるの里か、吾骨を埋るの里か。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事もなく昨日の生活を今日に繋ぎ、今日の生活を明日に延ばすような生活を最も面倒のない生活と思い、そういう無事の日暮しの中に、一日でも安きを偸もうとしているのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸もあらはに衣裂きて、濃青の淵にのぞむとき、母の腕による如き安きおもひのなからずや。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の事に憤慨するよりも、一鉢の朝顔に水を遣る真実味を愛するといった風で、驢背の安きに如かずという亡国の賢人に似たところがある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜界は安きことなし、猶火宅の如し衆苦充満して、甚だ畏怖べしつねに生、老、病死の憂患あり是の如き業の火、熾然として息まず　私どもの住むこの世界は、あたかもさかんに燃えている火宅である、という釈尊のこの体験こそ、尊い人間苦への警告だったのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "附きやすき花粉のしめりのごとく、そはまた※の汗のごとくに顫へやすし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
