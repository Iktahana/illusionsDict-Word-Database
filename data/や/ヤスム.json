    "definitions": [
      {
        "index": 1,
        "gloss": "to be absent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何故なら芸術といふものは其処で休むためのものであつて、其処で生産しようといふやうなものではないからである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五十人の生徒をあづかつてゐるのだから、その人間が自分一人の用事のために学校を休むなぞといふことはなりません」と、叔母は茶棚を片附けながら、押入れの中を拭いてゐる僕に喋舌りつづけてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は人の前に出る毎に、この反対衝動の発作が恐ろしく、それの心配と制止観念とで、休む間もなく心を疲らし、気を張りきって居らねばならぬ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ素朴の疑問に就いて鷹揚に首を振つて考へ、「砂濱の萩の花も、這ひ寄る小蟹も、入江に休む鴈も、何もこの私を批評しない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（立ちながら休むときは、脊の担い梯子へ、息杖を当てがって、肩を緩めるので「一本立てる」というのである。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几代りにまた腰をかけて、少し休む。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は関わずに、すぼめて逆さに立てた蝙蝠傘を支えにして、しゃがんで休む。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな山の中で休むより、畑へ往ってから休もうというので、今度は民子を先に僕が後になって急ぐ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を懐へ入れ足を展して休む。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼は、働らく時間と休む時間とを、タイムテーブルによつてはつきり區別し、頭腦の能率を最も經濟的によく利用するのである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男も茶店に休む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝点呼から消燈時間まで、勤務や演習や教練で休むひまがない。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――みんな欲で欲には限りがない――役目となれば五円が十円でも、雨の日雪の日にも休むわけにはいかない、やっぱり腰弁当で鼻水をたらして、若い者の中にまじってよぼよぼと通わなければならぬ。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの鳥の啼くのでも大概平均三声くらい啼いてから少時休むという場合が多いようである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴も、飯も、勤務時間も、休む寝床も、はッきりと区別がついていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………休むひまに、道具の名前一つでも覚えるようにせい！",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも都会に住み慣れ、ことに最近は心の休む隙もなかった後で、彼はなおさらこの静けさの中でうやうやしくなった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその娘の家のぐるりを歩いてはその下のベンチで休むのがきまりになっていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分と休む間もない位で、夜の目も合わさないで尽力したです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけに文公を揺り起こして、「オイちょっと起きねえ、これから、おいらは仕事に出るが、兄きは一日休むがいい。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は随分暑かッたが森へ来て少し休むと薄暗い奥の方から冷たい風が吹いて来ていい心持になった、青葉の影の透きとおるような光を仰いで身体を横に足を草の上に投げ出してじっと向こうを見ていると、何という静かな美しい、のびのびした景色だろう！",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京女の気まぐれ者にはそれで済でゆくので、三日も四日も仕事を休む、どうかすると十日も休む、けれどサアとなれば人三倍も働くのが宅の磯｜様だと心得ている、だからサアとなれば困りや仕ないと信じている。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貧乏が好きな者はないよ」「そんなら何故お前さん月の中十日は必然休むの？",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいしたこともあるまいと初めは医者にもかからず、役所にはつとめて通っていましたが、だんだんに悪くなりましてしまいには役所を休むようになりました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校を休む事にきめる。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで生徒のほうで勝手に休むことに相談一決してみんなで失敬してしまったものである。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、これらの諸仏諸祖は、私たちが仏陀覚者に成り終らない限り、休むことが出来ないのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、けれど、ごらんなさい、そら、どうです、あの立派な川、ね、あすこはあの夏中、ツヰンクル、ツヰンクル、リトル、スター　をうたってやすむとき、いつも窓からぼんやり白く見えてゐたでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、けれど、ごらんなさい、そら、どうです、あの立派な川、ね、あすこはあの夏中、ツインクル、ツインクル、リトル、スター　をうたってやすむとき、いつも窓からぼんやり白く見えていたでしょう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おろかな男は、やすむのにさへ、へまをする。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
