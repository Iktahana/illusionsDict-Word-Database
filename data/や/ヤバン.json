[
  {
    "uuid": "36b7aece-04d5-5d41-8d46-9a53b31a8b56",
    "entry": "野蛮",
    "reading": {
      "primary": "やばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "savage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何ものにも捉はれない野蛮人めいた狂暴無智の感情の大浪と、そのうねりくねる所の狂的なリズム。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の神経は、近代文明の病癖を受けて針のやうに過敏であり、その感覚は驚くべく洗練された者であるにも関らず、彼の精神は全く子供のやうな単純さと、野蛮人のやうな生生した原始的の驚きに充たされて居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はば室生は文明人の繊細な皮膚と野蛮人の強健な心臓とをもつて生れた、近代世紀の幸福なる予言者である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその妻のごとき、純日本的な可憐な女を、彼のいわゆる『野蛮人』である西洋人の社会に、孤独で生活させることの痛ましさは、想像だけでも耐えがたい残忍事だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野蛮人』という言葉は、彼の語藻において『西洋人』と同字義であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、野蛮な人ではない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上思想を持込むなぞは野蛮人がありつたけの頸飾りを着けるがやうなものだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校へ行って文明を教わっている村の青年たちには、裃をつけて菅笠をかむって、無意味なような「ナーンモーンデー」を唱える事は、堪え難い屈辱であり、自己を野蛮化する所行のように思われたのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下流であがってはまた野蛮人のようにその白い岩の上を走って来て上流の瀬にとびこみました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "barbarus で思いだすのは「野蛮」と (Skt.)yavana である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「ヤ※ナ」が「野蛮」に通じまた「野暮な」に通ずるところに妙味がないとは言われない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争のないうちは吾々は文明人であるが、戦争が始まるとたちまちにして吾々は野蛮人になり、獣になり鳥になり魚になり、また昆虫になるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では野蛮でブルータルであると同時に一方ではまた新鮮で明朗で逞しい美しさがないとは云われない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始的無技巧という点では野蛮人の絵や子供の絵は最も代表的のものであろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれだけではいまだ野蛮人や子供の絵と異なるところはないが、それと大いに異なるところはこれらの材料から組立てる一種の「｜思考の実験」である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵がやぶれた、野蛮な人間の指が、むざんにも繊細なものを押しつぶしたのだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は子供のように野蛮に自分の体の一ヶ処を捻ってみた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮………………マリを跳ねかえした。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私の踊友達は中指で私をつつきながら、それでは日本人は野蛮人でもときによると貴方みたいに文明的な日本人もあるので、文明人には国と国の境界はないのだから妾は貴方をわるくは思わないと彼女が云った。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐突に、鋸くずのような幕が切っておとされて、野蛮な四重奏が苛立たしく鳴りだした。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからこれは野蛮民の戦争踊りが野蛮民に訴えると同じ意味において最高の芸術でなければならないのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも私の子供の時分のそれはちょうど野蛮民のそれと同様な超自然的なものであったに相違ないと思われるのである。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は徳川時代に於けるような、この野蛮なやり方に興味を持っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「張大人は野蛮だからよ……さぞ、内地の人間が見たら、おったまげるこったろうな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮な暴力的なことをやらなくたって、正式に娘を貰えばいいじゃないか、それなら俺れだって賛成だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "責任を問われる心配がない××××と××は、兵士達にある野蛮な快味を与える。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やばんで、らんぼうな兵隊たちの前で、王さまは、はだかのまま、踊りまわりました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "大して歩きもしないうちに、まっ黒な、やばん人のむれに行きあいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
