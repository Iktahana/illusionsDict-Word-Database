        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（當時の室生君は、今よりもずつと甚だしく野性的であつた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし實際言へば、芥川君の僕に對する實の興味は、やはり室生君の場合と同じく、僕の氣質の中の野性的直情にあつたのだらう。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の「野性的好男子」もわれらのような旧時代のものにはどうもあまり好感の持てないタイプである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして貴族組と遊んでゐるとき、平民組の子供の野性的な氣風にこがれてゐた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高踏的精神と野性的氣質。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "微妙なもの等の野性的な集団を見ることは、女の感覚には、気味の悪いところもあったが、しかし、芽というものが持つ小さい逞しいいのちは、かの女の愛感を牽いた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）小泉君と先般｜逢ったが、相変らず元気、あの男の野性的親愛は、実に暖くて良い。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に野性的で活力的で逞しく、美しいとさえ言っていいかも知れぬ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この燃え上がる恋心は、突発的で移り気な少年の気まぐれではなく、強い意志と傲然とした気質を持つ、野性的でたくましい男の熱情だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "小賢しさを知らぬ野性的な豪快さなどもあつて、わたしは普だんから、相当に不思議な作家だと思つてゐる。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家でおとなしく飲んでいられないような野性的な彼の卑しい飲み癖が、一層お島を顰蹙させた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし僕が野枝さんに惚れたとしたら、彼女の文学的才能と彼女の野性的な美しさに牽きつけられたからであった。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには洗練された都会育ちの下町娘よりも熊襲の血脈をひいている九州の野性的な女の方が遙かに好適であった。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "強情で、ナキ虫で、クヤシがりで、ヤキモチ屋で、ダラシがなく、経済観念が欠乏して、野性的であった――野枝さん。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "平林たい子の「施療室にて」が、『文芸戦線』にのって、その野性的でつよい筆力を注目されはじめたのは一九二七年頃のことであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野性的の感○蚕種寒心太製造　　　　　隣室の話　男、中年以上姉さんという女　　もっと若い女、　　　芸者でもなし。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野性的で、行儀作法は知らないけれども、いいところのある女なり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなつたひとは、田舍の女學校を出て、すぐ上海に來て喫茶店に働いてゐた娘ださうで、まだ十九で非常に野性的な女だつたのださうだ。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野性的の皓い齒並の美しさが、笑ふ度に、何とも云へない魅力を持つてゐたし、太い眉と眼はつまつてゐたけれども、眼は大きく情をたゝへてよく光つてゐた。",
              "citation": {
                "source": "崩浪亭主人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野性的で、行儀作法は知らないけれど、いゝところが多分にあった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱き者よの言葉は、そっくり私に頂戴出来るんですが、それでいいと思う、野性的で行儀作法を知らない私は、自然へ身を投げかけてゆくより仕方がない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉づきはよかったが、顔はタヒチの女のように脣が厚く大きく野性的な表情で、気がむくと虎やライオンの真似をして稽古場で朋輩を笑わせていた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな感情も心にしまつてはおけないゆき子の野性的な性格が、愛らしかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬紅の赤い、田舎々々した女に、このやうな獣のやうな、野性的な力があるのかと、富岡はとりのぼせて、片手でウィスキーのグラスをあふつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて男がこうした態度を執る時……殊にストーン氏のような男らしい風采と、溢るるばかりの野性的な元気に充ち満ちた男性が、このような敬意と熱誠を示す時、相手の女性は最も甚だしく心を掻き乱され、引き付けられるものである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その豊富な角苅の銀髪とブラシのように生やしたゴリラ式の狭い前額と太い房々とした長生眉と、大きく一文字に閉じた唇を見ると、成る程これならば嫌疑の掛かるのも無理はないと考えられそうな野性的な、頑固一徹の性格をあらわしていた。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、室内にとじこめられた単に愛玩具の外国産のものでなく、自由に戸外をもかけ廻る野性的な日本種がいい。",
              "citation": {
                "source": "猫性",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
