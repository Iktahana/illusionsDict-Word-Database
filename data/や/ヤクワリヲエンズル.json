[
  {
    "uuid": "b67ad0b7-7c26-5975-85d1-bbc1a454ebb4",
    "entry": "役割を演ずる",
    "reading": {
      "primary": "やくわりをえんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-ずる変"
      ],
