        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五月八日　明くれば十月二十五日自分に取って大厄日。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇、さすがに厄日前後らしい天候。",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月四日朝焼、曇、雨、厄日頃らしい天候。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十九日というのは厄日でさ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの分際でこう申しちゃあ失礼でございますけれども、何だかあなたはお厄日ででもいらっしゃいますように存じますわ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十日という厄日が、古来の経験で恐れられていた実証が、あまりに如実だったので、夕方凪ぎ晴れてきた時には、その渦雲を浮べた空に私は半ば讃嘆したような感じを持った。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月廿四日　朝は曇つて厄日前の空模様だつたが、おひ／＼晴れた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕焼の色が不穏だつた、厄日近しといふ天候。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は二百十日だつた、まことにおだやかな厄日であつた、めでたいめでたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "『物みな我れに可からざるなし』　九月三日　曇、さすがに厄日前後らしい天候。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月九日　雨、さすがに厄日前後で雲行不穏。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄日近い天候、雲の色も風の音も何となく穏かでないものがあつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まことにおだやかな厄日、ありがたいことである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百二十日、さすがに厄日らしく時々降つたり吹いたり、雷鳴があつたり、多少不穏な空気が動かないでもなかつたが、無事だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄日前後で雲行何となく不穏。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄日らしく降つたり吹いたり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は二百三十日、厄日を無事平穏に通り越して、めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに厄日ちかい風物、雲のたゞすまひ、風のうごきかたが何となくおだやかでない。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月七日　曇、厄日前後らしい時化模様。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆の十四日が百姓平次郎に鉈をふるわせる厄日であり、室三次の命の綱である馬が軍隊に徴発され、その八十円を肥料屋と高利貸に役場で押えられた室三次の女房は絶望して発狂した等々。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "・墓へ藷の蔓・秋風のふるさと近うなつた　八月廿九日厄日前後らしい空模様である、風のために本まで動く、炊事、掃除、読書、なか／＼忙しい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はお前にも大厄日だ。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲が、初秋に行はれるのは、もとは、二百十日・二百二十日の厄日を控へた、農村では最大切な時期に、此神事が行はれたのだと思ふ。",
              "citation": {
                "source": "草相撲の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて二百二十日の厄日もまたそれとは殆ど気もつかぬばかり、いつに変らぬ残暑の西日に蜩の声のみあわただしく夜になった。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、民間にて厄年、厄日というものがある。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、厄日または凶日として避け嫌う日がたくさんある。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "片瀬へ着いたのは大嵐の眞つ最中、忘れもしない二百十日の厄日の翌る日、陸から見ると江の島が泡の中へ湧き上がるやうな恐ろしい景色でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地獄から來た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片瀬へ着いたのは大嵐の真っ最中、忘れもしない二百十日の厄日の翌る日、陸から見ると江の島が泡の中へ湧き上がるような恐ろしい景色でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっくりと柔味のある光線をうけてしおらしげに耳朶やくびすじはうす赤にすき通って居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど薄着になったときで、彼女の躯のしなやかさや、弾力のある軟らかなまるみやくびれが、美しくあらわれていた。",
              "citation": {
                "source": "女は同じ物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
