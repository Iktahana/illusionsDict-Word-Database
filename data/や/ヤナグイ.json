        "examples": {
          "standard": [
            {
              "text": "古戦場で発見された武士の遺品には、矢の入った胡籙もあったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弓道の稽古では、胡籙から素早く矢を取り出す練習も重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は伝統的な弓術の衣装を身につけ、腰には胡籙を帯びていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それにも辛抱すると、女はいろいろいたわってくれたが、十日ばかりして、笞のあとがすっかり回復したころ、ある夜、女は男に水干袴と立派な弓、やなぐい、すねあて、わらぐつなどを与えて、装束させてからいった。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
