        "examples": {
          "standard": [
            {
              "text": "昔ながらの製法で作られた山塩は、独特の結晶形をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これと同じようなことが、山の頂きと谷との間にあって山谷風と名づけられています。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「湖水や海の水が、冬になって表面から冷えて行くときにはどんな流れが起るか」という問題にも関聯し、また飛行家にとって重大な問題である突風の解釈にも導かれ、更に進んでは海陸風や山谷風、また大東亜の空を吹く季節風にまでも、拡張されて行くのである。",
              "citation": {
                "source": "「茶碗の湯」のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
