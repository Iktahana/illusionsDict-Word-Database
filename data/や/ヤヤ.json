[
  {
    "uuid": "f1c4af0a-4145-590b-9d48-6a2745681030",
    "entry": "稍",
    "reading": {
      "primary": "やや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "形容詞-語幹"
      ],
