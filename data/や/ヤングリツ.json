          "literary": [
            {
              "text": "この実験は、材料のヤング率を測定するときに、いつでも使われる方法である。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、ふつうの物質では、棒は円の弧の形に曲り、その彎曲度から、ヤング率が計算される。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樫の卓の上に立てるとすると、樫のヤング率は1.3×1011くらいである。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
