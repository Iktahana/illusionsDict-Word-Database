    "definitions": [
      {
        "index": 1,
        "gloss": "the year before the unlucky year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
