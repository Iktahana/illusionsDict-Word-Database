          "literary": [
            {
              "text": "やる事なす事この卵的な性格を帯びたのだ。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつらはやることなすことすべて支持される。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいじょうぶだ、へびはいねえよっていってやりましたら、おれさまともあろうものが、こまっけえやつの下風についてたまるけえと、こんなことをガミガミ言いのこしまして、どこかへずらかっちまいましたんですよ」　いっているところへ、どうもやることなすことが伝六流でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "……両国橋の橋詰めで、あいつに河へ追い込まれてからは、何彼につけて怖じ気がつき、やることなすこと食い違い……」　なお女房は祈っていた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは馬鹿たれで、やることなすこと、へまばっかりを一生涯つづけて来たが、またしても、哀れな女に大嘘をついてしもうた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
