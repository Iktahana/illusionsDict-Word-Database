          "standard": [
            {
              "text": "料理で出た野菜くずをコンポストに入れ、自家製堆肥を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "玉ねぎの皮などの野菜くずを煮出すと、美味しいベジブロスが取れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捨ててしまう野菜くずも、工夫次第で立派な一品料理に変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "植物、野菜、果物の腐敗したものを好み、ごみため、下水の近くに繁殖するものであるから、庭の片隅を二尺四方ぐらい掘り、野菜くずなどを入れ、米のとぎ水をかけ、古ムシロでフタをして、その上からもまた、とぎ水をかけ、箱か平石などをのせておく。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
