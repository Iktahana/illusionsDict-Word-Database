    "definitions": [
      {
        "index": 1,
        "gloss": "medicated bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後園の桃園では女の死体をおろした岳父が狂気のようになって、婢のはこんできた薬湯を口や鼻から注ぎ込んでいた。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「魂よせじゃ、魂よせじゃ」　岳父は薬湯の器をほうりだして叫んだ。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の湯屋は白湯を主としていたのであるが、明治二十年頃から温泉、鉱泉、薬湯、蒸風呂などの種類が殖えた。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "回診の折り院長は掌から手首にまでも及んだ焦色を見て首を傾け、薬湯につけてあとを繃帯することを看護婦に命じた。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前の晩に私はこの三人で散歩に出かけ、中将湯に寄つて皆なで「中将湯」を喫まう、男だつて差支へないと云はれて、私は紅茶々碗ですゝめられる薬湯を見たりして間もなく二人を撒いた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝松はその薬湯をすすったばかりで、粥も喉には通らなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の母の同居してる家では、リュウマチを患っている老人のために、上州の方から取り寄せられた湯の花で薬湯がほとんど毎日のように立てられた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日ヒゼンの薬湯に入る。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途、薬湯に入つてコダハリを洗ひ流す、そして一杯ひつかけて、ぐつすり寝た、もとより夢は悪夢にきまつてゐる、いはゞ現実の悪夢だ。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年の自記に、阿部家に願つて、「湯島天神下｜薬湯へ三｜廻罷越」と云ふことが度々ある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は此家は所謂「湯島天神下薬湯」の家かとも疑はれる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし蘭軒の語に分明に「移家」と云ひ、「構成湖上家」と云ふを見れば、どうも薬湯の家とは認め難い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月七日に蘭軒は湯島天神下薬湯へ湯治に往つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私儀去十二月下旬より足痛相煩引込罷在候而、加藤遠江守様御医師谷村玄申聞候、依之月代仕、湯島天神下薬湯え三廻り罷越申度段奉願上候所、即刻願之通山岡衛士殿被仰渡候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私儀足痛全快仕候に付、薬湯中には御座候得共、明廿三日より出勤仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二月二十五日頭風追々全快仕候に付、月代仕、薬湯え三廻り罷越度段奉願上候処、即刻願之通被仰付候段、山岡治左衛門殿被仰渡候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤向覚書を見るに、蘭軒は十二月十一日に例の湯島の薬湯に往つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十二月十一日足痛追々全快には御座候得共、未聢と不仕候間、湯島天神下薬湯え三廻り罷越度奉願上候処、即刻願之通被仰付候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十三日に蘭軒は又薬湯の願を呈して、即刻三週の暇を賜はつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒豆を薬湯で煮て飲まそうとしているが、今日は山羊も凋れて悲しげである。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪のくすぶっている炉の傍に、薬湯がかかっていて、蝿が荒筵の条目を斜めに匐っているばかりだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は故人となった桂文団治なども、そのつるつる頭を薬湯へ浮かばせていたものであった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい達磨を書いた油障子の立ててある髪結床の前に、薬湯と、横板の看板のかかった湯屋があった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "又――」　肩で、大きい呼吸をして、暫く、黙っていたが、女中の運んで来た薬湯を、仁十郎の手から一口飲んで「人に優った気力も、使い果してしもうた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主が、入って来て「お薬湯」　と、云って、斉彬の膝のところへ、薬湯を置いて行った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉彬は、眼を開いて、久光を見て「何か、珍しい話はないか」　と、聞いて、薬湯へ、手をかけた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、斉彬が、薬湯を飲み終ると「首尾、如何で、ござりました」　と、口を切った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
