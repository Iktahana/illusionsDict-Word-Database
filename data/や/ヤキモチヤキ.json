        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "津田氏よりも私のほうが、もっとやきもちやきなのかも知れないと思ったからである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異人さんはやきもちやきよ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれでね、あの人は、おツそろしいやきもちやきなんですつてさ――それがもとで女の方で愛想を尽かしてしまつたんだつて――」「ほう！",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母さんにしろ此処の姉さんだつて、いざとなれば気狂沙汰のやきもちやきなんだから可笑しくつて仕様がないや。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中で一番のやきもちやきはあの爺だらうと妾は思つてゐるんですが……」　私はテルヨから左う聴いた時、驚きのあまり思はず胸一杯に空気を吸ひ込み、長い※があるかのやうに顎を掴み百貫の鉄棒のやうに徐ろに左腕を宙にあげてゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やきもちやきなんだよ、／＼、いゝ年をして……」　そんなことを父が喋ると、面白がつて笑ふ彼だつた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔自慢で村の若者たちから騒がれたこともあるとかで、幾らか横着な性質だったから、ある日も家内に、「あのう加藤さんところの奥さんは、やきもちやきですわね。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、やきもちやきだと隣りのおかみさんが教しえて下さいました。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてはやきもちやきだつせ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通り部屋の中をグルッと見廻して、トンと突衿をすると一緒に、お君のすぐ顔の処へパフッと座ったお金は、やきもちやきな、金離れの悪い、五十女の持って居るあらゆる欠点を具えた体を、前のめりにズーッとお君の方に延しまげた。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やきもちやきめ」「チェッ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、やきもちやきのスベタのことを？",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やきもちやきつて……。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのようなやきもちやきの奥さんでなければ、どこへ飛んでいくか解らないのですよ。",
              "citation": {
                "source": "翩翩",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮島をこしらえたのは平清盛ですが、神様は女の守神で、やきもちやきで、すきなひととは行かないところの由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも女の守神のくせにやきもちやきとは何と飛んだ神様でしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぞ／＼やきもちやきの女とかけて何と解く。",
              "citation": {
                "source": "佐藤春夫詩集",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その代りあの方と口をきくのはこれ限りよ、わたくしやきもちやきですからね」五　吉岡の家は湯島聖堂裏の高台にあった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やきもちやきはコキュ以上にお気の毒である。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
