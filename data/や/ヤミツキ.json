[
  {
    "uuid": "8e6d21e8-8627-58bf-9388-5a23499b4e05",
    "entry": "病みつき",
    "reading": {
      "primary": "やみつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
