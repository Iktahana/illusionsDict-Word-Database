          "literary": [
            {
              "text": "「やれば出来るわよ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信簿に、もっとやれば出来るはずだと書いてある。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれば出来るに決っていることをやるのを研究と称することになっていた我国の習慣では、それも致し方ないことであった。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、やれば出来るに極っていることを、誰もやらないのだから不思議だ。",
              "citation": {
                "source": "九谷焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "円の面積を算出する公式も、鶴亀算の応用問題の式も、甚だ心もとなくいっそ代数でやればできるのだが、などと青息吐息の態とやや似ている。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やればできる力をもつてゐながら、なかなかやらうとしない一種の引込思案、乃至は億劫がり、右｜顧左｜眄、いづれも、「意志」の栄養不良、動脈硬化、関節不随であります。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもやればできるといふ自信をもちたい。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと三日のうちに、ご用命の物を調達いたします」　至極単純な張飛は、「それみろ、やればできるくせに。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
