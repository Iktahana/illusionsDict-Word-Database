[
  {
    "uuid": "d9c26825-626d-5563-bf3f-3f26029c06eb",
    "entry": "遣る",
    "reading": {
      "primary": "やる",
      "alternatives": [
        "ヤる"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
