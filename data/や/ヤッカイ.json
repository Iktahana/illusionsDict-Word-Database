[
  {
    "uuid": "dd11fbbc-96d4-5c9b-a7c7-95d8d1622512",
    "entry": "厄介",
    "reading": {
      "primary": "やっかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
