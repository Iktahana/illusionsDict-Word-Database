        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「やっぱし、怪我をして内地へ帰るんが一番気が利いてら。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やっぱし、あしこのところからはいろうとしたのか？",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紅毛人は、やっぱし、教会だとか慈善だとか云ってけつかって、かげじゃなか／＼大きな商売をやっているね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一円くれてやっても、やっぱし、シェシェでそこすんだりだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱし、ここにゃ、日本の軍隊がいないせいだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日、やっぱし日光丸で着いたんだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、ええ、やっぱし、（しがうまく云えなかった）郭店の方から、歩いてやって来たんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺等も、やっぱし、これぐらいな六ツか七ツの時から、仕事をしろ、仕事をしろと、親爺に叱られて育ってきたものだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし俺は、お払い箱だ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし、薬がきくんだな！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに卑屈に落ちぶれたって、やっぱしコツコツと働かなきゃならないのが工人だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし俺を好かなくなりやがったんだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし、君等は、馬賊の習慣から、ぬけきれねえんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地へ帰れば、やっぱし稼がなければ、金は取れやしないよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか、やっぱしそうだったか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし、まっさきに露助を突っからかしただけあるよ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪五円にゃ、安いとて売れるせに、やっぱし、二束三文で、買えるだけ買うといて、うまいことをやった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱし買えるだけ買うといてよかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし、人間のずるい、金の融通のきく奴が、うまいことをしくさるんだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱし、あれは本当だろうかしら？",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら少ないとてケージは、やっぱし一ツ分占領するんだぞ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、社会でうろ／＼した末、やっぱし俺等のような士鼠が食って行けるのはこの鉱山だけだ、どこをほっついたっていゝこたない、と思って帰って来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「テーモ、やっぱし何だか聞いたような名だなあ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先斗町の青楼の灯が瞬いているのを見ると、三好は、「やっぱし京都はええなア」　思わず溜息をついて、「――お前とこないして橋の上を歩いたこともあったなあ」　未練たらしく、しみじみと言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――やっぱし頼む方が無理やった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好きだ」「ほな、やっぱし……」　思わず言って、君勇はふとうなだれたが、やがてきっと顔を上げると、「坊ン坊ン、あて坊ン坊ン好きどす」「…………」　鶴雄ははっとして君勇の顔を見た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五条署では直ちに容疑者を留置して取調中だが、犯人は目下の所不明」　小田は読み終ると、「やっぱし殺された。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やっぱし、そうだったかと、小田の心は改めて重くなった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、やっぱし……」　おれの直感があたった――と咄嗟に呟きながら、小沢はあわててそのあとを追うて駈け出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄ちゃん、掏摸になりイ」「ふーん」　次郎は子供のくせに腕組みをして考えたが、やがて、「――いや、やっぱし止めとこ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
