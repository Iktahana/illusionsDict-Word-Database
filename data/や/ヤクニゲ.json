        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は負けが込み始めると、隙を見て役逃げをしようとするから油断できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、今の役逃げじゃないか？」と鋭い指摘が入り、博打の場に緊張が走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "役逃げは博徒の間では最も卑怯な行為の一つとして忌み嫌われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さあはやくにげましょう」　高一が、父秋山技師をつれてトーチカを出たとき、ちょうどそこへ、大石大尉が陸戦隊をひきつれてかけつけました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしてよ」「ふーん」「はやくにげましょうよ。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、灰かぶりは、王子のそばからすばやくにげだして、うちのうしろの庭のなかにとびこみました。",
              "citation": {
                "source": "灰かぶり",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、灰かぶりがあんまりすばやくにげてしまいましたので、とうとう、あとからついていくことができませんでした。",
              "citation": {
                "source": "灰かぶり",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくにげないと、いまにもここへやって来ますよ」　さるが、こんどはかんだかいこえでいいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
