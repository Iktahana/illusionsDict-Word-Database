        "examples": {
          "standard": [
            {
              "text": "久しぶりに再会した親友は、過労とストレスのせいか見るからに頬が痩せこけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食事も喉を通らないほどの深い悲しみによって、彼女はわずか一週間で痩せこけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "暗い牢獄の奥で、幽霊のように痩せこけた囚人が、虚ろな目で壁のシミを数えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "町じゅうもう彼女の噂でもちきりで、あのイズマイロフの若女房は、これまでずっと生まず女で、だんだん痩せこける一方だったものが、それが急に正面がせり出して来たのは、そもそもどういう訳だろうかと、しきりに評定し合うのだった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            }
          ]
        }
