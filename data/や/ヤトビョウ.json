        "examples": {
          "standard": [
            {
              "text": "野兎病は感染症であり、特に野生動物との接触には注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "野兎病の症状は多岐にわたり、早期の診断が重要とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "専門家が野兎病の予防策について講演を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小児麻痺に似ているオーストラリアＸ病はヒトがヒツジから感染したと思われ、1904年以前には知られていなかったが現在はアメリカ合衆国全土に蔓延している野兎病は多種の動物から感染している。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "野兎病と呼ばれるいわゆる「新しい」病気については別の問題がある。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランシスはこの病気を「トゥラレミア」（野兎病）と名付けた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんどすべての野兎病研究者はこの病気に罹ったことがある。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
