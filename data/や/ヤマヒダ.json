    "definitions": [
      {
        "index": 1,
        "gloss": "folds of a mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母体の山脈は、あとに退き、うすれ日に透け、またはむれ雲の間から薔薇色に山襞を刻んで展望図の背景を護っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根連山から聖ヶ嶽へかけて濃い薄い霞が山襞ごとに幾重にも引きはへて、そのところどころから野焼の煙が白く真直にのぼつてゐる西の方の展望は、閑かで匂はしくて、それももう冬のものではない。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "悉く水田地帯で、陸羽国境の山巒地方から山襞を辿って流れ出して来た荒雄川が、南方の丘陵に沿うて耕地を潤し去っている。",
              "citation": {
                "source": "荒雄川のほとり",
                "author": "――私の郷土を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處も前の上臈の庵のあとゝ同じく小さな谷間、と云つても水もなにもない極めて小さな山襞の一つに當つてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾つか折れ込んだ山襞の奧に當つてゐるので、場所の高いに似ず、殆んど眺望といふものがなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "火山をめぐる温泉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根の左右に幾つともなく切れ落ちてゐる山襞、沢、渓間の間にほのかに靄が湧いて来た。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤い山襞のあちこちに遥々都から御あとを追うて来た御側の女がやがて身重になって籠ったあとの森だとか、同じくおあとを慕われた姫宮がどうなされたとかいう様な伝説のあとを幾箇所も見てすぎた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処も小さな山襞の一つに当っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明神ヶ岳の山裾から、ヤグラ岳、金時山の頂きにかけて翼を伸した陽りが、山襞※に添つてぢくざくに光つてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の下は、直ちに上諏訪市街で、町外れから真碧な諏訪湖が、遠く上伊那境の連山まで拡がって、山襞の凹所から、天竜川の日に輝きつつ流出する遠方まで明瞭に見渡される。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の茶屋の二階からずうっと見晴すと、遠い山襞が珍しくはっきり見え、千曲川の上流に架っているコンクリートの橋が白く光っている上を自動車が走っているのまで、小さく瞰下せる。",
              "citation": {
                "source": "上林からの手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両脇から頂上の砦へのぼっている山襞は袖付の裂け目に似ていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷から、川から、山襞から、鬼気立ちのぼっている焔のことだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に映る山襞が胃の内部にまで縛りつづいて来ているように見える、ある何かの紐帯を感じる刻刻の呼吸で、山波の襞も浸蝕されつつあるように痛んで来る。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして高瀬川の峡谷を距てて、深い山襞に雪を含んでる、それら一連の山岳は、一種の霊気を帯びて、人の心に迫ってくる。",
              "citation": {
                "source": "霊気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その谷の奥、重畳たる山襞のきわまるところに上河内が白くスカイラインを画いている。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川小屋と覚しきものの屋根が、薄黒い山襞の蔭に識別された。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶臼岳や、朝日岳の山襞がはつきり見えて来た。",
              "citation": {
                "source": "山の音を聴きながら",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々迫撃砲などそこから撃ちだすといふ側背の廬山は、例の飯塚部隊長戦死の跡といふ山襞をむき出して、右手前方に伸び、その先端の金輪峰が晴れた秋空にそゝり立つてゐる。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾を引いた山襞の間に、白く光るのは谷川の水であらう。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は夕方になると山襞に添って黒くひろがる斑点を指して、幼い私に「白川狐」の物語を、麦田打つ手を休めて、語ってくれた。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父逝いて幾年、晩秋がめぐりきて、夕陽が赤城の山襞を浮き彫りにするとき、私の眼には白川狐が、餅を食べている姿が甦る。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川狐は、いまもなお赤城の山襞に、永遠の生を続けているであろう。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "天城の山襞から流れ出た澄明な水に育った大きな鮎が、客膳を飾るに接しては人の心に鮮味の動くを感ずるであろう。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その低い山が彼女の言っている山であるらしいのは、その指先きを辿りながら私にもすぐ分ったが、唯そこいらへんには斜めな日の光がくっきりと浮き立たせている山襞しか私には認められなかった。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう消えて行くわ……ああ、まだ額のところだけ残っている……」　そのとき漸っと私はその父の額らしい山襞を認めることが出来た。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷川岳と万太郎山との南面の山襞には、四季雪の消え去ることがない。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "視線の届くところに、翁の眉毛のように幾筋もの白い残雪を、山襞に輝やかした谷川岳が間近に高く聳えていた。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく、娘は唐草の風呂敷包みを一つ背負って、万太郎山の南向きの山襞に猟小屋ほどもない小さな炭焼小屋へ嫁に行った。",
              "citation": {
                "source": "猿ヶ京",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "新治村の諸山脈と吾妻郡と越後の国境にまたがる山襞には、むくむくと毛ののびた大狸が棲んでいて、猟師の財産だ。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
