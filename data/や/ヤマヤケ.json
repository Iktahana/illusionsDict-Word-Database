        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう雲は鼠色になり、向うの山には山焼けの火がまっ赤です。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　山焼けの火は、だんだん水のように流れてひろがり、雲も赤く燃えているようです。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう山焼けの火はたばこの吸殻のくらいにしか見えません。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年の二月に山焼けがあった。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保九年（五年目）と十二年（八年目）に二度の山焼けがあった。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保十六年の四月、また山焼けがあった。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
