        "gloss": "wedge marks in stone (usu. remaining from stone-splitting, now used for visual effect)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「山男だ、山男だ」みんなは叫んで、がやがやあとを追おうとしましたが、もうどこへ行ったか、影もかたちも見えませんでした。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね床にもぐつてからも、山猫のにやあとした顔や、そのめんだうだといふ裁判のけしきなどを考へて、おそくまでねむりませんでした。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水をちよろ／＼と吹上げて、しやあと落してゐる處ですがね。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ちよろ／＼さへ氣恥かしいのに、しやあと落すだけは何とかなるまいかね。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなに野次られて顔を赤くしながらも、それでもまんざらでもなさそうに、にやにやしているＫもＫだが、それを、やあやあと言って野次っている学生は、いったい、何のつもりなんだろう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へむ畜生、支那の捕虜になるやうぢやあとても日本で色の出来ねえ奴だ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあと寄って行くと、向うでも気づいて、よう、来ましたね、小倉へ……と起そうとしたその背中を見た途端、寺田は思わず眼を瞠った。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川の乳屋も知ってる人と見え、やあとあいさつして遠慮もなくあがってきた。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島灣口をふさげる、桂、野々、宮戸、寒風澤の四大島は、早やあとになりつ。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤氏は氣輕にうなづいて書類を鞄にしまひこむと、ぢやあといつて立上り、「近いうちにまた來ます。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　と、其の時、釜場へやって来た人間が、やあと声をかけた。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　もう永年のつき合いで、だが顔を見、やあというだけで気がくつろぐというのではないから、はる子は時に千鶴子の訪問から気ぜわしさだけをアフタア・イメイジとして受けた。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は驚いて手を放し、小声でじやあとで来るのを待つてるぜ、　と云うや否や再び同じ木から伝つて外に逃げたのです」「うんお前は、そこでやす子と今云つた通りの問答をしたんだね。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だつて、それじやあとでやすが誰かに林田のことを話すかも知れないじやないか。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、鏡とでも相談してみ給へ――その面でしやあしやあとよくもそんな眞似が出來たものだ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの尊敬する学校の先生たちが勿論私たちにいろんなことをおさとしになる程何処も彼処もとゝのつた人だとは信じはしませんけれどもまさかに、そんなにも度はづれな疑ひやあとかたもないうそをついて生徒をいぢめるなどとは全く思ひもよらないことでした。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷の村からは何里も離れたこの都会の他人の家でも、幾晩かそこに寝おきした今は遠慮もとれた風で勝手にあがって来て、目を醒した若い二人に気軽くやあと云いながら帯剣をはずし、うるさそうに頸や顎をのばして、軍服の襟ホックをはずした。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ま、そんなところだの」　廊下に、足音が聞えると、障子が、開いて十二、三の女の子が、三人　おばあ子、来るかやあと　鎮守の外んずれまで　出てみたば　と、叫んで、踊りながら、入ってきた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、飮みなれ、飮まんとかけまつせと、こないいひながら、野呂さんの頭からあつうい御酒をじやあとかけはりましてんと。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春暁やあとさきもなき夢の橋　　妙子　ぼうっとしてそれこそ、ばら色の靄でもかかっている様な、春暁のねむりの中に、ほっかりと七彩の夢の浮橋があとさきもなくかかっている。",
              "citation": {
                "source": "女流俳句を味読す",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一二―一一四登りをはりて壁を離れしふたりの詩人は、ふたゝびあたりを見ることに心ひかれて今ともに默し　一一五―一一七晝の四人の侍婢ははやあとに殘されて、第五の侍婢｜轅のもとにその燃ゆる尖をばたえず上げゐたり　一一八―一二〇このときわが導者。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "この連中がフロックを眺めて、やあ――やあと一ツずつ云った。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も一番あとで、やあと云った。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の這入って来るのを見ると、やあと云って手を出す。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちもあまり握り心地が好い訳でもないから、いっそ廃したらよかろうと思うのに、やっぱりやあと云って毛だらけな皺だらけな、そうして例によって消極的な手を出す。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
