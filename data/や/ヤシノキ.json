          "literary": [
            {
              "text": "青黒い蛇（こんなものは、あんまり感心しないね）それからヤシの木。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸にはバナナやヤシの木がしげつて、うつくしい実をつけてゐますし、山のはうの森のなかや野のなかには、いろんなめづらしい草があつて、薬草もたくさんまじつてゐました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤシの木陰で休んだ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに戻ってくる」　数分後、ヤシの木陰で二人だけになり、国王が尋ねた。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
