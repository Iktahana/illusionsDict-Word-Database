        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "利根の鉄橋を越えて行くに夏｜蕎麦をつくる畑｜干瓢をつくる畑などあれば埼玉や古河のあたりの夏蕎麥のなつみこめやもおほに思はゞ麥わらをしける廣畑瓜の畑葉かげに瓜のこゝたく見ゆるなど口ずさむ。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからはやもおりました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれ改めてお礼ながら、この歌の返しの有りや無しやもお知らせ申しにまいりまする。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何時ぞやもお咄したとおり、あの方はお齢も若いし、美しい御顔でもあるし私が行ったりするのは、憚からなけりゃなるまいと思っています。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やもお女中もゐない家庭なので、ふしぎに思つて、ある時、訊いてみると、新婚二年ぢかい若奧さんは、「えゝ、宅では、出かける時、ベビーにミルクをたんと飮ませておいて、家の中のハンモツクに、落ちないやうに縛つて入れておくんですの。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんやもおでかけかね？",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも急に云いだしたことで、忠左衛門夫婦にはいやもおうも云うひまがなかった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正篤には供のゆるしを得てあったのだが、間際になってその係りから云いわたされ、いやもおうもなく江戸に残されてしまった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正三君はいやもおうもない。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じぶんも立身の種になるんだから、いやもおうもありゃあしない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
