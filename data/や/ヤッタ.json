    "entry": "やった",
    "reading": {
      "primary": "やった",
      "alternatives": [
        "やったー",
        "ヤッター",
        "ヤッタ",
        "やったあ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
