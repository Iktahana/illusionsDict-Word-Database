      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蓋し斯の如き間抜野郎によつて、実感は実践的意味といふものから可なりに遠いであらう。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその結果が今「間抜野郎」となつたのである。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐売りのラッパに酔ふとしてまことに随一だが、それを呼びとめるとしていとも間抜野郎である。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は珈琲店の椅子で酒を飲み、大衆と共に「あなたと呼べば」を唄つた後で、自ら自分の髪の毛をむしりながら、自分に向つて「この大馬鹿野郎奴」と叫ぶのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして逆に、「この馬鹿野郎！",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『斯う成つちやあ一番腕ツコキだ、さあ野郎、文句は言はずと、出ろ』男は片脚はづして下駄を脱いだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この龍宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬つころの悪魔の杓子野郎が、と彼女はわめいた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪魔の杓子野郎つたら、逃がしはしないから！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "杓子野郎は振返つてみるとこの有様なので、――ここぞとばかり彼は思つて、直ちに跳んで返した。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分らねえか、此ぼけ茄子野郎！",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の親が私にして呉れたのと、私の親ほどな年輩の世間の他人野郎とは、何と云うひどい違い方だろう。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この野郎白っぱくれて、網を張ってやがるんじゃねえかな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔付きにも似合わねえ野郎だ！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、お前さん、何だぜ、俺と話しをしてるとお前さんの迷惑になるかも知れねえぜ」（此野郎。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "途方もねえ大仕掛な野郎たちだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう臭くなってるんだぜ」「馬鹿野郎！",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此野郎、行って見ろったら行って見ろ！",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのセリフ位、古くならないで、何時も鋭い実感を伴つて、亭主野郎の頭上に落ちて来るものも少ないだらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな野郎がきやがったなと思うていると、「や政夫さん。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハハハハハ」　この野郎失敬なと思ったけれど、吾々も余り威張れる身でもなし、笑いとぼけて常吉をやり過ごした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿野郎、実に厭なやつだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその翌朝、再度平常の紳士意識に歸つた時、大金をもつてるルンペンを見て、この泥坊野郎奴と罵るのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、帽子が変ッてるぞ、Ａの奴だな」「班長殿、Ａ居ませんが、あの野郎、自分の帽子を間違えて、あ、それ」「写真をもう一枚、送って貰うんだな」　煙草出す。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静、　「兄さんッたら一寸来てよ、大変なの」　「五月蝿えな」　「大変なのよ、来て御覧」　「どうしたんだ」　「今、家の表で喧嘩がはじまったの、大騒ぎよ」　「ちえッ、喧嘩なんか珍しくもねえ、喧嘩なら俺ァ毎晩やってらァ、昨夜も権六の野郎と喧嘩して向う脛蹴っとばしてやった」　「違うの、そんな喧嘩じゃないの。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしは清水港の次郎長って、けちな野郎で御座います」　湯をくむお静「昼間の男だ」と気付く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も旅から帰ったばかりで、お半にも逢えねえ中に、旅に出るなァ辛えだろうが、なーに、半年も経ちゃ、ほとぼりもさめるだろう」　その時、児分の一人、表から来て、　「親分、変な野郎が五六人、先刻から、表をウロウロしていますが、何かあるんじゃありませんか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「併し折角帰って来たんだから俺ァお半の処へ一寸寄って行きてえなァ」　「この野郎暢気な事云ってやがらァ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴の野郎、何しに来やがったんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶴の野郎何を言ってやがるんだろう」　と、そっと梯子段の処で窺う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
