  {
    "uuid": "91d1499f-cd84-51c3-9b6f-eff535bcd83c",
    "entry": "薬事",
    "reading": {
      "primary": "やくじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
