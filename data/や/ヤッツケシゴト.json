        "examples": {
          "standard": [
            {
              "text": "締め切り間際で、やっつけ仕事になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "こんなやっつけ仕事では、クライアントに満足してもらえないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はやっつけ仕事にならないよう、計画的に作業を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ベテラン編集者や印刷のプロには、現在のポストスクリプトの手並みはド素人のやっつけ仕事に見える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔の鋭尖窓は残らず割れ、その内二つはやっつけ仕事で塞がれていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいがやっつけ仕事めいた番組だが、その夜の出来はことにひどかった。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
