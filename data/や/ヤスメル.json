    "definitions": [
      {
        "index": 1,
        "gloss": "to rest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所でもし感情喪失が原因なれば、人は先づ退いて心身を休めるの必要があるのであらう点で、前二者とは趣を異にするのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言つて疲労を休める為に、休息してゐるといふわけでもない。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は自分などのやうに、うるさく騷がしい都を離れて、しばらく疲れた頭を休める爲にかういふ山中の自然を索ねて來るものゝある一方では又、東京では斷ち切れない色々の窮屈を束縛をふりちぎつて、一日だけ、はめを外づして暴れ※はる爲にわざ／＼かういふ土地を選んで來る人もあるのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十五分すれば、二人は衛兵所へ帰って休めるのだった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人も、土地を買わなければ、その屍を休める場所がない。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山や溪が※ぎ合い心を休める余裕や安らかな望みのない私の村の風景がいつか私の身についてしまっていることを私は知った。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした村のなかでは、溪間からは高く一日日の当るこの平地の眺めほど心を休めるものはなかった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る照る鈴鹿は曇る＝といい、袷遣りたや足袋添えて＝と唱える場合には、いずれも疲を休めるのである、無益なものおもいを消すのである、寧ろ苦労を紛らそうとするのである、憂を散じよう、恋を忘れよう、泣音を忍ぼうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁や野鴨の渡り鳥も、この池でその羽を休める。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「急用なら中止しましょう」と紳士は一寸手を休める。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて某は僕を從へ我家をさして歸る途すがら曩に雲飛が石を拾つた川と同流に懸つて居る橋まで來ると、僕は少し肩を休める積りで石を欄干にもたせて吻と一息、思はず手が滑つて石は水煙を立て河底に沈んで了つた。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある寒い夕方野こえ山こえようやく一つの古い町にたどり着いて、さてどこを一夜のやどりとしたものかと考えましたが思わしい所もありませんので、日はくれるししかたがないから夕日を受けて金色に光った高い王子の立像の肩先に羽を休める事にしました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きの手を休めるわけには行かないのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉蔵が其と見て、「やあ」と云って仕事の手を休めると、「やあ」と若者も同じ様に云って、吉蔵の傍へ停ち止まった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る／＼鈴鹿は曇る＝といひ、袷遣りたや足袋添へて＝と唱へる場合には、いづれも疲を休めるのである、無益なものおもひを消すのである、寧ろ苦勞を紛らさうとするのである、憂を散じよう、戀を忘れよう、泣音を忍ばうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからしばらくたつた温い日、栄蔵は勉強に疲れた頭を、海から来る新鮮な風にあてて休めるため、波打際の方へおりていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其夜の雁も立去らず、餌にかはれた飼鳥のやう、よくなつき、分けて民子に慕ひ寄つて、膳の傍に羽を休めるやうになると、はじめに生命がけ恐しく思ひしだけ、可愛さは一入なり。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "快く頷いて、北陸地方を行脚の節はいつでも杖を休める香取屋といふのがある、旧は一軒の旅店であつたが、一人女の評判なのがなくなつてからは看板を外した、けれども昔から懇意な者は断らず留て、老人夫婦が内端に世話をして呉れる、宜しくば其へ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも気を休めるが一番だよ、今夜は附いているから安心をおし。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、馬の息を休めるために、ゆっくり歩きました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "双た親は鍬を休めるたびごとには自分の方を向いて話しをする。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏でも寒いと唄われている木曽の御嶽の山中に行きくれて、彼はその疲れた足を休めるためにこの焚火の煙りを望んで尋ねて来たのであろう。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな話でもするのが、一日のうち義雄が氣を休める時間である。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "射撃の手を少し休めると、忽ち抜刀の一隊が押し寄せた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから野崎がもうあと三日休めるぞと言ったので、うかうか三日休むことにした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "診察の方は二、三時間休めるか？",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぎようによってはむれるような厭な匂いであるが、生生の気の溢れている青葉の匂いが漂うていて、読書に疲れた頭を休めるには適している晩であったが、なんだか不安で厭で、歩くと左の痃癖のあたりが張るように痛くて歩くのが苦しかった。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに、あとはきれいさっぱり、安心して休めるというものだ。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私とて同じこと、どこまで行っても真白でふわふわと、頼り無い白雲のなかに、眼も体もやすめようとする所もなく、疲れはてて仕舞った時、ひとりでに私の首が下を向き、翼をやすめるに屈竟な黒く落ち付いた土の底が、はっきり見えましたので、急いで茲まで降りて参りました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署長は汗を拭くひまもなく息をやすめるひまもなくそのきらきらする枯草をこいでそっちの方へ進んだ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
