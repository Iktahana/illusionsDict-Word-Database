        "examples": {
          "standard": [
            {
              "text": "人生は山あり谷ありだが、それが面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "起業してからの道のりは、まさに山あり谷ありだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「山あり谷あり」は、彼女がよく口にする言葉だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この後には山あり谷あり流れあり、嘘だと思つたら、次の會場へ。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後には山あり谷あり流れあり、嘘だと思ったら、次の会場へ。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山あり谷あり川あり野ある変化の上に、四季の花を満し、風月の優雅さに溺れ得られる日本の庭から、ドストエフスキイもトルストイも想像は出来ない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事場を覗くとそこにも山あり谷ありで、少しも自然の地形に逆わない。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
