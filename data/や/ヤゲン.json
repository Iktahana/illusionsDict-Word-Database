[
  {
    "uuid": "4c0c3bba-e5f6-53ff-9304-6768b02e31b1",
    "entry": "薬研",
    "reading": {
      "primary": "やげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
