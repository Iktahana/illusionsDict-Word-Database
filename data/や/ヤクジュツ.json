        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本のドイツ文学の教授も、字典を引かなければ、その名を知る能わず、むかし森鴎外が、かれの不思議の才能を愛して、その短篇、「塔の上の鶏」および「女の決闘」を訳述せり。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――読みかけていた一書は蕃書取調所に命じて訳述させた海外事情通覧である。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳述の法に就ては訳者自ら語るを好まず。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士にとつて稼ぐといふ事は倫理学を方々で講演したり訳述したりする外には何も無かつたのは飛んだ仕合せであつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若干の訳述上の難点について、友人小宮豊隆君の示教を仰いだことについて、ここに改めて感謝の意を表しておきたいと思う。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は文化主義について、さきに阿部次郎さんの訳述されたリップスの『倫理学の根本問題』から多く啓発せられたのですが、近頃は高田保馬さんと左右田喜一郎博士の論文とから更にいろいろの教を受けたことを茲に感謝します。",
              "citation": {
                "source": "婦人改造の基礎的考察",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に読んだのは佐川春水氏が「銀行盗賊」と改題して訳述した「赤髪組合」か、それでなければ訳者を失念したが、太陽か又は太陽と同型の雑誌に発表された「青い宝石」で、どっちが先だったか確かな記憶はない。",
              "citation": {
                "source": "ドイルを宗とす",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁良が光緒三年（明治十年）にウールジー(Woolsey)のインターナショナル・ローを訳述した時には、さきに用いた「万国公法」なる名称を棄てて「公法便覧」と題し、書中にも「万国公法」なる語を用いずして総べて「公法」と称している。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は明治六年にウールジーのインターナショナル・ローを訳述せられたが、これを「国際法」と題された。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "五三　国際私法　国際私法の名称は、その初め支那の同治三年即ち我が元治元年に丁※良の漢訳した「万国公法」の中に「公法私条」という名称を用いたのが始めで、その後ち慶応二年に西周助（周）先生がフヒスセリングの講義を訳述して「万国公法」と題して出版したものの中には「万国私権通法」という名称を用いてある。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "また慶応四年に開成学校から出版された津田真一郎（真道）先生訳述の「泰西国法論」中には「列国庶民私法」とある。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ち明治五年に中村敬宇先生は、ミルのリバーチーを訳述して「自由之理」と題せられたが、この書もまた広く世に行われたものである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く、初め支那において丁良が光緒三年（明治十年）にウールジー（Woolsey）のインターナショナル・ローを訳述した時には、さきに用いた「万国公法」なる名称を棄てて「公法便覧」と題し、書中にも「万国公法」なる語を用いずして総べて「公法」と称している。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "五三　国際私法　国際私法の名称は、その初め支那の同治三年即ち我が元治元年に丁スセリングの講義を訳述して「万国公法」と題して出版したものの中には「万国私権通法」という名称を用いてある。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し其は、私たちの罪でもなく、又多くの場合、訳述者の咎でもないことが、段々わかって来た。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し其は、私たちの罪でもなく、又多くの場合、訳述者の咎でもないことが、段々わかつて来た。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "因つてその大要を訳述する事左の如し。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論之は今の処翻訳術語に依る外はないからのことだが、併しその対策として「やまと言葉」を持って来ることに較べれば、この生硬な翻訳述語で考えたり書いたりした方が、まだしも俗語的で日常的で大衆的だとさえ云えよう。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳述者、福地源一郎」。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち余が｜舎密の階を訳述して同志に謀るゆえんなり。",
              "citation": {
                "source": "平仮名の説",
                "author": "清水卯三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "★明治二十四年九月、探偵小説「薔薇娘」ブラック訳述（原作不明）今村次郎速記、三友舎発行、四六判ボール芯表紙、二九二頁。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
