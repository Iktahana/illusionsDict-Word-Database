        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甲府の知り合ひの人にたのんで、下宿屋を見つけてもらつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその前は、荻窪の最下等の下宿屋の一室を借りて住んでいたのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏伊香保へ行つた人は、たいてい宿屋のことから気分を害し、順つて伊香保全体を悪く見てしまふ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が十九歳の夏休みに父に伴われて上京し麹町の宿屋に二月ばかり泊っていた時の事である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "根津辺の汚い下宿屋で極めて不規則な生活を送っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室津の宿屋の主人はかなりのお婆さんであったが、われわれ二人の中学生の初旅を珍しがって大変にもてなしてくれた上に「珍しいものを見せて上げよう」と云って持出して来たのが一巻の絵巻物であった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が日清戦争に予備役で召集されて名古屋にいたのを、冬の休みに尋ねて行ってしばらく同じ宿屋に泊っていたときのことである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその前は、荻窪の最下等の下宿屋の一室を借りて住んでゐたのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは宿屋も、ひどく、おたかく止つてゐる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の宿屋というものを、思わせる「糸屋」と看板を出した旅籠屋には、椽側に紡車を置きっ放しにして、ひっそりかんとしている、馬車はここで停まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "割烹を兼ねた宿屋で、三層の高楼は、林泉の上に聳え、御手洗川の源、湧玉池に枕しているから、下の座敷からは、一投足の労で、口をそそぎ手が洗える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく富士山麓の宿屋としては、北の精進ホテル以外において、もっとも景勝の地を占めたものであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学生の登山隊が、百人ほど、町の宿屋にいるのだそうで、チンチクリンの男の浴衣を、間に合せに着て、歩いているのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の店頭には、かがり火をたき、白木の金剛杖をたばに組んで、縄でくくり、往来に突きだしてある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの宿という心当りもなかったが、無作法なる宿引きが、電車の中の客席へ割り込んで、あまりにツベコベと、一つの宿屋を吹聴するので、宿引の来ない宿屋にゆくに限ると決め、電車の窓から投げ込まれた引札の中から選り取って、大外河を姓とする芙蓉閣なる宿屋へ、昼飯を食べに入った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が日本アルプスでも、上高地は、私が明治三十五年に、白骨温泉から梓川を渉って、霞沢岳を踰え、この峡谷に下りて、槍ヶ岳へ登ったときは、夏とはいえ、寂寥無人、太古の如き感があって、温泉の湧出はあっても、今日のような宿屋は、まだ建っていなかった。",
              "citation": {
                "source": "上高地風景保護論",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の町は、夜九時になると死んだやうになる、偶然飛び込んだ旅人を泊める宿屋までも、十時になると眠り込む。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西あたりの山のホテルを想はせるやうな帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルといふ宿屋に泊つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前日に伊香保通のＭ君に聞いたところでは宿屋はＫＫの別館が靜かでいゝだらうといふことであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋が滿員の場合には入口に「滿員」の札でも出しておいたら便利であらう。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋とお土産を賣る店の外には實に何もない町である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある宿屋の前の崖にコンクリートで道路と同平面のテラスを造り其の下の空間を物置にして居るのがあるのは思ひ付きである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、宿屋の階段の連續的足音の奇現象を觀察することの出來たのは思はぬ拾ひものであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れも矢張り宿屋へ蓄音機を持ち込み、宿屋で東京音頭を踊るタイプの、無邪氣で善良で、人に迷惑をかけるのを人情の厚い證據とするアルトルイスト日本國民のすることである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に、かうした宿屋には鐵筋コンクリートの階段と舞踊室、外へ聲の漏れぬ蓄音機演奏室などを設けたら自分等のやうな我儘者の爲にはいゝと思ふが、それでも騷ぎたい人達には張合がなくていけないかもしれない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉が利いたのか、それとも宿屋で受けた色々の「教育」が利いたのかも知れない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場へ行って清澄な温泉に全身を浸し、連日の疲れを休めていると、どやどやと一度に五、六人の若い女がはいって来て、そこに居たわれわれ男性の存在には没交渉に、その華やかな衣裳を脱いで、イヴ以来の装いのままで順次に同じ浴槽の中に入り込んで来た。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三等が満員になったので団員の一部は二等客車へどやどや雪崩れ込んだ。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の扉をはげしく叩く音――この降るのに誰がまあ、」と思いながら扉を開くと、どやどやと三人ばかり入って来たのは青年、壮年、老年を混ぜて三人の労働者達でした。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
