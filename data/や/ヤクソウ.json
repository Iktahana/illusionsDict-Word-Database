[
  {
    "uuid": "f4ade8a3-991f-5373-9c40-95091f524263",
    "entry": "薬草",
    "reading": {
      "primary": "やくそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
