      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "medicinal herb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薬草と葫とバタとこね合せたパテを作って置き、それに引き出した身をまぶし再び殻に詰め込み火鍋にかける。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬草の混ぜ合せに秘伝がある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「高野山に肺病なら必ず癒るという薬草があるのです。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は寿々さんのためにそいつを捜しに出かけたんだがね、なるほど確かにそれに違いないと思う薬草はあるにはあるんだが、容易なことじゃ採れっこないですよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は髪を振り乱しその大釜の周囲を何やら呪文をとなえながら駈けめぐり駈けめぐり、駈けめぐりながら、数々の薬草、あるいは世にめずらしい品々をその大釜の熱湯の中に投げ込むのでした。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人たちは、その銅像を見あげては、沼のほとりで、薬草をさがしていたヘンデル先生のことを、しみじみ、思い出すのでした。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人たちは、ヘンデル先生の教えてくれた薬草を、さっそくせんじて、病人にのませました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人たちはこの薬草を、ヘンデル草とよぶようになりました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、村はかなり大きくなっていて、大むかし、ヘンデル先生が薬草をさがしていたあたりまで、家ができていました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬店に聞いても、お百姓に聞いても、薬草取りに聞いても、年寄りに聞いても、読書人に聞いても、大工に聞いても、みな一様に頭を振るだけであった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、妙法蓮華経薬草諭品、第五偈の半を開いたのを左の掌に捧げていたが、右手に支いた力杖を小脇に掻上げ、「そりゃまあ、修行者は修行者だが、まだ全然素人で、どうして御布施を戴くようなものじゃない。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　名だたる北国秘密の山、さもこそと思ったけれども、「しかし一体、医王というほど、此処で薬草が採れるのに、何故世間とは隔って、行通がないのだろう。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　譬えば仙境に異霊あって、恣に人の薬草を採る事を許さずというが如く聞えたので、これが少からず心に懸った。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「少々無理な願ですがね、身内に病人があって、とても医者の薬では治らんに極ったですから、この医王山でなくって外にない、私が心当の薬草を採りに来たんだが、何、姉さんは見懸けた処、花でも摘みに上るんですか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が以前美女ヶ原で、薬草を採ったのは、もう二十年、十年が一昔、ざっと二昔も前になるです、九歳の年の夏。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔隠に逢った小児が帰った喜びのために、一旦本復をしたのだという人もありますが、私は、その娘の取ってくれた薬草の功徳だと思うです。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑草についても、どれが薬草で、どれが毒草かを、実によく心得ている。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥座敷上段の広間、京間の十畳で、本床附、畳は滑るほど新らしく、襖天井は輝くばかり、誰の筆とも知らず、薬草を銜えた神農様の画像の一軸、これを床の間の正面に掛けて、花は磯馴、あすこいらは遠州が流行りまする処で、亭主の好きな赤烏帽子、行儀を崩さず生かっている。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は烏川の上流にある室田の旧家で、その家から山の薬草を蒐めて出す取引先の高崎の薬種問屋に青年は預けられていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで七年薬草の匂いの褐くしみこんだその部屋の畳を新しく取り替えて、蚊帳をつると、あらためて寺田屋は夫婦のものだった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安い薬草などを煎じてのんで、そのにおいで畳の色がかわっているくらい――もう、わずらってから、永いことになるんだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "噫、かかるもろもろの匂のなかにありて薬草の香はひとしほに傷ましきかな、哀れ、そは三十路女の面もちのなにとなく淋しきごとく、活動写真の小屋にありて悲しき銀笛の音の消ゆるに似たり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も何時もわが歩みの目標となる軟かなるその壁の色はまだ芽にいでぬ薬草のにほひ痛き畑のあなたに暮れゆかんとす。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつぞやは死なうとも思つた、俺の好きな植物園の薬草花壇で、毒薬を喫んで、あの大蒜の根や、茴香の蕾を抓み散らして、精一杯に苦んで、藻掻いて血を吐いて、而して笑つて真蒼に腐つて了ひ度い――とも思つた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これが貴重な薬草だということが発見されるといいんですがね。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち心得たる体にて彼の唐人に誘はれ行くに、港の入口、山腹の中途に聳え立つ南蛮寺の墓地に近く、薬草の花畑を繞らしたる一軒の番小舎あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もすぐ行くから」チーフメーツはようやくそういうと、急いで帽子をとった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに茶摘みをする女の赤い襷と白い手拭いとが見え、裸で茶を製している茶師の唄が通りに聞こえた、志多見原にはいちやくそう、たかとうだいなどの花があった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本もはやくそういう風俗にしたいなんどと。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな暗いところでは――」　それでもようやくそう言いかけると、　「もちろん良くありません。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
