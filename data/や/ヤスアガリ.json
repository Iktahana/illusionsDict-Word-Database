          "literary": [
            {
              "text": "ＵＮＩＸの担う基幹的なネットワークに、パーソナルコンピューターの群れによって形成される小規模のネットワークがぶら下がる形が、しばらくの間は最もリスクの少ない、安上がりなシステム構成上の選択であり続けるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストスクリプトが日本語の組み版の伝統的ルールから目を反らせているかぎり、ＤＴＰは質の悪い印刷物を作る安上がりなシステムの域を突破できない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は『女房をもらえば働き手がひとり助かるから安上がりだ』とひとりそろばんをはじいたわけである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミン　いいえ、もっとも安上がりなやつですよ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結局、安上がりで究極の恐怖を体験したもんだ」了",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンセン病患者の大部分は貧しく家で個人的に治療したり乞食として放浪させるよりはハンセン病療養所で一緒にしておくのが安上がりであり効果が高い。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
