[
  {
    "uuid": "f506e568-9b7e-514a-9bb9-18885aff2d74",
    "entry": "や座",
    "reading": {
      "primary": "やざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Sagitta (constellation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ついでに言うが、一般に言って写生の句は、即興詩や座興歌と同じく、芸術として軽い境地のものである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝楽屋の中では　定九郎の仲蔵や座長らしい大石役者や、其他がペコペコ謝っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は慌てて又もや座敷へ引返して、先ず有合う燐寸を我袂に入れた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や座に見えた菅子の姿。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の中に、やや座を開いて控えたのは、すなわちこれ才子の御方。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや座敷に続く芝生のはずれの石垣には海の波が来て静かに音を立てていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずらずらと広間の左右に八九名の者が居並んで、正面にどっかと治右が陣取り、主水之介の姿をみるや否や座をすべって、気味のわるい程にもいんぎんに手をつきつつ迎えました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大福引きで箪笥や座蒲団をくれたり、商品券をくれたりするようなこともない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を着けてはならないと井上氏が宣告して置いたにも拘らず、俳優や座付作者たちから種々の訂正を命ぜられた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡せば、お部屋の中は大変な有様で、旦那様もかなり抵抗なさったと見え、枕や座布団や火箸なぞがところかまわず投げ出されているのでございます。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな門を中に入らなくとも、路から庭や座敷がすっかり見えて、篠竹の五、六本｜生えている下に、沈丁花の小さいのが二、三株咲いているが、そのそばには鉢植えの花ものが五つ六つだらしなく並べられてある。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　するうち綺麗に磨き立てられた台ランプが二台、狭苦しい座敷に点され、火鉢や座蒲団もきちんとならべられた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの雑誌にもそういうような論文や座談会の話が出ている。",
              "citation": {
                "source": "もう少しの親切を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは廊下や座敷で動いている人間のいろんな姿を見ることが出来た。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、職場の若い文学者たちに向って正論をとく本人は、作品をかくために、「できるだけいろんな機関の役員も止め、会合や座談会にも出ないようにしている、ときいている」「ほかならぬ宮本百合子だから、党も一種の例外として黙認しているのではないかと考えられる。",
              "citation": {
                "source": "孫悟空の雲",
                "author": "――『近代文学』十月号平野謙氏の評論について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」義雄は、薄いかけ蒲團と敷き蒲團が延べてある上に、その不足を補ふインバネスや座蒲團を載せてある床を、そのまま圓めて障子の方に押しやる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、あの男に、もしやすると、鵜飼の意識が蘇ってきたのではないかしら」　そうして、滝人の心の中で、いろいろなものが絡みはじめてくると、それまで数年間の疲労が一時に発し、もはや座にいたたまれぬような眩暈を覚えてきた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらなり先生夫は嘸御困りで御座いませう、としばらく考へて居たが、此裏町に萩野と云つて老人夫婦ぎりで暮らして居るものがある、いつぞや座敷を明けて置いても無駄だから、慥かな人があるなら借してもいゝから周旋してくれと頼んだ事がある。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらなり先生それはさぞお困りでございましょう、としばらく考えていたが、この裏町に萩野と云って老人夫婦ぎりで暮らしているものがある、いつぞや座敷を明けておいても無駄だから、たしかな人があるなら貸してもいいから周旋してくれと頼んだ事がある。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人相手の料理屋をしてる伯母さんの家で、帳場や座敷の手伝いをしていたということだが、まあそれとしておこう。",
              "citation": {
                "source": "朝やけ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが住んでいなければ、夜な夜な怪風吹き起り、日中といえども台所や座敷などにツムジ風などが起り、ネズミその他のジャングルとなるであろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵も蓙や座蒲団なぞを用意してそのあとについた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは奧方が注意以外の智慧で、ざぶ／＼と先づ掻※して、「可からう、可からう、そりやざぶりとぢや。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト玄関から、庭前かけて、わやわやざわざわ、物音、人声。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの、若旦那は、深夜台所へ忍び込み、あの、ひやざけ、……」と言いも終らず番頭、がっぱと泣き伏し、お内儀、「げえっ！",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときに、たまらず起きて、ひやざけを茶碗で二杯、いや三杯も呑むことがある。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまの上の草むらは又もやざわざわと乱れてそよいだ。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒やざこを取って喰っているのなら見たこともあるが」と。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このようなうちに住むは、もういっ刻もいやざます。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから、わちきひとりにさせたらいやざんすよ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
