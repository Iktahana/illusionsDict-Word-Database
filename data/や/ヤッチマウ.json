    "definitions": [
      {
        "index": 1,
        "gloss": "to screw up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "面倒くさかったらやっちまうんだね。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっちまうか※……」　二人は一寸息をのんだ、が……声を合せて笑い出した。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――じァ、やっちまうか……。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本人は困り出すと、何んのことだか分らずとも、エッといって、元気になって何んだってやっちまう。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ手当り次第にやっちまうのでしたからね。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えっ、彼奴にピストルを持たせて……ふんふん、ええっ、やっちまうのか。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと十日と迫ったおせいの身体には容易ならぬ冒険なんだが、産婆も医者もむろん反対なんだが、弟につれさせて仙台へやっちまう。",
              "citation": {
                "source": "死児を産む",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから朝、すっかり今日はやっちまう気でかかったが、どうもそわついてそわついて湯の中にいても、現心なし。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の得意の水練で、相手をやっちまうんだな」　と、千二をはげました。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、（そんなくらいならいっそ、てめえ、しまいにのこったじぶんのぶりのひとかけを、こどもたちにわけてやっちまうのがましだ。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっちまうかな」と、鑿を取り上げた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道伴になったお爺さんに、もう少しで蜜柑をやっちまうところでしたよ」「あらどうして」　津田は何と答えようが平気であった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなけりゃあ、もっとちゃんとアロアを見張ってもらえるよう、修道院にアロアをやっちまうぞ」　かわいそうな母親は震え上がって、彼の言うとおりにすると約束しました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまってるけど、ツイ、お互いに人間だから、やっちまう。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうしても、やっちまうハメになったら、そいでもいいじゃないか。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いことはしないでおこうと思ってもつい悪いことをやっちまう。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大納言様がいらっしゃってなよたけに何かいけないことをなさろうとしたら、そしたら、僕達はすぐに飛出して行って……やっちまうんだ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、なんといっても、とどのつまりは、娘が自分で好いた男にやっちまうな。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるでごっそりやっちまうんだからな。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もしも計画が可能で、君はただ頷けばいいだけなんだったら……なら、君はやっちまうのかい？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたしのような貧しい寡婦にとって、それをただでやっちまうなんてとても無理ですよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいでやすか、これを着順が確定する五秒前にやっちまう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
