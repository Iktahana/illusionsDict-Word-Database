        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "友人たちは私を呼ぶのに佐野次郎左衛門、もしくは佐野次郎という昔のひとの名でもってした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、私を佐野次郎なぞと呼びはじめたのは、たしかに馬場なのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、口に出して言われないような、われながらみっともない形で女のひとに逃げられたものであるから、私は少し評判になり、とうとう、佐野次郎というくだらない名前までつけられた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い質問、「知ることは幸福であるか」　　佐野次郎左衛門様馬場数馬。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、この帝大生が佐野次郎左衛門さ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎、呑まないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹、太宰、佐野次郎、馬場、ははん、この四人が、ただ黙って立ち並んだだけでも歴史的だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎にしちゃ大出来だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎さんには、死んでも言うものか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ佐野次郎が電車にはね飛ばされて死んだのを知っているか」「知っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎氏と遊びたくてせっせとこれだけこしらえたのだが」「僕におくれ」「いいとも」「菊ちゃん。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎は死んだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで綺麗な着物と帯とを買えば、きっと佐野次郎のことを忘れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製作の経験も何もない野次馬たちが、どうもあの作家には飛躍が無い、十年一日の如しだね、なんて生意気な事を言っていますが、その十年一日が、どれだけの修業に依って持ち堪えられているものかまるでご存じがないのです。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかが席の一隅から野次を飛ばした。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やアい、パパだつて下手だわ」　途端に、夏繪は手を叩きながら、復讐的に野次り立てた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はこゝらで一つ野次ってやらうと思ひました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左団次の佐野次郎左衛門、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して、その電話のおかげで、主人や女給はひどく申訳のないような顔をしてひたあやまりに、井深君と水兵服の少女とにあやまるし、入口に立っていた野次馬もこそこそとそれぞれ散らばってしまった。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人たちは私を呼ぶのに佐野次郎左衞門、もしくは佐野次郎といふ昔のひとの名でもつてした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、口に出して言はれないやうな、われながらみつともない形で女のひとに逃げられたものであるから、私は少し評判になり、たうとう、佐野次郎といふくだらない名前までつけられた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」佐野次郎左衞門樣、馬場數馬。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、この帝大生が佐野次郎左衞門さ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹、太宰、佐野次郎、馬場、ははん、この四人が、ただ默つて立ち並んだだけでも歴史的だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎にしちや大出來だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎さんには、死んでも言ふものか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は大学の講師をして月給三十五円とおやじからの仕送りで家庭をもっていたのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利の田舎おやじらしい、塔の欄干から外へ墜ちかけた。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは甲蟲のように※く。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじの妻は驚いて卒倒しかけている。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
