    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese yam (Dioscorea japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後に小田原の町を放れ、函嶺の湯本近に一軒、茶店の娘、窶れ姿のいと美しきが、路傍の筧、前なる山凡そ三四百間遠き處に千歳久しき靈水を引いたりといふ、清らかなる樋の口に冷たき其の土を洗ふを見て、山の芋は鰻になる、此の牛蒡恁くて石清水に身を灌がば、あはれ白魚に化しやせんと、そゞろ胸に手を置きしが。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の芋が鰻になったりする「事実」も同様である。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――老人田舎もののしょうがには、山の芋を穿って鰻とする法を飲込んでいるて。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の芋と自然生を、分けて別々に稱ふ。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――麻袋には昼飯の握つた奴、余るほど詰めて置く、ちやうど僥幸、山の芋を穿つて横噛りでも一日二日は凌げるだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子を生め、子を生め、山の芋。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ難有いのは山の芋と漬物とであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の芋をも提げて来た。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雲哲　山の芋が鰻になつても、山猿がうなぎになつたと云ふ話は聞かないな。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山には、山の芋どころか、のびるだって、余計は残っておらんぜ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "到来物の粕漬を送つたり、掘立の山の芋を寄こしたりして、その度に一寸絵の事をも書き添へておくが、画家などいふものは忘れつぽいものと見えて、粕漬や山の芋を食べる時には、つい思ひ出しもするが、箸を下に置いてしまふと、今の好物も誰が送つて来たものか、すつかり忘れてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の口添は粕漬や山の芋と違つて、画家の忘れ物を直ぐ思ひ出させる効果がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにはアケビの蔓があって、どこには山の芋が埋まっている。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋粥とは山の芋を中に切込んで、それを甘葛の汁で煮た、粥の事を云ふのである。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿の御意遊ばさるるには、明朝、卯時までに、切口三寸、長さ五尺の山の芋を、老若各、一筋づつ、持つて参る様にとある。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――山の芋と云ふからには、勿論芋粥にする気で、持つて来させるのに相違ない。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、眼がさめると、直に、昨夜の山の芋の一件が、気になるので、五位は、何よりも先に部屋の蔀をあげて見た。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとそれが、悉く、切口三寸、長さ五尺の途方もなく大きい、山の芋であつた。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位は、今更のやうに、この巨大な山の芋が、この巨大な五斛納釜の中で、芋粥になる事を考へた。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位はさつき、あの軒まで積上げた山の芋を、何十人かの若い男が、薄刃を器用に動かしながら、片端から削るやうに、勢よく切るのを見た。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、その山の芋が、一つも長筵の上に見えなくなつた時に、芋のにほひと、甘葛のにほひとを含んだ、幾道かの湯気の柱が、蓬々然として、釜の中から、晴れた朝の空へ、舞上つて行くのを見た。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻が山の芋になるといふことは伝説ばかりではない。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――坊主々々山の芋、坊主々々山の芋！",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女の作業が長い山の芋をムリにも引きぬくような無法な荒々しさになり、とうてい詩情のまじる余地がないと見てとって手を離した。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついには彼女自身の手を土の中の山の芋のようにゾンザイに扱って、無法に荒々しくひッこぬこうと努力したのである。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が旅をした範囲で山の芋をこんなに豊かな風情をそえて食べさせてくれた店はほかにない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "Yam（ヤム）【名】やまのいも、とろろいも。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "題は「やまのいもハ薯蕷デモ山薬デモナイ」であって詳しく、その事由を図入りで説明しておいた（『牧野植物学全集』第六巻に転載）。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昭和二年（1927）十二月三十一日発行の『植物研究雑誌』第四巻第六号での「やまのいもハ薯蕷デモ山薬デモナイ」であった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
