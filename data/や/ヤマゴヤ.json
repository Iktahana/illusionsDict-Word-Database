[
  {
    "uuid": "d649f801-beb7-579a-a011-09f9e36e9174",
    "entry": "山小屋",
    "reading": {
      "primary": "やまごや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
