    "definitions": [
      {
        "index": 1,
        "gloss": "by virtue of one's office",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神田七段の昇段問題で日本將棋聯盟に紛擾起り、分裂の危機に頻すとの事、お役目柄倉島君忽卒として暇を告げて行く。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようなれば吾々も役目柄、その通りに大公儀へ申上げねばならぬが……サア、サア、サアとか何とか難癖をつけて催促をしおるらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは役目柄ズッと入るけに、アンタはすこし遅れて、いつもの通りの物貰いの風で、人にわからん様、入んなさいや」「おっとアラマシ承知の助。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "非人同然の人間から遠廻しに役目柄を皮肉ったような事を言われながら、それでも道理には相違ないので文句が言えなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは在るどころでは御座いませんが」「申して見い……」「それが私の口からは申上げ兼ねまする名前で御座いまして……」「余が役目柄を以て相尋ねる事じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにお先まっくらなぞと嘲弄されては役目柄が相立たぬわ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目柄がよう出来た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間外れたお役目柄が天道様の下で通用するかえ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大風呂敷が何を包んだものか、何処の穴から出て来たものかがわからぬうちは、お気の毒ながらお役目柄がお先まっくらじゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、蔵元屋の行末に見限りを付けたお艶婆と申合わせて、お金奉行の御威光で、蔵元屋の残り金を欲しいだけ奪り上げて、役目柄案内知った長崎あたりから、日本国の外へでも出る了簡で御座いましっろうか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "役目柄、多鶴子はあちこちのテーブルへ挨拶に出むかなければならなかったが、その都度豹一に、「ちょっと待っててね」と、言った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐古は役目柄辛抱強く待った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "教誨師も一向気の乗らぬ調子で役目柄だけのお茶をにごす。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分もお役目柄でもう何もかも御承知でございましょうが、和泉屋の伜も飛んだことになりまして……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷たさといふものは、彼等の役目柄から來るおのづからなものであり、また仕事に慣れ切つてゐるといふところから來るものであり、鑑定に對する高ぶりとも云へるほどの強い自信から來てゐるものでもあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目柄、御奉行様は半※でも対座なさりますれば必ず相手の人物をお見抜き遊ばす方でございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁辺なら尚更厳しゅう取計らわねばならぬ役目柄じゃが」「赤面の至り……では何か公辺の仔細でも……」「……それじゃ……それそれ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまずこれを新総長にお眼にかけようと思って、斎藤先生に紹介してもらいに行ったら、それはこっちから紹介してもいいが、役目柄、学部長の若林君の手を経て提出した方がよかろうと云われたから、こっちへ担ぎ込んで来た訳だ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は、役目柄そんなこと位を知らんでどうするのじゃ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅田堤で進物駕籠を襲い、織江を奪い取ったもの、松平冬次郎に相違なく、その冬次郎の隠れ家は、下谷の裏町だということを、田沼主殿頭に知らせたのは、役目柄そういう方面のことには、精通している十二神貝十郎で、そう知らされると主殿頭は、即刻冬次郎の隠れ家を襲い、織江を奪って来るようにと、九十郎に命を下した。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "召次の役目柄、男で葵ノ壺へ入れるのはこの男だけだったが、公子はさしあたって善世を手なずけるところからはじめた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "といい条、発見けた以上は役目柄叱らない訳にもいかず、そんなことをしていては日もまた足らずなので、そこで歴代の大目附が、経験と必要に即して案出したのがこの咳払いである。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "資成は、役目柄、どうもはっきりした態度をとれないらしい法皇の立場に、逸早く気づいたから、これで用事は済んだとばかり、さっさと清盛の所に帰ってくると、「何か、ひどく慌てふためいている様子で、ろくすっぽ返事をくれません」と報告した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "役目柄、こんな事が世間に知れてはまずいが、何とかなるものなら、一と骨折ってはくれまいか」　と言うと、「よく判りました、奥様。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一人女房のお定は、一番疑われる地位にいるわけですが、昨日から半病人の姿で、万七や平次が役目柄で逢っても、ろくに口もきかず、そっぽを向いて泣いてばかりおります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "役目柄、こんな事が世間に知れてはまづいが、何とかなるものなら、一と骨折つてはくれまいか」　と言ふと、「よく判りました、奧樣。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈な鬪爭心が、武者顫ひになつて八五郎の五體を走ると、役目柄の勇氣が、勃然として振ひ起ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈な闘争心が、武者顫いになって八五郎の五体を走ると、役目柄の勇気が、勃然として奮い起ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その床の上へそつとおろして、さて役目柄の八五郎が改めて見ると、寢卷は双肌を押し脱いだまゝ、髮は少し亂れて、顏にはたいした苦惱の色もなく、生前の活々した美しさはないにしても、決して醜い姿ではありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
