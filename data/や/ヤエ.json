        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八重桜多き由なれど花なければ吾には見分け難し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日御帰りで御ざいますそうな」と御八重が来る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその碑石が八重葎に埋もれた頃に、時分はよしと次の津浪がそろそろ準備されるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃絵が面白くなった末から二番目の八重子は水彩絵具と筆とを買って規定の金額は一度に使ってしまった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が読書している隣りの室で、八重子と宗二とがひそひそ話し合っては、宗二が何か半紙へ書いていると思ったら、それは八重子作の御伽噺を兄が筆記しているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重子の日記にはおやつやおかずの事がだいぶ詳しくかいてあった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと八重子と冬子が今年も銀座へ連れて行ってくれと云い出した。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは三月の末の晴れた日で、小幡の屋敷の八重櫻にも青い葉がもう目立つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八「孫七」の娘のお八重が、見知らぬ男と睦まじげに笑いかわしながら、自動車からおりて来た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重の雲遠くたゝへて、　　　西東はてをしらねば、白堊紀の古きわだつみ、　　　なほこゝにありわぶごとし。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は水に影を重ねたが、八重撫子の風情はない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御濠は西の方滝の口に至り、南の方呉服橋八重洲橋鍛冶橋数寄屋橋に至るまで船を通ずべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとへざきなるも好く、八重ざきなるも好く、やぐらざきなるも好し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁はひとへなれど、おもひきつて大きく咲きたる、なか／＼に八重なる花の大なるより眼ざまし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重ざきの黄なる殊に美し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏　あんずと漢めきたる名を呼ばるゝからもゝの花は、八重なる、一重なる、ともに好し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに八重の淡紅に咲けるが、晴れたる日、砂立つるほどの風の急に吹き出でたるに、雨霰と夕陽さす中を散りたるなど、あはれ深し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰ったら女中の八重が室の掃除をしていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日となって行って見ると、そのわれわれの座席の前に補助椅子の観客がいっぱい並んで、その中には平気で帽子をかぶって見物している四十格好の無分別男がいたりしたので、自分の席からは舞台の右半がたいてい見えず、肝心の水谷八重子の月の顔ばせもしばしばその前方の心なき帽子の雲に掩蔽されるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウンラートが気が狂ったのを見て八重子のポーラが妙な述懐のようなことを述べるせりふがあるが、あれはいかにも、ああした売女の役をふられた八重子自身が贔屓の観客へ対しての弁明のように響いて、あの芝居にそぐわないような気がした。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重子はここで黙って百パーセントの売女としてのポーラになりきることによってこの悲劇を完成すべきではないかという気がしたのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の「女一代」では八重子が娘になり三十女になり四十女になって見せる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青丹よし寧楽の都は咲く花の　　にほふがごとくいま盛りなり奈良七重七堂伽藍八重ざくら　前の和歌は当時を詠んだ古歌であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の茶屋あとの空地を見ると、人の丈よりも高く八重葎して、末の白露、清水の流れに、螢は、網の目に眞蒼な浪を浴びせて、はら／＼と崖の樹の下の、漆の如き蔭を飛ぶのであつた。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に「年波」、「八重の潮路」、「渡守」、「心なるらん」などの歌詞はきれぎれに打誦ぜられき。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其の宿の名は、八重垣姫と、隨筆の名で、餘所ながら、未見の知己。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩、琉球、朝鮮、吉野、花の名の八重百合というのもある。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちの頭巾やえり卷には氷がまっ白な毛のやうになって結晶してゐて、ちょっと見ると山羊の毛でも飾りつけてあるやうでした。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう今日きりやめさせて了えやえい」と彼女は同じことを繰り返した。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「また、何ぞ笑われたやえいんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
