    "definitions": [
      {
        "index": 1,
        "gloss": "expresses reverence towards the listener",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
