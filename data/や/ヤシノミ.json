        "examples": {
          "standard": [
            {
              "text": "浜辺に流れ着いたヤシの実を拾い上げ、どこから来たのかと思いを馳せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冷たく冷やしたヤシの実のジュースは、喉の渇きを潤すのに最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熟して地面に落ちたヤシの実を割ると、中から真っ白な果肉が現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おいしいヤシの実だの、パイナプルだの、バナナだの、赤と紫の大きな花だの、香気のいい草だの、又は、大きい、小さい鳥の卵だのが、一年中、どこかにありました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸してヤシの実のくさい水をのんで、ようようのどのかわきをとめて生きていた。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその前にヤシの実を十個ばかり拾って、艇内にはこんでおく必要がある。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから近くのヤシの林へはいって、なるべく色の青いヤシの実を拾いあつめた。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五個のヤシの実は、やっと両手に抱えて持ちはこびができる。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼくの腕からヤシの実がころがり落ちた。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころころとヤシの実がころがるのが見える。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、大洋漁業の標本室にはマッコーの腹から出たヤシの実があったが、戦争中、海兵の靴が片方だけ、腹から出たこともあったという。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
