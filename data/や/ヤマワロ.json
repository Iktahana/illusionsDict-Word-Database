    "definitions": [
      {
        "index": 1,
        "gloss": "one-eyed mountain spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
