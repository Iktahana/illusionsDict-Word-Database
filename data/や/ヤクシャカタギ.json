        "examples": {
          "standard": [
            {
              "text": "彼はプライベートでも常に人目を意識しており、根っからの役者気質だと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "稽古場で演出家と激しく議論する姿に、彼の頑固な役者気質を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "損得勘定抜きで芝居に打ち込むのは、彼の役者気質ゆえだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "徳三郎の璃寛は、先輩として、門地も、容貌も、優なるものであつたが、あまり無邪気な役者気質や、後立てが手をひいたり、又無力だつたりした為に、魁車の為には、目の上の瘤ともならず消えてしまつた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
