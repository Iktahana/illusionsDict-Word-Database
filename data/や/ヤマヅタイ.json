  {
    "uuid": "32a712ba-f763-5ba6-bb90-2e844d8adb81",
    "entry": "山伝い",
    "reading": {
      "primary": "やまづたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
