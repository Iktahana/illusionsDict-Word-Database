      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cheap kind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに引きかえてＹ君は、第三十騎兵連隊勤務の一等安手の下士官の身分に過ぎないのだから、この恋に到底望みのなさそうなことを杞虞する程の己惚れさえも持ち合わせない。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は行きがけに、安手な京焼の赤湯呑を引攫うと、ごぼごぼと、仰向くまで更めて嗽をしたが、俥で来たのなどは見た事もない、大事なお花客である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅にある安手な机と書棚、新子の荷物が部屋の真中に薄情そうに雑然と置かれてあるのを見ると、ものかなしくなって、そのまま暇を告げて、東京へ帰りたい気持がした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、とにかく洋館などは、過去の大地震に煉瓦一枚落ちなかったほどに、堂々として、内部の装飾も家具もこの頃の文化住宅の薄っぺらな、吹けば飛ぶような安手なものとは違って、荘重典雅を極めている。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、私の考えと、政吉の考えとは、どうも一致いたしませんで、政吉はまず差し当りの儲けを見て行くという意見で、たとえば私が下職の方の塗師の上手の方へやろうというのでも、政吉は安手の方の塗師重で済まして、手間を省こうという遣り口。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "身を引いた時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、いかさまがさつ屋らしく、そこらあたりの小格子遊女ででもあるのか、すこぶる安手の女で、あまつさえもう大年増です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "命の惜しい侍や、ブルブル顫えている泥棒や、どうにも仕方の無い安手ゴロや、そんなものばかり現れて来る。",
              "citation": {
                "source": "大衆物寸観",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切角の甲賀氏の作がその洗練されていないユーモアのために安手に感じられるということは如何にも残念です。",
              "citation": {
                "source": "マイクロフォン",
                "author": "「新青年」一九二六年一一月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしては安手だなあ、どっちみち後をつけてみよう、猿のいるというその屋敷に、君尾という娘がいるかもしれない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは、東洋趣味を軽蔑する風潮が、ようやく日本に旺になって来たようだが、東西両様の一致に進む理想も、セルの著物のように安手な物とならねばよいと思う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "春葉氏の説によると、結婚後一二年で直ぐ出来るやうな、極安手な早上りは別として、少し遅い子供は七年目とか十三年目とかちやんと年期を追うて出来るものなのださうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と甚く感心してゐたが「真理」といふものは、独逸製以外に、京都でもちよい／＼安手なのが出来るものと見える。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森氏は小学教員のやうな安手な勿体振をつけて、「三千七百万円になります。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに最も好都合な事件を、矢庭に何らの理由も必然性もなくくっつけ、変化と色彩とで読者を釣り歩いて行く感傷を用いるのであるが、しかし、何といっても、ここには自己身辺の経験事実をのみ書きつらねることはなく、いかに安手であろうと、創造がある。",
              "citation": {
                "source": "純粋小説論",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "広さの割合に窓が少なく、室の周囲は鉛の壁になっていて、床の混凝土の上には、昨夜の集会だけに使ったものと見え、安手の絨毯が敷かれてあった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、法水に固唾を呑ませたものは、この装置ではなく、安手の襟飾を継ぎ合せて貼ってある、台の底だった。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが僕は、君の云うような、安手な満足はせんよ。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷霧に蝕む北方の屋根に校倉風の憂愁を焚きあげて、屠られた身の影ともない安手の虚妄をみてとつたいま、なんと恐ろしいものだけだらうか。",
              "citation": {
                "source": "逸見猶吉詩集",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御座なりな文句ほど、その人間を安手に見せるものはないのである。",
              "citation": {
                "source": "言葉の魅力［第一稿］",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、日本人の如く、軽々しく他人の立場を計量し思惑を働かせて、同情し、寛大となり、諦らめ、いい加減のところでヒラリと利他的な安手な悟りへ身を飜すべき不誠実さは許さるべきでありますまい。",
              "citation": {
                "source": "無題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、この安手な観念が先づ第一に彼を責めつける一矢を放つことになりました。",
              "citation": {
                "source": "淫者山へ乗りこむ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、寧ろ、これらの作品を以て、蒼ざめた日本新劇に、多少の活気を与へる、安手ながら一時の清涼剤だと心得てゐる。",
              "citation": {
                "source": "再びテアトル・コメディイについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、その「安手」なところを、あまり「安手」に扱はうとしたところが、この劇団のいはば不心得である。",
              "citation": {
                "source": "再びテアトル・コメディイについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、文学的には安手でも、舞台的には、この二作、それぞれ「由緒の深い」技巧上の伝統をもつてをり、生なかの俳優では演りこなせない仕組がかくされてゐるからだ。",
              "citation": {
                "source": "再びテアトル・コメディイについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新開地の興味は、粗製濫造の模擬都市であるところから発するのであつて、その安手なといふ印象は、特に金をかけないからではなく、都市建設の文化的能力を欠いだ手合によつて次ぎ次ぎに偽物が積み重ねられて行くからである。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外の安手な木造洋館で、舞台は白ペンキ塗のバルコニイを前にした、八畳の応接間兼食堂。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時代」をつけた蝋燭立もいゝが、しかしこの安手な感じはどこから来るのでせう。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼は自分の安手な感傷に腹立つ気にもならないほど、張合ひのない落胆のなかへ落ちこむのだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたはること、またいたはられることによつて医しがたい世界であり、同時に、そのいたはりを拒むことによつて孤独の相や厳しさを高めうるほど安手なものではないのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが思惟するものは何ぞやすでに人生の虚妄に疲れて今も尚家畜の如くに飢ゑたるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
