[
  {
    "uuid": "041f7f7d-aa99-574d-bb55-8c44ee50c60f",
    "entry": "安手",
    "reading": {
      "primary": "やすで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
