[
  {
    "uuid": "842ff3cf-b199-583e-afbd-abe9ba935c1b",
    "entry": "流鏑馬",
    "reading": {
      "primary": "やぶさめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
