        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山の緑が深まる頃、遠くから山杜鵑の鳴き声が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏のはじまりを告げる山杜鵑の声は、里山に風情を添える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、山杜鵑の鳴き真似をして遊んだ記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "和佐保町の噂　山杜鵑若葉に啼く晴々しい五月の頃となった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "Tricyrtis macropoda (species of toad lily)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
