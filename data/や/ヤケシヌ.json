    "definitions": [
      {
        "index": 1,
        "gloss": "to be burnt to death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大火が起れば旋風を誘致して焔の海となるべきはずの広場に集まっていれば焼け死ぬのも当然であった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "助けて下され焼け死ぬる、蜻蛉は藺草に縋りつく。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はもうこれなり焼け死ぬものと見きわめをつけやっと帯や小帯をつないで子どもをしばりつけて川の上へたぐり下し、下を船がとおりかかったらその中へ落すつもりでまっているうちに、つい火気で目がくらんで子どもをはなしてしまい、じぶんも間もなく橋と一しょに落ちこんで流れていったのだと話していました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったら――そこはすでに、両面に火の手をひかえており、後は海なので――何万人というひなん者は、まったく被服しょうのざん死者と同じように、ことごとく焼け死ぬか海へおちてでき死するかして、一人もたすからなかったはずです。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、とう／＼これなり焼け死ぬのか。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、咽喉がかわいた、水を一ぱい持って来い」「だめです、そんな暢気なことを云ってちゃ、焼け死にます、早く起きてください」「酒を飲んで焼け死ぬる奴があるか、水を持って来い」　火はもうその時｜華表に燃え移っていた。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大火が起これば旋風を誘致して炎の海となるべきはずの広場に集まっていれば焼け死ぬのも当然であった。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまで落ちたら焼け死ぬ外はありません。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごしていると焼け死ぬぞ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえ見せつけられたら、兄は焼け死ぬでのう。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け死ぬッ」　女は目を吊りあげ猛然と身を起した。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子といつたところで、とても達きやうがないし、皆はあれあれといふばかりで、じつと火の行方を見つめてゐました……」「恐ろしいことだ、人の焼け死ぬるのを目の前に見るなんて……」頭の禿げた銀行家らしい男は、唸るやうに言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論小使部屋だ、マツチ箱の様な中に持つて来て、角火鉢、大薬鑵、炭取、箒、寝台、布団、机、鈴、乃至茶碗、土瓶、飯箱、鉄串に至るまで、まるで足の踏み処も無い始末、もし火事が始まつた時には、小使はキツト焼け死ぬるに異ひないと思つた。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっきり赤ン坊は焼け死ぬものと誰もが思ったが、小さい布団のまま引摺り出されて眠っていたという子は、支那人の人浚いの難からも逃れたのだった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこでもう今度は焼け死ぬに違ひないと、覚悟をきめた時でした。",
              "citation": {
                "source": "老いたる素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪路の情緒は、唆り立てられ、煽り立てられ、沸き立たせられる――彼女の全身は、いかなる炎よりも熱く燃えて、殆んど焼け死ぬかと思われるばかりだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、芝が火事だそうだ」「江戸中みんな焼けるがいい」「そうして浮世の人間どもが、一人残らず焼け死ぬがいい」「そうして俺ら窩人ばかりが、この浮世に生き残るといい」　夜の闇が四辺を領していた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "する内に火は※々と燃え移り、又作の宅は一杯の火に成りましたが、此の時隣りの明店にいた清次は大いに驚き、まご／＼しては焼け死ぬから、兎も角も眼の悪い重二郎のお母に怪我があってはならんと、明店を飛出す、是から大騒動のお話に相成ります。",
              "citation": {
                "source": "西洋人情話英国孝子ジョージスミス之伝",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手を火の手でふさがれて、もうこんどは焼け死ぬかと思ったことが四度もあったんですがねえ」「みんな源ちゃんのお手柄だよ。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れで足がすくみ、倒れて焼け死ぬか。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうっておくとあいつは焼け死ぬばかりだ」　　　　　４　偵察機と怪塔ロケットをつなぐ一本の麻綱にぶらさがり、怪塔へじりじり近づいていく勇敢な青江三空曹の服が、ぷすぷす燃えだしたのを見て、機上の小浜兵曹長ははっと胸をつかれたようにおもいました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ青江三空曹も、いさましく怪塔に進撃の途中で、火だるまになって焼け死ぬかとおもわれたその時――「おい青江、がんばれ」　とつぜん、青江の耳になつかしい声がきこえました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、大丈夫だよ」「いいえ、大丈夫ではないわ」「ねえ兄ちゃん、あたしたちは火事で焼け死ぬか、潜水艦のために殺されるか、どっちかなんだわ。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそ焼け死ぬだろうと思った。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後までここに踏みとどまって焼け死ぬか、それとも一刻を争うて突破を試むるか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アハハハハ、火水の苦しみとはこれだ、水の中へ投げ込まれて往生のしきれぬ奴が、火の中で焼け死ぬのだ、お喋り坊主、これでも出て来ないか」　パチパチと火の燃える音が聞えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが燃える時分には、土蔵の中は煙でいっぱいになって、火で焼け死ぬ前に、人は煙のために窒息してしまわねばならないことは明らかです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、おまえたちのおつきあいで焼け死ぬのはごめんだぜ。",
              "citation": {
                "source": "こわいことを知りたくて旅にでかけた男の話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイパンにいるとき、カナカ人の豚小屋が火事になったことがあったが、豚が焼け死ぬときだって、あんなひどい騒ぎはしない。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
