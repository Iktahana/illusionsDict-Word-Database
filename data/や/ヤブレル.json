    "definitions": [
      {
        "index": 1,
        "gloss": "to get torn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神よ、しかしそれがよく編みなされてゐればゐる程、破れる時には却て速かに乱離することを知つてをります。",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような律動のある相が人間肉体の生理的危機であって不安定な平衡が些細な機縁のために破れるやいなや、加速的に壊滅の深淵に失墜するという機会に富んでいるのではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "和喰　「ワシ」波浪「ケプ」破れる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん熔かした水晶製の器物は耐火力が強く、また熱のために破れる憂いがない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日が來ると魂は顫へ、われわれを呼ぶ、そしてわれわれがそれを認めると直ぐに、咒縛は破れるのだ。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝にでも落ると石崖の角で腹が破れるだろう。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶩は、ぶさいくな水かきのある脚を、破れるばかりにかわして、ひょくひょくした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の心臟が破れる音。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　八　台所と、この上框とを隔ての板戸に、地方の習慣で、蘆の簾の掛ったのが、破れる、断れる、その上、手の届かぬ何年かの煤がたまって、相馬内裏の古御所めく。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今蔵々々と母は逃げながら自分を呼ぶ、自分は飛び込んで母を助けようとすると、一人の兵が自分を捉えて動かさない……アッと思うとこの空想が破れる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人同志間でも、お互いに助け合って行こうと言い交わしますけれど、その意志や感情は実生活上のいろいろの事情のために妨げられて、どんなに変化するとも知れませんから、二人の結束もいつ破れるか判りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は血の気で頭の皮膚が破れるかと思うばかり昂奮して、黙って座を立って行って、土蔵の中の机の前に腰かけた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "褪せる事なき無飾の花冠を頭に戴き、破れる事なき無縫の晴着を身につけて、私はいつまでもあなたさまの花嫁で居られるので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは破れるほどな寒い晩に、ぱつといきれが立つに限る。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」陳氏は笑いころげ哄笑歓呼拍手は祭場も破れるばかりでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「雲井文彦君万歳※」と一時に破れるばかりの拍手と万歳の声が起って、いずれも帽を投げ、手布を振ってその首途を祝した。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市中は破れるばかり風説をしましょう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって、そのままにしておけば、それなりに転げ落ちて、そこから大地が破れるだろうと、愚にもつきませんが気が寄って取越苦労、昇天する蛇玉でも祭籠めたように、寝る間も気扱いをしましたそうで。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の小間はびり／＼と皆破れる。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けたたましい百舌鳥の声にふっと四方の平静が破れる。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "占いは、大変好い話で、当人は十分その気になっているけれど、この縁談には邪魔が入り、破れるというのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬶が破れるやうに怒鳴つてるので、亭主もかなしい思ひを感じてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は血の気で頭の皮膚が破れるかと思ふばかり昂奮して、黙つて座を立つて行つて、土蔵の中の机の前に腰かけた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、臨終のお父さんを喉が破れるほど呼びつづけて、それでも、お父さんは、死んじゃったんです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、誰か私に向つて、さあさ、このごはんは白米です、おなかが破れるほど食べて下さい、東京はひどいつて話ぢやありませんか、としんからの好意を以て言つてくれても、私は軽く一ぱいだけ食べて、さうしてかう言はうと思つてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は津軽のあちこちの知合ひの家を訪れたが、一人として私に、白いごはんですよ、腹の破れるほど食ひ溜めなさいなどと言つてくれた人は無かつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と耳もやぶれるばかりの音がやって来ました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この日、退院の約束、断腸のことどもあり、自動車の音、三十も、四十も、はては、飛行機の爆音、牛車、自転車のきしりにさえ胸やぶれる思い。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういわれて、人魚のひいさまは、王子の手にくちびるをあてましたが、心臓はいまにもやぶれるかとおもいました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれを十一羽のはくちょうに投げかければ、それで魔法はやぶれるのだよ。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
