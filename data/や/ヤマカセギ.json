    "definitions": [
      {
        "index": 1,
        "gloss": "making a living in the mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
