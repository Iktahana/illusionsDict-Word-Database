    "definitions": [
      {
        "index": 1,
        "gloss": "rural female shaman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "熊野田楽のふりと、熊野巫覡の霊感とが、聖階級の念仏衆の信仰・行儀に結びついたのだ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野巫女や熊野の琵琶弾きは、何時までも、信者の多い東国・奥州へ出かけて、念仏式な「物語」を語つた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ金性の肉のおとろへ、みやま瀧ながれ、青らみいよいよおとろふ、いのれば銀の血となり、肉やぶれ谷間をはしる。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああくらき緑をやぶり、天上よりきたるの光、いま秋ふかみ、あふげば、一脈の金は空にあり。",
              "citation": {
                "source": "鑛夫の歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああすべて惱ましき光の中に桃の笑みてふくらむ情慾の一時にやぶれてどくどくと流れ出でたり。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十米レエスならば、まず今世紀、かれの記録を破るものはあるまい、とファン囁き、選手自身もひそかにそれを許していた、かの俊敏はやぶさの如き太宰治とやらいう若い作家の、これが再生の姿であろうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の雨の夜　冬の黒い夜をこめてどしやぶりの雨が降つてゐた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夕明下に投げいだされた、萎れ大根の陰惨さ、あれはまだしも結構だつた――今や黒い冬の夜をこめどしやぶりの雨が降つてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨の中を漂ひながらいつだか消えてなくなつた、あの乳白の※嚢たち……今や黒い冬の夜をこめどしやぶりの雨が降つてゐて、わが母上の帯締めも雨水に流れ、潰れてしまひ、人の情けのかずかずも竟に蜜柑の色のみだつた？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし黒人になれば多分唯一面のちやぶ臺、一握の卓布の面の上にでも矢張りこれだけの色彩の錯綜が認められるのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、こうなったら、やぶれかぶれ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっくらな草や、いろいろな形に見えるやぶのしげみの間を、その小さなみちが、一すじ白く星あかりに照らしだされてあったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの大事なタダシはいまどんな歌をうたってゐるだらう、雪の降る朝にみんなと手をつないでぐるぐるにはとこのやぶをまはってあそんでゐるだらうかと考へたりほんたうに待って心配してゐらっしゃるんですから、早く行っておっかさんにお目にかゝりませうね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵がやぶれた、野蛮な人間の指が、むざんにも繊細なものを押しつぶしたのだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは卵をやぶつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　摩天楼の鏡の面からつやぶきんをとるために、私は、藍色のカーテンで市街に向ってひらいた窓を閉ざすと、「――それよりか、君のコオセット・ボタンがいくつあるか計算さしてもらいたいもんだね。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが武の母は石井翁の細君の妹だけに、この無為主義をあやぶみ、姉は盲従してこそおれ、女はやっぱり女、石井さんの隠居仕事で二十五円の上に十円ふえるならどのくらい楽と思うか知れないと、武をして石井翁を説き落とさすつもりでいるのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がやり出せば、やぶれかぶれだ、畜生！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海浸す日より棲みゐて、　　　　たゝかひにやぶれし神の、二かしら猛きすがたを、　　　　青々と行衛しられず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からす麦かもわが播けば、　　　ひばりはそらにくるほしく、ひかりのそこにもそもそと、　　上着は肩をやぶるらし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三なる技師は徳薄く、　　　すでに過冷のシロッコに、なかば気管をやぶりたれ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「署長さん、ご存じでしょうか、近頃、林野取締法の第一条をやぶるものが大変あるそうですが、どうしたのでしょう。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの大事なタダシはいまどんな歌をうたっているだろう、雪の降る朝にみんなと手をつないでぐるぐるにわとこのやぶをまわってあそんでいるだろうかと考えたりほんとうに待って心配していらっしゃるんですから、早く行っておっかさんにお目にかかりましょうね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
