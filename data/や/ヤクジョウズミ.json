        "examples": {
          "standard": [
            {
              "text": "そのマンションの部屋はすでに約定済みで、もう内見することはできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予約していた限定品が約定済みになっていることを確認し、胸をなでおろした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "画面上には「約定済み」の文字が並び、セールが盛況だったことを物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "誰れでもおしかさんは別者にして、近衛様のお側室さま格に思い、やがて呼迎えられる日のあることを、遅かれ早かれ、約定済みのように傍の者も思っていたが、侯爵は思いもかけぬ病気で不意にこの世を去られた。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもたまに明いていたと思うと、ちゃんともう約定済みになっているんですからね。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ったら、鶴屋の主人が「おっと、三千歳は先刻おれが約定済みだ。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
