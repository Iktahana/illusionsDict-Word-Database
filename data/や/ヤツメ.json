  {
    "uuid": "01e5c814-a177-5318-8b17-f2b6fb4e58aa",
    "entry": "奴め",
    "reading": {
      "primary": "やつめ",
      "alternatives": [
        "しゃつめ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fellow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「庄太の奴め、そそくさして、蚊いぶしを忘れて出て行きゃあがった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "行者の奴め、なかなかうまく考えたもんですよ」「むむ」と、半七は又かんがえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思は仕方なしに俟っていると、暮方になって漸く季は出て来て、余怒なお色にあるばかりで、「自分に方鼎を売付けた王廷珸という奴めは人を馬鹿にした憎い奴、南科の屈静源は自分が取立てたのですから、今書面を静源に遣わしました。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "目※連　――阿難の奴め、すっかり弱りきった。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、のうのうと居睡りくさって、何処に、馬の通るを知らぬ婦があるものか、野放図な奴めが。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の奴めも、殿樣の方には遠慮したと見えて、御家來の顏へ※を掛けやがつた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃、晃と呆れた奴めが。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉弟が心ひとつにして、馬盜人のかたきの奴めを……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こほろぎや人になかせて夜もすがら憎い奴め叔父を案山子に残せしよ　十六日、午後より青山へ墓参にゆく。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことをきいた兄さんのアア王は大層憤りまして、「おのれ、サア王の憎い奴め。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよけんめいでみつめてゐるみつめてゐるなにものかをだがかはいさうに奴め　背後に氣がつかない、背後には未知の犯罪もうもうとしてゐる黒の板塀。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやじが背負い残した家霊の奴め、この橋くらいでは満足しないで、大きな図体の癖に今度はまるで手も足もない赤児のようなお前によろよろと倚りかかろうとしている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家霊の奴め」　わたくしの肩は逸作の両手までがかかって力強く揺るのを感じた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大親分も宜いけれども、奉行や代官を相手にして談判をした末、向ふが承知せぬのを、此奴めといふので生捕りにして、役宅を焚き、分捕りをして還つたといふのでは、余り強過ぎる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も知らぬ顔して、おのが利得にならぬことは指一ツ動かさず、ぬっぺりと世を送りくさって、みずから手は下さねど、見す見す正道の者の枯れ行き、邪道の者の栄え行くのを見送っている、癇に触る奴めらが世間一杯。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此奴め人をからかふな、ハヽハヽヽ。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思は仕方無しに俟つてゐると、暮方になつて漸く季は出て来て、余怒猶ほ色に在るばかりで、「自分に方鼎を売付けた王廷珸といふ奴めは人を馬鹿にした憎い奴、南科の屈静源は自分が取立てたのですから、今書面を静源に遣はしました。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の奴め、苦なしでふわふわとのしおった、その時は、おらが漕いでいる艪の方へさ、ぶくぶくと泳いで来たが、急にぼやっと拡がった、狸の睾丸八畳敷よ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八「そうする内に、またお猿をやって、ころりと屈んだ人間ぐれえに縮かまって、そこら一面に、さっと暗くなったと思うと、あやし火の奴め、ぶらぶらと裾に泡を立てて、いきをついて畝って来て、今度はおらが足の舵に搦んで、ひらひらと燃えただよ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ろくでもない事を覚えて、此奴めが。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍはそこで奴め墓場で何人かと媾曳でもするのかと思った。",
              "citation": {
                "source": "死体を喫う学生",
                "author": "田中貢太郎",
                "note": "青空文庫"
