    "definitions": [
      {
        "index": 1,
        "gloss": "eighth (place, position, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "岡目八目で言いたいままの放語と思えど、久しく本邦に在留せし英人が、木戸、後藤諸氏草創の難に思い比べて、禁ぜんとして禁じ得ざる激語と見えたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたからは、云いならわされている通りおか目八目で、そのいりこんだ関係の大略が見えている場合もあって、いろいろの観察が下されてもゆく。",
              "citation": {
                "source": "遠い願い",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿の新聞記者、八目鰻売、勅語額売、どの人もそれ／″＼興味を与へてくれた、人間が人間には最も面白い。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂岡目八目で、他人の打つ手は批評が出来るが、さて自分で打つて見ると、なか／＼傍で見て居た様には行かないものさ。",
              "citation": {
                "source": "大勢順応",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国人が岡目八目で、やっぱり冬寒くなる前が一番｜好いと云っているね」「そうですかねえ。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "田楽刺し、八目刺し、ないしは菱鉾の刳り刺し、お望み次第突き刺して見せる？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口は岡目八目の然らしむる所以だと大目に見て頂きたい。",
              "citation": {
                "source": "西洋画のやうな日本画",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今境に依り書味の異なるものを案じ、八目を選び、之を読書八境といふ。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が、岡目八目と云うものの真価を、あまり考えなさすぎたことをつくづく思う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってまた野菜も作れない、それだけに野菜の善悪を見る目は自他の別を超越する、公平の態度をとることが出来る、――つまり日本の諺を使えば岡目八目になる訣ですね。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六―一八目の俄にくらめるための恐れを我より取去れるその聲、我をして重ねて語るの意を起さしむ　一九―二一その言に曰ふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに岡目八目さ」　これがこの男の口癖である。",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は火袁理命の目無堅間・熊野大神の八目荒籠・秋山下冰壮夫の形代を容れたといふ川島のいくみ竹の荒籠などぼつ／＼見えてゐるのが其で、どうやら供物容れが神の在処であつたことを暗示してゐる様である。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をかしる為に、様々の物を用ゐてゐる中、秋山下冰壮夫のかたみ（身代り）として、出石川の河の石を塩にまぶし、出石川の竹の葉に包み、其竹で造つた八目の荒籠に入れて、此竹葉の萎むが如青みしぼめ。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡目八目これを見て頻に襤褸買といひしも一理なきにあらざるべし。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二因縁に象った十二の襞の頭巾を冠り、柿の篠懸の古きを纏い、八目の草鞋を足に取り穿き、飴色の笈を背に背負い、金剛杖を突き反らした筋骨逞しい大男。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「岡目八目、こうっ、大丈夫けえ？",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならなぜそれをあたしの場合に使って下さらなかったの」「使わないんじゃない、使えないのよ」「だって岡目八目って云うじゃありませんか。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にいるあなたには、あたしより余計公平に分るはずだわ」「じゃ継子さんは岡目八目で生涯の運命をきめてしまう気なの」「そうじゃないけれども、参考にゃなるでしょう。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡目八目でお嫁に行かなかったからよ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍観者と云うものは岡目八目とも云い、当局者は迷うと云う諺さえあるくらいだから、冷静に構える便宜があって観察する事物がよく分る地位には違ありませんが、その分り方は要するに自分の事が自分に分るのとは大いに趣を異にしている。",
              "citation": {
                "source": "中味と形式",
                "author": "――明治四十四年八月堺において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し勝ったつもりだったが、こしらえて見ると、たった十八目の差か。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな、お稽古ごとにも、岡目八目と申すのがあるのでございましょうか……」　とお追従笑いをされまして、新しく、煙管を吸いつけられました。",
              "citation": {
                "source": "ながうた勧進帳",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の主観的な一生懸命さでさえ、成長を阻むものとなり得るということは、一応も二応もわかって居て、岡目八目的にはわかっていたが、我身にひきそえて、この頃は自分たちの生活の本来的なよいものでさえも、それをよいように活かさなければ、わるいものにさえも転化して作用すると思って居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "側で見ていると、岡目八目でよく分る。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身が溶けて油丈けになる」　と鳥目の薬の八目鰻を売っていると思えば、その向いには、「……次の食が直ぐ進む。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、おれのくちばしやつめを見ろ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊の木の中でも樺の木でも、またかれくさの地下茎でも、月光いろの甘い樹液がちらちらゆれだし、早い萱草やつめくさの芽にはもう黄金いろのちいさな澱粉の粒がつうつう浮いたり沈んだりしています。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色にしてややつめたく、透明なるところの気分である。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝子のやつめ、かってに注文して強くしてもらっているのじゃないかな」そんなことがふっと思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
