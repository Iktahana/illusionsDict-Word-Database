    "definitions": [
      {
        "index": 1,
        "gloss": "(many) mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左に従い来る山々｜山骨黄色く現われてまばらなる小松ちびけたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南のほうには相模半島から房総半島の山々の影響もそれと認められるように思った。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の草枯れの色は実に美しいと東の山ばかり見ているうちはや神島まで来て、久礼はと見たけれども何処とも見当がつかぬ。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は高くなって、四方は壮大な円形劇場のように開展する……出た……出た……木曾御嶽は、腰から上、全容を現わした、木曾駒ヶ岳も近くに立ち上った、方々から頭を白く削った稜錐状の山々が、波のように寄せて来た。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの山々から瞰下されて、乾き切っている桔梗ヶ原一帯は、黒水晶の葡萄がみのる野というよりも、橇でも挽かせて、砂と埃と灰の上を、駈けずって見たくなった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに反して、日本の山々は、富士、白山、立山、三｜禅定の神社はいうも更なり、日本北アルプスの槍ヶ岳や常念岳の連山にしてからが、石垣を積み、櫓をあげ、層々たる天主閣をそびやかした松本城を前景に加うることなしに、人間味と原始味の併行した美しさを高めることは出来ない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "道志山脈、関東山脈の山々の衣紋は、隆として折目を正した。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、シッソン、ウイードあたりから、仰ぎ見るシャスタの偉大さは、アルプス式の山々に見ることの出来ない鮮明美がある、孤にして閑である、独にして秀で、単にして完き姿である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極暑九十七度九分、山々に未だ雪あるに呆れ候、一昨夕、稀なる夕映、望遠鏡にて西山一帯を眺めいたるところ、駒ヶ岳の絶巓、地蔵の頭、間の岳、農鳥の絶頂なる、各三角測量標を、歴々と発見いたし候」（七月十八日）、この時の感じは、何だか自分が観て、Ｎ君に知らせているような気がした。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の連峯は雨雲の底面で悉くその頂を切り取られて、山々はたゞ一面に藍灰色の帷帳を垂れたやうに見えてゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の連峰は雨雲の底面でことごとくその頂を切り取られて、山々はただ一面に藍灰色の帷帳を垂れたように見えている。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西国にて知れる限りの山々を翁はみな自分の分身のように感じられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は山々を愛するがゆえに、それ等の山々の美醜長短を、人間の性格才能のように感じ取った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神の翁は西国の山々へはほとんどこどもを間配り終り、その山々の神としての成長をも見届けた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は相変わらず螺の腹にえび蔓の背をしてこそおれ、達者で、あさけ夕凪には戸外へ出て、山々の方を眺めた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "想う刹那に、山々の方から健在のしるしの応答えが翁の胸をときめかすことによって受取られた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁のふる郷の西国の山々にも新粟を初めて嘗むる祭はあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島山に小さいながらも姿は等しい三十余の山々。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた親は、なお、祖父の神の偉大さを語るにこういう言葉を使った、「なにしろ、西国の山々はもちろんのこと、東国でも、福慈とか、この筑波とかいう名山には必ず、こどもをお遺しになり、山を拓かすと共に、眷属の繁栄をお図りになった方なのだから」と。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "双親を通して申込まれる山々からの縁談も無いことはないのだが、ぜひ自分でなくてはと望むらしい熱意ある需めとは受取れなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の窓から伊勢路の山々が見え出した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "低くてなだらかな山々が広く長く根を張っている姿も、やはりいかにも落着いたのんびりした感じを与える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊が函館まで南下して来て対岸の山々を眺めて、さてあきらめて引き返して行ったことを想像するのは愉快である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が心は清めるか濁れるか」　封じ目ときて取出せば一尋あまりに筆のあやもなく、有難き事の数々、辱じけなき事の山々、思ふ、恋ふ、忘れがたし、血の涙、胸の炎、これ等の文字を縦横に散らして、文字はやがて耳の脇に恐しき声もて※くぞかし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの水平線は灰色の靄に隱されて、海と空との間に、陸奧の山々が幽かに浮んで見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに先刻の手早き藝當が其效果を現はして來たので、自分は自分と腹が定まり、車窓から雲霧に埋れた山々を眺め『走れ走れ電車、』　圓太郎馬車のやうに喇叭を吹いて呉れると更に妙だと思つた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々は悉く雲に埋れて僅かに其麓を現すばかり。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の麓には村あり、村々の奥には墓あり、墓はこの時｜覚め、人はこの時眠り、夢の世界にて故人｜相まみえ泣きつ笑いつす。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが今年死ぬと来年は私一人っきりでさびしゅうございますから」　ともっともな事を親切に言ってくれたので、燕もとうとう納得して残りおしさはやまやまですけれども見かえり見かえり南を向いて心細いひとり旅をする事になりました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "決済に関しても、注文や情報の送付と同時に交換できる電子マネーが確立されていれば、そちらを使いたいのはやまやまです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
