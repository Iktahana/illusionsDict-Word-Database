        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ドレッバーはちょっと野暮用があるとのことで、待っててくれ、あとで落ち合おうと。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それもきのうのひるすぎですが、ちょっと野暮用がありましてね、両国を通ったと覚し召せ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとそこまで野暮用で」「冗談だろう、嘘をいえ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮用というなりではない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又丹波笹山で生捕りましたる、八尺の大鼬なんかぢやあるまいネ」　捕物の名人錢形の平次と、その子分の八五郎、野暮用で龜戸へ行つた歸り、東兩國の見世物小屋へ入つたのは、初夏の陽も、漸く蔭を作りかけた申刻（四時）近い刻限でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮用で本所からの歸り、橋の中程まで來ると、ガラツ八がかう言つて平次の袖を引きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮用で本所からの帰り、橋の中ほどまで来ると、ガラッ八がこう言って平次の袖を引きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "また丹波篠山で生捕りましたる、八尺の大鼬なんかじゃあるまいネ」　捕物の名人銭形の平次と、その子分の八五郎、野暮用で亀井戸へ行った帰り、東両国の見世物小屋へ入ったのは、初夏の陽も、漸く蔭を作りかけた申刻（四時）近い刻限でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人魚の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とは野暮用で話さねばならないんです」「えっ、それは本当ですか、貴方」ゴリオ爺さんは顔色を変えて言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から野暮用でフリート・ストリートへ行くところだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち開花するだろうから任せて、俺はほかの野暮用でペルシャに戻った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで策を弄して、モートン氏を英国の端っこへ野暮用で追っ払いました。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにお願いがありやすが、この町に残って、野暮用をしてもらいたいのでやす」　血色の良い少佐の顔が曇った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし野暮用を慎重にやっていただけたら、それ相当のお金を差し上げやす。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮用は、ポストクラブへ行って、大金が賭けられたものをすべて見つけて、その中で今日のマーストパーク競馬でセルウィンの賭けを探すことでやす。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のとこは、ちと野暮用だ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
