[
  {
    "uuid": "314b9799-435a-59bf-9029-383da0c27be8",
    "entry": "躍進",
    "reading": {
      "primary": "やくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "making rapid progress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いかに科學日本の躍進を誇る現代でも、本質的にフアンタスチツクの夢を持たず、子供の心理と沒交渉に語られる如き奇怪の童話、即ち「事實に即した現實主義の童話」とか「科學的合理主義の童話」なんてものは有り得ない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その砲煙弾雨の中を一意敵に向って散開し、躍進する千変万化の姿は、男性の姿態美の中でも、最高潮した「気をつけ」の緊張美以上に超越したものの千変万化でなければならぬ。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして人間生れつきの性質上、生命の躍進、進展は本能であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も国民的自覚の大意力は凝つて百錬の氷鉄の如く、発して焦天の大火焔の如く、旗裂けて怯まず、馬倒れて屈せず、剣折れて撓まず、砲弾と共に躍進して遂に随所に凱歌を奏し得たり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "官軍勇を奮って躍進するが、なかなか頑強であって、之を抜く事が出来なかった。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つ事少時、三発の号砲を聞くや、躍進して迫り、右翼第一線の塁を抜いた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の日諸隊躍進｜何れも先駆の功名にはやり後方の配備甚だ手薄だった。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初老的」な感情の躍進が、色彩に反映したものと観察を下すのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "大真面目に神泉氏の鯉、蓮の題材から狸への飛躍を祝福し、更に毛皮への躍進を求めてゐるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景、それから花鳥、そして人物、それから美人画といふ風に最近では新しい方向のものに手をつけてゐて、その動きの躍進的な転変極りない行き方は、観賞者をして希望は一体何作家なのか、何を専攻する作家なのかといふ感想も抱かせる、今更、児玉希望は美人画でもあるまいといふ風評も立つのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會主義共産主義ヲ誤解シテ其ノ私有財産ヲ分與スルモノナルカノ如ク考ヘ、又ハ國民ノ凡テニ其日暮シ其年碁シノ生活ヲナサシムル者ト考フルガ如キハ、現實的改造ノ要求セラレツツアル現代社會革命説ノ躍進的進歩ヲ解セザル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ハ此ノ改造ニ基ク國家ノ大富力ヲ以テ海軍力ノ躍進的準備ヲ急グベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等ハ舊時代ニ生レ其ノ見ル所歐米ノ小天地ニ限ラレタルノミナラズ、淺薄極マル哲學ニ立脚シタルガ故ニ、躍進セル現代日本ヨリ視ル時單ニ分科的價値ヲ有スル一二先哲ニ過ギザルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國境ヲ撤去シタル世界ノ平和ヲ考フル各種ノ主義ハ其ノ理想ノ設定ニ於テ、是レヲ可能ナラシムル幾多ノ根本的條件則チ人類ガ更ニ重大ナル科學的發明ト神性的躍進トヲ得タル後ナルベキコトヲ無視シタル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の個性は或る已みがたい力に促されて、新たなる存在へ躍進しようとする。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はこの時代的着色から躍進しなければならぬと私は思う。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、ロックンロール・ファンのリスナーが、この曲をナンバーワンに押しあげるのに全精力を使い果たし、歌謡曲派の躍進を許してしまったように見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお貞さんは巧に躍進していつの間にか女子文壇を去り博文館の文章世界の投書家となつてしまつた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは、日本の工業力が躍進したとか、日本人が世界的発明をしたとか耳にしますが、これを全体的に考え、かつしずかにおちついて調べてみますと、わが国一般国民の科学力は、とても一等国らしいところはなく、三等国以下ではないかと思われる節もあります。",
              "citation": {
                "source": "『火星兵団』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の選に於て、僕の非常に愕いたことは、その応募作品の質が前二回に比して躍進的向上を示したことである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二楽章なしに直に第三楽章への躍進であり、表現と高興との中心への侵入であります。",
              "citation": {
                "source": "桜の花",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といつたのは、実際言葉どほりに生活の跳飛であり、経験の躍進であり、更にまた新しい心持の世界の新発見でありました。",
              "citation": {
                "source": "桜の花",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "東亜諸民族の疑心暗鬼が除去されたならば、一日も速やかに少なくも東亜連邦に躍進して、東亜の総合的威力の増進を計らねばならぬ。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体主義は国力の超高速度増強を目標とするのであり、「自由」から「統制」への躍進である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大道は人類の王道への躍進である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も肉体的表情であって翻訳を必要としないスポーツで日本は世界の最前列に伍していることや、所謂躍進日本の他の一面としての文化紹介を欲する政府当局の意嚮などが、外務省文化事業部へ反響して、先ず国際文化振興会が半官的な組織で成立し、つづいて島崎藤村氏を会長とする日本ペン倶楽部が組織された。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が全体としておかれている国際的な事情と、積極的に新しい歴史の時代に立とうとしている関係上、同じ躍進の状態と云っても明治時代とは全然ちがっている。",
              "citation": {
                "source": "風俗の感受性",
                "author": "――現代風俗の解剖――",
                "note": "青空文庫"
              }
            },
            {
              "text": "躍進日本という愛唱される標語の実質は、極めて極めて現実的な道によって獲得されつつある一方、何ゆえ文化形態の外貌においては抽象的な、気分的なロマンチシズムが人為的に高揚されなければならないか。",
              "citation": {
                "source": "近頃の話題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "びやくしんとも違ふが、似た木が六七本。",
              "citation": {
                "source": "五葉の松",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
