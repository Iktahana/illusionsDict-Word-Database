        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、何せれいの家の建て直しに、着て出る着物の調整に、やっさもっさ、心をくだき、あまりの向上心に、いきおい守るほうを失念してしまっていた。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いうと、おだやかでないが、陰気で、しなやかに撓む、クニャクニャした気象の女だったら、どうか我慢も出来たであろうが、お八重さんが、サックリした短所も長所も、江戸ッ子丸出しの気性だったのだから、その嫁と姑のやっさもっさが、何処やら、今から見ると時代ばなれがしている。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭にはチョクリチョクリと芝居を打たれ、楽しみに頼りにもと思って連れて来た息子は人前にも出されない様だし、※子の祖母へ云い訳の立たない事をして居るのでお関は、朝から晩まで家を外に出歩いて、近くに出来る水道の貯水池の地所を買い占めに口を利いてやっさもっさして居る主人を捕えて、「どうするんですよ、彼れは。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰かきで麦っ粉をやっさもっさこねます。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、こんなことでやっさもっさやってると、今にどんなことが起きるかわかりやせん。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らずの、手のかかったことしてやっさもっさやっているが、もういいということにいたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい僕はまだあなたまで相手に、やっさもっさしなくちゃならないんですか」とラスコーリニコフはけいれんするみたいにじりじりしながらいきなりぶっつけに切り出した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
