[
  {
    "uuid": "2fd0ce6b-084d-5ca0-ba43-7180a2e8e05b",
    "entry": "夜間",
    "reading": {
      "primary": "やかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「まああたしまだ、仕度なんてしてやあしないわ、それに今晩はあれですもの……夜間（撮映）……ねえ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、いや夜間のことはチヤンと承知だつたから、俺は途中でランチで済ませて来たんだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間倦んじ疲れて、懈怠の心が起らうとする時、頭をもたげて燈光の中に先生の黒い痩せたお顏を瞥見すると、いまにも抑揚頓挫のある言葉で話しかけようとしてゐられるかの如く思はれる。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三台のポムプは、昼夜間断なくモーターを焼く程働き続けていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間写真などに金属元素マグネシウムの粉を燃やす事があるが、あれはただ短時間強い光を出すだけで、灯用にはならぬ。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの光は写真の種板によく感じるからこれを使えば夜間でもほとんど昼間同様の写真が撮れる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間の照明も強い灯光を用いてはならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に人目を嫌って逃げるものや、夜間のみ出あるく獣の天真の態度はなおさら知り難い。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また夜間ならば糸に触れると点火器の引金が落ち、マグネシウムがパッと燃え上がって、動物は驚いて遁げる間のない中にカメラに写される。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中を選んだのは畢竟無線電信には夜間の方が故障が少ないためだという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩私は醉つぱらつて、夜間營業の店へ這入つた。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　堂島ホテル附近にある、夜間薬品店の売子の売行表と、商業的な饒舌は、女の温度にたいしてひどく慇懃なのだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前０時を過ぎると、死体のように冷やかな銀行街から、大江村を渡って、鬢にほつれるある女が夜間薬品店にあらわれると、灯籠道でもあるくように蒼ざめて、淀川の水面に赤いレッテルの商標を投じた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、カバーをかけたタクシーが夜間薬品店のまえでとまると、なかから、林田三郎が仕掛花火のように商館にかけこんだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夜間の遊覧飛行イルミネェーションで作られたファンタジツクな科学の尻尾、――妻にたいする愛を結びつけて、……。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　内田百間君の「掻痒記」を読んで二三日後に偶然映画「夜間飛行」を見た。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、日照とか夜間放熱とか気温とか風当たりとかそういう単なる気象的条件の差異によってこれらの遅速を説明しようと思っても、なかなか簡単には説明されそうもないような結果であった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間は陸上の空気が海上のものよりも著しく冷却するから、これと反対の過程が行なわれて、上層では海のほうから陸へ、下層では陸から海へ微風が吹く、これがいわゆる陸風である。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海陸風の原因が以上のとおりであるから、この風は昼間日照が強く、夜間空が晴れて地面からの輻射が妨げられない時に最もよく発達する。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕なぎというのは昼間の海風から夜間の陸風に移り変わる中間に、一時無風の状態を経過する、その時をさして言うのである。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間の、闇にまぎれて、こっそりと麻酔薬を買いに来る人間を見張っているのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　巡警は、人が出入をするのは、暗くて見分けのつかない夜間だと睨んでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア、夜間通船の目的でなくて隅田川へ出て働いて居るのは大抵こんなもので、勿論種々の船は潮の加減で絶えず往来して居る。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、これもやはり私の洗面台の問題の一つであるが、前夜にたてた風呂の蒸気が室にこもっているところへ、夜間外気が冷えるのと戸外への輻射とのために、窓のガラスに一面に水滴を凝結させる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏じゅうは昼間に暖まった甕の水が夜間の放熱で表面から冷え、冷えた水は重くなって沈むのでいわゆる対流が起こる。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、木のふたで密閉したから夜間の冷却が行なわれず、対流が生ぜず、従って有害なものが底のほうに蓄積して窒息死を起こしたのではないかというのである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは、わずかな高低｜凹凸の複雑に分布した地面の水準測量をするのに、わざと夜間を選び、助手に点火した線香を持って所定の方向に歩かせ、その火光をねらって高低を定めたと言い伝えられていることである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉は夜間双眼鏡を手早く取って、きっとそっちを見ました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかん平さんは一昨年なくなりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の執念の残っていそうな櫛やかんざしのたぐいも拾い出されなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
