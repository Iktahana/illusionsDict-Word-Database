          "literary": [
            {
              "text": "「ねえ、僕が川上の世話を焼きすぎるといって心配したり、かれこれいうものがあるけれど、男は女に惚れているに限ると思うのです。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君はあんまりやきすぎるよ」　蓮香はますます怒った。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪教退治というものは、新興成金にヤキモチをやきすぎる傾き濃厚で、もっと大きな悪質の狸は、他にゴロゴロしているようだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんは、よけいな世話をやきすぎる、と少年は心の中で思っていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
