        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パンをオーブンで焼きすぎて焦がしてしまい、結局食べられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クッキーは焼きすぎると風味が飛んでしまうから、焼き時間には注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ああ、また電子レンジで温めすぎて、ご飯を焼きすぎちゃったよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
