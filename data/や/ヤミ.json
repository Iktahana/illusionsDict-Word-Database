[
  {
    "uuid": "d627442f-de80-5b42-9dec-2c9e8574dcee",
    "entry": "闇",
    "reading": {
      "primary": "やみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "darkness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汝等ともに闇くして、且はひめやか。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾宮沢賢治落ちしのばらの芽はひかり樹液はしづにかはたれぬあゝこの夕つゝましくきみと祈らばよからんをきみきたらずばわが成さんこの園つひにむなしけん西天黄ばみにごれるに雲の黒闇の見もあへず",
              "citation": {
                "source": "開墾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、それはおまへの今ゐるのが何の変哲もない峠道のことで、闇夜のことだし草一本満足には見えぬ有様だからだらうなぞ思ふ人もあるかも知れぬ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家なんかの部屋を夢闇に片附けるのは却て不可ないことだつて。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "周圍は眞闇の田舍道で、田圃の中に蛙が鳴いてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」妹は、夕闇の迫った薄暗い部屋の中で、白く美しく笑って、「ねえさん、あたし、この手紙読んだの。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅から旅館までの俥の上で自分の息が見知らぬ町の暗闇の中に、白く立昇つたことを夢のやうに覚えてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "２猫が鳴いてゐた、みんなが寝静まると、隣りの空地で、そこの暗がりで、まことに緊密でゆつたりと細い声で、ゆつたりと細い声で闇の中で鳴いてゐた。",
              "citation": {
                "source": "曇つた秋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのが身の闇より吠えて夜半の秋　黒犬の絵に讃して咏んだ句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇夜に吠える黒犬は、自分が吠えているのか、闇夜の宇宙が吠えているのか、主客の認識実体が解らない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖簾をかけた質屋の店も、既に戸を閉めてしまったので、万象｜寂として声なく、冬の寂寞とした闇の中で、孤独の寒さにふるえながら、小さな家々が眠っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の詩情が歌うものは、こうした闇黒、寂寥、孤独の中に環境している、洋燈のような人間生活の侘しさである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり車窓に目醒むれば汽笛は闇に吠え叫び火焔は平野を明るくせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符賣る家の闇きらんぷの火影に見れば、先きほど隣室にてなやみし、醉ひしれたるをのこなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内は雜然としてかんてらの燈火が四邊一面の光景を花やかに、闇の地に浮模樣を染め出した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景な下宿の庭に鬱陶しく生いくすぶった八つ手の葉蔭に、夕闇の蟇が出る頃にはますます悪くなるばかりである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱陶しいほど両側から梢の蔽い重なった暗闇阪を降り尽して、左に曲れば曙湯である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労も不平も洗い流して蘇ったようになって帰る暗闇阪は漆のような闇である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かで轡虫の鳴くのが静かな闇に響く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後｜田舎へ帰ってからも、再び東京に出た後も、つい一度もやもりというものを見なかったが、駒込の下宿に移って後、夏も名残のある夜の雨にこの暗闇阪のやもりを見つけた時、十九の昔の一夜がありあり思い出された。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やもりは雨のふる夜ごとに暗闇阪の街燈に出ているが、いつ何処から這い上がるとも知れぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇阪を下りつめた角に荒物屋がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬が容捨もなく迫って来て木枯しが吹き募るある夜、散歩の帰り途に暗闇阪近くなった時、自分の数間前を肩をすぼめて俯向いて行く銀杏返しの女がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇阪の街燈は木枯しの中に心細く瞬いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が年中で一番｜厭な時候が再び来て暗闇阪にはまたやもりを見るようになった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇阪の街燈には今でもやもりが居るが、元のような空想はもう起らぬ、小さな細長い黒影は平和な灯影に眠っているように思われるのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「闇汁会」や「柚味噌会」の奇抜な記事などもなかなか面白いものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人となつた今日でさへ、さうした悲運はやみはせぬ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
