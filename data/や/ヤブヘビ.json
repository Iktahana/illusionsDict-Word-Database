        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "下手に詮索すると、かえってやぶ蛇になるだけだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その秘密に触れることは、やぶ蛇になる可能性が高いので、避けるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は自分から余計なことを言って、やぶ蛇になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "まさにやぶ蛇である。",
              "citation": {
                "source": "女靴下の話",
                "author": "西東三鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、下級生をバックして五年生に対抗するのは、やぶ蛇だぜ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "エアロン・フィリップスを知っているかと訊く必要はあるまい、やぶ蛇だろうから。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じられないぜ、ロンドンに住んでる英国人が、ロンドン塔を見てないって」「スリムさん、本当に見てないのですよ」　アメリカ人は三個目の卵をむきながら、「ええっ、やぶへびだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうやぶへびじゃないぞ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、探偵さん、きみもとんだやぶへびをしたもんだねえ。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが名探偵といわれるほどあって、おれの正体を見やぶったのは感心だけれど、そいつが、とんだやぶへびになってしまった。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
