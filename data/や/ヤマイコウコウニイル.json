        "examples": {
          "standard": [
            {
              "text": "病膏肓に入る前に、治療を開始すべきだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が病膏肓に入ったと聞いて、覚悟を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度病膏肓に入ると、回復は難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "思えば、ヤマメ、ハヤ、ヤマベ釣りも、「やまいこうこうにいる」というか、ずいぶん遠方まで出かけたものだ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to become a slave of a habit",
