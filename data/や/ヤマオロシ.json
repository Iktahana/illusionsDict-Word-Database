    "definitions": [
      {
        "index": 1,
        "gloss": "wind blowing down from a mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蝋の灯は吹くとなき山おろしにあかくなり、くろうなりて、ちらちらと眼に映ずる雪なす膚白かりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人、五六人という群れになって北山おろしの木枯らしに吹かれながら軒並みをたずねて玄関をおとずれ、口々にわざと妙な作り声をして「カイツットーセ」という言葉を繰り返す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋の灯は吹くとなき山おろしにあかくなり、くらうなりて、ちらちらと眼に映ずる雪なす膚白かりき。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷い火を汗に浴びると、うら山おろしの風さ真黒に、どっと来た、煙の中を、目が眩んで遁げたでござえますでの。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の家の話を聴いた為めでしょうか、それとも景色自体が三山の山おろしの吹き交ぜて土も草木も掻き苛まれつけているその為めでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山おろし劇しうして、白雪街を籠め、廣こうぢの石の「トリイトン」に氷の鬚おふるときは、我喜限なかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "心を鎭めて目を閉づれば、冷なる山おろしの風は我頬を繞りて吹けり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "法華の三昧を行なう堂の尊い懺法の声が山おろしの音に混じり、滝がそれらと和する響きを作っているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き迷ふ深山おろしに夢さめて涙催す滝の音かな　これは源氏の作。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十人の楽人が吹き立てた楽音に誘われて吹く松の風はほんとうの深山おろしのようであった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度しわすのもの淋しい夜の事でしたが、吹すさぶその晩の山おろしの唸るような凄い音は、今に思出されます。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても世が世なれば、四條橋の下には、一臺十五錢と言ふ安い床が出來て、なんのことはない「夜の宿」の背景のやうな所なれど、河原の夕涼の面影を殘した唯一のもの、風は叡山おろし、水は加茂川、淺瀬をかちわたるよきたはれめもありといふ。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月はじめの秋の日は吹き消すようにあわただしく暮れかかって、うすら寒い西山おろしが麻の帷子にそよそよと沁みて来たので、千枝太郎はいよいよ心寂しくなった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　朝晩の山おろしの風が、刺すやうな冷たさになつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのぼのと有明の月の月影は紅葉吹きおろす山おろしの風　（信明）　これも客観的の歌にて、けしきも淋しく艶なるに語を畳みかけて調子取りたるところ、いとめずらかに覚え候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡の辺の里のあるじを尋ぬれば人は答へず山おろしの風　（慈円）　趣味ありて句法もしっかりと致し居候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのぼのと有明の月の月影に紅葉吹きおろす山おろしの風（信明）　これも客観的の歌にて、けしきも淋しく艶なるに、語を畳みかけて調子取りたる処いとめづらかに覚え候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡の辺の里のあるじを尋ぬれば人は答へず山おろしの風（慈円）　趣味ありて句法もしつかりと致しをり候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの／＼と有明の月の月影は紅葉吹きおろす山おろしの風　（信明）　これも客觀的の歌にてけしきも淋しく艶なるに語を疊みかけて調子取りたる處いとめづらかに覺え候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡の邊の里のあるしを尋ぬれは人は答へす山おろしの風　（慈圓）　趣味ありて句法もしつかりと致し居候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では凄いほどに山おろしが松の梢を鳴らしていたりなどして、不断経の僧の交替の時間が来て鐘を打つと、終わって立つ僧の唱える声と、新しい手代わりの僧の声とがいっしょになって、一時に高く経声の起こるのも尊い感じのすることであった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山おろしが烈しくなり、もう葉のない枝は防風林でも皆なくなった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山おろしに木の葉も峰の葛の葉も争って立てる音の中から、僧の念仏の声だけが聞こえる山荘の内には人げも少なく、蕭条とした庭の垣のすぐ外には鹿が出て来たりして、山の田に百姓の鳴らす鳴子の音にも逃げずに、黄になった稲の中で啼く声にも愁いがあるようであった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "山おろしに堪へぬ木の葉の露よりもあやなく脆きわが涙かな　村の者を驚かせないために随身に人払いの声も立てさせないのである。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "松風の音も荒かった山おろしに比べれば穏やかでよい住居としているようには今夜は思われずに、山の椎の葉の音に劣ったように中の君は思うのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大老人のあずま琴で興味のしらけてしまった席から中将の帰って行く時も山おろしが吹いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで水の底で助けて帰されたことを、薬売りが咄しますと、主人も驚いたには違いありませんが、その御主人の言葉に「毎年秋祭りの前後に、はげしい山おろしが吹荒れると、中妻のおばあさんが来たということを、里の者は何の訳か言いつたえている。",
              "citation": {
                "source": "糸繰沼",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝晴れし雪のけしきは長閑にて松の日影にしづくこぼるる朝日さす枝はしづくになりにけり積れどあたら松の上の雪朝ぼらけみ山おろしの吹くすゑに一むら曇る松の雪かな冬月。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
