[
  {
    "uuid": "11c68f60-f442-5d7e-9698-6f75b1526f80",
    "entry": "薬価",
    "reading": {
      "primary": "やっか",
      "alternatives": [
        "やくか"
      ],
      "is_heteronym": false
    },
    "grammar": {
