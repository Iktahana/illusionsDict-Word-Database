    "definitions": [
      {
        "index": 1,
        "gloss": "cart (esp. a food cart)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酒場であらうと屋台であらうと、その場に眠つてしまふ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか寿司の屋台が出てゐる日があり、今日はそれは見えなかつたが、四五本の柱にトタン屋根を張つた、一時拵への氷店が出来てゐた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "わめき、罵詈、溺れるような死にものぐるいの手と脚のもがき、屋台の顛覆。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに崩れようとする家は、一本のくさびをはずしても、巨大な屋台骨が、一度に、バラ／＼に崩壊してしまうものだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "短夜屋台を引きて帰りくる、　　　目あかし町の夜なかすぎ、うつは数ふるそのひまに、　　もやは浅葱とかはりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋のすぐ前に屋台店のようなものが出来ていて、それによごれた叺を並べ、馬の餌にするような芋の切れ端しや、砂埃に色の変った駄菓子が少しばかり、ビール罎の口のとれたのに夏菊などさしたのが一方に立ててある。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオンの店をだされたアンナが町の花屋の屋台の花をぼんやりながめる。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な片手落ちの若返り法などを試みて造化に反抗するとどこかに思わぬ無理ができて、ぽきりと生命の屋台骨が折れるようなことがありはしないか。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをそっと小わきにかかえ、ちかくの支那蕎麦の屋台へ、寒そうに肩をすぼめながらはいって行った。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がその屋台を出て、電車の停留場へ行く途中、しなびかかった悪い花を三人のひとに手渡したことをちくちく後悔しだした。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私にはその時突然、東京の荻窪あたりのヤキトリ屋台が、胸の焼き焦げるほど懐しく思い出され、なんにも要らない、あんな屋台で一串二銭のヤキトリと一杯十銭のウィスケというものを前にして思うさま、世の俗物どもを大声で罵倒したいと渇望した。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り屋台、手古舞、山車、花火、三島の花火は昔から伝統のあるものらしく、水花火というものもあって、それは大社の池の真中で仕掛花火を行い、その花火が池面に映り、花火がもくもく池の底から涌いて出るように見える趣向になって居るのだそうであります。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台店もひらきました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れも致しません、あれは秋のなかば、月の非常にいい夜でございましたが、私は十二時すぎに店をしまいまして、それから大いそぎで築地の或る心易くしている料理屋へ風呂をもらいに行きまして、かえりには、屋台でおそばを食べ、家へ来て勝手口をあけようとしても、もう内｜桟をおろしてしまったようで、あきませんでした。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に建てた妙な屋台造りに生き人形が並べてあった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん見物人が多くなって、わざわざ遠方から汽車で見物に来る人さえできたので、おしまいにはそれを相手の屋台店が出たりした。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台鮨の暖簾に顔をつツこむと、会計役を承つた勃凸があとから支払ひをした。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂は縦に、壁は横に、今も屋台は浮き沈み、危く掘立の、柱々、放れ放れに傾いているのを、渠は何心なく見て過ぎた。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿が、毛氈の赤い色、毛布の青い色、風呂敷の黄色いの、寂しい媼さんの鼠色まで、フト判然と凄い星の下に、漆のような夜の中に、淡い彩して顕れると、商人連はワヤワヤと動き出して、牛鍋の唐紅も、飜然と揺ぎ、おでん屋の屋台もかッと気競が出て、白気濃やかに狼煙を揚げる。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と書いたお定りの屋台は、昼｜行燈と云う形。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺一ぱいにならんだ屋台の青い苹果や葡萄が、アセチレンのあかりできらきら光っていました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御手洗を前にして、やがて、並んで立った形は、法界屋が二人で屋台のおでん屋の暖簾に立ったようである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は屋台が廻って、この玄関前へも練込んで来て、芸妓連は地に並ぶ、雛妓たちに、町の小女が交って、一様の花笠で、湯の花踊と云うのを演った。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台のまがきに、藤、菖蒲、牡丹の造り花は飾ったが、その紅紫の色を奪って目立ったのは、膚脱の緋より、帯の萌葱と、伊達巻の鬱金縮緬で。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫婦は――新婚旅行の意味でなく――四五年来、久しぶりに――一昨日温泉へ着いたばかりだが、既に一週間も以前から、今日の祝日の次第、献立｜書が、処々、紅の二重圏点つきの比羅になって、辻々、塀、大寺の門、橋の欄干に顕われて、芸妓の屋台囃子とともに、最も注意を引いたのは、仮装行列の催であった。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、踊屋台の引いて帰る囃子の音に誘われて、お桂が欣七郎とともに町に出た時は、橋の上で弁慶に出会い、豆府屋から出る緋縅の武者を見た。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこのくらいな間だったが――山の根に演芸館、花見座の旗を、今日はわけて、山鳥のごとく飜した、町の角の芸妓屋の前に、先刻の囃子屋台が、大な虫籠のごとくに、紅白の幕のまま、寂寞として据って、踊子の影もない。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半助さん……」ここで踊屋台を視た、昼の姿は、鯉を遊ばせた薄もみじのさざ波であった。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬二頭が、鼻あらしを霜夜にふつふつと吹いて曳く囃子屋台を真中に、磽※たる石ころ路を、坂なりに、大師｜道のいろはの辻のあたりから、次第さがりに人なだれを打って来た。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの人たちは、かねやたいこをならして、やまや谷をさがしてゆくだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
