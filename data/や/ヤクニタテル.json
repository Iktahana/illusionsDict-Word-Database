[
  {
    "uuid": "dea37f90-88b2-5913-b920-cb178af46d09",
    "entry": "役に立てる",
    "reading": {
      "primary": "やくにたてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
