    "definitions": [
      {
        "index": 1,
        "gloss": "to take the easy way out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
