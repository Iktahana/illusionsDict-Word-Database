  {
    "uuid": "b9b1cae1-f401-5645-a3bc-0552b991ca35",
    "entry": "扼する",
    "reading": {
      "primary": "やくする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
