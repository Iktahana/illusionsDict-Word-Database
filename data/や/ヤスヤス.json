[
  {
    "uuid": "8c47452c-d05f-51d1-b0f2-cc9dbe018f2f",
    "entry": "易々",
    "reading": {
      "primary": "やすやす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
