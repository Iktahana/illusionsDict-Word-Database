        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……其の宿の名は、八重垣姫と、隨筆の名で、餘所ながら、未見の知己。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の八重垣姫が呼び物となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝術感及び實感の交錯は芝翫の八重垣姫、茜屋のお園の演伎の際、屡※東京座や歌舞伎座の大入場の喧噪として現はれたものである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでハムレットか八重垣姫のように淋しいの。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏へと口笛吹き吹き行くと、　蔓細千成、茄子の花、おはぐろつけたて中年増、　黄と白、赤の葱坊主、毛槍かつげば供奴、　人蔘の花、八重垣姫の花かんざしの額髪、　花の痛いは種｜牛蒡、勧進帳の篠懸けだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ら四人はいま雲の八重垣の真洞の中に蛤をとっている。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重垣姫に扮した鍛冶屋の娘が、馬車から下りるのを見た。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの団十郎の八重垣姫に対して勝頼をつとめ、団十郎の岩藤に対して尾上を勤めた頃が、その人気の絶頂であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちの招待日は三月二日で、芝居は午前九時開場、狂言は「廿四孝」と「山姥」と「お染久松」とで、粂八は八重垣姫と山姥を勤めていたが、どちらの役も無論に団十郎張りであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は多年立役を勤めていて、その女らしい声を失っている上に、努めて団十郎の仮声を使おうとする結果、その調子は太く濁って、すこぶる聞き苦しいものであったが、八重垣姫に扮した舞台顔はたしかに美麗で、優雅で、その音声から受ける一種の不愉快の感じを打消すに十分であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年市村座で見せられた団十郎の八重垣姫も無論すぐれたもののように記憶していたが、今になって考えると、どうも粂八の方がすぐれているらしいと私はその時に思った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの狂言は、一番目が芝翫の「朝比奈」、中幕が栄三郎の「八重垣姫」、二番目が彼の柿の木金助。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "和卜、八重垣、大詰め、小詰め、天狗抄花車、柳生流にも色々ある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――酔うてゐる、さらに飲む、いよ／＼酔ふ、――澄太君来庵、君は私の酔態に避易してゐることがよく解る、――そこへ一洵君も来庵、三人同道して道後の八重垣旅館へ押しかける、私だけ酒をよばれる、三人で悪筆乱筆を揮ふ、夕方、自動車で伊予鉄ホールの講演会へ出かけて、初めて澄君の講演を聴いた、よか／＼。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重垣姫の恋も、御駒才三の恋も、御染久松の恋も、まあ似たり寄ったりであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの目の前には花ぐしの揺らぐ八重垣姫や、前髪の美しい久松や、しゅすの帯をしめたお里や、狂乱のお舟や、文箱を持った力弥や、――美しい人の幻影が絶えずちらつくようになった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は例の汚い縞木綿の風呂敷包を片手に、傘もささずに、焼けつく日光に直射されながら例の通り、ただぶらぶらと野良犬のように、根津の八重垣町あたりを歩いていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも投げ出したいような気持ちで走って行きながら、「貴方は八重垣町の方へいらっしゃるんじゃあないですかッ！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重垣町の八百屋で唐もろこしを二本買って下宿へ帰る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、八重垣町の縫物屋へ奥さんの夏羽織の仕立物を取りに行く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも投げ出したいような気持で、「貴方は八重垣町の方へいらっしゃるんじゃあないんですかッ！",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は名門の出の某男爵が濡衣に扮したおり、彼女は八重垣姫を振りあてられて真面目に化粧い衣装をして、自ら「はじかき姫」だと言っていたことをも思いだす。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形遣ひは、栄三郎――梅幸――と二人で勤めたのだから、定めて八重垣姫の人形に扮した伯父からは、あべこべに叱られ通しだつたであらう。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "立役方面でなくとも、定高や萩の方や、政岡や、重の井や、篠原、又、時姫・八重垣姫などが、始終恣に、自分の持ち役として実現させることの出来る位置にゐる彼だつたら、歌舞伎座・帝国劇場の技芸委員長の持つたやうな自覚に住し得たかも知れぬ。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "福助――後、梅玉――主役の日蓮記、双蝶々のおせきに、廿四孝狐火の人形遣ひ、政治郎――現在梅玉――の日朗・八重垣姫で、市村座を開場した。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行成績は思はしくなかつたさうだが、当時殆水の出端と言ふべき盛りの政治郎の、八重垣姫の美しかつたことは、伝説のやうに言はれてゐる。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治郎時代の梅玉が明治三十年に東京で八重垣姫をした頃の美しさなどは、素晴しいものだつた。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまごめに　八重垣つくる。",
              "citation": {
                "source": "歌の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その八重垣を　この名高い、すさのをの尊のお歌は、實は、よく意味がわからないのです。",
              "citation": {
                "source": "歌の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば或る青年俳優が「本朝二十四孝」の八重垣姫を演るのに、ある部分は成駒屋の型で演じ、また他の部分は、故人梅幸の型で演じたとしても、誰も怪しみもしないし、非難もしはしない。",
              "citation": {
                "source": "流儀の定め",
                "author": "觀世左近",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
