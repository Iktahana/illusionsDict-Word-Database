    "definitions": [
      {
        "index": 1,
        "gloss": "kerria (Kerria japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山吹や井手を流るる鉋屑　崖下の岸に沿うて、山吹が茂り咲いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹や笠に挿すべき枝の形　ひとり行く旅の路傍に、床しくも可憐に咲いてる山吹の花。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山吹は少女の象徴であるかも知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の「山吹や」の句も、同様にその芭蕉幽玄体の一つである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹の青いえだや何かもじゃもじゃしている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を這入ると、山吹が一ぱいに咲いてゐるのが目についた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ南谿が記したる姉妹の此の木像のみ、外ヶ｜浜の砂漠の中にも緑水のあたり花菖蒲、色のしたゝるを覚ゆる事、巴、山吹の其にも優れり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚もすら／＼泳ぐだらうし、松には藤も咲いてるさうだし、つゝじ、山吹、とり／″＼だと言ふ、其の間を、船の影に驚いて、パツと群れて水鳥が立つたり、鴎が泳いで居たり……」「然うで、然うで、其の通りで……旦那。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩角、松、松には藤が咲き、巌膚には、つゝじ、山吹を鏤めて、御仏の紫摩黄金、鬼の舌、また僧の袈裟、また将軍の緋縅の如く、ちら／＼と水に映つた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去ぬる年、中泉から中尊寺に詣でた六｜月のはじめには、細流に影を宿して、山吹の花の、堅く貝を刻めるが如く咲いたのを見た。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り荷物をかついで魚臭い漁師町を通り抜け、教わった通り防波堤に沿うて二町ばかりの宿の裏門を、やっとくぐった時、朧の門脇に捨てた貝殻に、この山吹が乱れていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝見ると、山吹の垣の後ろは桑畑で、中に木蓮が二、三株美しく咲いていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦の雨夜の茶話は今も心に残っているが、それよりも、婆さんの潮風に黒ずんだ顔よりも、垣の山吹よりも深く心に沁み込んで忘られぬものが一つある。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹の青いえだや何かもぢゃ／＼してゐる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また道灌が傘の代りに山吹の花を貰ったという歴史的の原でもない。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上の小さな一輪挿しには椿、さつき、菜の花、海棠、山吹、薔薇という順序に花が挿されて、最後の薔薇が花を開き切らない中にそこを去るようになりました。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "円髷もあろうし、島田もあろうし、桃の枝を提げたのも、藤山吹を手折ったのも、また草籠を背負ったのも、茸狩の姉さんかぶりも、それは種々、時々だというけれど、いつも声がして、近づいて姿が見える――とそういうのが、近国にも響いた名所だ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お桂夫人は知らぬ顔して、間違って、愛読する……泉の作で「山吹」と云う、まがいものの戯曲を、軽い頬杖で読んでいた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻、山吹、寺内の蓮の華の頃も知らない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "對岸の湯宿の石垣に咲いた、枝も撓な山吹が、ほのかに影を淀まして、雨は細く降つて居る。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹の花が石垣に咲いて、卯の花が影を映す。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅――驚くな――山吹などを輕くあしらつた、此の角座敷。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹がいまを壮に咲いていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹は黄なる貝を刻んだようで、つつじの薄紅は珊瑚に似ていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が牝牛の如きは、何だか極りでも悪かったように、さらさらと雨のあとの露を散して、山吹の中へ角を隠す。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、麓の牛が白象にかわって、普賢菩薩が、あの山吹のあたりを御散歩。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　公園の入口に、樹林を背戸に、蓮池を庭に、柳、藤、桜、山吹など、飛々に名に呼ばれた茶店がある。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "棣棠　やまぶきは唐めかぬ花なり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "些少でござりまするが、お灯明料にご受納願いとうござる」　包んで出したのはやまぶき色が三枚。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉のいなかよりたんまりとやまぶき色をご用意のおだんな衆が三人ほど参り候まま、万障お繰り合わせご入来くだされたく、みなみな首長くしてお待ちいたしおり候。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
