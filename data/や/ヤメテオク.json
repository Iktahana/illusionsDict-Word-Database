    "definitions": [
      {
        "index": 1,
        "gloss": "to pass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "終りに牧水氏の歌について、一言寸感を述べたいと思つたけれども、既に紙數が盡きたから止めておく。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇藝術に於る通俗性の是非については、ここに論ずべき範圍でないから、只次のことを言ふに止めておく。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ頭に刻まれた問題だけを簡単に書き止めておく。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今年はもう止めておくれやとわたしから頼んでいるだよ」　一昨年の正月も去年の正月も、一日門附けしたあとで松次郎が、酒のきらいな木之助を居酒屋へつれこみ、自分一人で飲んで、ついにはぐでんぐでんに酔ってしまい、三里の夜道を木之助が抱くようにして帰って来たのを木之助は思い出した。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以て誠に名聞がましいが、何かの参考になるかも知れないと思って記憶している通りを書き止めておく次第である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、一つの蕾を枯らすことなくそのままの大きさに止めておくことができたら、それは魔術である。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも最近の雑誌などを読むと、ＧＵＩの源流探しはマッキントッシュ、リサとたどってゼロックス、パロアルト研究所のアルト（例のアラン・ケイ大人の作だ）あたりで止めておくのが流行りのようだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はこれで止めておく。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（関尹子に行気・煉気・化気の説があるがこれには関係しない）人の気に就いての言説はこれに止めておく。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんな、だんな、止めておくんなさいよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、前に述べた不思議な道具の使用法が如何に深刻なものであるかを、彼等はあらかた知る事が出来たと云うに止めておく。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男性（夫をも含む）を虐待し、その苦痛を忍受しつつ唯々諾々として自分の美の光りを渇仰する有様を見て、初めて愛欲の徹底的満足を受ける実況は、容易に覗い得られぬと云うに止めておく。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の例は深く立ち入ったらどれ位あるかわからぬが、ここでは「江戸ッ子減少」の原因を明らかにするだけに止めておく。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした都会の真ん中を流るる河は、いつもこうした呪わしい、忌まわしい使命を持っていることを説明するに止めておく。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、暇をくれるという話さえ決れば、代りの奉公人の来るまでは勤めてもいいとのことであったが、私たちはいつまでも彼女を引止めておくに忍びなかった。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは予の意志ぢゃ、予を重んじておくりゃらば、顏色を麗しうし、其むづかしい貌を止めておくりゃれ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まア、キタナラしい、そんな話は止めておくれよ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢の赴くところ、彼は到底さういふ控へ目な發言におのれを止めておくことは出來なかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここではただこの古い考えの筋道だけを述べるに止めておく。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでここにはただ、自然科学のすぐ近くまで肉迫していたと思われるかの大哲学者ハーバート・スペンサーの前記の所説（六九頁参照）に注意を促すに止めておく。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆の要求に沿うた内容ということは、いずれの場合でも決して、現代の民衆生活の一番低い部分の水準に迎合して、そこ迄引き下げ止めておくということではない。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評を印象の上だけに止めておくということが所謂印象批評だ。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の先であるいはいろいろ印刷物の表面では民主化、民主化といって、日本の民主化は進行している、きわめてスムースに進行しているというようなことをいいながら、その半面で露骨にファシズムを植えつけて行くことが可能なような社会意識に日本を止めておくことは私ども日本の人民にとって非常に恐ろしいことです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へることが出来る程ならいゝ加減な処で止めておくことなんか出来る筈がありません。",
              "citation": {
                "source": "編輯室より（一九一四年一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもう一歩進んで考へますと、この人格尊重も気むづかしい、然し必要な、細君をつなぎ止めておく為めの方便にすぎなかつたかもしれません。",
              "citation": {
                "source": "妾の会つた男の人人",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を訪問するわけもないし、よしかりに遊びに来たとしても、日が暮れるまでロス氏のほうへ知らせずに引き止めておく家もあるまい。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この沖の只中で船を止めておくのは、エムデンの目標を晒しておくようなものだというので、乗客が血眼になって騒ぎ出した。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が疳癪を起して、湯呑みで酒を飲もうとしたら、毒になるから、毒になるからと言ッて、お前さんが止めておくれだッたッけねえ。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに運ばれてきた火酒の壜からは、相手にだけ奨めて、自分は飲む態に止めておくように、夫人は、眼立たないように注意した。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただ作者の言をここに付記するに止めておく。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
