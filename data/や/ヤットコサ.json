        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから何里も行くうちに二人はもう死にそうにつかれましたが、それでもやっとこさ向うへ着きました。",
              "citation": {
                "source": "二人の男と荷車曳き",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "予科の方は三級、二級、一級となって居て、最初の三級は平均点の六十五点も貰ってやっとこさ通るには通ったが、矢張り怠けて居るから何にも出来ない。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真白い大きい大きい花束を両腕をひろげてやっとこさ抱えると、前が全然見えなかった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、叩くな、何人だろう」　伯父さんはやっとこさ起きあがって、暗い中をさぐりさぐり庖厨の方へ往って土間へおり、足でさなずって下駄と草履をかたかたに履いて、其処の戸を放して裏口へ出た。",
              "citation": {
                "source": "餅を喫う",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとこさ話の出来る処まで来た」「まったく……あのスチームの音は非道いね。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪われた鼻　　　　　　　――運命と鼻の表現（六）　獣からやっとこさと人間へ進化して来た鼻は、初めて地面から手を離して四方をキョロキョロ見廻しました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲留仙は硯を右の手に持ち、左の手に紙と筆とを持ってやっとこさと腰をあげる。",
              "citation": {
                "source": "涼亭",
                "author": "――序に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寝言にしちゃおかしいぞ、人もくるようにないが、それとも何人か泊りにでもくるだろうか」　老人はこんなことを言いながらやっとこさと腰をあげ、すこし頽れて時おり隣の灯の漏れてくる壁の処へ行って顔をぴったりつけて好奇に覗いて見た。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寝言にしちゃおかしいぞ、人も来るようにないが、それとも何人かが泊りにでも来るだろうか」　老人はこんなことを云いながらやっとこさと腰をあげ、すこし頽れて時おり隣の燈の漏れて来る壁の破れの見える処へ往って顔をぴったりつけて好奇に覗いて見た。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お町は後から大きな飯櫃をやっとこさと拘えて来た。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか、そっとだよ」　広栄は平生傍に置いてある松葉杖を執って、それにすがってやっとこさと起ち、境の襖を啓けて入って往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか、それでは」　広栄は松葉杖を執ってやっとこさと起って、定七といっしょに次の室へ往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとこさと、今日はもう箕の輪へだけ廻るとしよう。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストは食卓につくなり、変な眼つきをしてその肉片を見ていましたが、暫くすると口のなかで、皿のなかの油揚山羊ならよいが小猫の肉ならやっとこさで逃げ出しゃれと、二、三度繰り返して言いました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから田圃の中の畦道を横千切りに近道をして走りながら、一直線に温泉鉄道の停車場へ来て、やっとこさと終電車に間に合って、一時間経たないうちに町の宿屋へ帰って参りました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお婆さんは頭巾と覆面で顔をすっかり隠して、片手に短い杖を突き片手に重たい果物の籠を提げて、さも疲れたらしくよぼよぼと歩いていましたが、今紅矢からこう尋ねられると、立ち停まりながらやっとこさと腰を延ばしまして――「はい。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんださか、こんなさか」　それでもやっとこさ、峠のうえまで、ちいさな汽缶車が大きな薪炭を引きあげました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃になってわたしは、いろんなことに慣れもしたし、ことにザセーキン家では、やっとこさいろんなことを見せつけられた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一頁をやっとこさ読んで見たら、こんな風に書いてあった。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かで人間らしいあったかい人づきあいを欠いて、やっとこさと金を溜めて、どうやら家を建てるより子供の教育だ、立派な子孫を残すために、小さい碌でもない財産を置くより子供の体にかけようと熱心に貯金していたら、それがどうでしょう、このごろは金の値打は百分の一になってしまったのです。",
              "citation": {
                "source": "社会と人間の成長",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの二三分もしたであろうか、やっとこさ心を落着けて、それは一体何だろうかともう一度つついてみようとした。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとこさ、うちまでたどりつくと、おかあさんは、ジャックがいなくなったので、すっかり、がっかりして、ひどい病人になって、戸をしめてねていました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとこさと、豆の木のはしごの所までくると、ジャックは、ハープにむかって、「もうやめろ。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人は、やっとこさでそこから足をひきぬきました。",
              "citation": {
                "source": "母の話",
                "author": "アナトール・フランス",
                "note": "青空文庫"
              }
            },
            {
              "text": "上瞼の凹んだまるで白粉っけのない顔で、癖で少し右肩を振るようにしながら、「――惜しかった、やっとこさ三年があすこまでのり出したのに」と云った。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は水棲人のやつがなにを抛ったのだろうと、大蕨を折ってやっとこさで掻きよせた。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしゃあ考えました、こりゃあやっぱしええ学校に上げなくっちゃ嘘だとね……区役所で通知を貰うんには骨も折りましたが、はあ、いいあんばいにやっとこさこんな立派な学校へあげることができて――これ、忠！",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "年といったらやっとこさ十五、それでいて仕事は一人前さ」「だが相手の大将も、尋常の奴じゃアないんだからな」やっぱり猪右衛門は不安らしい。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとこさ今しがた床から起き、ざっと顔を洗ったばかりで、まだ朝化粧も施していず、寝巻のままで縁へ出て、そこに釣るしてある金糸鳥の籠を覗き、あっちへ飛んではパチパチと啼き、こっちへ飛んではピ――チクと啼く、ばかに元気のよい小鳥の動作を、微笑しながら見ていた時だった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
