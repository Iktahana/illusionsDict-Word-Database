[
  {
    "uuid": "15a96de4-a1a2-5069-b383-850a65fd42ed",
    "entry": "柳樽",
    "reading": {
      "primary": "やなぎだる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
