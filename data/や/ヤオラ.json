        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてやおら立上った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えらく、源叔父今はいかん、波の音ききつつ古き春の夜のこと思いて独り炉のかたわらに丸き目ふさぎてやあらん、あるいは幸助がことのみ思いつづけてやおらんと。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "面の色は変えたれども、胸中無量の絶痛は、少しも挙動に露わさで、渠はなおよく静を保ち、おもむろにその筒服を払い、頭髪のややのびて、白き額に垂れたるを、左手にやおら掻上げつつ、卓の上に差置きたる帽を片手に取ると斉しく、粛然と身を起して、「諸君。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようなら」　渡瀬はやおら腰を上げにかかったが、また酔のさめるのが不安になった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云いながら、彼は始めて私から視線を外ずして、やおら立ち上った。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と殊勝らしく眼を擦り赤めてやおら病院を退出ぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表皮と裏皮に、さらに心を籠めた息を吐きかけると、やおら肩に当てて打ち出した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "申すまでもなくこの家にこの鼓が……」　とやおら顔を上げて鼓から二人の顔へ眼を移した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、やおら御質問。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまた柳の根方に片足かけ、やおら二本目の煙草を喫ってから、見残した芝居の幕のあとを見届ける気持で、半町ほど距った人混の中のかの女を追った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下唇をぐっと突き出して、しばらく考えてから、やおら御質問。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がぶがぶ大コップの果汁を飲んで、やおら御意見開陳。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両々｜相対峙して譲らず、一時はこのために会が決裂するかとも思われたが、その時、座長の近衛篤麿公が、やおら立ち上って、支那の革命を主張せられる御意見も、また、清朝を支持し列国の分割を防止せむとせられる御意見も、つまるところは他国に対する内政干渉であって、会の目的としては甚だ面白くない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは十目の見るところ、百聞、万犬の実、その夜も、かれは、きゅっと口一文字かたく結んで、腕組みのまま長考一番、やおら御異見開陳、言われるには、――おまえは、楯に両面あることを忘れてはいけません。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やおら、手を伸して紫の影を引くと、手巾はそのまま手に取れた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその苦しく衝上げた金属製の皮膚下の板を、やおら引き下げるために、わざとにっこり笑った顔を突き付けるように池上の方へ向けて、「あら、あの若いおきみさんと二人並べて見較べられちゃ、あたしとても敵わないわ」　と言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、思い切って絵葉書を破り捨て、やおら立上って覚束ない口振りを真似、「さあ、やりましょーう」と言うのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に顫えてもいないのを見ると、そうでもないと安心している私の眼の前へ、やおら擡げて来た先生の顔を見て、わたくしは驚かないではいられませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋の橋の上で裸の大の字になりなさい」と言ったところでわたしが傍にさえいたらわたしの方を子供のようにちろ／＼頼りに見ながら群立つ人々を人臭いとも思わず、赤子の寝起きのようにやおら裸の大の字になり得る女だった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やおら白い眼と白い牙をむいて「何だ貴様は」という表現をします。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、自室で座りながらそのことに考えを巡らせていると、やおら戸が開いて、モリアーティ教授が僕の目前に立っているではないか。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどなたかは知らないけれど、眼光鋭い女性記者はやおら「東芝が自分のところのマシンにダイナブックという名前を付けておる事態を、あなたはどう受けとめておるか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる席に列なりては、口利くだに慚ずかしきものを、いざさらば帰るべしとて、思うままに言い罵り、やおら畳を蹶立てて帰り去りぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向で欲しけりやおら兼の野郎呉れつちやつて構あねえ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の院の窟の案内頼みたき由をいい入るれば、少時待ち玉えとて茶を薦めなどしつ、やおら立上りたり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると死はやおら物憂げな腰を上げて、そろそろとその人に近寄って来る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて漁夫たちはそこらを片付けてやおら立ち上がると、胴の間に降り積んだ雪を摘まんで、手のひらで擦り合わせて、指に粘りついた飯粒を落とした。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土下座せんばかりの母親の挨拶などに対しても、父は監督に対すると同時に厳格な態度を見せて、やおら靴を脱ぎ捨てると、自分の設計で建て上げた座敷にとおって、洋服のままきちんと囲炉裡の横座にすわった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だぶだぶのズボン一つで、節くれ立った厚みのある毛胸に一糸もつけない大男は、やおら人中から立ち上がると、ずかずか葉子に突きあたらんばかりにすれ違って、すれ違いざまに葉子の顔を孔のあくほどにらみつけて、聞くにたえない雑言を高々とののしって、自分の群れを笑わした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
