    "definitions": [
      {
        "index": 1,
        "gloss": "to excuse (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まあ、二、三日は学校を休ませるつもりだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心得のある老紳士はそっと彼女に背を向け中庭の薄明が室内の電燈と中和する水色の窓硝子に疲れた眼を休ませる。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだは牛を休ませるために、綱を解いて置く。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき王さまは、エリーザを休ませるためことに用意させた、そばのちいさいへやの戸を開きました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁は私の腦髓を休ませるものではありません。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸すなという掟のある宿を借りて、ひょっと宿主に難儀をかけようかと、それが気がかりでございますが、わたくしはともかくも、子供らに温いお粥でも食べさせて、屋根の下に休ませることが出来ましたら、そのご恩はのちの世までも忘れますまい」　山岡大夫はうなずいた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして渋りがちな筆を休ませる間に、今まで書き連ねて来たような過去の回想やら当面の期待やらをつぎつぎに脳裏に浮かばしていたのだった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用があったら呼ぶからと云って、お幾を女部屋に休ませる。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起の兄も、郷里の方から出て来たお母さんを休ませるために、床を離れずにいる様子であった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "滋養物を取らなければ不可――働き過ぎては不可――眼を休ませるようにしなければ不可――種々に言われて来た。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "産業別の各組合が、それらの「休みの家」を持っていて、賄つきで組合員を休ませるのであるが、どの「休みの家」も実に立派なものだ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して休ませるには及ばん。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は節子や子供等を休ませるために往きに節子が寄って花を買った家の附近を探した。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く寒かった間は、岸本は谷中の方に居る時の彼女の骨の折れることを思って、自分の家では寧ろ彼女を休ませるくらいにした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は家事の一切を引きうけて台所の世話から客のもてなしから朝からせわしくとっと、とっとと働きながら、夜は、疲れた看護婦と母を少しなりとも休ませるために四時位までずつうす赤いスタンドの下に本を並べて起きました。",
              "citation": {
                "source": "二月七日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は馬を休ませるためで、第二には自分も何か少し食べて元気をつけるためであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論これはほんとうの退校でなくて、少しばかりの間、学校を休ませるということだろう。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしはたしてこの二十年間は、全然無意識に過ぐるものであるか、またもしなんらかの意味があるとすれば、意識的の時間すなわち四十年の意識時間を休ませるだけの作用あるものであるか。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は僕を休ませるために社の倶楽部とかいう二階建の建物の中へ案内しました。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、にこにこ笑って、その病める火星人に、ゆっくり体を休ませるように言った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その低俗な満足が結局左門を休ませる。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、これに対する返事を認めておこうと兵馬は、傍の料紙硯を引寄せましたけれど、少し疲れているためと、頭を休ませる必要から、また仰向けになって眼を閉じていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪病をつつむ腐りし肉の上に、爛れたその心の悲しみを休ませるのである。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら、彼等を立ち止らせて休ませるたびに、左側の先導馬は、いかにも並外れて勢のある馬らしく――頭や頭に附いているすべてのものを激しく振り動かし、こんな丘へこんな馬車を曳き上げるなんてことが出来るものかと言っているようだった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、その手をちょうど彼の破滅させられた頭をそこに休ませるかのように、自分の胸の上に組み合せた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば八時間くらい照射して、次に四時間暗くして休ませるというふうにすれば、どんどん生長するであろう。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また雨が降れば休ませる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この突風は心身過労のイエス様を休ませるための神の恩恵の計らいでありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　弥吉は、恐る恐る、一つには児太郎を休ませるつもりだった。",
              "citation": {
                "source": "お小姓児太郎",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかましいのがさわり、脳溢血でも起されては大変だと思うので皆をかえし、ゆっくりやすませる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
