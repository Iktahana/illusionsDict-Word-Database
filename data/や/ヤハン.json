  {
    "uuid": "b72dd864-b5ac-59f2-8bd0-d8c328f37a43",
    "entry": "夜飯",
    "reading": {
      "primary": "やはん",
      "alternatives": [
        "よめし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dinner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜飯田さんとたい子さんが唄いながら遊びに来る。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………　じゃ今夜飯田町から……　終列車……　エ……　ここで待っててネ……　妾がお金を盗み出して来るから……　二千円位あってよ……　…………　三平はビックリして又のぞいた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になって、佐藤氏も来られ、夜飯頃倉知氏が見えると、話はすっかり陶器の方へ入って岡田さんは、酒をのんでは、メランコリーな表情をして居た。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしよう、子供人工営養で夜飯はいられない、といううちに五銭がなくて切れてしまう。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜飯後、ラジオをかけて、上野寿々本の中継コンニャク問答をきく。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩飯の後で、母屋から此處へ食物か呑物を運んで來なかつたか、――誰か用事か何にかで來たものはないか、――昨夜飯の後で外へ出た者は誰と誰で、出なかつた者は誰と誰か、詳しく調べて來てくれ」　平次は八五郎に細々と言ひ付けて、それから今朝死骸を見付けたといふ、番頭の有八を呼びました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "北冥の魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜飯の後で外へ出なかつたのか」「何處へも出ません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "北冥の魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相吉と辨次郎は、二人共｜昨夜飯を食つたかい？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相吉と弁次郎は、二人とも昨夜飯を食ったかい？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜飯後、これも全く珍しく、つよいアクセントの言葉をきいて、愉快だった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い萱や光る茨やけむりのような穂を出す草で一ぱい、それにあちこちには栗の木やはんの木の小さな林もありました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな主人に巻き添いなんぞ食いたくないから、みんなタオルやはんけちや、よごれたような白いようなものを、ぐるぐる腕に巻きつける。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い萱や光る茨やけむりのやうな穂を出す草で一ぱい、それにあちこちには栗の木やはんの木の小さな林もありました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――うちと夫婦になりたいと言やはんねん」「…………」　他吉の顔の筋肉がかすかに動いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、僕と結婚したら……」「――あんた、平気で冗談言やはんねんなあ」「――冗談や思てるのん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子「中瀬古さんは見合いしやはんのね」鶴三「男も年頃になれば見合いもするさ……」葉子「うちかテ、見合いしようかしら？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　君枝は首垂れて、蚊の音を聴いていたが、ふと顔をあげると、耳の附根まで赧くなり、「次郎さんな、うちと夫婦になりたい言やはんねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蝶子は「私のこと悪う言やはんのは無理おまへん」としんみりした。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『歎異抄』に「念仏はまことに浄土に生るゝ種にてやはんべるらん、また地獄に堕つべき業にてやはんべるらん、総じてもて存知せざるなり」といえる尊き信念の面影をも窺うを得て、無限の新生命に接することができる。",
              "citation": {
                "source": "我が子の死",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父よ、もしみこころにかなはばこの杯を我より離したまへ、されど我が意のままをなすにあらず、唯みこころのままになしたまへ」とか、「念仏はまことに浄土にむまるるたねにてやはんべるらん、また地獄におつべき業にてやはんべるらん、総じてもて存知せざるなり」とかいう語が宗教の極意である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つるやはんならそこどすがな。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏はまことに浄土にむまるるたねにてやはんべるらん、また地獄におつる業にてやはんべるらん、総じてもて存知せざるなり。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、木版画や錦絵を並べている店を私共は「絵やはん」と呼んでいました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絵やはん」の前を通るとこれが目に止まり、絵がほしくてたまらなくなりました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも道で人に逢ふと、「するがやはんの蚊帳洗濯や。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬が飛びあがったのは事実だが、今度は道の向う側の茨やはんの木のしげみに飛びこんだ。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん朝になつてはいつそう苦しいのでしたけれど、モンペをはき、きやはんをつけると気が張り、またどうやらその日一日がつゞけられるのでございました。",
              "citation": {
                "source": "早春箋",
                "author": "辻村もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駒はものいひたげに、もぢもぢとしてやがて、　あのお母アさん、焼餅たらいふものおくれやはんか。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞお母アさん何も御心配おしやはんと……　さりげなくいふお糸の胸は、乱れ乱れてかきむしらるるやうなり。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やすくいへばわらのきやはんなり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
