        "examples": {
          "standard": [
            {
              "text": "隣家の不始末による火事で、私の大切にしていた蔵書はすべて焼け失せてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "空襲の被害に遭い、街の歴史を物語る古い建造物の大半が焼け失せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "避難所から戻ると、自宅があった場所には何も残っておらず、家財道具は無残にも焼け失せていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その夜わたくしは、前々から諦めはつけていた事でもあり、随分悠然として自分の家と蔵書の焼け失せるのを見定めてから、なお夜の明け放れるまで近隣の人たちと共に話をしていたくらいで、眉も焦さず焼けど一ツせずに済んだ。",
              "citation": {
                "source": "草紅葉",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今其所有物である校舎、殊にその六角塔が焼け失せるとはどうして思ひ得よう。",
              "citation": {
                "source": "父の死",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
