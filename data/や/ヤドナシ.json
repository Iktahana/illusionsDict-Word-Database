        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宿無しだッてことはお綾｜様承知の上だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠国の者ではあり、下谷あたりの木賃宿にころがっている宿無し同様の人間ですから、死ねば死に損で誰も詮議する者もない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて普通の宿無し乞食とも思われない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一には宿無しの次郎左衛門に自分のからだを任せたくはなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、後に至つてこの物語のつながりが如何に辿られたか、又宿無しのヂプシが彼女のあどけない美しさにひかれて、あの九月の日にアグレイアを盜み去つてからどうしたかといふやうなことを、讀者諸君に語るであらう。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しも今日はゆず湯の男哉　二十二日は寒い雨が降った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまた宿無しが一句うかんだ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しが風呂桶を買ふ暑さ哉（大正13・７「読売新聞」）郊外生活の一年　震災以来、諸方を流転して、おちつかない日を送ること一年九ヵ月で、月並の文句ではあるが光陰流水の感に堪えない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、里見の領内の乞食や宿無しのたぐいは一掃された。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる蒲鉾小屋で、そこに住んでいる者は宿無しの乞食であることを喜兵衛は知っていた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月のひかりに照らされた彼の風俗はまぎれもない乞食のすがたであるが、年のころは二十七八で、その人柄がここらに巣を組んでいる普通の宿無しや乞食のたぐいとはどうも違っているらしいと喜兵衛はひと目に見たので、おのずと詞もあらたまった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人とはいえ、相手は宿無しの乞食である。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しが風呂桶を買ふ暑さ哉（大正十三年七月）",
              "citation": {
                "source": "風呂を買うまで",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しはこゝで澤山だ。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "路通　　おれはこの姿で東海道の松原に寢てゐるところを、芭蕉の翁に見つけられて弟子の一人に取立てられたが、人間並の生活はおれの性にあはないと見えて、師匠にさんざん叱られた上に、二三年前から再び元の宿無しだ。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しの乞食野郎め。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しでも寢るところは何處にかある。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今までトルストイの手元ばかり見詰めてゐた乞丐は、吃驚して跛足をひきひき、宿無し狗のやうに直ぐ前の歴山公園の樹蔭に逃げ込んでしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ黒がいけません」　こう言いながら、お菊は穢い宿無し犬に追われて来た。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無し犬の黒は私の前を通り過ぎた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふたたび猫・猫・猫――何てまあ宿無し猫みたいな人間と、人間のような棄て猫とがじつに仲好くうようよしてる無秩序そのものの古河ＬＩＳＢＯＡ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九人おりますが、みなそれぞれ不幸な運命のもとに生まれた人ばかり、白髪の老人や、切髪の奥様や、宿無し児や若い娘などもおります。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎ去つた快樂は現在の自分を滿足させるに足りないのに、矢ツ張り、こんなところにこびり付いてゐるのは、宿無し犬が掃き溜めの汚物に飢ゑをつなぐと同樣、ここに自分の苦痛の必然な餌じきを求めてゐるのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦家へ帰ると、今度は人を恐れて縁の下へもぐりこんだ宿無し犬のように、一歩も外へ出ようとしない。",
              "citation": {
                "source": "情状酌量",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿無しや立ん坊が私窩子をひきずりこむ処である。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ猫だけが知っていて、宿無し猫が無数に集ってきていた。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかのやどなし犬でしょう。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
