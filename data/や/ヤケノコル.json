      {
        "index": 1,
        "gloss": "to escape being burned (esp. of a building or the items in it)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
