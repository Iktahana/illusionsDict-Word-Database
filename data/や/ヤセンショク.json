        "examples": {
          "standard": [
            {
              "text": "兵士たちはリュックに野戦食を詰めて出発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦場では、温かい野戦食は貴重なものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この野戦食、意外と美味しいな！」と新兵が驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "手にした野戦食は、柏の葉でくるんである色の黒い握り飯だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずは酒に体でもあたため、こよいは充分に身を養っておけ」　と、野戦食を喰べながら評議にかかった。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこへ兵糧の朝餉が運ばれて来たのを機に、正成はそれ幸いに、さいごの貧しい野戦食を正行と向いあって摂りながら、幕舎の外へ命じていた。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
