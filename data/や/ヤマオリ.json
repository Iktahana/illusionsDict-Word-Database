        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "紙を半分に折って、山折りと谷折りを交互に繰り返して鶴を折る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この複雑なモデルは、たくさんの山折りと谷折りを正確に行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは、簡単な山折りと谷折りで動物の形を作るのに夢中になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さて、この文字面を表にして、一番上の水平点線を山折り、順に谷折り山折りして、一番下の水平点線まで蛇腹に折り畳み、細長い短冊にします。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、この短冊の文字面の右端側から、縦点線を山折り谷折りします。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "順に左側へ蛇腹に畳み、最後の縦点線を山折りして完了です。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "先端の裳裾を開いて、文字面を出した状態で、右端から、山折り谷折りして蛇腹状に折り畳めば、第三、第四の文字が現れます。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
