    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gentle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、まあこのおしまひの手合なんぞは、云つてることに何の意味もないにしてからがチヨイト頭を捻ること言換れば位置にお構ひなしに移動の万能範囲を拡げることが、いとも優秀なことのやうに思はれることは現時の流行感冒である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ音楽やリズムといふことに対しては優れた感覚を有してゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の十九世期の一仏蘭西女、此のフェイドオ劇場の一女優、此の巡業家の妻、此の子供を育てるに実に良心的でやさしさ此の上もなかつた一小市民――それがコリンヌ風な意味ででもサッフォ風な意味ででも抒情的な詩人であつたといふわけである。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち、右の二つの場合に就いてみると、心理的優秀といふことは、必ずしも実質的優秀を意味しない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は、Ａが金持でＢが貧しい場合だが、もしそれが反対であつても、必竟ＡがＢを、「あんな奴でも偉いのかなァ」と思ふ、つまり交際の上でＡがＢより優勢になることは同前なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の頃ジュル・ラフォルグは、象徴派作家達の中で優勢な位置を占めてゐた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴派詩人達は殆んど女のやうな優雅さを持つてゐた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を見合せれば「神」や「義務」の話をする叔母を除いては、その夏休みは優に懐かしい夏休みであつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――可愛くもあり、面倒でもあり………さうだ可愛くもあり、面倒でもあり、可愛くもあり、面倒でもあり、可愛くも………（女コーヒーを立てゝ持つて来る）女　（優しく）お飲みなさいな。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姑の婦人もまた、旧武士の家庭に育った士族の娘で、純日本風の礼儀正しき教育を受け、かつ極めて善良に優しい心根の人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから優れた作品なのだ、というわけでは無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の敗者たるもの、この優しい慰めに接して、泣かじと欲するも得ざる也。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木が好きで、學校のぐるりに樣々の植木を、優雅に配置し、ときどき、ひとり、兩手をうしろに組んで、その植木の間を、ゆつくり縫つて歩いてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、山崎氏には、浅見、尾崎両氏の真の良友あり、両氏共に高潔俊爽の得難き大人物にして帷幕の陰より機に臨み変に応じて順義妥当の優策を授け、また傍に、宮内、佐伯両氏の新英｜惇徳の二人物あり、やさしく彼に助勢してくれている様でありますから、まずこのぶんでは、以後も不安なかるべしと思います。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物質的」に「精神的」は圧へられてゐるので、精神はスキマからチヨツピリ呟くから神秘的に見えたりするけれど、もともと東洋で精神は未だ優遇されたことはない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――我国の女がまことに無表情に出来てゐることを知つてゐる者のその誰でもが今彼女の夫に対してしたことは、まあ女優か何かにしか思へなかつたのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫といふのも妻君と同し映画会社の、俳優監督係なる役にある男だつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督係なるものが、如何に俳優に嫌はれてゐるかといふことはそれ程説明の必要もあるまい。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "………「あゝさう、俳優達の悪口だ」、――彼は今社長の前へ来てから始めてホツトした。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "………それから愚にもつかない話を、例へば俳優の私生活などを色んなに捏造しては曝け出してお目に掛けた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「………あゝなる程………成程、」　不器量であり、不器用である妻君の女優は、本当のことを言つたら三流四流といふ所でなければならなかつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども竹山俳優監督係夫人といふことは、盲同然の人間の寄り集つてゐる所ではその人間の価値如何のどんなに大切な標準器になるかは言ふまでもない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで妻君は一流の三四人中に数へらるべき所謂スター女優なのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに朝など俳優部屋の、最も奥の鏡台に着く時など、妻君自身は余り好い心地はしなかつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあね………」と妻君は俯向いて揃へた指を伸ばして、女優的しなを作つたりしてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻君の話の役に立つた細つそりした女優とは、それは妻君の顔と、即ち雲泥の差を有つてゐたのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給日といへば女優部屋などは、普段とは和気の可なり横溢してゐるものだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の細つそりした女優は、自分よりも新参者の出来たことを、その和気の横溢した中でモヤモヤと感じた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いつたい此の会社の社長といふ男は、会社としての収入のみを考慮の中に入れたが、俳優其の他の傭入や解雇は、全然竹山俳優監督係に任せ切りだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
