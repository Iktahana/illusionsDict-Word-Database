    "definitions": [
      {
        "index": 1,
        "gloss": "to have a go",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三次が、「旦那Ｔ「神信心って奴もやって見るとまんざら悪かァ御座んせんね」　と言って「急ぎやすから御免なせえ」と其の儘スタスタと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただやって見るのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、真実の処、能のヨサの正体をこれ以上に説明すると、第二義、第三義以下のブチコワシ的説明に堕するので、能のヨサを第一義的に自覚するには「日本人が、自分自身で、舞いか、囃子をやって見るのが一番捷径」と固く信じている者である。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち豊吉はたちまち失敗してたちまち逃げて帰って来るような男ではない、やれるだけはやって見る質であった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三、その仕事を一ぺん自分で二日間やって見る。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は別にやって見たいともやって見たくないとも思って居なかったが、そう言われて見ると、またやって見る気がないでもない。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「……まあ……」　二三度やって見ると、どうも、顔の動くとおりに動く。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら怖ごわ花の木の方に眼をやって見ると、木は金茶色の花を一めんにつけて静に立っていた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、真実のところ、能のヨサの正体をこれ以上に説明すると、第二義、第三義以下のブチコワシ的説明に堕するので、能のヨサを第一義的に自覚するには、「日本人が、自分自身で、舞か、囃子をやって見るのが一番｜捷径」と固く信じている者である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "放してやって見ると、やっぱり土に飛びついたまま再び動けるようすもない。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分でやって見るといいや、これ以上おれたちの腕にゃ合わねえんだから」三上はいよいよ打っつけるようにいい切った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに言う、秀郷の巻絹や俵どころでなく、如意瓶とて一切欲しい物を常に取り出して尽きぬ瓶を作る法が『大陀羅尼末法中一字心呪経』に出で居る、慾惚けた人はやって見るが宜しい。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学分析をやって見るに著しく燐を含めりとか。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五分でどうやって見るんだよ」　高志はふりかえらずにいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけのものをひっぱってゆけるかね」「ぼくもわからないが、なあに一生懸命やって見るよ」「じゃあ、ひとつやって貰おうか。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、冗談に云ってるんじゃないぜ、俺は何うあってもお前から聞き出すよ」「出来るなら、やって見るがいいわ」彼女は冷かす様に云った。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験者は研究中のことですから、いろいろやって見る必要があります。",
              "citation": {
                "source": "科学が臍を曲げた話",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ手探りでやって見るんだ。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけの準備計画があっても、やって見ると容易に思うように行かない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るものならやって見るがよい」「何？",
              "citation": {
                "source": "卑怯な毒殺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るか出来ないか知らないが、まあ僕もやって見る」　とも附加した。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し実際にやって見ると、階級的自己批判としての諷刺文学は、あるいは画よりも困難をもっている。",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、母が死んで、自分でうちの細かい会計までやって見るとなると、これが急に目立って来たのかも知れない。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンのためとあるからには、いろいろおかしなこともやって見るがいいさ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう次第でその場に居合わせた私などは、事実多少懐疑的にもなったのだが、処が併し、実際に演説をやって見ると意外にも決してそうではないということが判って来た。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なからぬ困難が予想されるが、私は読者の忍耐と誠意と自身の熱意とに信頼して、この仕事をやって見る。",
              "citation": {
                "source": "意味深き今日の日本文学の相貌を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人生に明らかな知性と豊かで健全な人間的情熱の発動を熱望する一人の作家が、今日の現実を見る勉強としてやって見るつもりである。",
              "citation": {
                "source": "意味深き今日の日本文学の相貌を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あることに動こうとする自分の本心が、人間としてやむにやまれない力におされてのことだという自信があってこそ、結果の成功、不成功にかかわりなく、精一杯のところでやって見る勇気を持ち得るのだと思う。",
              "citation": {
                "source": "自信のあるなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は果してよく期待にそむかないような仕事をなしおうせるかどうか勿論やって見なければならないが、今の自分の気待では出来るだけやって見る積りだ。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、降り、私がやって見る」　母親は、小学校というものもなかった時分に育った婆さんだから、高等小学を出たぬいより、機械なんかいじるのはもっと下手であった。",
              "citation": {
                "source": "杏の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
