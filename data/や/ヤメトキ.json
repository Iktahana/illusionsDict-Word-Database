        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「お祖父ちゃん、もう今年は良え加減に、鎧みたいなもん着るのん止めときなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "止めときます」　とは咄嗟にどうしても出なんだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう良え加減に、鎧みたいなもん着るのん止めときなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ他に多くの苦情もあるのですがこの位で止めときます。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずガラス絵としての大略の事を申したつもりです、長くなりますからこれで止めときます。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「左樣ですな、――止めときませう。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからそんな金もらうのやめとき」　そう西に念を押される前に、古川は申し入れを断って両親にアメリカ行きの資金をねだる気持ちに傾いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そないな話、やめとき……親爺が苛々と言ふ。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯一郎　　やめときませう。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田氏はタジタジになり、坐りなおしてお辞儀をすると、太田夫人は八つ手の葉のような大きな手を振って、「石田さん、やめときなさい……こいつはですね、米国工学士などと自称しとるが、なんのことやら、わかったもんじゃないですよ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと、買い物をしたいから、……」「お京さんへの土産なら、やめときなせえ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胃がわるくて元気がないからやめときましょう」。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、明日はやめときましょう。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
