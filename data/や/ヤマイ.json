    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mountain well",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水の少いその山畑を作る人の掘ったものであろう、二丈余りある深い山井戸であった。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無間山井遷寺は聞きしにまさる雄大な荒廃寺であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『続｜山井』、鷹の峯のつち餌になるな犬桜　　　　宗房しゝ食うたむく犬は鷹の餌食かな　　勝興と。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も校勘學に於ては、儒家に於て徂徠門下に當時已に山井、根本諸人の如きあり、佛家にも忍澂和上の如きありたれば、此の一事は敬首和上の特見とし難し。",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "山井大納言は六月十一日に亡き人となった。",
              "citation": {
                "source": "余録（一九二四年より）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同仁病院長｜山井博士の診断に従えば、半三郎の死因は脳溢血である。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも山井博士の信用だけは危険に瀕したのに違いない。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "常子は夫を見つめたまま、震える声に山井博士の来診を請うことを勧め出した。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし常子、マネエジャア、同僚、山井博士、「順天時報」の主筆等はいずれも彼の失踪を発狂のためと解釈した。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同仁病院長山井博士の説によれば、忍野氏は昨夏｜脳溢血を患い、三日間｜人事不省なりしより、爾来多少精神に異常を呈せるものならんと言う。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしマネエジャア、同僚、山井博士、牟多口氏等の人びとは未だに忍野半三郎の馬の脚になったことを信じていない。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは北京滞在中、山井博士や牟多口氏に会い、たびたびその妄を破ろうとした。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後又十餘年を過ぎて外山井上兩博士は共に明治廿八年初刊の「帝國文學」紙上に時々詩を發表した。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "参考歌に、「安積香山影さへ見ゆる山井の浅き心を吾が念はなくに」（巻十六・三八〇七）がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッフェープランタンの創設せられた当初、僕は一夕生田葵山井上唖々の二友と共に、有楽座の女優と新橋の妓とを伴って其のカッフェーに立寄った。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員の中押川春浪黒田湖山井上唖々梅沢墨水等の諸氏は既にこの世には居ない。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ、検事局から、山井検事が、書記を連れて、出張して来た。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五）　中肉中背、濃い眉毛と少し大き過ぎる締った口の外には特長のない、眼鏡も髯もなく、毬栗頭で、黒の背広に鼠色のネクタイという、誠に平凡な外貌の山井検事が、大兵肥満で、ガッシリした、実行力に富む署長と、相対した時には、佳いコントラストを為した。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体を巨細に視た上、煤けた部分を払わせて、熟々と眺めて居た山井検事は、更に頸の部分、手拭の巻きつけてある工合や、頸に喰い込んでる有様等、詳細に観察した後、二三の質問を、警察医に発した。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者が『論語』本文の研究史において右の二つの流れに劣らず注目すべきものとしたのは、伊藤仁斎や山井｜崑崙などの、「シナにおいてはかつて考えられなかったような日本特有の論語に対する見解」である。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士族の尊いお方をも、いやしい穢多をもひとしくうやまいます。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）僧団上首の一人　――うやまい奉る無上尊。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うやまい奉る御教の数々。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちやまいすたれるやうに思はれるのも、いやだからねえ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか私のうやまいを受けとってください」　虹は大きくといきをつきましたので、黄や菫は一つずつ声をあげるように輝きました。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うやまいを受けることは、あなたもおなじです。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生どうか私のこころからうやまいを受けとって下さい。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに皮膚のやまいを嫌っているので、自然と用心深く、いままで、ほとんど吹出物の経験なぞ無かったのです。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく心づきてみれば、メエルハイムが言葉も振舞いも、この君をうやまい愛ずと見えぬはなし。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "参朝すると六卿がうやまいあわてて、※をあべこべに穿いて出て迎えた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
