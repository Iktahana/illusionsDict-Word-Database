  {
    "uuid": "b56cb8f9-3ce0-57aa-9394-b2ff66688bec",
    "entry": "山井",
    "reading": {
      "primary": "やまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
