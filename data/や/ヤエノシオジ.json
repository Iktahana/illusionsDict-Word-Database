        "examples": {
          "standard": [
            {
              "text": "船は八重の潮路を越え、はるか異国の地へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の心は、八重の潮路を旅する船のように自由だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "故郷を離れ、八重の潮路の向こうに新たな生活を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その間に「年波」、「八重の潮路」、「渡守」、「心なるらん」などの歌詞はきれぎれに打誦ぜられき。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "信天翁　　　　　シャルル・ボドレエル波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生檎りぬ、楫の枕のよき友よ心｜閑けき飛鳥かな、津潮騒すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "信天翁　　　　　シャルル・ボドレエル波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生檎りぬ、楫の枕のよき友よ心閑けき飛鳥かな、奥津潮騒すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルル・ボドレエル信天翁波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生擒りぬ、楫の枕のよき友よ心｜閑けき飛鳥かな、奧津潮騷すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "満願の日、導師三井寺の公顕僧正は高座にのぼり、鐘を鳴らして表白を声高らかに読みあげていわく、「九重の都を出でられ、八重の潮路をかきわけて、ここまでお出でになられた陛下の御心はかたじけない極みである」　この神前に捧げられた言葉には、上皇を始め諸臣みな感激した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは近江の国の琵琶の湖、日本第一の大湖でございますが、行方も知らぬ八重の潮路とは違います、それだのに、米友さん、お前さんの、今のその漕ぎっぷりを見ていると、本当に下関まで、この舟を漕ぎつけて行く呼吸でした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
