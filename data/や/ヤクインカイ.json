        "examples": {
          "standard": [
            {
              "text": "新規事業の承認を得るため、来週の役員会でプレゼンを行う予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "役員会での議論は深夜まで及び、最終的に合併の延期が決定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "議事録を作成するため、秘書として役員会の隅でメモを取り続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "組合本部の役員会がある筈なれど差支える事があって往をやめた十五日　朝根室｜分娩牡犢である。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "松尾氏も若井氏も共に美術協会の役員であったので、或る日の役員会に一同が集まっていました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "鶏の製作を引き受けたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪業　ある地区で商業報国会の役員会が開かれ、警察の経済関係官から一場の訓示があつた。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
