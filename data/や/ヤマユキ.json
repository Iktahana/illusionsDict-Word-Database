    "definitions": [
      {
        "index": 1,
        "gloss": "snow that falls on mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水郷の早春黒髪三品山色連天葦の芽あをむ水ぎはに、黒髪梳くや子の母、うなじの白さ、つめたさ、遠山雪のはるけさ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて高山雪上に映る物の影は紫に見える故、支那で濃紫色を雪青と名づく（一九〇六年二月二十二日の『ネーチュール』三六〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "白根山雪を帶びて、その頭だけを連山の上に露はす。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの碁盤忠信のごときは彼が専売であるにもかかわらず、吉野山雪中の立廻りなどは、猿之助の横川覚範にかえって薙ぎ立てられる形で、大鎧をきて重い兜をかぶって奮闘する彼の太刀先や足どりがとかくにみだれがちであるのを、私ははらはらしながら見物していた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○家に居なくなった母　○雲が母の顔に見える　○子供山の向うに行ってしまう　　　　　○茅野　○かんてんをつくる木のわく沢山雪の上にある。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬になると全山雪に覆われてしまう時が時々あって、しみじみと雪の山の美しさを味わわせてくれるのである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "初期のこの派の宗匠の生花の記録があるが、それは山雪や常信の花の絵をほとんどそのままにうつし出したものである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山林に自由存す』といふ詩も、『遠山雪』といふ詩も、『翁』も『去年の今日』も皆その丘の上の家で出来たのだ。",
              "citation": {
                "source": "丘の上の家",
                "author": "抄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又譬へば、「可消」にかゝるにしても、「零雪虚空」「天きらし零来雪之」「豊国之木綿山雪之」と言つた風に、重くるしい修辞を整へること、「佐保山に立つあま霧の」の場合と同じ事である。",
              "citation": {
                "source": "副詞表情の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平賀元義の歌に、「鏡山雪に朝日の照るを見てあな面白と歌ひけるかも」というのがあるが、この歌の「面白」も、「おもしろくして古おもほゆ」の感と相通じているのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえにわが日本人民は、氷山雪屋のうちに住するエスキモーのごとく鯨油を飲み、海豹の肉を食い、寒気と戦わんがためにこの世に生活するものにあらず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵那山雪中の大合戦以来とんと掛け違ってお目にかかりませぬで」　数馬にとってその声ばかりは聴き覚えあるように思われた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠見場まで登ると林が尽きて一時に眺望がひらけ、全山雪のような花崗岩の細砂に掩われた駒ヶ岳の八合目から上が眼前に展開した。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御岳では二の池の西側に僅かしかなかったのですが、乗鞍には沢山雪が残っていたので、これは御岳より高い山ではないかと思って残念なような気がしたのでした。",
              "citation": {
                "source": "木曾御岳の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四山雪なおうずたかきにもかかわらず、陸上は七十度以上の温度にして、夏服を要するほどなり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月遊欧北、那山雪幾堆、渓頭移歩去、樹下凍風来。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "千湾万曲の岸頭に、脈々の岩山雪をいただきて走るを見る所、毫もノルウェー西岸と異なることなく、その風光の美は二者伯仲の間におる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　　瑞西初夏（瑞西の初夏）駅路春風過、瑞山雪漸消、客楼人未満、湖畔夏寥寥。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも沢山雪の広く積ってある所はそれほど巌も厳しくもなし、まあ平坦になって居りますから登り易いがそうでない所は実に危ない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山雪路の長旅苦しい中にも遙かに北を眺めて見ると、チベット高原の山々が波を打ったごとくに見えて居るです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "リオン、モンペリエ、ニースを過ぎて、地中海の岸にヨウ素を探し、翌一八一四年の正月終りには、六千尺のコール・デ・タンデの山雪を越えて、イタリアに入った。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月八日　〔巣鴨拘置所の顕治宛　駒込林町より（小山敬三筆「高山雪景」の絵はがき）〕　十一月八日。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺生は好まない私も、全山雪に埋れた峯々、彼らがそこを我がもの顔にかけ歩くところは、見たい気がした。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三十三年春）山雪の幻像　　――雪形の発掘と記録――　五月から六月にかけて、高根の雪がとけるにしたがい、山肌がだんだん現われてくる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、いささか元気がついて、梅田の方へ歩いて行くと、植木屋の店頭で見つけたのが「加賀の白山雪割草、定価十銭」　　　　　　　　＊　十銭といったところで、単位が書いてないから、一株十銭なのか、一たば十銭なのか、わからない。",
              "citation": {
                "source": "雪割草の花",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の少年の頃「お山行（やまゆき）」といへば石鎚登山の連中を指した。",
              "citation": {
                "source": "初旅の残像",
                "author": "安倍能成",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
