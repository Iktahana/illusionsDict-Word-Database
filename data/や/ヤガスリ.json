    "definitions": [
      {
        "index": 1,
        "gloss": "pattern resembling that of arrow feathers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
