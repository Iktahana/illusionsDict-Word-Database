      {
        "index": 1,
        "gloss": "managing to find a way (to raise money, make ends meet, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
