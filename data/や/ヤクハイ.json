        "examples": {
          "standard": [
            {
              "text": "白が河原に捨てられていたので、役牌のアンコを目指して鳴くことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、中が重なった。これで役牌が確定して一安心だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初心者は、まず役牌を揃えてあがる感覚を掴むのが上達の近道だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "と、岩根の一所に、人一人ようやくはいれるくらいの、小さい岩穴が開いていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばやくはいり込んだ、文次、折よく誰にも見とがめられずに、追われるように表玄関へかかって、土間に立って案内を乞うた。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこのとき、姉を迎えに行ったポーレンカが、群衆を押し分けながらすばやくはいってきた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの灯りは、お通さんが起きて待っている灯りかも知れないね」「…………」「さ、お師匠様、はやくはいろう、今おいらが、門を叩いて門番さんを起すからね」　そこへ向って、駈け出そうとすると、武蔵は城太郎の手首をぐっと握って、「まだ早い」「どうしてさ、お師匠様」「わしは、お館へははいらぬ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
