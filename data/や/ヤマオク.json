    "definitions": [
      {
        "index": 1,
        "gloss": "deep in the mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
