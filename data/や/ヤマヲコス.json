    "definitions": [
      {
        "index": 1,
        "gloss": "to surmount a difficulty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
