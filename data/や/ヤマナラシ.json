    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese aspen (Populus tremula var. sieboldii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ここに万の神の声は、狭蠅なす皆｜涌き」は火山鳴動の物すごい心持ちの形容にふさわしい。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山鳴動して一鼠が飛び出したといったようなときの笑いは理知的であり、校長先生の時ならぬくしゃめが生徒の間に呼び起こす笑いなどには道徳的の色彩がある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「島山鳴動して猛火は炎々と右の火穴より噴き出だし火石を天空に吹きあげ、息をだにつく隙間もなく火石は島中へ降りそそぎ申し候。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳴り谷答えて、いずくにか潜んでいる悪魔でも唱い返したように、「我は官軍我敵は」という歌の声は、笛吹川の水音にも紛れずに聞えた。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "風出でて山鳴ふかき日の暮は遥かに恋し海の汐鳴山上の黎明ひようひようと風吹きとほる山の秀は月かげ白し夜明けたらしも雪ふかき山の尾の上に啼く鶏の啼き応ふ鶏の声のしたしさ道のべの春きさらぎや多摩の山方、まだ寒き障子の内、人影の、手に織る機の、ていほろよ筬うつらしき。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大巌の一枚戸のような奴がまた恐しく辷りが良くって、発奮みかかって、がらん、からから山鳴り震動、カーンと谺を返すんです。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂わば崩落の前兆であるその物音を、炭坑の人びとは山鳴りと呼んで恐れていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地響とか山鳴とかいふべき氣味の惡いどよみが再び空の何處からか起つて來た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鶯が啼く、音色のよいのも啼く、水音をさがして飲む、腹いつぱい、うまい／＼、山鳴、山霧、さびしいな、何となく心細い。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（この前後より山鳴動することはげしくなる）みなたたりかもしれない。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳴りいよいよ激しくなる。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の吹く日は、山鳴りのやうな、松の唸りがするものなのだが、今夜は松の唸りも聞えなかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳴りのやうな、ごおつと響くやうな風の音がした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳴がして、兵の頭へ、雨のように降ってきた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は益々烈しく、山鳴が聞えて來た。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂「泰山鳴動、鼠一疋」「竜頭蛇尾」こんな場合に使はれる。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは、山鳴りが比較的静まった。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大山鳴動して鼠一匹という寓話を聞かれたことがありますか？",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　歴史の概念に到達したところで、最早餘談を試みる必要もない譯であるが、今やそれが單に記録であると知れたので、讀者或は大山鳴動走鼠一匹の感を爲すものあらば、甚だ遺憾と思ふのであるから、萬一の誤解を驅逐するため、越境の譏を犯して、記録の困難を一瞥して見る。",
              "citation": {
                "source": "歴史の概念",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その山賊はとっつかまったんですか」「ところが、泰山鳴動して鼠一匹でね。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろの胆吹の山が息をついては吐き、吐いてはつくように山鳴りをつづけている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大山鳴動して鼡一匹！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山鳴動して鼡一匹さ、アッハッハッハッ、見せたかったよ姥に！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『天寛日記』にも慶長二年三月朔日浅間山噴火慶長四年二月廿日浅間山鳴動などの記事があり、其他『当代記』、『慶長年録』等にも同様の記事が見えているから、浅間山へ参詣衆とあるのは富士の浅間神社へ参詣したのではなく、上信界の浅間山へ登山したものと見て差支ないようである。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに立った土生仙之助が、抜刀を雨にかばいながら濡れ草を分けて、「起きて来たのはいいが、泰山鳴動して鼠一匹じゃあねえかな……よく降りゃあがる」　独語ちつつその前にさしかかった時だった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある髪結いは、飯綱山の方に火の如き雲が出たので、怪しんで見詰めていると、その雲がくるくる廻って、消えると同時に山鳴りがして大地震になり、道路に揺り倒されたと言う（時雨の袖）。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山鳴動して半星一ツ転がり出した土俵異変――これを名付けて『太刀、駒の八百長崩れ』といつたのである。",
              "citation": {
                "source": "八百長くづれ",
                "author": "栗島山之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おじさま、そろそろ今年の最後の虫を捕りに行きましょうよ、こおろぎなら、まだ、そこらに沢山鳴いているわ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泰山鳴動して鼠一疋も出なかったね。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳴りのことは神主様が保証して下さいました、山ヌケでございますから、地の裂けて人を陥す憂いは無いそうでございます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
