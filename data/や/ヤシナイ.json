[
  {
    "uuid": "809c354a-a403-5dbf-b792-6f9fc6ac42cd",
    "entry": "養い",
    "reading": {
      "primary": "やしない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
