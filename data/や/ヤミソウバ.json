        "examples": {
          "standard": [
            {
              "text": "戦争中は、物資の闇相場が高騰した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "外貨の闇相場は、政府の公式レートとは大きく異なっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "希少なアンティークは、闇相場で取引されることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "取引は市価の闇相場だから、別にこの取引を拒絶することはない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか闇相場と豹変主義のみでもないだろう。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲食物の闇相場の話やら、第二封鎖の話やら、何やら彼やら、世間の誰もが寄ればきまって語り合う話が暫くつづいている中夕食がすんだ。",
              "citation": {
                "source": "羊羹",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "飮食物の闇相場の話やら、第二封鎖の話やら、何やら彼やら、世間の誰もが寄ればきまつて語り合ふ話が暫くつゞいてゐる中夕食がすんだ。",
              "citation": {
                "source": "羊羹",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか闇相場と豹変主義のみでもないだらう。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            }
          ]
        }
