        "examples": {
          "standard": [
            {
              "text": "理不尽な上司の叱責に、ヤケ腹を立ててその場で会社を飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何度も失敗を繰り返す自分に対し、ヤケ腹が立って仕方がなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲の期待に応えられない焦りから、ついヤケ腹を起こして周囲に当たってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "直之輔はそれ以前より睡くて睡くて堪らねど、甲田の手前それをこらへて、ヤケ腹に傍に置たる麦酒をグイ飲して、ようやくに忍びいたるなれば、酔の廻るにつれて前後を忘れ、我にもあらずそこに倒れ伏せしかば、今は花子とさしになりぬ。",
              "citation": {
                "source": "当世二人娘",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            }
          ]
        }
