    "definitions": [
      {
        "index": 1,
        "gloss": "(ancient) Japan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兼六公園で驚いたのは、大和武尊の銅像であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋くさい文明が田舎のすみずみまで広がって行っても、盆の月夜には、どこかの山影のような所で、昔からの大和民族の影が昔の踊りを踊っているのではあるまいかと。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和大峰いりのほら貝は聞えないが、町から野、野から山へと、秋草をわたり、落葉松の枯木をからんで、涼しくなる鈴の音は、往さ来さの白衣の菅笠や金剛杖に伴って、いかに富士登山を、絵巻物に仕立てることであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって「いき」とは東洋文化の、否、大和民族の特殊の存在様態の顕著な自己表明の一つであると考えて差支ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米語に対する社会一般の軽薄な好奇心を統制して大和言葉ないしは東洋語の尊重を自覚させるにはどうしたらいいか。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に天晴な大和男児の姿である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に『万葉集』巻十四の東歌および巻二十の防人の歌において例外が取分け多いのでありますが、私の見る所では、これは東国の言語で、大和その他中央部とは違った田舍の言語であるがためにそういう例外が多いのであるという風に考えられるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吉日を選びてなしたるわざの、すゑとほらぬを数へてみんもひとしかるべし」というのは、現代の科学者が統計学の理論を持出してしかめつらしく論じることを、すらすらと大和言葉で云っているのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠にはならないまでも、私はいわゆる新しい大和絵や歴史画を見ると、せっかく頭の中にもっている「過去」の幻影を無残に破壊される場合が多い。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それから、支那人の中には、よくない思想を抱いている奴があるかも知れない、それにも気を配って、大和魂を持っている吾々がそんな奴に赤化されては、勿論、いけない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをすすめた人間は大和で塗師をしている男でその縄をどうして手に入れたかという話を吉田にして聞かせた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で聞くと宗門名誉の説教師で、六明寺の宗朝という大和尚であったそうな。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の探偵になるような奴あ大和魂を知らねえ奴だ、大和魂を知らねえ奴あ日本人のなかまじゃあねえぞ、日本人のなかまでなけりゃ支那人も同一だ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台堀と油堀とを連ぬる小渠は一条のみならず、また木場附近の大和橋及び鶴歩橋の架れる一渠その他の小渠は、一これを記する能はざればなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "河内の高屋に叛いているものがあるので、それに対して摂州衆、大和衆、それから前に与一に徒党したが降参したので免してやった赤沢宗益の弟｜福王寺喜島源左衛門和田源四郎を差向けてある。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが発達し開明した結果、今日では日本内地の旅行は先ず昔の所謂「江の島鎌倉見物」「石尊参り」「伊勢詣」「大和めぐり」「箱根七湯めぐり」などという旅行と同様、即ち遊山旅と丁度同様になって居るかと思います。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておもしろい事にはその彫刻に現わされたガルダの顔かたちが、わが国の天狗大和尚の顔によほど似たところがあり、また一方ではジャヴァのある魔神によく似ている。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和魂だけで器械を使ったのでは、第一器械もこわれるが、場合によっては自身の命も危ういのである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類が進歩するに従って愛国心も大和魂もやはり進化すべきではないかと思う。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲煙弾雨の中に身命を賭して敵の陣営に突撃するのもたしかに貴い日本魂であるが、○国や△国よりも強い天然の強敵に対して平生から国民一致協力して適当な科学的対策を講ずるのもまた現代にふさわしい大和魂の進化の一相として期待してしかるべきことではないかと思われる。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで關はないと思つたら病院に持つて行きたまへ」「楠だな」と井田は思ひながら、すつと奧齒に氣息を引いて小腕を膝頭に乘せた儘「大和」を拾ひ上げた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須走村では禰宜の大和家に火の玉が落ち、それから村一統も焼払われたという噂なぞ聞えて来た。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類の身体はギリシャ、ローマ時代（日本の上古・大和時代）を頂上として漸次退化しつつありと叫ばれるに至ったのもこの不自然な体の扱い方に依るのだ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大和田は程遠し、ちと驕りになる……見得を云うまい、これがいい、これがいい。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と大和尚のように落着いて、大く言ったが、やがてちと慌しげに小さな坊さまになって急いで出た。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鬼は日本で云う山男或は山と云い、ここらでも主になるものは元来何であるかと云うと、大和民族の我々よりも早く既に此の本土に棲んでいた人種で、其中にはアイヌもありましょう、所謂土蜘蛛という穴居人種もありましょう、又は九州の熊襲の徒もありましょう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐うたを、やまと言葉をフランス語を。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はやがて、唐うたを、やまと言葉をフランス語を学び、そして哲学を宗教を知ることによつてよき思想を持ち絵や文学や音楽を味つて充分官覚の洗練されたそのやうなマヽを持ち得るでせう。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦争文学」「戦争小説」「やまと桜」「討露軍歌かちどき」等の戦ものばかりをのせる文学雑誌が現れた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間やまと新聞かで品川芸者の評判記が出てゐたが、おもちやさんが一流の流行つ児だと書いてあつたんだ、蔭乍ら喜んで居たよ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
