  {
    "uuid": "a64859a5-9a55-5780-9543-af5e0e607cb9",
    "entry": "ヤム",
    "reading": {
      "primary": "ヤム",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
