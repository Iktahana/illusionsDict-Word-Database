[
  {
    "uuid": "5941ab85-56f2-5b5c-a309-cf2e3a07ab12",
    "entry": "止む",
    "reading": {
      "primary": "やむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
