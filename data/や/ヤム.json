      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "yam",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その結果は、「要するに御当人ウヤムヤなんだ」といふことになる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭を屈めた際につむつた眼を、云ふことの出来ない表情で開くと、閉つた口をムニヤムニヤとさせた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユフダチ　ヤムノヲ　マツウチニツカレガ　デタカ　オヂイサンイツカ　グツスリ　ネムリマスオヤマハ　ハレテ　クモモナクアカルイ　ツキヨニ　ナリマシタ　この月は、春の下弦の月である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イサックが悲しげに彼に握手して、　――メラ、君に贈る親愛、古いスグヤムグラの誓をもって！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査も、ウヤムヤで来なくなってしまった。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメガ　ヤムト　マヘヨリモ　イツソウ　アタタカナ　ヒノ　ヒカリガ　ソソギマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州出羽は裏面ではモヤモヤムクムクして居ても先ず治まった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じポルツガル人はシヤムにもスポンジケイクの製法を教へた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヤムではそれを Kanom Farang と呼ぶ、シヤムには尚 Oeufillet の菓子を伝へた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのシヤムの名は Foi Thong である。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ組合の薄白痴は石油ににじむ赤き髪に雑種児の矜を思ひ、けふの夜食も焼パンにジヤムと牛乳を購はんとぞ思ふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼アイヌ、家屋の空見ず、さやら葉の青の長葉の、アイサク・ピヤパ（髯なき稷）フレ・ピヤパ（赤き稷）チヤク・ピヤパ（はぜ稷）ヤムライタ・ヨコアマム（藪虱に似し稷）、また、脚高の熊檻、仔の熊の赤き舌見ず、汗垂らし、拭ひもあへず。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由を熱望する時代には至粋は自由の気となりて、ウィリヤム・テルの如き代表者の上に不朽なる気禀をあらはし、忠節に凝れる時代には楠公の如き、はた岳飛、張巡の徒の如き、忠義の精気に盈ちたる歴史的の人物を生ずるに至るなり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、そんな気がしたので、後者の一派はこれはまた、僕にしてみると、あまりに覇気がなく、文壇妥協派で面白くもなかつたが、ウヤムヤに僕はそつちの一員になつてしまつたのだ。",
              "citation": {
                "source": "貧しき文学的経験（文壇へ出るまで）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅なる帷の長く垂れたる背後にて、我等二人は「シヤムパニエ」酒の杯を傾け、別後の情を語りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヤムニイの谿をも渡りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "困るな」「それから早川の下宿のお神も新聞の写真を見て、早川さんの方は間違いないが、女の方は誰だかわからんようです……とウヤムヤな事を云いおるんだ。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "盃を探し索めるべく発足したばかりのアスフアルト街上のチヤムピオンであります。",
              "citation": {
                "source": "〔モダン紳士十誡〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の傍らに立つてゐる白いジヤムパアの娘は、僕の好意を持つ鍛冶屋の子であるが普段はこれに切りと乗り廻してゐる癖に写真となつたら何うしても諾かないのさ。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて貴女は学校では百メートルのチヤムピオンだつたんですものね。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヤムや西蔵の仏像の色彩を連想する類ひのエメラルド・バミリオン、黒、白の斑点――何と、これが土の上に飛んで、土に隠れる警戒色なのだらうか。",
              "citation": {
                "source": "冬日抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは歓迎にしびれた五体を籐椅子に横たへながら、どこからか聞えるシヤムパンの音を聞いてゐた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵はまた網にも魚ひとつ入らず、だがうまいことなど滅多にある筈はないと誰しもあきらめてゐるので不平の声もなく、酒を賞とかけてのギヤムブルがはぢまつた。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクニツク・ランチとか“For the camping ready”などゝいふ項はピクニツクやキヤムピングに赴かぬ場合でも、折にふれてはわれわれの貧しい食卓の役に立つた。",
              "citation": {
                "source": "ライス・ワッフルの友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、何うせ僕は何処に住んでもキヤムピングに等しい暮しばかりを過して、女房の不機嫌をかふと同時に“N's Cooking note”ばかりが役にたつてしまふのであつた。",
              "citation": {
                "source": "ライス・ワッフルの友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極へ着いたものは自分がペンギン鳥と踊つてゐる心になり、シヤムに行けば象の鼻をねじり倒した画は自分の活動と思ひ、クルツプやモスコウ、イルクツク、ニユーヨークなどは、ほんとに腕に力が入つた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
