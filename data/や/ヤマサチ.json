[
  {
    "uuid": "eff2bbbc-3d8d-55f0-9c40-140fea991da4",
    "entry": "山幸",
    "reading": {
      "primary": "やまさち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
