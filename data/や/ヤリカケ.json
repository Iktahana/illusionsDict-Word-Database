        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其を何故途中で廃止したかといふに、当時私は専ら写生文に努力して、どうか此の遣り掛けの仕事を、完成と迄は行かずとも、或点迄推し進めて見度いと志して其方に没頭した為めに、自然俳句には遠ざからねばならぬ羽目になつたのであつた。",
              "citation": {
                "source": "進むべき俳句の道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大胆に遣り掛けた事を、これから遣るのですね。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "就任当時は従来やりかけていた「水のジェットに対する電気の作用」などをやっていたが、そのうちに彼の頭の中では大規模の仕事の計画が熟しつつあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うらが始めからやらん云うのに、お前が何んにも考えなしにやりかけるせに、こんなことになるんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやりかけた仕事にとりかかるとまた電話がかかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗って行くうちに、その朝やりかけていた仕事のつづきを考えはじめて、頭の中はやがてそれでいっぱいになった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついてやりかけの事に手は帰っても、一度ぼんやりしたところを覗いて来た自分の気持は、もうそれに対して妙に空ぞらしくなってしまっているのだった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまあやりかけた事ですからこれからも一度あのパンフレットを銘々一人ずつご説明して苦しいご返答を伺おうと思います。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだよかないけれど、註文の間に合わそうと思って、今日初めてやりかけの仕事にかかってみたんだが、少し詰めてやるてえと、頭がずきんずきん痛むんでかなわねえ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年で習つて、折角はやりかけた医術も、過労のため押し切れなく成り、それで儲けて建てた、かなり立派な家も人手に渡し、田舎へ引込んだ年であつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは学問のある姉の言うことだから本当だろうと思ってやりかけて、随分莫迦を見ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この計晝は渠が數年前既に或老友の手したになつてやりかけたことだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い風に顫えながら、それでも私はコクリコクリやりかけた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の友人は、何よりもまず事物の正確と、思考の集中を愛するだけに、また、自分のやりかけている事に、横道から闖入されることも、ひどく嫌うのであった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ死刑になりにいく道みちも、やりかけたしごとをやめようとはしませんでした。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりかけてゐた爲事に充分氣を腐らしてゐた矢先なので、『え？",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらに居る間、これを着て、折角やりかけた画を続け給へ。",
              "citation": {
                "source": "朝居の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は、今或処から頼まれて論文をやりかけてゐるんですがね、一寸聞いて呉ませんか、大体の主張を……」　彼は、鶴村が屹度蓄音機を廻すだらうと思つてゐたら、そんなことを云ひ出した。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でその夜徹夜してやりかけの爲事を片附け、翌日立つ事に約束した。",
              "citation": {
                "source": "水郷めぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりかけていた為事に充分気を腐らしていた矢先なので、「え？",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙と白紙を買ったのは、その頃、少し文人風の書画の真似をやりかけていたからであった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりかけた途中でそんな事が知れると先生にしかられるにきまってるから黙っているべきだという。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月のはじめに僕は一度東京へ帰ったが、妙義の宿がなんとなく気に入ったのと、東京の残暑はまだ烈しいのとで、いっそ紅葉の頃まで妙義にゆっくり滞在して、やりかけた仕事をみんな仕上げてしまおうと思い直して、僕はその準備をして再び妙義の宿へ引揚げた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおも僕は、博士の手さきをみていると、そのうちに博士は鞄のなかに書類を一通り重ねあわせ、いったん鞄の蓋をやりかけたが、そのとき急に忘れていたことを思いだしたように、ポケットをさぐると、大型のピストルを一挺とりだし、右手にぐっと握った。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も昨日それをやりかけた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後七時になって、急に苦しくなって、やりかけていた実験を中止した。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験装置がやりかけたままになってそこに転がっているのも、まことに痛ましいことであった。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「編物をやりかけてゐましても、あなたさまのことばかり考へて、私は、南京玉の粒をいくど数へ違へたかわかりません。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくやりかけたこの一枚をすまして了はうと、皆急ぎはじめた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やりかけの道路工事は葬式の後始末がすむとすぐに續けられた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
