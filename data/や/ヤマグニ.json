    "definitions": [
      {
        "index": 1,
        "gloss": "mountainous country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "郷里が山国で夏中は雷雨が非常に頻繁であり、またその音響も東京などで近頃聞くのとは比較にならぬほど猛烈なものであったような気がする。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ちょいと伺いとう存じますが、）（これは何でござりまする、）と山国の人などは殊に出家と見ると丁寧にいってくれる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の中二階からはその屋根が少しばかりしか見えないが音はよく聞こえる水車、そこに幸ちゃんという息子がある、これも先生の厄介になッた一人で、卒業してから先生の宅へ夜分外史を習いに来たが今はよして水車の方を働いている、もっとも水車といっても都の近在だけに山国の小さな小屋とは一つにならない。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、山国の門附芸人、誇れば、魔法つかいと言いたいが、いかな、さまでの事もない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国に育ったから、学問の上の知識はないが……蕈の名の十やら十五は知っている。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国の冬に馴れたる彼女は、泳ぐように雪を掻いて歩んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨の山国の風雪の夕、この一軒家に於て稀有の悲劇を演じたる俳優の中で、僅に生残っているのは幸運の冬子｜一人に過ぎぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで何百年来この山国を閙した※の眷族も、果して全滅したであろうか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨は名に負う山国であるから、山又山の奥深く逃げ籠った以上は、容易に狩出すことも能ないので、余儀なく其儘に捨置いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……雪が消えて、まだ間もない、乾いたばかりの――山国で――石のごつごつした狭い小路が、霞みながら一条煙のように、ぼっと黄昏れて行く。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また信州の寒い山国へ出かけるものもあった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一寸伺ひたう存じますが、）（これは、何でござりまする、）と山国の人などは殊に出家と見ると丁寧にいつてくれる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の実、矢叫の如き流の音も、春雨の密語ぞ、と聞く、温泉の煙りの暖い、山国ながら紫の霞の立籠る閨を、菫に満ちた池と見る、鴛鴦の衾の寝物語りに――主従は三世、親子は一世、夫婦は二世の契と聞く……『全く未来でも添へるのでせうか。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風もふわ／＼と樹の枝を擽つて、はら／＼笑はせて花にしやうとするらしい、壺の中のやうではあるが、山国の夜は朧。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雨が降るのではない、月が欠伸する息がかゝるのであらう……そんな晩には獺が化けると言ふが、山国に其は相応はぬ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでいてこの先、川上へ十町も行けば石河原の多い瀬川になってどんな山国へでも行ったかのような感じになるのがわたくしにはおかしく思えて、お秀とは別に、サブリ小屋の中で眺めています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨と木曽と、僕はかさねて山国の秋を見たわけですが、場合が場合だけに、今夜の山の景色の方がなんとなく僕のこころを強くひきしめるように感じられました。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは山国で水の清らかなせいであろう、すべての人が色白で肌目が美しい。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは六十前後、見るから山国育ちの頑丈そうな大男で、小脇には二、三枚の毛皮をかかえていた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷へ帰ろうにも旅費がないので困ったが、その辺は山国で有名な山が多いので、李生はその山へ眼を著けて、猟をして自活をすることに定め、毎日弓を持って山の中へ出かけて往った。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国にても加賀越中は怪談多く、山国ゆえ、中にも天狗の話は枚挙するに遑あらねど、何ゆえか山男につきて余り語らず、あるいは皆無にはあらずやと思う。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰の降った夜更の事――二　山国の山を、町へ掛けて、戸外の夜の色は、部屋の裡からよく知れる。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝ、山国の門附芸人、誇れば、魔法つかひと言ひたいが、いかな、然までの事もない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は中山国分寺の僧に救はれて、京都に往く。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん海抜六百尺をもって最高点となすユトランドにおいてはわが邦のごとき山国におけるごとく洪水の害を見ることはありません。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ斯ういう山国には不思議なことが絶えないので困る。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国の秋は俄かに寒くなって、けさは袷でもほしいような陽気でした。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わづか三四日の旅行なので、成るべく有効に使ひたいと思つたし、この山国には行つて見たい処が沢山あつたけれど、結局そんな平凡な処へ落著くより外なかつた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
