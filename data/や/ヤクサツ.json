[
  {
    "uuid": "a1e57a3b-3edc-5dcb-ac5a-929eab77ef56",
    "entry": "扼殺",
    "reading": {
      "primary": "やくさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strangulation (with the hands or arms)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扼殺――つまり喉を締めたのだ。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活に結びついた知識といふものを、狹く卑俗にだけ解釋して青年のさういふ知識一般への情熱を壓迫し扼殺して了つてはならないだらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし幸福論を抹殺してかかるなら、主知主義を扼殺することは容易である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからやす子の方は扼殺だということが明らかになつたよ」　するとまた、電話のベルがけたたましく鳴りはじめた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをあとから行つて、ただちに扼殺する。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかし、気管中にも栓塞したらしい物質は発見されず、口腔を閉息した形跡もないばかりか、索痕や扼殺した痕跡は勿論見出されなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その部分に当る頸椎に脱臼が起っていて、疑いもなくレヴェズの死因は、その扼殺によるもので……、恐らくそうしてから、絶命に刻々と迫ってゆく身体を、犯人は吊し上げたのであろう――と断ぜねばならなくなってしまった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく犯人は、レヴェズを前室に引き込んで扼殺し、その屍体を奥の屍室の中に担ぎ入れたのであろう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、皮下出血や腫張があって、扼殺の形跡は歴然たるものなんだ。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、浄善尼を扼殺した四本の手も、同様其の中に蠢いていたのだよ。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩序を保つための形式が、成長を遂げるべき本来の精神を扼殺したのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すさまじい扼殺が行われた夜、葛木と光麻呂は遠い別棟に居り、花世はまだ十一で、眠っていたところを清成に抱きだされたのだったから、三人の子供らは母がそんなひどい死にかたをしたことは露ほども知らなかった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ある意味で、表現の潔癖を生命とし、そして、その限界があやうく文学を扼殺しようとしている、実に犠牲の大きい仕事を果したユニックな才能である。",
              "citation": {
                "source": "「にんじん」とルナアルについて",
                "author": "岸田国士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人間の村の背後の山の上に昔はあったと考えられる祭場に、熊の姿で現われ、そこで熊が人間の手に扼殺されるまでの様を演じます。",
              "citation": {
                "source": "アイヌ宗教成立の史的背景",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分下手人はお咲の布團の上に馬乘りになつて、兩手の恐ろしい力で、この造化の大傑作とも言ふべき美しい娘を扼殺したのでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "酒屋忠僕",
                "note": "青空文庫"
              }
            },
            {
              "text": "すさまじい扼殺が行なわれた夜、葛木と光麻呂は遠く離れた曹司におり、花世はまだ十一で、眠っていたところを清成に抱きだされたのだったから、三人の子供らは、母がそんな死にかたをしたことは露ほども知らなかった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷といふものは一つも無く、強い腕で首のあたりを卷かれ、其儘｜扼殺されたことは疑もなく、衣紋の亂れのひどいのに比べて、顏は寧ろ陶醉的な、法悦的な安らかさを湛へてゐるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに語った当時の嬰児扼殺が対岸の茨城県に比して少なかったのは、柴原県令の撲滅対策があずかって力が大きかったのである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキストの首領であった大杉栄・伊藤野枝夫妻と六歳だかの甥宗一の三人が、憲兵隊で甘粕大尉に扼殺され、古井戸へ投げこまれたのも、このときだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、いつかのデモ事件の犠牲者は、あきらかに他殺だったな、と私は考えた、扼殺とも圧死ともとれる屍体。",
              "citation": {
                "source": "ロンリー・マン",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはね、これは扼殺です。",
              "citation": {
                "source": "恐怖の正体",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑識課員は、股野の死因が、強力なる腕による扼殺であること、ドアの把手その他室内の滑かなものの表面が、布ようのものでふきとってあること、一応指紋は採集したけれども、犯人の指紋は恐らく発見されないだろうということ、表口にも裏口にも、顕著な足跡は発見されなかったことなどを報告した。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた即ち北村克彦が股野重郎を扼殺した犯人で、そのにせアリバイを作るために、元の股野夫人あけみさんが、股野さんの替玉になって、窓から顔を見せ、助けを呼ぶというお芝居をやったことをね」　花田はいやに丁寧な云い方をした。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、完全扼殺となると、にわかに名案もうかんで来ない。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絞殺、恐らく両手を以てやくさつされたものらしい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
