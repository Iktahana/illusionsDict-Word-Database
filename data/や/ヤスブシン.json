    "definitions": [
      {
        "index": 1,
        "gloss": "cheap structure (e.g. of houses)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "工場のみならず到處に安普請の家が建ちかゝつて居るのが此間中目について居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の借家は少し安普請で、家具は仕入れ。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階、二階、人が住んでゐるのかゐないのか、息詰まるやうな靜けさを包んだ、安普請の洋館だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りだ、安普請をするとその通りだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場のみならず至るところに安普請の家が建ちかかっているのがこのあいだじゅう目についていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その西洋料理店は名前こそ堂々としていたが、もとよりペンキ臭い安普請のけちな店構えであった。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄間も、壁も、襖も、古く、どっしりして、安普請では無い。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筋向うに瓦斯器具一切を売る安普請の西洋館がある。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲が好さそうにもあり、張り合ってるようにも見える二区切りの土地の上の洋館のけばけばしい安普請の一方には歯科医、一方にはダンス練習所の真鍮札がかかっている。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　名前は清閑荘だが、このアパートはガタガタの安普請で、濡雑巾のように薄汚なかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てめえどもは、御覧のとおり、安普請のバラック旅館にはちがいないのですがア。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡易な別荘風の安普請であった。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がたつく胸壁の震え方はまるで、安普請のなかで強力な発動機を回しているかのよう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "）が、仕方がない、押付け仕事の安普請で、間取りに無理がありますから、玄関の次が暗いのです。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボロでも安普請でも関はないが、斯んな見せかけは閉口だ。",
              "citation": {
                "source": "悪筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "安普請の古家ですから、年造は何の苦もなしに台所の雨戸をこじ明けてはいる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれも、これも粗末な木口を使った安普請で、毒々しく塗り立てた格子や、櫺子窓の紅殻色が、むっとするような不快な感じを与えるのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、一番上等といっても、元来下宿屋に建てた家だから、建前は粗末なもので、動もすると障子が乾反って開閉に困難するような安普請ではあったが、形の如く床の間もあって、年中｜鉄舟先生やら誰やらの半折物が掛けてあって、花活に花の絶えたことがない……というと結構らしいが、其代り真夏にも寒菊が活てあったりする。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りは名高い大きな書店や、文房具屋や、支那料理などの目貫の商店街であったが、一歩横町へ入ると、モダアニズムの安価な一般化の現われとして、こちゃこちゃした安普請のカフエやサロンがぎっちり軒を並ベ、あっちからもこっちからも騒々しいジャズの旋律が流れて来るのだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ横町の路次のなかに、このごろ新しく建てられた、安普請の平屋がそれで、二人はまだ泥壁に鋸屑の散っている狭い勝手口から上って行くと、台所や押入れの工合を見てあるいた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "町にはそっちこっちに、安普請の貸家が立ち並んで、俄仕立ての蕎麦屋や天麩羅屋なども出来ていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は気兼ねして足音忍ばせ階段を昇つて来たのだが、安普請では自分でもびつくりするほどぎしぎしと軋むのだ。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見くだすやうに、こんくりーとの石段を入口に三段ばかりもつて、何處もかもガラス戸で、安普請のくせに傲然と他の二角を見下してゐる、現代式の貸家だつた。",
              "citation": {
                "source": "夏の夜",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒に松の家と云う電燈の出た、沓脱ぎの石が濡れている、安普請らしい二階家である、が、こうした往来に立っていると、その小ぢんまりした二階家の影が、妙にだんだん薄くなってしまう。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　伝蔵のお供で、母と三人、京大阪から中国九州まで食べ歩いたとき、波子は家族といふものに就て、この人生の、いや、地球の土台のやうな心棒が、案外たよりない足場のうへに出来上つたグラ／＼した安普請のやうな気がして、ふと、一番だいじな信念をなくしたやうな気持になつた。",
              "citation": {
                "source": "波子",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、町をうずめている家々は、見るからに安普請のものばかりであった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の自作を本業としてゐた農民が遽かに土地の賃貸しで地主にをさまり、大袈裟に云へば、お城のまはりに士族屋敷が並ぶやうに、そこだけは榎や杉の立木に囲まれた奥深い御殿まがひの建物を中心に、いはゆる色とりどりの安普請、なかにはいくぶん趣味を匂はせた新様式の文化住宅もあるといふ式の一区画である。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "広さは広いが、安普請であつた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "名はすごいホテルだが、実物はやすぶしんの小屋をすこし広くしたようなものであった。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "上ってだいいちにおどろいたことは、その娼家が、やすぶしんではあるがとほうもなくひろいということだ。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
