[
  {
    "uuid": "cf325038-5dda-57be-8053-35a11596505b",
    "entry": "焼き払う",
    "reading": {
      "primary": "やきはらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
