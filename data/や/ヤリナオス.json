    "definitions": [
      {
        "index": 1,
        "gloss": "to do over again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち電気単位の測定を決定的にやり直すことであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーはレニョーの実験における浮力の補正に誤りのあることに気付いたので、もう一度詳しくやり直す必要を感じたのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは困るから結局かんじんの右の目をもう一ぺん打ちこわして、すっかり始めからやり直すほかはないと思うとはりつめた力が一時に抜けて絵筆を投げ出してしまいたくなった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもう一度すっかり消してやり直す勇気がなかったから今度もまたそのままでやり続けた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕も十年計画で、やり直すつもりです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家と読者は、もういちど全然あたらしく地割りの協定をやり直す必要がある。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもしそれにうっかり踏込みでもするとぷりぷり憤ってまた露地口まで戻って来て、そこで足数を考え合せ露地入りをやり直すのだった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっと見当を付けては書き込みと削除だらけの原稿を一字一字数え、足りなくても多すぎても一からやり直す悪夢の作業が脳裏によみがえる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼女は不慣れな手つきで二三度もやり直すのであつた。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "空白の頁は、こまかい計算をしたり、またやり直すのに便利なために明けておいた。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題は、同時に、そうちょいと簡単に、ナンセンスでやっつけるわけには行かない代物なのだから、自分とすると、またまたここで、抑々ソヴェト生産拡張五箇年計画は、というところからやり直すのが、ひどい苦痛だ。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらのもと／＼通りの努力一つで、十分にまた初めからやり直すことが容易でないこともなからう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに無駄骨を折るよりも、今すこし君に休養してもらってから、今一度実験をやり直す事に……」「待って下さい……チョット……それじゃ先生は、その神秘の正体をスッカリ御存じなんですね」「そうさ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからお前はやり直すのだ。",
              "citation": {
                "source": "闇中問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の高さは御互に知らんとしても、山の上で何を見物して何時間かかるぐらいは多少確めて来なくっちゃ、予定通りに日程は進行するものじゃない」「進行しなければやり直すだけだ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝで最初から、語原論をやり直す必要がある。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も、やり直すのが面倒くさかつたら、やり直す必要はないです。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーが私のすぐ背後からついて来て、大男の水夫長が打ち損じたのをやり直す暇もないうちに、水夫長を斬り倒してしまったのだ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敗作はやむを得ん、これに手を入れてみてもタカが知れてゐるので、全然新しくやり直す、いや、別個の作にとりかゝる、これが文学の方法です」「文学ではありませんよ。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度やり直す勇気が出た。",
              "citation": {
                "source": "述懐",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じことを新しくやり直す。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ来て新しくやり直すがいいだよ」　とはげましてくれた。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何もかも新しく、これからやり直すのだ。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピアノを音階からやり直すといっても、私にはもう年がない。",
              "citation": {
                "source": "久野女史をいたむ",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまある会合の席上、私はある有力者に「これではとうてい委員会の職責を果たすことはできない、よろしく委員会そのものに下部組織を設けて徹底的に調査をやり直すべき」を進言したのであったが、私の言も不徹底であったためか、それはいれられなかった。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはまた話をやり直すまでのことだが、」と瀬戸は云った、「それほどむずかしい条件ではないじゃないか。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めて鍵の数字の勉強をやりなおすというわけです。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ながらのアコースティックギターを持ってもう一度舞台に立った彼は、涙ながらに「新しいマッチをすって、やりなおすんだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然信頼性の確保は困難になり、一度仕様変更ということになれば、大変な手間をかけて設計と配線をやりなおすことを覚悟せざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎から来たと云う大工、云われたことを間違え、四枚硝子戸を当てるとどっちにもあかないような鴨居をこしらえ又やりなおす。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
