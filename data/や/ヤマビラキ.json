    "definitions": [
      {
        "index": 1,
        "gloss": "start of the mountain-climbing season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
