    "definitions": [
      {
        "index": 1,
        "gloss": "arrow wheel (decorative windmill on the pole on which carp streamers are raised)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
