        "examples": {
          "standard": [
            {
              "text": "日本神話に登場する八十禍津日神は、災厄をもたらす神とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の人々は、八十禍津日神の怒りを鎮めるために祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「八十禍津日神の祟りか？」と村人たちは恐れおののいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "禍ひを下す神を、大禍津日神・八十禍津日神といひ、神官は嫌うてゐるが、実は大切な神なのである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其を、対句式に表現した結果、その性格に分裂を起して、八十禍津日神と言うた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
