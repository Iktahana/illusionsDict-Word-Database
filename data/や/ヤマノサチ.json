    "definitions": [
      {
        "index": 1,
        "gloss": "food of the mountains (wild game, mountain vegetables, mushrooms, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山の生活、山の幸福、そこに何一つ充ち足らわぬものがあろうか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――竜胆を手折ってくれたその振袖は、すらすらと裳に薄を掛けた後姿が見えて、市松大柄な年増は、半身を根笹に、崖へ下りかかる……見附かった山の幸に興じたものであろう。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、獲ものでない、山の幸は、其の姿を見、その、もの語を聞くのにある、と、思ひつゝ。",
              "citation": {
                "source": "鳥影",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろ形も、罎と鎌で調子を取って、大手を振った、おのずから意気の揚々とした処は、山の幸を得た誇を示す。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうに蟹田町は、田あり畑あり、海の幸、山の幸にも恵まれて、それこそ鼓腹撃壌の別天地のやうに読者には思はれるだらうが、しかし、この観瀾山から見下した蟹田の町の気配は、何か物憂い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――学資を十分に取って、吉原で派手をした、またそれがための没落ですが、従って家郷奥能登の田野の豊熟、海山の幸を話すにも、その「入船帳」だけは見せなかった。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山には山の幸、野には野の幸、庵には庵の幸がある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあり合わせの魚や山の幸をさし出して心からもてなした。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山の谷はよほど山の幸に富んでいるらしい。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山の幸福とよろこびと潤沢な日日とを恵まれますように。",
              "citation": {
                "source": "木の十字架",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の幸、野の幸、海の幸と言えば大袈裟ですが、街頭に栄えた闇市場で普通に手に入る材料の、普通の料理でありました。",
              "citation": {
                "source": "乾杯",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の幸、野の幸、水の幸、とりどりである。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこへ到着して、もっぱら山の幸を供する料理屋であるときいて、さては例の芋虫のウチだなと思いだした。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の幸、海の幸の話。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いの者は一晩山の小屋に泊ったあげく、山の幸のモテナシに降参して、逃げて帰った。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "また箕白の句に「あけび蔓引けば葉の降る秋の晴」、蝶衣の句に「山の幸その一にあけび読れけり」がある。",
              "citation": {
                "source": "アケビ",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東は海山の幸にめぐまれて食糧事情がよかったが、東京も食糧事情がよくなったので、不便を忍んで通勤していた人たちが東京へ戻りはじめたのである。",
              "citation": {
                "source": "温浴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその季節の初めに、盛大な祭を行って、山の神に山の幸を授けてくれるように祈るのが、この熊祭の本来の意義だったのであります。",
              "citation": {
                "source": "アイヌ宗教成立の史的背景",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒に縛られて舁がれてゆくこの高雅な山の幸は、まるで童話の中の不仕合せな王子のやうに慎ましく、痛ましい弾傷は見えなかつたけれど、いかめしい角のある首が変なところへ挟まつたまま、背中をまるくして、揺られながら、それは妙な形の胡坐を組んでゐる優しい獣の姿であつた。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に四季折々の海山の幸があつてみれば、我々日本人の大多数が季節の変化を喜ぶに何のふしぎもない。",
              "citation": {
                "source": "われらが四季感",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌汁の中には山の幸たらの芽。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沢山の幸福にめぐまれながら、たった一つの不幸のために、自分を非常に不幸な人間だと思っている人もあるし、……それかと思うと、不幸だらけの人間でありながら、自分で何かの幸福を見つけ出して、勇ましく戦って行く人もある。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡山の幸吉の事績によって、津田生は、金助や、弓張月や、夢想兵衛のロマンスと違った、科学的技術者が日本に厳存していたことを知ると共に、苦心惨憺して、すでに没収され、湮滅せられた幸吉のあとを探ったものと見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも山神がその好意をめでて、のちのち山の幸を保障したことは同じであった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "九度山の幸村、漂泊の豪士後藤｜基次、徳川家に取って、神経にさわる人間は皆、世のなかを韜晦して、そして努めて、人目につかない暮しを、法則としている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "月叟伝心――九度山の幸村は、あの時、権之助を一見すると、遉にすぐ、権之助の人となりを知ってくれた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の芋、栗、甘柿、野葡萄、松茸などの山の幸。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "香のよい松茸やら、種々な山の幸が、見事に台盤に盛られてございますな」「む。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
