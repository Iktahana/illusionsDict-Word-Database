        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども観衆の大半は、ひょっとしたら、やっぱり侘びしい人たちばかりなのではあるまいか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、やっぱり、言葉でなければいけないか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と断じて、悠然と引上げ、「ああ、やっぱり、ヒットラーに限る！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、やっぱり神さまのお恵みでございましょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな姿はやっぱり好いな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それから、――ＡはやっぱりＢを信じている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やっぱり、その事が先生にとっても、まず第一に気がかりになる様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴫はやっぱり見えぬらしい。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りにはやっぱり御院殿の坂が見付かった。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私にはこのアステーア、ロジャースの踊りのデュエットは見ていてやっぱりおもしろい。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけがわからないくせにやっぱりおもしろいのが不思議である。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、またやっぱり腹と意気がなくては芸はできないものではないかと思うのである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、やっぱり節約からでしょうか。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚のびっくりするような大きいチョコレート菓子可愛ゆい麦粉菓子のヒヨコ、馬鈴薯が本物かと思ったらやっぱり何かを練ってつくったお菓子なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの間をつづってオリーブのつくり葉が、金銀のモール線を綾なして居るのは、どこでも同じしつらえではあるが、独逸はやっぱり独逸らしい。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり、立派だわ、うらやましいわ」　と声に出して言った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話器から離れると彼女は「やっぱり若い者は元気があるね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり時代だね」　主人のこの言葉によって私は、二十何年か前、作楽井氏が常に希望を持つ為めに、憧憬を新らしくする為めに東海道を大津まで上っては、また、発足点へ戻ってこれを繰返すという話を思い出した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「やっぱり血筋ですかね。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりこれも岩頸だ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "題はやっぱり述懐だ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やっぱり星だとジョバンニは思ひましたがこんどもすぐに答へることができませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら何がその川の水にあたるかと云ひますと、それは真空といふ光をある速さで伝へるもので、太陽や地球もやっぱりそのなかに浮んでゐるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとさっきの白服を着た人がやっぱりだまって小さな銀貨を一つジョバンニに渡しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすぐ眼の下のまちまでがやっぱりぼんやりしたたくさんの星の集りか一つの大きなけむりかのやうに見えるやうに思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふ岸も、青じろくぽうっと光ってけむり、時々、やっぱりすすきが風にひるがへるらしく、さっとその銀いろがけむって、息でもかけたやうに見え、また、たくさんのりんだうの花が、草をかくれたり出たりするのは、やさしい狐火のやうに思はれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらからみると、ここは厚い立派な地層で、百二十万年ぐらゐ前にできたといふ証拠もいろいろあがるけれども、ぼくらとちがったやつからみてもやっぱりこんな地層に見えるかどうか、あるひは風か水やがらんとした空かに見えやしないかといふことなのだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、ちょっと喰べてみて、（なんだ、やっぱりこいつはお菓子だ〔。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とおもひながら、やっぱりぽくぽくそれをたべてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やっぱりおなじことを考へてゐたとみえて、カムパネルラが、思ひ切ったといふやうに、尋ねました、鳥捕りは、何か大へんあわてた風で、「さうさう、ここで降りなけぁ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
