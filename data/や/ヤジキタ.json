        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これに準社友の芋倉長江画伯を取り合わせると古今の名コンビで、弥次喜多以上の悲惨事を到る処に演出する。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで見ると、忠臣蔵、弥次喜多、女と男の柔道の絵なぞで、買って少し行ってのぞいて見る間のねうちであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠に乗っても一里三十二文、それもこれも御用という名を頂いているおかげで、弥次喜多の道中だってなか／＼こんなことでは済みません。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は二人で出かけると、方々の新聞社なぞで跡をつけられるんで、自然足も遠くなつたが、十年前までは、本因坊がメリンスの腰巻き、私が麻の股引をはいて、随分弥次喜多旅行に出かけたものだ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の演出は、初めに返って、第一ナンセンス・レビュー「弥次喜多」二幕十二場だ。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弥次喜多」が始まって、第一景。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんたる暴言」「ソモソモ我等こと二名の弥次喜多はだな。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日のメンバーはと見れば、落語　　三遊亭銀馬琵琶　　稲田黄洋落語　　勝太郎物真似　江戸屋猫八曲独楽　三増紋也万才　　弥次喜多獅子舞　今村恒美画伯このほか、作家の土師清二先生、『水之趣味』の青山浩氏、竿師の稲荷町東作氏三人のあいさつ、毎日新聞写真部同行という豪華版である。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ともチョンマゲの弥次喜多のような衣装で、尻をまくって膝まで立ち込み、夢中になって釣っていると、渡月橋の上から助監督が、「撮影が始まりますから早くきてくださーい」　と、大声でどなるので、初めて気がつき、橋の上を見ると黒山の人だかり。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月東宝進出の予定狂言一、北村小松原作　斎藤豊吉脚色　渡洋爆撃隊二、古川緑波作　歌ふ弥次喜多　金比羅道中三、菊田一夫作　曲芸団のロッパ五月二十八日（火曜）　有楽座千秋楽。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木静一・徳山・山田伸吉・上山と堀井も来り、食事しつゝ「歌ふ弥次喜多」の相談。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "床へ入って、「映画とレヴュー」誌のために、「歌ふ弥次喜多と徳さん」七枚書いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝村と鈴木宿へ来り、中央亭の洋食を食ひ、一時近く迄「弥次喜多」相談。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時過ぎに堀井・白川・それに「弥次喜多」打ち合せに来た山田伸吉とで雀を始める。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事して、腹ん這ひになり、「弥次喜多」四時迄かゝって四十枚迄書く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弥次喜多」又五枚ばかり書いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歌ふ弥次喜多」金比羅道中記、昨夜十一時頃から、つひに床の上へ腹這ったまゝ徹宵、手首が痛くて眠くって、此う骨の折れたのは珍しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕自身「歌ふ弥次喜多」を読む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「曲芸団」のプリント未だ出来ず、「弥次喜多」のみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十八日（金曜）　八時すぎ、清が眼をさまして足をバタン／＼やるのが面白く、眺めてたが、ついでに起きちまひ、「弥次喜多」一景だけ皆に覚えて来いと言った手前、覚える。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から「弥次喜多」、一景を本なしで立ち、二・三景と立ち、こゝでやめて、徳山とリッツへ寄る、スープのみやり、歯科寺木へ寄る、上歯の手入れ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から三時迄「弥次喜多」、三時半頃、漸く出来た「曲芸団」のプリントで、読み合せ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弥次喜多」を立ち、歌もまとめる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "セリフ「弥次喜多」からかゝり、十二時半頃迄かゝって、「曲芸団」の三分の一ほど覚え込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から「弥次喜多」音楽入りで通す、徳山味があって中々面白さうだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時すぎから「弥次喜多」、劇場が馬鹿デカいので、客が掴めない、久しぶりでしろとに返った感じ、ワッといふ笑が中々とれず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のところでは分らないが、「弥次喜多」は、何か誤算があったやうだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弥次喜多」は、チャンと受けるやうになった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は「弥次喜多」も「曲芸団」もめちゃにカットしたので芝居してゝも嘘みたいになり、受け方も半滅で、すっかりクサる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の部は「弥次喜多」も、腹話術復活、「曲芸団」も大分復活したので、受け方もグツとよくなって来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
