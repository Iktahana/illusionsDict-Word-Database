    "definitions": [
      {
        "index": 1,
        "gloss": "to translate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昭和十年六月、ジイド全集に「暦」を訳す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、認識能力或は意識によつて、己が受働する感興を翻訳する。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで「実在」をリアルと訳する意味で、芭蕉は真のリアリズムの詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは飜訳することも不可能だし、説明することも不可能である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に詩は、むしろ翻案すべきものであつて翻訳すべきものではない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実の意味を言へば、外国語は決して訳することが出来ないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は、初めから誤訳することを目的として誤訳してゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上へ、まだ活字が揮発油で濡れているパリ・ミデイの一版を抛り出して、キャフェの蕭条をまづ第一に味わいに来たのは Boulevardier（界隈の人、或は大通漫歩の人と訳すべきか）と呼ばれている巴里の遺物である。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「身振によって思想および感情を翻訳することについては日本派のもっている知識は無尽蔵である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "直訳なら「平和化」で、先ず「平定」とでも訳する所であろうが、とにかくフランス人らしい巧妙な措辞である。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタイン自身の言葉として出ている部分はなるべく忠実に訳するつもりである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、何故お前は家常茶飯のような危険極まる作を翻訳するのだと云う人もありましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来ご承知のごとくビヂテリアンといふのは動物質のものを食べないといふ考のものの団結であり、日本では菜食主義者と訳するけれども主義者といふよりは、〔〕むしろ菜食信者といふ方が、よく実際に適ってゐるとも思はれる。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "語を訳すことの易くして意を伝ふる事の難きは、かゝる事の多ければなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの役目はただそれらの怪異現象の記録を現代科学上の語彙を借りて翻訳するだけの事でなければならない。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音や光でさえも、音波の形が音色を与え、光波の波長の大小が色彩を与える事を考えると、今より百年後の生理学の立場から見てあるいはルクレチウスの言葉を適当に翻訳する事ができるようになりはしないか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある程度まで近代的に翻訳する余地があるかと思われる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼は地下に空洞の存在を仮定し、その空洞を満たすに「風」をもってしたのは困るようであるが、この「風」を熔岩と翻訳すれば現在の考えに近くなる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）　ルクレチウスの atom. 現代の原子と区別するためにかりに元子と訳する。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを翻訳すると次のようなことになる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように米相場や株式の高下の曲線を音に翻訳することもできなくはないはずである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし以下にいうところの命題の大部分は、適当に翻訳する事によって風景画にも応用されるだろうと思っている。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを自分の現在の場合の言葉に翻訳すると、「研究の手首を柔らかくして、実験の弓で自然の弦線の自然の妙音を引き出せばよい」とも言われるであろう。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妙なばんばが出て来て、妙なじんまをずいて、ずいてずきすえた」これを翻訳すると「変な老婆が登場して、変な老爺をしかり飛ばした」というのである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の推移は顕在的には不可能であるが、心理分析によってこれを潜在意識の言葉に翻訳するとそれが必然的な推移であって、しかもその推移がその夢の作者の胸裏の秘密のある一面の「流行の姿」を物語ることになるのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に俳句等の日本詩は、到底外国語で模倣ができず、またこれを翻訳することも不可能である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ぼうっとした印象が、美的な快感を損わない程度の軽い哀愁として、読者の胸にいつの間にか忍び込む理由を、客観的に翻訳すると色々な物象として排列されます。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "林はだんだん深くなりかしの木やくすの木や空も見えないようでした。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら式のぶらぶらあるき、彼岸もはやくすぎた、四月上旬の田畝路は、些とのぼせるほど暖い。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やうやくすゝきの輝きを間近かに見た時、深い溝は彼女を渡さなかつた。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
