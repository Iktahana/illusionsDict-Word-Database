          "standard": [],
          "literary": [
            {
              "text": "）それともも少し上等になると、例へばヴィオロンの批評には、「まづ、ボーイングはと……つまりボーイングなる眼点よりしてこの提琴演奏家はと……」といつた具合らしく、発表された批評文恰かも生理衛生の答案みたいなのがあるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "痍に悩める胸もどき、ヴィオロン楽の清掻や、ワルツの舞の哀れさよ、疲れ倦みたる眩暈よ、神輿の台をさながらの雲悲みて艶だちぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "痍に悩める胸もどき、ヴィオロン楽の清掻や、闇の涅槃に、痛ましく悩まされたる優心。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉　　　　　　ポオル・ヴェルレエヌ秋の日のヴィオロンのためいきの身にしみてひたぶるにうら悲し。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼等に声があったら、この白日の庚申薔薇は、梢にかけたヴィオロンが自ら風に歌うように、鳴りどよんだのに違いなかった。",
              "citation": {
                "source": "女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィオロンセロを主とする四重奏で、美しいメロディーがとび出して来た。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "萎れかけた草の葉かげから聞える昼間の虫の声は、正しく「秋のヴィオロンのすすり泣する調」であろう。",
              "citation": {
                "source": "蟲の声",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒り立つたるビエルヂバブには、遮二無二ヴィオロン掻きめさる！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返ると、彼はヴィオロン彈きが灰色の岩へ取りついて、風の吹き過ぎる合間々々に、コルトルダンスの曲を彈かうとしてゐるのが眼についた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこ声高きヴィオロンと。",
              "citation": {
                "source": "訳詩集「月下の一群」",
                "author": "その著者堀口大学に与ふ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
