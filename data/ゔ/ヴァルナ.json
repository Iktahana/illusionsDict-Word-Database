        "examples": {
          "standard": [
            {
              "text": "ヴァルナ制度における最高位であるバラモンは、祭祀を司る階級である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カースト制度の基盤となったヴァルナは、紀元前千年以上も前に成立したとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社会科の資料集で、ヴァルナとジャーティの関係について調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水天はバラモンの水神ヴァルナであって、密教の諸仏諸天大集会に西方の守護神をつとめているが、天平時代の守護神のように純然たる仏の「守護神」となっておらず、なお本来の水の神としてその地位を得ているのである。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、フースクヴァルナや、あそこにある大きな工場もさ！",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "18　ターベルイからフースクヴァルナまで四月十五日　金曜日　ニールスは、ほとんど一晩じゅう目がさめていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは飛びつづけて、フースクヴァルナにきました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
