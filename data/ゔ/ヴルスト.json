        "examples": {
          "standard": [
            {
              "text": "ドイツのクリスマスマーケットでは、様々な種類のヴルストが売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はビールと一緒に、焼きたてのヴルストを美味しそうに食べていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域は、伝統的な製法で作られたヴルストで有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "法水は考証気味な視線を休めずに、「まるで騎士埴輪か鉄の処女としか思われんね、これがコペツキーの作品だと云うそうだが、さあプラーグと云うよりも、体躯の線は、バーデンバーデンのハンスヴルスト（独逸の操人形）に近いね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとそのヴルストみたいなものを取ってくれないか」と一人が言う。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃヴルストじゃない。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            }
