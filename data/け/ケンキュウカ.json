[
  {
    "uuid": "29702ca0-de67-501f-9edb-1f783c621487",
    "entry": "研究家",
    "reading": {
      "primary": "けんきゅうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
