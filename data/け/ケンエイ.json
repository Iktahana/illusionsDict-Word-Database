    "entry": "巻纓",
    "reading": {
      "primary": "けんえい",
      "alternatives": [
        "かんえい",
        "まきえい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rolled tail (of a traditional Japanese hat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無紋の袍に灰色の下襲で、冠は喪中の人の用いる巻纓であった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『太平記抄』慶長十五年作二十四巻、巻纓の老懸の註に、老懸とは下々の者の鍋取というような物ぞと見え、寛永十九年の或記に浅黄の指貫、鍋取を冠り、弓を持ち矢を負うとあり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために顔がいっそうはなやかに引き立って見えるのを、女房たちは楽しんでながめている所へ、源宰相の中将が、これも鈍色の今少し濃い目な直衣を着て、冠を巻纓にしているのが平生よりも艶に思われる姿で訪ねて来た。",
              "citation": {
                "source": "源氏物語",
                "author": "藤袴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
