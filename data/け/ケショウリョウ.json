[
  {
    "uuid": "a9b827c6-0f97-5a8d-80de-b1a710edc152",
    "entry": "化粧料",
    "reading": {
      "primary": "けしょうりょう",
      "alternatives": [
        "けわいりょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
