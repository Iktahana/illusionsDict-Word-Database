[
  {
    "uuid": "5266913b-8340-5b4b-9d93-a16ddf388653",
    "entry": "研究材料",
    "reading": {
      "primary": "けんきゅうざいりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
