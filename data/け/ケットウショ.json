        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第58図　ファン・ヘルモントの肖像画および血統書（彼の「医学の基礎」（Elzvir edition, 1648）１ページの対向）　次の世紀にアルケウスはファン・ヘルモントにおいて至る所で中心的な位置を占めていて、動物体および非動物体において調節し制御しているのに出会う。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど、馬には、血統書が重んじられる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊澤天皇はしらないが、人間の系圖とくると、馬の血統書ほどな信用もおくわけにゆくまい。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、馬は血統書ひとつで國際的評價さへもつが、人間のは、桓武の末流も、清和源氏のながれも、古本一册にも値しない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "血統書ニ依ルトコノ犬ノ父ハロンドン生レデレスリート云ウ名ダッタノデ、ソノ仔モ同ジ名デ呼バレルコトニナッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
