[
  {
    "uuid": "468e82da-684c-58df-93b4-8e12b27de909",
    "entry": "遣唐使",
    "reading": {
      "primary": "けんとうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
