[
  {
    "uuid": "3ef20dff-9666-5d16-b346-ebc2b8a1b747",
    "entry": "権能",
    "reading": {
      "primary": "けんのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
