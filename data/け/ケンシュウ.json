[
  {
    "uuid": "cb42ce47-17b4-594b-a8a0-651a451f4004",
    "entry": "兼修",
    "reading": {
      "primary": "けんしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "studying two subjects together (e.g. as a major and a minor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上にその成績はどうかといふと一芸専門の者が皆｜達者で二芸以上兼修の者は腕が鈍いといふでもない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "公卿中尤徳望智識兼修ノ者ヲ以テ、之ニ充ツ。",
              "citation": {
                "source": "新官制擬定書",
                "author": "慶応三年十月十六日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも従来本館にて教授するところの学科は西洋、東洋の両部ありて、東洋部中には日本学ありシナ学ありインド学あり、日本学中には史学、文学、宗教学、哲学を兼修せしめ、シナ学中には文学、宗教学、哲学を兼修せしめ、インド学中には宗教学、哲学を兼修せしめしなり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "メルボルン市には約十日間滞在せしにつき、教授にも会見し内部の情況をも聞き及び候うが、第一に文学や哲学の専門科これなく、ただアーツの科目の下にて論理学、哲学を兼修するに過ぎず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか教育学、心理学、倫理学は別に二年間の教育科あれば、この方にて兼修する由に候。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
