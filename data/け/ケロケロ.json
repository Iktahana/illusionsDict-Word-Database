    "definitions": [
      {
        "index": 1,
        "gloss": "completely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水ぎわではかじかが二三びきかたいまるい木の珠数玉をかちあわせるようななごやかなよい声でけろけろとないていた。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、」　たちまち妙な顔、けろけろと擬勢の抜けた、顱巻をいじくりながら、「ありゃね、ありゃね、へへへ、号外だ、号外だ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんどはかえるが、ぬまの中で、けろけろとなきはじめました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "序でだから言ふが、この頑固な皮膚病も内地へ着いて四五日温泉に入つたりなぞしてゐると、けろけろつと治つてしまつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」けろけろとして訊いた。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩が「すべての安楽は困苦を通過せざるべからず」と云う第四の真理を経験して、けろけろとあたりを見廻した時には、家人はすでに奥座敷へ這入ってしまっておった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "名づけ親が足のほうに立っていると、思いつきのいいかげんな処法をして、それで病人は、けろけろとなおるのでした。",
              "citation": {
                "source": "死神の名づけ親（第二話）",
                "author": "ヤーコップ、ウィルヘルム・グリム　Jacob u. Wilhelm Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
