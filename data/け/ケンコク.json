[
  {
    "uuid": "4013d8be-8e9c-5d34-99b1-e9532963d259",
    "entry": "建国",
    "reading": {
      "primary": "けんこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
