        "examples": {
          "standard": [
            {
              "text": "３ヶ月の研修期間を無事に終えた新入社員たちに、配属先を告げる辞令が交付された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "研修期間中は給与が一定額に制限されるが、その分しっかりと基礎を学ぶことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試用期間と研修期間を兼ねているため、この時期の評価が本採用に大きく影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが正式の配属先を決めるに先だって、半年ほどもかけて新人に各部署を体験させる研修期間中に伝送工場を覗いてみると、ここで扱っている技術にも興味が湧いてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
