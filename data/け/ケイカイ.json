[
  {
    "uuid": "ac98ce3e-70af-5379-9bf5-e2253cfec002",
    "entry": "警戒",
    "reading": {
      "primary": "けいかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vigilance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "必要もない肩を張つたり、無意味な猜疑の眼を向けたり、馬鹿げた警戒をしたりしてゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男を神は、世の嘲笑と指弾と軽蔑と警戒と非難と蹂躙と黙殺の炎の中に投げ込んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、あなたのお手紙の長さに感奮し、その返礼の気持もあり、こんな馬鹿正直の無警戒の手紙を差上げる事になりました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ多くの一般の人々は、僕の変人である性格を理解してくれないので、こちらで自分を仮装したり、警戒したり、絶えず神経を使ったりして、社交そのものが煩わしく、窮屈に感じられるからである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査が一人道側へ立って警戒している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の警戒か分からぬ。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何かを警戒していることは分かる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ首相が入院していた時の物々しい警戒を思い出す。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生行路に横たわる幾多の陥穽に対する警戒の芽生えを植付けてくれたような気がする。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がひとに深切を施すのは、たいへんの美徳で、さうして内心いささか報恩などを期待してゐるくせに、ひとの深切には、いやもうひどい警戒で、あいつと對等の附合ひになつてはかなはぬなどと考へてゐるんだから、げつそりしますよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、たとひ乙姫さまが、あなたの事を何もご存じ無くつたつて、乙姫さまは警戒なんてケチくさい事はてんで知らないお方ですから、何も斟酌には及びません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらはただ、自分の品位を落しやしないか、それだけを氣にしてわくわくして、さうして妙に客を警戒して、ひとりでからまはりして、實意なんてものは爪の垢ほども持つてやしないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、私の文章の vocabulary は大袈裟なものばかりで、それゆゑ、人にも反撥を感じさせる樣子であるが、どうも私は、「北方の百姓」の血をたつぷり受けてゐるので、「高いのは地聲」といふ宿命を持つてゐるらしく、その點に就いては、無用の警戒心は不要にしてもらひたい。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは君にもお鉢が廻るんだろうが、兎に角警戒を要する。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、機会のある毎に私達は、この勤労生活を善意に受けている可憐な人々に好意を見せ、かりにも他国人らしい警戒の素振りなど見せたことはありませんでした。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルシェヴィキに反対する白系露人が工部局のロシア義勇兵に続々加盟して、ガーデン・ブリッジ、四川路橋、蘇州橋等の橋上に哨兵小屋を急造して警戒を始めた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂は絶えず三｜人の存在を警戒しながらも、一｜心に、敏活に働いた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、蜂は大事な犧牲の蜘蛛の死骸を警戒しに行つたのだつた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その間にも絶えず三｜人の樣子を警戒し、なほも二三｜度蜘蛛の死骸の存在をたしかめに行つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、なほも警戒するやうに念を入れるやうに穴のまはりを歩きまはつてゐたが、やがてひよいと飛び上ると、蜘蛛の死骸をくはへて再び穴の所へ舞ひもどつて來た。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、さうした故意とらしい女の仕草が油斷を作らせるためではないか知らと思ふと、私は警戒の氣持を弛める譯にはいかなかつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、氏の智は絶えず自己を守らうとする、警戒しようとする。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己を守らうとするが故に、警戒しようとするが故に、氏は常に外に対して昂然と身を持してゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日、一日、遠く丘を越え、谷を渡り、山に登り、そうして聯隊がつくりつけてある警戒線の鉄条網をくゞりぬけて向うの方に出かけて行きだした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道沿線へは多くに分れて小部隊が警戒に出かけた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本の中隊は、汽車に乗ってイイシの警戒に出かける命令を受けた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "警戒所でとった煖炉の温度は、扉から出て二分間も歩かないうちに、黒龍江の下流から吹き上げて来る嵐に奪われてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路に添うて向うの方まで警戒隊が出されてあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鉄橋の警戒隊は列車の窓を見上げて叫んだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶応義塾をひらいた諭吉は、しだいにひょうばんのまとになってきたので、日ごろから、けいかいをしていたわけでした。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
