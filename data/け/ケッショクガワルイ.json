          "literary": [
            {
              "text": "）今日は大変に血色が悪いよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お休なさらないの」「己は寝ない積だ」「まあ」「お前はひどく血色が悪いではないか。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえきょうは、冷気のせいか、それとも青く見せる月に似た灯火の光のせいか、常より血色が悪いように見えた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "母も、お汝の血色が悪いと云うて、案じておる。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
