    "definitions": [
      {
        "index": 1,
        "gloss": "to shave (wood, leather, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "屋根板を削るのや、頼まれて日雇に行くのが、その家の業だつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「時間を減らして、その代りあまり必須でない科目を削るがいい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくその初めは切｜實な人間生｜活の慰樂として遊びとして創り成された將棋に違ひないと思ふが、それを慰樂や遊びの域を遙に越えて、正に骨味を削るが如くあれほど必死に眞劍に爭ひ戰はなければならないとは！",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、外には、骨を削るような労働が控えている。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪車が咽ぶその反対の方向では、白楊の丸太を喰うマッチ工場の機械鋸が骨を削るようにいがり立てた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開け放された裏の出入口からは、機械鋸と軸素地剥機が、歯を削るように、ギリ／＼唸っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと削るうち待ってくれ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが画かきは、削るのがすんで立ちあがり、愉快そうに、「さあ、はじめて呉れ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらは朝から晩まで、俺らの耳のそば迄来て、世界の平和の為に、お前らの傲慢を削るとかなんとか云ひながら、毎日こそこそ、俺らを擦って耗して行くが、まるっきりうそさ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらは朝から晩まで、俺らの耳のそば迄来て、世界の平和の為に、お前らの傲慢を削るとかなんとか云いながら、毎日こそこそ、俺らを擦って耗して行くが、まるっきりうそさ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにゴリゴリと物を削る音が一そう高くなったようです。",
              "citation": {
                "source": "雪子さんの泥棒よけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二一課　橋は流れて水は流れず　私たち鰹節をナイフで削るときには、鰹節を確と握り押えてナイフの方を動かして削ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鰹節削りの鉋が出来て鰹節を削るときには、今度は鰹節の方を動かします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を削るのには必ず鰹節を握り押えて削るもの、すなわち「水は流れて橋は流れず」の一方ばかりの考え方に凝り固まっている人は、折角鰹節削りの鉋箱が出来ても、どこまでも鰹節の方を動かしてはならぬものとして、鉋箱を逆にして鰹節に宛てがうでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ目の浜の石屋に頼まれての、今度建立さっしゃるという、地蔵様の石を削るわ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜枚……二｜枚、と兩方で、ペエジを遣つ、取つして、眠氣ざましに聲を出して讀んで居たが、恁う夜が更けて、可恐しく陰氣に閉されると、低い聲さへ、びり／＼と氷を削るやうに唇へきしんで響いた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと削るうち待つてくれ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが画かきは、削るのがすんで立ちあがり、愉快さうに、「さあ、はじめて呉れ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の話を――或時、※さんと一所に見えた事のある志賀さんが聞いて、西洋の小説に、狂氣の如く鉛筆を削る奇人があつて、女のとは限らない、何でも他人の持つたのを内證で削らないでは我慢が出來ない。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉を削るとはこの事じゃろう。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓矢取っては一万石、大名株の芸人が、イヤ楊枝を削る、かるめら焼を露店で売る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉を殺いで、骨を削るのです。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛筆のシン夢野久作　子供が鉛筆を削っているとあまり無茶に削るので何べんでもシンが折れました。",
              "citation": {
                "source": "鉛筆のシン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へても見ろ、どんな種類の人間が、肉を削るやうな苦しい思をして一文にもならない勞作をして居るか。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も長いから少々削るかも知れない。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰｜曰く、燕は重兵を握り、且素より大志あり、当に先ず之を削るべしと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に事に当る者、子澄、泰の輩より以下、皆諸王を削るを議す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝廷よりは燕王の爵を削るの詔、及び王府の官属を逮うべきの詔至りぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に疏を上りて、諸藩を削るを諫めたる高巍は、言用いられず、事｜遂に発して天下動乱に至りたるを慨き、書を上りて、臣願わくは燕に使して言うところあらんと請い、許されて燕に至り、書を燕王に上りたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "武装｜蜂起、と聞き、小さいナイフを買い（いま思えば、それは鉛筆をけずるにも足りない、きゃしゃなナイフでした）それを、レンコオトのポケットにいれ、あちこち飛び廻って、所謂「聯絡」をつけるのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
