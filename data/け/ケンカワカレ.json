[
  {
    "uuid": "4deaca01-d8d3-5f05-ba14-560b8bd713a0",
    "entry": "喧嘩別れ",
    "reading": {
      "primary": "けんかわかれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
