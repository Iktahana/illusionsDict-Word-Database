    "definitions": [
      {
        "index": 1,
        "gloss": "formation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又、仮りに、三造が、自身の意志と世間の誘惑とを、半々に受容れながら、理窟上言へば、微温い、歴史的に言へば不思議な一個の結成物たる、役柄をみせて死んでゆくかもしれぬといふことは十分に推量出来ることである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は肝腎の右肺部を檢査しようかと思つたが、粟粒がどの位廣く結成されたかを確めるために頭蓋骨を開いて腦膜を調べて見たくてたまらなくなつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新撰組結成六ヶ月で、近藤勇、土方歳三は、その隊長芹沢鴨を、その妾宅に襲つて斬つた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田屋斬込み　新撰組結成の翌年、元治元年六月五日は、彼等にとつて、最も記念すべき日であつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由民主党が結成され、いわゆる五五年体制が固まって、高度成長に向けて歯車が回りはじめた頃です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのオレにとって谷川ユズルのバンド結成宣言は、どうにも納得がいかなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ先ず神話の結成を学問上に綺麗に洗い上げて、それに伴う信仰を、教義史体にはっきり書き、その信仰を司祭的に取り扱った機関を寺院史体にはっきり書く方が好さそうだ。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸田直介――と言うのは、最近東京に於て結成された瑪瑙座と言う新しい劇団の出資者で、大月と同じ大学を卒えた齢若い資産家であるが、不幸にして一人の身寄をも持たなかった代りに、以前｜飯田橋舞踏場でダンサーをしていたと言う美しい比露子夫人とたった二人で充分な財産にひたりながら、相当に派手な生活を営んでいた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿部、伴、健、荒川、その他小作人三人、組合員二人――これだけが、二日の間に三時間位しか寝らずに、「岸野小作争議団」結成のために馳けずり廻った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、その會合をＴ郡組合支部結成第一囘準備會といふことにして、どこに事務所を構へるかといふことになつたとき、さきの男がさぐるやうな眼つきをしていつた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも杉村を支持する下の組織がなほ充分な結成を見ない今日、正面切つて石川と對立することは組織を崩壞せしめる危險を孕まないとはいへぬのである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "台湾、朝鮮、満州、支那に於て遺憾ながら他民族の心をつかみ得なかった最大原因は、ここにあることを深く反省するのが事変処理、昭和維新、東亜連盟結成の基礎条件であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新の眼目が王政復古にあったが如く、廃藩置県にあった如く、昭和維新の政治的眼目は東亜連盟の結成にある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東亜連盟の結成を中心問題とする昭和維新のためには二つのことが大事であります（四七頁の図参照）。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、われわれが明治維新で藩侯に対する忠誠から天皇に対する忠誠に立ち返った如く、東亜連盟を結成するためには民族の闘争、東亜諸国の対立から民族の協和、東亜の諸国家の本当の結合という新しい道徳を生み出して行かなければならないのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の見地からすれば、現代の国策は東亜連盟の結成と生産力大拡充という二つが重要な問題をなしております。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日われらは、まず東亜連盟の結成を主張している。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも指導国家と自称せず、まず全く平等の立場において連盟を結成せんとするわれらの主張は世人から、ややもすれば軟弱と非難される。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この觀察にはいまだ徹底せざる不十分さがあるかも知れぬが、日本が獨立國家として再出發するに當つては、共産黨を斷然壓倒し得るごときイデオロギー中心の新政黨を結成し、正しき統制主義國家として獨立するのでなければ、國内の安定も世界平和えの寄與も到底望み得ざるものと確信する。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　東亜諸民族の団結、即ち東亜連盟の結成。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東亜連盟結成の根本は民族問題にあり。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二個勢力に結成せらるるまでが人類歴史の現段階であり、戦争より見れば第一次欧州戦争以来の持久戦争時代がそれである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "持久戦争と言うても局部的には決戦戦争が行なわれて集団結成を促進するのであるが、武力の活動範囲に未だ制限多く自然に数集団となるわけである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はこの意味に於て人類の準決勝時代と言うべく、この時代の末期である世界が二個の勢力に結成せられる時、次の決戦戦争の時代に入り最終戦争が行なわれる事となる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツは天才ヒットラーにより戦争の中に於て着々欧州連盟の結成に努力し、恩威併行の適切なる方策により輝かしき成果を挙げている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本はその実力によって欧米覇道主義の侵略を排除しつつ、一個の集団へ結成せんとしつつあるが、我が東亜は今日最も不完全な状態にある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年天長の佳辰に発せられた総軍司令部の「派遣軍将兵に告ぐ」には、事変の解決のため満州建国の精神を想起せしめ、道義東亜連盟の結成に在る事を強調せられた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに誘致せられて中国各地に東亜連盟運動起り、十一月二十四日南京に於ける東亜連盟中国同志会の結成となり、昭和十六年二月一日東亜連盟中国総会の発会式となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二節　我が国防　現時の国策即ち昭和維新の中核問題である東亜連盟の結成には、根本に於て東亜諸民族特に我が皇道即ち王道、東方道義に立返る事が最大の問題である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち東亜（我が）国防全からずして、東亜連盟の結成は一つの夢にすぎない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
