[
  {
    "uuid": "b6ec01c3-7162-5c86-86e8-068b87dc7056",
    "entry": "結成",
    "reading": {
      "primary": "けっせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
