[
  {
    "uuid": "d6f1e20a-3b19-5f4e-8619-f93bec765eea",
    "entry": "境内",
    "reading": {
      "primary": "けいだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grounds (esp. of shrines and temples)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしたヘルンの小泉八雲が、常に最も好んだ散歩区域は、寺院の閑静な境内だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田神社は、武田信玄を祭ってあって、毎年、四月十二日に大祭があり、そのころには、ちょうど境内の桜が満開なのである。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内は、塵一つとどめず掃き清められていた。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内の杉の樹に、長さ二寸もある蛞蝓がゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内は雜然としてかんてらの燈火が四邊一面の光景を花やかに、闇の地に浮模樣を染め出した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田神社は、武田信玄を祭つてあつて、毎年、四月十二日に大祭があり、そのころには、ちやうど境内の櫻が滿開なのである。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内は、塵一つとどめず掃き清められてゐた。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒込の富士から神田明神、深川八幡の境内、鉄砲洲の稲荷、目黒｜行人坂などが、その主なる場所であった、がそれも、今ではお伽噺になってしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さびた境内にたたずんで、夜山をかけた参詣の道者が、神前に額ずいての拍手を聞きながら、「日本の山には、名工の建築があるからいいなあ」と思った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩境内に踏みいると、乱雑なる町家から仕切られて、吉野山の杉林を見るような、幽邃なる杉並木が、富士の女神にさす背光を、支持する大柱であるかの如く、大鳥居まで直線の路をはさんで、森厳に行列している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の傍には、周囲六丈四尺、根廻りは二丈八尺、と測られた神代杉がそそり立って、割合に背丈は高くないけれど、一つ一つの年輪に、山の歴史の秘密をこめて、年代の威厳が作り出す色づけと輪廓づけを、神さびた境内の空気に行わたらせている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能山の上り口の右手にある寺の門が少し傾き曲り境内の石燈籠が倒れていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この幼い子供達のうちには我家が潰れ、また焼かれ、親兄弟に死傷のあったようなのも居るであろうが、そういう子等がずっと大きくなって後に当時を想い出すとき、この閑寂で清涼な神社の境内のテントの下で蓄音機の童謡に聴惚れたあの若干時間の印象が相当鮮明に記憶に浮上がってくる事であろうと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地震のあとで鎌倉の被害を見て歩いたとき、光明寺の境内にある或る碑石が後向きに立っているのを変だと思って故田丸先生と「研究」していたら、居合わせた土地の老人が、それは一度倒れたのを人夫が引起して樹てるとき間違えて後向きにたてたのだと教えてくれた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東照宮前から境内を覗くと石燈籠は一つ残らず象棋倒しに北の方へ倒れている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二の嶺のいや遠長き山路をも妹許訪へば気に呻はず来ぬ　富士の西南の麓、今日、大宮町浅間神社の境内にある湧玉池と呼ばれる湛えた水のほとりで、一人の若い女が、一人の若い男に出会った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときには根津權現の境内やＢＡＲの卓の上で詩作をしたりした。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝稲荷神社境内　（茶店は腰掛茶屋である。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり日中だけの営業で、日が暮れたら店を片付けて住居に帰る）　三次の奴が境内の茶店に腰をかけて嫌に嬉し相にしている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝お稲荷さん境内　其辺へ三次はやって来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝稲荷神社境内　勝坊と手に手をとって三次がやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「翌朝三次は久し振りでお稲荷様にお詣りした」Ｓ＝稲荷神社境内　お絹の腰掛け茶屋は閉っている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に仲蔵は妙見の境内へ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝境内――　仲蔵が通り過ぎる背後から嘉助老人思い切って、　「アもし」　仲蔵、訝しそうに振り返ると、　老人が、Ｔ「仲蔵殿とやら　申されぬか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝境内　嘉助は五郎蔵の一太刀、肩先に受けアッと言って倒れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同後追うと、　大吉は仲蔵を境内の安全な場所へ置き、再び戻って来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）境内　易者の前へ立った左膳である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝或る神社の表　団九郎がその境内へ逃げ込んだ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝境内　武蔵が大小の木太刀を手に悠々と腰打ち掛けて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝神社の境内で　武蔵が二本木太刀を手に持って居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
