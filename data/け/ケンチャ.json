        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あるとき各流の宗匠ことごとく環視の中で献茶の手前、長盆の乱れ飾という台子の奥儀をすらすらと顔筋一つ動かさず、並みいる宗匠これにはアッと舌を巻いた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "えならぬ仙味の献茶一ぷくを、すずやかに服み終ると、彼はただちに、勅の主旨を、院主につたえた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男　　けんちゃんがわるいんだよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男　　けんちゃんがレンズを持ってきて、黒いもんならなんでも燃えるから、やってごらんっていったから、ぼくうそだと思って……。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男　　だって、けんちゃんが……。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けんちゃんか」「暢気じゃないか、こんな処で寝るなんて」　沙利置場に寝ていることは判ったが、場所が判らなかった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
