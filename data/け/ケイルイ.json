[
  {
    "uuid": "e52d5472-df78-50be-8e4b-a5347804f2b1",
    "entry": "係累",
    "reading": {
      "primary": "けいるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
