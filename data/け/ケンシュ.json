  {
    "uuid": "baa61034-84da-5838-a9c1-b6ef6eb52b15",
    "entry": "賢主",
    "reading": {
      "primary": "けんしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wise master",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晝は終日兵術を修し、夜は燈下に先哲を師として、治亂興廢の理を講ずるなど、頗る古の賢主の風あり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子の堯舜禹湯文武を稱するが如く、墨子も堯舜禹湯文武を稱し、聖王賢主の民を率ゐ躬を正しうしたところに準據してゐるのであつて、自分の小さな知識や感情から一家の言を成し、我より古を成さうとしてゐたのでは無いのである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "醍醐天皇は、あれ程の賢主であったけれども、異国の人相見を都にお引き入れになったのは、大へんなお心得ちがいだったといわれている。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて汝ら廟堂の臣ども、みなこれ凡眼の愚夫、豈、賢主暗君の見分けがつこうや。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
