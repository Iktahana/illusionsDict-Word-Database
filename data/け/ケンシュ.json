  {
    "uuid": "d2f1ca5f-2201-5d2d-83cf-20bd9cf74f87",
    "entry": "黔首",
    "reading": {
      "primary": "けんしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "グレシア正教の寺院を沈滞のままに委せて、上辺を真綿にくるむようにして、そっとして置いて、黔首を愚にするとでも云いたい政治をしている。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愚にせられた黔首が少しでも目を醒ますと、極端な無政府主義者になる。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黔首を愚にしなくてはならない。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
