        "examples": {
          "standard": [
            {
              "text": "銀行から融資を受けるために、具体的な収支見通しを記載した計画書を提出する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、登山に行く前には、必ず家族に計画書を渡しておけよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロジェクトのリーダーは、メンバー全員に今後のスケジュールを記した計画書を配布した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "フランス人のブローカーが彼の居間に自由に出入して殖民地の一獲千金的紙上利益をタイプライターが創造しているだけの計画書を示し、彼に荘重な約束手形の署名をさせるようになった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めから終りまでの研究計画を、きちんと立てて、その計画書の章をそのままに追って、実験を進めて行くという風なやり方になり易いのである。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどではなくても、研究の計画書は、非常に詳細に出来ている。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究者は、その計画書どおりに、レールに乗って動いて行くだけである。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも表面的には、立派な調査書ができていて、それに基づいて部厚な計画書が印刷されている。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画書はすでにある。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡した計画書はよく読んだか」　二人の手下は読んだと文句を言った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
