    "definitions": [
      {
        "index": 1,
        "gloss": "report of (one's) research",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むしろ国民社会一般の幸福安寧に資すべき調査研究報告機関のようなものになってしまう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は怖くなって、早々に研究報告を纏め上げ、これをアシュル・バニ・アパル大王に献じた。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究報告書は経費の都合上十分抱負が実現されなかったが、とにかく鴎外時代となって博物館から報告書が発行されるようになったのは日本の博物館の一進歩である。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "テイラー博士のテイクロトロンの研究報告は、俄然一座を大きく刺激したようであった。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「酒を飲みながら俺の研究報告をきいた方が好からう、ノートは読み憎いぞ。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の研究報告会でＱがＡに打ち負かされたときなどには私は私がＱであるかのように萎れてしまった。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、前週出した、インドにおける綿花生産の消長と英国資本主義との関係に関する学生の研究報告の批評があった。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "序文で、作者はこの小説は小説ではなくて、研究報告であると言っている。",
              "citation": {
                "source": "「結婚の生態」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キツプリング、ブラツクウツド、ビイアスと数へて来ると、どうも皆｜其机の抽斗には心霊学会の研究報告がはひつてゐさうな心持がする。",
              "citation": {
                "source": "近頃の幽霊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この研究報告は日本人の食物と栄養観念とにも緊要な反省資料を提供するものであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "米人はそんな場合は実際には起こり得ないと、非実際なるを嗤ったが、今日原子爆弾によってその研究報告の値打ちが燦然と光を増したわけである。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はおれの書いた落雷の研究報告を悪用して、あの恐るべき殺人法を思いついたのだ。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界各国天文台の研究報告を待つて、博士は引責自殺の覚悟あり明午前一時公式の経過発表をなすはず。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大正五年以來研究報告書を出版致し、今ではいつしか十三册まで發行致しました。",
              "citation": {
                "source": "考古學教室の思ひ出話",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに不幸にして近時余輩の有する余暇と余輩の健康とは、当分かくの如き増大号の頻繁なる発行を見合すべく余儀なくせしむるに至ったが為に、余輩は前々号以来、俗法師の研究を始めとして、再びこれら特殊民に関する雑多の研究報告を、断片的に本誌普通号上に分載発表することとした。",
              "citation": {
                "source": "特殊部落ということについて",
                "author": "まず部落としての集団的取扱いを廃せよ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカならば、年に何万という研究報告が出るであろうし、日本でも何千という数であろう。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにさらに詳しい研究報告も英文で書かれて理研の報文に当局の許可を得て出版されているのだから、今頃書くのは少し陳腐の感がないでもないが、それだけに別に差し障りのあることもないだろうと思われる。",
              "citation": {
                "source": "球皮事件",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方文化研究報告、第七輯、拙稿「呪師とカワウソ」参照。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈共著者山田秀三〉〈『北方文化研究報告』第十一輯　昭和31年３月〉",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（注）浜田耕作氏によると、大阪城大手門入り口の大石の一は横三十五尺七寸高さ十七尺五寸に達し、その他これに伯仲するものが少なくない（『京大考古学研究報告』第十四冊、六〇ページ）。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満鉄における満鮮史の研究は、大正元年だか二年だかに、会社の事情でうちきりとなり、東京帝大の文学部の名で研究報告を続刊し、その出版費を会社から提供する、という形で纔かにその生命をつなぐことができた。",
              "citation": {
                "source": "学究生活五十年",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　『本邦新聞の企業形態』に就いて　東京帝大文学部内の新聞研究室の第二回研究報告『本邦新聞の企業形態』という本が出ている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに第一回報告として『新聞研究室第一回研究報告』なるものが出版されているが、之は思うに、わが国に於ける理論的な新聞研究の最高水準を略々占めるものだと云っていいだろう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――新聞紙と読者との連関（之は新聞の社会的機能から云って最も大事な問題の一つだ）を主題としたもので注目すべきは、小野秀雄「新聞と読者」（東京帝国大学文学部、『新聞研究室第一回研究報告』の内）である。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　「新聞学の主要な問題の一つは、人と人との間の社会的精神的交通関係を実現する手段を系統的に理解することである」（小山栄三「原始的公示形態と通信方法――新聞前史の一考察――」、前掲、『新聞研究室第一回研究報告』四六頁）。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもここで調査審議された政府案は、エッキスパートの研究報告として、素人の集りである議会に単に諮問され賛成を押しつけるに過ぎないような形になるから、これは議会政治の実質的な虚脱機関に他ならず、従ってここに新官僚の参謀本部が出来るわけだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤豊治は九州大学の工科研究室に籍のある研究生で、恩師の鹿谷弘吉｜博士が、或る研究報告をするため上京した後を追って、その助手を勤めるために昨夜東京へ着いたのである。",
              "citation": {
                "source": "亡霊ホテル",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身の上が危ないと、今日明日にも危ないとその噂とりどりの最中でも、ふだんと少しのお変りもなく王宮内のいろいろな研究所の中でさも楽しそうに所員の研究報告なぞに耳を傾けておいでになるのです。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この順序を決めるには久曾神昇氏「二四代集と定家の歌論書」〔『国語と国文学』昭和十年七月〕という名研究報告に安心してたよれるのである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
