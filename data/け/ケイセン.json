    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a spring that gushes forth from a valley",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山奥の静かな渓泉のほとりで、しばし休息を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "澄んだ渓泉の水は、冷たくて心地よかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "渓泉から流れ落ちる水音が、心を癒してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、奥へ奥へとすすむうちに、林の小道は幾筋にも分れ、或いは渓泉に切れ、或いは丘の上下にうねり、遂に逸した優形の男の影は見つかりません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
