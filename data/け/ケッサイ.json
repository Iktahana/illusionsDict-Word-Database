[
  {
    "uuid": "ee3a932e-c102-5093-bee4-fb47f4596ad3",
    "entry": "決済",
    "reading": {
      "primary": "けっさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
