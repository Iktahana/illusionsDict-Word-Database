        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここでうっかり嗾けるようなことを云ったら、病犬のような彼女は誰に啖い付こうも知れなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人も口笛を吹いたり何かして、外の犬を嗾ける。",
              "citation": {
                "source": "犬",
                "author": "レオニイド・アンドレイエフ　Leonid Andrejew",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛ちやんは精一ぱい大きな聲で、『其※事をすれば玉ちやんを使嗾けるから可いわ！",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいさんお金持やよってに」「そやそや」と雪子も嗾けるような口調で、「何処がええ、悦ちゃん、洋食か、支那料理か」「そうかて、まだお金受け取ってえへんねん。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分で自分をけしかけるように、大ぎょうな表情を見せながら、「それで泣くというのは変じゃありませんか」　とむりに追窮した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度そんなくだらねえ話をしにきやがったら、犬をけしかけるぞ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰った帰った、犬をけしかけるぞ。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達もかかれッ」　けしかける白覆面の声にサッと黒い人山が動いた。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、自分の家の鳩へ、他所の犬をけしかけるのをやめた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら小僧はそのあとをつけていって、わざと犬をけしかける者もあった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの現実の間で「二つの世界」をいうならば、それは一方に真実世界平和のために努力しつつある人々の良心の世界があり、他の一方に、平和のための戦争挑発、平和のための原子兵器、細菌兵器使用をけしかける屠殺者的平和主義者の世界と、この「二つの世界」があるだけである。",
              "citation": {
                "source": "平和の願いは厳粛である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男や軍人が書いたのでは陳腐だというので、警察官の女房などにわざわざ「満州里遭難血涙記」を書かせ、公爵近衛文麿の戦争をけしかける論文。",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに警察が誤つた疑いをもつているのを知りながら、それを指摘せず、反対にけしかけるとは！",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「全體あんた等が、そんなことを言うて、若い者にけしかけるからいかんのぢや。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "より強力な政治とは、より、この本質の羽を伸ばさせてやることだ」　こう、悪魔は思想家たちを、けしかける。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みつ子の顔が浮んで来、こんな気まぐれも所詮は道化染みた大仰な身振りに過ぎぬといふ意識があつたが、反面には、もつと道化ろ、もつと道化ろと自分をけしかけるものがあつた。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、そこで大音に、若者達へけしかけるように云った。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう叫ぶと弦四郎は二度も三度も、けしかけるように刀を揮った。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方は富五郎はバッサリ切った音を聞いて、直に家へ駈けて行く、其の道すがら茨か何かで態と蚯蚓腫れの傷を拵えましてせッ／＼と息を切って家へ帰り＊「けしかけるおだてるそゝのかす」　富「只今帰りました」　という。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "もたれない、と尾崎士郎がけしかける。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかが私をけしかけるのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに犬などをけしかけるとはなにごと。",
              "citation": {
                "source": "支那の狸汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は体をすこし休めたが、そのあいだ、死者の霊たちがまわりを飛び舞い、追跡をつづけて復讐するように私をけしかけるので、すぐ旅の支度をした。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の後を追ふもの、「うし、うし」とけしかけるもの、さまざま。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来る道々宮家に対し、討とうか討つまいか考えものじゃの、宮家方に附いては家が持たぬのと、云い出したのは兄者人じゃ」「それもさ家のことを思えばこそじゃ」「それそれ」　と、大弥太はけしかけるように云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恩を仇じゃ、な、まるで」　と、大弥太はまたも、けしかけるように云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまかい着物を着た年増と、派手な衣裳の娘と、それは、年とった牝猫と若い牝猫との喧嘩の場面を磯五に聯想させて、真ん中にすわっている磯五が、困りながら、内心面白くてくすくす笑って、けしかけるようなこころもちで見物しているとき、もう一度障子が人影を浮かべて、手代のひとりが、ちょっとあたまをのぞかせた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサ　……（鉄造の顔を見詰めてゐた後）お辻が田所さんと出来てしまふと、あんたが困るんでせう、だから、あんな事言つてミルさんを、けしかけるんだ。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×目かくしされて書かされてしまふ○○書［転向書］　　×地下にくぐって春へ、春への導火線とならう　　×欠食の胃袋が手をつなげとけしかける！",
              "citation": {
                "source": "鶴彬全川柳",
                "author": "鶴彬",
                "note": "青空文庫"
              }
            },
            {
              "text": "安岡っ引に御用呼ばわりなどをされる覚えはねえ、側へ寄ると河童をけしかけるぞ」「神妙にせい」「糞でも喰らえッ」　二匹の犬のように、猛然と噛み合う二人、後ろからは女房がガラッ八の髷節へ、必死とブラ下がってしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の小判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
