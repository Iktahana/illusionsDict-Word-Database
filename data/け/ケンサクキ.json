        "examples": {
          "standard": [
            {
              "text": "図書館には、蔵書を検索できる検索機が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "空港のセキュリティチェックで、荷物の内部を調べる検索機が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い検索機は応答が遅く、利用者の不満が高まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こうした紙の本でもできたことをカバーしたうえで、Expanded Book はエンジンとして利用したハイパーカードを活かして、強力な検索機能を提供した。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書を目的とする人だけではなく、検索機能を利用して、たとえば言葉の用例を調べる研究者もいる。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ出向く必要がない、閉架や貸し出し中の本がない、検索機能を利用して調べものができるなど、その利点は数多く存在する。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
