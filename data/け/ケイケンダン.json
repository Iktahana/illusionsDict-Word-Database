    "definitions": [
      {
        "index": 1,
        "gloss": "story of one's experiences",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女一人のときでも、気に入った若い同業の女のためには、経験談をよく話した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "経験談の代りに「空想談」は何様です？",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四四課　人間の味　ある料理通が次のような経験談を致しました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子はそのカナリヤの餌を貰うのに寄宿の家のものに何といったらいいのか困り果てたという話は、かの女がむす子から度々聞いた経験談だが、観察の角度を代えていままた話されると、相変らず面白かった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子が、だいぶ経験も積んで、巴里郊外の高等学校の予備校の寄宿舎に、たった一人日本人として寄宿した経験談も出た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私一個の貧しい経験談に過ぎぬのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は目を輝かせて、経験談かそれとも彼等の想像か分らない上級生の話に聞き入り、ほんの詰まらない事にもドッと娯しげな歓声をあげた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、校長から、此処の島民児童の特徴や、永年の公学校教育の経験談でも聴くにとどめようと思った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "忰のこの経験談をわたしが物語ると、彼はその人をよく知っていると言った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその人達にこの経験談を致して聞かせました。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "その経験談を只今あなたにも致したのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の事は、語るのも聞くのもいや、などと言いながら、つい自分の「貴重なる経験談」など語ってしまったが、しかし、私の戦争の追憶の中で、少しでも語りたいと思うのは、ざっとこれくらいの事で、あとはもう、いつかのあの詩のように、昨年は、何も無かった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、そんな危ないことには手を着けないことにして、ここでは自分がこれまで書いた七、八十種の脚本に就いて、一種の経験談のようなものを書き列べて見ようかとも思ったが、それも長くなるのでやめた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授上の経験談が出る。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）話題と云つぱ、何日でも酒と、若い時の経験談とやらの女話、それにモ一つは釣道楽、と之れだけである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものように二人が聴き手で、照子は、京都で三月程、ひどく窮迫した生活を仕た経験談をした。",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日柏軒、抽斎、枳園等が榛軒の所に集つて治療の経験談に※の移るを忘れたことがある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る会の席でその男が、打たずにいる間に棋が上がると云う経験談をすると、教員の山村さんが、それは意識の閾の下で、棋の稽古をしていたのだと云った事がある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は寝台の上に起き上つて、隣同士や、向ひ同士などで、快活に病気とは全く関係のない世間話や経験談などをして笑ひ興じてゐた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから最前から饒舌り続けた経験談なんかは、ミンナ受け売りのゴッタ雑炊だ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神講座にも、科外の臨時講演にも、幾多の学界、芸術界、実際社会等の実力ある識者が講師として、いろいろの専門的知識の講話と経験談とをして下さることも、この学校の一つの特色にしたいと考えています。",
              "citation": {
                "source": "文化学院の設立について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩田金千代も、鈴木竜作も、裏金の陣笠をもらって、新らしく入ってきた隊土に、戦争の経験談を話した。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私の友人の経験談ではありますが、先年、銀座の有名な某食堂で友人四、五名を招待して会食した時のこと、たまたまその料理の中へ、例のたらの芽が出た。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が昨夜、御自身の経験談をおはなしなすった。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、彼が、火星人のためにさらわれて行った経験談であった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子は先の女房の子の様ですから……』　栄一はまだ老人の夢の様な経験談を聞きたいので、『遊説の結果はどうですか？",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、実にいろいろなことをして来た男で、退屈な守備の夜々、類例のない豊富な経験談で、いつも彼を興がらせた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の書いた専門的な研究から、素人患者の経験談に類するもの、さらに、相当の歴史をもつらしい結核患者相手の月刊雑誌に至るまで、ほとんど、あますところなく手にとつてみた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
