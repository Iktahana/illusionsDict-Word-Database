          "literary": [
            {
              "text": "エピナスの古い考えはケルビン、タムソンの原子説を産んだ。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なあにケルビン（××大使のこと）が来る筈だったけど、加減がわりいって断って来たから、結局俺一人になった訳よ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は今日ケルビンに会ってその後の形勢を聞いてみるつもりだったんだが……万一こっちのからくりが曝れそうだったら、いつも云う通りカルロ・ナインを締めるだけの事よ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一族は五つの部屋をたがいに訪ねあうほか気のまぎらしようもない無味単調な生活の中にとじこめられ、夕食後、廃帝の部屋へ集って低い声で讃美歌やケルビンの歌を合唱することだけがただひとつの慰安になった。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
