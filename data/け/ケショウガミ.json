        "examples": {
          "standard": [
            {
              "text": "食卓を汚さないように、ランチョンマットの上に化粧紙を敷いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お祝いの席では、箸袋として上品な化粧紙が使われることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "和菓子を包むのに、柄の美しい化粧紙を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はこのごろ果実屋の店頭に見られる梨の実の、薄い化粧紙に包まれた青白い透き徹るやうな肌と、舌に載せると、そのまま溶けて消えさうなきめの細かい媚態とに、あの華陽洞の隠士のついぞ知らなかつたらしい一味の清愁と近代の憂鬱とを感じて、それに強く心がひかされるものだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は默つて、化粧紙で小鼻のあたりを拭つてゐた。",
              "citation": {
                "source": "新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
