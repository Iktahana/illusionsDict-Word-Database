      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "omission of a character",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＊　このプラカートの欠字は一九四八年の今日うずめることができない。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日（欠字）に警報が出たが、間もなく空襲警報となった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月に生れ、二月に柔ぎ、三月に芽ぐみ、四月に〔一字欠字〕び、五月に茂る。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで（註　このあと数字欠字）壇は団へと解体され再組織化されることとなる。",
              "citation": {
                "source": "「壇」の解体",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "□□□及び□□という二ヶ所の欠字については、これまた後にタンテイの次第を申上げます。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本に、ごく稀に、二字三字ずつ欠字があるのは、なぜでしょうね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫くいにしては数が少なすぎるし、欠字の形が縦横に不自然でなければならない筈だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この欠字はいつもタテであるし、前後がハッキリしていて、ある単語や、ある意味をなす一句の全部がチョッキリ欠字になっていることを示しているのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこの欠字は人から人へ写本されつつあるうち、誰かが故意に欠字にしたものだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも甚しく曰くありげなところに限って欠字になっているのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じところが欠字になっているかしら。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰くありげとは、天皇の名とか、ミササギの場所とか、そういう事が記載されているらしい所に限って欠字になっているのさ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると「入鹿臣□□林太郎」という欠字には、どうやら、天皇的な、それに類する語、蝦夷の私製の特別な語があったのかも知れないが、そういう語がはいっていたのではないかね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この欠字の特殊な在り方によるのみではなく、日本書紀が蝦夷入鹿を誅するのを記述するに途方もないテンカンやヒステリイの発作を起しているからです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま書紀にそういう文章があって、同時に上宮聖徳法王帝説という妙に冷静な欠字をもった書物があったということが、おのずからムラムラと私にタンテイの意慾を起させただけのことです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠字は「依而」の二字であろうか。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の窓ガラスに五色の色ガラスをはめて、その家の有様が、明治十何年（欠字）御届とある井上安治の板画「両国橋及浅草橋真図」といふのを見ると、ほとんどぼくの記憶通りの状態に写されてゐますから、相当古くからこの一角にあつた家でせう。",
              "citation": {
                "source": "私のこと",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、大名をとめて○○○の月夜かな　この欠字になっているところになんでもいいから植物の名前で埋めてみよ、ということであって、私はいろいろの植物をもってきましたが、居士は、どうしても大名らしいという点から原句に及ばぬ、もっと考えてみよ、といって承知しませんでした。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻の道○○○○○より続きけり　右の句の欠字を埋めること。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで欠字のままにしておいた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
