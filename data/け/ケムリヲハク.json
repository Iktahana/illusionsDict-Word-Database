    "definitions": [
      {
        "index": 1,
        "gloss": "to emit smoke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酒中花欠皿に開いて赤けれども買う人もなくて爺が煙管しきりに煙を吐く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はにこにこ笑ひ立ちどまって巻煙草を出しマッチを擦って煙を吐く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はにこにこ笑い立ちどまって巻煙草を出しマッチを擦って煙を吐く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なぜ、あたしの赤い煙突はあのように元気よく煙を吐くのかしら……そんな筈ではないのに！",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、青年の言葉通り、赤い煙突は再び煙を吐くことがなくなった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまた清々しく一吸して、山の端の煙を吐くこと、遠見の鉄拐の如く、「夏はさぞ涼いでしょう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、とにかく、これは問屋、市場へ運ぶのではなく、漁村なるわが町内の晩のお菜に――荒磯に横づけで、ぐわッぐわッと、自棄に煙を吐く艇から、手鈎で崖肋腹へ引摺上げた中から、そのまま跣足で、磯の巌道を踏んで来たのであった。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫いらずを飲んだ人は口から白い煙を吐くそうであるからねずみでも吐くかもしれない。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車この地を過ぎ、石炭坑數箇處この附近に發見せられ、その機械場、常に煤煙を吐くに至りて、風致頓に俗了せり。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の方を見れば、數百千の煙突煙を吐く。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして岩内じゅうの漁夫たちが一生懸命に捕獲して来た魚はまたたくうちにさらわれてしまって、墨のように煙突から煙を吐く怪物のような会社の製造所へと運ばれて行く。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤煙をうかべて流れる大川のほとりや、鉛いろの空に煙を吐く大煙突の立つ塀の近くなどに立つて時を過した。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の農場や植物園や、いたるところにある牧草畑や、豊平川の上流や、真駒内の牧場や、その頃はまだ今のやうではなかつた定山渓や、月寒や、円山や手稲山や藻岩山や、その頃近くでは熊の出る唯一の山であつた札幌岳や、煙を吐く樽前山や、――私がほんたうに自然に親しんだときがあつたとすれば、それは少年の頃であつた。",
              "citation": {
                "source": "忘れえぬ風景",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の煙突から煙を吐くだろうが、これは凝っと密集して光のない空に突き刺っている。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛びついて煙を吐く火花とならずに、しめっぽい涙が出たのは寧ろ不思議な位だ。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　變な顏をしてお駒は言つたが、何と思つたか、定吉の煙草入と煙管とを引き寄せ、一服詰めてまだ燃えてゐる蝋燭の火につけ、苦さうに顏を顰めて煙を吐くと、コン／＼と咳をして、板の間に顏を摺り付けつゝ咽せ入つた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その黒船って奴は、お前、何んしろ、船の中から、煙を吐くんだそうだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほ、ほ、ほ、門弟衆に、見せてやりたいわね」　平馬は、唇をゆがめるようにして、煙を吐くと、荒っぽく、ぽんと雁首を灰吹きに叩きつけて、立ち上って、庭に下りようとする。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかかる評価とは、かく煙を吐く浅間山は雄大であるとか、すだく虫は可憐であるとかいう評価と同じく、自然的事実に対する評価であって、その責任を問う道徳的評価の名に価するであろうか。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干の所へ倚つて見ますと、本宅の煙突は午近くなつてます／＼濃い煙を吐くやうになり、窓の隙間から男女の雇人の烈しく働いて居る姿の見えるにつけて、私は我儘者、不勉強者であると云ふことばかりが思われるのでした。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方八方から、内外に迫る不調和の感じ、的のない憤り、生活力が適当なはけ口を見出せないで黒煙を吐く心持。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒煙を吐く煉瓦づくりの製造場よりも人情本の文章の方が面白く美しく、乃ち遥に強い印象を与えたがためであろう。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビレラフォンの方では、その代りに、怪物の獅子首に致命傷を与えて、それがもうぶらりと垂れてしまって、口の中の火もほとんど消えて、ぱくぱくと濃い黒煙を吐くくらいにしてしまいました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向は日の光の強い為に立続く人家の瓦屋根をはじめ一帯の眺望がいかにも汚らしく見え、風に追ひやられた雲の列が盛に煤煙を吐く製造場の烟筒よりも遥に低く、動かずに層をなして浮んでゐる。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向は日の光の強いために立続く人家の瓦屋根をはじめ一帯の眺望がいかにも汚らしく見え、風に追いやられた雲の列が盛に煤煙を吐く製造場の烟筒よりも遥に低く、動かずに層をなして浮んでいる。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭を焚いて臭い煙を吐く蒸汽船に、たとえば茶のような商品は、いかになんでも、積むことができない。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "……池の畔りに、高い煙突からもくもくと黒煙を吐く赤煉瓦の建物がある。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの煙を吐く煙筒などいうものは昔はなかりしほどに、世の中は桜も、藤も、美しく見物いたし候が、煙のある今日は花も、紅葉も、みな煙り候え」　淀君は今日三河の山奥の人々が訛るような口調で静かに物語られた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
