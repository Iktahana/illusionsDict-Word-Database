        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふだんケチケチ働いてばかりいるんでしょう？",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、町のおじさんおばさんは、いなかの人のように、お銭のことではケチケチしません。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、町のをぢさんをばさんは、田舎の人のやうにお銭のことではケチケチしません。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケチケチしてたつて仕様が無いよ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして直ぐに不景気になつて、家庭に居る間はケチケチと煩い小言を、女に浴せた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はよく譲吉に、「貴方のように、ケチケチして居ては、何時が来たって買えやしないわ。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケチケチ勉強なんかして、エラくなるぜ、そういう奴は」「ま、いいじゃないですか」　ワラが、クスクス笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浅川ッたら蟹工の浅か、浅の蟹工かッてな」「天皇陛下は雲の上にいるから、俺達にャどうでもいいんだけど、浅ってなれば、どっこいそうは行かないからな」　別な方から、「ケチケチすんねえ、何んだ、飯の一杯、二杯！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "金なんて心配するねエ……おふくろがケチケチ云へば友達に借りるよ。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大丸の親爺め、どうせ今年きりでこの鰊場投げ出さずばなんめえものを、わずかばしのものケチケチしやがって思いきりのわりい奴だてば。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――物を粗末にしないことは尊い、しかも、ケチケチすることはみじめである、卑しくなるな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚劣で単調なケチケチした環境に永らく圧迫されて圧結していた感情が、時を得て一時に爆発したに過ぎなかったのだ。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "△私たちの生活は雑草にも及ばないではないか（と草取をしながら私は考へた）見よ、雑草は見すぼらしいけれど、しかもおごらずおそれずに伸びてゆくではないか、私たちはいたづらにイライラしたり、ビクビクしたり、ケチケチしたり、ニヤニヤしたりしてばかりゐるではないか、雑草に恥ぢろ、頭を下げろ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケチケチ体制のスタート　大内淳義は、迷い続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋葉原に続いて、横浜、名古屋、大阪に開設していたビット・イン、そして通常は電子デバイスを扱っている販売店の中で特に希望するところ数か所だけに流すという、新規の経費を抑えたケチケチ体制で臨むこととした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察部長はどうやら酒をケチケチするのが嫌いな性分らしく、乾杯は何度ということなく重ねられた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "チビチビ、ケチケチ、ならしにしてなまけているのはいけない。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "金兵衛は相当ケチケチした親方らしいが、それでも人使いが上手かったのだろう。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "町子はまたイラ／＼して本当にまあどうしてこんなにイヤなケチケチした了見をもつてゐるんだらうと思つた。",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は一度だしたお金をケチケチするもんじゃないよ」「オレは男じゃねえよ。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれには、楽園とも思われた渋谷のバラック住いは、千々子さまにとっては、地獄以上の苦痛だったので、ケチケチした貧乏暮しが、癪にさわってたまらない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケチケチしないで、思いきり豊かにやっていただきたいの。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな、あんたはん見たやうな青年団がケチケチするの、見とむないぜ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香代　いいぢやないか、ケチケチするない。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケチケチするねえ江戸っ児だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕樣がねえなア」「ケチケチ言ひなさんなよ、酒の一本や二本、何んでえ」　船頭の三吉は、お燗番の卯八の文句に取合ふ樣子もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "笑ひ茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "しようがねえなア」「ケチケチ言いなさんなよ、酒の一本や二本、なんでえ」　船頭の三吉は、お燗番の卯八の文句に取合う様子もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笑い茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいわよケチケチしないでよ、田村のおばさまがみな払ってくださるわ、それに、金魚藻をどっさり包んでね、ほかに、今年のたべおさめに、みみずのみじん子を缶詰の空かんに一杯入れて頂戴、久しくいただかないから、どんなに美味しいでしょう。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいいから、テオさんもあんたの弟なんだから、それにお金持なんだから、毎月の金を一度に五十フランずつ三度に送るなんてケチケチしてないで、一度に百五十フラン送ってくれたらどうなの？",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
