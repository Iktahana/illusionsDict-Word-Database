[
  {
    "uuid": "348aeccf-a97f-5306-88cb-9f346dcc63ff",
    "entry": "見地",
    "reading": {
      "primary": "けんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
