    "definitions": [
      {
        "index": 1,
        "gloss": "land survey",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "皇居の造営、首府たる京都市街の復興、検地、金山銀山の経営、朝鮮との外交政策等を見ても、決して単なる癇癪もちの荒大名ではない。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『猫の草紙』に「その中に分別顔する鼠云々、きっと案じ出したる事あり、このほど聞き及びしは近江国御検地ありしかば免合に付きて百姓稲を刈らぬ由。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "領内利根吾妻勢多三郡百七十七箇村に検地を行い、元高三万石を十四万四千余石に改め、川役網役山手役井戸役窓役産毛役等（窓を一つ設くれば即ち課税し、出産すれば課税するの意）の雑役を設け終に婚礼にまで税を課するに至った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらは第二の探検地、北方をさしてすすんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草四郎が松平伊豆守に当てた陣中の矢文にも、領主松倉長門守の重税を訴へ「近代、長門守殿内検地詰存外の上、剰へ高免の仰付けられ、四五年の間、牛馬書子令文状、他を恨み身を恨み、落涙袖を漫し、納所仕ると雖も、早勘定切果て――」と書いてゐる。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした、検地の役人は見えたかい」と、先方はやっぱり竿と針の方を見ながら米友に問いかけるのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、気をつけて帰り給えよ、それは拙者から言って聞かすまでもないことだが、今日は別して、通行に気をつけなくてはならん」「それは、どういうわけなんだ」「それはな、さいぜん、それ、君に向って尋ねたろう、検地の代官がこの土地へ来たか来なかったか、そのことをうっかり拙者が君に尋ねたろう、それなのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ例の老中差廻しの検地の役人の一行が、東の方から威儀堂々として通りかかったのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの、虎狼も三舎を避けるはずの江戸老中差廻しの検地役人の一行が、この長持と駄馬とのために行手を遮られてしまったのですから、これはただで済まされないのが当然です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後の、この地方一帯への見せしめのため――老中差廻しの検地役人の一行が、ことごとく怒髪天を衝きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが大公儀直通の検地お代官なのだから始末が悪い！",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友としては、検地の役人の一行の余憤でこの馬が、イヤというほど尻っぺたをひっぱたかれたから、それでこうして暴れ出して来たのだとは思いもよりません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "無軌道に走って行くのは是非もなく、走れば走るほど、街道の役人の一行と民衆との混乱の現場から離れて行くのは是非もないことで、しかし、これだけを以て見れば、それは検地役人一行のためにも、米友のためにも、むしろ幸いであったということを、米友の知れる限りの人が是認し且つ安心する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方怒髪天を衝いて、片っぱしからちかよる民衆をひっくくり上げた検地役人の一行は、いったいこの村は何という村？",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "検地の役人は、多分そんなふうにまで憎悪が進んでいったらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋敷跡には代官屋敷の地名も残ったが、尾張藩への遠慮から、享保九年の検地の時以来、代官屋敷の字を石屋に改めたともいう。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "村方の関係としては、当時の戸籍とも言うべき宗門｜人別から、検地、年貢、送籍、縁組、離縁、訴訟の手続きまでを記しつけたもの。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保検地以来のことを記したあたりはことに省いてあって、そのかわり原案の草稿にない文句が半蔵の目についた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠勝入国の際検地が案外寛大であったので、農民その徳を頌し、土地を測るに用いた間竿を切って神に祭ったのだというのである。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにこの高家川部落創設許可の際の約束書に、「隣村萩原村慶長年暦御検地の砌、皮田の者三人之由、此節にては多人数に相成、野山等苅込にて、本郷一統迷惑に及び」云々とあるのを見ると、慶長以来享和以前の二百年間にも、夥しい増加のあった事が察せられるのである。",
              "citation": {
                "source": "特殊部落の人口増殖",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛文検地帳ニハ、此社ノ跡辺皆仮名ニテフクチト記タルハ誤ナルコト知ヌベシ。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又隣村｜縄ノ上小松明神文永癸酉（十年）年十二月十五日ノ棟札ニ、都留郡福地郷之上村トアリ、又鳥沢ノ南桂川ヲ隔テ藤崎村アリ、古検地帳ニ伏地埼、伏崎トモ記セリ、是又福地崎ナルベシ。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『国志』は検地帳にフクチと記したるは誤なること知ぬべしと書けるも、其理由は挙げてない。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此名の初めて地図に記されたるは、蓋し前記明治十三年十月出版の『上野国全図』ならんも、『郡村誌』に拠れば、貞享三年九月の東小川村の検地水帳に、字地の中に明に菅沼なる名称を掲載せるを見る。",
              "citation": {
                "source": "古図の信じ得可き程度",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の諸算書を見るに、築城、河川、売買貸借、測量検地、度量衡、金銀の換算、租税、木材、その他の実用に関するもの多く、卑近な商工業用とともに武士階級に必要なるものも説かれている。",
              "citation": {
                "source": "和算の社会的・芸術的特性について",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは検地の事業が始まる。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "検地水利などの必要も起こる。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを土地台帳の作成と同時に、全国一統の一間一分の絵図に引き直したのが、明治新政を記念するあの大きな検地事業であった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府の代官の検地というのがあって、それと土地の者とが衝突して、その巻添えを喰ったために、米友の連れて来た馬が逸走して、それを米友が追いかけて、ついに姉川の古戦場の川原まで行ってしまったことがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "検地の代官を呪う一味徒党の片われがいるかいないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
