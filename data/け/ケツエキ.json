[
  {
    "uuid": "47ccfbb0-5d57-5ef4-959b-bce5a7ae6946",
    "entry": "血液",
    "reading": {
      "primary": "けつえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
