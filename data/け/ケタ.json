        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『やつちまへ』『疊ん仕舞へ』彌次馬の聲援、畢竟は我が味方と、芳は勇み立つて、無手と對手の襟髮を掴むや、馬手の下駄は宙を飛んで、その頬桁を見舞はんとす。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鳥居の柱は立っているが上の横桁が外れかかり、しかも落ちないで危うく止まっているのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の方へ下りる坂脇の稲荷の鳥居も、柱が立って桁が落ち砕けていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ桁が違っていよう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる測定をなす際にも直接間接に定め得る数量の最後の桁には偶然が随伴す。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小刀を井戸の桁の上に置いて水を釣ったが釣瓶を漸くの事引摺り上げると、其拍子に小刀はポカンと音して井戸の中へ落て了った。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは極めて大ざっぱな目の子勘定ではあるが、それでもおおよその桁数としてはむしろ最悪の場合を示すものではないかと思われる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場のある向うの丘からこちらの丘へ燈火をつけない橇が凍った雪に滑桁をきし／＼鳴らせ、線路に添うて走せてきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄鉄のひゞきと、滑桁の軋音の間から英語のアクセントかゝったロシア語が栗本の耳にきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は滑桁の軋音を残して闇にまぎれこんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は、踏みつけられた雪に滑桁を軋らして、出かけて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつか放送局でラジオ相談所として推薦した本郷の某ラジオ屋へ試みに修繕に出したら、今度は断然｜桁ちがいに感度を低下してしまって、もう拡声器では聞かれなくて、テレフォンでやっと聞こえるようになってしまった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女たちがまた手伝って、衣桁にかけてある艶やかなお振袖を取って、お蝶のすくんでいる肩に着せかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑桁のきしみと、凍った雪を蹴る蹄の音がそこにひびくばかりであった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は雪の上に二筋の平行した滑桁のあとを残しつつ風のように進んだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑桁の金具がキシキシ鳴った。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちとらとは、桁が異うわい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな井桁、堂々とした石の組み様、がっしりしていて立派であった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小児に振向けた、真白な気高い顔が、雪のように、颯と消える、とキリキリキリ――と台所を六角に井桁で仕切った、内井戸の轆轤が鳴った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "工学士は、井桁に組んだ材木の下なる端へ、窮屈に腰を懸けたが、口元に近々と吸った巻煙草が燃えて、その若々しい横顔と帽子の鍔広な裏とを照らした。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東枕の白い切に、ほぐしたお髪の真黒なのが濡れたやうにこぼれて居て、向ふの西向の壁に、衣桁が立てゝあります。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――義兄さんの歌の本をお読みなさるのと、うつくしい友染を掛物のやうに取換へて、衣桁に掛けて、寝ながら御覧なさるのが何より楽なんですつて。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の苔蒸す欄干を葉がくれに、桁を蔦蔓で埋めたのが、前途に目を遮るのに、橋の彼方には、大磐石に堰かれて、急流と奔湍と、左より颯と打ち、右より※と潜り、真中に狂立つて、巌の牡丹の頂に踊ること、藍と白と紺青と三｜頭の獅子の荒るゝが如きを見るとせよ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、もしも、シノニムの数が、上記４の二倍であるとすれば、以上の百分値はやはり二倍になるだけであるから、このほうから結果の桁数に著しい影響は起こらない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に比較の標準を少し下げて、メタセシスを許容すると、Ｐの展開式のｉ項に※が乗ぜられる事になるが（ただし子音が皆異なるとして）、これでは少なくもｎがあまり小さくない限り、明らかに最後の結果の桁数に変化は起こらない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな「間違い」や「杜撰」でさえも、最後の結果の桁数には影響しないというところにある。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても偶然の場合とは桁数がちがって多い。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは現在の場合結果の桁数を変えるほどの影響がありそうもないことは少しあたってみてもわかると思う。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駿河町」の絵を見ると、正面に大きな富士がそびえて、前景の両側には丸に井桁に三の字を染め出した越後屋ののれんが紫色に刷られてある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人数の桁数のちがうデパートであったらはたしてどうであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
