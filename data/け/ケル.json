        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "叫び声、殴る響、蹴る音が、仄暗いプラットフォームの上に拡げられた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うーむ、吉兵衛、手は何だ」　「手は金銀に桂二枚」　「そうか、金銀に桂二枚と……」　次郎長、将棋盤を蹴る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、きしきしという軋りが聞えて、氷上蹄鉄を打ちつけられた馬が、氷を蹴る音がした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑桁のきしみと、凍った雪を蹴る蹄の音がそこにひびくばかりであった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして脚を抜く時に蹴る雪が、イワンの顔に散りかかって来た。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし内川が、彼を蹴るなら蹴るで、彼は又、彼として、考えがあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて背戸と思う処で左に馬小屋を見た、ことことという音は羽目を蹴るのであろう、もうその辺から薄暗くなって来る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲つな、蹴るな、貴下酷いことをするじゃあありませんか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱ぎ捨てる時も、ズボンのポケットに両手をつっこんだままで、軽く虚空を蹴ると、すぽりと抜ける。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴんと張り拡げられた薄墨いろの肉翅のまん中で、毛の胴は異様に蠢き、小鳥のような足は宙を蹴る。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　（発き出したる形代の藁人形に、すくすくと釘の刺りたるを片手に高く、片手に鉄槌を翳すと斉しく、威丈高に突立上り、お沢の弱腰を※と蹴る）汚らわしいぞ！",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居に置けば、蹴る、脇へずらせば踏もうとする。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は右の足を働かして強く蹴ると、敵は足下に倒れたらしい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子が不幸の小石を蹴ること。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうずねもまた相当に痛いことを知ったが、これは足で蹴るのに都合のよいところであって、次郎兵衛は喧嘩に足を使うことは卑怯でもありうしろめたくもあると思い、もっぱら眉間と水落ちを覘うことにきめたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴんと張り拡げられた薄墨いろの肉翅のまん中で、毛の胴は異様に蠢き、小鳥のやうな足は宙を蹴る。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三の方は道を歩いて来たためにちと脚が草臥ているからか、腰を掛けるには少し高過ぎる椽の上へ無理に腰を載せて、それがために地に届かない両脚をぶらぶらと動かしながら、ちょうどその下の日当りに寐ている大な白犬の頭を、ちょっと踏んで軽く蹴るように触って見たりしている。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に性急である、故に彼等に、其理論の堂々として而して何等危險なる要素を含んでゐないに拘らず、未だ調理されざる肉を喰ふが如き粗暴の態と、小兒をして成人の業に就かしめ、其能はざるを見て怒つて此れを蹴るが如き無謀の擧あるは敢て怪しむに足らぬので有る。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏む、蹴る、下駄で敲く、泥溝へ突仆す。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "川蒸汽の、ばらばらと川浪を蹴るのなんぞは、高櫓の瓦一枚浮かしたほどにも思われず、……船に掛けた白帆くらいは、城の壁の映るのから見れば、些細な塵です。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て脊戸と思ふ処で左に馬小屋を見た、こと／＼といふ物音は羽目を蹴るのであらう、もう其辺から薄暗くなつて来る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲つな、蹴るな、貴下酷いことをするぢやあありませんか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイリスは、地を蹴る乱雑な響に腹底をいたぶられた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり足を蹴るものがある。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいわよ」　安子はいきなり戸を蹴ると、その足でお仙の家を訪れた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "力よ、荒魂飛び搏くと、勢ひ蹴るひと空や、はたはた、ああ、はたはた、光の、陽のしじまの耿たる幅乱すと。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三町目谷の坂下へ来かかると、麹町通りの方から雪を蹴るようにして足早に降りて来る人々があった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し青は、その人間を蹴るでもなく、斜坑の斜面を押し上げられて行った。",
              "citation": {
                "source": "狂馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年紳士は、ゆったりと、煙草を燻らしながら地面を蹴るようにして歩いた。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
