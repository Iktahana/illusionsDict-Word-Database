    "definitions": [
      {
        "index": 1,
        "gloss": "Superintendent General of the Metropolitan Police",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
