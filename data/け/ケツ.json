[
  {
    "uuid": "1d490a44-c775-58b2-91f0-df6ef800ce80",
    "entry": "穴",
    "reading": {
      "primary": "けつ",
      "alternatives": [
        "ケツ"
      ],
      "is_heteronym": false
    },
    "grammar": {
