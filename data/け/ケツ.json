    "definitions": [
      {
        "index": 1,
        "gloss": "ass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上に芥川君は、小穴隆一君や堀辰雄君等の、大勢の若い人たちと一緒であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の胸には借金の穴が黒くぽかんとあいている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹の顔は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の遠い先祖は、冬の来る前に穴を掘り、熊や狐やの獣と共に、小さくかじかまつて生きたへて居た。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椀を流し口の穴の上に俯向きに当てて、押したり放したり押したりまた放したりする。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し口の穴のつまったのをこうして疎通させる工夫と見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金谷の隧道長くて灯を点したる、これは昔蛇の住みし穴かと云いししれ者の事など思い出す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを自分だけが陰気な穴の中で聞いているような気がする。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか暗い何もない穴のような処へ来ている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な眼をして凍つたやうになつて、地図を穴のあく程みつめて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際、今は、穴あらばはひりたい氣持です」と書いて寄こしました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銚子の底くらゐの大きい深い穴が腰にぽつかりできてしまつたのです。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その翌る日、狸は自分の穴の奧にこもつて唸り、「ああ、くるしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こつちだ、穴の奧だよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほほう、」とよろこび、穴の奧からゐざり出て、「や！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は穴の奧で三日間は蟲の息で、生きてゐるのだか死んでゐるのだか、それこそ全く幽明の境をさまよひ、四日目に、猛烈の空腹感に襲はれ、杖をついて穴からよろばひ出て、何やらぶつぶつ言ひながら、かなたこなた食ひ搜して歩いてゐるその姿の氣の毒さと來たら比類が無かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向って蝙蝠岳の残雪が、銀光りに輝いて、その傍に三角測量標が、空を突いて立っている、間の岳（赤石山脈）は森に隠れて見えない、冷い風が、暗い穴からでも来るように、ひいやりと吹く、鳥はひんから、ひんからと、朗らかに囀ずる、登るに随って、蝙蝠岳はほぼ正西に、間の岳は北西に、いずれも残雪白く、光輝を帯ぶ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く穴の中から這い出したい。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空々寂々の境で、山という山の気分が、富士山に向いて、集中して来る、谷から幾筋とない雲が、藍の腐ったような塊になって、立ち昇る、富士山はこの雲と重なって、心もち西へ西へと延びて来るようだ、蝕った雲の淵の深さが、何十尺かの穴となって、口が明く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入っては、私は虫が嫌いなので、障子を締め切ってしまうと、あっちでも、こっちでも障子の外で、カサカサカリカリと忍び音がする、嘴や鬚で、プツリと穴を明けて、中を覗き込んで、呪っているのではあるまいかと、神経が苛々する。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体を白く塗つてゐないから、白鳥とは見えないが、又鰭を振る魚とも見えない、船の長さ七間半、幅四尺、深さ三尺ぐらゐで、両方の舷側には、小さな穴を明け、棕櫚繩で、長さ九尺ぐらゐもあらうかといふ樫製の櫂を、左右に二挺結びつけてある、櫂の折れ目に鉄環でツギをあてたのもある。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる所には怖ろしい罅穴（Crevasse）が出来て、穴の深さは二、三丈位に達するのを往々見受ける。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本山岳における万年雪の罅穴の標本としては、信州白馬岳の大雪田の末、白馬尻に見ることが出来る、日本山岳会員辻村伊助氏の説明によると、この罅穴は幅約一米突深さ五米突に及んでいるそうである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、絶えず、空家の二階から、おとし穴のやうなＮの借間を訪問した。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鼻の穴に指を突っ込んで、鉄筋コンクリートのように、鼻毛をしゃちこばらせている、コンクリートを除りたかったのだが一分間に十才ずつ吐き出す、コンクリートミキサーに、間に合わせるためには、とても指を鼻の穴に持って行く間はなかった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鼻の穴を気にしながら遂々十一時間、――その間に昼飯と三時休みと二度だけ休みがあったんだが、昼の時は腹の空いてる為めに、も一つはミキサーを掃除していて暇がなかったため、遂々鼻にまで手が届かなかった――の間、鼻を掃除しなかった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると『それ貝が鳴った』とばかり、夫人を初め女中や書生たちが大騒ぎをし、先を争って離れの書斎に駈けつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちはその場合、できるだけつまらなそうな顔をしてやろうじゃありませんか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気の弱さは、気の弱い人が人を気にしない間、善良をだけつくるのだが、人を気にしだすや、それは彼自身の生活を失はせる、いとも困つた役をしはじめる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今は余つぽど好くなつた方だが、まだあんたの生れない頃Ｆ町にゐる時なんかは、それはそれはお母さんのお友達といふお友達が、とても貴方は体が続くまいから出て行け出て行けつてさへ言つたものですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
