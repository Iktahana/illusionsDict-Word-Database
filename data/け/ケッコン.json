[
  {
    "uuid": "45d9e5c4-f0c6-5fef-a6d7-354eb9a3d4e3",
    "entry": "結婚",
    "reading": {
      "primary": "けっこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "marriage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しルモオルと結婚した。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルン夫妻の結婚は、すべての点において特異であり、世の常の凡俗な夫婦関係とちがっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と結婚して間もない頃、雨でずぶ濡れになった小猫を拾って帰り、その泥だらけのままの猫を懐中に入れて、長い間やさしく暖めていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が結婚致しましたのは、松江に来てからのことで、二十四の秋でございますから、当時としてはずいぶん遅い結婚でございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、美しい結婚できます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病な私には、人の結婚の世話など、おそろしくてたまらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小生と雖も、貴兄の幸福な結婚を望んでいる事に於いては人後に落ちないつもりだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、小坂氏と相談して結婚の日取をきめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、結婚式の日まで一週間、私の家に滞在する事になっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの結婚の事に就いては少しも言わず、ひたすら世界の大勢に就き演説のような口調で、さまざま私を教え諭すのであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚に感激を持っていません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　四月二十九日に、目黒の支那料理屋で大隅君の結婚式が行われた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その料理屋に於いて、この佳き日一日に挙行せられた結婚式は、三百組を越えたという。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式は午後五時の予定である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんとお母さんとは、結婚してから十二年経つても子供が生れなかつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年十二月、結婚。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の人生に於ける唯一の理想は、重役の娘と結婚して、郊外の文化住宅に住み、何も他に為すことがなく、新婚の妻と朝から晩までイチヤついて居たいのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の初節句、結婚の披露、還暦の祝い、そういう機会はすべて村のバッカスにささげられる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ことしのお正月に、甲府の人と平凡な見合ひ結婚をして、けれども私には一錢の貯金も無し、すぐに東京で家を持つわけに行かなかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の敷金として、百圓くらゐ用意しなければならぬし、その他家財道具一切を買はなければならぬし、そのためには、どうしても、もう百圓は必要であらうし、とにかく、結婚當時の私には、著てゐる著物と、机と夜具、それだけしかなかつたのであるから、ずゐぶん心苦しいことが多かつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚してもう十年以上にもなるのだが、未だ世繼が無いのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はこの山には人身の岳神が住み守ると聞いたが、それにしたら、その岳神は結婚していて、恐らくその妻は良人より年長のいわゆる姉女房であるであろうと山占いをした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が主人に連れられて東海道を始めてみたのは結婚の相談が纏まって間もない頃である。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私と主人との結婚話が決まると、その日から灰吹掃除を書生に代ってやらせた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚後も主人は度々東海道へ出向いた中に私も二度ほど連れて行って貰った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "確か芭蕉だと思った」「では私たちは男竹斎に女竹斎ですか」「まあ、そんなところだろう」　私たちの結婚も昂揚時代というものを見ないで、平々淡々の夫婦生活に入っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な結婚をした出戻りではあるがまだ三十になったばかりの美しい敏子はかなり派手な着物をすらりとした身体に着こなして魅力の溢れた挨拶をした。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分の研学の仲間に南ロシアから来ている女学生があって、その後一九〇三年にこの人と結婚したが数年後に離婚した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、いうわけで、王女さまはけっこんしようとおもいたちました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
