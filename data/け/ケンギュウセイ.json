    "definitions": [
      {
        "index": 1,
        "gloss": "Altair (star in the constellation Aquila)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
