[
  {
    "uuid": "ce0bda71-9bf0-564a-8d6a-0d5aba5f88a8",
    "entry": "兼題",
    "reading": {
      "primary": "けんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "subject for a poem (announced prior to a meeting of poets)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶を飲みながら兼題の歌、橋十首を作る。",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の兼題は「雉子」と「藤」とだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは床屋連、八公連などが月並の兼題を得て景物取りの句作を為すよりかくいひし者が、俳句の流行と共に今は広く拡がりて、わけも知らぬ人まで月並調といふ語を用ゐるやうになれり。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一、二歳の時｜夙く奉公に出たのであるから、教を受けるには、宿に下る度ごとに講釈を聴くとか、手本を貰って習って清書を見せに往くとか、兼題の歌を詠んで直してもらうとかいう稽古の為方であっただろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "床前に坐らせられた正客の栖方の頭の上に、学位論文通過祝賀俳句会と書かれて、その日の兼題も並び、二十人ばかりの一座は声もなく句作の最中であった。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶と高田は曲縁の一端のところですぐ兼題の葛の花の作句に取りかかった。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜学すすむ教師の声の低きまま昭和七年九月十日　『山茶花』十週年記念大会兼題。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "囀や絶えず二三羽こぼれ飛び昭和八年六月十三日　北海道旭川俳句大会兼題。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道々の余花を眺めてみちのくへ余花に逢ふ再び逢ひし人のごと五月十三日　仙台俳句会兼題をおくる。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼題に「網戸」あり。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に信州では「けって」なる言葉を生み、陸中には「けんだい」なるいい方が残る。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
