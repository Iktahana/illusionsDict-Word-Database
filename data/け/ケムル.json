    "definitions": [
      {
        "index": 1,
        "gloss": "to smoke (e.g. fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さみだれが煙るように降る夕方、老妓は傘をさして、玄関横の柴折戸から庭へ入って来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻の梢は立派な寄木を遠い南の空に組み上げ私はたばこよりも寂しく煙る地平線にかすかな泪をながす。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば南洋エファテの Aso（燃える）Asua（煙る）サモアの Asu（煙）や、マレーの Asap（煙）（マレイでは火山は Gunong berasap すなわち煙山とも Gunong berapi 火山ともいう。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはヘブリウの ‘Esh（火）‘as´en（煙る）‘as´an（くすぶる）などが示唆され、これと関係あるアラビアの ‘atana（煙る）から西のほうへたぐって行ってイタリアの Etna 火山を思わせ、さらに翻ってわが国の Iduna を思わせる。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨に煙る泥道の上には彼れ一人の影が唯一つ動いた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまでの距離はないが、月夜には柳が煙るぐらいな間で、島へは棹の数百ばかりはあろう。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その森、その樹立は、……春雨の煙るとばかり見る目には、三ツ五ツ縦に並べた薄紫の眉刷毛であろう。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊男はまた俊男で、素知らぬ顏で降濺ぐ雨に煙る庭の木立を眺めてゐた。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　河の氷がようやく崩れはじめ、大洋の果てに薄紫の濛靄が煙るころ、銀子はよその家の妓三四人と、廻船問屋筋の旦那衆につれられて、塩釜へ参詣したことがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ、そうに違いありませんけれど、やっぱりたかが金魚ですからね」　すると真佐子は漂渺とした顔付きの中で特に煙る瞳を黒く強調させて云った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朦朧とした写真の乾板色の意識の板面に、真佐子の白い顔が大きく煙る眼だけをつけてぽっかり現れたり、金魚の鰭だけが嬌艶な黒斑を振り乱して宙に舞ったり、秀江の肉体の一部が嗜味をそそる食品のように、なまなましく見えたりした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙るような長い睫の間から瞳を凝らしてフォークに眼を遣り、瞳の焦点が截片に中ると同時に、小丸い指尖を出してアンディーヴを撮み取った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその遠方に模糊と煙るが如く白くひろがつてゐるのは、十三湖らしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暴戻な肘で撃れる度に、何故かイベットの睫の煙る眼ざしを想出す。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、セントルイスの前をはなれて、カラ子は雨に煙る木屋町の灯の方へ歩き出したが、急に踵をかえして、しかし、トボトボとその横丁をセントルイスの軒下へ戻って来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には苦き嘲笑に雲かき乱れ、重りゆく煩悶のあらびはやもまた黒き恐怖のはたためき海より煙る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鷺は貴くて、身のほそり煙るなり、冠毛の払子曳く白、へうとして、空にあるなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんまろきもの、輪のごときもの、いつまでも相逢はず平行びゆくもの、また廻るもの、はじめなく終りなきもの、煙るもの、消なば消ぬかに縺れゆくものみなあはれ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんまろきもの、輪のごときもの、いつまでも相逢はず平行びゆくもの、また廻るもの、はじめなく終りなきもの、煙るもの、消なば消ぬがに縺れゆくものみなあはれ。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄み透る明るい空の青が、水平線近くで、茫と煙る金粉の靄の中に融け去つたかと思ふと、其の下から、今度は、一目見ただけで忽ち全身が染まつて了ひさうな華やかな濃藍の水が、擴がり、膨らみ、盛上つて來る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄み透る明るい空の青が、水平線近くで、茫と煙る金粉の靄の中に融け去ったかと思うと、その下から、今度は、一目見ただけでたちまち全身が染まってしまいそうな華やかな濃藍の水が、拡がり、膨らみ、盛上って来る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の雨に煙る京の町の青いほのくらさが車窓にくもり、玉江は傍のクッションに埋めた父の身体の中で、がらがらと自信が崩れて行く音をきく想ひがした。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて若葉に山の煙るころから啼きそめる鳥である。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の山に啼く鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "然までの距離はないが、月夜には柳が煙るぐらゐな間で、島へは棹の数百ばかりはあらう。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんだうの花のコップが、湧くやうに、雨のやうに、眼の前を通り、三角標の列は、けむるやうに燃えるやうに、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黝き菅藻の袍はねて、　　　　叩きそだたく封介に、雲ののろしはとゞろきて、　　こぶしの花もけむるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんどうの花のコップが、湧くように、雨のように、眼の前を通り、三角標の列は、けむるように燃えるように、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大庭葉藏が、ベツドに坐り雨にけむる沖を眺めてゐるのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨にけむる沖を眺めたわけである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思つたら、もう次から次から、たくさんのきいろな底をもつたりんだうの花のコツプが、湧くやうに、雨のやうに、眼の前を通り、三角標の列は、けむるやうに燃えるやうに、いよいよ光つて立つたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
