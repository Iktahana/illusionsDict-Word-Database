[
  {
    "uuid": "03a6c99e-b183-5dce-8ba5-8a668f841744",
    "entry": "毛筋",
    "reading": {
      "primary": "けすじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
