[
  {
    "uuid": "61e9b3fa-e0d9-56dd-92cd-31eb4b7bd96a",
    "entry": "脛骨",
    "reading": {
      "primary": "けいこつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
