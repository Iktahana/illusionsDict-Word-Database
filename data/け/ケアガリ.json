        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　鳥は、ついておいでというように、蘆のなかから飛びだして、南の青いそらの板に、射られた矢のようにかけあがりました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、一生けん命、駈けあがりました。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみはくるっと一つまわって、いちもくさんに天井裏へかけあがりました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊江はそこの傾斜の赭地の肌を駈けあがりながら揮返った。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠屋は兎もかくもその門口へおろすと、大次郎は待ちかねたように転げ出して、その二階へ駈けあがりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちは艇をとび出して、水を渡って海岸の砂の上に馳けあがり、気のゆるみで二人とも、人事不省に陥った。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端にお妙は傘も包みも投げ出して内へ駈けあがり、屏風を押倒して父の手に取りすがる。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "文三さんとやら、さあおはいり」　声に応じて陣幕をかかげ、恐る恐る姿をあらわしたのは、さっき盆地を駈けあがり、天草の部下にとらえられた男、楠右衛門の子の文三であった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の制止も聞かばこそ、改札口をやぶり、なだれをうって一部はプラットホームに駈けあがり、そこに停車していた列車にわれがちに乗りこんだが、そこでも百人近い死傷者が出た。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿者どもめ、つけあがりをつて、わしを同輩かなんぞのやうに思つてけつかるのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "かふ申てもけして／＼つけあがりハせず、ますますすみかふて、どろの中のすゞめがいのよふに、常につちをはなのさきゑつけ、すなをあたまへかぶりおり申候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには、いちばん駭いて、部屋の端にあった階段を、むちゃくちゃに駆けあがりました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三十段も駆けあがり、次の一足を踏みだそうとすると、足に触れるものがありません。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてもただの親切とは思われないで、或晩密かに忍んで行くと、女はいきなり横面をひっぱたいて、「身よりもなくて可哀そうだと思って、目をかけてやれば、つけあがりやがって、生意気な真似をしやあがる。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおつけあがりますから。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗い階段を螺旋まきに駈けあがり天井を抜けると、ささくれ立ったコンクリートの屋上に出る。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "八木少年は、爆発を今とめることのできるのは自分だけであると思い、一所けんめいに階段をかけあがり、扉の錠をはずして又階段をあがり、又新しい扉にぶつかっていった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しくするとつけあがりますからね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はしておけばつけあがり思ひきつた神がかりの凄文句をぬかす奴だが、そこで、と貴殿はひらきなほり、そのセンチメンタルな情景を、さてまた何の魂胆あつて書いたんだと仰有るか？",
              "citation": {
                "source": "をみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは何ごと、と全員はおどろいて、あるいは甲板にかけあがり、あるいは高声器の方に聞き耳をたてた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫はすぐ鼻のさきに、大きなししがふいにあらわれたので、あわてて、長ぐつのまま、あぶないもこわいもなく、軒のかけひの上にかけあがりました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わしておけばつけあがり思いきった神がかりの凄文句をぬかす奴だが、そこで、と貴殿はひらきなおり、そのセンチメンタルな情景を、さてまた何の魂胆あって書いたんだと仰有るか？",
              "citation": {
                "source": "おみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、きゃっと一声、悲鳴をそこに残すと、気が変になったように室外に飛び出し、階段を三段ずつ一ぺんに駈けあがりつつ一｜米でも遠くへ遁がれようと努力した。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩田大尉は小浜兵曹長をひきつれて、すぐさま昇降口をかけあがりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
