    "definitions": [
      {
        "index": 1,
        "gloss": "the wise and the foolish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは顔だけから見た人猿優劣比較論であり、老若賢愚比較論である。",
              "citation": {
                "source": "猿の顔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だ夫れ人間に賢愚あり、善悪あり、聖汚あるは、その暗黒と照明との時間の「長さ」を指すべきのみ。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "老幼賢愚の隔意なく胸襟を開いて平々凡々に茶を啜り、談笑して御座る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドにも親王の御履歴に少しく似た話が『賢愚因縁経』十二に出て居る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し人の賢愚正邪は實のある話をした上で分かるものである。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『賢愚因縁経』四に、波羅奈国の人苦心して七瓶金を蓄え、土中に埋み碌に衣食せず病死せしが、毒蛇となってその瓶を纏い数万歳を経つ、一朝自ら罪重きを悟り、梵志に托し金を僧に施して、蛇身を脱れ天に生まれたとあり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『賢愚因縁経』十二に、舎衛国の婆羅門師質が子の有無を問うと六師はなしと答え、仏はあるべしという、喜んで仏と衆僧を供養す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『賢愚因縁経』五に、仏が給孤独園にあった時、園中五百の乞児あり、仏に出家を乞うて許され、すなわち無漏の羅漢となる、祇陀太子、仏と衆僧を請じてこれら乞食上りの比丘を請せず、仏乞食上りの輩に向い太子汝らを請せず、汝ら鬱単越洲に往き自然成熟の粳米を取って食えと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く上に引いた『賢愚因縁経』の瓢箪から駒でなくて麦を出した話から転出されたので、瓢から出た穀物を国中に施したなども両譚相似いる。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "お政治向きを譏ったり、浮世の間違いをののしったり、善悪両道のトンチンカン、賢愚明暗の行き違い、そういうのをアテッコスッたり！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚、善悪、美醜を問わず、いずれも神の子であるという自覚をもって敬愛することが大事です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚文質のひとしからざるも、いづれか幻のすみかならずや、とおもひ捨てゝ臥しぬ。",
              "citation": {
                "source": "芭蕉",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇は小便をしても手を洗わなかったり、酒を呑んだり、淫売と交際したり、漁師と友達だったりしたということであるが、僕も実に交遊天下にあまねく、虫の好く人間なら、その境遇と職業と主義と、人格と才能と美醜と、賢愚と貧富とエトセトラの如何を論ぜず、友達になる。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚、善悪、凡聖、老少、男女の区別も意義をなくする。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間界上下賢愚一同に、子孫を愛惜せざるはなく、痘疹を憂懼せざるはなし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人に貧富賢愚の差あることは実際上免れがたし、しかれどもその実際上の差等あるにもかかわらず、個人自身よりしては自ら侮りて卑屈の地に立つべからざるなり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "この劫に遇ふものは賢愚｜倶に滅びてしまふ。",
              "citation": {
                "source": "鴉片",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も鈍感といい、敏感という事は、そうした人々の賢愚の絶対値を極めるものでない。",
              "citation": {
                "source": "徹底的な浜尾君",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "意志さえ堅固なれば、賢愚を問わず、百難前に迫っても、これを冒して断行する。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは貴賤、大小、老幼、賢愚と等しく交わり、その態度は嫺雅優美なりというもおろか、愛情はその目より輝き、その唇に震う。",
              "citation": {
                "source": "武士道の山",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "家長、というのは即ち坂田で、彼は或る意味では凡庸なのだが、或る意味では凡庸の枠縁からはみ出していて、而もそれが、賢愚いずれの方へはみ出しているか見当がつかなかった。",
              "citation": {
                "source": "坂田の場合",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚、美醜、壮健な肉体もあれば病弱もあり、強情な性癖もあれば触れれば傷つく精神もあるのだ。",
              "citation": {
                "source": "咢堂小論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも仏像の類と違って賢愚雅俗のあらゆる人面の芸術的表現を余儀なくさせた。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚おしなべて哀れはかない運命の波に浮沈する盲亀の面貌である。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、この男が読んでいるならとにかく、その何とかいう犬が、こっちの裏も表も読みきっていて、善悪正邪も、賢愚不肖も、いちいち鑑定して置いて、吠えにかかるのだというのが癪じゃないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚と、不肖と、性格と、体格には、遺伝があり得るけれども、怪我というものは後天的なものだから、兄貴が負傷して跛足になったからとて、弟まで怪我をして跛足になり得るという遺伝はないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化に乏しい楽茶碗、あるいは黒無地塗りの茶器棗の如きに於ても一つは芸術として燦然たるものあり、一つは二束三文取るに足らざるものあり、驚くべき賢愚高低があるのである。",
              "citation": {
                "source": "私の陶器製作について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "材料の良否は人の賢愚善悪にも等しいもので、腐ったようなさかな、あるいは季節はずれの脂っ気を失ったさかななどは、魂の腐った人間に比すこともできれば、低能あるいは不良に比すべきもので、優れた教育家の苦心が払われたとしても、その成果はおぼつかないものであると同様である。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "人之賢愚以心、不以形、故不可遽見也。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝手に家を飛び出すなら、一切、家に迷惑をかけんぐらいの決心が必要だ。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
