        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何という大きな乾坤の動きであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の老富豪が取引所の柱の陰に立って乾坤一擲の大賭博を進行させている最中に、従僕相手に五十銭玉一つのかけをするくだりがある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾坤一擲という言葉はこんな場合に使ってはいけないだろうが、自分にはそういう言葉が適切に思い出される。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもちろん風雅の心をもって臨んだ七情万景であり、乾坤の変であるが、しかもそれは不易にして流行のただ中を得たものであり、虚実の境に出入し逍遙するものであろうとするのが蕉門正風のねらいどころである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハタと止めば、其の空の破れた處へ、むら／＼と又一重冷い雲が累りかゝつて、薄墨色に縫合はせる、と風さへ、そよとのもの音も、蜜蝋を以て固く封じた如く、乾坤寂と成る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふむまた売卜乾坤堂、天門堂とすれば可い、一番みてもらいたいくらいだ、向は仕立屋、何、仕立物いたしますか、これは耳寄、仕立屋に（ぬい）が居ようも知れねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あまつさえ、地震の都から、とぼんとして落ちて来たものの目には、まるで別なる乾坤である。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾坤一擲の意気でありました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、つまらぬ小細工ばかり弄して、男らしい乾坤一擲の大陰謀などは、まるで出来ない。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩に曰く、乾坤　果して何物ぞ、開闔　古より有り。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "能く　風雅　無窮の意を探らば、始めて是れ　乾坤　絶妙の詞ならん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾坤　恨あり　家いづくにか在る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿夭は乾坤に付す、丘の祷ることや久し焉。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の力をして縦に吾人の脛脚を控縛せしめよ、然れども吾人の頭部は大勇猛の権を以て、現象以外の別乾坤にまで挺立せしめて、其処に大自在の風雅と逍遙せしむべし。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜川由次郎、鳥羽屋小三次、十寸見和十、乾坤坊良斎、岩窪北渓、尾の丸｜小兼、竹内、三竺、喜斎等がその主なるものである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語家には乾坤坊良斎、五明楼｜玉輔、春風亭柳枝、入船米蔵がある。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを通過しなければ、鏡花世界なる別乾坤は、ついに、覗くことができないのである。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "能は常に以上の諸要素を以て、舞台面上に別｜乾坤を形成して行く。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉が「乾坤の變は風雅のたね也」と云つたといふのにも、いくらか此の意味がありはしないかと思はれる。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハタと止めば、その空の破れた処へ、むらむらとまた一重冷い雲が累りかかって、薄墨色に縫合わせる、と風さえ、そよとのもの音も、蜜蝋を以て固く封じた如く、乾坤寂となる。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾坤の白きに漂ひて華麗に差出でたる日影は、漲るばかりに暖き光を鋪きて終日輝きければ、七分の雪はその日に解けて、はや翌日は往来の妨碍もあらず、処々の泥濘は打続く快晴の天に曝されて、刻々に乾き行くなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この堂、よしや朽つとも、宗吾の氣魄は、萬古乾坤の間に磅※すべき也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷紅血を流すが如き夕燒の空を背にして進みゆくほどに、暮靄、乾坤を封じて、老杉の下の小路くらく、燈を點ずる頃、鹿野山宿に達す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すかぎり、恰も一幅の墨繪の如く、三伏のあつさもこの一雨に洗はれて、萬斛の凉味、乾坤に溢る。",
              "citation": {
                "source": "八鹽のいでゆ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "此平然たる所には、實に乾坤に充滿する無限の信用と友情とが溢れて居るのだ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此平然たる所には、実に乾坤に充満する無限の信用と友情とが溢れて居るのだ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで横浜警察署でも、いわば乾坤一擲の大勝負をするつもりで取りかかったんだ。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "言をかえていえば、それ等社会学、経済学的原則が実行に移されようとする時、乾坤一擲、新たな生命を以て、しんからうまれ変らなければならない根性が、人間の、人生に向かう態度のうちにあるのではないだろうか。",
              "citation": {
                "source": "男…は疲れている",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く一、師の云、発句案ずる事諸門弟題号の中より案じいだす是なきものなり、余所より尋来ればさてさて沢山｜成事なりと云り、予が云、我『あら野』『猿蓑』にてこの事を見出したり、予が案じ様たとへば題を箱に入てその箱の上にあがりて箱をふまへ立ちあがつて乾坤を尋るといへり、云々　と、けだしこれ題詠の秘訣なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道無門、千差有路、透得此関、乾坤独歩。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
