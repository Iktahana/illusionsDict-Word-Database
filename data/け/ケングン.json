    },
    "definitions": [
      {
        "index": 1,
        "gloss": "expeditionary army",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし懸軍数百里望郷の情は、武将の心を傷ましむるものがあったであろう。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信など長駆して来て、小田原を囲んだが、懸軍百里の遠征では、糧続かず人和せず、どうにも出来なかった。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸軍万里、計を帷幄の中にめぐらし、勝を千里の外に決する将略に於ては我義仲に比肩する能はず。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が粟津の敗死は既に彼が、懸軍長駆、白旗をひるがへして洛陽に入れるの日に兆したり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
