    "definitions": [
      {
        "index": 1,
        "gloss": "shallow, glib and obsequious person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
