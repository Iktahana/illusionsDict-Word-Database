        "examples": {
          "standard": [
            {
              "text": "交通事故で運ばれた患者は、すぐに最寄りの県病院に搬送された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の中核医療機関である県病院は、常に多くの患者で賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は県病院の看護師として、地域医療に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三人目の子供を産むために、下の児を連れて県病院の施療病室にいる女房は？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "広島県病院より）　　　三度の手術もむなしく、病院を去った長き忍耐の日　私は筆を持つとじきにあなたに訴えたき気持ちになるのです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "広島県病院より）　　　病院よ、祝福あれ　あなたたちは私らからの便りを毎日心持ちに待っていて下さったことと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年も前のことだが、死ぬ前、姉は県病院に入院していた。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
