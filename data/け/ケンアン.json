[
  {
    "uuid": "04cedb5e-b720-5e93-9c2c-fb63d3c3efff",
    "entry": "懸案",
    "reading": {
      "primary": "けんあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
