    "definitions": [
      {
        "index": 1,
        "gloss": "pending question",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「……只今では最後の懸案として、あの区長の動静について注意しているのですが」「ハイ。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二章　演繹推理学　翌日、我々は約束通りに合流し、懸案のベイカー街二二一番地Ｂの部屋を見に行った。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、此処で、「ガリバー旅行記」「ラマンチアのドンキホーテ」「ピルグリムス・プログレツス」等の遍歴物語を読み、そして私にとつて、久しい懸案であつたところの「山彦の街」と題する至極浪漫的な創作の稿を起した。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「惣八どのと甚兵衛どのとは、腕前においていずれが上じゃ」などいう懸案が同門の間に、提出せられるたびに、惣八郎は「われらがごとき」といって謙遜した。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその仕事も、今懸案中の問題が解決しないと何となく精が出ない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの愉快な、晴れ晴れとした氣持に乘じて、かねて懸案の、廣岡の問題を一擧に解決して了はうと思つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七　一月の末からの懸案であつた伊貝との問題もかうして遂に解決した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも早速取り上げてもらわねばならぬ重要な問題の一つに著作権に関する懸案がある。",
              "citation": {
                "source": "著作権の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには永年の懸案であった家の増築ということも彼の気分転換に相当役立った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、吾々は依然として日本に於ける文化の対立を重大な懸案として見出す。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃、健康が勝れないと云う稍々悲観した手紙を受取って居たので、三月には、二人でお訪ねしましょうと云う事が正月頃から懸案に成って居たのである。",
              "citation": {
                "source": "われらの家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて東晉以來、支那教界の大懸案となつた、沙門が君父に拜禮を行ふべきや否やの問題は、『明律』によつて最後の決斷を與へられた。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が明治の發展によつて、此等新舊の懸案は、皆立派に解決されて居る。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな氷の島だから何にもなるまいけれど、とにかく、ながい懸案だった猶太国ができあがる。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にして小説的表現を多分に取り入れるかが、懸案である。",
              "citation": {
                "source": "今日の条件",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからながい間の懸案だつた個人雜誌を遂に出すことになつた。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにサッポロ本庁との間には諒解ずみになっている懸案を、名は出張所であるが、実はそこに長官もいる東京で、最後の決定を得なければならぬのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も懸案になつて居た大劇場・小劇場問題が曲りなりに解決して、技術の修練を積み、芸目を増す必要に迫られた青年役者の為には、こよない機運が開けて来たことになる。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此問題が解決すれば、大きな文楽経済や人物の上の懸案が、一部は消えるのである。",
              "citation": {
                "source": "義太夫と三味線",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての懸案はただその日、ただその時刻だけであった。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに懸案を残して去るといふことは、それだけ、我々が無力で、不勉強であつたといふことになります。",
              "citation": {
                "source": "真間・蘆屋の昔がたり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前々からの懸案なのである。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の之に続けて書かうとする第一部は、私個人にとつては、久しい懸案で、殆ど書かないまゝで四十年に近い年月を経た。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ久しいかな懸案状態の日ソ関係、遂に此処に至る。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、そのことをよく知らないから、答えられない」　この問題は懸案になった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の胸の中には、一つの具体的な懸案があった。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆樣御承知の樣に、多年の懸案であつた自動車製造事業法案も愈々議會を通過致しました事は、啻私達自動車工業に携つてゐる者のみの喜びとする所ではありません。",
              "citation": {
                "source": "ボデー意匠審査会　美術の粹を蒐め獨特の形態美へ",
                "author": "――豐田常務の挨拶――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパに向かって、この国を開くか開かないかはまだ解決のつかない多年の懸案であって、幕府に許されても朝廷から許されない貿易は売国であるとさえ考えるものは、排外熱の高い水戸浪士中に少なくなかったのである。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に兵庫の開港はアメリカ使節ペリイがこの国に渡来した当時からの懸案であり、徳川幕府が将軍の辞職を賭けてまで朝廷と争って来た問題である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせよ多年の懸案であった学校生活を一擲して、いよいよ文学者生活に入ることになったのであるからその、一言一行に生き生きした打晴れた心持の現われているのも道理あることであった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
