        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はその年の三月に、女と二人で、Ｋ市から上京したのだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "フニクラレの客車で日本人らしい人に出会って名乗り合ったら、それは地質学者のＫ氏であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校の理科の時間にＴＫ先生という先生が坩堝の底に入れた塩酸カリの粉に赤燐をちょっぴり振りかけたのを鞭の先でちょっとつつくとぱっと発火するという実験をやって見せてくれたことを思い出す。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一早稻田高等學院の「學友會雜誌」に、Ｋ教授の追悼記が載つてゐました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ教授といふ人は、どんな人だか、私はちつとも存じません。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ばん終りには、Ｙ・Ｔといふ人が、「Ｋ君は歩きながら語り合ふ樣な人であつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、「勢ひこんで議論を吹きかけるとＫ君は大抵だまつて、ものの十秒も考へてから言ふのである。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の言ふことも、さう、そんなこともあるよ、とＫ君は獨特のアクセントで言つてたいてい贊成してくれる。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ君は氣の弱い人である。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく澤山の人がＫ君を輕んじてゐたと思ふ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ君は決して他人の惡口を言はない。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ・Ｋといふ人が、その前の頁に書いてゐます。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかつかと歩み寄つたＫ少尉、いきなりびんたの一つも張るかと思つたらさにあらず、『それ位にして置いて早く集つて下さい、濟まんが』とやつたものだ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "側にゐた上官が、そんなことで威嚴が保てるか、と眞赤になつてＫ少尉の膏を搾つたといふが、Ｋさんは、そんな人だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、「本當の意味のユーモアは、Ｋ君の持味だつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕口を言はず、駄洒落を飛ばさないから、Ｋ君をユーモリストだと誰も思はないけれど、挨拶をさせたり、序文を書かせたりしたら、Ｋ君のものは天下一品だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな輕い微笑をＫ君は絶えず人々に、そつと投げかけてゐた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからＫ君のゐる傍は、いつも和やかな春風が吹いてゐた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その前の頁には、Ｔ・Ｉといふ人が、「變な言ひかたかも知れないが、Ｋさんは、ほんとの聲を出す人であつた、さうしてほんとの聲しか、出さない人であつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實にＫ氏は、いい人だ、できた人だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい人が、どうして死んだのだらう、と追悼記の一ばん前の頁をひらいて見ると、そこに、學院長Ｋ・Ｍといふ人の弔詞が在ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一早稻田高等學院教授陸軍騎兵中尉Ｋ・Ｋ君逝けり。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島では」と、折から忙しい中を講演に来てくれたＫ君が、笑ひながら、臍の話を批評した。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "前日に伊香保通のＭ君に聞いたところでは宿屋はＫＫの別館が靜かでいゝだらうといふことであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＫＦという女優らしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼ですがあなたはＫさんですか」ちょっとそう云って聞いてみたいような気がした、と同時に、それが自然に何のこだわりもなく云えるまでに到達していない自分を認識することが出来たのであった。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家にとつて世界は、即ち彼の世界意識は、善いものでも悪いものでも、其の他如何なるモディフィケーションを冠せられるべきものでもない。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の精神生活は、反対に極めてデリケートで贅沢だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家にとつて世界は、即ち彼の世界意識は、善いものでも悪いものでも、其の他如何なるモディフィケーションをも許容出来るものではない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このケーブル線路の上の方の部分は近頃の噴火に破壊されていたので徒歩の外に途はなかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
