    "definitions": [
      {
        "index": 1,
        "gloss": "writing in blood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに壁の血書、無意識に眼の上あたりへ書いている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者のドイツ風の名前、殺人という明確な動機、壁の不吉な血書、これらすべてが政治亡命者か革命家の仕業であることを示している。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "血書　われは眠ることを期せずして、身を藁蓆の上に僵しゝに、前の日よりの恐ろしき經歴は魘夢の如く我心を劫し來りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は其事を我心上に血書して復た消滅すべからざらしめしが故に、亦併せて此景の詳なることを記し得たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて大阪府の薄給官吏が血書してこの意を述べ、空しく予の志を怜れむと匿名書を贈られたが最上の出来じゃ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸旗本早乙女主水之介、天譴を加えて明鑒を待つ」　ぺたりとその血書の一札を磔柱に貼っておくと、「いかい御雑作に預かった。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　「血書」「健ちゃ、徴兵よかったな。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長が徴兵検査に行ったもののうちで、採否の分らねえようなものに、こっそり血書ばさせて、村の名誉にしようとしたって……。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "△昨夜、樹明君と立ち寄つたおぢさんのところで、血書の話を聞いて、みんな微苦笑したことであつた、血書もかう流行的になつてはインチキがあるのも当然だらう、黒い心を赤い血で書いて、それがどうしたといふのだらう、裃をきてゐても不真面目があり、どてらをきてゐても真摯がある、シンケンらしいウソを呪ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都で大学生が血書をして切ない思いのあまりを言い入れたとかいうような事は、貞奴の全盛期にはすこしも珍らしい出来ごとではない。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ヤッ……これは血書じゃないか。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに驚くべき一事は、新聞社へきた血書の葉書が、つぎの「ジャック」の犯行時日を予言して、みごとに適中していることである。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最期に血書したる片袖を画中より脱け出でたる白鷹｜齎し来てその子石川五右衛門に渡す。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "※瑁の櫛へ巻き付けた血書！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、これを血書するのぢやぞ。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "経文を血書してゐる筆の先にも、どうかすると、長者の妹娘の姿がちらめいた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "身毒は、再度血書した。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが却けられたときに、三度目の血書にかゝつた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四度目の血書を恐る／＼さし出したときに、師匠の目はやはり血走つてゐたが、心持ち柔いだ表情が見えて、人を恨むぢやないぞ。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "血書歎願を出したんだつて？",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、わしは、お前が血書歎願をしたつていふ話を聞いたぜ。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保栄『五稜廓血書』の筋書はあらかた忘れてしまっても、この五稜廓に立つ感情は、一九五二年まで時機をおくらせただけのふかさはあった。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の写経は血書きなのであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも何んのために血書きなどという、荒々しい写経をするのであろう？",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と探り知った桂子は、（ではわたしは観音経の血書き、これ一つで姥の調伏に向かい、その調伏を破ってやろう）　こう考えてこの館で、血書きの写経をやり出したのであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血書き写経のさまたげになると、そう思ったのでこの館へ、小次郎の来ることをかたくとどめ、二条の館へ止どめて置いた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろから日光がさすと、きらきらして無数の雪のけっしょうがみな光線をはねかえし、スペクトルというもののようになる。",
              "citation": {
                "source": "山の雪",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
