        "examples": {
          "standard": [
            {
              "text": "壁一面が木材の化粧張りになっており、温かみのある空間が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いテーブルの天板に新しい化粧張りを施し、見違えるようにきれいになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家具の表面に施された化粧張りは、見た目の美しさを高める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（平煉瓦の化粧張りの壁）この組み方は実に面白いものだ。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう化粧張りはただ、保存せられ磨かれるに値する・立派なしっかりした・壁面にのみふさわしい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
