    },
    "definitions": [
      {
        "index": 1,
        "gloss": "place of scenic beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恐らく富士山麓の宿屋としては、北の精進ホテル以外において、もっとも景勝の地を占めたものであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "平泉の旧跡はなるほど景勝の地である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要塞というものは必ず景勝の地であり、また必ず地学的に最も興味ある地点になっているのは面白い事実であろう。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌が濱の佛國、英國、獨國大使別館、いづれも景勝の地を占めて湖に臨んでゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石に其処だけは自然に土盛りが高くなっていて、多少の景勝の地は占めている。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは村に於ける一つの景勝の地であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの熱海の雜沓が周圍の海や山によつて救はれてゐるやうに、こゝにはまた豐岡川があり、瀬戸があり、日和山のやうな場所もあつて、附近に多い景勝の地がやゝもすれば俗地に陷り易い温泉地から城崎を救ひだしてゐる。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "附野（津々野）のお薬師さまにまゐる、景勝の地、参拝者もかなりあるらしい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れは大安寺に次ぐ景勝の地を占め、満洲にある道教の廟観の中の巨擘である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは谷あひの、景勝の地を占め、いかにも平和な気の靉靆たる所で、欧洲人の避暑地、避寒地となつてゐる。",
              "citation": {
                "source": "チロルの古城にて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが守鶴はそれに答えて、いえ館林よりも、もっと景勝の地が、ここから余り遠くないところにありますから、そこになすっては如何ですといって、正通和尚の先に立って歩いた。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、なるほど館林よりも景勝の地だ。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理にこしらえた新都会　元来宝塚は、大阪市と神戸市より程近い地点にあって、美しい六甲の峰つづきである譲葉嶽の山麓に位して、生瀬の渓谷から奔流して来る武庫川の早瀬にそうた、すこぶる風光明媚な景勝の地であるので、新温泉場の出現とともに来遊客は非常に増加した。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北には遠く奥日光の男体山が雪を着て高く聳えるなど、まことに景勝の地を石坂家の邸は占めていた。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地粋あり、山水美あり、造化之を包みて景勝の地に於て其一端を露はすなり。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩性ある者が景勝の地に来りて、神動き気躍るは至当の理なり、然れども景勝の地に僅に造化が包裡する粋美の一端なる事を知ば、景勝其自身に対する観念は甚だ大ならずして、景勝を通じ風光を貫いて造化の秘蔵に進み、其粋美を領得するは豈詩人の職にあらずや。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならなぜさして景勝の地でもないこの里が夫程名高くなって、後迄も伝わったのであろうかと云えば、それは疑いもなく此附近で最も早く拓けた土地という以外に、月の神を祭った大社が曾て存在していたことに基くものと推定するのである。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この景勝の地を占めている笹ノ湯の建物が橋の上から瞰まれる。",
              "citation": {
                "source": "三国山と苗場山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟尾瀬が如何にも物さびた山奥に在る景勝の地で、貴人の隠棲所にふさわしいというような考えから、尾瀬と大納言とが結び付けられたもので、古人はそれで満足していたのであろう。",
              "citation": {
                "source": "尾瀬の昔と今",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本アルプスの中で景勝の地といえば、南北を通じて恐らく上河内（上高地）に及ぶ所はありますまい。",
              "citation": {
                "source": "日本アルプスの五仙境",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴉が鳴き雀が飛ぶようになっては、如何に景勝の地でも、仙人ならば目を閉じ鼻を摘んで、これはこれはと逃げ去ることと想います。",
              "citation": {
                "source": "日本アルプスの五仙境",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白浦、吹上、和歌の浦、住吉、難波、など景勝の地に月を賞ずるものもあれば、尾上の曙の月を惜しむものもいた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（咲く花に背をむけて四月に家郷を去り、景勝の地をたずねるに、なんぞ文化の地と野蛮の地を問題にしようか。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の景勝の地を占めた伯爵邸は、見るからに爽やかなたたずまいでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "食魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言、必ず上天の聞に達し、自ずからこの下土永く景勝の地の利を受けん。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "到着の翌日ダルメイダは島内数カ所の小堂を見て廻ったが、いずれも元は仏寺で、景勝の地を占めていた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし当って、新将軍のお館なども、どこか景勝の地を選んで御造営にかかってもらいたいが」　と、申し入れた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それとも卿らは、ふたたび都へ帰って天下に立つお望みもすてて、この岐阜の景勝の地に、悠々、巨館を造営して、生涯を信長の食客となって若隠居でもしたいというお心か」　義昭の側臣らは、一言もなく、引き退った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの本丸は絶好な景勝の地にあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
