[
  {
    "uuid": "d603f269-8da4-52b4-96d5-e80603b7dd26",
    "entry": "景勝の地",
    "reading": {
      "primary": "けいしょうのち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
