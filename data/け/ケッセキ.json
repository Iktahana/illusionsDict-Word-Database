[
  {
    "uuid": "c0a78bba-0ede-5882-b5bc-dc6e9541ca4f",
    "entry": "欠席",
    "reading": {
      "primary": "けっせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
