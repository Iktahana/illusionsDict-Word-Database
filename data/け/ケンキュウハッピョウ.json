    "definitions": [
      {
        "index": 1,
        "gloss": "research publication",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いや、いちいちその研究発表を、いま、ここで、せずともよい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともあなたの研究発表ですか？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書を読んだからといって、べつだん、その研究発表をせずともよい。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一日読書をしては、その研究発表。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗黒中のインテリゲンチャ虫の趨光性に就いて　暗黒中の『下等動物の趨光性学説に就いて』といふ興味ある林泉太郎博士の研究発表の講演は終つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村博士は泣いた、それは無理もない、林泉太郎博士の今回の研究発表によつて、野村博士の従来の暗黒中の幼虫の光線に対する反応が、光度、感受性、内的傾向の三つよりなるとする三大原則は脆くも打破られたのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによって会員其他の学徒に研究発表機関を確保すると共に、間接に生活地盤の一端をも提供出来たならば、と思うのだ。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は云わば職業的に、この狭い領域に於ける専門家なのだから、その専門について単に筆を執りさえしたら、それが専門的な研究発表や何かでなくて世間一般の読者を想定するものである以上、この狭義の所謂「戦争ジャーナリスト」となって現われる次第である。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四六年以後久しく行われなかった学会、研究発表会などが各専門分野で盛んに行われ始めた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その研究発表は約二四〇題目であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究発表は約六〇題目であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学教授は研究発表の自由を有つてゐるのだから、何もあのやうな形式で物を言はれなくとも済む筈だ、などいふ言ひ訳らしい当局者談なるものも、新聞に載せられた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかも万一、貴方が過去の御記憶を回復されましたお蔭で、この事件の真相が判明致すことに相成りますれば、その必然の結果として、実に、二重、三重の深長な意味を持つ研究発表が、現代の科学界と、一般社会との双方に投げかけられまして、世界的のセンセーションを捲き起すことに相成りましょう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで思い切って吾輩の精神科学の研究発表の原稿を全部焼き棄ててしまって、あとにその内容の概略を書いたヒヤカシ半分の遺言書を残しておけば、彼奴、若林は嫌でも応でもその著述の中に、この遺言書を組み込まなければ研究発表の筋が立たなくなる訳だ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは精神病学者としての吾輩の立場から見ると、発病の原因と経過さえ判明すれば、発狂さした犯人の名前は、目下不明と書いておいても、研究発表上、何等の差支えがないのだからね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……正木博士が行った巧妙奇怪を極めた犯罪に魅惑されて、自分から進んで調査をしているうちにいつの間にか正木博士の研究発表の材料を集める役廻りを引受けさせられていたのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩田良平氏が美妙の日記を研究発表されるということであるから、やがて世に知れるであろう。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の「演劇一般講話」と題する一文は、菊池寛氏の主宰する文芸講座の為めに特に「演劇論」といふ標題で執筆したものであつて、これは、厳密な意味に於ける研究発表ではなく、従つて、学界に向つてその価値を問はうとするやうな野心は毛頭ない。",
              "citation": {
                "source": "「我等の劇場」緒言",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どものしてゐる民俗学の発生的見地は、学者自身の研究発表の上にも、当然、持せられるべきはずであります。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　内海達郎は、研究発表の準備に忙しく、しばらく見舞を怠つてゐると、ロベエル・コンシャアルが退院したといふ通知をうけとつた。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに生憎な事にこの両君の新研究発表と時を同じゅうして、これも極めて偶然に、従来の再建論者の巨頭だった小杉老先生が、両君の発表とは没交渉に美術院において、その得意の再建論を講演せられたのであったからたまらない。",
              "citation": {
                "source": "法隆寺再建非再建論の回顧",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　研究マニア　物事万事研究にしくはないが、やたらにスキーのそこを削り、こゝに板をはりつけ、そこに漆を塗り、こゝに墨をつけ、さて、これが物理的には雪の面にこうなり、どうなるに違いないと、誰をつかまえても研究発表を始めれば、もうマニアックである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく国外から招かれる知名のイプセン学者――たとえば、アルフレッド・ケル、モンティ・ヤコブス、ベルンハルト・デイボルトなどの研究発表は、ここで行われるものと推定されます。",
              "citation": {
                "source": "イプセン百年祭講演",
                "author": "久保栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "公式の総会や研究発表が終つて、いくつかのやや私的な級友会のやうなものが、二晩ぶつ通しにあつたけれども、守屋為助も八女陸郎も、その方には顔を出さず、二人だけで勝手に飲み、食ひ、歩き、かつしやべる機会をつくつた。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先刻ご承知かもしれんが、最近二日間に亙つて、日本心理学会の秋季総会と研究発表が学士会館で行はれました。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "名文家と好色家との間にある心理的もしくは生理的な必然の関係は将来必ず研究発表されるであらう。",
              "citation": {
                "source": "永井荷風",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なお形態心理学の研究が盛んなのは九州帝大の心理学教室で、古典的な文献の集録も出版されているし、研究発表や著述も多い。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、アカデミーや研究発表の諸機関のようなものも亦、観念の社会的精神的交通のエージェント乃至機関でなければならぬからである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に自身の健康を卜する料とするだけであるが、稀に同好の士がゐて、研究発表を微に入り細を穿つて相互に交換するのも亦たのしい。",
              "citation": {
                "source": "黄金綺譚",
                "author": "潔癖の人必ず読むべからず",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
