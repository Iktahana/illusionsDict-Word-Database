    "definitions": [
      {
        "index": 1,
        "gloss": "way of holding a calligraphy brush, with elbow away from the body and arm in the air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
