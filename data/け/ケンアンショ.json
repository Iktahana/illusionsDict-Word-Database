    "definitions": [
      {
        "index": 1,
        "gloss": "certificate of post-mortem",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
