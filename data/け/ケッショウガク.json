          "standard": [
            {
              "text": "結晶学の進歩は、材料科学の発展に大きく貢献した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は大学で結晶学を専攻し、鉱物の研究に没頭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結晶学は、X線回折法を用いて物質の構造を解析する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "結晶学の実習でダイヤモンドの標本を学校から持って帰り、初めてリカ子に見せたのが思えばこのリカ子のわれわれ二人に迷い出した初めであった。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "座はそれから次第に結晶学の法則そのままの形をとり始め、その各人の比重に従って沈み出した。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な勉強ずきで哲学から鉱物学、結晶学まで専門にやったマリエッタ・シャギニャーンは、当時紡績織物専門学校で紡績についての研究をやっている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
