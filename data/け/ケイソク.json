[
  {
    "uuid": "d0f52b4f-4e96-5df0-a28e-12919f28dc06",
    "entry": "計測",
    "reading": {
      "primary": "けいそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
