    },
    "definitions": [
      {
        "index": 1,
        "gloss": "measuring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後にまた、大湯附近の空気中のイオンを計測するために出張を命ぜられて来たときは人車鉄道が汽車の軽便鉄道に変っていたが、それでもまだやはり朝東京を出て夕方熱海へ着く勘定であったように思う。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鼻の大きい人の鼻を普通の計測的の大きさの比以上に廓大して描いたり、喜怒の感情の発現を誇張した身振りで示すがごときは、最も月並な慣用手段である。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には地震計測の方面がある。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある外国の新聞に今回の地震の地震計記象を掲げた下に Japanese Earthquake reduced to line. と題してあるのを面白いと思って見たが、実際計測的研究者にとっては研究の対象は地震よりはむしろ「線に直した地震」であるとも云われる。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空間の概略な計測には必ずしもメートル尺はいらない。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の届かぬ距離の計測には両眼の距離が基線となって無意識の間に巧妙な測量術が行なわれる。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "質量と力の計測にも必ずしも秤はいらない。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに現在の計測を精鋭にゆきわたらせることができたとしても、過去と未来には末広がりに朦朧たる不明の笹縁がつきまとってくる。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "計測係りが黒板に二十五秒七四と書いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたもずいぶんね」「なぜですか」「だって、まさか運動会の計測係りになって得意になるようなかたでもないでしょう」　三四郎はまた話頭を転じた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それ等のものを、測定器によって計測したならば、ある程度まで犯人か否かを発見することが出来るばかりでなく、じっと死体を見つめて居ると、今にもその死体が息を吹き返して、丁度、ポオの小説に書かれてあるように、「貴様が犯人だ！",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "上記三つの計測術の支配者とも言うべき天体は、いわゆる旧世界でも新世界でも、最古の文化民族の間で神々の中の首長として尊崇せられていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時既にガリレオ（Galilei）及びホイゲンス（Huyghens）の周到な計測によって地球表面における重力の大きさがよく知られていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "計測機器メーカーの横河電気の依頼を受けて、彼らはすでに一六ビットのマイクロコンピューターの開発プロジェクトをスタートさせていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事があるというならそちらこそ来るべきだろう」　ソード電算機システム、アイ電子計測、リコー、松下通信工業といったまともな企業から、もっと確かそうなベーシック購入の打診をすでに受けていたゲイツは、そっけなくそう答えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "情報処理専門の学科が設置される前の慶応では、コンピューターは工学部の計測工学科に割り振られていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電算事業の主流に押し上げられたソフトウエアの左甚五郎　計測工学出身の同窓生たちと会ってお互いの仕事に関して話したり、彼らから異動の連絡を受けたりするとき、古山はしばしば、それぞれの分野に散っていった大学時代の仲間たちがその道で主流にまわらなかったことを痛感させられてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "代わりに、数学を生かすことができてしかも物にも触れるだろうと考えて、応用物理の計測工学を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳しいＮＡＳＡの規準には適合できなかったものの、地上でなら充分使い物になるトランジスターを部品メーカーから大量に調達したり、電子機器メーカーから用済みとなった計測器を仕入れてきたりと、環境の特殊性を存分に生かして、マッカラムは教室の整備に努めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある小さな計測器メーカーは、機器のコントローラーをマイクロコンピューターを使って作ってほしい旨、松本先生に打診してほしいと編集部に丁重に連絡を入れてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にバアトンが計測した黒人の penis は平均長さ何｜吋だ抔と註してある。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人はあの像のように……」と法水は、そこでいったん唇を閉じ、じいっと真斎を瞶めながら、次に吐く言葉との間の時間を、胸の中で秘かに計測しているかの様子だった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有様を、法水は異常な冷やかさで見やりながら云い続けたが、その態度には、相変らず計測的なものが現われていて、彼は自分の言の速度に、周到な注意を払っているらしい。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は衣袋から巻尺を取り出して、一々印像に当て靴跡の計測を始めた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中から要点を摘出してみると、ダンネベルグ夫人の死因は明白な青酸中毒で、薬量も、驚くべきことには〇・五と計測されたが、肝腎の屍光と創紋とは、いずれも生因不明であって、単に蛋白尿が発見されたという一事に尽きていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、机を二つばかり重ねて、その上に神鏡を据え、しきりと何かの高さを、計測しているようであったが、やがて不安げに頷くと、背後の祝詞文に明かりを向けた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "計測掛が黒板に二十五秒七四と書いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたも随分ね」「何故ですか」「だつて、真逆運動会の計測掛になつて得意になる様な方でもないでせう」　三四郎は又話頭を転じた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
