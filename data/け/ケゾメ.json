          "literary": [
            {
              "text": "で、御用の化粧品屋に言ひつけて、毛染め薬をいろいろ取り寄せて、王の化粧室に備へつけておくことにした。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、王は化粧室に入つて毛染め薬を取出した。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは人間の白毛染め薬を用いて、豹の斑紋を巧みに染めつなぎ、動物のからだ一面に虎斑を描き上げたのだ。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
