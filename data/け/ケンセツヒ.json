    "definitions": [
      {
        "index": 1,
        "gloss": "construction (building) costs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
