    "definitions": [
      {
        "index": 1,
        "gloss": "being outstanding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、さらに一歩を進めて、科学上の傑出した著述はすべて芸術であると言おうとすれば、これにはおそらく容易に同感を表しかねる人が多いであろうと思われる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は白石は徳川時代における傑出した哲学者であり、また人間であると思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本は、千の平凡人よりも一人の快男児を要し、十万百万の平凡人よりも、一人の英雄豪傑を要する時代なり、大英雄、大豪傑出でずんば、日本は世界の大舞台に立つて、宇内の第一等国となる能はず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、ひとつ、これは中でも傑出しています。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして或る手腕家によつて、此一事実から傑出した文学を作り上げる事が出来るだらう。",
              "citation": {
                "source": "文芸とヒロイツク",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無口で鈍重な逸作が、対社会的な画作に傑出して居るのは、その部分が機敏に働く職能の現れだからである。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『蛇性の婬』の話は、上田秋成の『雨月物語』の中でも最も傑出したものとせられているが、しかし、これは秋成の創作でなしに支那の伝説の翻案である。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の信念の通りに言えば、志賀氏は現在の日本の文壇では、最も傑出した作家の一人だと思っている。",
              "citation": {
                "source": "志賀直哉氏の作品",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に白鳥洋子の「彼女」は傑出している。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも泰時、時頼等の傑出した人物が相継いで執権となり、鎌倉幕府の全盛時代を現出した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "傑出した人の行動は目に立ちやすくて気の毒である。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もこの佐竹の鯉の傑出的良さに騒がなかつたとしたら、殊によつたら彼は私一人の批評のために描いてくれたのかも知れない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから古ローマのネロ帝は荒淫傑出だったが、かつて揃いも揃って半男女の馬ばかり選り集めてその車を牽かしめ、異観に誇った（プリニウスの『博物志』十一巻百九章）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "高安氏の持論によると、詩人芸術家すべて傑出してゐる人物には、定つたやうに髯が無いといふのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの北国人の宇宙創造説は自然界の真理という点から見て、これまでに述べたすべての説よりも傑出している。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "また珍しいほど偏見のない頭脳をもったドイツ人クサヌス（Cusanus トリール Trier の近くのクエス Cues で一四〇一年に生れ、トーディ Todi の大僧正になって一四六四年に死んだ）もまた当代に傑出した人であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように錯雑した現実の中にある現代の文学としては、云ってみれば、文学と歴史とのことが今日において一般の関心をひきながらも、続々傑出した歴史文学を生み出して行き得ないでいる社会と文学の生理そのものが、後代に向って一つの歴史的事実を訴えるものであるということにもなると思う。",
              "citation": {
                "source": "歴史と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武家気質というものをそれなり歴史のなかのものと承認して、その心理の範疇のなかへ近代人としての鴎外が整理と観察の光りを射こんだ創作態度から云うと、この「阿部一族」は内容、構成、文章等最も傑出した作品である。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の創作が現実を反映すると言うこと、作家の人間的な全面がおのずからそこに露出しているということ、しかも芸術家である人々は、それぞれの時代や自身の制約の中にありながらも比較的常に敏感に自分と周囲との人間生活を観察しているので、小説は傑出したものであればあるほど謂わば人間臭さが強い。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "森鴎外は傑出した智能を持った人であり、科学と文学との美を当時の水準では最高に身に具えた人であった。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品は、少くとも同じ作者によって書かれた従前の諸作のうちでは、この作者の主要なテーマ、何をなすべきかが積極的に答えられている点でも傑出したものであることに疑いない。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等のさまざまな問題を与えつつ「大地」はたしかに昨今の傑出した映画の一である。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、古典ロシア革命文学の中に、どんな傑出した階級的アレゴリーがあったか？",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "またイギリスの最も傑出した作家の一人、サッカレーの作品はその傑作「虚栄の市」の中で、光彩陸離と、なり上り結婚のために友情も信義もけちらかして我利をたくらむやり手な美しい女性を描いた。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西の傑出した女性の作家は、兎に角彼女等の芸術家的客観性によって、男性を描写してはいる。",
              "citation": {
                "source": "わからないこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、楠公は古今の武将の中でも智略に勝れていた人であったことは争われぬ歴史上の事実でありますから、智の方面に傑出した相貌の顔に作りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "楠公銅像の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "万能的なのは一心がかたまらぬせいか、心が籠らないせいか、傑出するには足りなかった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "谷中時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の傑出した論説の中には一九〇九年の窮民救助法調査会に先鞭をつけているものもあった。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、虫は好かないけれど、演技は傑出しているというところを自分の好悪からはなして観るような芸術鑑賞のよろこびも、もっと女のゆたかな客観性としてもたれてもいいであろう。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
