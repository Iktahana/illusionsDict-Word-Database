        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自己嫌悪で一ぱいだ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己嫌悪、含羞、閉口しているのであろう。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌悪感、それが私の全体をひつ括んでゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までも、嫌悪感と云ふものは幾度か、殆んど数へ切れない位に私の首を締めつけた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "非情の自然が、自らその頑な固定性に飽いて、抗い出た自己嫌悪の旗印か、または非生の自然に却って生けるものより以上の意志があって、それを生けるものに告げようとする必死の象徴ででもあるのであろうか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己｜嫌悪に打負かされまいと思って、彼の額から脂汗がたらたらと流れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井荷風が『歓楽』のうちで「得ようとして、得た後の女ほど情無いものはない」といっているのは、異性の双方において活躍していた媚態の自己消滅によって齎らされた「倦怠、絶望、嫌悪」の情を意味しているに相違ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "概して文化の程度が低く、原始民族のタブーと迷信に包まれているこの地方には、実際色々な伝説や口碑があり、今でもなお多数の人々は、真面目に信じているのである、現に私の宿の女中や、近所の村から湯治に来ている人たちは、一種の恐怖と嫌悪の感情とで、私に様々のことを話してくれた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人にたいする人種的、嫌悪。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、さっと顔一面に嫌悪の情をみなぎらせたが、急に、それを自覚して、かくすように、「いらっしゃいまし。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人も、職長も、古参の社員も、嫌悪した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは、戦争に対する嫌悪、恐怖、軍隊生活が個人を束縛し、ひどく残酷なものである、というようなことが、強調されている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから戦争は、悪く、戦争は、いやな、嫌悪さるべきものである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルビュスは、戦争の惨禍を呪咀するばかりでなく、戦争の責任者に対して嫌悪を投げつけ、インタナショナルの精神を高揚している。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが間もなく彼はだんだん堪らない嫌悪を感じ出した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女の諦めたような平気さが極端にいらいらした嫌悪を刺戟するのだった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくそれへの嫌悪から私のそうした憎悪も胚胎したのかもしれないのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堯はなにか露悪的な気持にじりじり迫られるのを感じながら、嫌悪に堪えたその犬の身体つきを終わるまで見ていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかしどこかからきこえて来た軽はずみな口笛がいまのソナタに何回も繰り返されるモティイフを吹いているのをきいたとき、私の心が鋭い嫌悪にかわるのを、私は見た。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦躁と言おうか、嫌悪と言おうか――酒を飲んだあとに宿酔があるように、酒を毎日飲んでいると宿酔に相当した時期がやって来る。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵に対する私の嫌悪はこのわげを見てから急に強くなりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり私の前に坐っていた婦人の服装が、私の嫌悪を誘い出しました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれに相当する日本語に対してはいっそうはげしいほとんど病的かと思われるほどの嫌悪を感じるようである。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん、そうだ、評論家というものには、趣味が無い、したがって嫌悪も無い。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三野村さんあなた、勉強をおしやすのにそないに女を傍に置いたりしてよう絵が描けますなあいうて私がきくと、そなことない、お園が傍についておってくれんと絵が描けんおいいやすのどす。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
