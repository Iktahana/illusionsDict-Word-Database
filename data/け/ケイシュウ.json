    },
    "definitions": [
      {
        "index": 1,
        "gloss": "accomplished lady",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（明治二十八年十二月「文藝倶樂部」臨時増刊　閨秀小説）",
              "citation": {
                "source": "十三夜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、若い閨秀畫家らしいことはその手紙の中に見えてゐる。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた「国民小説」「新小説」「明治文庫」「文芸倶楽部」というような純文芸雑誌が現われて、露伴紅葉等多数の新しい作家があたかもプレヤデスの諸星のごとく輝き、山田美妙のごとき彗星が現われて消え、一葉女史をはじめて多数の閨秀作者が秋の野の草花のように咲きそろっていた。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入満と唸るといえども、常住の寡慾に肖もやらで、慈善の慾は極り無く、貪るばかりに取込みても人に施すにはいまだ足らずと、身を粉にし、骨を折る、賢媛、閨秀の難有さよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の閨秀作家、紫式部の心境がわかるような気がした。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬ひこれが閨秀たるの説明をなしたる後も、吾人一片の情を動かすを得ざるなり。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春頃出たんだ、『閨秀小説』というのがある、知ってるかい。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また……ああ惜しいかな、前記の閨秀小説が出て世評一代を風靡した、その年の末。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の山も、広小路にも、人と車と、一斉に湧き動揺いて、都大路を八方へ溢れる時、揚出しの鍋は百人の湯気を立て、隣近な汁粉屋、その氷月の小座敷には、閨秀二人が、雪も消えて、衣紋も、褄も、春の色にやや緩けたであろう。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金泥を空にながして彩つた眞夏のその壯麗なる夕照に對してこころゆくまで、銀鈴の聲を振りしぼつて唄ひつづけた獨唱の名手、天飛ぶ鳥も翼をとどめてその耳を傾けた、ああ、これがかの夕日の森に名高く、齢若き閨秀樂師のなれの果であらうとは！",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ついでだからちょっと聞いておきますがさっきのなんとかベーンですね」「アフラ・ベーンか」「ぜんたいなんです、そのアフラ・ベーンというのは」「英国の閨秀作家だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一　閨秀作家一瞥『女人芸術』がだんだんととのってくる。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、欧米の先進国に比して、日本にはまだ、文壇の第一線に立つような閨秀作家は見られない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫式部を先祖にもつ閨秀作家たちの奮起をのぞんでやまない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、未来の閨秀作家は学校から帰って来ると、机に向って文を書くというよりは、寧ろ多く手紙を書くので、男の友達も随分多い。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは閨秀歌人になるがいいな」と私は或る時言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、到頭妻を納得させて、遠田澄庵という人の紹介で、当時閨秀歌人として、水戸の志士林の妻として女傑と称されていた中島歌子の萩の舎へ十五歳の夏子を入門させたのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若松賤子は、ほかの閨秀たちが殆どみな雅俗折衷の文章にとじこもっていたときに、口語体で翻訳をした。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　若い人たち――殊に若い閨秀作家たちの作品には、よく教えられることがあります。",
              "citation": {
                "source": "靄の彼方",
                "author": "――現代風俗描写への待望――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の閨秀画家としての地位はこのあたりから不動のものとなったとも言えるでしょう。",
              "citation": {
                "source": "作画について",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "華美な東京の女　大阪に尾形華圃という閨秀画家がいて、私より三つほど年上でしたが、その人と連なって東京博覧会の時にはじめて東京見物に行ったのでした。",
              "citation": {
                "source": "好きな髷のことなど",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒物店の三畳の奥で、この閨秀の傑作が綴りだされようと誰が知ろう、それよりもまた、その文豪が、朝は風呂敷包みを背負って、自ら多町の問屋まで駄菓子を買出しにゆき、蝋燭を仕入れ、羽織を着ているために嘲笑されたと知ろうか。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄堂、其の妻、その六七歳の娘子、閨秀畫家の有澤江水、三浦英蘭二女史之に乘り、主人公の土田氏を始め他はみな徒歩す。",
              "citation": {
                "source": "町田村の香雪園",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白ばら」は最初ての閨秀作家号に載るし、「小町湯」や美妙との合作もつづいて発表された。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "※「リルケがヴォルプスヴェエデの繪かき村のなかで暮らしてゐる間に書いた日記の中には、後に彼の妻となつた女流彫刻家クララ・ウェストホフに對するばかりでなく、「ブロンドの閨秀畫家」パウラ・ベッカアに對する數多の仄めかしが見出される。",
              "citation": {
                "source": "「鎭魂曲」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、序だから一寸聞いて置きますが先刻の何とかベーンですね」「アフラ、ベーンか」「全体何です、そのアフラ、ベーンと云ふのは」「英国の閨秀作家だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、同じ時代の、卓抜な閨秀作家、ド・セヴィニエ夫人の同著作は、悉くこれ、「書簡」である。",
              "citation": {
                "source": "戯曲及び戯曲作家について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは痴川の女であつて閨秀画家であるが、三十五で二十四五に受取れる神経質な美貌であつた。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
