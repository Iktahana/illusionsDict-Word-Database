[
  {
    "uuid": "896bdc5d-b656-500c-9dd9-842be8c52f6c",
    "entry": "閨秀",
    "reading": {
      "primary": "けいしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
