[
  {
    "uuid": "146db20d-fbe8-5b22-9c4a-f1ff55fb7f4f",
    "entry": "喧嘩を売る",
    "reading": {
      "primary": "けんかをうる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
