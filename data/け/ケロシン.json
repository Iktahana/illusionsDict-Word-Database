        "examples": {
          "standard": [
            {
              "text": "昔はストーブの燃料としてケロシンがよく使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ケロシンランプの明かりは、キャンプサイトを温かく照らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "航空機のジェット燃料にもケロシンが用いられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "厨房ストーヴに使う新式のケロシン油は、いきなり火になるむかしの石油のような引火性がなく、じれったいような緩慢な燃えかたをするものだということを、太郎は知らなかった。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "久美子は煖炉の燃えさしの上に紙屑や木箱の壊れたのを積みあげ、ケロシン油をかけて火をつけた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
