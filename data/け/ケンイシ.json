        "examples": {
          "standard": [
            {
              "text": "アーチ橋の中央にある剣石をはめ込むことで、構造全体が安定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その古い石門は、剣石に刻まれた紋章から中世のものだと推測された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "修復作業では、最も重要な剣石のひび割れを慎重に補修した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「あの岩の島の名は、何だったかしら」「双剣石よ」　二つの岩がするどくそそり立ち、大きい方の岩のてっぺんに松の木が一本生えていた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの双剣石まで、泳ごうとしたんだ」「双剣石まで？",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わずかな明るさを背にして、双剣石はくろぐろとそびえ立っていた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの双剣石まで」　五郎はアルコールを含みながら、その方角を見た。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく福は双剣石に泳ぎ着き、ここに戻らずに近くの岸へ上り、陸路を歩いて宿舎に戻ったんじゃないか。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ福や、双剣石や、その他いろんなものとの――」「ああ」　女は胸を反らしながら、かすかにうめいた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように天へ祈念をこらして、大喝一声すると、剣石ともに響いた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
