[
  {
    "uuid": "25614a28-73ae-5ee0-a067-88abcc28c525",
    "entry": "刑余",
    "reading": {
      "primary": "けいよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "having served time in prison",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼にして若し金剛石の光を見ざりしならば、また吾をも刑余に慕ひて、その誠を全うしたらんや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は刑余の人の妻子である。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者が男色事件で刑余の人になってしまったのも尤もである。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花絲雨裡　　落花糸雨の裡、塵外刑餘身　　塵外刑余の身。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑餘始作無爲叟　　刑余始めて無為の叟となり、空倚危欄望北を望む。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐爾刑餘垂死叟　　爾を憐む刑余垂死の叟、半生得失待誰知　　半生の得失誰を待ちてか知らむ。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑餘一枕蠹書裡　　刑余　一枕　蠹書の裡、造物還吾風月身　　造物　吾に還す　風月の身。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ尊は高天が原の外に刑余の姿を現はすが早いか、あのやうに恬然と保食の神を斬り殺す勇気はなかつたであらう。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑余の身をこうして無事に暮せるのも、其後の正しい決心の賜物だというのだった。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、ドコにいると名乗るほどの安定はない、刑余の亡命者でござるがな、今日は、どういうものか、虫の居所が少し違っていると見えて、じゃんじゃんの鐘を聞くと、急に上野の地が恋しくなったようなわけで、山へ登ってみましたよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "実が刑余の人であるにも関らず、こういう昔の話が出ると、弟達は兄に対して特別な尊敬の心を持った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で普通学務局長の下村寿一氏は、刑余者の子弟だという理由で入学出来なかったというような噂さは聞かぬ、師範学校の校長は併し、なるべく学風に適した生徒を取るように賢明な裁断を下すべきだろう、と云っている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭がいやなのではない、遊びが面白くないのではない、みんなこの額の刻印が、自分というものを刑余の入墨者同様な、卑屈な日蔭者にしてしまったのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごらんになりますか」と言って幸内は、そろそろ歩みよって、まずその一方の薦を、ちょっと刎ねのけて見ると、刑余の死人のその男の方と覚しいのがまず現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手から栄二、けいより一二歳上だが之も最近「或る場所」から出て来たのですこしふけて見える、暫くあたりを見廻しているがけいに気がついて……栄二　あの……。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一本の樹の枝を見つけてそれへ帯をひつかけた頭の上で、その両端を結びつけいよいよ首を吊らうとしたんだ。",
              "citation": {
                "source": "ぶらんこ（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は私がいま書いたような歴史を、めいめいの家族史のうちに直感的に反省しながら、それが直感的であるだけいよいよしんじつに、事態の真相を把握させているのであろう。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯にたつた一度の幸福を、もしできたら、夢のなかで、もう一度味つてみるつもりだつたの」「僕と一緒にいられるだけいようと、どうして思わないの？",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、ひさ、戸塚へゆく時間で出かけいよいよ二階へ上ったら到頭十時まで一息に眠ってしまいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もう今となっては、こんな美学や快感なんかどうだっていいはずなのに、この場に及んでよけいより好みが強くなってる。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけいよ、その相手は、凡者でないぞ！",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
