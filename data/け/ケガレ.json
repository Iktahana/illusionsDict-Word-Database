        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汚れ易く、破れ易く、着くづれし易く、こんな服装を讃へなければならない我々日本男児は、なんとなく不幸であるやうに思へる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三この穢れた涙に汚れて、今日も一日、過ごしたんだ。",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてじめじめする肌の汚れも洗って清浄な心になりたくなるので、手拭をさげて主婦の処へ傘と下駄を出してもらいに行く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れ煤けたガラスに吸い付いたように細長いからだを弓形に曲げたまま身じろきもせぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ曇り初めし空に篁の色いよ／＼深くして清く静かなる里のさまいとなつかしく、願わくば一度は此処にしばらくの仮りの庵を結んで篁の虫の声｜小田の蛙の音にうき世の塵に汚れたる腸すゝがんなど思ううち汽車はいつしか上り坂にかゝりて両側の山迫り来る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃では神棚の燈明を点すのにマッチは汚れがあるというのでわざわざ燧で火を切り出し、先ずホクチに点火しておいてさらに附け木を燃やしその焔を燈心に移すのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁はしみに汚れ、明り取りの窓｜硝子はところどころ破れ落ちかかって煤けている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら汚れてもよいように衣物を着換えて来たね。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々は、賢き陪臣、ニコチンに、汚れたる歯を押匿す。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず色々の書物が出て来る、大概は汚れたり虫ばんだりしてもう読めなくなっている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし空気を抜いておいてもだんだん炭線が損じガラスの内面が汚れて暗くなる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の色には汚れがあり、焔の色には苦熱があり、ルビーの色は硬くて脆い。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の汚れを去り、焔の熱を奪い、ルビーを霊泉の水に溶かしでもしたら彼の円山の緋鶏頭の色に似た色になるであろうか。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末な白木の札であるから新入りでない人の札はみんな手垢で薄黒く汚れている。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも、真黒な指の痕をつけている人は、名札の汚れなどという事には全然無関心な人であるというくらいのことは云われそうである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと汚れ方との相関もあるらしいがまだよく調べてみない。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あはれ果敢なき塵塚の中に運命を持てりとも、穢なき汚れは蒙むらじと思へる身の、猶何所にか悪魔のひそみて、あやなき物をも思はするよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三五八頁には右の手を清浄な事に使い、左の手を汚れに使う種族の事がある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外には幾枚かのカンヴァスの枠に張ったのが壁にたてかけてあったのと、それから、何かしら食器類の、それも汚れたのが、そこらにころがっていたかと思うが、それもたしかではない。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服の上に汚れた白の上っぱりを着たままで、肩から絵具箱をかけ、片手にも画架か何かを持っていた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きたなく汚れて、それでいて実に美しいものも世の中にはある。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん吸うて出した汚れた空気は、背嚢に帰って苛性加里で清浄にされ、再び用いられる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた手拭の上へ載せて見たりマントの上へあてがつて見たりして色の反映を量つたり、またこんなことを思つたり、　――つまりは此の重さなんだな。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顏は、自然に使ひ耗らされ、汚れ、皺だらけになり、旅行中嵌めきつてゐた手袋のやうに、伸び切つてしまつてゐる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間のように窪んだ所には、汚れた布団を敷いたように、雪が消え残っている。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙが汚れたハンカチを振っている。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "割引電車の青い労働帽の炎のような太陽が燃えて、世が明けわたると、半開のビルデングの鎧戸を汚れた袴をはいた女事務員がくぐり、表情の失せた勤め人たちが、破れたわい襯衣から栄養不良の皮膚をのぞかせて鏡のように磨かれた石造の建物に吸いこまれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台から跳ねあがる音がして、黒いスカートのもとから素足のままで、フランのワイシャツに汚れたネクタイを締めながらスマ子女史は英介氏の部屋にやってきて、ストーブのまえでうずくまりながら、――お仕事できたらしいわねえ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、彼女は二階の縁側の拭き掃除が終って、汚れ水の入ったバケツを提げて立ったまゝ屋根ごしに近所の大きな屋敷で樹を植え換えているのを見入っているところだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた茶碗を洗い、土のついた芋の皮をむいた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
