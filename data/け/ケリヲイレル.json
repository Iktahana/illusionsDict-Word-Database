        "examples": {
          "standard": [
            {
              "text": "彼は、長年のライバルとの試合で、渾身の力を込めた「蹴りを入れる」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が、サッカーボールを、ゴールに「蹴りを入れる」練習をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと気合を入れて、確実にゴールに蹴り入れろ！」と、コーチは指示を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "片桐は慶一のベッドに飛び乗り、こんどは肋骨をねらって、一発、二発と、蹴りを入れる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
