    "definitions": [
      {
        "index": 1,
        "gloss": "belligerent attitude",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
