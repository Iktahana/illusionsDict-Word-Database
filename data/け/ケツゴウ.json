[
  {
    "uuid": "828336d4-431c-5d6b-b5d4-72a92a95c056",
    "entry": "結合",
    "reading": {
      "primary": "けつごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
