    },
    "definitions": [
      {
        "index": 1,
        "gloss": "combination",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一、一作品中に於けるデータ（細部）とデータは、理想的に云へば絶対に類推的に結合されてゐてはならぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂェラルドの詩を見るに、個々の実感は余りにそれ自身として強烈であつて、観念と結合しない。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新星と豊国がその時から結合した。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁石と豊国とがその時から結合した。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ人の名が色々な住所と結合してぱらぱらに散在しているので、どれが現住所であるか、当人でさえ時々間違えることがありそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんは多くの同種類の云い伝えと同様に、時と場所との限られた範囲内での経験的資料とある形而上的の思想との結合から生れたものに過ぎないだろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならず徴表結合の如何によっては「下品」ともなり「甘く」もなる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつまた或る徴表と結合する場合には「いき」と或る意味で対立している「渋味」となることもできる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "媚態と「諦め」との結合は、自由への帰依が運命によって強要され、可能性の措定が必然性によって規定されたことを意味している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂直の平行線と水平の平行線とが結合した場合は、模様として縦横縞が生じてくる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "万字は垂直線と水平線との結合した十字形の先端が直角状に屈折しているので複雑な感を与える。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が分析によって得た幾つかの抽象的概念契機を結合して「いき」の存在を構成し得るように考えるのは、既に意味体験としての「いき」をもっているからである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱力学にエントロピーの観念の導入され、またエントロピーと公算との結合を見るに至りし消息もまたここに至って自ずから首肯さるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにもし人間以上の官能を有するいわゆるマクスウェルの魔のごときものありて、分子一つ一つの排置運動を認めその運動や結合の方則を知りて計算するを得ば、少なくも吾人が日蝕を予報するくらいの確かさをもってこれらの現象を予報するを得べし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような観念の結合連鎖によって組み立てた力学物理学は吾人にとって非常に便宜なものであるが、しかしまたこの建設物が唯一な必然なものだとは信じられない。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれら分子がまた原子から成立している事も疑いない事で、分子中における原子結合の状況についても各方面から推定を下す手掛りが出来ている。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "能知者と所知者の結合を包括する全体が更に大きな普遍的で絶対的な能知を反映する事によって芸術たる価値が定まると考える事が出来るだろう。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの言葉が出来る前には人間の感覚知覚は経験と記憶聯想によって結合され、悟性によって幾多の分析抽象を行った末に一つの観念なり概念なりが出来なければならない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今月の月給だけでは、薬代、牛乳代などが払えぬので、校長に無理に頼んで三円だけつごうしてもらった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、じぶんが死んだのちに、子どもたちがもどってきて、この農場を受けつごうというわけではないのですから、荒れはてるにまかせておいたほうが、かえってよかったのでしょう。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
