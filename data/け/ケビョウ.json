[
  {
    "uuid": "056dac71-9a03-5bda-9bff-4f6efa954226",
    "entry": "仮病",
    "reading": {
      "primary": "けびょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "feigned illness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "棚倉怒ったが苦笑して、Ｔ「ナンダ、仮病か？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時に当てられた仮病院は、長いがらんとした建物で、中央に手術台があり、十人の負傷者がいずれも、附添人に囲まれ、部屋の隅々に横たわっていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあに、君、ありア仮病さ、ワトソン君、なんだか専問家に僕のほうで教えるような形になって変だけれど、その真似をして仮病をつかうぐらいのことは何でもないんだよ。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮病という主題で、僕もときどき小論文でも書いてみたくなる。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仮病をつかって、家の二階にごろごろしていることはねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっさと飛び起きて、草鞋をはく支度をするがいいじゃあねえか」「いえ、決して仮病では……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "親たちに苦労をかけ、家じゅうの者をさわがして、お前さんが仮病をつかって平気で寝てもいられめえじゃあねえか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、仮病はわかっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子には仮病を続ける必要があったのをつい忘れようとしたのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が古藤を連れて横浜に行ったのも、仮病をつかって宿屋に引きこもったのも、実をいうと船商売をする人には珍しい厳格なこの永田に会うめんどうを避けるためだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなれなれしい調子で興録を見やりながら、「興録さん、そうおっしゃればわたし仮病じゃないんですの。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮病を使うなら、はじめからもどらなきゃいいじゃねえか」「やったよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "借りたプログラムに手紙を書いたり、仮病を使ったり、映画の批評や何かを話し込んで別室に連れ出したり、自由自在とある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰ってもやっぱり橋場が恋しいので、仮病をつかって熊が出るなんて騒いでいる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにも知らない親たちは娘の仮病を心配して、もう一度橋場へやろうかと云っていたが、やっぱり其の儘になっていると、店の者のうちに何処からどうして聞き出したのか橋場の一件を知っている者があって、それが男湯へ来た時に勘蔵にうっかりしゃべったので、勘蔵は急に気を悪くした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘ももうちっと仮病をつかっていれば、なんにも間違いはなかったのかも知れませんが、陽気もだんだん暑くなって来るので、もう我慢が出来なくなって、うっかり車湯へ出て行ったのが運の尽きです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度戸山には赤十字社の仮病院が設けてある時であった。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の永年、軍隊の指導部員としての生活をして来て、軍規の野蛮さ、絶対命令に対するはかない抵抗としての兵士たちの仮病を見破りつづけて来た人々。",
              "citation": {
                "source": "孫悟空の雲",
                "author": "――『近代文学』十月号平野謙氏の評論について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さんの、気病よ」「仮病でなくて幸だ、ハハハハハハ」　登美がお茶を出したり、それを英輔が飲んだりするのを傍で眺めると、縫子には自分の寝ているのが詰らなく感じられてきた。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が覚めてみると、此処は師団の仮病舎。",
              "citation": {
                "source": "四日間",
                "author": "ガールシン",
                "note": "青空文庫"
              }
            },
            {
              "text": "一名｜仮病とも云われるそうな」「不面目病とも申されるそうな」「恥晒らし病とも申されるそうな」――などと悪口を云う者もある。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が仮病をしておると、まわりの者は本当の病気だと思うし、本当に病気をしたら、こんどは仮病だと思うだろう。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに義龍の病気は仮病であった。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は仮病を使って一室にこもり、ウンチクを傾けてアチャラカの脚本を書いた。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに病気なのかい、それとも仮病かい。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間の後私はとうとう堪え切れなくなって仮病を遣いました。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度の文も一度になり、仮病をこしらえたり旅へ出たり、何とかして遠退く算段ばかり。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
