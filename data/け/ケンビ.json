[
  {
    "uuid": "1dd2281b-be65-505a-8666-a880e0c8cc48",
    "entry": "兼備",
    "reading": {
      "primary": "けんび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
