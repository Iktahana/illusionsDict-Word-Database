        "examples": {
          "standard": [
            {
              "text": "日本語の「する」や「なる」といった動詞は、特定の文脈で軽動詞として機能することが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "言語学の授業で、軽動詞がどのように複合動詞を形成するかについて学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「散歩する」の「する」は、本来の意味を失い、軽動詞として使われている例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "セエラにまともに見つめられると、アアミンガアドはよけいどうしていいか判らなくなりました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
