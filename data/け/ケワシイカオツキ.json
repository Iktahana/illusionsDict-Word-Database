        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は眉をひそめながら「私はきっと険しい顔つきでもしているのだろう」と考えた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いったい、これはなんだとお思いです……どういう死にかたをすれば、死んだあとも、あんな膚色をしているとお考えです」　藤波は、おいおい不安をまぜた険しい顔つきになって、「さア、それは……すると、なにか毒でも」「おやおや、心細いですな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "三人目",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に険しい顔つきになって、裾をひるがえしながらつかつかとはいってくると、懐手のままで葵のまえへ立ちはだかって怒鳴った。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が高くなると、年老いた、険しい顔つきの男が、女のように泣きながらやってきました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして書類が何であるか察するといよいよ険しい顔つきになった。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、そんな声を聞きつけると、大人対手のように険しい顔つきになった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老けた、複雑な、険しい顔つきであった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
