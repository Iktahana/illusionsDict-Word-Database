[
  {
    "uuid": "4ded3ed9-2d9c-575a-85bd-0b682cc3a207",
    "entry": "経学",
    "reading": {
      "primary": "けいがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Confucianism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに音楽というもの、音の不断の刺戟というものが人間の頭脳に生理学の上からどう影響するものか、非常に研究されるべき神経学、心理学のテーマがあるとも思われます。",
              "citation": {
                "source": "期待と切望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "徂徠が修辞上の古学と経学とを結びつけんとしたるは僻せり。",
              "citation": {
                "source": "病牀瑣事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "允成は寧親の侍医で、津軽藩邸に催される月並講釈の教官を兼ね、経学と医学とを藩の子弟に授けていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎の経学の師には、先ず市野迷庵がある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時｜多紀藍渓時代に百日課の制を布いて、医学も経学も科を分って、百日を限って講じたことがある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも五百には、経学などをさえ、殆ど男子に授けると同じように授けたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百の師として事えた人には、経学に佐藤一斎、筆札に生方鼎斎、絵画に谷文晁、和歌に前田夏蔭があるそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化元年十三歳の時は兄の許にあるを屑とせずして家を出で、経学の師嘉陵村尾源右衛門と云ふものに倚つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リンチ事件で揺れ動く早稲田大学で、政経学部の新島淳良教授（四四）＝東京杉並区永福四の一二の一八＝が、このほど突然辞表を出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、昨夜九時の急行で、九大の神経学会に行くとかいう旨を伝えられたそうですが、その時召使の一人が、津多子様が電話室からお出になったのを見たのみで、それなり、吾々の眼には触れなくなってしまわれたのです。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の末に私は小姓そのままで、経学修行として京都へ行けとの命があった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして段々と山本の話を聞くと、私のこの度経学修業として京都へ来ることになったのは、他の一面には、諸藩の情勢にも注意して何か変った事があれば藩の当局へ報知することをも心得ていねばならぬのであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も肥後藩の生駒新太郎氏は最初大寮長で、後に少助教へ転任したのだが、経学家であったから私は心安くしていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも江戸時代の支那文学がやや明かに経学と詩文との研究を分つようになったのは、荻生徂徠の門より太宰春台、服部南郭の二家を出してより後のことである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも好しこの時代に至って江戸の文物は一般に円熟し、詩賦文章は経学倫理より分離し、純然たる芸術として鑑賞せらるべき気運に到着していた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山が古河藩の聘に応じて毎月日を定めて経学詩文の講義に赴いたというのは恐らくこの時であろう。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲津毅堂は連月三河屋に詩筵を開いたのみならずまた儒者と社を結んで経学文章を論究した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤倹兄に過ぎる位の男にて、経学に通じ能書なり、兵学を研究し西洋砲術を研究せり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "官公私立大学専門学校の収容学生を半減する案とか、学校数減少案とか、官立諸大学の一部を民営に移す案とか、帝大の法文経学部を廃止する案とか、いう諸提案が夫なのである。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三五・七）（一九三五・八）　大学・官吏・警察　　　一、杉村助教授の場合　東京商大の哲学者、杉村広蔵助教授は、学位請求論文（商学博士の）「経学哲学の基本問題」を同大学へ提出した。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に漢代以後支那哲学の正統となった儒教は教学の尤なるものだ（経学・礼教）。",
              "citation": {
                "source": "再び科学的精神について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "此鏡は天道さまより誰にも／＼与へおかるれども磨ざればてらさずと、われ若かりし時ある経学者の教に聞しと、狐の話につけ大学の蹄にかけて風諫せしは、問ひし人｜弱年にてしかも身もちのくずれかゝりし者なればなりき。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "トッド、ロンベルク、ロックハート・クラーク、デュシェーヌ、ミッチェルによって大きな影響を受けた臨床神経学はヒッツィヒ、フリッチュ、フェリア卿、の脳機能の局在についての実験研究によって完全に革命を受けた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルコーのもとでフランスの神経学者たちは脳および脊髄の目立たない疾患の診断に非常に正確さを与え、新しい解剖学的、生理的、実験的な研究の結合した結果は、以前は内科学で最も目立たない複雑な領域を明白で確実なものにした。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨床家オポルツァー、22版を重ねた解剖学の教科書の著者ヒルトル、生理学者ブリュッケ、神経学者テュルクおよびウィーンの医学部長フォイヒテルスレーベンを挙げることにしょう。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はフィラデルフィアの神経学者ミッチェルの友人で精神病の領域について興味を持っていた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕃山といっても経学をきくためではない、笛をまなびたいのだ、などと気焔をあげた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪性貧血患者および多数の絶対菜食主義者に起きる神経学的合併症の脊髄変性は、コバラミンだけしか予防できないことが間もなく判った（6）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてある人が、スイッツルの神経学者ヘラグースという名を忘れて、どうしても思出せなかったが、数時間の後に偶然心にうかんで来た。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
