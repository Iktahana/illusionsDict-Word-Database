[
  {
    "uuid": "1a6a8a90-4fa8-52dd-b6a2-79f1a6b5090c",
    "entry": "鍵盤",
    "reading": {
      "primary": "けんばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "keyboard (of a piano, typewriter, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "箱の前の鍵盤のようなものの一つを指で押すと槓杆の仕掛けで一疋の猫の尻尾をぐいと押す。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数疋の猫がそれぞれ高低の異った鳴声を出すようにしてあるので、うまく鍵盤をたたいてやれば猫の音楽が出来るというのである。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、子供の時に唱歌をやったと同じように、時々ピアノの鍵盤の前に坐って即興的のファンタジーをやるのが人知れぬ楽しみの一つだそうである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前を過ぎる幻像を悲痛のために強直した顔の表情で見詰めながら、さながら鍵盤にのしかかるようにして弾いているショパンの姿が、何か塹壕から這い出して来る決死隊の一人ででもあるような気がするのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信機の方はピアノの鍵盤のようなものにアルファベットが書いてあって、それで通信文をたたいて行くと受信機の方ではタイプライターが働いて紙テープの上にその文句をそっくりそのままに印刷して行く仕掛けである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君自らが音楽家であつたといふ事実をよそにしても、いろはにほへを鍵盤にした最も進んだ詩人の一人であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は裏庭を左にした壁のオルガンの前に腰かけて、指の先の鍵盤から湧き上がる快い楽音の波に包まれて、しばらくは何事も思わなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏者の白い十本の指があるときは泡を噛んで進んでゆく波頭のように、あるときは戯れ合っている家畜のように鍵盤に挑みかかっていた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばピアノの鍵盤や、オストワルドの色見本は、言わばそういう方向への最初の試歩である。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵盤のアクションのぐあいの悪いのを一つ一つたんねんに検査して行く。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気ままにピアノの鍵盤をたたきまわっても一つの音楽であるかもしれないがソナタにはならないと同様である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また女の捨てばちな気分を表象するようにピアノの鍵盤をひとなでにかき鳴らしたあとでポツンと一つ中央のＣを押すのや、兵士が自分で投げた団扇を拾い上げようとしてそのブルータルな片手で鍵盤をガチャンと鳴らすのや、そういう音的効果もあまりわざとらしくないようにうまく取り入れられている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノの鍵盤とピアノの音とが、銅鑼のクローズアップとその音とに交互にカットバックされるところなどあったように記憶する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部への月影憂鬱のかげのしげるこの暗い家屋の内部にひそかにしのび入りひそかに壁をさぐり行き手もて風琴の鍵盤に觸れるはたれですか。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の縁をピアノの鍵盤に擬へて、氣取つた身振をして滅多打に敲いても見た。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに文句に絶えず頭を使いながらせき込んで印字機の鍵盤をあさる時、ひき慣れないむつかしい楽曲をものにしようとして努力する時、そういう時には病的に過敏になった私の胃はすぐになんらかの形式で不平を申し出した。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この満場｜爪も立たない聴衆の前で椿岳は厳乎らしくピヤノの椅子に腰を掛け、無茶苦茶に鍵盤を叩いてポンポン鳴らした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　宗三が、不平らしくなじるのを聴きながら、京子は自分の部屋へ入ったかと思うと、ピアノの鍵盤を、双手でヤケにたたき鳴らした。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心に、鍵盤の上を梭のように馳けめぐっている白い手が、一番に浮かんだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、思うと、その白い蝋のような繊手は、直ぐ霊活な蜘蛛か何かのように、鍵盤の上を、駈け廻り始めた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、演奏が進むに連れて、彼女の膝の、夏草模様に、実物｜剥製の蝶が、群れ飛んでいる辺を、其処に目に見えぬ鍵盤が、あるかのように、白い細い指先で、軽くしなやかに、打ち続けているのだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいたい、鍵盤てやつは、もうたくさんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか現実感がないまま、慶一は令子にむかって足を踏みだし、頭のなかで、ギターコードを鍵盤上に展開した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心に、鍵盤の上を梭のやうに馳けめぐつてゐる白い手が、一番に浮かんだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、思ふと、その白い蝋のやうな繊手は、直ぐ霊活な蜘蛛か何かのやうに、鍵盤の上を、駈け廻り始めた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、演奏が進むに連れて、彼女の膝の、夏草模様に、実物剥製の蝶が、群れ飛んでゐる辺を、其処に目に見えぬ鍵盤が、あるかのやうに、白い細い指先で、軽くしなやかに、打ち続けてゐるのだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "パデレウスキーは何といつても、今では世界切つてのピアノ弾きで、旅行をする折にも手が硬ばると可けないからといつて、ピアノを汽車のなかに担ぎ込んで、閑さへあれば鍵盤を打つてゐる人である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "解決策として考案されたのは、ピアノから鍵盤を五本だけ抜き取ってきたようなキーセットだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、今に蝶が鍵盤の上にとまるだらう、すると、その小さな足の下で鍵盤は動き出して、音楽を奏するにちがひないと、心ひそかに待ちかまへてゐる。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
