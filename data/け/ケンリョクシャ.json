[
  {
    "uuid": "4d0b3dc6-32d5-584a-8a51-f508e7314db9",
    "entry": "権力者",
    "reading": {
      "primary": "けんりょくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
