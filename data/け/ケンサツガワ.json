        "examples": {
          "standard": [
            {
              "text": "検察側は被告人に対して懲役10年の実刑を求刑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判において、検察側は新たな証拠物件を提示して犯行を立証しようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "検察側と弁護側の主張は真っ向から対立し、公判は長期化の様相を呈している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "川口検事が立って、（一）検察側はだんじて拷問、人権蹂躙を行っていない。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "検察側の分が大いにわるくなるのである。",
              "citation": {
                "source": "演劇への入口",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いざ裁判が開始されると弁護人側の証人は続々と出廷して人肉試食の事実なしとの証言を行ったが、検察側の証人は裁判が終幕するまで遂に一人も出廷せずという、裁判史上稀有の事態を現出したのであった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、検察側は飽くまで強硬な態度に出た。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
