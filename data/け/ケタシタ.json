        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぜなれば、八段目をよく見ると一度に上から二桁下りてゐる。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "七段目で一桁下つて引いてあるが、その下にも何もないのであるから間違ひなくそれは１である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなれば、八段目をよく見ると一度に上から二桁下りている。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "七段目で一桁下って引いてあるが、その下にも何もないのであるから間違いなくそれは１である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターは小型のものでも数千万円していた当時、国民車的コンピューターを目指して一桁下の価格を実現したこのマシンは、一九六四（昭和三十九）年十月に発表された改良型のＮＥＡＣ―１２１０と合わせて、予想をはるかに超える八七〇台を売り上げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、そんなに僕が身装のことを気にするのなら帰りがけに小田原の町にある僕の生家を訪れて、講演会に出席するために要用と偽り、親父のもうにんぐこうとを持ちだして来てやらうと、倉造が点頭いてゐたことなどをつけたした。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志兄さんの部屋に飾ってあったから」　令子は、わたしの写真といっしょに、と小さな声でつけたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしには、兄さんと慶一さんは、ヘッケルとジャッケルみたいに見えるわ」　そういって、最後に笑いをつけたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう場合には運転手は必ず負傷しますが、乗っておられる方は大抵かすれ傷ぐらいですむのが普通です」　交通巡査は、二人の運転手の証言を確認してから彼自身の意見をつけたした。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああああ、そんなつもりでわざわざ国から出て来すか」　とまた附けたした。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　すわりながら小野さんは日本語でつけたした。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、社会的というと何か人間的というよりもあとからつけたした思想みたいに思って来た。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もこの商売を廃めてしまったでは御座いませんから」　と附けたした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尤も、女中にそんなことを言われて、調戯われて来たらしいんだ」と復た彼は附けたした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことも附けたした。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とマニーロフがつけたした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "とチチコフは心で呟やいたが、すぐにまた、と附けたした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と家政婦は、その問いのおわるのも待たないで遮ったが、ちょっと間をおいてから附けたした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼は、少し考えてから附けたした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カラカラと笑ってつけたした。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女はあたしの友達の、箏の名人の浜子を見てつけたした。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敗戦を口実にするのが、卑怯なのです」　と語気強くつけたしたから、私もいさゝかその割り切り方に反撥を感じて、「然し、ヤス子さん。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にできることは脚本と、全体の構成、演出だが、その他の雑用に使はれても構はないとつけたした。",
              "citation": {
                "source": "暗い青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風変つた男の性格的な嗅覚であらうと、太平も率直に受入れたが、何か大きな孤独の中で特別の人間苦を見つめてゐる男であらうといふやうな想像は、後日になつて附けたしたものであらうと思はれた。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき谷村は更に意外な発見をつけたした。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときも、然し、娘はやがてまじめな顔になつて、かうきびしく附けたしたものだ。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから新十郎は説明をつけたした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、御成功を祈りますよ」　そして、更に一言、咒文の様につけたした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに、私ののぞみもつけたしたら、おどけたアクションをつけてほしいこと。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく余り、神経をたかぶらせないのが得策ですよ」　と、遠山は笑ひながらつけたした。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
