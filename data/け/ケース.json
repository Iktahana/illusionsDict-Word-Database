      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "case (container)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ロシアは八かましいと聞いていたから、自ら進んでスートケースの内容を展開しようとしたら税関吏の老人はニコニコしながら手真似で、そうしなくてもいいと制するのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな、今で言えばスーツケースのような格好をした黒塗りの革鞄に、これも赤く大きく千金丹と書いたのをさげていたと思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには羊皮の帽子をかむり、弾丸のケースをさした帯皮を両肩からはすかいに十文字にかけた男が乗っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　オツベルはいつかどこかで、こんな文句をきいたようだと思いながら、ケースを帯からつめかえた。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オツベルはケースを握ったまま、もうくしゃくしゃに潰れていた。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはたばこをくわえてマッチをすったり楽器をケースへ入れたりしました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショッチュウ気を付けてケースの中味が在るか無いか調べなくちゃならないのが面倒臭い位のもんでさ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "困っちゃって、ボクスか何かの古い皮革のケースに入れたまんま向うの棚の片隅に置いといたんです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば同じようなスートケースが少なくも四五度現われて、それが皆それぞれ違った役目をつとめると同時にその物を通して過去をフラッシュバックして運命の推移を意識させる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそう思いながら、新らしい日和下駄を買ってそっとスーツケースの奥に入れた。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそはあの男に出しぬかれないぞ」　そう呟いた時、スーツケースを持った伊都子がエレヴェーターから降りて来た。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の停車場に着くと、父は車夫を呼んでチェッキで大きな赤革のスートケースを二つも受け取らせた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのスートケースの一つと共に車に乗って波止場へ向う道々、私は何時の間に父がこんな大きな荷物を持ち出したものかと思い迷った。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はそのサクソニヤ号へ二つのスートケースと一緒に入って行った。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "床脇の棚のところに、加世子のスウツケースや風呂敷包があり、不断着が衣紋竹にかかっており、荒く絵具をなすりつけた小さい絵も床脇の壁に立てかけてあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、パティキュラー・ケースがああなると云う丈けで、全体がああ云う運命になると云うことは含んで居ない。",
              "citation": {
                "source": "予の描かんと欲する作品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と麻川氏は叔母さんにケースを出したが叔母さんは喫まないのでお辞儀だけした。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒っぽい絽の羽織の着流し姿で小さいケースを携げて居る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は落着いて煙草ケースから一本取出して投げやりに口に銜えた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い口調でそう言って、シガレットケースから煙草を取り出し、一本口にくわえて、「マッチないか？",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルのケースをさげた日本の憲兵が時々入口から中をのぞきに来た。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言って巻莨入れのケースを開けて、一本を口に銜えました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど古トランクが一つ、旅館のペーパーがところ／″＼貼ってあるスーツケースが大小二つ、電灯の下に見出されました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは父よりもわたくし自身穢されたような気がして、スーツケースの横腹を白足袋の趾尖で蹴りつけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからせめてこの穢すものゝ置きどころでも片隅へ違えてやりましょうとスーツケースに手をかけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は座席に即くと悠々小田島のシガレットケースから煙草を抽き出してふかし始めた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここン所坂野医院大繁昌だね」　坂野はにやりと木崎の顔を見ながら、ケースの中からヒロポンのアンプルを取り出し、アンプル・カッターを当てて廻すと、まるで千切り取るように二つに割った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
