      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで勃然として床を蹴り、一直線に私の所へ飛んで來たのだといふ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこへ二階からドヤドヤドヤと降りて来た良子の義理の兄さんが、便所に行かうとして椽側に出ると、其処に猫の食べ物を入れてやるお皿が置いてあるのを見ると、お祖母さんの眼を怖い顔で見ながら、そのお皿を庭の方へ蹴り棄てた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴り出されたお皿は庭の土の上で、だんだん雨に濡れてゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "願くは我れを蹈みつけ侮辱し唾を吐きかけまた床の上に蹴りきびしく苛責しああ　遂に――わが息の根の止まる時までも。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板を下駄で蹴りながら、昨日稽古した「エコー」と云うのを歌う。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉其奴を蹴り倒し、ピシャリ戸を閉めて、Ｔ「人違いすな　此村大吉、御用と　呼ばれる覚えない」　と外の役人の一人が、Ｔ「五郎蔵の訴えにより　罪状明白じゃ　神妙にしろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴り上げられた心臓が喉も詰りそうに激しく悸つ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして荒々しく床板を蹴りながら柵のところへやって来た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "６４＝表　伊吉蹴り出された。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "64＝表　伊吉蹴り出された。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "態を見ろ、弱虫｜奴」　といきなりその長い八本の足で達磨を蹴り飛ばしました。",
              "citation": {
                "source": "章魚の足",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると章魚は、「お前なんか黙っておれ」　と言って又蹴りつけました。",
              "citation": {
                "source": "章魚の足",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと思ふとおんつぁんは毛嫌ひする老いた牝犬のやうに、勃凸をすげなく蹴りつけることもあつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波濤を蹴りて數百の。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "担える籠は覆りて、紙屑、襤褸切、硝子の砕片など所狭く散乱して、脛は地を蹴り、手は空を掴みて、呻吟せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆は立つ足もなくあわて惑う、牛あれて一｜蹴りに駈け散らして飛び行く。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、撲り、蹴り倒すといっても、今となってみれば妻の体に指一本ふれることも、けがらわしいもののように思えてならない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島と高松を往復する一〇〇｜噸足らずのボロ汽船であったが、彼の石炭のいれ方がちゃちだから船が進まんと、罐の前でへっぴり腰を蹴り飛ばされた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」権右衛門はバケツを蹴り倒した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その男は幸子を助けると思いの外、そこでしばらく思い迷った様子だったが、どういうつもりかあらためて幸子の体を下へ蹴り落したのだ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいない窓の一つ一つを、念入りに眺めまわしながら、なおも奥深く身を隠すように這い退って、彼の足の先に茂り合ったアカネ草の中に入ろうとしたが、その拍子に、編上靴の先で彼の足首を蹴りつけるとギクリとして振り返った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから尚ヘルンは、かかる神神を泥靴で蹴り、かかる信仰を讒罵し、かかる善良な人人を誘惑して、キリスト教の僞善と惡魔を教へようとする外人宣教師を、仇敵のやうに痛罵してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのうちに、三人は同じ方へ水を蹴りました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はかっとなって、端の綴じが僅か残っている金網を怒りの足で蹴り放った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う岸は倉庫と倉庫の間の空地に、紅殻色で塗った柵の中に小さい稲荷と鳥居が見え、子供が石蹴りしている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにそれが、ときどき侘びしくふらと家を出て、石を蹴り蹴り路を歩いて、私は、やはり病気なのであろうか。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "濶歩埋葬地の間をよぎりて、ふと立停ると見えけるが、つかつかと歩をうつして、謙三郎の墓に達り、足をあげてハタと蹴り、カッパと唾をはきかけたる、傍若無人の振舞の手に取るごとく見ゆるにぞ、意気｜激昂して煙りも立たんず、お通はいかで堪うべき。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは父よりもわたくし自身穢されたような気がして、スーツケースの横腹を白足袋の趾尖で蹴りつけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が底を探りたる、者とてはなく、汝がゆたけき内奥を、知るものとてなかりけり、さまで汝等秘密をば、守らんこと敏なりき！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
