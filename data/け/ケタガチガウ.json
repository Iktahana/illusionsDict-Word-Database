          "literary": [
            {
              "text": "人物の器の桁が違うのである。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫大な国防献金と云っても、膨大な軍事予算や事変追加費予算の嵩に較べれば、まるで桁が違うのである。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「冗談じゃない、桁が違うんだ。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十人か何百人かの女学生がこっそり紙と糊とで造った日本の秘密兵器とは桁が違うよ」「材料といえば、一体何原子だろう？",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺のとは桁が違うと仲人の方が仰有っていました」「結構でした」「豊子さんは余っ程のところでないと納まりませんわ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし下町の目抜と山の手の突っ端とは地価の桁が違う。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら、もう一段桁が違うかも知れない。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
