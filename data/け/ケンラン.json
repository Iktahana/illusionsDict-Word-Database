      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gorgeous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなに絢爛たる面貌にくらべて、四肢の貧しさは、これまた驚くべきほどであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう周圍が眞暗なため、店頭に點けられた幾つもの電燈が驟雨のやうに浴せかける絢爛は、周圍の何者にも奪はれることなく、肆にも美しい眺めが照し出されてゐるのだ。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はリキュール酒のようなあまさで、夜の街を覆うと、絢爛な渦巻きがとおく去って、女の靴の踵が男の弛緩した神経をこつこつとたたいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう周囲が真暗なため、店頭に点けられた幾つもの電燈が驟雨のように浴びせかける絢爛は、周囲の何者にも奪われることなく、ほしいままにも美しい眺めが照らし出されているのだ。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらにしても、当時仏教文化の絢爛成熟した有様が覗われます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの絢爛さは、また華厳教義の華やかさでもありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに従って護法の諸天、神将達が絢爛なる武装にて控え居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法を護る諸天善神達は絢爛なる甲冑に槊、剣、戟、金剛杵、弓箭にて働く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども花開いて絢爛たり。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして恐る／＼絢爛たるスペイン革の覆いを除けて、彼自身の姿と向き合った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきつけとも云うべき明るい広間に、十人もの六月の牡丹の如く絢爛たる女が並んでいた。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は下賤から身を起して、人品あがらず、それこそ猿面の痩せた小男で、学問も何も無くて、そのくせ豪放｜絢爛たる建築美術を興して桃山時代の栄華を現出させた人だが、一方はかなり裕福の家から出て、かっぷくも堂々たる美丈夫で、学問も充分、そのひとが草の庵のわびの世界で対抗したのだから面白いのだよ。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは欧洲文芸復興期の人性主義が自然性からだんだん剥離して人間｜業だけが昇華を遂げ、哀れな人工だけの絢爛が造花のように咲き乱れた十七世紀の時代様式らしい。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の望む美魚はどうしても童女型の稚純を胴にしてそれに絢爛やら媚色やらを加えねばならなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また子を産んで、水を更えた後の藻の色のように彼女の美はますます澄明と絢爛を加えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この絢爛な退屈を何十度となく繰り返しているうち、僕はいつの間にか、娘のことを考えれば、何となく微笑が泛べられるように悠揚とした気になって来ました。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は」　襖が開いて閉って、そこに絢爛な一つくねの絹布れがひれ伏した。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで絢爛に泳いでゐた二つのキヤリコの金魚が、気圧の重さのけはひをうけて、並んで沈むと、態と揃へたやうに二つの顔をこちらへ向けた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに絢爛たる面貌にくらべて、四肢の貧しさは、これまた驚くべきほどであつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水無ければ、絢爛の美、錦繍の文、竟に成らざるなり。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウプサラ署の死體收容室でイングンの體から絢爛たる銀色の夜會服を脱いでみると、言ふまでもなくその下は下袴をまとはぬ素肌だつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絢爛の才能とか、あふれる機智、ゆたかな学殖、直截の描写力とか、いまは普通に言われて、文学を知らぬ人たちからも、安易に信頼されているようでありますが、私は、そんな事よりも、あなたの作品にいよいよ深まる人間の悲しさだけを、一すじに尊敬してまいりました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窄めたものは丈けが巻軸ほども短くて、それを並べて山型に立てゝある有様は燭台に並ぶ色蝋燭のように壮厳で絢爛であります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しきものは命短しというをモットーとするように豪奢と絢爛が極まると直ぐ色｜褪せてあの世の星の色と清涼に消え流れて行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅と緑の光弾、円蓋、火箭、ああ、その銀光の投網、傘下し、爆裂し、奔流し、分枝し、交錯し、粉乱し、重畳し、傘下し、傘下し、傘下し、八方に爛々として一瞬にしてまた闇々たる、清秀とも、鮮麗とも、絢爛とも、崇美とも、驕奢とも、譬うるに言葉も絶えた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは其の頃、友人の誰もが、私の作品よりも私の性格と談話との絢爛さを買っていたようだったから。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絢爛たる才気と洗錬された趣味と該博な知識とを有った・端倪すべからざる才人だった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にかくの如く突兀・奇峭にして、又絢爛を極めた言葉の豪奢な織物でなくては、とても、氏の内なる美しい幻想を――奇怪な心象風景を――写し出すことは出来ないのである。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは彼の企てた『硝子のやうな透明感』また、東洋の七宝のやうな光りのけんらんたるアラベスクを現出してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝やけの美しい空に、自然児としてのほこりを感ずることもあったし、夕映えのけんらんたる色どりの空をあおいで、神の国をおもい、古今を通じて流れるはるかな時間をわが短い生命にくらべて、涙することもあった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
