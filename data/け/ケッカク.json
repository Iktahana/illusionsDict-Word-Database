[
  {
    "uuid": "59a6cde2-a805-5b2e-99bd-68d5334f531a",
    "entry": "結核",
    "reading": {
      "primary": "けっかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tuberculosis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腎臓結核という、わるい病気でございまして、気のついたときには、両方の腎臓が、もう虫食われてしまっていたのだそうで、医者も、百日以内、とはっきり父に言いました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺結核でそこに転地しているある人を見舞いに行って一晩泊まった時がちょうど旧暦の盆の幾日かであった。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで肺炎から結核になろうと、なるまいと、そんな事は念頭にも置かなかった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合のあることは昔からも知られていたであろうが、それが欧州大戦以後、特に外科医の方で注意され問題にされ研究されて、今日では一つの新療法として、特殊な外科的｜結核症や真珠工病などというものの治療に使う人が出てきた。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉類の中の結核　獣肉中に結核の有無を見るには従来ただこれを切開して吟味するより外に手段はなかったが、近頃ある人がＸ光線で透して見てすぐに病所の有無を知る事を発見した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月十七日『東京朝日新聞』）　　　　　　　　　六　　　　　　結核の初期診断法　一時有名であったコッホのツベルクリンは、その後ただ結核病の診断にのみ用いられていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち結核の疑いある患者にこれを注射すると、もしそうであれば発熱などの反応を起すからわかるというのであった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今度仏国のカルメットという人の発表した所に拠ると、酒精で沈澱させたツベルクリンの一プロセント溶液を眼に点ずると、健康体ならば何の異状も起らぬが、少しでも結核のあるものならば、二十四時間内に充血して紅くなるという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千人近くの患者について試験をしてこの事を確かめたが、ある場合殊に小児などでは、他の方法でどうしても知れなかった結核の存在をこの法で見付けたと称している。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結核病研究の万国会議　来年九月二十一日より十月十二日まで米国ワシントン府で表題の会議が開かれる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体七部門に分れて、結核に関する病理、療法、予防その他一切の会議をするはずで、また開会中は該病に関する展覧会を開いて公衆に観せるそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年一月一日『東京朝日新聞』）　　　　　　　　　五十九　　　　　　結核病と食物　結核菌を接種した動物に種々の食物を与えて病の経過を試験した結果によると、脂肪分を主に与えたものは四十日くらいで死し、含水炭素殊に砂糖を多く与えたものは八十七日くらいで死んだ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その病室にはアメリカへ出稼ぎに行つて、肺結核に罹つて、故國で死にたいと云ふ望みから重體のまま歸朝して來た中年の紳士が、その十日程前からはいつてゐたのだつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのね、この先の結核の患者の方ね。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところがねえ、次が大へんなんですよ、耕牧舎の飼牛がね、結核にかかっていたんですがある日とうとう死んだんです。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな既に結核に冒されてしまったような風景でもなければ、思いあがった詩人めかした海でもない。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪で死んだというが肺結核だったらしい。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは肺結核で死んだ人間の百分率で、その統計によると肺結核で死んだ人間百人についてそのうちの九十人以上は極貧者、上流階級の人間はそのうちの一人にはまだ足りないという統計であった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれは、今非常に多くの肺結核患者が死に急ぎつつある。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に一｜昨年の冬、衣絵さん、婿君のために若奥様であつた、美しい夫人がはかなくなつて居る……新仏は、夫人の三｜年目に、おなじ肺結核で死去したのであるが……　園は、実は其の人たちの、まだ結婚しない以前から衣絵さんを知つて居た……と言ふよりも知られて居たと言つて可からう。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……えゝ、尤も、結核は、喉頭から、もう其の時には舌までも侵して居たんださうですが。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合のあることは昔からも知られていたであろうが、それが欧州大戦以後特に外科医のほうで注意され問題にされ研究されて、今日では一つの新療法として特殊な外科的結核症や真珠工病などというものの治療に使う人が出て来た。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結核菌が、からだのあちこちを虫食いはじめていたのでした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかみから、いま聞いて来たんですけどね、」　と橋田氏も、まじめな顔をして、「あの子は、腎臓結核だったんだそうです。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腎臓結核は、おしっこが、ひどく近いものらしいですからね、ミソを踏んだり、階段をころげ落ちるようにして降りてお便所にはいるのも、無理がないんですよ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青松園には三十六人の肺結核患者がゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
