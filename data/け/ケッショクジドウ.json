        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨夜仙台の新聞で欠食児童何百という表題の記事を見て来たばかりの眼には、この目前見渡す限りの稲の秋は甚だそぐわない嘘のような眺めであった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "農漁村を通じて欠食児童は、二十万に登っている。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠食児童なんか聞いたこともない。",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠食児童は二十万人だ。",
              "citation": {
                "source": "ロシア革命は婦人を解放した",
                "author": "――口火を切った婦人デーの闘い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の子供も欠食児童だよ」　「まとめて救援してやるよ　出しな！",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ははは、……腹が空いてゐるんぢやないかね、……我輩がひとつ、欠食児童救済事業を起すかね」　と、つづけて、「高等乞食」は機嫌よく云ふのであつた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人女給といふものも甚だ月並なもので、御亭主と懇ろになれば店に居つくが、さもなければ、いつ誰と消え失せるか、ヒモがついたり、無断欠勤の温泉旅行等々、わがまゝ無礼、元来この節の日本人の飲み助どもときては、女よりは酒、少しでも安く酒、たゞもう欠食児童なのだから、女などあてがうのはモッタイない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九　百姓弥之助が植民地へ戻ると二ツの欠食児童が待って居る。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠食児童とは猫の子である、この植民地へはまぐれ猫、のら猫がよくやって来る。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼弱者虐待防止案といい、欠食児童救済事業といい、このあらわれに他ありません。",
              "citation": {
                "source": "近頃感じたこと",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、全村の小学校児童九百名のうち、四百名までは欠食児童であるというのだ。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
