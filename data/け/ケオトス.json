        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ライバルを蹴落とし、彼はトップの座に上り詰めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その選手は、他の選手を蹴落とすかのようにゴールへ向かって突き進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過酷な競争社会では、常に誰かを蹴落とす覚悟が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "けれどそもそも互いを蹴落とすべきライバルを抱え込んで、果たしてＡＣＥは一つの「構想」足りうるのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉藻ほどの才女ならば、ひそめるその力を利用して、頼長めを殿上から蹴落とすことが出来るかもしれないと、忠通は頼もしく思った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉藻も立ちどころに殿上に召されて、やがては予定の通りに頼長や信西の一派を蹴落とすことも出来る。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで初めに、逆向きのロケット・エンジンを、暫くの間だけはたらかせて、速度を時速一、〇七〇マイルだけおとす。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気になるなよ　もうたくさんじゃわい　いなねば　上からけおとす！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気になるなよもうたくさんじゃわい　いなねば上からけおとす！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
