        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蛇でもいもりでも焼いてしまえば結局炭と若干の灰分とになってしまうのだから、黒焼きがきくものなら消し炭を食ってもきくわけだ、とざっとこういうふうに簡単に結論を下してしまう。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると三郎は、どこから出したか小さな消し炭で雑記帳の上へがりがりと大きく運算していたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりひるすぎには、ブドリはネリといっしょに、森じゅうの木の幹に、赤い粘土や消し炭で、木の名を書いてあるいたり、高く歌ったりしました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十｜燭の電燈に照らされた板張りの上の小さな火鉢に、消し炭が一パイに盛られている傍に、男と女が寄り添うようにして跼まって、濡れくたれた着物の袖を焙っている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草の火はねえかえ」　お冬は気がついたように立ち上がって、煙草盆に消し炭の火を入れて来ると、源蔵は腰から筒ざしの煙草入れを取り出して、一服｜喫いはじめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　お作は妙におどついて、にわかに台所から消し炭を持って来て、星のような炭団の火を拾いあげては、折々新吉の顔色を候っていた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にお庄兄弟が、消し炭の火を吹きながら玉蜀黍を炙っていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けどもな、あの穴へ手を入れると、あの時に燒けたのが消し炭になつてゐて、黒う手に附きまツせ。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま消し炭を持ってくるから」　母は麻糸をかたよせてたとうとした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは古今集の恋歌でございますが、筆蹟は消し炭で書いたのですから確と分りませぬ。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "竈の下も風呂の下も毎日灰をかき出し、大きい灰ふるいを用意して必ずそのかきだした灰をふるい、小さな消し炭を消しつぼに入れること。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝか、欄干の後を見るんだよ、大抵は消し炭だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火の呪ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目につかぬ石塀の隅へ、消し炭で書いてあった文字である。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
