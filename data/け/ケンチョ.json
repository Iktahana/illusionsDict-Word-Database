[
  {
    "uuid": "090519c8-1872-5c01-9bd9-690ffaa2e301",
    "entry": "顕著",
    "reading": {
      "primary": "けんちょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
