[
  {
    "uuid": "3dec7e16-1d9d-5a1e-a2fb-ec30d3dcae63",
    "entry": "慶賀",
    "reading": {
      "primary": "けいが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
