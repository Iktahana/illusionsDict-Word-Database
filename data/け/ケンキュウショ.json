[
  {
    "uuid": "778264df-74a2-5a7a-a229-84d6a187f349",
    "entry": "研究書",
    "reading": {
      "primary": "けんきゅうしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
