        "examples": {
          "standard": [
            {
              "text": "ギリシャ神話に登場するケルベロスは、冥界の番犬だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ケルベロスは三つの頭を持つ恐ろしい犬として描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "RPGゲームのボスキャラクターとしてケルベロスが出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "への字形に排列した此三山は、体から言えば、希臘神話に現れている地獄の怪犬ケルベロスのように一身三頭である。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上甲州側信州側からは、此山は一寸見えないが、栃本では近所の小高い所へと登れば、自分がケルベロスにたとえた三山がよく見えて、中央の山は小さく、如何にも拳に似て居る。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルベロスといふ犬だ。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルベロスがうなつた。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルベロスは煖炉の正面に蹲つて白い色の化物のやうに、ぢつと火を見詰めてゐる。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
