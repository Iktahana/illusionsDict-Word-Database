[
  {
    "uuid": "3c90937e-62e4-51ac-bd07-d9ce9b98f565",
    "entry": "形跡",
    "reading": {
      "primary": "けいせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
