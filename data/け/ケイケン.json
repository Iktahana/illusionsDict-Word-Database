[
  {
    "uuid": "bbe6b2c0-5a3a-5696-ac45-ff850f4914f5",
    "entry": "経験",
    "reading": {
      "primary": "けいけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
