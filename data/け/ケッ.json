    "definitions": [
      {
        "index": 1,
        "gloss": "ugh (when angry, irritated, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）ぽけっとに手を突込んで路次を抜け、波止場に出でて今日の日の魂に合ふ布切屑をでも探して来よう。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ腐った臓腑だけっか入ってねえんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、いやに明けっ放しでいやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　暑苦しいために明けっ放した表から、誰かが呼んだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は叫ぶ、坂部さんがいなければ木下さんへゆけってこかねい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼ばれて君江「けったいな奴」と言った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではとお小夜、Ｔ「あたしはこの道から」　なりひらが、Ｔ「俺はこっちから」　半次が、Ｔ「何っちが早いか馳けっくら」　で、なりひらとお小夜がスタートに付く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「けったいやなあ、それなんや。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は終日、彼女にあたえられた部屋で過去の瞑想にふけっているようであった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただいろんな事を止め度もなく考えて、思いにふけったものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼はもはやけっしてうたわざりき、親しき人々にすら言葉かわすことを避くるようになりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯れに棒振りあげて彼の頭上に翳せば、笑うごとき面持してゆるやかに歩みを運ぶ様は主人に叱られし犬の尾振りつつ逃ぐるに似て異なり、彼はけっして媚を人にささげず。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のざらざらした、屋根がひくい、息づまる寄宿舎で、彼等は思い／＼の考えにふけった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何か、自分でも分からないような考えにふけった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りたけって走って来る。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小屋といふのも南の方は明けっぱなしで壁もなく窓もなくたゞ二尺ばかりの腰板がぎしぎし張ってあるばかりだった。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやもうから意気地がござりません代わりにゃ、けっして後ろ暗いことはいたしません。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといおまえが何かの折に、おれの生命を助けてくれてさ、生命の親と思えばとても、けっして巡査にゃあ遣らないのだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崖の上の端近く、一高の学生が一人あぐらをかいて上着を頭からすっぽりかぶって暑い日ざしをよけながら岩波文庫らしいものを読みふけっている。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、「真田三代記」、「漢楚軍談」、「三国志」といったような人間味の希薄なものを読みふけったのであった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時代に上記のごときおとぎ文学や小説戯曲に読みふけっているかたわらで、昆虫の標本を集めたり植物※葉を作ったり、ビールびんで水素を発生させ「歌う炎」を作ろうとして誤って爆発させたり、幻燈器械や電池を作りそこなったりしていたのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが反対に画面の右端を左へ向いて駆けって行くのでは迫った感じが出ないであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、将来大マラソン家になろうという野心も無く、どうせ田舎の駈けっくらで、タイムも何も問題にならん事は、よく知っているでしょうし、家へ帰っても、その家族の者たちに手柄話などする気もなく、かえってお父さんに叱られはせぬかと心配して、けれども、それでも走りたいのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五円の稿料いただいても、けっしてご損おかけせぬ態の自信ございます。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――山よりほかに、……　なぞという大時代的なばかな感慨にふけって、かすかに涙ぐんだりなんかして、ひどく、だらしない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっして噛まないということは、科学的に証明できるはずはないのである）その猛獣を、放し飼いにして、往来をうろうろ徘徊させておくとは、どんなものであろうか。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、注射代などけっして安いものではなく、そのような余分の貯えは失礼ながら友人にあるはずもなく、いずれは苦しい算段をしたにちがいないので、とにかくこれは、ひどい災難である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "山梨県は、もともと甲斐犬の産地として知られているようであるが、街頭で見かける犬の姿は、けっしてそんな純血種のものではない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのような姿は、いかにも異様であり、風紀上からいっても、けっして許されるものではないのだから、私は別の手段をとらなければならぬ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は荒鷲のようにたけりたけって、グラスをつかんだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
