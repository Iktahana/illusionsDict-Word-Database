    "definitions": [
      {
        "index": 1,
        "gloss": "official certification",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それらの試作映画を文部省かどこかで検定し、優秀なものは全国に配布することも出来るであろう。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象台の測器検定室の一隅には聖母像を祭ってあって、それにあかあかとお燈明が上がっていた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう検定方法は切実な要求さえあらばいくらでもできるはずであるのにそれが実際にはできていないとすれば、その責任の半分は無検定のものに信頼する世間にもないとは言われないような気がする。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこで、心得のある、ここの主人をはじめ、いつもころがり込んでいる、なかまが二人、一人は検定試験を十年来落第の中老の才子で、近頃はただ一攫千金の投機を狙っています。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、国漢文中等教員の検定試験をうける準備中であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は国漢文中等教員検定試験の勉強中であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて彼は国漢文中等教員検定試験を受けて、落第したことがあった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワープロ検定の三、四級が、十分間に三百〜四百字程度。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮火の進行状態は、技師の検定に委ねられた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "益子が十九の春、Ｋの許に嫁いで来た時、その米三君は、国語の検定試験を受けるために、田舎から出て、Ｋの家に寄寓してゐた。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "……）　学校を中途で退学して以来、隆造は実家との折合が悪く、で、いつそ叔父の勧める儘に自分は検定で医者の資格を得よう、と志して三年程前から叔父の医院に依つて居たのだが、今だに彼は前期の免状さへ取れなかつた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……兄さん、僕はやっぱり、英語の検定をとることにしました。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "興津の高さんは、あんなに学問ができて、中学校の先生をしているが、検定試験を受けるたびに、からだがふるえて、うまく答案ができないんで、気の毒なことにいまだに月給が上がらずにいる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い人達が内省的な心理学をきらって、唯表面の変化丈を観察し、検定する事で、外面的心理学を樹立させようといきまくのはきっと彼等も私と同じような「木偶感」に縛されているからであろう。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の校長は、検定試験を受けることをつねにすすめた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和にある講習会へ出かけて、検定の資格を得ようとしているものもある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長と校長とは愉快そうに今年の豊作などを話していると、若い連中は若い連中で検定試験や講習会の話などをした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "関さんは文部の中学教員検定試験を受ける準備として、しきりに動植物を研究していた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "△「新年を床の青磁の花瓶に母が好みの蔓梅もどき」△小畑に手紙出す、これより勉強して二年三年ののち、検定試験を受けんとす、科目は植物に志す由言ひやる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年はだめだが、来年は一つぜひ検定を受けてみたいんだが」　と清三は言った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "検定試験上りの秋野は十三円で、古い師範出の校長は十八円であつた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し資格から言へば、同じ正教員でも一人は検定試験上りで、一人は女ながらも師範出だから、孝子は校長の次席なのだ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "突当りの並んだ二脚の、右が校長閣下の席で、左は検定試験上りの古手の首座訓導、校長の傍が自分で、向ひ合つての一脚が女教師のである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年は文部省の検定試験を受けて、歴史科中等教員の免状を貰ふた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二高で高等学校の検定試験を受け及第。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "検定試験に及第して伊予の方のある私立学校の教師として赴任して行った足立の噂も出た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "が石畑君はその後独学して、検定をとって、六高に入り、大学を経て、高文もパスし、今は満鉄にいるという通知が来た。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としては、英数漢の三科目を専門に学んで女学校卒業の検定試験を受けた上、女子医専に進もうと独りできめていたのだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学は首席で柔道は初段、数学の検定を四年のときにとった彼は、すぐまた一高の理科に入学した。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処だいろ油断のでけんていふ気のしはせんかなあ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
