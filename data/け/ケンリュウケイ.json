        "examples": {
          "standard": [
            {
              "text": "微弱な電流を検知するために、高感度の検流計が使われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "実験では、ガルバノメーター、つまり検流計を用いて電流の方向を調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "検流計の針がわずかに振れ、回路に電流が流れていることを示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "機械はウイムスハルストの感応起電機と、ダルソンバールの検流計である。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに瓦斯の炎をぶうぶうと吹きつけながら、室井君は歯車を片手でがらがら廻しては、検流計の望遠鏡を覗いていた。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室井君の「地球磁気の根源に関する」大研究も、検流計が一つとあとはアスベストスの棒と手細工のがらがら廻る歯車とが出来上がれば、とにかく実験が始められた。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば検流計にしても、寒暖計にしても、測風計にしても、皆従来の物理学または気象学の器械をそのまま使っているわけである。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍土内の温度は熱電対と検流計とで電気的に測るのである。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方法で精密な検流計を使うと、零度附近で百分の一度の精度が得られる。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検流計のためにはテントを張って貰った。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に太い柱を埋め込み、その上に検流計を安置して、黒い布で周囲を蔽う。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに瓦斯の炎をぶうぶうと吹きつけながら、ＨＭ君は歯車を片手でがらがら廻しては、検流計の望遠鏡を覗いていた。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＭ君の「地球磁気の根源に関する」大研究も、検流計が一つとあとはアスベストスの棒と、手細工のがらがら廻る歯車とが出来上れば、とにかく実験が始められた。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
