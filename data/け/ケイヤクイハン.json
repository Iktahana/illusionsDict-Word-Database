        "examples": {
          "standard": [
            {
              "text": "相手方が契約違反をしたため、損害賠償を請求した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の行為は明らかな契約違反だと、弁護士が指摘した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "契約違反によるトラブルを避けるため、事前に契約内容を徹底的に確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「それぢや契約違反の賠償として二百円の科料を命ずる。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを考慮しないで長期にわたる契約をするものだからほうぼうで見苦しい契約違反沙汰が持ち上るのである。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは契約違反である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルメルは久五郎を契約違反で訴えた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "生糸貿易にかけては素人のフリをして、期限ぎれや、わざと粗悪品をつかまされるように仕向けて、契約違反で訴えて、品物はタダ取りの罰金はモウカルというモトデいらずの商法の大家が多かったのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
