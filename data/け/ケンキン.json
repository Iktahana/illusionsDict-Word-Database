    "definitions": [
      {
        "index": 1,
        "gloss": "additional post",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（この間に、他書の編纂※訂など命ぜられ、又、音樂取調掛兼勤となりしことも數年なりき。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば君はあの女学校も兼勤だったね。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども政務の方にも必要なので、ヤハリ目付を本役として側用達は兼勤という事であった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜が――捜がしたに違ない」と先生の口が、喫飯と返事を兼勤する。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御部屋住の前次様のお附き元締兼勤を仰付けられました。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治から大正へかけて、私は一度右の帝室博物館の天産部に兼勤していたことがあった。",
              "citation": {
                "source": "寒桜の話",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやしくもこの鏡に対する間は一人でいろいろな化物を兼勤しなくてはならぬ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
