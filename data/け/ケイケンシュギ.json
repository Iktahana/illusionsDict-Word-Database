    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Pietism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
