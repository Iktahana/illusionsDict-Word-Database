        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このワインは経年によって味がまろやかになり、深みが増した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史的建造物の保存には、経年による劣化を防ぐための専門的な技術が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経年の変化を楽しめる革製品は、使い込むほどに味わいが増す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "其後者の後半に、「経年二百凌霜雪、春色異他妖艶叢」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "○慰むる心はなしに雲隠り鳴き往く鳥の哭のみし泣かゆ　〔巻五・八九八〕　山上憶良　山上憶良の、「老身重病経年辛苦、及思児等歌七首長一首短六首」の短歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者としての観点も述べておくと、BL はいかんせん経年劣化が否めず、読み物というよりは研究やコレクションのためのものになっています。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、義経年来の愁眉を開き、一生の安穏を得るものと思い候。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
