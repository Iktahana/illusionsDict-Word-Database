    "definitions": [
      {
        "index": 1,
        "gloss": "silkworm (in the first or second instar)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからまた、やはり夜明けごろに窓外の池の汀で板片を叩くような音がする。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私どもの不注意からしばらく役目を欠かしましてお申し訳けございません。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手は囲いの出口をあけごく叮寧に云ったのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜あけごろ、遠くから小さなこどものあぶがくうんとうなってやって来て網につきあたった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜あけごろ、遠くから蚊がくうんとうなってやって来て網につきあたりました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもおさわがせいたしましてお申しわけございません。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は前後の見境ひもなくあんなことをいたしましてお申し訳けございません。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「本日もやはり晩の七時から二件だけございます。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つまらない賭けごとが、病氣のやうにからまつてきて、執拗に自分の心を苛らだたせた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、お待たせして申しわけごぜえませんだ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、申しわけござりません。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のかけごえのみ盛大の、里見、島崎などの姓名によりて代表せられる老作家たちの剣術先生的硬直を避けた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長吉面をあげい……」「へえ、へえ、申しわけございません」　と、一度あげた面をまた地に伏せてしまった。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも昨日は、突然にだまって帰ってしまって申わけございません」　と、その患者は云いわけを申しました。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けごろ死体を検視するために呼ばれて行った。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けごろ登志子が、不図眼を醒すと、驚いたことには未だ、カーテンの向方に窺へる兄の部屋には満々と明りが点いてゐて微かに人の声さへが洩れて来るのであつた。",
              "citation": {
                "source": "海路",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文句に「一めいわく仕るはにがにがしき御仕置にて、さんざんしほうけごんご道断なり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "其より古く俊頼口傳集上にもいけごめのみさゝぎとて藥師寺の西に幾許ものかくありと見ゆ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それを聞きながらこの小僧奴一錢だけごまかすな、と思つた。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申、申しわけござりませぬ……いかにもわたくし、下手人でござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞いだしたとなると、鉄火というか、伝法というか、雪までがたいそうもなく江戸前に気短なところがあって、豪儀といえば豪儀ですが、ちらりほらりと夜の引きあけごろから降りだしたと思ったあいだに、たちまち八百八町は二寸厚みの牡丹雪にぬりこめられて、見渡すかぎりただひと色の銀世界でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申しわけござりませぬ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "申、申しわけござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "呑みますぞ」「うんうん……」「少しはお気が晴れましたか」「うんうん……」「申しわけごわせんな。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わざわざお呼びたていたしまして、なんとも申しわけござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "「も、申しわけござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなはそのるす中に、あの、なんとかいいましたね、そうそう、お弓さんか、まだけさは姿を見せませんが、おっつけご入来になりましょうからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに拝まれりゃ、地もとの観音さまに申しわけござんせんや」　まことに淡々として名利に淡泊でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は憂さ晴しの酒を飲めるやうな健康ではなかつたので、生死の間をさ迷ふやうな心持で、凝つと腕組みをしたまま思案ともつかぬものに耽つてゐると、母親は急にこそこそと片づけごとをはじめたり、あちこちの箪笥に錠をおろして別の家に赴いたまま幾日でも帰らなかつた。",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
