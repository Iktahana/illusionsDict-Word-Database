  {
    "uuid": "824d9c6d-c47e-568e-bf97-6cedbd87ef8e",
    "entry": "軽症者",
    "reading": {
      "primary": "けいしょうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person (patient) with minor illness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寝床は妻の寝室と同じであるとしても、軽症者の静臥すべきベランダにあった。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者達も朽ち果てて行く自分の体を、毎日ぼんやり見て暮す苦しさから逃れたいためでもあらうが、作業には熱心で、軽症者は激しい労働をも続けてゐた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "附添もこの院内の作業の一つで、一日十銭が支給されて、軽症者の手で行はれてゐた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしたことに悲しんだり嘆いたりしてゐられるうちは、まだまだめでたい軽症者であること！",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々じつと鏡を眺めながら、「軽症者、甘たれやがつて！",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく病勢の進んだ人もゐたし、またどこにも病人らしい所の見えない軽症者もゐた。",
              "citation": {
                "source": "キリスト者の告白",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
