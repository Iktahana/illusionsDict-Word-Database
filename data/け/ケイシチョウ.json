    "definitions": [
      {
        "index": 1,
        "gloss": "chief superintendent (police)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ドュフランは官署へ出かけて行って警視長官チアベと向い合った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警視長官は笑いながら先手を打って唄うたいの反則事件の調書を見せようとした。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視長官は市会議員に対する儀礼としてちょっと熟考の形を取ったが肚は決っていた。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警視長官は面白くもない昔の唄を町の唄うたいが義務で唄う表情を想像して笑いたくなったが我慢して穏かに断った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんは、すぐに、むせんでんわでけいしちょうへしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをみると、こばやしくんは、むせんでんわで、けいしちょうのなかむらけいぶにしらせました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかむらけいぶは、すぐに、けいしちょうのヘリコプターを、げんばへとばしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　二十めんそうは、ヘリコプターでにげましたが、山の中でつかまって、とうきょうへつれもどされ、けいしちょうにいれられてしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、けいしちょうにいるのは、おれの手下だよ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "９　おまわりさんからしらせをうけて、けいしちょうのヘリコプターがとんできました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんいん六人と、それからけいしちょうの中村けいぶに話をして、けいじ六人をつれ、あくる日のひるごろ、石村さんの家にやって来ました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
