        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たゞ数ヶ月の後、石垣島の王のやしきの隅にその頃日本では、なかなか得ることの出来なかつた世界の地図が落ちてあるのを家来の一人が発見した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の日本人経営のクラブとかレストランでは先例によって女を雇入れることはめったにないことなのだが、私は天津の日本租界、敷島町の或るレストランに近頃日本の少女が青磁の衣服をつけてそれでなくとも感傷的になった旅人の私の心を瞑想的にするのに会ったことがある。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "落度があればそれッきり、まことに頃日の様子では、内々じゃ持扱って、私の落度を捜しているかも知れませんもの。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日聞く――當時、唯一の交通機關、江戸三度と稱へた加賀藩の飛脚の規定は、高岡、富山、泊、親不知、五智、高田、長野、碓氷峠を越えて、松井田、高崎、江戸の板橋まで下街道、百二十里半――丁數四千三十八を、早飛脚は滿五日、冬の短日に於てさへこれに加ふること僅に一日二時であつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後、多年中絶して居たのが、頃日區劃整理に及ばず、工事なしに復興した。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日読みさしのアナトール・フランスの小説の中にこんな話が出ていた。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃日本では他の或る国と戦争を始めていたが、それに動員された兵士であろう。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃日本では他の或る國と戰爭を始めてゐたが、それに動員された兵士であらう。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃日本の文壇では「日常性の哲学」といふことが言はれて居るが、元来文学者の生活には、常に「哲学する日常性」が必要なのである。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃日本では、南方へ南方へと、皆の関心がもっぱらその方面にばかり集中せられていたのであるが、私はその正反対の本州の北端に向って旅立った。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「勿論かさねまして、頃日に。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別に、一大事に関して早瀬は父様の許へ、頃日に参った事はないですかね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日の事ですが、今も云った、坂田礼之進氏が、両国行の電車で、百円ばかり攫徒に掏られたです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんはね、それにね、頃日は、家族主義の事に就いて、ちっと纏まった著述をするんだって、母屋に閉籠って、時々は、何よ、一日蔵の中に入りきりの事があってよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門際の流に臨むと、頃日の雨で、用水が水嵩増して溢るるばかり道へ波を打って、しかも濁らず、蒼く飜って竜の躍るがごとく、茂の下を流るるさえあるに、大空から賤機山の蔭がさすので、橋を渡る時、夫人は洋傘をすぼめた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日至る處の辻にこの聲を聞かざるなし。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の中の七日、珍しく朝凪ぎして、そのまま穏かに一日暮れて……空はどんよりと曇ったが、底に雨気を持ったのさえ、頃日の埃には、もの和かに視められる……じとじととした雲一面、星はなけれど宵月の、朧々の大路小路。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃日本橋筋二丁目の姉の家に寄宿していた私は、毎日この銭湯へ出掛けていたが、帰りにはいつも「花屋」へ立ち寄って、珈琲を飲んだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日高橋邦太郎さんに聞けば、文士芥川龍之介さんは香以の親戚だそうである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃日本人が歐羅巴に來る度に樣子を觀てをりました。",
              "citation": {
                "source": "混沌",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃日本に来られたオイゲン・キュウネマンさんはある宴会の席で私に言われた。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人様は今頃日本のどこかで、怨めしい憎い女と思召して、寝ても醒めても怨んでおいでなされましょうか。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又今から百年ばかり前に死んだ仮面劇の作者（名前は忘却）の墓石に刻み付けられた楽譜ようのものの正体が、どう研究しても分らなかったのが、この頃日本の能楽研究が盛んになるに連れて、その楽譜ようのものが打楽器の音譜である事が判明した……というような話も聞いている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日は拿破里に往きて、客に題をたまはりて、即座に歌作りて謳はんと志したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語全く忘れしを、近頃日本人と往復し、少しく話す樣に成れりと。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "同窓の朋友の間にも、その温雅なる風采と、秀麗なる容貌と、学識の豊富なるをもって聞えた、俊才で、且つ人魂と、流星と、意見の衝突以来、不快の念を抱いて、頃日夫人の許を辞して、谷中の寺に隠れたけれども、梓は子爵家の婿君である。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日僕の書く物の総ては、神聖なる評論壇が、「上手な落語のようだ」と云う紋切形の一言で褒めてくれることになっているが、若し今度も同じマンション・オノレエルを頂戴したら、それをそっくりお金にお祝儀に遣れば好いことになる。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近頃日本で起った自然派というものはそれとは違う。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄は金銀と異なり、わずかな分量では利得にならぬと聞いたが、頃日米国禁鉄となってから、一粒の鉄砂も麁末にならぬような話を承る、ふとした事から多大の国益が拡がった例多ければ、妓家の黒壁が邦家の慶事を啓かぬにも限らぬと存じ、本誌紙面を藉りてその筋の注意を惹き置く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
