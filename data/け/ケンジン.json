[
  {
    "uuid": "c2eb00d6-ce8c-5769-b0d6-df4e4dc312cf",
    "entry": "堅陣",
    "reading": {
      "primary": "けんじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
