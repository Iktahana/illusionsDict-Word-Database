        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこへコケットのダンサーが一人登場して若い方の靴磨きにいきなり甲高なコケトリーを浴びせかける。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケトーの真似ばかりするな」これが同君のモットーであった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃次第に露骨になりつつある都会のある階級の女のコケトリーについて、人から色々の話を聞かされていた私は、この無心の子供のこの非凡な註説を無意味には聞き逃す事が出来なかった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにコケトリなしだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トウサンハ　ダマツテ　ウケトリマシタ。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンケトの話ばっかしや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は、短い海老茶袴のやうなものゝ上に、男のものでもありさうな毛糸のジヤケトを着て、ぷか／＼と煙草を喫してゐる。",
              "citation": {
                "source": "お蝶の訪れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなものの言い方やこんな態度は、私がこのごろになって初めて発見した母に対する一種のコケトリイだった。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯んなものゝ云ひ方や斯んな態度は、私が此頃になつて初めて発見した母に対する一種のコケトリーだつた。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フケトリと鋏も、そこにおいてある。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍介はポケトから五十銭一枚をとりだして、テーブルの上へ置いた。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "食ひものはな、こゝに居たつて大して不自由はしねえんだ、三度々々食へるしな、ケトバシでも、たまにやアンコロでも食へるんだ、……女はさうはいかねえや。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "食いものはな、ここにいたって大して不自由はしねえんだ、三度三度食えるしな、ケトバシでも、たまにゃアンコロでも食えるんだ、……女はそうはいかねえや。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエトロはマリアに魅せられ、マリアもつよく彼にひきつけられて、この一八七六年の日記は、寸刻もじっとしていない若々しい激情の波瀾と、まじめさとコケトリイとの鮮やかな明暗が一頁ごとに動いている。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　来た初めに一番驚いたのは監房にクシとフケトリとが揃えてあったことです。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛人たちの感情経緯のなかでは、愛の純朴を愚弄するくらいあれやこれやのコケトリーを容認しながら、良人と妻との日ぐらしの姿では、清純な女の愛のこころから行われる行為の選択さえ女の自然な味とうけとられず、女の反抗という感じでうけとられたり、かたくなさとして否定の面にだけみたりするのは、どうしてだろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」義雄は無遠慮ながらポケトからパンを出して、それを少しづつ口に入れた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌までの切符を除いてはたツた十錢銀貨と二十錢銀貨とが二三枚自分のポケトに殘つてゐるばかりだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄はかの女がその鋭鋒を隱してゐる樣子を看破したので、わざと平氣で、勇とお鳥との間に坐わり込み、ポケトから卷煙草を一本探り出し、それに火をつけて、二三度うまさうに吹かす。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、氷峰の細君になるときまつたお鈴の弟が??義雄に一度遊廓をおごられた關係から??病人の見舞ひとして、ビスケトの鑵を贈つて來たのを持つて行つてやると、お鳥は他の患者等に對して見えがいいと喜んだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はかの女の財布の中と自分のポケトとをそらで數へて見て、大抵大丈夫だらうと決心し、かの女だけをその次ぎにつづく二等車へ乘せてやつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケトには、まことに僅かのはした金しかないその洋服すがたも、自分ながら見すぼらしかつたが、さびしい暗い町を歩くには多少安心であつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、氷峰の細君になるときまつたお鈴の弟が――義雄に一度遊廓をおごられた關係から――病人の見舞ひとして、ビスケトの鑵を贈つて來たのを持つて行つてやると、お鳥は他の患者等に對して見えがいいと喜んだ。",
              "citation": {
                "source": "――泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後坪内先生から「ゲンコーウケトッタツボウチ」として電報を下さった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
