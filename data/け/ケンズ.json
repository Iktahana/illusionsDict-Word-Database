        "examples": {
          "standard": [
            {
              "text": "設計ミスを防ぐため、ベテランのエンジニアが若手の図面を検図する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "検図の段階で致命的な欠陥が見つかり、設計をやり直すことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デジタル化によって、検図作業の効率が飛躍的に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）　ご存じのように、今まで、ずいぶんひどい目にあっていながら、私のぼうけんずきは、やっぱりやみませんでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "古歌にちなんで足曳と命名されたこの駿馬は、野に放したが最後、山鳥のように俊敏に、草を踏みしだき、林をくぐり、いや、鳥のごとく天空をも翔けんず尤物。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "730やがて勇將踏みとまり槍を揮ひていつ迄も、船に猛火を掛けんずるトロイア勢を防ぎとめ、ものすごき迄高らかの聲を放ちて叫びいふ、729　原語ヘプタポデーン。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかたがないから、あの三つの子どものくびがはいたつされるのをまって、そのさきを一けんずつまわってこわしてみたが、なんにも出てこなかった。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
