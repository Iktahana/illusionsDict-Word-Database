        "examples": {
          "standard": [
            {
              "text": "市役所から提示された再開発の計画案に対し、住民から多くの意見が寄せられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンペのために、デザインチームは3つの異なる計画案を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この計画案なら、コストを抑えつつ納期を早めることが可能です」と担当者が胸を張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この都市計画案が発表されてから、玄石は急に憂鬱になった。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇団の挺身活動に関し、それぞれの計画案を予め委員会に於て取纏めておくことは必要であり、それによつて、各劇団の使命が自ら明かとなる。",
              "citation": {
                "source": "空襲時に於ける興行非常対策について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ、それらの計画案に基き、更に綜合的計画を委員会に於て作製することも出来、各劇団の部署を定めることも出来る。",
              "citation": {
                "source": "空襲時に於ける興行非常対策について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その計画案は次のようなものだった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画案に出てくる小川秋明博士の主宰する右翼団体の者が投爆担当と決定したのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
