        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "カヤリの煙がユラユラと壁に映つて、十一時頃であり、そのうちまた出掛けさうな気配にもなつたりして、時は刻々に過ぎつゝあつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "目が覚めて、宿酔の厭ふべき頭の中で、戸の外の、寒い朝らしい気配を感じながら私はおまへのやさしさを思ひ、また毒づいた人を思ひ出す。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや湿って落ち付いた下層の落葉は朽ちた冷たい気配と共に彼の足踏みを適当に受け止めた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃この界隈に噂が立ちかけて来た、老妓の若い燕というそんな気配はもちろん、老妓は自分に対して現わさない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが十三回十四回頃からロスの身体の構えに何となく緩みが見え、そうして二人が腕と腕を搦み合っているときにどうもロスの方が相手に凭れかかっていたがるような気配が感ぜられたので、これは少しどうもロスの方が弱ったのではないかと思って見ていた。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋはその気配におどろいただろう。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼さがりからは冬の陽の衰えた薄日も射さず、雪こそは降り出さなかったが、その気配を見せている灰色の雲の下に、骨を削ったような榎や樫の木立は、寒い凩に物凄い叫びをあげていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大島のかさねを黒いコートでつつんで、リスの毛皮を左乳に垂らした、頬紅をささない蒼白な厚化粧の女が、いつも一点をみつめ前後の気配を感ずる都会の女の乗った車が、中央九番街のクロス・ワード模様の東洋銀行のまえで停止すると、彼女のフェルトの草履が石畳を踏んで衣服の黒い裾裏が地上を流れる風にはねかえった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、田口のなんか事ありげな気配で栗本は直ぐ不安にされた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つくらい次の部屋で、何か気配がして、開けたてに扉が軋る音が聞えてきた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生は、淋しい、大学に近い郊外の闇の中に、何か動く人の気配が感じられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は、出てくる気配がなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部に人の気配がする。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の縁の公会堂附近に人がだいぶ集っている気配がして唄のようなものがきこえてきた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がじいっと耳を澄ますと、納屋で蓆や空俵を置き換えている気配がした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "４８＝例のお類の室　人の気配にお類固くなる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "48＝例のお類の室　人の気配にお類固くなる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその人達はそれらしく動きまわる気配もなく依然として寝台のぐるりに凝立していた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかな気配ではあったが、しかし不思議にも秋風に吹かれてさわさわ揺れている草自身の感覚というようなものを感じるのであった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "影の中に生き物らしい気配があらわれて来た。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした、錯覚に似た彼らを眠るまえ枕の上から眺めていると、私の胸へはいつも廓寥とした深夜の気配が沁みて来た。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、月光による自分の影を視凝めているとそのなかに生物の気配があらわれて来る。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうです、それは「気配」の域を越えて「見えるもの」の領分へ入って来るのです。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩が現われ、頸が顕われ、微かな眩暈のごときものを覚えると共に、「気配」のなかからついに頭が見えはじめ、そしてある瞬間が過ぎて、Ｋ君の魂は月光の流れに逆らいながら、徐々に月の方へ登ってゆきます。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて実に抜け目なく観察していて、人にその気配が兆すと見るやたちまち逃げ足に移る。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸宅などの気配はなかった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉が種々と衣服を着こなしているのを見ながら、彼は信子がどんな心持で、またどんなふうで着付けをしているだろうなど、奥の間の気配に心をやったりした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "変な気持は、電燈を消し眼をつぶっている彼の眼の前へ、物が盛んに運動する気配を感じさせた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厖大なものの気配が見るうちに裏返って微塵ほどになる。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成るたけ順礼を遠くよけて、――最う人気配に後へ振向けた、銀杏返の影法師について、横障子を裏へ廻つた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
