  {
    "uuid": "25b13875-6a53-5e60-8652-6b1ab4ebcb67",
    "entry": "渓水",
    "reading": {
      "primary": "けいすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mountain stream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小舎の前の渓水に嗽ぐ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "老鶯に送迎せられ、渓水に耳奪はれ、やがて砧の音と欺かれて、とある一軒の後ろに出づれば、仙界の老田爺が棒打とか呼べることをなすにてありけり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛夏深山の渓水に、よく蝮が来て居る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "松山温泉より旭岳に登るには、人の踏み付けたる跡あるのみにて、道路なく、大部分は渓水の中を歩かざるべからず。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "渓水の落款10・１（夕）　亡くなつた高田実は、道頓堀の劇場へ出る時には、いつも日本橋｜北詰にある定宿へ泊つたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子が見つけた額には、気取つた筆で無意味な文字を二三字｜擲り書にして、渓水と落款があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子は抱月氏の顔を見て、「この額の渓水つて誰なの。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、渓水といふと……金子堅太郎かな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かあの人が渓水といつたやうに思ふ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二日卯発し駅をいづれば、渓水浅流の太田川にながれ入る所あり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山花（山あぢさゐ）を折り、渓水にて茶を煮（霜の花）、墨形落雁（古翁を祭る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥炭を含んだ渓水は、染粉を溶いたように古びた色になる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪橋の下からくぐり出す渓水を汲んで渇を癒し、吐息をつきながら鉄の鎖を握ってよじのぼった。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "後閑の対岸で、本流へ合するのは、谷川の渓水を集めて下りきたった赤谷川である。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを落ち鮎、鯖鮎、芋殻鮎などといって、奥山から渓水と共に流れきたった落葉と共に、簗へ落ち込むのである。",
              "citation": {
                "source": "季節の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "嶺の紅葉を波頭にのせて、奥山から流れる渓水と共に、里近い川へ出てくる秋の山女魚を木の葉山女魚というが、これは殊のほか骨がやわらかい。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、澄んだ渓水の中層を落葉に絡まりながら下流へ下流へと落ちていく魚がある。",
              "citation": {
                "source": "木の葉山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "春さき、川の水が温まってくると、中流に遊んでいた山女魚は上流へ上流へと遡り、夏には冷徹な渓水に棲みついてしまう。",
              "citation": {
                "source": "木の葉山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、肉充ち脂乗って、味覚に溶け込む風趣を持ってくるのは、初夏から、渓水の涼風肌を慰める土用頃である。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根川、白砂沢、また、花咲峠から渓水を運んでくる塗川にも渓流魚は豊富である。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両年前から飛越線が通じて旅行者が訪れるようになったが、八月から九月へかけては鮎の友釣りにばかり専念して、渓水に岩魚を追う人は極めてまれだ。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人の言葉に、渓水を飲む地方の人は心までも潔いとやら。",
              "citation": {
                "source": "伊香保土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処は熊ノ穴と称し、関門状をなした巨岩の間から、渓水が急瑞をなして奔出し、雷の如き響は耳を聾する許りで、壮観とされたものであるが、今は足下｜遥に渓声を聞くのみである。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨畑から小河内へ踰える日に、雨畑川の上流｜捻切沢で驟雨に襲われ、暫く木蔭に雨宿りをしていると、渓水が少しく増して急に水の中がざわつき出した。",
              "citation": {
                "source": "大井川奥山の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、死ぬと思われなかった貞丈まず逝き、次いで三語楼、渓水と後を追って、モリヨリヨンの同志、いまやわずかに生き残りいるは柳家金語楼と私とのみになってしまった。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども人の無意識的に、自家の便益なる方針に向って動くは、なお鹿が渓水に向って動くが如し。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲斐国志』には護王院山或は「午王院ノ嶺東ヨリ渓水出テ云々」など山名として用いられ、それが唐松尾連嶺に充てられていたもののようである。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "琴川　一名帯締川、濫觴ハ奥仙丈ノ中ヨリ発シ、中牧大窪二山ノ渓水相集リテ南流シ、杣口、千野ノ宮、窪平村東ヲ歴テ、室伏村ノ東南ニテ笛吹川ニ注グ。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西保川　奥仙丈ノ中ヨリ発源シテ、大沢川北原ノ上ニテ大沢川ヨリ発ス、此山ハ小楢峰ノ別称ナル可シ及ビ其他ノ渓水七八道相湊リ、南流シテ北原ヨリ牧平ニ出ヅ、上流ヲ漆川ト云。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スミ子ちゃんは、このごろ、なんだかノイローゼ（しんけいすいじゃく）みたいね。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
