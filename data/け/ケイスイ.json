        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の病原を洞察した宿禰は、蚯蚓と、酢漿草と、童女の経水とを混ぜ合せた液汁を長羅に飲ませるために苦心した。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "男親の手で育った娘が、段々成長し、始めて経水を見るその前後のことが、詩的な、さびた、ごく日本的筆致で書いてある。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "神国の風にて経水などある女、又は忌服ある者、皆此の村に行きて宿する故に人甚だ之を賤しむ、今も其村穢多に非ずして、人の殊の外嫌ひ賤む村あるは、皆此宿村・産所村の末也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スミ子ちゃんは、このごろ、なんだかノイローゼ（しんけいすいじゃく）みたいね。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
