    "definitions": [
      {
        "index": 1,
        "gloss": "complexion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "血色のいい頬、その頬が涙で洗われている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥えて居た方はことに衰へて、あのはち切れさうだつた血色のいゝ皮膚が、今はもうタブタブして居て、ガサガサした感じさへ与へて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かに戸があいて、赤い毛布でこさえたシャツを着た若い血色のいい男がはいって来ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日々に憔悴し、血色が悪くなり、皮膚が老衰に澱んでしまった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "）今日は大変に血色が悪いよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭の日などには舞台据えらるべき広辻あり、貧しき家の児ら血色なき顔を曝して戯れす、懐手して立てるもあり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩すると血色がよくなるぜ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かに戸があいて、赤い毛布でこさへたシャツを着た若い血色のいゝ男がはひって来ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに蒼ざめて血色｜悪しき顔の夜目には死人かと怪しまれるばかり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに蒼ざめて血色悪しき顔の夜目には死人かと怪しまれるばかり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚絆も足袋も、紺の色あせ、のみならず血色なき小指現われぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い黄色い光を部屋じゅうに送る大きな空気ラムプの下にいても、新井田氏は血色の悪い人だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田の血色が惡くなつて時々淋しい心になつた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三人の子供達――行夫、敏夫、登三――も生れ代つたやうな活溌な血色のいゝ子達になつてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟は互に顏を見合せて、互にひどく血色が惡いと思ひ合つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、ここは」　良人は浴室で一風呂浴びて来た血色のいい肌へ浴衣に丹前を重ねたものを不器用に着て縁に立ちました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が目立つて血色がよくなつて、段段晴晴した気分に向つてゆくのを見ると、男の愛する「生」の歓喜の前に自分の計画の全部を捧げてしまひたいと云ふ心が萌すのであつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が目立つて血色がよくなつて、段々晴々した氣分に向つてゆくのを見ると、男の愛する「生」の歡喜の前に自分の計畫の全部を捧げてしまひたいと云ふ心が萌すのであつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒鷲の爪から逃れ出た温め鳥のように、冬子は初めてほッと息を吐いたが、髪を振乱した彼女の顔には殆ど血色を見なかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ血色が不良いようだが……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでおど／＼している様では俺もおしまいだと思うと眼の前がカッと血色に燃えて、用って何もありません、唯歩いているだけです。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一｜血色の好いのと理合の濃なのとが、目に付いた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、腕の血色を見ても、濁が除れて、若い血が溌溂として躍ツてゐるかと思はれる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔にも手足にも、むくみが來て、血色も思切ツて悪くなツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "大手拓次といふ名の字面から浮ぶ聯想は、何かしらがツちりした、骨組の太い、血色の好い、四角張つた人間のやうに思はれる。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にリボンで飾つて押し樹てて歩く露西亜文学の旗も、スコットランド、ランカシヤ、ノーサムバア、ダルハム、中部及びウヱールズから来た血色の好い饑餓行進もそれが習慣であるといふ意味を通じて、英国人の頑心を漸次消解させ逐年長閑さを増すロンドン・メーデー風景となつたのだ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、どんなにかして血色をよくしたく思ひ、スポオツをはじめたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよほど前からこの血色を苦にしてゐたものであつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
