    "definitions": [
      {
        "index": 1,
        "gloss": "animal sacrifice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "令宗廟血食也」（『漢書』霍光傳）がそれである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり重要なのは家の存続であり、祖先をして永く血食せしむることである。",
              "citation": {
                "source": "家の話",
