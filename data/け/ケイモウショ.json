        "examples": {
          "standard": [
            {
              "text": "この啓蒙書は、プログラミング初心者にも分かりやすく解説されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けの啓蒙書は、科学への興味を引き出すのに役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は医学の啓蒙書を書き、一般の人々に健康知識を広めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "明治の初期の文学では、江戸末期の戯作者風な作者と黎明期の啓蒙書・翻訳文学が対立したが、尾崎紅葉の硯友社時代には、仏文学の影響やロシア文学の影響をもちながら、作家気質の伝統は戯作者気質の筋をひいていた。",
              "citation": {
                "source": "作家と教養の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ意味で古典こそ最上の啓蒙書なのである。",
              "citation": {
                "source": "哲學はやさしくできないか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本はそれまでも、コンピューターの啓蒙書を何冊か読んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
