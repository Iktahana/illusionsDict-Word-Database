[
  {
    "uuid": "4b8f2526-6c19-559e-ae54-729ef1748508",
    "entry": "県令",
    "reading": {
      "primary": "けんれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
