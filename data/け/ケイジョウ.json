[
  {
    "uuid": "0b54b534-e1a1-5f48-826d-a97b95c06c8f",
    "entry": "刑場",
    "reading": {
      "primary": "けいじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "place of execution",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここに来ると自分はどういうものかきっと、ドストエフスキーの「イディオット」の死刑場へ引かれる途上の光景を思い出すのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは勿論幾日かの後に主人のあとを追ったが、その後も刑場あたりでは夜ふけに犬の悲しい啼き声がきこえるとかいう噂が伝えられて、通行の人々を恐れさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅前の処刑場へ引っぱって行かれる土匪が、保安隊士に守られて、蠅のように群がる群衆や丸腰の兵士に俥上から口ぎたない罵声をあびせつつ通りかかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚徒は、刑場へ引いて行かれる途中で目につく店舗のあらゆる品物を欲するがまゝに要求した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、刑場らしい、かまえも、竹矢来も、何もなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふと、三台の洋車とすれちがいに、又、三台の洋車が、刑場を目がけて全力で突進して来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしは刑場からやつて来たのです、今日一人の罪人が刑に処せられました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩馬に乗せられ刑場へ曳かれて行く死刑囚が、それでも自分のおちぶれを見せまいと、いかにも気楽そうに馬上で低吟する小唄の謂いであって、ばかばかしい負け惜しみを嘲う言葉のようであるが、文学なんかも、そんなものじゃないのか。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと賑やかなことであるが、おや、刑場はすぐもうそこに見えている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、玄白たちが小塚原の刑場で罪人の屍を腑分する時の緊張などを、先生は特徴のあるゆっくりした語調で説いて聞かせたが、あの最初の講義は、自分の前途を暗示し激励してくれているようで、実に深い感銘を受けた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍で囲み、旗を立て、淡く清く装った得意の人を馬に乗せて市を練って、やがて刑場に送って殺した処で、――殺されるものは平凡に疾病で死するより愉快でしょう。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑場の鈴ヶ森は自然海に近かった。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイモンは容赦なく死刑場に引き出されました。",
              "citation": {
                "source": "デイモンとピシアス",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の夏、某城下へ二人の怪しい男が来て、不思議な術を行って見せたので、藩では早速それを捕え、死刑にすることにして刑場へ引出したが、切支丹ではどんな魔法があって逃げだすかも判らないと云うので、警護の士が厳しく前後を取り囲んでいた。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また刑場の四方には竹矢来を結って、すこしの隙もないようにしてあった。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑場の真中には磔の柱が二本鬼魅悪く立っていた。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて逃ぐる者は逃ぐるに任せつつ、死骸狼藉たる無人の刑場を見まはし、片隅に取り残されたる手桶｜柄杓を取り上げ、初花の磔刑柱の下に進み寄りて心静かに跪き礼拝しつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁女の事より人を殺め、長崎に到りて狼藉の限りをつくされしが、過ぐる晩春の頃ほひ、丸山初花楼の太夫、初花の刑場を荒らし、天地の間、身を置くに所無く、今日此処に迷ひ来られし人と覚し。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、裃紋附の上に荒縄をかけられ、刑場へ引かれたが、この時、松陰は同囚等への告別のつもりで、自筆の「留魂録」の冒頭の歌、身はたとひ武蔵の野辺に朽ちぬとも　　　留め置かまし大和魂　と、次の辞世の詩、「吾今為国死。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾は執えられて刑場へ往ったが、胸の中には無実の罪で殺されるという怒りが一ぱいになっていた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾は刑場に往くのをこばんで無実であることを言いはったが、心では九幽十八獄にもこんな無道理なことはないと思うて、悲しみと怒りで泣き叫ぼうとしたところで、仲間の呼ぶ声が聞えてきた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫と天井から一幅落ちたが、四辺が暗くて、その何にも分らぬ……両方の棚に、ひしひしと並べた明｜晃々たる器械のありとも見えず、寂となって隠れた処は、雪に埋もれた関らしく、霜夜の刑場とも思われる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑場に引き出されても、平気でいました。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は、ゆらゆら地平線に没し、まさに最後の一片の残光も、消えようとした時、メロスは疾風の如く刑場に突入した。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大声で刑場の群衆にむかって叫んだつもりであったが、喉がつぶれて嗄れた声が幽かに出たばかり、群衆は、ひとりとして彼の到着に気がつかない。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　セリヌンティウスは、すべてを察した様子で首肯き、刑場一ぱいに鳴り響くほど音高くメロスの右頬を殴った。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の若い馬賊の手下がそつと街に忍びこんだ、丁度街端づれの広つぱにある刑場の獄門の下をなにごころなく通ると。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の人々は獄門の酔つぱらつた首が毎夜のように合唱を始めて寝つかれないので、なんとかして貰はなければ困ると刑場の兵士に苦情を持ちこんだ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
