    },
    "definitions": [
      {
        "index": 1,
        "gloss": "constitutional government",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "政友会とか、憲政会とか云えば彼等には分る。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは政友会が内閣をとるか憲政会が内閣をとるかよりははるかに重大な問題である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子の行く座敷も、とかく選挙関係の人が多く、それも土地に根を張っていた政友会系の人が七分を占め、あと三分が憲政会という色分けで、出て間もない銀子はある時これも政友系の代議士｜八代と、土地の富豪倉持との座敷へ呼ばれたのが因縁で、倉持のものとなってしまったのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "族制々度の国には族制々度の理想あり、立憲政躰の国には立憲政躰の理想あり、若し支那の如き族制に起りたる国に自由の精気を需め、英米の如き立憲国に忠孝の精気を求めなば、人は唯だ其愚を笑はんのみ。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治は立憲政體になつてゐる。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立憲政體が立つた時、西洋の制度を參考にせられた。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂内閣の憲政擁護運動のために、北海道の山奥から引っぱり出された奈良原到翁は、上京すると直ぐに旧友頭山満翁を当時の寓居の霊南坂に訪れた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち三十二歳の時、山ノ内｜憲政から頼まれて、関東管領職を譲られ、上杉氏と称したのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄四年川中島合戦には、謙信は上杉憲政から、一字を貰って、政虎と云っていたのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年の立憲政治も、この安定した国情の上に築かれたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "立憲政治　明治時代に創始された立憲政治の起源は、維新当初の五箇条の御誓文である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、五箇条の御誓文に依り、憲法を制定し、立憲政治を行ふといふことは、明治天皇の叡慮であつたと拝察してよい。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いふ意見が、よほど御思召に叶つたやうであり、同年末には、立憲政治に就いて、山県有朋、黒田清隆、山田｜顕義、伊藤博文、大隈重信などの各参議に対して、意見の提出をお求めになつて居られる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、憲法制定、立憲政体の実施については、政府に於ても、明治天皇の大御心に依つてその大方針が確立してゐたのであるから、当時に於ける自由民権運動の騒ぎは、藩閥政府の強権に対して、不平分子が国会開設の名を利しての抗争とも見るべきであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、民意に基づく国民戦争を行ふについて、立憲政治がいかに有力であるかを示したのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "林述斎曰く、桜の前の彼岸桜、牡丹の後の芍薬、カキツバタの後の花菖蒲、撫子の前の石竹、菊の後の寒菊、何れも品格は劣れども、又すて難くやとは、憲政会連が若槻首相を評する様に聞える。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは政治に於て、専制政体が立憲政体に変更されたのとよく似ている。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、演壇または青天井の下で山犬のように吠立って憲政擁護を叫ぶ熱弁、若くは建板に水を流すようにあるいは油紙に火を点けたようにペラペラ喋べり立てる達弁ではなかったが、丁度甲州流の戦法のように隙間なく槍の穂尖を揃えてジリジリと平押しに押寄せるというような論鋒は頗る目鮮ましかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の大官貴紳は今の政友会や憲政会の大臣よりも遥に芸術的理解に富んでいた。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令普選になっても、美徳がある限り天下はいつまでも太平であろうとは誰でも感じていることで、この美徳を打破って憲政有終の美を満たすには、唯一つ「選挙民の自覚」あるのみというも亦十人が十人自覚している。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡會や縣會に出て、地方政治に關係した時には、わしは政友會にも憲政會にも所屬してはゐなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "政友会か、憲政会か、それとも国民党かな。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "信常氏はその時憲政会のある代議士と一緒だつたが、二人は照子のお世辞に好い気になつて、一ぱし画家や詩人の積りで画を描いたり賛をしたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅氏は憲政会の所属代議士であると共に、郷里では田地持だといふので郡農会の会長をも勤めてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雀鮨の進物６・24（夕）　犬養木堂は、憲政擁護の神様だつた頃は、人が頼むと、おいそれと気持よく絖なり、画箋紙なりへ達者な書をかいて呉れたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "首実検６・27東京日日（夕）　師範学校の二部生の試験答案に、坪内逍遙とは、坪のなかをぶら／＼歩くこと、樋口一葉とは、憲政会でちやきちやきの代議士だといふのがあつたといつて、大分世間の笑ひ草になつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家一門の栄耀栄華の陰には、敗戦の不運に泣く源氏の将兵があり、又、天皇と上皇は、互にけんせいし合いながら、政権をねらうという、不穏な空気が時代を支配していた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
