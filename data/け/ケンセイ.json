[
  {
    "uuid": "0f25371a-73cf-5a94-8f7b-0c3dccbcb8ff",
    "entry": "憲政",
    "reading": {
      "primary": "けんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
