        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "室の照明は私設ガスタンクのガスによって、倹約と保守的な気分と面倒がりとのために電燈設備をしないでしまった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地方の倹約な商家では平日雇人のみならず主人達も粗食をしていて、時々「贅沢デー」を設けて御馳走を食ったという話もある。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあにこの書物ぁ倹約教へだのだべも。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御維新の大変動で家が追々微禄する、倹約せねばならぬというので、私が三歳の時｜中徒士町に移ったそうだが、其時に前の大きな家へ帰りたい帰りたいというて泣いていて困ったから、母が止むを得ず連れて戻ったそうです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとも知らずわずかの車賃を倹約するつもりで我慢して歩いて行った。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあにこの書物ぁ倹約教えだのだべも。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこの節は御倹約ということに決定たのですから」「何の御倹約だろう」「炭です」「炭はなるほど高価なったに違ないが宅で急にそれを節約するほどのことはなかろう」　真蔵は衣食台所元のことなど一切関係しないから何も知らないのである。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから十二、一、二と先ず三月が炭の要る盛ですから倹約出来るだけ仕ないと大変ですよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳が朝から晩まで炭が要る炭が高価いて泣言ばかり言うのも無理はありませんわ」「だって炭を倹約して風邪でも引ちゃ何もなりや仕ない」「まさかそんなことは有りませんわ」「しかし今日は好い案排に暖かいね。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本へ来ているのは金をこしらえるためだから、なんでも出来るだけ倹約するのですと彼自身人に話したそうである。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、ある国に非常に倹約な殿様がありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの方は倹約致せ」といいつけました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、文句の倹約は、殿様｜直々のお触出しですから、今さら、もとへと願い出も出来ません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめは倹約えんやらえ」と。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "来客の空腹なると否とは此方の関する処にあらず、夫れより一飯にても倹約して貯金を為すべき也。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僅か拾銭を倹約した為に」と思ふと、急に忌忌しくもなつてくる。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭のまき水を倹約する日もあった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら諸式高値でも、こゝの店は随分倹約だぞ。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小月は競馬で人出が多い、三時の汽車に乗る、嘉川着四時二十分（小郡下車だと六銭多くかゝる、私の倹約も必要からだが、ホンモノである）。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは電車賃さえ倹約の身の上だが、急いで用も無い身体である。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保年間の諸事御倹約の御触に就いて、その一人物が大いに、こぼしているところなのであります。",
              "citation": {
                "source": "三月三十日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "質素倹約、清廉潔白の官吏である。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国のために質素倹約を率先｜躬行していたわけなのである。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常日頃の倹約も、あのような慈善に備えて、――」「いい加減を言ってるわ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "定まって晩酌を取るというのでもなく、もとより謹直倹約の主人であり、自分も夫に酒を飲まれるようなことは嫌いなのではあるが、それでも少し飲むと賑やかに機嫌好くなって、罪も無く興じる主人である。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……菜大根、茄子などは料理に醤油が費え、だという倹約で、葱、韮、大蒜、辣薤と申す五｜薀の類を、空地中に、植え込んで、塩で弁ずるのでございまして。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれるというひとがあったら、それは、もらってもいいけれど、酒と煙草とおいしい副食物以外には、極端に倹約｜吝嗇の私にとって、受信機購入など、とんでも無い大乱費だったのである。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倹約しなければいけない、と生れてはじめてそう思った。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿までの電車賃をけんやくして、鳴子坂の三好野で焼団子を五｜串買ってたべる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電気けんやくして居るなあ、はばかりと同じね」一寸つける。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
