        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "思えば思うほどひとり壁立｜万仭の高さに挺身して行こうとする娘の健気な姿が空中でまぼろしと浮び、娘の足掻く裳からはうら哀しい雫が翁の胸に滴って翁を苦しめた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "健気なむす子よと言い送り度い。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵が健気に言ってのけた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだ全体で拍子をとるようにして小枝をゆさぶりながらせっせと働いているところは見るも勇ましい健気なものであった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう老婆を見ると、いかにも弱々しく見える一方では、また永い間世の中のあらゆる辛苦に錬え上げられて、自分などがとても脚下にもよりつかれないほど強い健気なところがあるように思われて来る。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験地獄に直面して、そこに自分の小さいながらも人生の血路を切り開いて行った健気な態度、自分の繊弱い性質をどうにかして支持して行った苦心、そこに立派に少年の一つの理想が握られていました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、夫は、妻のこの健気な姿に幾度むせび泣いたことでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其勇気は健気とも云うべきであったが、此種の冒険は気の強いばかりでは押通せるものでない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十八歳の娘さんのいじらしいばかりに健気な気持については、註釈めいたものは要らぬだろう。",
              "citation": {
                "source": "十八歳の花嫁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "健気なむす子よ、とかの女は心で繰り返した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸作は、むす子の仕方を想像して、健気な奴と云った表情で笑っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、歳子の観察によると、彼は趣味の高さから来る近代文化に対する自虐的な反抗と、複雑濃厚なあらゆるものに飽き果てゝ素朴なものゝ愛に引き返した一種洗練された健気にも寂しい個性が感じられた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まきには落着いた母性的の分別が備はつて、姿形さへ優しく整ふし、ひろ子にはまた、しほらしく健気な娘の性根が現はれて来た。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそは桂子自身の生命が、更に桂子の生命を支へ上げんとする健気な力、そして永遠に新しき息吹である。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分獄吏の中の誰かが、健気な少年連の態度に心を動かして同情していたのであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康之を聞き「団右衛門は健気なるものなり、首は見苦しくとも実検せん」とて、法通り実検した。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新子は、口が利けなくなっていたが、それでもまだ健気に、涙だけは抑えていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の一行に書き記した「この健気なる老人を賛美してやって下さい」との言葉には、一首一首を確かめながら清書の作業をやり終えた祖母の感慨が、よく現れているように思いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の母が暴力では及ばないのを悟って、すかしつなだめつ、良人までを道具につかったり、木部の尊信する牧師を方便にしたりして、あらん限りの知力をしぼった懐柔策も、なんのかいもなく、冷静な思慮深い作戦計画を根気よく続ければ続けるほど、葉子は木部を後ろにかばいながら、健気にもか弱い女の手一つで戦った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ見ろ、猫や犬の方がまだ健気な処がある。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした乾児達の健気な働きと、自分に対する心持とを見た忠次は、その中の二三人を引き止めて他の多くに暇をやることが、どうしても気がすすまなかった。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御支度さッしゃい」　健気な菊路の旅姿を先にして、主水之介、京弥、老神主三人がこれを守りながら、目ざす大和田十郎次の屋敷へ行き向ったのが丁度暮れ六ツ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが菊路は、涙ぐましい位にも今｜健気でした。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いて／＼、すつかり泣き切つたあとの洗はれたやうな胸を大切さうに抱へて、私はいつまでも／＼泣いじやくりをして居るなんといふその時の私は、柔順なそして健気な心を持つた女であるのだらう！",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻も姉も、彼女の無邪気な、鳩のような態度と、澄んだ、清らかな茶色の瞳と、路傍にタタキ付けられて救いを求めている小鳥のような彼女のイジラシイ態度……バスケット一つを提げて職を求めつつ街を彷徨する彼女の健気な、痛々しい運命に、衷心から吸い付けられてしまっていた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりほかに申しわけのしようがないと我が娘ながら健気に申しておりました。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いた話であるが或種の不良の徒はあゝいふ盛り場などに出入して、働く乙女の健気な様に魅せられ、様々な甘言を以て誘惑しようとする者があるさうだね。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去における一切の思想と感情とに、ある根本的の動搖があり、新しき生活の革命に入らうとする、けなげにも悲壯な心境が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして我が室生犀星は、けなげにも發奮して立ち、新生活への勇ましき門出をしてゐる。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　特務曹長は、なさけなげな声を出して、アカシヤのかげにかくれるように伏せをした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
