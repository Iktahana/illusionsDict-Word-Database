[
  {
    "uuid": "ac13fe50-a23d-5556-97ef-9d02ce01570e",
    "entry": "検印",
    "reading": {
      "primary": "けんいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seal of approval",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "装幀の事は今迄専門家にばかり依頼してゐたのだが、今度はふとした動機から自分で遣つて見る気になつて、箱、表紙、見返し、扉及び奥附の模様及び題字、朱印、検印ともに、悉く自分で考案して自分で描いた。",
              "citation": {
                "source": "『心』自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "健吉からは時々検印の押さった封緘葉書が来た。",
              "citation": {
                "source": "争われない事実",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇の皮をまいたステッキや、蟇の皮で作った銭入れや、狼の歯で作った検印などを持って喜んでいます」　俊夫君の顔はにわかにうれしそうに輝きました。",
              "citation": {
                "source": "髭の謎",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "済んだのは、検印をして、給仕に持たせて、それぞれ廻す先へ廻す。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員はその男の切符に検印を済ますと更に群衆の顔を見た。",
              "citation": {
                "source": "頭ならびに腹",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表紙には「屍体台帳……九大医学部」と大字で楷書してありまして、その表紙を開くと、各｜頁ごとに「屍体番号」「受取年月日」「引取人住所氏名」「引渡年月日」なぞいうものが、一面に行列を立てて書込んである上と下に、一々若林という検印が捺してあります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙のないその二冊には、ただピーボディ博物館という、検印が押してあるのみなので、軽率にも私は、取るに足らぬ目録のたぐいかと誤信して、そのまま書き屑のなかへ突っ込んでしまったらしいのである。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一つの芽生』、五百部検印。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波から、Ａの『ペルシャ文学史考』の検印千五百枚持って来る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三週間で街へでるよ」「そうはいかないだろう」「なぜさ」「住田嘉久馬が雲がくれじゃ検印がもらえないだろ」「さすがに知ってやがんな、新聞社は。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど検印がもらえないという心配もあるわけだね」「大ありナゴヤだよ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても検印はとれねえぜ」「チェッ！",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の役人は検印もそこそこに退却してしまった。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの家では人を頼んで検印を押すだけに十日もかかった。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後春陽堂の人来りて全集第二巻再版の検印を請ふ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "春陽堂の人来り全集第二巻五版の検印を求む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雑誌『少年』に就ては、表紙のペン画が好きでしたが、其の作者の北沢楽天さんが之は又選者で、ウラメシや、毎度学校の先生の年の検印をもらっては大いに苦心して、はめ絵や判じ絵を出しました。",
              "citation": {
                "source": "少年の食物",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "小判は吹き立てと言ってもいいほど真新しい真物ですが、その表には、あるべきはずの検印が捺してなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分」「八、大急ぎで奉行所へ飛んで行って、書き役から、近頃検印のない御用金か何か盗まれた事がなかったか、訊いて来てくれ」「ヘエ」　八五郎は、そう囁かれると猟犬のように飛んで行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「検印のない小判を奪られた事が、奉行所の記録にもないというのかい」「十年この方ありませんよ」「はてね？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "引出した手には、山吹色の小判が二三十枚、そのいずれも、検印のない品ばかりではありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浜町の石置場から見せ金の積りで五十両持って来たが、死骸と一緒に置くわけには行かないし、検印がないから急には捨てる場所も思い付かない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "［自注４］本の印――顕治の手紙にあるあて名の百合子という字をそのまま木版にして検印用の印をつくった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『明日への精神』検印しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "検印の判のことちっともおっしゃらないことね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑摩書房より「来訪者」再版検印紙送り来る。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると翌朝、その高瀬という人から裁判所の検印のある手紙が届いた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに価値のあるものはないですよ、価値のあるものは裁断されず、検印が投稿原稿に押されます。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜陽の検印（二万）を持って修治さんと御一緒に東京へ出掛ける。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついてはそれがし、いずこまでも夫婦いっしょにとおもいきわめていたけれども、しかしつく／″＼かんがえてみるのに、そなたはそうけんいんさまの妹御であらせられるし、そのうえこゝにいるひめたちは故備前守のわすれがたみのことでもあるから、やはりこれは助ける方が道だとおもう。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
