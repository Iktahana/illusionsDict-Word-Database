    },
    "definitions": [
      {
        "index": 1,
        "gloss": "party to a contract",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "保険の契約者は、定期的に保障内容を確認すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンの契約者名義を変更するため、店舗に出向いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "賃貸物件の契約者には、いくつかの義務が課せられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "スワデシの契約者が三億人出來るといふやうな幸運を吾々は期待し得ない。",
              "citation": {
                "source": "スワデシの誓",
                "author": "エム・ケー・ガンヂー",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年のうちに一人でも契約者が出来るなんて、考へてもゐなかつたでせう。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "草々　栃木町室町、高瀬仁之助」　こうして犠牲者を出したものの、被害民たちの結束した行動は、脛に傷もつ地方議員や、なお迷いの覚めない示談契約者たちを畏怖させるに十分であった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダに立って契約者のスペンサに言った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
