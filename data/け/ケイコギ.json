    "definitions": [
      {
        "index": 1,
        "gloss": "training clothes (judo, kendo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
