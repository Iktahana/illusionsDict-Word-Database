        "examples": {
          "standard": [
            {
              "text": "救急外来に配属されたばかりの研修医が、指導医の指示を仰ぎながら懸命に処置を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寝る間も惜しんでカルテを読み込む研修医の姿に、看護師たちも信頼を寄せ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "研修医としての日々は過酷だが、患者さんからの「ありがとう」という言葉が何よりの励みになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "狂人の幻想を強化したと父親および医師が精神科研修医に咎められないようにである。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
