        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、端から端まで、――女達のいるところから、ケージのおりて来るところまで、――枕木を踏んばり通さなきゃならなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑外へ出るだけでも、八百尺をケージで昇り、――それは三越の六倍半だ――それから一町の広い横坑を歩かねばならない。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら少ないとてケージは、やっぱし一ツ分占領するんだぞ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市三は、ケージから四五間も手前で鉱車を止めた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　阿見がケージをたゞ一人で占領して上へあがると、びっこの爺さんが笑い出した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は、井村がケージの脇の梯子を伝って這い上った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分遠くケージから離れて来たもんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから竪坑にまでかついで行かれ、一ツ／＼ケージで、上に運びあげられた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三本脚の松ツァンは、ケージをおりて、坑内へ這入って来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫はケージに乗って昇降するたびに、ヒヤ／＼せずにいられなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "置き場に困る程無茶苦茶に杉の支柱はケージでさげられてきた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母や、母は、まだ、ケージを取りつけなかった頃、重い、鉱石を背負って、三百尺も四百尺も下から、丸太に段を刻みつけた梯子を這い上っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ちゃんと、ケージのロープまで、もとの継いだやつにつけ直しちゃったんだよ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて読んでみようか」とパッケージを開き、私は中から取り出したフロッピーディスクを小さなコンピューターに差し込みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれのパッケージには、エキスパンドブックを刊行する経緯をありのままに、かつ印象的な言葉で綴った、しおりが入っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッケージもいくらかにつくでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらんとした事務所で、パッケージに一枚一枚ディスクをつめていると、萩野さんがひょっこり顔を覗かせます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ作り手から、十〜二十部程度のパッケージを預かり、十頁分を立ち読み用に仕立てておきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文してくれた人には、サイバーブックセンターからパッケージを送付。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈買う〉という行為が、〈物を所有する〉ということと深く結び付いてきた点を考慮しても、第一歩としてはパッケージを送るのが妥当だろうと判断しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブックのデザインやグラフィックスの処理、パッケージの仕立てとどこを取ってみても、Dairiqui の作品は、清潔な美意識に支えられた上品な手仕事で貫かれています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "使い古しの段ボールや、プリントアウトした書類の裏側を使ったセンスの良いパッケージを手に取ると、ブックを開く前にもう、微笑みが浮かんできます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば手作りの受注開発がもっぱらだったメインフレーム用のソフトもパッケージ化されるはずだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九七二年、メインフレーム用パッケージ・ソフトの販売と保守、教育にあたるアシストを設立。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューター用パッケージ・ソフトの販売とサポートで独立系ソフトハウスの最大手の地位を築いてきたアシストが、パーソナルコンピューター用に九千七百円の優しい文房具シリーズをぶつけるに至った経緯にはすでに触れた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしアシストはそもそも受託開発のみの日本市場に対してアプリケーション・パッケージの役割を正面に掲げることで切り込んできた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マッキントッシュ先生、僕はあなたのことが大好きです」とパッケージのくるみに印刷しちまったようなものではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかったマックとＷｉｎｄｏｗｓ　ＮＴは、パッケージ・アプリケーションを部品化してパーソナルコンピューター文化を大型に拡張する形で。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中から小頭達の眼が光り、炭車もケージも、ポンプも扇風器も、一層不気味に静まり返って動きつづけていった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイ、確かに、十時二十分頃から十時半までの間に、ケージから坑外へ出て行きました」「なに、十時半より前に出て行った？",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
