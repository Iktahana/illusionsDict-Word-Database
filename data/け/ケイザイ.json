[
  {
    "uuid": "7f7549ce-2e02-5713-a787-c9463946a7aa",
    "entry": "経済",
    "reading": {
      "primary": "けいざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
