[
  {
    "uuid": "1f47e1b0-44a8-58bb-8ae4-2466920c09bd",
    "entry": "検非違使庁",
    "reading": {
      "primary": "けびいしちょう",
      "alternatives": [
        "けんびいしちょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
