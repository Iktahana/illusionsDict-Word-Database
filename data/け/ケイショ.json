    "definitions": [
      {
        "index": 1,
        "gloss": "classic Confucian writings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
