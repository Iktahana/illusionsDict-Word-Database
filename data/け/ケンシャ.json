        "gloss": "prefectural shrine (of prefectures other than Kyoto and Osaka)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
