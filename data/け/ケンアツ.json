        "examples": {
          "standard": [
            {
              "text": "配管の破裂を防ぐため、作業員は慎重に検圧を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エンジンを始動させる前に、燃料系統の検圧を行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "検圧の結果、想定以上の負荷がかかっていることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "艇がしばらく進むうちに、潜航の電鈴が鳴り、検圧計に赤い電灯が点いた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その一帯には、砕けた検圧計の水銀が一面に飛散っていて、それを見ると、最初一撃を喰らうと同時に、検圧計を掴んだのが、ほとんど反射的だったらしい。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、握ったままくるりと一廻転して、引きちぎった検圧計もろとも、背後に倒れたのではないかと推断された。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その附近には、砕けた検圧計の水銀が飛び散っていた……」「水銀……」　検事が思わず反問すると、法水は、その魔法のような兇器を明らかにした。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
