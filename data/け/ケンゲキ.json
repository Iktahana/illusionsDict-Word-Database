    "definitions": [
      {
        "index": 1,
        "gloss": "sword play",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「花柳街のセット」「宿屋の帳場」「河原の剣劇」「御寺の前の追駆け」「茶屋の二階の障子の影法師」それから……。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「いで――　三味や太鼓も賑やかに」　「振り面白く踊り出だす……」Ｔ「当世流行　剣劇踊りの　始まり　はじまり」　チョン、チョン、とやったものだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰朝後ただ一度｜浅草で剣劇映画を見た。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って見ていてたまらなく不快な破綻を感じる程度が剣劇に比して少ないように思う。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じ意味においてまたわが国の剣劇の大立ち回りが大衆の喝采を博するのであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "這個髯斑に眼円にして面赤き辺塞の驍将に対して、爾き言を出さむには、当時流行の剣劇の朱鞘で不可、講談ものゝ鉄扇でも不可い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう映画の剣劇的立ち回りではいつでも実に不思議な一種特別の剣舞の型を見せられるような気がする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の親分か、ジゴマのエキストラみたいなスゴイ処がある。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上記の点で著しく対蹠的のコントラストを形成するものは、日本の剣劇映画における立ち回りの場面である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な剣劇の立ち回りがそれであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の股旅ものや、幕末ものでも、全部がまだ在来の歌舞伎芝居の因習の繩にしばられたままである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新派には新派の型があり、義太夫には義太夫の型、女剣劇や映画俳優の実演にも型があり、浪花節なども近頃は浪花節専門の声色屋が出来ている。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤勇　新撰組隊長、近藤勇と云へば、剣劇、大衆小説に幾百回となく描き尽され、幕末物のヒーローであるが、その実質としては、暴力団の団長以上には評価されない。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いずれ剣劇や活動写真が好きだろう。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中里、白井、大仏氏らが筆をたったあとの大衆文学壇は、今日の状態では、沢田正二郎没後の剣劇と同一の試練にたえなければならぬであろう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京へかえったら二三の知人が、　――どうですね、日本のプロ文士の剣劇レビューは？",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エロ・グロ、剣劇の興行政策をこれまで日本で最もいい制作をしていた東宝にもちこんで、近代的な社会感覚をもっている従業員たちを追いはらっている渡辺銕蔵が、教員の資格審査委員の一人であるという事実は、見のがされてはならない。",
              "citation": {
                "source": "三年たった今日",
                "author": "――日本の文化のまもり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後東宝経営者は、興業資本の利潤追及の方向を強化して、保守的な文化性の低いスター中心に作った第二組合に、安価なエロ・グロ・剣劇映画を作らせ（渡辺銕蔵社長の宣言）第一組合を無活動におとしいれ数百名のくびきりを行った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百六十四名、主に少女工（十五歳未満）剣劇ファン○職工と女工と別の出入口をもっているところもある。",
              "citation": {
                "source": "工場労働者の生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも其の宵に、地方を廻って来た或る劇団の剣劇を見たのだそうだ。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "写し出される映画は殆ど皆剣劇だった。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が映画館で剣劇を見た事を立証する為に彼は二枚のプロを大切に持って帰って来た。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して彼等がたしかに其の夜映画館に居たことを出来るだけはっきり証拠立てる為に彼は数本の剣劇映画の場面とストーリーを十分におぼえて来た。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十津川の関所にと掛ると、番兵二人（小波、露紫）が出て、問答の末に大立廻りに成るので有つたが、これが今の剣劇の元祖で、非常に激烈な切合ひで有つた。",
              "citation": {
                "source": "硯友社と文士劇",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "当今芝居でも剣劇というのが何よりも流行するというのももっともなことだと思う。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人も子供も、夏は暑いから、せめては新世界へでも出かけて、剣劇の刃の先きからでも冷気を吸うより外に素晴らしいこともなさそうである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の流行も無理のない勢いだろう。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白い手袋の運動を剣劇の興味を以て、丁稚小僧の大勢がぼんやりと自転車を抱えながら眺めている。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の俳優、レビューガール、どんな大部屋の大根役者でも大井広介にきけばたちどころに名前が分る。",
              "citation": {
                "source": "大井広介といふ男",
                "author": "――並びに註文ひとつの事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の興行街には久しく剣劇といいチャンバラといわれた闘争の劇の流行していたことは人の記憶している所である。",
              "citation": {
                "source": "裸体談義",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
