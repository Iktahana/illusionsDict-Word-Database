[
  {
    "uuid": "264fcb58-6213-539d-879b-a7cd8ce1cd47",
    "entry": "警備",
    "reading": {
      "primary": "けいび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
