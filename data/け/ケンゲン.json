  {
    "uuid": "d1e1380f-2ffb-526f-9e52-316aafd93c92",
    "entry": "乾元",
    "reading": {
      "primary": "けんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kengen era (1302.11.21-1303.8.5)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "元亨利貞を四徳と解すべきや否やは既に歐陽修も疑問を挾んだのであつて、象傳では元の字は上に附いて乾元・坤元といふ語に組立てられてゐるのに、文言では四徳と解してゐるのは如何したものかと恠しんでゐる。",
              "citation": {
                "source": "易疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "年代順に列記すれば、建保七年、弘安二年、正安四年（乾元元年）、元亨元年、元徳二年、文明五年、慶長五年の諸鈔本である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾元二年に大赦があった。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
