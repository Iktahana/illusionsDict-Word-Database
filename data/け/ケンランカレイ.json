        "examples": {
          "standard": [
            {
              "text": "その寺院は、絢爛華麗な装飾が施された門で有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演劇の舞台装置は、絢爛華麗で観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女がまとっていたウェディングドレスは、まさに絢爛華麗だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いや、あの鼈甲牡丹のように、絢爛華麗な文章丈を取っても、優に明治文学の代表者として、推す価値が十分だと思うのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、あの鼈甲牡丹のやうに、絢爛華麗な文章｜丈を取つても、優に明治文学の代表者として、推す価値が十分だと思ふのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば此のレヴュウ団は、ドラマとしてよりもスペクタクルとしての絢爛華麗な効果を狙った見世物を上演する団体であって、美男俳優やギャッグ専門の喜劇役者を始めそれぞれ一流の歌姫や踊児などを多数専属せしめ、絶対に女形を必要とする様なレベルトアールは組まないからで有ります。",
              "citation": {
                "source": "陳情書",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
