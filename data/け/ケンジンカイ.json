        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "××大学政経科二年生　　Ｙ――県人会幹事　　　　　小　　鐘　　　　登　　　　　　　東京市　　区　　町　　　　　　　　　番地　　　方　　　　　　　　　電話　　　　　番　つまり上掲の如き名刺でその時のは鉛筆で処番地が書き込まれて、電話の個所は空のまゝであつた。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来愛郷心なるものは、県人会の世話にもならず、旧藩主の厄介にもならない限り、云はば無用の長物である。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいでしょう」とか、紹介しておいて、自分は歓迎に来ている県人会の人達のほうへ行ってしまいました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "県人会でお逢いした翌日、ぼくは横浜へ着いた日に撮ったあなたの写真を、すぐあなたの寄宿舎のほうへ送っておきました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にも近頃よくある奴だが、わたくしは同国ですとか、あれは他府県の者だとか、やれ県人会だ町人会だと、騒ぎ立てるのが滑稽だ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "故大佐と余とは陸海軍の相違があるから、たまたま県人会などの席で顔を合せた程度で、深い交りというものはなかった。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治御一新以来全国各県の県人会あつて、ひとり東京県人会のみがない。",
              "citation": {
                "source": "「東京恋慕帖」自序",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
