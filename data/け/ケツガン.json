        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうだ、この頁岩の陰気なこと。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）例の楢ノ木大学士が衣嚢に両手を突っ込んで少しせ中を高くしてつくづく考へ込みながらもう夕方の鼠いろの頁岩の波に洗はれる海岸を大股に歩いてゐた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はすぐとろとろする疲れて睡れば夢も見ないいつかすっかり夜が明けて昨夜の続きの頁岩が青白くぼんやり光ってゐた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ところでこゝは白堊系の頁岩だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」学士の影は黒く頁岩の上に落ち大股に歩いてゐたから踊ってゐるやうに見えた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その灰いろの頁岩の平らな奇麗な層面に直径が一｜米ばかりある五本指の足あとが深く喰ひ込んでならんでゐる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅い頁岩の筈だったと思って楢ノ木大学士はうしろを向いた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足跡さへずんずんたどって遁げてさへ行くならもう直きに汀に濤も打って来るし空も赤くはなくなるし足あとももう泥に食ひ込まない堅い頁岩の上を行く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）例の楢ノ木大学士が衣嚢に両手を突っ込んで少しせ中を高くしてつくづく考え込みながらもう夕方の鼠いろの頁岩の波に洗われる海岸を大股に歩いていた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はすぐとろとろする疲れて睡れば夢も見ないいつかすっかり夜が明けて昨夜の続きの頁岩が青白くぼんやり光っていた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ところでここは白堊系の頁岩だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」学士の影は黒く頁岩の上に落ち大股に歩いていたから踊っているように見えた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その灰いろの頁岩の平らな奇麗な層面に直径が一｜米ばかりある五本指の足あとが深く喰い込んでならんでいる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足跡さへずんずんたどって遁げてさえ行くならもう直きに汀に涛も打って来るし空も赤くはなくなるし足あとももう泥に食い込まない堅い頁岩の上を行く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その断層には学者乞食と言われる花田が特に興味を持つ頁岩があるのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんの彼の言葉から察するのに彼は鉈庖丁で肉を叩きながら尾根山の岩膚が多那川へ露き出しになっている瀞の頁岩のことでも考えているのでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓司がふと見ると、足下の象の鼻の途中から下、瀞の渚近くまで岩層が露出していて、学者乞食の花田が頁岩のあると言って頻りに研究の材料にしている地点へ、運転手風の男が試掘用のハンマーで岩石を打ち壊しては堤の上の自動車の中へ運び入れています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手が丘の根の頁岩から幾塊かの岩塊を壊し、車に積んで運び去るのを見て啓司は苦笑しながら言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根山の象ヶ鼻の瀞の頁岩へ、東京の事業家が目をつけ出したという報せを啓司から町のスタフ達は聞いて、彼等は今まで兎角煮え切らないでいた町全体の人間と資力を挙げて製紙工場を中心に拡大強化し、積極的に各種の事業を経営して行こうという議は捗りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頁岩からは天然のセメントが出るし、もう少しの研究でベントナイトが得られるとかどうかとかで、そのベントナイトから防湿紙が作り出せるなど、その他いろ／＼話に、研究に、この町は活気を呈して参りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも必死に苦しんだ人間の脳の襞が、法則を積み重ねた頁岩のように層層として視線のゆく所にあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪横に深く坑道を穿つて採掘する物であると思つてゐた炭砿の概念は忽ちに裏切られて、唯だ表皮の油頁岩層を三四丈も剥いで取れば、下は一面に石炭なのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剥ぎ取つた油頁岩は贅物でなく、それを乾溜して重油を製してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが十発ばかり正確に狙って撃つと、敵は止まって、点在する頁岩の後ろに隠れてしまった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
