        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この屋根の上に蘆が生えて、台所の煙出しが、水面へあらわれると、芥溜のごみが淀んで、泡立つ中へ、この黒髪が倒に、髻から搦まっていようも知れぬ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れの青空の中に隣の西洋館の屋根の煙出しが並んで三本あった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、下｜唇のない、おじいさんの煙出し人形が立ちあがって、このきれいなお花たちにむかって、おじぎをしました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙出し人形が、さっそく、テーブルのはしまでかけていって、腹ばいになって、引出しをほんのちょっとあけました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、煙出し人形がたずねました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、煙出し人形は、ひとりで踊っていました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い藁屋が二三軒、煙出しの口も開かず、目もなしに、暗から潜出した獣のやうに蹲つて、寂と寝て居る前を通つた時。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼は首は開いていた屋根の煙出しから出て行った事を察した。",
              "citation": {
                "source": "ろくろ首",
                "author": "ROKURO-KUBI",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の煙出しは白樺薪の濃い煙を吐き出している。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處は煙出しと明取りになる。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして此處は即ち前に申す通り明取りと煙出しになつて居る。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの煙出し兼明取りの所はいろいろに色取るのです。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん煙出しなんかないので、しょっちゅう煙がこもっているし、どこも真黒に煤けている。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の囲炉裡から出る煙が、木造で屋根のついた、四角い煙出しから出て、そして風が無いので屋根を這っている。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭がまは、かやの屋根に蔽われ、その屋根のうしろの煙出しからは、浅黄色の煙がほうほうとこぼれ出て、傍の雑木の梢にからまりながら消えて行った。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "バケから外して煙出しの穴から下の※ノ間へ投げおろしておき、舳のほうへ行ってバケを入れると、七本釣れた。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "持てるだけの鰹を両脇に抱え、さて下へ行ってみると、さっき煙出しの穴から投げおろしておいた鰹が骨ばかりになっている。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん煙出しのないいろりであるから、煙はもうもうと部屋をこめる。",
              "citation": {
                "source": "ケリイさんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上に煙出しの口を開く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花冠はちよつと見ると一枚の花弁で出来た樽形の煙出しのやうな形をしてゐるだらう。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞその五枚の花弁が、一つ一つはつきりと分れてゐないで、煙出しのやうな形に一つにかたまつて了つたのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから寺の庫裡という言葉、これは煙出しのある家という梵語「クテイ」で、庫というのも梵語らしい、厨も同じ梵語かと思われます。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "李朝の代表的建築である康寧殿と交泰殿とは既に他に移転せられ変形せられ、今はただ温突の煙出しのみが小山に沿うて淋しく佇んでいる。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸のない階段口が煙出し穴みたいに壁へ開いている。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして豆ランプがひとつ、煙出しのなかでぼんやりともっていました。",
              "citation": {
                "source": "灰かぶり",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の上の木製の煙出しに入っている、焼串のような棒は、頭髪を一時的一定の形に置くものであり、煙出しの端からぶら下っている真鍮の曲った一片は、顔を剃る時、こまかい毛を入れるもので、床屋はこの端に剃刀をこすりつける。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙出しや教会の尖塔の無いこと、屋根の高さが一般に同じで、所々に高い防火建築、即ちクラがあることに気がつくであろう。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "主として山だが、立木でも、煙出しでも、屋根でも、土手でも、ゴミためでも、何でもかまわぬ。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "別荘は古風な建て方の西洋館で、スレート葺きの屋根の上に、長方形の煖炉の煙出しが、ニューッと突出していた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、おかみさんが、「ばか、あれがおまえの小ねこなもんか、ありゃあ、けむだしに日があたっているんじゃないか。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
