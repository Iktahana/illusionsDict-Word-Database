        "examples": {
          "standard": [
            {
              "text": "この森には、径の大きい木が数多く生い茂っており、壮大な景色を作り出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ダムの放水管は、大量の水を流すため、径の大きいものが使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の釣り上げた魚は、驚くほど径の大きいものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "のみならず、その両親の慈愛の賜である結婚費用……三十幾粒の宝石は、赤軍がよく持っている口径の大きい猟銃を使ったらしく、空砲に籠めて、その下腹部に撃ち込んであるのでした。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径の大きい黒いこうもり傘をさし、彼は庭を見て歩いた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
