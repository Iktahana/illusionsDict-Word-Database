          "standard": [
            {
              "text": "植物の図鑑には、種類を特定するための検索表が載っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この検索表を使えば、誰でも簡単に昆虫の種類を調べられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複雑な検索表を理解するには、ある程度の知識が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分は中学の時使った粗末な検索表と首っ引で、その時分家の近くの原っぱや雑木林へ卯の花を捜しに行っていた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い花の傍へ行っては検索表と照し合せて見る。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
