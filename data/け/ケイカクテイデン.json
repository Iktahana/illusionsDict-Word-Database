          "standard": [
            {
              "text": "発電所の故障により供給力が不足したため、地域ごとに時間をずらして計画停電が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「計画停電の間は冷蔵庫が使えないから、生鮮食品の保管に苦労するわね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市役所はホームページを通じて、計画停電の対象エリアと時間帯を周知した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "節電のための計画停電という奴だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画停電は全国的なものであるから、ストリップ劇場のあるところ、全国すべて同じことが行われているに相違ない。",
              "citation": {
                "source": "安吾の新日本地理",
