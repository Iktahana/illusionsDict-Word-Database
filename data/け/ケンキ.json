  {
    "uuid": "623a1c84-d4d1-5ba6-94b8-f1f8b451dc24",
    "entry": "建機",
    "reading": {
      "primary": "けんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "construction equipment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「おや、これゃ、こんなもんは、届けんきゃなんないぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、そのとき、にわには、あのクリスマスの晩、この木のまわりをとびまわった、けんきのいいこどもたちが、あそんでいました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってのとおり、なにごとによらず、人に術を施すということは、術者自身が心気を一つにしなけんきゃならぬのでな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけんきゃあならん、なあ、　金と子の縁にうすいと出て居る。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、もっと　けんきうしよう。",
              "citation": {
                "source": "赤いねこ",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそうなってみると急に驚くほどの女らしさを見せ、けんきょな気持でいろんな面での自分の無知を恥じながら、「私のような、文学のことも政治のことも何にも知らない者でも、それをやっている人を助けることでみんなの仲間入りが出来るというなら、私決心するわ。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やっと、ふたつのどくろの持主をみつけて、暗号のけんきゅうをはじめたところなのだ。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
