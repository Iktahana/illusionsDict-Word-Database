    "definitions": [
      {
        "index": 1,
        "gloss": "sightseeing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また時々は夫人に芝居見物をすすめて、『歌舞伎座に団十郎、たいそう面白いと新聞申します。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "国技館の角力を見物して、まじめくさり、「何事も、芸の極致は同じであります。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、映画見物の小学生が十人ほど焼死しました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、映画見物の小学生が十人ほど焼死しました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは歌劇ミカドを見物して、日本人を理解したといふ程度であり、俳句を HAIKAI として解釈した程度であらう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は世界第一であったナウエンの無線電信発信所を見物したのもこの見学団の一員としてであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年の暮には南ドイツからウィーンを見物してヴェニスに泊ったのがちょうどクリスマスであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も陳列所前の砂道を横切って向いの杉林に這入るとパノラマ館の前でやっている楽隊が面白そうに聞えたからつい其方へ足が向いたが丁度その前まで行くと一切り済んだのであろうぴたりと止めてしまって楽手は煙草などふかしてじろ／＼見物の顔を見ている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高層の風が空中に描き出した関東の地形図を裏から見上げるのは不思議な見物であった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの樹の実を尋ねて飛んで来る木椋鳥の大群も愉快な見物であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神代櫻へは、わざわざ團體で行かなくても、私たちだけで、のんびり見物に行きませう、賞金もらつたら、そのお金で行きませう、さうしませう、と三人で話をきめた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、映畫見物の小學生が十人ほど燒死しました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だもんだから、近所隣で井戸を掘り下げると、そこで最初はおとなしく見物してゐるが、水気を含んだ土が出て来、土混りの赤又は黒の水が出るに及んでは、子供心に冷静を失つてしまふのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "平松から大谷の町へかけて被害の最もひどい区域は通行止で公務以外の見物人の通行を止めていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の番傘を借りて明神池見物に出掛けた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所が場所だけに見物が段々背後に集まつて來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が収まったので上野二科会展招待日の見物に行く。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾窓の二面は普通の新衣裳の飾人形だが、残った一つの入口に向って右の飾窓のがみんなの目あての「エッフェル塔見物」の機械人形だ。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎がお蘭のところへ来なくなって、この白痴の少年が金モールの服をつけ曲馬の間に舞台に現れて、唄をうたい踊りを踊ったのち、真鍮の小判だの肖像入の黄財布だのを福の縁起だといって見物に売るという噂を耳にした、お蘭は立っても居てもいられなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は藤川から出発し岡崎で藤吉郎の矢矧の橋を見物し、池鯉鮒の町はずれに在る八つ橋の古趾を探ねようというのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これから私たちの行先が桑名見物というのを聞取って「あすこなら、私よく存じている者もおりますから、御便宜になるよう直ぐ電話で申送って置きましょう」　と言って帰って行った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人の間に立って私はしばらく見ていた。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔長崎を見物した時に見た露文の看板の記憶が甦って来るのを感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに見物には分かっているが靴磨き二人には所有者不明の写真機がある。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではしかし見物の多数が承知しないから最後の法廷の場がどうしても必要である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは真犯人の旧騎士吉田を今の新聞記者吉田に仕立ててそれをこの法廷の記者席の一隅に、しかも見物人にちょうどその目標となるべき左の顋下の大きな痣を向けるように坐らせておく必要があるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、自分は地獄へ行って見物して来たと宣言して、人々に見て来たあの世のさまを物語って聞かせたら聞くものひどく感動して号泣し、そうして彼はいよいよ神様だということになった。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都見物を一定時日の間に最も有効にしようというには適当な案内者あるいはこれに代るべき案内書があると便利である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりの旅人が金閣寺を見物しようとするには案内の小僧は甚だ重宝なものであるが、本当に自分の眼で充分に見物しようとするには甚だ不都合なものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江の島をけんぶつして來たよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
