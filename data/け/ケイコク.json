      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "将門傾国の謀を萌すと雖、何ぞ旧主を忘れんや。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢皇｜重色思傾国……楊家女有、と同一字だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾国の美人ってしろものをおめえにもとりもってやるから、しっぽを振ってついてきなよ」「いやです、あっしゃ今から伊豆守さまのお屋敷へ駆け込み訴訟に参りますよ」「伊豆守さま……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂粉に彩どられた傾国の美こそなかったかも知れないが、美の価値を、自分の目の好悪によって定める、男の鑑賞眼は、時によって狂いがないとはいえない。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫣然一笑、東洋でいう傾国の笑いというやつ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の傾国傾城の「うら悲しい微笑」。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「傾国の美人てのも、いるそうですね。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「傾国の美人……。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "成島柳北があたかもこの年の秋に著した『柳橋新誌』第一編にお菊の事を記して、「彼ハ傾国ノ色絶世ノ技アルニ非ラズトイヘドモ、繊繊タル女手ノ力ヲ以テ大ニ巨閣高楼ヲ墨水ノ西ニ営ミ、扁シテ有明楼トイフ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この名打ての美男が、気を張り詰めてポウッと上気していたところへ、何を思ったか、急にニッコリ白い歯並を覗かせたのだから、女なら傾国の一笑というやつ――壁辰、訳もなく釣り込まれて、こっちも、にっと笑ってしまった。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば畢竟この苦し紛れに叫び出した語であろうと思うが、支那人は婦人を指して傾城傾国といい、長恨歌にもこの文字が使用されて「漢皇色を好んで傾国を重んず」などとも歌ってある。",
              "citation": {
                "source": "現代の婦人に告ぐ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子は男子に自由を奪われているから、表面は反抗し得ないけれども、事実の上はその情意を恣にしていわゆる傾城傾国をやる。",
              "citation": {
                "source": "現代の婦人に告ぐ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾国の女王クレオパトラの昔もかくやと偲ばれんばかり、透き徹るような美しさというものはおそらくこういう女を指すものだろうと思わずにはいられなかったのであったが、しかも緩やかに巻いた腰帯は金糸銀糸の綾織に、紅玉石か真珠でも一杯に刺繍てあるらしく、それが今｜陽に燦めいて煙々と瓔珞の虹を放っている光耀さ！",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾国の美には迷わぬが……」　云いかけた時である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾国一　王允は、一家を挙げて、彼のためにもてなした。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾国の美とは、こういう風情をいうのではあるまいか。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞説、喬家の二名花とは、姉を大喬といい、妹を小喬と呼ぶそうで、その傾国の美は、夙にわれわれも耳にしているものです。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "朕、いま傾国の兵をあげ、昔日の盟を果たさんことを、あえて関羽の霊に告ぐ。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾国の美人であるといわれて、初め袁紹の二男｜袁煕の夫人となったがそれを攻め破ったときから、曹丕の室に入り、後、太子曹叡を生んだのであった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "九人の子女はみな傾国の美や佳人の園生であったという。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああれがけいせいけいこくと云い、金さえあれば自由になるものか、わしもやっぱり人の子じゃア……。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文に曰く、“やみかわ、きちんど　に　けいこくする。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連中が、われわれに対してけいこくをこころみたのかな。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、おもてがわのほうの血を落したかとおもうと、それはうらがわに、いつか、よけいこく、にじみ出していました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
