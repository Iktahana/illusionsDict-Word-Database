    "definitions": [
      {
        "index": 1,
        "gloss": "government",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これが、一年前在モスクワの息子経国から「……いまやあなたは支那国民の敵となった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた「経国美談」「佳人之奇遇」のごとき、当時では最も西洋臭くて清新と考えられたものを愛読し暗唱した。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野竜渓の「経国美談」を読まない中学生は幅がきかなかった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年の、佳人之奇遇、経国美談などを、古本屋から捜して来て、ひとりで、くすくす笑いながら読んでいる。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の智識としては馬琴、為永の小説や経国美談、浮城物語を愛読し、ルッソーの民約篇とかを多少｜噛っただけである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ在官者よりも自由であって、大抵｜操觚に長じていたから、矢野龍渓の『経国美談』、末広鉄腸の『雪中梅』、東海散士の『佳人之奇遇』を先駈として文芸の著述を競争し、一時は小説を著わさないものは文明政治家でないような観があった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は二回目で、一番目が依田学海作の「拾遺後日連枝楠」、二番目が矢野龍渓の「経国美談」であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、面白く思われるのは、自由民権が唱えられた時代からのより社会的性質のつよい文筆家たちは「経国美談」の作者の矢野龍溪にしろ中江兆民にしろ、主として新聞人として活躍していることである。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その主なるもののみを挙げるならば、　東海散士柴四朗「佳人之奇遇」、「東洋之佳人」、矢野竜渓の「経国美談」、「浮城物語」、末広鉄腸の「雪中梅」、「花間鶯」、木下尚江の「良人の自白」、「火の柱」、内田魯庵の「社会百面相」等がある。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪内氏の訳になるリットンの「開巻悲憤慨世士伝」とか、井上勤訳する処のモアの「良政府談」とか、創作では、東海散士の「佳人之奇遇」、矢野竜渓の「経国美談」等々皆然りである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ちこの名称が久しく行われておったが、「経済」という語は、経国済民から出ておって、太宰春台の「経済録」などが適当の用法であることは勿論であるから、明治十四年の東京大学の規則には「理財学」と改められた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ただ強制に服する根性や、諸事に間に合う風流の本義から、経国の学が発露したり、臣民の道が説きだされたり、道徳律がひねりだされたりして、それが国風となり万人に強制されることになっては、かなわない。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自分で自分を韜晦せねばならぬほどの経国の器量を備えているというわけではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその宇宙の大勢を達観し、経国の大計を画するに到りては、彼に向って望むべからず、また責むべからざるなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヴル経国済世の建設的偉図も、あるいはマジニー一片の革命的｜檄文に如かざるものあり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "不是尋常風月遊、観欧察米献皇猷、知君智海無涯底、納尽万邦経国籌。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佳人の奇遇」「雪中梅」「経国美談」等、おもに政治小説であった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『経国大典』に当時下官の者に銀入糸の馬鞍を禁止した旨が記してあるから、この錠も一般庶民の用品ではなかったことが推察される。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格的・道徳的・道学的・な権威と感化力に基づく教化であり、民衆に対する支配者の文化政策の前資本主義的形態であるのだから、之は一種のほぼ封建的な教育活動であると共に、又一つの政治活動（修身――経国――治国平天下）であり、徳育政治という意味での徳政（但し殿様の借金の踏み倒しのことではない）である。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文章経国大業　不朽盛事」　という文字がその晩にかぎって何となく空々しく、遠いところへ外れてゆくように思われる。",
              "citation": {
                "source": "親馬鹿入堂記",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細面のくせに血色の良い、しかも頭は半白、元気は若者をしのぐ好々爺だつたが、大いに経国の本義を論じてゐるらしく、其の説たるや頗る珍重すべきものであつた。",
              "citation": {
                "source": "車中も亦愉し",
                "author": "小津安二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古今集』以後の和歌集が勅によって撰ぜられたのは、『経国集』・『文華秀麗集』・『凌雲集』などの詩集が勅によって撰ばれたのに倣ったのであるが、一度『古今集』が出てからは、これが永く御歴代の催しとなった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（真に、剣も道ならば、剣から悟り得た道心をもって、人を生かすことができない筈はない）　と、殺の反対を考え、（よしおれは、剣をもって、自己の人間完成へよじ登るのみでなく、この道をもって、治民を按じ、経国の本を示してみせよう）　と、思い立ったのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる「一剣天下ヲ治ス」と当時に標語されたように、剣の哲理と経国の道――すなわち政治性とのかかわりなども深く考えられていた。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし、柳生流の本来とするところは、流祖石舟斎が、但馬守｜宗矩の出府に際して、懇ろに諭しているとおりに、――殺人ノ剣タル勿レ、治国ノ剣、経国ノ剣トシテ家流ノ本旨トナシ、又奉公ノ念トセヨ。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康の大事は、治民｜経国の大事と共に、これの消耗を、夜間の秘戯にスリ減らすほど、愚かでもなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああれがけいせいけいこくと云い、金さえあれば自由になるものか、わしもやっぱり人の子じゃア……。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文に曰く、“やみかわ、きちんど　に　けいこくする。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連中が、われわれに対してけいこくをこころみたのかな。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、おもてがわのほうの血を落したかとおもうと、それはうらがわに、いつか、よけいこく、にじみ出していました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
