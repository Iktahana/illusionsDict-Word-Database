    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forgetfulness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "健忘症の政治家や気まぐれな学界元老などの手に任せておくにはあまりに大切な仕事である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、人間というものが、そういうふうに驚くべく忘れっぽい健忘性な存在として創造されたという、悲しいがいかんともすることのできない自然科学的事実に基づくものであろう。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこれを忘れているおかげで今日を楽しむことができるのだという人があるかもしれないのであるが、それは個人めいめいの哲学に任せるとして、少なくも一国の為政の枢機に参与する人々だけは、この健忘症に対する診療を常々怠らないようにしてもらいたいと思う次第である。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｗという名前を覚えていないし、それこそ、なんの恩怨もないのだし、私は高等学校時代の友人の顔でさえ忘れていることが、ままあるくらいの健忘症なのに、Ｗ君の、その窓から、ひょいと出した丸い顔だけは、まっくらい舞台に一箇所スポットライトを当てたようにあざやかに眼に見えているのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の読者というものは恐ろしく健忘性なものであると仮定するか、あるいはまた新聞購読者の大多数は、ほんの気まぐれに、十日に一度｜二十日に一度ぐらいその日の新聞を買って見るだけである、ということでも前提に置いて考えてみなければ全くわけのわからない「煩雑」であり「浪費」である。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は特別に記憶の好い性質ではない、寧ろ健忘性に属する方だ。",
              "citation": {
                "source": "なつかしき挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御当人がそういう健忘性だから世間からも西という公使があったかなかったか今では全く忘れられている。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "健忘症６・27（夕）　先日神戸高商の小川忠蔵、小久保｜定之助の両氏が、英語専攻の学生に饗ばれた返礼を、安上りだといつてカフエエ・オリエントでする事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂も七十五日、という日本らしい健忘症のうちに消しさられないことを切望する。",
              "citation": {
                "source": "目をあいて見る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの健忘症はおどろくべきものである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に数行を隔てて同じ事を反復してゐるのは、忌憚なく言へば、老茶山の健忘のためかと推せられる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は近頃ひどい健忘症になってね。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂発作後の健忘状態という奴だ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち『逆行性健忘症』に陥った……というぐらいの事は新聞記事を読んだだけでチャント見当がついている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐れな健忘症の状態に止まっているのであった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人物の名前に対する吾々の健忘性の故ばかりではない。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その西洋のものといえども、私の健忘症は見たものを次から次へと忘れて行くが、私はアドルフマンジュという役者を忘れ得ない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年を経過するころには健忘症の世人は、もう博士がこの奇妙な研究室に閉じこもって、蜘蛛の研究をしていることなどは思い出してみようともしなかったが、ある夜辻川博士を訪ねてきた友人の大学教授潮見博士が、この研究室から墜落惨死した事件があって、一時また騒ぎだしたことがあった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、其にはあまり健忘の時間が、私の上に立ち過ぎてゐた。",
              "citation": {
                "source": "「なよたけ」の解釈",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際一時代たつと人間の健忘性は過去の痛苦を実感しなくなると見え、誰が始め出すのか知らないが、今にもヴェルダンのような悲劇がどこかでまた起ろうとしてる。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それにも拘らず、人間の神経麻痺性と健忘症は驚くべきもので、廃墟の上にまた新らしい都市が建てられ、今では人口三十万、シチリア第二の大都市として、巨額の果物・硫黄を産出している。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに健忘なわたくしのことゆゑ記憶がかすんでゐる。",
              "citation": {
                "source": "緑蔭叢書創刊期",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜いかな、その日その日の紛々たる出來事が絶えず眼前に現るゝので健忘の我々は、かゝる偉人の存在をもさつさと葬り去つてしまふ、無理も無いが殘念である、教育上からも多大の損失である。",
              "citation": {
                "source": "野口英世博士の生家を訪ひて",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで二月五日立春の日に村上辰雄君と宮崎泰二郎君と筆記者建宮君とが來訪し、老來健忘のみならず資料は悉く燒亡して甚だ覺束ない私の幼少年時代の思ひ出を記録した。",
              "citation": {
                "source": "「晩翠放談」自序",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "大ブリテン、ロンドン市に於てさえ斯くの如き公共事業がすべて慈善心の上になり立って居ること、而もその慈善心というものが、ジョンブルの紳士国に於てもいかに健忘で、絶えず叫びかけられなければ彼の良心的一ポンドをも出さないのであるか。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴の入口の朝顔を鉢植えにし鉄骨ビルの窓へうつすことも、また穴へ戻って入口に植えかえることも、それを無碍の境地で行い、苦もなく安住する悟道が天性的に備わっているが、それを支えているものは、すみやかに忘れるという天与の健忘症によるのであろう。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体のほかに持つてゐたのは頭抜けた楽天性と健忘性と野性のままの性慾だつた。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから井ノ頭病院の精神科へ送られ先生達の診断を受けたところ電話ボックスの中以来のことは常人同様はっきり覚えているし文章も巧く英語も話すが、完全な逆行性健忘という病気であるということが分りました。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この山口さんのようなのを逆行性健忘症というのだそうだが、普通は頭を強打するというような外部からのショックでなるものだそうだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけんぼうのイルカは、トンボ返りをうっていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
