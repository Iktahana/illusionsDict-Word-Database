        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "敷石道を蹴立てる靴音のその音波で、靄はうらうらと溶けていった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一太は砂埃りを蹴立てるような元気でまた電車に乗り、家に帰った。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こツてりと油を付けて結ひ上げた千代松の丁髷に、車夫の蹴立てる白い砂埃りが煙のやうに掩ひかゝつた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が砂煙を蹴立てるので広い場内が真白に曇つて仕舞つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴立てるようにして急いだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前がそれほど幸内が大事なら、幸内をつれて勝手にどこへなりと行きなさい、父はもうお前のすることについては何も言わぬ、お前もこれから父の世話にならぬ覚悟でいなさい」と言い捨てて、座を蹴立てるようにして立去りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――浮世はなれた感じにぼんやり浮いているそれらのなかを縫っていそがしく白い波を蹴立てる蒸汽。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看視人も早いが逃げる男も早く、二人の蹴立てる水しぶきは、しだいに遠くなり、やがて根戸川の川口のほうへと、見えなくなっていった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが伊兵衛一人、斬って通れ」　十郎兵衛が雪を蹴って殺到した……降りしきる雪の中に、白刃が条を描き、蹴立てる雪が煙のように闇を染めた。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち並ぶ劇場、映画館、飲食店、織るがごとき雑沓、露天商人の叫び声、電蓄の騒音、子供の泣き声、数万の靴と下駄とのかなでる交響楽、蹴立てる砂ぼこり。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は快く新しい家に入る気にならないのを説明したら、彼は、（それではもう決った、やはり先と同じだ）と椅子をけたてるようにして席を立ち、母上のところに行って何か話し、かえり、今朝、まだ寝て居るところに来て、私に kiss した。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれか顔の広い人物があったら、教示にあずかりたい」　　　　仇人　　　　　　一　吉田屋のお民が、お駒を、お目見得泥棒とののしって、席をけたてるようにしてかえっていったあとだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
