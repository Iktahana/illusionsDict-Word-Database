        "examples": {
          "standard": [
            {
              "text": "冬に備えて、孫のために心を込めて柔らかな毛編みのベストを編み上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母は昔から毛編みが得意で、家の中には手編みのクッションやカバーが溢れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "静かな午後にラジオを聴きながら、毛編みの手を動かす時間は何よりの贅沢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "五人の男達は皆同じやうな身なりをしてゐた、厚い青色の毛編みのシヤツが、上半身をしめつけてゐて、それがズボンのしめ帶の中へたくし込まれてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色の毛編みのチョッキを着ていたが、それもすり切れよごれ裂けた古いもので、折り目の所には皆穴があいていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
