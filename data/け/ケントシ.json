          "literary": [
            {
              "text": "私は紙挟みを開いて、ケント紙に線を加へ数字を記入しながら、滅多に眼ばたきもしなかつた。",
              "citation": {
                "source": "どうしたら私は憐れな彼女を悸さずに済せるだらう",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙片は薄いケント紙を長方形に切ったもので、葉書よりやや大きいかと思われるものだった。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケント紙のしっかりした角封筒の上に、ゴシックの装飾文字のような書体で、伸子の宛名がかいてある。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、水に落ちたケント紙のような色の空だったわ。",
              "citation": {
                "source": "暑くない夏",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
