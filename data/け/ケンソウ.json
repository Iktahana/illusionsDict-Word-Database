[
  {
    "uuid": "d4a67b57-308f-5a42-a2e5-53b14f2db091",
    "entry": "喧騒",
    "reading": {
      "primary": "けんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tumult",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで私は、橋や荷足を見残しながら、　　レストオランに這入るのだ――わんわんいふ喧騒、むつとするスチーム、　　さても此処は別世界。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧騒の声が地下室に充ちて向き合っての話声も聞取れなくなった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この驚くべき聴感の能力のおかげで、われわれは喧騒の中に会話を取りかわす事ができ、管弦楽の中からセロやクラリネットや任意の楽器の音を拾い出す事ができる。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その技術あまりに拙しとて、観客は総立ちになりて喧騒をきわめ、結局一夜かぎりにて中止となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅近くではあったが、それだけ中央の喧騒から遠去かり、別世界の感があった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央の喧騒を批評的に見渡して自分たちの場席を顧みると、頼母しい寂しい孤独感に捉えられた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、むす子が眼をやっている間近の柱の絵を見上げて、それから無意識的にその次の柱、また次の柱と、喧騒の群の上に抽んでて近くシャンデリヤに照らされている柱の上部の絵を、眼の届くまで眺めて行った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老美人は子供のようなはしゃぎかたさえ見せて、喧騒の渦の音が不安な魅力で人々を吸い付けている市の中心の方角へ、しきりに新吉を促し立てた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "包囲した鬨の声のような喧騒に混って音楽の音が八方から伝わる。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの喧騒も混み合いも新吉がカテリイヌを追い求める心をまぎらわすことは出来なかった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と相州さまは、大きくあぐらをかいて盃をふくみながら一座の喧騒のさまを心地よげに眺めて居られました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく喧騒が大きくなったころ、先生は、「だれだっ」と一かつされる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はぎこちない気持で、町中や公園の喧騒の中を歩き廻った。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の男女の喧騒の中に在って沈着に大砲を準備して居る老人は此の村の村長でもう七十歳にもなるが砲術の名人で二十八年間此の役を引受けてやっているそうです。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに一日中喧騒を極めて、猥雑な空気に濁っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら今高華なる都会の喧騒より逃れて漸く田園の風光に就く、やさしき粗野と原始的単純はわが前にあり、新生来らんとす。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その上手の、まだ木の香のなまなましいバラックの、戸は引いて、窓も閉めたのが、その中では何か盛んに喧騒していた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "生長し、生殖し、受胎し、産卵し、展望し、喧騒し、群立し、思考し、歓喜し、驚異し、飛揚し、飜躍し、――島そのものから、ああ、島そのものからすばらしい創世紀にあるのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら今高華なる都会の喧騒より逃れて漸く田園の風光に就く、やさしき粗野と原始的単純はわが前にあり、新生来らむとす。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きかふ人かげ、馬車や自働車の燈のくるめき、電車の鐸――銀座の二丁目から三丁目にかけて例も見馴れた浅はかな喧騒の市街が今はぼかされ掻き消されて、ただ不可思議な恍惚と濃厚な幻感とが恰度水底のキネオラマのやうに現出する。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼の大天幕の下、土人の男女の喧騒の中で、生温い風に吹かれながら、曲芸を見る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八十一、八十二、八十三、……」「らっしゃいませ」「珈琲ワン」「ありがとうございます」「ティワン」　喧騒のなかで、豹一の声は不気味に震えていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝子は、其画家たちの喧騒を見たり聞いたりした。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく都会の喧騒の中に居た物が俄に美しい海辺に遊ぶ身となつたのだから吾身も心も段々と健康になつて行つた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワークスのプロモーションにあたって連携プレーを狙う各社からの挨拶が続いているにもかかわらず、アルコールがすでに回りはじめたのか、会場の一部からは通夜の宴の喧騒を思わせる大声が上がり始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サモアルは空つぽでペチカは燃えず、されば新劇林のごとく静かなる部屋にかかる小沢の喧騒な演技もまた情熱の現れか？",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥村土牛はその石であり、周囲の喧騒のもみ合ひの中で、超然としてゐたことが、却つてこの作家を社会的表面に浮かびだすといふ結果にさせたと言ふことができるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝馬鑑定に、心の動揺や喧騒や迷いは大いなる妨げとなる。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分先刻の若者なども毎晩此家に入浴に来る処から此家と親しくしているのであろうが、その喧騒と来たら実に烈しいものであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
