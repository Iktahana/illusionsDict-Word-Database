        "examples": {
          "standard": [
            {
              "text": "アイルランドでは今でもケルティック語が話されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スコットランド・ゲール語はケルティック語の一種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ケルティック語の研究は言語学的に非常に興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "英語とケルト語の方言……オランダ語の素質も、ダイア語の素質も持っていない。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく仕事を休んで故郷のブルターニュに帰り２年のあいだ引きこもり古典の著者たちの本を読みケルト語を勉強した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、古いフランスの通俗語の上に、プロヴァンス語、スペイン語、イタリー語、地中海の海港の言葉である東方語、イギリス語、ドイツ語、フランス・ロマンとイタリー・ロマンとローマ・ロマンとの三つの種類のロマン語、ラテン語、それから、バスク語、及びケルト語。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（ただしケルト語の mac は息子という意味である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルト語をとれば――blavet（ほとばしる水）―― blavin, ハンカチ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
