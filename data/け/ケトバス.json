    "definitions": [
      {
        "index": 1,
        "gloss": "to kick (hard)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もうそうなると、気の上った各自が、自分の手足で、茶碗を蹴飛ばす、徳利を踏倒す、海嘯だ、と喚きましょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗黒で固より見当は付かぬが、市郎は勝つに乗って滅多矢鱈に蹴飛ばす中に、靴の尖には応えがあった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっそり茶の間へはいって来て、ものも言わず、長火鉢の奥に坐っている老母を蹴飛ばすようにして追いたて、自分がその跡にどっかと坐って、袴の紐をほどきながら、「何しに来たんだい？",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のつそり茶の間へはひつて来て、ものも言はず、長火鉢の奥に坐つてゐる老母を蹴飛ばすやうにして追ひたて、自分がその跡にどつかと坐つて、袴の紐をほどきながら、「何しに来たんだい？",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五寸程芽の出掛かつた椰子の實の落ちてゐるのを蹴飛ばすと、水の中にころげ入つてボチヤンと音を立てる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五寸ほど芽の出掛かった椰子の実の落ちているのを蹴飛ばすと、水の中にころげ入ってボチャンと音を立てる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　開墾地の人たちは叫びながら、戸口を蹴飛ばすようにして戸外へどどっと雪崩れ出していった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こみ合っているならこみ合っているように、気をつけて通れ、むやみに人を蹴飛ばす奴があるものか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが市区改正の大事業……言葉を換えて云えば東京の改造……否、寧ろ日本文化の中心改造という大仕事を眼の前に控えながら、高が一局長の椅子に市会が押し上げた人物が気に入らぬ位の事で、市長の椅子を蹴飛ばす程短気であろうとは、誰しも想像し得ないところであっただろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（勘太郎は落ちてゐる鯣を足にて蹴飛ばす。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲谷は、はッと冷たくなると、お柳を蹴飛ばすように、逆にお柳に向っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちろりんは随分な嫉妬焼きで雌が他の雄と談話でもしてゐようものなら、いきなり相手を後脚で蹴飛ばすさうだが、薩摩者もこの点ではちんちろりんに劣らぬ道徳家である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は女を蹴飛ばすのみならず、その上に女を不縹緻にさへするものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそのためにつむじを曲げて、芝居を蹴飛ばすようなことがあっちゃあ大痛手だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな障碍物でも蹴飛ばすような勢いで、往来をめがけて走り出すのだった。",
              "citation": {
                "source": "雨の回想",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を捉えられたのならば蹴飛ばす事が出来る。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏木戸を蹴飛ばすような騒々しい音と一緒にあの植木屋が大事件だ、というような顔をして飛んで来た。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高きに登りて小便をする程壯快な事は無いと云つた人があるが、女もその快感を味ははんが爲めに、汗臭くなつて健脚をほこり、土踏まずの無い足で富士の嶺を踏つけ、日本アルプスを蹴飛ばすのか。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうして、あいつの、あの色香や、あの心意気を、蹴飛ばすことが出来ないのだ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお打ち明け致しましょう」　ところがそれ前に若侍は、蹴飛ばすような声で云った。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事か知らんと一同足を止めて見ますると、向うから罪人が四五十人、獲物々々を携え、見るも恐ろしい姿で、四辺に逃げ惑う老若男女を打敲くやら蹴飛ばすやら、容易ならぬ様子であります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "花時の向島、敵討があると云うので土手の上は浪を打ちますよう、どや／＼押掛けてまいりまして、蟠龍軒の死骸を見ては唾を吐くやら蹴飛ばすやら弥次馬連が大騒ぎをして居ります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴飛ばすやうな勢ひで、やうやく主婦を階段の下へ追ひ降したのである。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ふことを聴かぬ子を叱らないから、ますます横暴を極め、父親の背中さへ足で蹴飛ばす。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏壇を背負い、犬猫を蹴飛ばすの混乱になってきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（彼女は、掲示の貼紙を引き剥がし、慈善箱を足で蹴飛ばす）微々　　あツ、はひつてます。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いろいろ悩まはったみたいやけど枝雀はん、落語をけとばす覚悟を決めはったんやな」と思わず大阪弁でつぶやいてしまうのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して、そこに、世の常のモラルと分別をけとばす何かの新しい人生価値があるのだろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この石が目印ってわけか」ひげ面男は石をけとばすと、そこへしゃがみ、両手を使って土をかきだした。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、まだ生きているな」　丸木は、そう言うと、片足をあげ、新田先生の鮮血りんりたる頭を、けとばすようなかっこうをした。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
