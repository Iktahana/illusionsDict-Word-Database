  {
    "uuid": "daaacdb2-56fc-5467-afc9-ca252fd002bd",
    "entry": "眷属",
    "reading": {
      "primary": "けんぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
