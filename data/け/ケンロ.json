        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東　ゆだん大敵西　ゆうれいの浜風　東のは意義顕露なり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "両箇は彼の見る目の顕露なるに気怯せる様子にて、先を争ふ如く足早に過行きぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            }
          ]
        }
