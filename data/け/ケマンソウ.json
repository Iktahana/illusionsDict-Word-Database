        "examples": {
          "standard": [
            {
              "text": "春になると、庭の片隅でハートの形をした華鬘草が可憐な花を咲かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "華鬘草のピンク色の花は、まるで小さな袋から雫が垂れているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母は華鬘草の育て方が上手で、毎年たくさんの花を楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "菫、苧環、櫻草、丁字草、五形、華鬘草の類は皆此方に栽ゑて枕元を飾るべし。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓に活けられた桃色の美しい繊麗な花も私の旅情を引立てたが、華鬘草と云ふ花である事を若くてお優しい岡田夫人から教へられたのも、嬉しい思ひ出の花となるであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
