        "examples": {
          "standard": [
            {
              "text": "「もっと色々な場所へ行って、見聞を広めるべきだよ。」先生はそう言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は海外留学を通して、見聞を広める絶好の機会を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "読書は、家にいながらにして見聞を広めることができる素晴らしい手段だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そいつはまあ無い日の方が多いけれど、無ければ無いで公園を散歩する、スポーツを見物する、友達のところからオートバイを借りて来て矢鱈に街中を駆け廻つて、気分を晴し、同時に見聞を広める……。",
              "citation": {
                "source": "東京駅にて感想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな意味もあって、私は太ってすっかり出無精になった妻を仕事や旅行にも引っぱり回し、私と同じように見聞を広める機会を与えるようにしている。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行は確かに見聞を広める。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
