[
  {
    "uuid": "f1151114-dd58-5b29-aa21-f50506ad1f30",
    "entry": "敬意",
    "reading": {
      "primary": "けいい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
