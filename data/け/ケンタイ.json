    "definitions": [
      {
        "index": 1,
        "gloss": "weariness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "漸くにして彼等も倦怠を覚えてゐる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等さへまた倦怠に入りつゝある昨今、芸術界が経済学だの歴史だのといふことを気にしはじめてゐることは、随分ありさうなことで、そして同情さるべき事情である。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよ、芸術とは云つてみれば人類の倦怠を医する役を持つてゐるといへばいへる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてなんとなく空虚と倦怠を感じると同時に妙な精神の不安が頭をもたげて来る。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は倦怠を観念して生きてゐるのだよ、煙草の味が三通りくらゐにする。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井荷風が『歓楽』のうちで「得ようとして、得た後の女ほど情無いものはない」といっているのは、異性の双方において活躍していた媚態の自己消滅によって齎らされた「倦怠、絶望、嫌悪」の情を意味しているに相違ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "漠とした倦怠にうち沈みながら、少年が窓に凭れて、ぼんやりしてゐることがある。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "随つて、芥川氏の智の視野に映じてくる処のものも、人生の、若しくは人間の悲哀、苦悶、憂鬱、寂寥、倦怠、幻滅――要するに暗き世の姿である。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って見るせいか、子供等の顔にはどこかに倦怠の影がうかがわれた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに比べると低地の草木にはどこかだらしのない倦怠の顔付が見えるようである。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生島はその年の春ある大学を出てまだ就職する口がなく、国へは奔走中と言ってその日その日をまったく無気力な倦怠で送っている人間であった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれを助けてやるというような気持は私の倦怠からは起こって来ない。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという倦怠、なんという因循だろう。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労または倦怠が一たんそうしたものに変わったが最後、いつも私は終わりまでその犠牲になり通さなければならないのだった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから昼間は阿片喫煙者のように倦怠です」　とＫ君は言いました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩春の午後の日が倦怠に似た感情で山腹を照らしてゐるとき、なんといふ靜かさでそれは咲いてゐたらう！",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだのに、この瑠璃は終日溪を飛去らず、自ら自らの聲をたのしんでゐるやうに永い午後の倦怠を歌つてゐる。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し一時間前の倦怠ではもうありませんでした。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上長々しい前置きによって私は多くの読者の倦怠を招いたであろうと思う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれを逐条ここで述べることは私の任務でないのみならず、いたずらに読者の倦怠を買うに過ぎないであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれがみんないかにも迷惑そうな倦怠しきった表情をしているのである。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような場面の繰り返しが多すぎて倦怠を招く箇所が少なくない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕をこまぬいて頭を垂れ、ぼんやり佇んでいようものなら、――一瞬間でも、懐疑と倦怠に身を任せようものなら、――たちまち玄翁で頭をぐゎんとやられて、周囲の殺気は一時に押し寄せ、笠井さんのからだは、みるみる蜂の巣になるだろう。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一種の楽器のあまり長い独奏は聴者の倦怠をきたしやすい。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで倦怠を起こさせないためには演奏者は実に古今独歩の名手でなければならないわけである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこれはたとえて言わば簡単な唱歌の同じ旋律を繰り返し繰り返し歌うようなものであって、同じものが繰り返さるることによって生ずる一種の味はなくはないであろうが、しかしこういうものばかりが続いてはおそらく倦怠を招くに相違ない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――二月二十一日（月曜）　おすみ君も眠られなかった由、十二時頃昼けんたいの食事をしてから、三時近く、Ｙと二人で出てゆく。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十日（金曜）晴　朝昼けんたいの食事が終りかけて居たところに、『婦人の国』の富沢来。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　いつそ共（みんな）そぎやんいうとるけんたい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よね　　それがくさい、此ん前、米ば積み出す時、ムツシユウ・真壁の握らせ方が足らんだつたけんたい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
