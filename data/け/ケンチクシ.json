    "definitions": [
      {
        "index": 1,
        "gloss": "authorized architect and builder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
