        "examples": {
          "standard": [
            {
              "text": "景気の急激な悪化を受けて、会社は新規店舗の出店計画変更を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「山の天候が怪しくなってきたな。ガイドの指示に従って急遽計画変更だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ユーザーの要望を取り入れた結果、アプリのUIデザインに大幅な計画変更が生じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし私は、この計画変更にも持久戦争に対する予感が無意識のうちに力強く作用していたことを認めます。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この計画変更が知られることを好まないので他の大学に移ってハルデルウェイク大学で医学の学位を得た。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが突然の計画変更を引き起こし、フェンウィックを動かしたものだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
