    "definitions": [
      {
        "index": 1,
        "gloss": "\"awakening of insects\" solar term (approx. March 6, the day on which hibernating insects are said to come out of the ground)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "啓蟄の季節が来たのだろう。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓蟄て間のない小蛇が、井戸端の湿地に、灰白い紐のように延びていたが、草履を飛ばせ、跣足となり、白い蹠をあらわしている死骸の染八の、その蹠の方へ這い寄って行った。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一太陽年を太陽の黄経に従って二十四等分し、その各等分点を、立春、雨水、啓蟄、春分、清明……という風に名づけたのである。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜥蜴以下｜啓蟄の虫くさ／″＼なり昭和六年三月十三日　東大俳句会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓蟄や日はふりそゝぐ矢の如く三月十一日　草樹会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに鉱毒被害深さ八九寸より三尺に渡り候田圃には、さらに陽気の立ち登るを見ず」二月の啓蟄、三月の穀雨と読みたどって、「小満四月、中の節。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
