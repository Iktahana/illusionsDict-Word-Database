[
  {
    "uuid": "b4617b3a-217c-5bb9-9cb7-12967aea6989",
    "entry": "決定",
    "reading": {
      "primary": "けってい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
