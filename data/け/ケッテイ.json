    },
    "definitions": [
      {
        "index": 1,
        "gloss": "decision",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "云へば平凡なこととなるけれど、あれやこれやの作品が、その読む人の人格といふ点で関連し合ひ、ひいては文学一般の了得が、その人なりに満足され、つまり、競技に勝つだけでなく、そのフォルムも自分にとつて決定的である筈のものが最後的に探索されねばならないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげよ我等の日章旗人みな愁眉をひらくの時わが戰勝を決定してよろしく萬歳を祝ふべし。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私たちは、それを決定的な汚点だとは、ちっとも思いません。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、私は今、神が在る無いを唯決定しさへすればいいといふ所存ではない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切は絶望的に決定されてる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの湿気が全くなく、常に明るく乾燥した空気の中で、石と金属とで出来た家に住んでる西洋人らに、日本の俳句が理解されないのは当然であり、気象学的にも決定された宿命である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論その間ぎわの数日の気温の高低はかなりの影響をもつには相違ないが、それにしてもこの現象を決定する因子はその瞬間の気象要素のみではなくて、遠くさかのぼれば長い冬の間から初春へかけて、一見活動の中止しているように見える植物の内部に行なわれていた変化の積算したものが発現するものと考えられる。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃になって、自分に親しかった、そうして自分の生涯に決定的な影響を及ぼしたと考えらるるような旧師や旧友がだんだんに亡くなって行く、その追憶の余勢は自然に昔へ昔へと遡って幼時の環境の中から馴染の顔を物色するようになる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、いま、決定するのは、あなたがた、讀者である。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤獨だから酒を飮むのか、酒を飮むから家の者たちにきらはれて自然に孤獨の形になるのか、それはおそらく、兩の掌をぽんと撃ち合せていづれの掌が鳴つたかを決定しようとするやうな、キザな穿鑿に終るだけの事であらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間一髮に於いて、狸の悲運は決定せられた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私たちは、それを決定的な汚點だとは、ちつとも思ひません。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼には、彼の仲間の留學生たちに對する自己嫌惡にも似た反撥もあり、明治三十七年、九月、清國留學生のひとりもゐない仙臺醫學專門學校に入學するのでありますが、それから二箇年間の彼の仙臺に於ける生活は、彼の全生涯を決定するほどの重大な時期でありました。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、一綴音を明瞭に発音するに必要な時間に一定の制限があるとすれば、事柄はほぼ決定してしまうはずである。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの問題の決定に必要な十分な海洋観測の材料がないために問題はそのままに問題として残され、やがていつとなく忘れられていた。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "転向の原因、勢力消長の決定因子が徹底的に分らない限り、一時間後の予報は出来ても一昼夜後の情勢を的確に予報することは実は甚だ困難な状況にあるのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより何と何とを一対として考えるかは絶対的には決定されていない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで多くの場合には各自の意見を参酌し折れ合って大体の価値を決め、そうして皆が十分の責任を負うというだけの自信を得た上で及落を決定する。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の学者がそれについて何とかいうのを待ってその鼻息を窺ってから決定した方がいい、ということになる恐れがある。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでただ現在の重量や温度その他の外界条件一切を羅列しても一条の弾条の長さは決定するものではない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその二つの世界の限界を定めようとする時にドーミエーやゴヤやロートレークの或る作物をいずれの領分に配していいかを決定するのに迷うのである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして簡易な解析と手軽な実験によって問題の大きい輪郭を明快に決定するという行き方であったように見える。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし星学者が日蝕を予報すると同じような決定的な意味でいうなら、私は不可能と答えたい。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自然現象中には決定的と統計的と二種類の区別がある事に注意を促したい。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってすべての現象を決定的に予報しようと努力して来た。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "決定的あるいは統計的の予報が可能であるとした場合に、その効果如何という事は別問題である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題に対する国民や為政者の態度はまたその国家の将来を決定するすべての重大なる問題に対するその態度を覗わしむる目標である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたでいくら心配してもお母さんがあれでは駄目だ」　これが台所会議の決定であったらしい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は終日、彼女にあたえられた部屋で過去の瞑想にふけっているようであった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崖の上の端近く、一高の学生が一人あぐらをかいて上着を頭からすっぽりかぶって暑い日ざしをよけながら岩波文庫らしいものを読みふけっている。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
