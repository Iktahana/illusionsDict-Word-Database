[
  {
    "uuid": "2b52189e-fb09-5425-a9c7-b8eaee95c2e1",
    "entry": "血気",
    "reading": {
      "primary": "けっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
