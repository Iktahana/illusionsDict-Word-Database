    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aphorism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
