[
  {
    "uuid": "fa3caa1d-f605-56d7-b56f-54249487f4c5",
    "entry": "警句",
    "reading": {
      "primary": "けいく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
