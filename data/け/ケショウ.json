[
  {
    "uuid": "b2d8c5b2-68c5-5729-9ba4-864d94613eb9",
    "entry": "化生",
    "reading": {
      "primary": "けしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
