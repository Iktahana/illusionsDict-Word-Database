  {
    "uuid": "25e0cb54-b430-5e04-8eda-22cc960816db",
    "entry": "健啖",
    "reading": {
      "primary": "けんたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
