      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gluttony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日頃健啖なのに、下の女の児は一杯食つた切りで、「御馳走様」と云つて、サッサと寝床にもぐり込んだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお流れをみんな健啖な道化師の玉が頂戴するのであった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人も健啖だったが、画家の良人はより健啖だった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日博士は生来の健啖に任せて羊の炙肉をほとんど一頭分も平らげたが、その後当分、生きた羊の顔を見るのも厭になったことがある。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が笑うと、「健啖だなあ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に小太郎の健啖ぶりは、痛快と云うよりも、親の眼からは、あの小さい身体のどこへはいってしまうのかと、ハラハラするほどで、スープと肉と、その後のトルヴィルというケチャップで、色をつけた鳥めしのような前川家自慢の料理を、大きい皿でおかわりをして喰べている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれお目にかゝつた時お話しいたしたいと存じますが、爽々しい秋風が銀座のペーヴメントに訪れる頃には、それこそほんたうに健やかな健啖家となつた貴女が私の拵へたキモノを着て初秋の微風のやうに……などと、もう私ははつきりとそんな夢を描いて居るのですわ。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して好文會には、下戸多く、其の代りに健啖家多し。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ頗る健啖家であった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この腕白猫めは頗る健啖家で、少とやそっとのお裾分では満足しなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから以後著るしく健康を損じて、平生｜健啖であったのが俄に食慾を減じ、或る時、見舞に行くと、「この頃は朝飯はお廃止だ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃｜健啖な大熊老人は、それ等の届けものの食料品を、とに角｜一と通りは味わってみるのであった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それを炙ると、新鮮な肉からは、香ばしい匂いが立ち、俊寛の健啖な食欲をいやが上にも刺激する。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の健啖10・22（夕）　話はずつと古くなるが、伊太利の詩人ダンテが、ある時カアネ・デラ・スカラ家の食事に招かれた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、これから一つ詩人の健啖を祝さうぢやありませんか。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた方は私の健啖のいいのに吃驚なすつていらつしやるやうですが、私はまた当家の御主人の胃の腑の広いのに驚嘆してゐるやうな始末で。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "語を寄す、世上の健啖家、頓智さへよかつたら、諸君は六人分の飯を食つたつて少しの差支もない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は健啖、あまりに健啖だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、健啖家のＴ―は、肺病を患ってから、背骨の丸くなった背を一層丸くして、とめどもなく椀を替えながら苦笑した。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の主観のなかで甘えると、知性は忽ち痲痺してしまうところを見れば、知性というものの本質は健啖であって、ひろいつよい合理的な客観力を、養いとして常に必要としていることも理解される。",
              "citation": {
                "source": "知性の開眼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午は少壮者が健啖を競ふので、特に多く準備した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り料理を平げさすと、二人とも中々健啖だった。",
              "citation": {
                "source": "魚河岸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は健啖な彼を眺めながら子供のように微笑していた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車を四馬路に返して杏花楼で上海一の支那料理の饗応を受けたが、五十｜品からの珍味は余りに饒きに過ぎて太半以上｜喉を通らず、健啖家の某某二君も避易の様子であつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか塩けのある船の食事を健啖に平げて、つまり、はじめて――、数年ぶりの休息を取りもどしていたのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は病人の私から見ると、いずれも不思議な程健啖だった。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また小食の人も健啖家も、肉を注文すれば同じ分量を授けられる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "多食と美食とで豚のように肥え太りながら、老来ますます健啖で、二三日に亘る長夜の宴にも、最後まで踏み止まるだけの力を持っていました。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "スエ子けんたんで愉快。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
