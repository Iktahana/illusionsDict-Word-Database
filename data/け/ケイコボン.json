    "definitions": [
      {
        "index": 1,
        "gloss": "practice book used in jōruri and nagauta",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなたは稽古本なんか出して、何だか印をつけたりして、きざだったわね。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、校長と同じく日本橋五丁目の上るり本写本師、毛利金助に稽古本を注文していた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平もそれらの稽古本を開いて見ることもあり、古い江戸の匂いをかぐような気がして、民衆の間から産まれた芸術だというのと、声調が長唄ほどうわずった騒々しさがないのとで、時には聴く気にもなるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉は近くの下寺町で稽古場をひらいている竹本組昇に月謝五円で弟子入りし、二ツ井戸の天牛書店で稽古本の古いのを漁って、毎日ぶらりと出掛けた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉は商売に身を入れるといっても、客が来なければ仕様がないといった顔で店番をするときも稽古本をひらいて、ぼそぼそうなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお校長の驥尾に附して、日本橋五丁目の裏長屋に住む浄瑠璃本写本師、毛利金助に稽古本を註文したりなどした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉は近くの下寺町の竹本｜組昇に月謝五円で弟子入りし二ツ井戸の天牛書店で稽古本の古いのを漁って、毎日ぶらりと出掛けた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売に身をいれるといっても、客が来なければ仕様がないといった顔で、店番をするときも稽古本をひらいて、ぼそぼそうなる、その声がいかにも情けなく、上達したと褒めるのもなんとなく気が引けるくらいであった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下寺町の広沢八助に入門し、校長の驥尾に附して、日本橋筋五丁目の裏長屋に住む浄瑠璃本写本師、毛利金助に稽古本を註文したりなどした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじような理窟ですけれども、これが謡の稽古でもして、熊坂や船弁慶を唸るのならば格別の不思議もないのですが、清元の稽古本にむかっておかる勘平や権八小紫を歌うことになると、どうもそこが妙なことになります。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵双紙屋というものは今ではまったく亡びてしまったが、小説類の小売店は即ち絵双紙屋で、その名のごとくに絵双紙を売る傍らに小説類や浄瑠璃の稽古本を売っていたのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは姉の持っている稽古本をよみ尽くして、さらに太喜次さんのところから長唄の稽古本を借り出して来て、無茶苦茶に濫読した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪結いさんの娘からも常磐津の稽古本を借りて来て読み明かした。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁には三味線が二梃ばかりかかつて本箱の上には稽古本が二冊位のつてゐた。",
              "citation": {
                "source": "石川啄木と小奴",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古本も置いてある。",
              "citation": {
                "source": "燈火",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした節制のない家庭だから、その姉さんたちは赤いしごきを〆めて、三味線の稽古本など持って、遊芸を習いに通ったりしていたが、遂に家はつぶれ、私の中学時代にその姉さんは三次の料亭に芸者に売られた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがまだ稽古本のはいったつばくろぐちを抱えて、大門通を住吉町まで歩いて通っていたころ、芳町には抱え車のある芸妓があるといってみんなが驚いているのを聞いた。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗に洗つた足の指が、青竹色の吾妻下駄の鼻緒に揃つて、小砂利を輕く蹴かへす――肩には日傘、三ツ杵の白ぬき、または三ツ柏や瓢箪の染めてある稽古本入れのつばくろぐちをかかへてゐる。",
              "citation": {
                "source": "下町娘",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "（つばくろぐちは稽古本を入れる袋）　いま隣室の「女人藝術」編輯室には、いつものみんなの外に珍らしいお客さんたちも見えて、襖一重むかうでは、將來の女人としてのさま／″＼な希望が机の上に、人の口に盛んである。",
              "citation": {
                "source": "下町娘",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、釘抜部屋と背中合わせになっている中二階で、その禿は、稽古本を見ていたのだが、どうも小式部さんとしか思われない声で――可遊さん、そんな早く回しちゃ、眼が回ってならないよ。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古本に過ぎぬから、いくら種類があつても、校訂には役に立たぬが、並べて変遷をみるのは面白い。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四書や、唐詩選・蒙求の類も、僅かながら、此人の稽古本として残つてゐる。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に祭文語りの持つ稽古本や、大阪板の寄せ本などを見ても、大抵はがきやみと書いて居る。",
              "citation": {
                "source": "餓鬼阿弥蘇生譚",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古本で見馴れた仮名より外には何にも読めない明盲目である。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "清元の師匠のもとからの帰りででもあると見えて、二人とも稽古本を小脇にかかえながら橋を渡って来る。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処には貸本の小説や稽古本が投出してある。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと蘿月は何かその辺に読む本でもないかと思ひついて、箪笥の上や押入の中を彼方此方と覗いて見たが、書物と云つては常磐津の稽古本に綴暦の古いもの位しか見当らないので、とう／＼釣ランプを片手にさげて、長吉の部屋になつた二階まで上つて行つた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
