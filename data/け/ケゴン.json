    "definitions": [
      {
        "index": 1,
        "gloss": "avatamsa (flower adornment, as a metaphor for becoming a buddha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "華厳経に万物相関の理というのが説いてあるそうである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗きに華厳の滝をのぞきつ七時｜過中禅寺湖畔の旅籠屋に入る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は華厳の滝壺に下りんとて長塚も我もいさみきおう。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に根岸庵を訪いて華厳の滝壺にて採りたる葉広草、戦塲が原の菖蒲の花など贈る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また河水が流れ込んでも海が溢れない訳を説明する華厳経の文句がある。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文殊菩薩がある日、善財童子（文殊は智慧の象徴、善財は求道者、両者とも、華厳経中の人物です）に向って、「おまえ、これから世界中を探してみて、もし、薬にならないような草が在ったら持って来い」。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの呼吸を説明しているのが華厳経という経の主旨で、この宇宙一杯に拡がる網を帝釈網（諸法重々無尽なること帝釈天の天宮に掲げられたる宝網のごとし）と言います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代に行われた仏教宗派は、主に華厳宗、律宗であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの絢爛さは、また華厳教義の華やかさでもありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇を右の目的に運んで行く思想としては、法華、華厳、般若経等取交えられて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の根岩角に手をかけ、足を踏みしめて、ようよう飛沫雨のごとき中に下り立ちて、巨巌の上へ登り、海内無双の大瀑布、華厳の雄姿を眺めた時には思わず快哉三呼。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "華厳の滝が涸れたところで、私は格別、痛嘆しない。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その意味で、華厳の滝を推す。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「華厳」とは、よくつけた、と思った。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "華厳の滝や、吉野山など、殊にも色彩が見事で、いまでもあざやかに記憶に残っているが、時事の画片としては、やはり、旅順港封鎖、水師営会見、奉天入城など、日露戦争の画面が圧倒的に多かった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景といふものは、永い年月、いろんな人から眺められ形容せられ、謂はば、人間の眼で舐められて軟化し、人間に飼はれてなついてしまつて、高さ三十五丈の華厳の滝にでも、やつぱり檻の中の猛獣のやうな、人くさい匂ひが幽かに感ぜられる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「華厳」は、よかった。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あなたの「華厳」を読み、その興奮から、二十年間の抑制を破り、思い切って手紙を書いたと前に申し上げましたが、実は、その興奮の他に、私の此の行きづまりをも訴えたかったからでありました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「華厳」を、あれから、もう一度、ゆっくり読みかえしてみました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の華厳の滝のところは、ただもう、にこにこしてしまいました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは身のつまりで、遁げて心中の覚悟だった、が、華厳の滝へ飛込んだり、並木の杉でぶら下ろうなどというのではない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『恋』は華厳の寂寞に蒸し照る空気うち煽る。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり深く考えると、人生の行き止まりは三原山と華厳の滝以外になくなるんだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『華厳経』に一切宝中如意宝珠最も勝るとあり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "直下せずして、曲折するが、日光の華厳滝よりは遥に高き也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "華厳の下あたりまでその路を開いたら、更に新らしいすぐれた渓谷が展開されて来はしないか。",
              "citation": {
                "source": "あちこちの渓谷",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "大谷の谷もあの深潭から華厳の瀑壺まで行つた。",
              "citation": {
                "source": "水源を思ふ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは華厳の『十地論』どころの騒ぎではない。",
              "citation": {
                "source": "存在",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "華厳は議論だが――抽象究的で説明で一概に推して行つた議論だが、法華経はもう議論ではなかつた。",
              "citation": {
                "source": "谷合の碧い空",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "△　華厳を読むと、いろいろと面白いことがあるが、先づ打たれるのは、雑多紛々の人生である。",
              "citation": {
                "source": "くつは虫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
