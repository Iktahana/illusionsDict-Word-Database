          "standard": [
            {
              "text": "慶應義塾大学の学園祭は、毎年多くの来場者で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は慶應義塾大学の経済学部に合格し、春から東京で一人暮らしを始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の父も慶應義塾大学の出身なので、母校意識が強いんですよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現に此の十幾年ばかりの間に、幸徳が一度早稲田大学で講演したのと、堺が一度慶應義塾大学で講演したのと、二度だけしかない。",
              "citation": {
                "source": "遺言",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
