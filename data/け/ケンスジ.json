        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪の上に残った剣筋が、その一撃の激しさを物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "斬撃の後、空中に青白い剣筋が残っているかのように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の太刀筋は美しく、空間に正確な剣筋を描き出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
