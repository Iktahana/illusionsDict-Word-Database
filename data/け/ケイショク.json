[
  {
    "uuid": "8381398b-ce81-56a1-b26d-948699937045",
    "entry": "軽食",
    "reading": {
      "primary": "けいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "light meal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "差し当たっての問題は、ここで僕らは早めの昼食を摂るか、それとも飢え死に覚悟でニューヘイヴン駅構内の軽食堂までたどり着かんとするか。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "入って右側に売店とビュフェがあり、文具、日用雑貨、菓子、飲料などを買ったり、ホットドッグ、スパゲティ、ラーメンといった軽食をとることもできる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チタへつく午前十時頃、ブフェット〔軽食堂〕でハム、ピローシュカ〔あげパン〕、パンその他買う。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売柄よく旅行をしますが、仕事前に出される軽食と言うと僕は必ず蕎麦を注文します。",
              "citation": {
                "source": "麺くひ",
                "author": "桂三木助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は軽食堂形式で提供されていたとのこと。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モスク※夕刊」の編輯局のほかに印刷労働者のクラブも出来ているらしく、入口から左手の奥、棕梠の鉢植ごしに軽食堂がある様子だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして軽食の膳立であろう、甘そうな品々がならべてあった。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく庭で軽食を食っているような気がした。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽食の後で上等の珈琲とリキュー酒の振舞がすむと二人の客は庭と図書室とそれから家政婦――女は少なからざる威風を備えた、じみなしかし美貌の持主で陰府の聖母というような感じがした――とに紹介された。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "海沿いに並ぶ乾物屋で土産などを物色しながら、海鮮が大々的に売り出されていないことに首を傾げ、自転車の客が見込めるだろうに、それらしい軽食処があまり見当たらないことを不思議に思った。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ルクレティウス）彼らは食事と食事の間に軽食をとった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ドルのオール・アメリカン・ホットドッグは道ばたでの軽食の基本であり、パイプライン・バーガーは御馳走と言っていい出来ばえだった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージのところとは、マーモ・アンド・ケアワエの角にある軽食と雑貨の店だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "受けとるカウンターだけの軽食の店へいき、紙コップにコーヒーを買った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日系の軽食堂に、ぼくたちは入った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽食堂を出て、ぼくたちはスーパー・マーケットまでひきかえした。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝と昼にカウンターで出す朝食と昼食、そしてそれ以外の時間での軽食が、この店の商いの中心だ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんかん照りの駐車場にフォードを停めたぼくは、軽食堂をさがした。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へまっすぐ帰り、軽食、入浴。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに召使いたちが軽食を準備していた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は体に隠しているから、こんな雑踏で大金を出したら危なすぎる」　船長がうなずき、軽食を勧めた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
