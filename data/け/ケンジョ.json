    "definitions": [
      {
        "index": 1,
        "gloss": "audience seating (noh theater)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スカンボの花などもさっぱり見所のないもののように思っていたが、顕微鏡で見るとこれも実に堂々たる傑作品である。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し見所があると思ったのに牛につっかかれたくらいで職務も忘れて遁げるなんてもう今日限り免官だ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は前に仏蘭西の公使館づきであったから、勇美子は母とともに巴里に住んで、九ツの時から八年有余、教育も先方で受けた、その知識と経験とをもて、何等かこの貴公子に見所があったのであろう、滝太郎といえばかねてより。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう女としての見所もない大あばずれだと私達はきいて居た。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日の『タイムス』紙上を見ると、劇評家ウォーナック氏はこの一節を激賞して「この大悲劇中の見所は千代がわが子を残して去る一｜刹那にして、エデー嬢は悲劇俳優として大なる将来を有することを明かに示せり」といっていました。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど晴子という女は、芸者にしては見所がある、心掛けのいい奴だと、あの人が感心するようだったら、そこは若ーさんも肚のすわった男だから、この先きお前はんのためにも悪いはずはないにきまっている。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "朔造氏は幕に這入ると、装束のまま楽屋の畳の上に平伏して息も絶え絶えに噎せ入ったが、その背後から翁が、「ええい……このヒョロヒョロ弁慶……ヒョロヒョロ弁慶……」　と罵倒する大声が、舞台、見所は勿論、近隣までも響き渡ったので、観衆は皆眼を丸くして顔を見合わせていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと思って見所から楽屋を覗きに行ったものであったが、その時の翁の声と顔付の恐ろしかった事を想起すると、今でも肌に粟を生ずる思いがある。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声がトテモ大きくて烈しいので舞台から見所まで筒抜けに聞こえた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字呉れたところを見ると、多少の見所を彼はわたしに期待したのだつたかも知れないが何しろ肝心の師匠は正銘の精神病者だつたといふんだから、飛んでもない仕儀である。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観の作品には少しは見所のあるものもあらうからである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその少しばかりの見所のある作品で奇怪なことには、画壇の大御所的地位を保つてゐるといふことが更に不審といへるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊多摩刑務所で同志佐野博の母親が接見所で息子と話が終つたとき、同志佐野の手をギューッと握つた。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法師の意は、ありのままの寸法に書いては見所なき故、わざと過分に書くといったのだが、実際それぞれの物どもも、活溌に働く最中には、十二分に勢いも大きさも増すに相違ない。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "木犀の花はぢぢむさく、古めかしい、金紙銀紙の細かくきざんだのを枝に塗りつけたやうな、何の見所もない花で、言はばその高い香気をくゆらせるための、質素な香炉に過ぎないのだ。",
              "citation": {
                "source": "木犀の香",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の雨のゝちの月こそ見所あれ、槇、しばなんどの、木の葉にきらめきて、こずゑ葉末に真珠の玉見ゆ。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなお前さんとは比べものにならないほど、至つて小さな、どこに見所もない、けちな虫だが、でも、私はお前さんのやうに唯もうやきもきと自分ひとりのことばかりにかまけてはゐないぜ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の他の部分は日に焼けてはいたが、薄皮だけにかえって見所があった。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥坐舗の長手の火鉢の傍に年配四十｜恰好の年増、些し痩肉で色が浅黒いが、小股の切上ッた、垢抜けのした、何処ともでんぼう肌の、萎れてもまだ見所のある花。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体全体菊というものは、一本の淋しきにもあれ千本八千本の賑しきにもあれ、自然のままに生茂ッてこそ見所の有ろう者を、それをこの辺の菊のようにこう無残々々と作られては、興も明日も覚めるてや。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレハ大方｜馬見所の家根で、土手に隠れて形は見えないが車馬の声が轆々として聞える。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いのに似合ぬ怜悧な軍人だ、さういへばどこか見所がありさうな顔をしてるて。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "げん／＼の花盛り過ぎて時鳥の空におとづるゝ頃は赤き薔薇白き薔薇咲き満ちてかんばしき色は見るべき趣無きにはあらねど我小園の見所はまこと萩芒のさかりにぞあるべき。",
              "citation": {
                "source": "小園の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "其でも、腰拔でも譯がわからぬでも、日本が御互に眞面目であると言ふならば、眞面目であると云ふならば、ひよつとしたならば此國を持ち堪へることが出來るかも知れぬが、馬鹿なくせに生意氣で、惡るい方へばかり上手になつたと云ふに至りましては、何處までも見所は無くなつたのである。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛沼博士は自分に都合のいい人間は、よく可愛がるが、都合の悪い人間は排斥するし、昨日までよくても、今日はもう悪くなるという風だが、笠神博士は自分の悪口をいうような人間でも、学問の上で見所があれば、どこまでも親切に面倒を見る。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之でも庭｜中での一番立派な花を切つた積ですが斯んなに見所がありません」と云つて晶子の手に取らせ、そして「ロダンの承諾を得て其内御招待を致しますから必ず今一度｜入らつしやい」と云はれた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はなかなか見所があるですぞ――」　私がびっくりしているのも構わずに「うむ、なかなか観察が鋭い、君ならば或いはわしのいうことがわかってくれるかも知れんナ――どうじゃ、わしの研究室に来て見ないかね」「いや――、しかし……」「遠慮は無用。",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは『ホトトギス』の関係から広く文士連を招待されたので、見所も満員となった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きいたらうれしいけんじょ」きいたらうれしいけれど。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けんじょう、という風な力点よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
