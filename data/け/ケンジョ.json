[
  {
    "uuid": "b81d8f2a-cecb-56bd-82d1-60265f33d1a3",
    "entry": "見所",
    "reading": {
      "primary": "けんじょ",
      "alternatives": [
        "けんしょ"
      ],
      "is_heteronym": false
    },
    "grammar": {
