      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "authority",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかもさうした純潔の詩人の生涯こそ、かの音楽家のそれと等しく、人生の最も神聖なる住宅、即ち道徳及びその他の感情生活の世界を支配する最高至美の権威でなければならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術の権威のためにも、マルキシズムにかわる新しい認識論を提示しなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "権威ある批評をしようと思ったら、まず、ご自分でも或る程度まで製作の苦労をなめてみる事ですね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は校長の権威のために、道場の方には我不関でゐようと考へてゐたのに、遂に昼食時間道場の方に足を運んだ。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者とも知れぬ権威の命令で、自分は未来｜永劫この闇の中に封じ込められてしまったのだと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "信州の山岳の中でも、御嶽や駒ヶ岳などは、古くから多くの登山者を有していたが、宗教が権威を失った今日では、新しい登山家は、種々の理由からして、日本アルプスの中でも、殊に飛騨山脈を選び、飛騨山脈の中でも、最高点の槍ヶ岳や穂高岳の特色ある火成岩の大塊は特に多くの人々を引きつけているらしく思われる。",
              "citation": {
                "source": "上高地風景保護論",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分でも、自分が今、しかかる素振りに驚きつつ、彼は権威者のように「出せと云ったら、出さないか」と体を嵩張らせて、のそのそとみち子に向って行った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって「いき」は無上の権威を恣にし、至大の魅力を振うのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのような権威は今後ますます少数になるだろうと思われる。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると止むを得ず間口の広い方の権威者と間口が狭くて奥行ばかり深い権威者か二つに一つよりしかないような場合がないとも限らない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような云わば一元的 one dimensional な権威といえども学修者研究者にとって甚だ必要なものである事は勿論である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べた二種の権威者は丁度これに似たものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも学術上の権威者の一つの役目は丁度旅行者に対する案内者の役目である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人として権威の価値は明らかであるが、同時に案内人の弊害もある事は割合に考える人が少ない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」自分は同行者の温順な謙譲な人柄からその人がベデカの権威に絶対的に服従してベデカを通しての宮園のみを鑑賞する態度を感心もしまた歯がゆくも思った。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生にとっては教科書や教師のノートは立派な権威である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの権威を無批判的に過信する弊害は甚だ恐るべきものでなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史上の遺蹟や古美術品の案内や紹介ならばともかく、科学上の権威においてはそのような ambiguity はあり得べからざる事ではないかという人があるだろうが、不幸にして科学上の事柄でも畢竟五十歩百歩である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "権威というのは元来相対的なものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の生徒の科学知識に対しては中等教育を受けた者は大抵は権威となり得る資格があるはずである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学卒業者はその専門では先ず社会一般の権威となり得るはずである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学者と称せらるるものなどはその修むる専門の知識においては万人の権威であるべき訳である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからばあらゆる大学教授の学殖はすべて同一であるかというに、そういう事は不可能であるが、同じ物理学の中でもそれぞれの方面にそれぞれの権威があってこれらの人々の集団が一つの理想的な権威団を形成すると考えてよい。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この権威の財団法人といったようなものの権威の程度はどのようであろう。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり各部門においては現在既知の知識の終点を究め、同時に未来の進路に対して適当の指針を与え得るものが先ず理想的の権威と称すべきものではあるまいか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "移民法もなかなかむつかしいし……」「ベンゲットの他あやんが比律賓へ行けんいう法があるかい」「あるかい言うたかて、法律がそうなってるんやから、仕方ない。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは、陛下のお目になみだのやどったところを、はいけんいたしました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今夜はお客様もあるんだのに……」　と駆けて来た愛子にわざとつんけんいうと、叔父は神経の遠くのほうであてこすられたのを感じたふうで、「おゝ、それはわしがしたんじゃで、わしが掃除しとく。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九郎助、黙る）弥助　だが浅太郎、お前はな、いくら親分の気受けがいいからといって、あんまり年寄のことをつんけんいいなさんなよ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあなたのお顔をはいけんいたしますと、この上おひきとめ申しても、むだのようにおもわれます。",
              "citation": {
                "source": "浦島太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
