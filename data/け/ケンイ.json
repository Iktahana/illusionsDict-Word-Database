[
  {
    "uuid": "08a57093-f189-5e22-8e31-9377a8ac97dc",
    "entry": "権威",
    "reading": {
      "primary": "けんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
