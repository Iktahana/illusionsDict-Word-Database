[
  {
    "uuid": "834f6e5f-4929-53ca-ba7d-66c1d59a7d70",
    "entry": "計略",
    "reading": {
      "primary": "けいりゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
