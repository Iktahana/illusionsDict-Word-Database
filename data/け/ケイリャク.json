    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それほど苦心した甲斐があって、その計略は見ごとに成功した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さんは、きっと何か小細工をして岩見先生に近づき、こんなお手紙を私の父にお書き下さるようにさまざま計略したのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "計略を敵に見すかされてむざむざと討ち死にしたかな。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい計略計略って花田の奴はなにをする気なんだろう。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで、これからがほんとうの計略になるんだが、……おいみんな厳粛な気持ちで俺のいうことを聞け。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢本　　なんという智慧のない計略を貴様は考え出したもんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田　　みんな俺の計略がわかったな。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな児に限って、そりゃきっと夢中になって、お前さんの事なんざ落として、お宝を拾うから、とそのお前さん謀、計略？",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と云ひ掛けて、極めて計略の平凡なのに、我ながら男は氣の毒らしかつた。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかる後二人計略｜合期して泰助をして奇功を奏せしめたる、この処得右衛門大出来というべし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘も響かぬ山家にさえ、寝覚に跫音轟いたが、哄と伊豆の国を襲ったので、熱海における大地震は、すなわち渠等が予言の計略。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京驛を一番で立てば、無理にも右樣の計略の行はれない事もなささうだが、籠城難儀に及んだ處で、夜討は眞似ても、朝がけの出來ない愚將である。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははははは、拙者うまれつき粗忽にいたして、よくものを落す処から、内の婆どのが計略で、手袋を、ソレ、ト左右糸で繋いだものさね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを待受けて囲み撃つという計略であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまんは喧嘩の先手を打って、全達と石田と水野の三人に睡り薬を飲ませる積りで、その計略は成就したんですが、どうした間違いか全真にも飲ませてしまって、これも将棋倒しのお仲間入りをしたので、おまんもはっと思ったが今更どうにもならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あんなにやかましく、こまごま言ってやるのは、わしの、深く考えた上での計略なんだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もうお父さんも計略はしないから、お前もお父さんを信頼して思い切って言ってみなさい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、はじめ、ポローニヤスの朗読劇を、娘可愛さのあまり逆上して、王や王妃に、いや味を言うための計略、とばかり思っていたが、ゆうべまた、よく考えてみたら、どうもそればかりでも無いらしい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットさまひとりが、計略だの曲者だの、駈引きだのとおっしゃって、いかにも周囲に、悪い人ばかりうようよいるような事をおっしゃって、たいへん緊張して居られますが、滑稽だわ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の御胸中にどのような計略があるのかわかったものでない。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窃かに心を寄せるのが「内通」であり、利を啗わせて事を発させるのが「嘱賂を飼う」のであり、まだ表面には何の事も無くても他領他国へ対して計略を廻らすのが「陰謀」である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ若し政宗に陰険な計略が有ったとすれば、思う壺に氏郷を嵌めて先へ遣ることになったのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで笊の目を潜らして、口から口へ哺めるのは――人間の方でもその計略だったのだから――いとも容易い。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）を前置きに、（就きましては御縁女儀、）を場処柄も介わず弁じられよう恐があるため、計略ここに出たのであろう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人影も見えないのは、演義三国誌｜常套手段の、城門に敵を詭く計略。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が伯父様と伯母様の計略におかかりになったのです」「計略に僕が……」「そうです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "外道至極の楽しみ、之に過ぎしと打笑ひつゝ起上りしが、遂に妾が計略に掛かりて、今の仕儀となり果て終りしものに侍り。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫吉は、じぶんのけいりゃくが、うまくあたったので、だいとくいで、馬車よりも先へあるいて行きました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いまごろは、けいりゃくがうまくいったと、とくいになっているにちがいない。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで御返事には、いや、それよりも、いずれ信長が小谷のお城へおしよせてまいりましょうから、そのとき当国のにんずをもよおしてお味方に参じましょうと、そういうごあいさつでござりましたので、あたらごけいりゃくがむやくになったのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
