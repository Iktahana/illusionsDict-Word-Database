[
  {
    "uuid": "e7f367ab-b12a-5424-b7d5-97f7b7906a3d",
    "entry": "嫌疑",
    "reading": {
      "primary": "けんぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
