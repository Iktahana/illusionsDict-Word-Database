[
  {
    "uuid": "750e9d58-45ad-5027-9978-4d36fe8dc2e1",
    "entry": "剣幕",
    "reading": {
      "primary": "けんまく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
