        "examples": {
          "standard": [
            {
              "text": "彼女は、深い色合いの煙水晶のネックレスを身につけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "煙水晶は、その独特な色合いからパワーストーンとしても人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉱物展で、手のひらサイズの美しい煙水晶の原石を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "痩せて蒼い姉娘の方は母親の煙水晶の眼を受け、花やかな、みづ／＼しい妹娘は顎と頤の輪廓を受けてゐた――多分幾分かは柔らか味はついてゐるが、それでもまだ顏付に何とも云はれぬ苛酷なところが表はれてゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の許しを受けてそれを調べると、驚いたことに、それ等は鼈甲のわくに澄明な煙水晶をはめ込んだ物であった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
