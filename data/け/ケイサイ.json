[
  {
    "uuid": "91a02700-d49c-50ff-89df-f1439f8baca9",
    "entry": "掲載",
    "reading": {
      "primary": "けいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
