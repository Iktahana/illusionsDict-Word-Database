[
  {
    "uuid": "13ffdf9a-d573-5025-88ad-61ff1421ad5d",
    "entry": "結集",
    "reading": {
      "primary": "けっしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
