[
  {
    "uuid": "2ddfcfab-80c8-5649-a006-901c3709d465",
    "entry": "欠課",
    "reading": {
      "primary": "けっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cutting class",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてつまらない学課の体操や裁縫や商業の時間は殆ど欠課した。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体があまり丈夫でなく、戦時中の疲労がその頃になって出て来て、私は歩くことさえ苦痛であったから、医者の診断を出して時々の欠課を大目にみてもらっていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり前に云えば、女学校を自発的に中退したのも不真面目かも知れないし、学校中、欠課や欠席をして、映画をみたり、京都や奈良を散策したことはやはり不真面目。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ腐った臓腑だけっか入ってねえんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙う小ましゃっくれてけっからあ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐をあたるとあるから貸せと云ったら渋ってけっかる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がお前、カチヤの奴は鼻の先きで笑ってけっからあ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リリアン」の小鈴に肩入れしてけっかんのやろと図星を指されてぽうっと赧くなり一途に北田が頼もしかったが、肩入れはしてるんやけどナ、わいは女にもてへんのさかい、兄貴、お前わいの代りに小鈴をものにしてくれよ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇、河童、ろくろ首、けっかい等は珍しからず。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――細胞内における分子が相互にケンシテイションをひき起こし、そのけっか仮歪のポテンシャルを得たとすると、これは生命誕生の可能性を持ったことになる）云々。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りおさえるか逃がすか、それはこれからの室内捜査のけっかできまる。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、長戸検事のところへ出むいて、もう一度おとぎばなしをする必要を感じたのだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、二つの新しい発見があった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、結論にたっすることができなかった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、きょうの事件に間にあったのだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで伯爵と船長の間に、もう一度おし問答があったがそのけっか、両者の間に、次のような協定がまとまった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、えらばれた人は、次の十名であった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの穴がなかったら、洞穴は壺のようになっていて、潮が入るにつれ空気は圧縮されるけっか、海水をおしもどし、ある程度いじょうに海水を入れないですむ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、あと三時間ほどすれば、ルゾン号と洋上で出会うことに手はずがととのった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのけっかが、さらに『宇宙の女王』号の救援作業の成功か不成功かをさだめる原因となるのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは、あとに六号艇の艇長ゲーナー少佐が救助されたけっかはっきりした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、隊長テッド博士のはやい命令がよかったことがわかった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっか、本艇では高価なるブラウン管を二十何本、いや三十何本かを、とにかくたくさんのブラウン管をだめにしてしまった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の使者のなかで、一番上席のロバート大佐が、ギンネコ号に使いにいったけっかわかったことについて、一通りの説明をし、そのあとでポオ助教授の肩へ手をおいて、「……そこでポオ助教授から、見おぼえのある『宇宙の女王』号の空間｜浮標がギンネコ号の隅にあったことについて、くわしく話をしてもらおう。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのけっかわしたちの希望どおり、ガスコは、取りおさえられました。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈な砲撃が天蓋にくわえられたけっか、ぽっかり穴があいたのである。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうでもねえが、家でやかましく躾けている子供だから、ひょっとすると持っているの悪いと思って駐在所へ届けっかも知れねえ。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝ら、はア、いくつになると思ってけっかるんだ。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の資本主義は貿易第一主義を奉ずる自由経済の全盛期で、いわば資本主義の青年時代であったが、それですらインドや中国にたいする植民地化の戦争、その戦争のけっかとしての不平等条約と、その不平等条約によって保障された不当な利潤によって先進国の地位が保たれてきたのであった。",
              "citation": {
                "source": "黒船来航",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにいえば、この十進法のアメリカ明治幣制で、「銭」sen が出現するのも、名前のうえまで cent にリンクした向米一辺倒のけっかであろうかもしれぬ。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
