[
  {
    "uuid": "709724b3-16c6-5d27-bd33-1e35e98b9a97",
    "entry": "検挙",
    "reading": {
      "primary": "けんきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arrest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "検挙に次ぐ検挙であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長は犯人を検挙するために、褒美を十円やることを云い渡してあった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十五日の検挙はやる、四月十日の左翼の三団体の解散は喰らわす。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれが詐偽だという事になって検挙され、警視庁のお役人たちの前で「実験」をやって見せる事になった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にはあの村はみんな濁り酒ばかり呑んでゐたのにこのごろ検挙が厳しくてだんだん密造が減るならば清酒の売れ高はいくらかづつ増さなければいけない。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさまたちは密造罪と職務執行妨害罪と殺人罪で一人残らず検挙されるからさう思へ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸徳某｜外二十幾名が不軌を計つたと伝へられ、やがてそれが検挙となつて裁判沙汰に行はれた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "主食と闇煙草の販売を弾圧する旨の声明は、わざわざ何月何日よりと予告を発して、これまで十数回発表されたし、抜打ちの検挙も行われる。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（目撃者の話）――この乱闘現場の情景を目撃してゐた一人、大和農産工業津田氏（仮名）は重傷に屈せず検挙に挺身した同署員の奮闘ぶりを次のやうに語つた。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「流血の検挙をよそに闇煙草は依然梅田新道にその涼しい顔をそろへてをり、昨日もまた今日もあの路地を、この街角で演じられた検挙の乱闘を怖れる気色もなく、ピースやコロナが飛ぶやうに売れて行く。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地元曾根崎署の取締りを嘲笑するやうに、今日もまた検挙網のど真中で堂堂と煙草を売つてゐる一人の闇商人曰く――　警察や専売局がいくら自由市場の煙草を取締つても無駄ですよ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の六月十九日の検挙は、曾根崎署だけでなく、府下一斉に行われ、翌日もまたくりかえされたのだが、梅田でもやはり「警報」が出た。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子がストリート・ガールだから検挙されたのかも知れない――と直感する余裕もなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれ一斉検挙になるだろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、Ｓ署では明朝を期して、一斉に検挙の網を打とうと考えていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村はもと左翼劇団の演出家であり戯曲のほかに小説も書き、劇壇より文壇で有名であったが、思想運動の嫌疑で検挙され、保釈出獄以来執筆は許されず、匿名で「演劇集団」の演出をしているのだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村は左翼運動の嫌疑で、戦争勃発と同時に検挙されたが、保釈で出獄していたのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇器が発見されないために、犯人を検挙する手がかりが全く無い事になった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも普通の家ではないので、Ｆ市外の公園の入口に在る檜御殿と呼ばれた××教の教会堂が、先年の不敬事件に関する信者の大検挙以来、空屋同然になっていたのを自分の名前で買い取らせて、見事な住宅の形に手を入れさせたもので、そこに素敵な自動車や、大勢の女中を雇い込んで女王のように奉仕させた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "風間七郎は、その大勢の子分と一緒に検挙せられた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　検挙した闇の女を警察へ送るトラックであることは、一眼で判った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラックガールの嫌疑で検挙されたのだから、ひとにも言えぬ恥かしい取調べを受けたのだが、処女と判ればもう疑いの余地はなかったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波や心斎橋附近の夜の場所も空しく探したあげく、検挙されたのだろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘が昨夜、仏壇お春たちと一緒に検挙されたとは、むろん北山は知らなかったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたまた今日｜我邦において、その法律の規定している罪人の数が驚くべき勢いをもって増してきた結果、ついにみすみすその国法の適用を一部において中止せねばならなくなっている事実（微罪不検挙の事実、東京並びに各都市における無数の売淫婦が拘禁する場所がないために半公認の状態にある事実）は何を語るか。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結社は北はカヤンガル島から南はペリリュウ島に至る迄相当根強く喰込んでいたが、当局は島民間の勢力争いや個人的反感などを巧みに利用して、着々と摘発検挙をすすめて行った。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく聞いて見ると検挙は大部分島民の密告を利用するのだが、マルクープは其の最も常習的な密告者で、彼の密告によって多くの大ものが捕えられ、老人自身も亦既に相当多額の賞金を貰っている筈だという。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気の近藤勇は、一刻を争ふ場合と考へ、独力新撰組を率ゐて、検挙に向ふことになつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそうなってみると急に驚くほどの女らしさを見せ、けんきょな気持でいろんな面での自分の無知を恥じながら、「私のような、文学のことも政治のことも何にも知らない者でも、それをやっている人を助けることでみんなの仲間入りが出来るというなら、私決心するわ。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
