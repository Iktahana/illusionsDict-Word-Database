  {
    "uuid": "5cfbfa16-f3c4-5105-acd1-25c6d367d26c",
    "entry": "警固",
    "reading": {
      "primary": "けいご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
