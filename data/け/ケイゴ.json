      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "watching (esp. during an emergency)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "定重　　このたび將軍御上洛には海道筋の大小名、いづれも人數をひき連れて、路次の警固をつかまつるとあるに、叔父上のみ御不參とこれあつては、後日の御咎は逃れまい。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果こんなに厳重に警固しているうえは、いくら切支丹でも逃げることは思いもよらないから、願いを聞いてやっても好いと云うことになって二人の縄を少しゆるめてやった。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警固の士は驚いて一方の男を捕えようとすると、その男の体は鳶になってばたばたと縄を解いて空にあがり、ひろ、ひろ、ひろと鳴きながらその上を舞っていたが、機を見て降りて来て彼の鼠を掴んで何処ともなく逃げて往った。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警固の士は呆気にとられてそれを見送った。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同心らが三道具を突き立てて、いかめしく警固している庭に、拷問に用いる、あらゆる道具が並べられた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕におぼえの直江志津を抜き放ち、眼の前なる青竹の矢来を戞矢々々と斬り払ひて警固のたゞ中に躍り込み、「初花の怨み。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間の庭は、織田家の侍八百人余り、勝家の供侍三百余と共に、物々しい警固だつた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく四郎は警固の者四五十人と共に、島原の大江村に渡った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から武器を持った馬賊みたような警固人が、堂々と騎馬隊を作って行くので、知らない者が見ると戦争だかお茶飲みだかチョット見当が付かない。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千倉屋の若い者二人は彼の警固をかねて領ざかいまで附き添って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて滅多に出してもやられないので、代るがわるに警固しているあいだに、あるとき番人の隙をみて、すっぽんは表へ這い出した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年には一旦京都へ上つて歸つた如水と相談して、長政が當時｜那珂郡警固村の内になつてゐた福崎に城を築いた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "本丸は警固大明神の社のあつた跡なので、血の汚を避けて、これも利安に預けてある東の丸に産所をしつらはせたのである。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同心等が三道具を衝き立てて、嚴めしく警固してゐる庭に、拷問に用ゐる、あらゆる道具が並べられた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこうしてお迎いにまいりしからは、道中の御警固つかまつりませいでは……。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、南北両｜奉行所配下の与力同心たちがそれぞれ手下の小者どもを引き具して、万一の場合のご警固を申しあげるという順序でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのおのがたは上さまをご警固まいらせ、そうそうご城中へお引き揚げなさりませい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そもそもがこのあたり隅田川べりのお下屋敷は、殆んど大半が別荘代りを目的のものでしたので、警固の工合なぞも割に簡単な構えでしたが、しかし簡単とは言うものの、榊原大内記侯はともかくもお禄高十二万石の封主です。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御禁中警固、京一円取締りの重任にあるべき所司代詰の役侍が、その役柄を悪用して不埒を働こうとしているだけに許せないのです。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平のお殿さまからのお差し紙でござえますから、きっとまた何か突発したにちげえござんせんぜ」　しかし、案に相違して、そのお差し紙は、あすの吉例上覧お能に、警固のため出頭しろとのご命令書でしたから、ようやく納まりかかった伝六太鼓がまた鳴りかけようとしたとき――、今度はやさしくおとなう声がありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隊はまた坂上のくせ者めがけて逃がさじと駆けつける、残りの徒侍どもは矢を射こまれたなぞの御用駕籠をこれまたぐるりと取り巻いてご警固申しあげる、呼ぶ声、叫ぶ声、駆けこう足音、五十三次やれやれの宿の品川浜は、思わぬ珍事に煮えくり返るような騒ぎとなってしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご立腹ごもっともにござりまするが、てまえは伊豆守様のご内命こうむりまして、お出迎えご警固に参りました八丁堀の同心、役儀のある者でござりましてものぞいてはなりませぬか」「ならぬならぬッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か只ならぬ詮議の者でもがあるらしく、市中警固の係り役人共と覚しき藩士の面々が、いずれも異様な緊張ぶりを示して、あちらに一団、こちらに一隊、行く先の要所々々に佇んでいるのが見えました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まてッ」「はッ」「いずれは警固もきびしく運び出すであろうゆえ、それと分らば合図致せよ」「心得ました！",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
