[
  {
    "uuid": "da235130-69d3-5a5e-a519-ab0ca1d1c8ff",
    "entry": "欠乏",
    "reading": {
      "primary": "けつぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
