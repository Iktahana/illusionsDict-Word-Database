        "examples": {
          "standard": [
            {
              "text": "お遍路の旅は、見仏聞法を通じて自己を見つめ直す貴重な機会となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は寺院を巡り、見仏聞法の精神で仏教の教えを深く学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "見仏聞法は、心の平穏を得るための大切な行いの一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼に言わせれば、「見仏聞法の最初に難得難聞なるは、衆生無仏性なり」。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
