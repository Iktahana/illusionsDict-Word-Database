[
  {
    "uuid": "039f5546-8a87-5b35-bcf3-0da2890eb086",
    "entry": "県有",
    "reading": {
      "primary": "けんゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "owned by the prefecture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "御料林でなければ、県有林だった。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来彼等きょうだいの出生地、和歌山県有田郡湯浅村（現在湯浅町）は気性の荒いので近村に知られた漁村である。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍中将山県有朋は、陛下に供奉して西下して居たが、西南の急変を知るや、直ちに奏して東京大阪広島の各鎮台兵に出動を命じた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いふ意見が、よほど御思召に叶つたやうであり、同年末には、立憲政治に就いて、山県有朋、黒田清隆、山田｜顕義、伊藤博文、大隈重信などの各参議に対して、意見の提出をお求めになつて居られる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山県有朋という立派な名前があるのに、なにもわざわざ昔の名前をほじくり出して、なんのかのと、冷やかしがましいことを書き立てんでもよいだろう。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山県有朋から使いが立った、と分れば、わしが現在どういう職におるか、陸軍、兵部大輔という職が、どんなに恐ろしいものか、おまえなんぞなにも申さずとも、奴等には利き目がある筈じゃ。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも狂介はひとりで斬れるが、山県有朋の身のまわりにくっついている煙りが斬り難いというなら、やめることさ」「では、貴公は、おまえは、むかしの仲間を見殺しにするつもりか！",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はことさらに叔父の前に滔々と維新の大業を論じ、上は村田清風から下は山県有朋に至る長州の人材を讃嘆した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、山県有朋、非議会主義の代表者、陸軍の首脳。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一年二月十日、伊藤博文、山県有朋、黒田清隆、西郷従道、大山巌、井上馨六名御前会議。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "山県有朋総理大臣、松方正義大蔵大臣。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "右及答弁候也内閣総理大臣侯爵　山県有朋　　　議会に投げかけた最後の一声兇徒嘯集の疑獄は、三十三年の十二月、前橋地方裁判所で公判が開かれ、「官命抗拒」「治安警察法違犯」と云ふ判決であつたが、検事の控訴で、事件は東京控訴院へ移された。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "末山大将は吉田松陰や山県有朋を生んだ長門の国の人である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず在京及び近県有志と文部省より出発して、全国中央図書館会議にまでそれは発展したのであった。",
              "citation": {
                "source": "図書館法楽屋話",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大島氏の家は福島県有数の事業家で弥之助の依頼したＯ氏は当主の弟さんに当る人で、白菜だけでも四百町歩から作ってその種子を全国的に供給して居る、弥之助は先年その農場に遊んで同氏の為に「菜王荘」の額面を揮毫して上げた事がある、そこで早速同氏に当てて「モンペ」調製の依頼をすると直ちに快諾の返事が来た。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "和紙四つ折百八十六丁、五号活字二段組でぎっしりつまっているのが、内閣総理大臣兼内務大臣陸軍中将従二位勲一等伯爵｜山県有朋を筆頭とし、監獄｜石川島分署看守副長十等野口正義を末尾とするところの、当年の大日本帝国文武百官の一覧簿をなしているのだからみものである。",
              "citation": {
                "source": "武鑑譜",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十九年四月）　　　公爵　山県有朋　　　　　山県有朋　世間、山県有朋を見る何ぞ其れ謬れるや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "山県有朋も伊藤博文も、ここに別荘を建て、それぞれ古稀庵、滄浪閣と名づけて、今もその跡が残つている。",
              "citation": {
                "source": "時　処　人",
                "author": "――年頭雑感――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると野上氏はさしずめ山県有朋になるわけだが、なる程之は官僚の元祖であった。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると二十一日になって、総理大臣山県有朋の名で、正造の去る十七日の質問に対する答弁書が、議長の手もとへ届いた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は外遊を終えて帰国の途上にある山県有朋に手紙を送って、船中で帰国後の処置を誤たぬように警告を発した。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白の学習院へゆくまでの高原の道には家らしい家もなく、右に山県有朋の住む椿山荘の、三万坪にあまる広大な庭園は深い繁みに掩われて、しいんとしずまりかえり、歩きながら雉子や山鳥の声を聞くことも一再ならずであった。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内務大臣、山県有朋。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや、上下の意見が最後の段階まで来ていることを予感した伊藤は外遊中の内務大臣、山県有朋に電報を打って国内の事情を訴え、すぐさま帰国すべきことを要請した。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この官軍の参謀は、山県有朋であった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、山県有朋は、怨みをいだくこと極端な人間であった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍卿の山県有朋閣下からであります」　うしろに電信課の書記が直立していた。",
              "citation": {
                "source": "日本名婦伝",
                "author": "谷干城夫人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
