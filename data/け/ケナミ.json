    },
    "definitions": [
      {
        "index": 1,
        "gloss": "coat (of hair or fur)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからこれは少し変なものではあるが猫の毛並みにも時として週期性の縞状の疎密を呈することがある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にその毛並みのやり方が目に立って旨く出来ている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "実物写生ということのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い毛並みをしとしと小雨がうるおして背は冷たく輝いて大きな眼には力強さと自由が満ちて居る。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと反対で毛並みのいいお絹の髪は二十時代と少しも変わらなかった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋骨の見える痩せたセッタアは両足を腕にかけ眼を光らせ、日向臭い毛並みを垂れて彼を見詰めていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその毛並みの艶やかな美男の雄の単眼の一つへ硝子の針を刺し通してから、これを花嫁に与えた。",
              "citation": {
                "source": "青草",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に膝の三毛猫は、彼女の膝を飛び下りると、毛並みの美しい背を高くして、快さそうに欠伸をした。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの馬は実に立派で、まっ黒な毛並みがつやつやしてるから、私は一目で好きになってしまいました。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の黒い毛並みはなおつやつやとしてきて、以前にも増して立派になりました。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その菊女の膝の先に、鞣された白猫の皮が敷いてあり、日盛りの陽があたっているので、蚤は熱さに堪えられないからか、黒茶色の猪のような小さい躯を、綿のように白く柔かく、絹のように艶のある毛並みの間を、抜けつ潜りつさせて蠢めいていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼よりも馬の方が身綺麗であると思はれる位に馬は毛並みも艶々として来た。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真新しかつた時の天鵞絨の輝きこそなくなつたが、それはまだ円々としたふくらみを持ち、毛並みの上にかすかにできた掛癖の痕は、それが布地のいたみを感じさせるよりも、もうかなり自分の身体に合つてくれたといふ馴染深さを感じさせた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしらはつきりし、又何かしらとりとめもなく、空は冷い輝きを増し、山々の稜線はかつきりとし、葉の落ちつくした雑木山はずつと遠くのものまでが殆ど信じられないくらゐの細かい枝を無数に目に見させ、ブラッシの毛並みのやうな渋い赤褐色をどこまでもどこまでも拡げてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此馬がもつと毛並みのよい純白の馬で、跨つて居る自身も亦、若々しい二十代の貴公子の気がして来る。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此馬がもつと、毛並みのよい純白の馬で、跨つて居る自身も亦、若々しい二十代の貴公子の気がして来る。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此馬がもっと、毛並みのよい純白の馬で、跨って居る自身も亦、若々しい二十代の貴公子の気がして来る。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い肌を生漆のように艶々しくみがきあげた毛並みの下に、一｜尋もあろうと思える肉が細やかに動いている。",
              "citation": {
                "source": "越後の闘牛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この骨格と、肉付きと、毛並みの艶々しさを見て、誰か美を感ぜぬ者があろうか。",
              "citation": {
                "source": "越後の闘牛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と声をかけると、ちょうどおまんは小用でも達しに立って行った時と見えて、日ごろ姑がかわいがっている毛並みの白い猫だけが麻の座蒲団の上に背を円くして、うずくまっていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動作にはなんのこだわりもなく、その毛並みにはすこしの汚れもない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月光に照らし出された豹の姿の美しさ、軟かな毛並み鮮かな斑点、人の児のような優しい手つきでセッセと爪を磨いでいる。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カテリーナ・リヴォーヴナが、猫のふかふかした毛並みに指をさし入れて、もぞつかせはじめると、相手はただもう無性に鼻づらをすり寄せてくるのだった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、唾きをはく音や、腹だたしげな鼻息がきこえたかと思うと、毛並みをみだした猫が二三匹、屋根に立てかけてある小割板の束をがさつかせて駈けおりてきた。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉屋の主人の話だと、英吉利人はかう云ふ毛並みの猫のことを鼈甲猫と云ふさうであるが、茶色の全身に鮮明な黒の斑点が行き亙つてゐて、つや／＼と光つてゐるところは、成る程研いた鼈甲の表面に似てゐる。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても庄造は、今日までこんな毛並みの立派な、愛らしい猫を飼つたことがなかつた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉屋の主人の話だと、英吉利人はこう云う毛並みの猫のことを鼈甲猫と云うそうであるが、茶色の全身に鮮明な黒の斑点が行き亙っていて、つやつやと光っているところは、成る程｜研いた鼈甲の表面に似ている。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても庄造は、今日までこんな毛並みの立派な、愛らしい猫を飼ったことがなかった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩父の速がひき出した馬は、つやつやとした鹿毛のけなみもうつくしい、たくましいもので、鬼カゲと呼ばれてゐる名馬でした。",
              "citation": {
                "source": "鬼カゲさま",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな　それぞれ　けなみも　みじかく　ふわふわ　かわいらしく、　とぐちの　あたりで　ごろごろ、　ほこりを　たてつつ　たわむれます。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　そのあと　けなみの　おていれ。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
