[
  {
    "uuid": "c84901be-8161-510a-9d87-fb551a31a882",
    "entry": "毛並み",
    "reading": {
      "primary": "けなみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
