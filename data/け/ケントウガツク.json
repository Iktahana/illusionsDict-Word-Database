[
  {
    "uuid": "c7d9423b-f6e0-500c-b176-a5b0853c63d6",
    "entry": "見当がつく",
    "reading": {
      "primary": "けんとうがつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
