    "definitions": [
      {
        "index": 1,
        "gloss": "complimentary copy of a book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の聞いた風説によれば、或相当の出版業者などは内務省への献本二冊を一版に数へてゐるらしい。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと尊きテオピロ閣下よとルカは献本の宛名まで記して、自分がこのイエス伝を書くのは、先に書いた人もあるが不十分だから、自分が秩序を立てて詳細に書くのだと言っています。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二詩集『虹』大正八年九月　新潮社発行、岸田劉生装幀、武者小路実篤に献本。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野天の光』大正十年四月　新潮社発行、著者自装、小泉鉄に献本。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベエコンは、ホワアドの『ヘンリイ四世の歴史』の献本を受けた伯爵の不埒に、貴族の注意を集めるように宜しくやれと、彼女から指令されてあった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
