          "literary": [
            {
              "text": "畢竟これも職員が欠席者督促を励行しない為だと言つた。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だしいのは、二人で五分間も話せば用が足りさうなことを、わざわざ十六人も集つて、昼食を食ひ、それも、欠席者が七人ゐて、その分だけの余つた皿が、健啖家の前へ引き寄せられるといふに至つては、時節柄、人聞きも悪い。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし余らの前に欠席者でもあって、一脚の机が空いていれば、必ずその上へ腰を掛ける。",
              "citation": {
                "source": "博士問題とマードック先生と余",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠席者をかぎ出すのを喜びとしてる奴さ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
