        "examples": {
          "standard": [
            {
              "text": "トイレの後、子供に「ちゃんとケツを拭くんだよ」と教えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "おむつ交換の際、衛生のために丁寧にケツを拭く必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "兄さんだって、今に、手でケツをふくようになるのかも知れないよ」　と、次男の安彦が和した。",
              "citation": {
