    "definitions": [
      {
        "index": 1,
        "gloss": "to play a hand game (e.g. rock, paper, scissors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下の座舖で拳を打つ聲がする。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも彼が座を立ってからは、一段と酒席が乱れたとみえ、吾妻拳を打つ掛声まで交って聞える。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室からは支那の客の拳を打つ高い声が響き渡る。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳を打つ二人の男たやすげにすべてを拒む形するかな　拳と云ふものを目に見ない人には一寸解り難い歌かも知れぬ。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "確か桜の咲く頃に石井柏亭氏などと一所に江戸川の川甚と云ふ旗亭へ入つた時に、向うの方の座敷では拳を打つて居て、其れを此方からでは丁度手の先きだけが見えて面白いと云ふ歌も、この作者にある。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちでは拳を打つてる。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ顔ぶれがたいがい顔を揃へてゐて、麻雀の者、碁を打つ者、花牌をひく者、拳を打つ者、酒を飲む者。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると櫛の歯のように並連ったそれらの桟橋へと二梃艪いそがしく輻湊する屋根船猪牙舟からは風の工合で、どうかすると手に取るように藤八拳を打つ声が聞えて来る。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんの、」と幇間は拳を打つような手つきを一つしてから、「弘法も筆の過り、閉口へいこう。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "取卷の清五郎は、藝者のお袖を相手に、引つきりなしに拳を打つて居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "笑ひ茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やら闇を縫つて飛んで來た物が、したゝかに、左母次郎の振り冠つた拳を打つたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
