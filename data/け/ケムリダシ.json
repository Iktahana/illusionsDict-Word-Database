        "examples": {
          "standard": [
            {
              "text": "薪ストーブの煙り出しからは、心地よい薪の匂いが漂ってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の寒い日には、家の煙り出しから白い煙がもくもくと上がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "煙り出しの設計は、暖炉の効率に大きく影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、渠の勉強室になつてゐる六疊の室を見せ、「ストーヴをこの眞ン中に焚いて、煙りをここから出すのだ」と、煙り出しがまがつてそとへ出る角石の穴をゆび指した。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が全世界を塞ぎあるいは私の穴から私を煙り出しまた明るみに私の鼻が出た瞬間に私を殺すことが出来たらどんなものでしょうかね？",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
