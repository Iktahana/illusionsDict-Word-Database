[
  {
    "uuid": "19c90e5a-d7de-587d-9525-bd7bbc458b55",
    "entry": "ケイ素",
    "reading": {
      "primary": "けいそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silicon (Si)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎日葬式や命日というような儀式は見慣れてきてはいたけれども、自分の家から死者の出たのは、園が生まれてから始めてのことなので、よけいそうした感じが起らないのかもしれなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけいそいでみんなに追いつこうとしました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いせじまやあまのとねらがたくほのけいそらがさきに云々」と言ふので、此歌だけで見ると、阿度目磯良と、別に関係はない様であるが、元はあつたに相違ない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をきってからよけいそうです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人達も僕を見ようとして集まって来て、あわれだった昔のことなど思い出し、よけいその成功をよろこんでくれるだろう。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶ける雪のしたたりおちる音はすべての谷あいに聞かれ、氷は池で解けいそいでいる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あたくしなんぞでも、通るたんび、変ったなァとしみ／″＼思いますからあの人だったらよけいそうだろうと思います。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまりわれ／＼、その全盛のときに生れ合したんで、よけいそれだけに無常を感じます。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうみても東海道は戸塚あたりの安気な医者の住居位にしかみえない沢村宗十郎君の文化住宅（窓にすだれをかけたのがよけいそう思わせるのである）を横にみてそのまま八幡さまのほうへ入っても、見覚えの古い土蔵、忍び返しをもった黒い塀、鰻屋のかどの柳――そうしたものの匂わしい影はどこにもささない。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は自分の性質に素子よりもよけいそういう俗っぽさがあるらしいということは理解出来た。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、できるだけいそいで、その帯あげをとき、袋帯をほどき、その下の伊達巻や紐類をゆるめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人一人が殖えれば、台所だってそれだけいそがしいんだから、そうお客様になられちゃ困るよ」　独りであった時のように、単純に、「いやな母様！",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解できなかったために、よけいそのときの彼の表情とか言葉とかを、奇妙な衝撃として私は心にふかく刻みつけたのかもしれない。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからブラウンは、屋根裏部屋でカン高い熱弁をふるつている声がするためによけいそうぞうしい、せま苦しい一軒の借家にはいつて行つた……。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十そこそこの年齢らしいが、老成ぶった顔をして――つぶれている左眼の陰影がよけいそう見せるのかも知れないが――どこか哲人じみた風のある男で、背はむしろ又十郎より低いぐらい。",
              "citation": {
                "source": "柳生月影抄",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕を外国人と見てよけいそういう態度に出たのでしょうね。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニールスはできるだけいそいで、ぬれた沼地にいるガンのむれのところへもどってゆきました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "友だちの於福の名を聞いたので、日吉はよけいその人を、何だろうと考えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、田楽村の者は、近々と見て、よけいその確信を、つよめずにいられなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "生半可、雲谷の画風がどうの、牧谿がどうの、友松がいつの時代のと、考証癖が手伝ったり、江戸時代の画史画論の雑書の観念などが交じるので、よけいそこが混雑してしまうのではあるまいか。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
