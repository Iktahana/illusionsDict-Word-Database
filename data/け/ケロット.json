        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アスピリンをどっさり呑めば、けろっとなおるのだが。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　梟はもうけろっと澄まして答へました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」けろっとしていた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰とでもすぐ懇意になって、相手がまだけろっとする暇もない中に、もう『君、僕』で話しだす。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "けろっとしている水面に向ってつンと手ばなをとばした一人の男は「おンや？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飯台に向うと父親はけろっとしていた。",
              "citation": {
                "source": "前夜",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "などと云ってけろっとしていた。",
              "citation": {
                "source": "雨の山吹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きだした泰三は立停って、けろっとした顔で振返った。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムはそれをしまいまで聞いてから、けろっとした顔で百姓に問いかけた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにごともなかったように、けろっとしている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
