[
  {
    "uuid": "c41dbb05-8751-58aa-ad10-6df28cb5b063",
    "entry": "決する",
    "reading": {
      "primary": "けっする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
