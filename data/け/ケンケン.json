    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hopping on one foot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――それも片足だけでけんけんをしつゝ一種踊る樣な恰好を身體につけながら。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男らしさ」への義理立てだけといつた風に振り上げられたその兒の弱々しい拳や、歪められた顏や、殊にけんけんで踊る樣にした恰好が何度となく眼に浮んで來た。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は、喧嘩を好まず、否、好まぬどころではない、往来で野獣の組打ちを放置し許容しているなどは、文明国の恥辱と信じているので、かの耳を聾せんばかりのけんけんごうごう、きゃんきゃんの犬の野蛮のわめき声には、殺してもなおあき足らない憤怒と憎悪を感じているのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、けんけんごうごう、二匹は一つの手毬みたいになって、格闘した。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀子はちゆちゆとさへづり、子を思ふ焼野の雉子けんけんと夜も高音うつ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の啼くこゑかおかおと啼くは鴉、ぴよぴよと啼くは雛鶏、雀子はちゆちゆとさへづり、子を思ふ焼野の雉子、けんけんと夜も高音うつ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "けんけん小雉子が今啼いた、小雉子も寒かろ、寂しかろ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉、雉、雉ぐるま、雉はけんけん、鳩ぽつぽ、啼いてお山を今朝越えた。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "村雨ははらゝほろ、山梨の枝にかゝれば、けんけんほろゝうつ雉子の鳴く音に覺まされて、磐床いづる牧羊の神パアン、胸毛の露をはらひつゝ延欠して仰ぎ見れば、有無雲の中天をひとり寂しく鸛の鳥、遠の柴山かけて飛ぶ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつの理想主義、革命的社会思想、階級意識、戦争と力への反撥――そういったものを取材とする絵が芸術であっていいかどうかは第二の問題として――かれの絵は最も端的にそれを摘出し、議論し、口角泡をとばして、画室へ這入るとけんけんがくがくの声が四方の壁に沸き立っているような気がする。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何さっきあんなけんけんした声を出した？",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、結局それはいくたびか云ひふるされた、それもお互に「さう、さう」とうなづき合ふやうな弱点、短所を、さも事新しく理論化してこれを「民主主義」と結びつけ、けんけんがうがうの説をなすのが今日の風潮である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、海竜が出ました、角を二本｜生やした、こんな怖い顔をして、お杉のあまっこを追っかけて来たのを、命からがらで逃げて来やんした」　窓の外は、けんけんごうごうとして、潮のわくような騒ぎであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの金は、いまでも返すよ」「いりませんよ、あんなお金――」「そうけんけんいうな。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高音、そうけんけんいわずと、ここへ帰って来なさい。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "繩飛び、鬼ごつこ、隠れん坊、けんけん、子供の要求する遊びはなんでもした。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「猫かいや、猫はもうけんけんど、ネズミ取ってくれる。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと知りながら、お母さんはつい克子の手をとってはけんけんのわからない克子を、自分の足の上へ上がらせて片足をあげ、ちん、ばん、ばん、と飛んでみたりするのであった。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもけんけんはそれでおぼえてくれた。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "目のある者にとっては何でもないけんけん、だが克子にとってはどんなにか新しい驚異であったにちがいない。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当座は毎日けんけんをしていた。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女自身は夫の仲間が集まって、けんけんごうごうの論に夜を明かそうとも口出しはせず、その人たちののどをうるおす茶くみ役に不満ではなかった。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉子はその辺まで来て啼くとも解せられるし、蔵の向うに蜜柑畑の見えるような場所で、けんけんと啼く雉子の声を聞いたということにしても構わない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにたくさんの哲学的頭脳がこのとおりけんけんごうごうと騒ぎ立てているのもお耳にははいらないと見える！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、野良犬の吼えあう声がけんけんと遠い闇に聞えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のけんけん雉や何を泣くね親がないか子がないか親もあるが子もあるがたった一人の男の子鷹匠に捕られてきょう七日七日と思うたら十五日……というのであったが、土地によってはげんげの花といい、更に転じては「つくつくぼんさん何泣くね」とも歌っていた。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸家に飼われている闘犬や、鳥合ヶ原のお犬小屋の犬どもは、ここへ来て夜も昼も、けんけんと異様な啼き声を世間にこだまさせていた。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬のまねして、けんけんと啼き狂う。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
