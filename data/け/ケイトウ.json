[
  {
    "uuid": "42a1882a-5cfb-5ca2-9cb8-a3701986e72c",
    "entry": "傾倒",
    "reading": {
      "primary": "けいとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
