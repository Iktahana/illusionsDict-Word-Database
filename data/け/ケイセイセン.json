          "standard": [
            {
              "text": "成田空港へは、京成線を利用するのが便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末に上野公園へ行くために、京成線に乗った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "京成線は、東京の東部を中心に運行している鉄道網だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "驛前の市場にて惣菜物蜜柑等を購ひ、京成線路踏切を越え松林欝々たる小徑を歩む。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前地所周旋屋に導かれ眞間京成線路側の賣家を見る。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
