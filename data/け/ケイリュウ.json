    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mooring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "庭の端っこにある屋根付き船着き場に、整備され、係留してある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "係留してあるカーセジーニアン二世号が、ふと、ほんの一瞬、その透明にきらめく陽ざしのなかに溶解してしまいそうだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無数のロープのようであり、単独では弱いものの、からまって島を同じ位置に係留した。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨットは天然の小さな入り江に係留した。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、探検者達は無事に海底に着き、装備を取り出し、その中に配線と電池があり、爆破の為に持参したものであり、配線を持って砂地を横切り、行先は沈島の係留箇所、船長の言葉を借りれば、巨大な中空｜歯根を健康な歯肉に差したような場所だ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り難い、もう危険はない」　快速船が港に係留されていた。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰か空ボートに一人乗り込んで、どこか近くに係留しろ」　と警察艇の指揮官が命令。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
