          "literary": [
            {
              "text": "すると紙がぱっと蛍光色を呈して光りだした。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその中に、蛍光色の計器の表だけがぴかりぴかりと光る。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "強烈な、白い太陽の光のかわりに、ここには蛍光色とでもいえるような、ぼんやりした微光が Emeri の原野の上に漂っているだけである。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
