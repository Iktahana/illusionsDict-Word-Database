[
  {
    "uuid": "8656901d-7da0-57a6-a58d-086f71dee8fd",
    "entry": "ケチを付ける",
    "reading": {
      "primary": "ケチをつける",
      "alternatives": [
        "けちをつける"
      ],
      "is_heteronym": false
    },
    "grammar": {
