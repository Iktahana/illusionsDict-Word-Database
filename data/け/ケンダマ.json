          "literary": [
            {
              "text": "」　玉村さんは、おもわずさけんだまま、身動きもできなくなってしまいました。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "園田さんも、明智探偵も、その顔を見ると、あっとさけんだまま、立ちすくんでしまいました。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うわさに聞く黒い魔物だということがわかると、あまりのおそろしさに、アッとさけんだまま、地面にうつぶしてしまいました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひらいたかと思うと、さすがの悪人も、アッとさけんだまま、棒立ちになってしまったのです。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あっとさけんだまま、クッションの上にうつぶせになってしまいました。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
