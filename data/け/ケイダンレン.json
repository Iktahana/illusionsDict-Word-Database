        "examples": {
          "standard": [
            {
              "text": "経団連は、日本の経済政策に大きな影響力を持つ団体だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経団連の会長が、記者会見で景気の見通しについて語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は経団連と連携し、経済の活性化に向けた施策を推進している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここでカードを切れば、英国経団連へ入会するきっかけが出来る。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その問題で、経団連の意見はそのまま実行できぬという政調会副会長の意見だつた。",
              "citation": {
                "source": "政府を拘束しない",
                "author": "池田勇人",
                "note": "青空文庫"
              }
            }
          ]
        }
