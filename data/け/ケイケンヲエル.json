        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "珍しい貴い経験を得るためには親の叱言ぐらいは意に介しない底の小享楽家だったのである。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本をよむこと、人から話をきくこと、或は人の話と自分で見たこととを結びつけて、そこでまた一つの新しい経験を得るということもある。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで相当の年齢に達したならば独立し得られるよう、商売道の原則と社会に対する一般知識並びに経験を得るように指導して行きたいと考えている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびたび失敗するとそれでこの大切なる経験を得る（拍手喝采）。",
              "citation": {
                "source": "学問の独立と東京専門学校の創立",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
