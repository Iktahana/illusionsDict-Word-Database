    "definitions": [
      {
        "index": 1,
        "gloss": "cackling (sound of shrill laughter)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
