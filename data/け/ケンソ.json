[
  {
    "uuid": "c12fb280-8f7d-5956-9763-d23dda4b12c7",
    "entry": "倹素",
    "reading": {
      "primary": "けんそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
