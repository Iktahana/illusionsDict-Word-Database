    },
    "definitions": [
      {
        "index": 1,
        "gloss": "economical and simple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家康は「上を見な」「身の程を知れ」の「五字七字」を秘伝とまで考えたから、家臣の美服を戒め鹵簿の倹素を命じた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬祭の儀は、漢の文帝の如くせよ、と云える、天下の臣民は哭臨三日にして服を釈き、嫁娶を妨ぐる勿れ、と云える、何ぞ倹素にして仁恕なる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の詠みびとじゃ」　関白の座敷としては、割合に倹素で、忠通の座右には料紙硯と少しばかりの調度が置かれてあるばかりであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に倹素を忍んで、外に声望を張ろうとする貞固が留守居の生活は、かなの内助を待って始て保続せられたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしひとり巽斎だけは恬然と倹素に安んじてゐた。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　倹素に安んじた巽斎の偏愛を避けたのは勿論である。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或友人から巴里人は倹素だから家庭へ入るのは不愉快だと聞かされて居たが、一概に然うでも無さ相である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又感服した一つは、身に過ぎた華奢を欲しない倹素な性質の仏蘭西婦人は、概して費用の掛らぬ材料を用ひて、見た目に美しい結果を収めようとする用意が著しい。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "低き賃銀、薄き利潤、倹素な衣食に甘んじつつ過度の勤労に服する支那人に対して、一般に生活の向上した日本人が競争し得ないのは明かな事実ながら、猶併し予等は殖民地の邦人気質が概して下級労働を嫌忌し、懶惰、尊大、贅沢、虚栄の中に不当の利潤を求めて其日を送る風のあるのを否み難い。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さはれ流石に思慮深き家康は、秀吉の如く閨門の裡に一家滅亡の種を蒔かず、其が第一の禁物たる奢は女中にも厳に仮さで、奥向にも倹素の風行はれしは、彼の本多佐渡守が秀忠将軍の乳母なる大婆に一言咎められて、返す詞も無かりし一場の話に徴して知るべし。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、孔明自身が、自らゆるしていたところは、　謹慎　忠誠　倹素　の三つにあったようである。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "公に奉ずること謹慎、王室につくすこと忠誠、身を持すること倹素。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名馬も、雌は半値だそうです」　と私は、お酒のお燗をつけながら、負けずに、げびた受けこたえを致しますと、「けんそんするなよ。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「けんそんは美徳で。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あびらうんけんそわかと唱えて、押頂いて飲んだですて……（お気をつけられい。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕨の茎葉で蝮に咬まれた創口を撫でてかの歌を誦すと越後でいう由なるが、陸中の俚伝を佐々木喜善氏が筆したのには、蛇に逢いて蛇がにげぬ時「天竺の茅萱畑に昼寝して、蕨の恩を忘れたか、あぶらうんけんそわか」と三遍称うべし。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ鼻は丸く安座をかいていて小さい目は好人物というより、滑稽味のある剥身に似た、これもけんそんな眼だ。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お江戸離れて南へ三十里潮の花咲く椿島野増村から戀人の手紙ゆかぢやなるまい一とまづは歌ひ終ると、「聲が惡るいからね」とけんそんしてゐましたが、澄んだ素朴な聲でした。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹猫は身がるに岩の出たけんそな道を上つたり下りたりして、とう／＼お城の壁のま下まで来ました。",
              "citation": {
                "source": "虹猫の大女退治",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくも仲間にいれてくれたまえ」「なるほど、それではきみひとりが第五級だ」「なぜだ」「きみは十六歳で最年長者だから」「そうか」　けんそんなゴルドンも年齢を減らすことができないので、第五級の生徒となることにきまった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた「殺されるのは沢山」で「死ぬのは困る」男が、「うぬぼれもないことはないが、あまり見よいものではない」から、けんそんして見たりする。",
              "citation": {
                "source": "戯曲二十五篇を読まされた話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぢやけんそら町の方から云うて参つたのでせうが、私の方では何にも知りません、もし不服がありなさるなら、町の方へお出でなしてと云つた処がない。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "一草ごとに天にむかい手を合わせ、「朝日が下の三の葉草付くるととまる血がとまる、あびらうんけんそわか」と三度唱え、一草よりまたはじめのごとく唱えて一草とり、また唱えて一草とり、以上三草をもみて付くるときは、たちまち血とまること神のごとし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、梵語の言で「あびらうんけんそわか」という語を唱えるのであります。",
              "citation": {
                "source": "妖怪学一斑",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「假名で十九文字、斯う書いてある、『よさくさにやれみりゐけひぬげやいほてぬ』――解つたか、八」「――あびらうんけんそわか――見たいなもので」「馬鹿だなア」「でなきや、火傷の禁呪」「こいつは隱し言葉だよ」「へエ？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "櫛の文字",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はたき尽してあるだけ書いておしまいになったから、あたいを口説いたんじゃないこと、誰もほかの女に持ってゆくには、あまりにお年がとりすぎているから、けんそんしてあたいを口説いて見たわけなのよ、そしたら金魚のくせに神通自在で、ひょっとしたら人間よりかなお知る事は知っていると来たのでしょう。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲きょうけんそんして「いらない原稿紙があったら下さい」だって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云うようすが正しくしんけんそのもので、眼の色さえ変っているようにみえた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "けんそんはいいが、卑下するこたないよ。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの動作は毎日きちんと、狂いのない順序で行われるし、六ちゃんの顔には、どんなに優秀な運転手よりも敏感そうでするどい、しんけんそのものといった表情があらわれるのであった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
