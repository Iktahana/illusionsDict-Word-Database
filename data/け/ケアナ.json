    "definitions": [
      {
        "index": 1,
        "gloss": "pore (of the skin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "佐竹の顔は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、寢そけてしまつた私の頭の中は變に重く、それに寒さが加はつて來てゾクゾク毛穴がそば立つのが堪らなく不愉快だつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ身体中の毛穴から暖かい日光を吸い込んで、それがこのしなびた肉体の中に滲み込んで行くような心持をかすかに自覚しているだけであった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから今でも実さんが舞台に立つと臓腑がキリキリと巻き締まって、毛穴がピッタリと閉じるのが眼に見えるように思う。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎みに力を添えられて辛うじて座禅の形を続けていると収縮した毛穴から干からびた皮膚へ油汗がたらたらと押し出て全身が痛いようだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぼ一町もあるという、森の彼方にどうどうと響く滝の音は、大河を倒に懸けたように聞えて、その毛穴はここに居る身にもぞッと立った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これが生得絵を見ても毛穴が立つほど鼠が嫌なんだと言います。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間、雨の中を傘なしで歩いて来たので、下着を透して毛穴まで濡れていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は身体中の毛穴が自然と引き緊まるように感じた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹の顏は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人は予を凝視むるやらむ、一種の電気を身体に感じて一際毛穴の弥立てる時、彼は得もいはれぬ声を以て「藪にて見しは此人なり、テモ暖かに寝たる事よ」と呟けるが、まざ／＼と聞ゆるにぞ、気も魂も身に添はで、予は一竦に縮みたり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜度目に出会つたのが、いや急には動かず、然も胴体の太さ、譬ひ這出した処でぬら／＼と遣られては凡そ五｜分間位は尾を出すまでに間があらうと思ふ長虫と見えたので已むことを得ず私は跨ぎ越した、途端に下腹が突張つてぞツと身の毛、毛穴が不残鱗に変つて、顔の色も其の蛇のやうになつたらうと目を塞いだ位。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛穴から火が吹きだすほどの熱、ぬらぬらしたリパード質に包まれた結核菌がアルコール漬の三月仔のような不気味な恰好で肝臓のなかに蠢いているだろう音、そういうものを感ずるだけではない。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、寿子は祭に行きたいと駄々をこねることも出来ず、毛穴という毛穴から汗を吹きだしながら、ちいさな手に力をこめて、弾いていた。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、僕は、毛穴の立っているおからす芸者を男にしてしまっても、田島を女にして見たいと思ったくらいだから、僕以前はもちろん、今とても、吉弥が実際かれと無関係でいるとは信じられなくなった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男の横顔や首のあたりの・赤黒く汚れて毛穴の見える皮膚とは、まるで違って、洗い立ての熟したトマトの皮のように張切った銅赤色の光である。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻が赤く、苺のように点々と毛穴が見え、その鼻が顔の他の部分と何の連絡もなく突兀と顔の真中につき出しており、どんぐりまなこが深く陥ち込んだ上を、誠に太く黒い眉が余りにも眼とくっ附き過ぎて、匍っている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて身体中の毛穴から沁み入るような冷たさ、気味わるさが一層深まって来るようで、その枯れ葉や枯れ枝が、私の掌や膝の下で砕ける、ごく小さな物音まで、一ツ一ツに私の神経をヒヤヒヤさせるのでした。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸は、「それは君の心だよ、君の文章の拙いのは、君の心の毛穴が塞っているためだから、冥途に在る幾千万の心の中から、佳いのを一つ選びだして、君のために易えたからね」　と言って起ちあがり、扉を閉めて出て往った。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と胸を突くほど、足が窘む、手が縮まる、五体を手毬にかがられる……六万四千の毛穴から血が颯と霧になって、件のその紅い唇を染めるらしい。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今いわれた時も慄然としてこの通り毛穴が立ってら。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小糠雨の細いのが、衣服の上から毛穴を徹して、骨に染むやうで、天窓は重くなる、草鞋は切れる、疲労は出る、雫は垂る、あゝ、新しい筵があつたら、棺の中へでも寝たいと思つた、其で此の家を見つけたんだもの、何の考へもなしに駈け込んだが、一呼吸して見ると、何うだらう。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春の暖かさはちく／＼と痛いやうに痒いやうに毛穴から汗がにじみ出すのである。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "小女王は恐ろしがってどうするのかと慄えているので肌も毛穴が立っている。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その切ないものが身体中の筋肉を下から持上げて、毛穴から外へ吹き出よう吹き出ようと焦るけれども、どこも一面に塞がって、まるで出口がないような残刻極まる状態であった。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時地面のドン底の、彼の石男の亡骸の、　数限りない毛穴から、何億万とも数知れぬ、　大きい小さい様々の、石の卵が湧き出して、　暖かい日に照らされて、一ツ一ツにかえり出す。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鳥が来ると河馬はじつとして、あの毛穴の中の黴菌を鳥がとつてくれるのをまつてゐるんだつてさ。",
              "citation": {
                "source": "コドモノスケッチ帖",
                "author": "動物園にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかましく吟味した日本剃刀で、長い時間かかつて、毛穴を一本一本、その根まで掘り起すやうにして剃る。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「縦に皺の寄ったもんだけあな。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、息の音あ為ないがけあな。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
