[
  {
    "uuid": "fe4bbd6f-b94b-5a3d-87e4-02577f9aaf6d",
    "entry": "研究室",
    "reading": {
      "primary": "けんきゅうしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
