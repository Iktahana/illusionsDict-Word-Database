    "definitions": [
      {
        "index": 1,
        "gloss": "riser (in a building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
