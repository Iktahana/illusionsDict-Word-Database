          "literary": [
            {
              "text": "火傷の痕はみなケロイド状で、皮膚が盛り上ってゴムを塗りつけたようになる。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから次に、ケロイド状火傷者がたくさんいる。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学生の顔には一目でそれと知れる原子熱傷のあとのケロイドがあった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
