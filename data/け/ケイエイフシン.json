        "examples": {
          "standard": [
            {
              "text": "主力製品の売上低迷により、会社は経営不振に陥っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の経営不振が続き、ついに事業縮小を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は経営不振の責任を取り、社長の座を辞任した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、雑誌を廃刊し、また経営不振におちいった出版社は、ほとんど戦後の新興出版社であり、「老舗はのこっている」。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎の下ッ端は元々生活が苦しかったものだが、終戦後は別して歌舞伎の経営不振で、お給金はタダのようなものだという。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、社内に、いろいろ面倒ないきさつがあったらしく、一ト月と経たないうちに、中山君は経営不振の責を負って退社してしまった。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
