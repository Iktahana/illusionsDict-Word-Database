    "definitions": [
      {
        "index": 1,
        "gloss": "threshold (lacking the grooves needed for a sliding door)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしそれ百尺｜竿頭、百歩を進めた超凡越聖、絶学無造作裡に、上は神仏の頤を蹴放し、下は聖賢の鼻毛を数えるに到っては天魔、鬼神も跣足で逃げ出し、軒の鬼瓦も腹を抱えて転がり落ちるであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の収めざる蓐の内に貫一は着のまま打仆れて、夜着も掻巻も裾の方に蹴放し、枕に辛うじてその端に幾度か置易られし頭を載せたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はその風呂敷包みをもぎ取って、取り縋る彼女を蹴放して本所の方へ逃げてしまった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇ではあるまいかと想像しながら、市松は足をあげて強く蹴放した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大次郎は掴みつく奴を力まかせに蹴放して、また寄って来ようとするところを抜撃ちに斬りました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（臺所の被れ障子を蹴放して、助八は擂粉木を持ちて跳り出づ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはおどろいて障子を蹴放して縁さきへ転げ出すところを、また追っ掛けて行って滅茶苦茶になぐって……。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて奧の襖を蹴放して、山杉甚作が逃げて出るを、手先一人が追つて出づ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い影は仙吉を蹴放して、もとの塀のなかへ飛鳥のように飛び込んでしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガブリと潮水を呑まされながら、死に物狂いに蹴放して、無我夢中で舟に這い上ると、ヤット落付いてホッとしたもんだが……」「……結局……何でしたか……それあ……」「……ウン。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は気味の悪いのが三分と、新しい袴をひつぱられる腹立たしさが七分とで、最初は猿を蹴放して、その儘通りすぎようかとも思ひましたが、又思ひ返して見ますと、前にこの猿を折檻して、若殿様の御不興を受けた侍の例もございます。",
              "citation": {
                "source": "地獄変",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は氣味の惡いのが三分と、新しい袴をひつぱられる腹立たしさが七分とで、最初は猿を蹴放して、その儘通りすぎようかとも思ひましたが、又思ひ返して見ますと、前にこの猿を折檻して、若殿樣の御不興を受けた侍の例もございます。",
              "citation": {
                "source": "地獄變",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれを蹴放してやった。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ」と云う声を後に残し、若侍は雨戸を蹴放し、闇のお庭へ飛び出して行った。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠彦　　（物もいわず茂兵衛の笠を引ッ剥ぐ）甚太　　（茂兵衛の前に立ち塞がる）根吉　　（茂兵衛の背後から組みつく）茂兵衛　（彦の肩を掴んで砂地に叩きつけ根吉の首筋へ手をかけ、前へ廻して蹴放し、打ってかかる甚太の小手をとって投げつける）何をしやがる。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今や抜刀斬込み隊の勢いである、遠慮は無用、杉戸をがらりと明けて、襖は土足のままこれを蹴放してずかずかゆく、非常に壮快だ、無人の野を席捲する概がある、「どうだ」　三人は互いに顔を見交わした、そのまま各自は豪雄｜不羈の士である、そしてそこが主じの部屋だ。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出て行け、出て失せろ」　茂兵衛は正吉の背を蹴放した。",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、野郎ッ」　呻きながら跼む奴の、手から、刺身庖丁を奪い取った正吉、ばっと上へ跳上がると、ひらき戸を蹴放して奥へ踏み込んだ。",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話せばわかる、乱暴をするな」と彼は云った、「ぜんたいなにが欲しいんだ」「この野郎ふざけたことをぬかすな」　そうどなりさま、男の一人が得石の腰を力いっぱい蹴放し、得石はもういちど前へのめった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ウウム、見ていやがれっ、うぬも、和介の野郎も」どん――とお吉を一つ蹴放しておいて、平次郎は、奥へ駈けこんで行った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "助かろうなどとは考えるなよ」「では、では、どうしても」「あたりまえだ」「お慈悲ですッ」　しがみついて泣き吠える又八を、沢庵は立ち上がりざま蹴放して、「ばかっ」　と小屋の屋根も吹き飛ぶような大喝を吐いて睨めつけた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そいつをぽんと蹴放し、また、とたんに、も一つの脚へ搦んできたチンピラの横びんたへ向っては、「ちょめ！",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくなわしの帰宅を不愉快にさせおって」　廬は、蹴放した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の部屋の窓を夜どおし明けはなして盗賊の来襲を待ち、ひとつ彼に殺させてやろうと思っているのであるが、窓からこっそり忍びこむ者は、蛾と羽蟻とかぶとむし、それから百万の蚊軍。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はしご段をのぼりましたら一つの室があけはなしてありました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この野原には、学校なんかあるわけはなし、これはきっと俄に立ちどまった為に、私の頭がしいんと鳴ったのだと考えても見ましたが、どうしても心からさっきの音を疑うわけには行きませんでした。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけは、小屋の中がひどくむし暑かったので、壁の小窓という小窓を、あけはなしておかずにはいられなかったからです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルコニの戸をあけはなしたまま、ついそこにねむってしまったのです。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ところが、ありがたいことに、戸があけはなしになっていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の部屋の窓を夜どほし明けはなして盜賊の來襲を待ち、ひとつ彼に殺させてやらうと思つてゐるのであるが、窓からこつそり忍びこむ者は、蛾と羽蟻とかぶとむし、それから百萬の蚊軍。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
