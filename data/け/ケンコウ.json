[
  {
    "uuid": "22e42b22-aa33-5b76-b80a-16a18f10482a",
    "entry": "健康",
    "reading": {
      "primary": "けんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
