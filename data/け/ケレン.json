    "definitions": [
      {
        "index": 1,
        "gloss": "playing to the gallery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この困難を打開するために各種渉外連絡会が設立されている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "連合国総司令部との連絡をはかり物質的、精神的な援助を得るために科学渉外連絡会が設立された（四六年六月）。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々面會に來て、差入物や内外連絡のことを引受けて世話してくれたのは福田英子姉でありました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく若林と自動車で浅草へ乗り出し、電気館の洋物、土屋という弁士で人気を呼んでいるオペラ館の新派悲劇、けれんの達者な松竹座の福円などを見たものだったが、そのころ浅草を風靡しているものに安来節もあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら江戸屋の江戸五郎が水芸達者のけれん師であったにしても、舞台と地とでは場所が違うんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今日の文楽は僕の昔見た人形芝居よりも軽業じみたけれんを使つてゐない。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今日の文楽は僕の昔みた人形芝居よりも軽業じみたけれんを使っていない。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが丸本物の人形ぶりは、どの道一種のけれんであつて、よければよい程反省感を起させる。",
              "citation": {
                "source": "合邦と新三",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……深く御柔軟、深く御哀憐、すぐれて甘くまします「びるぜん、さんたまりや」様――――和訳「けれんど」――「どうです、これは。",
              "citation": {
                "source": "黒衣聖母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠菊之丞の得意は勿論、最初は、　――何しろ上方の、それも緞帳から成り上った器用役者、あざとくって、けれん沢山で見ちゃあいられねえ――　とか、　――ま、見たところは、美しいですが、とんと場違いで、近海の鯛に馴れた舌には、ちと頂けませんな。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二社大滝の場などは、其けれんの見せ場で、兼ねて夏芝居らしい舞台風情を十分発揮するのである。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪談物は尾上家の伝説の芸目の重要な物であり、けれんに属する筈の怪談物を芸術的にある点まで叩きあげた五代目菊五郎までの伝襲が、厳重な歌舞妓種目からも、之を除外させなかつたものと言へよう。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎入一人死んだゞけで、事実けれん物は、芝居芸術から消え去つた様に見える。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌者流曰く三十一字にして足る、何ぞ故らに新しき形を要せんと、殊に知らず、昔しの淳朴なるや、「八雲立」「難波津」の歌猶之を誦して、人をして感ぜしむるに足れり、今に至つては猶此緩慢なるものを須ゆべけれんや。",
              "citation": {
                "source": "詩人論",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもけれんたっぷり、ファーコートの下から桃色のピラピラ的（一生渋くはなれぬ人）芸人的。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども、人々が野や山より移して庭に栽植しないのはどうしたものか、やはり、野に置けれんげそうの類かとも思えども、しかしそう野でこれを楽しむ人もないようだ。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私は、妙てけれんな男になりはしたものの……ばかになったかというと、まだ必ずしもそうじゃない。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その風呂敷包みどうなさるんです」「これかいな、これは古いもんやがな」「古いものなら、綾ちゃんに始末してもらいます」「ほんなもん、手がつけれんほどひどいもんやでな、私がぼつぼつとな」「すると、やっぱり江州へお帰りになるおつもりなんですか」　母の肩はひどく曲っている。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "知足院の隆光とやらいう怪僧がまんまと大御台様を始め大奥ぐるみけれんに掛けて非道の御布令を出させたのも、結句は隆光の計画である。",
              "citation": {
                "source": "津軽の虫の巣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそんなけれんは外の病人に遣って見せ給え。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙てけれんだったわよ。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国五郎は一種の名人で腕もあったが、けれんも相当用いたもので、早替りや太夫のふところ抜けなど見物をあっといわせた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "難曲の名人綾瀬太夫素読みのような酒屋のさわり　東都の義太夫に重きをなした初代綾瀬太夫、大阪で鶴沢友次郎や長門太夫に仕込まれ、上京後やかましい政太夫に私淑したので、少しもけれん当込みのない真面目の芸風。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "余人ならば知らぬこと、山手武家侠客の総元締をする重左が、そんな甘い女のけれんに乗るものか、春日新九郎の体が欲しくば、日を改めて氷川下の邸へ自身で推参しろ、その時は生首か骨ぐらいは遺物がわりに返してもくれよう」「では飽くまで妾の家来を帰さぬと云いやるのじゃな」「知れたことだわ！",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と待っていたらしいが、会談してみると、案に相違して、平凡淡々何のけれんも手くだもない人物であることが分った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "事ここに到るまでにも、家康と秀吉とは、いつかは、今日あることを知っていたし、今日になっては、なおさら容易に、けれん小手技で、伏しうる敵でないことを、相互に知っての自重だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘もけれんもないところ、お千絵様はあなたにしんから惚れています。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言葉は至極平凡で、滔々の弁でもなく、なんらの機智もないが、ただけれんや駈引きがない。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "主思いの菊王も、ありがたくお縄をいただいて、好きな主の側へ行くがいい」　八荒坊の大言は、残念ながらけれんではない。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
