        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大連が一台ずつ、黒塗り真円な大円卓を、ぐるりと輪形に陣取って、清正公には極内だけれども、これを蛇の目の陣と称え、すきを取って平らげること、焼山越の蠎蛇の比にあらず、朝鮮｜蔚山の敵軍へ、大砲を打込むばかり、油の黒煙を立てる裡で、お誓を呼立つること、矢叫びに相斉しい。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟浄は強く水を蹴って、泥煙を立てるとともに、愴惶と洞穴を逃れ出た。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てた與吉の手は其の軸木の先から徒らに毛のやうな煙を立てるのみであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草は道の端へさうして畑の方へ吹き擢はれつゝ微かに煙を立てる。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁屑の交つた粉炭の燻りは蒲團の裾から少し煙を立てる。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "火はゆら／＼と搖れながら油煙を立てる。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草は道の端へさうして畑の方へ吹き攫はれながら微かに煙を立てる。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの命なりとも夫人にお授けください」　こう僧たちは言って、頭から黒煙を立てると言われるとおりの熱誠をこめて祈っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに兄弟の力を頼りに細々と煙を立てる有様である。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひらりとカンテラを翻えすと、崖の面を掠めて弓形にじいと、消えかかって、手の運動の止まる所へ落ちついた時に、また真直に油煙を立てる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "笏は、何ごとかを言おうとしたが、童子はものをも言わずに踞み込んだが、すぐ一抹の水煙を立てると、その水田の中へ飛び込んだ。",
              "citation": {
                "source": "後の日の童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井の穴の縁は、間もなく死者の頭にかこまれ、それから煙を立てる長いまっかな糸がしたたった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分の胸から血煙を立てる短刀を引きぬきながらその上におのれの製作銘を認むる刀剣師のような一種の満足を、彼は感じ得るのであった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
