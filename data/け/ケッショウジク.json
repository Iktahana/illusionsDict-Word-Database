        "examples": {
          "standard": [
            {
              "text": "結晶軸の方向によって、物質の電気的特性が変化することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この結晶は、特定の結晶軸に沿って劈開しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結晶軸を考慮して、光学素子を設計する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここにも、また、新たな結晶軸を求めつつある人類の生成物が、何かその綱紀を創りつつある。",
              "citation": {
                "source": "映画のもつ文法",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで氷の物性の研究を、本格的にやろうと思ったら、単結晶について、結晶軸の方向とその物性との関係を調べるのが、第一に着手すべきことである。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも結晶軸の方向を、希望した方向にすることはできない。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
