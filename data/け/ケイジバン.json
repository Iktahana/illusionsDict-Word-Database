          "standard": [],
          "literary": [
            {
              "text": "国府津と小田原の中間に「雀の宮」という駅があったようだと子供達と話していたら、国府津駅の掲示板を見ていた子供の一人からそれは「鴨の宮」だという正誤を申込まれた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の朝Ｋ市の中学校の掲示場の前におおぜいの生徒が集まって掲示板に現われた意外な告知を読んで若い小さな好奇心を動揺させていた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲示場の前を通る時彼れは今日の解剖の廣告が掲示板にぶら下つて風にひらめいてゐるのを見た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄は屋台を出ると、当り籤の番号の掲示板の出ている前へ立って、何の感情もなく、一枚一枚開いて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　掲示板には、上より順に一等、二等の番号が出ていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄は一枚ずつ掲示板と見くらべてみたが、三枚目まで全部はずれていることが判ると、もう掲示板を見上げるのも莫迦らしくなって、四枚目は一桁の数字だけ見て、破ってしまった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　びっくりして、鶴雄は掲示板を見上げた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と波止場の門の掲示板に書いてあった。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處だか分らないが、そこに役場の門前に在るやうな掲示板があつて、それに人の名が書いてある。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルの前の掲示板に、その日の夕刊が貼出されてあった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊自由に書き込める掲示板。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子掲示板上で実におぞましい罵詈雑言のぶつけ合いなど見るにつけ、心に引っ掛かるのはその点だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲示板でお知らせしたとおり、本日から、われわれオーディオ部が、起床放送を担当します。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験の席次は、例によって寮の掲示板に貼りだされたが、通知表には五段階評価が書かれているだけだから、そうしたくないなら、親にはいわなければよい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本棟一階ホールの掲示板には、ワラが書いた貼り紙がだしてある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲示板では、強風のために米棉相場が上り出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "参木はこの取引部の掲示板に表れた日本内地の好景気の現象に興味を感じた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町の帝国水産会の支部は、事務所の前の掲示板に墨くろぐろと初鰊の速報を書いてはり出した。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍在籍中にまとめた論文でワシントン大学から博士号を得た直後の一九七二年、キルドールは兵学校の掲示板で、インテルの４００４の「チップ上のコンピューター――二五ドル」という広告を見た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "32　黒い一枚の掲示板。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲示板は「北の風、晴」と云う字をチョオクに現している。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩寺あたり　僕は碌でもないことを考へながら、ふと愛聖館の掲示板を見上げた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛聖館の掲示板にかういふ言葉を書いた人は或はこの事実を知らなかつたかも知れない。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩寺あたり　僕は碌でもないことを考えながらふと愛聖館の掲示板を見上げた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛聖館の掲示板にこういう言葉を書いた人は或はこの事実を知らなかったかも知れない。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンチの凭れ板の列と、默りこくつてゐる些少の乘合客の頭とを越して、車室の突き當りに掛つてゐる掲示板が見透しになつて居り、窓外の險しい景色とは打つて變つて、ここは其處らの窓に蠅でも唸つてゐないかと思はれるくらゐ、ひつそりして暖かくうん氣ざしてゐる。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁、窓、カーテン、天井、天井からぶら下がっている幾つかの電燈、隅々の戸棚、蓋のしてある暖炉、大きな八角時計、晴雨計、寒暖計、掲示板、――壁にはところどころに何者の趣味だか、いや何の意味だか呉服店だのビール会社だのの広告絵、大相撲の番附などが麗々しく貼られてある。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は行った時には手ッ取早く掲示板を見て、まず上段の陳字を捜した。",
              "citation": {
                "source": "白光",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
