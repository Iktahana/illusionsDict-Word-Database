          "literary": [
            {
              "text": "泣けば決心が鈍ると、女は一生懸命に堪へて居たが、こみ上げて来る悲痛の涙は、もう胸一杯になつて居た。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣けば決心が鈍ると、女は一生懸命に堪へて居たが、こみ上げて來る悲痛の涙は、もう胸一杯になつて居た。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の顔を見ると、決心が鈍るかも知れないし、妻に余計な苦痛を与えるような結果になるかも知れない。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云ふ時代には如何に犠牲奉公の徳を高唱しても、顧みて妻子眷族の窮を思ふ時に、果して其決心が鈍る所なきを得やうか。",
              "citation": {
                "source": "蘇峰先生の『大正の青年と帝国の前途』を読む",
                "author": "吉野作造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
