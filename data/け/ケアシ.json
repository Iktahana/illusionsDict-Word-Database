    "definitions": [
      {
        "index": 1,
        "gloss": "hair or fur on the surface of fabric",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "考え出そうと頭を傾げ乍ら戸棚の奥まで徒に探した愛は、急に何か思い当て嬉しそうに柔かい毛足袋の音を立てて二階に行った。",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろこびと云いしれぬ胸のときめきにかすかにふるえる体をうす桃色の房の長い寝間着とまっしろにシックリした毛足袋につつんで長くとかした髪をくびに巻いて青磁の燭台に灯をつけた、部屋の出口を銀に光る鍵であけることも廊下に木のかげのさして居るのもこの上なくいい感じのする事だった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすっかり冬籠りの仕度をするためにその他、毛足袋だの何だのも云ってやった。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又（三）輪蟲類、（四）外肛蟲類に二三種、（五）環蟲類の中に原始環蟲類、毛足類の多毛蟲類に十二三種、貧毛蟲類に七八種ある。",
              "citation": {
                "source": "光る生物",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸まっちいからだの、禿げている頭の丸いハムレットが、紺の毛足袋の短い足を組みあわせ、血色のよい、髭のそりあとの見える東北人らしい顔を傾けて、To be or not to be と煩悶するのは、なんと滑稽なみものだったろう。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子のほうは柴犬に近いが親のほうはもっと毛足が長い。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "ａ『医学的心理学』　　　ｂ『精神鑑定例』三宅鉱一　　　ｃ『ヒステリーに就いて』　　　ｄ『性格学』　それから毛足袋と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛足袋、かかとが少しゴロつくかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩飯に私は海産の蠕虫――我国の蚯蚓に似た本当の蠕虫で、只すこし大きく、一端にある総から判断すると、どうやら Sabellaの属〔環形動物毛足類毛足多毛目サベラリア・アルベオラタ〕に属しているらしい。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "男たちは一人ずつ椅子に座り、居心地悪そうに磨かれた黒靴を毛足の長いグレーの絨毯に擦りつけていた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくあまたゝび改めて、ほと／＼元の姿を失ひたる曲を革に掛けたるとき、看客のうけあしきを見て、樂長はかならず怒りて云はむ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきにつけあしきにつけ主動的であり、積極的である男心に添うて、娘としては親のために、嫁いでは良人のために、老いては子のために自分の悲喜を殺し、あきらめてゆかねばならない女心の悶えというものを、近松は色彩濃やかなさまざまのシチュエーションの中に描き出している。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあちらに行って実際に見れば、よきにつけあしきにつけ東京にいて聞きしにまさる有様だが、同じ稗を食っている村の農民でも、そこに農民組合のあるところとないところでは、若い農民はもとよりのこと、老人連でさえ全く元気が違う。",
              "citation": {
                "source": "村からの娘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの足跡は、ほかならぬ私たちの足の下からしか現れないという意味で、一人一人の作家の必然の道がよきにつけあしきにつけ、その作家の文学の現実を決定してゆくし、日本の今日の文学の性格の一要因としてかかわりあってゆくわけである。",
              "citation": {
                "source": "日本の河童",
                "author": "――火野葦平のことなど――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか僕が雇われに行けあしめえし。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきにつけあしきにつけ、日本人のやることは、どういふものか素直に受け取られない傾きがある。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ云ひ換へれば、よきにつけあしきにつけ、教育が人間精神の形成に極めて消極的な役割しか演じてゐないといふことにある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "リューシは　かけあしで　たどっていきます。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "むらを　かけあしに　まわって、　２ひきいる　きつねがりの　こいぬを　さがしますと、　にくやの　とぐちのまえで　みつかりました。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの夜もどの夜も彼に睡眠を持って来てくれた、どの日もどの日も彼のかけあしを照らしてくれた、遂に彼は世界の平野の端に住むアサロニヤ人の国に来た、それから彼は再び神話の国に来た、彼が世界の向うの端においてはぐくみ育てられながら聞いた神話の国、それは現世の端を縁どってたそがれとぼかし交える国であった。",
              "citation": {
                "source": "人馬のにひ妻",
                "author": "ロード・ダンセイニ　Lord Dunsany",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけっこしてゆくお供さん、はやがけするときゃ、かけあしだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち　ぜんいん　ひっくりかえって　おりかさなって、　おきあがるや　かけあしで　にげだして　おともなく　きえてしまいます。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日、一日がかけあしで過ぎた感がする。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、いいか、かけあしっ……。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かけあしで、三度ほどまわったときでした。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
