    "definitions": [
      {
        "index": 1,
        "gloss": "to kick about",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お米を足で蹴散らすとは。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに出来る精一ぱいの反抗は、たったそれだけなのですか、鳩売りの腰掛けを蹴散らすだけのことなのですか、と私は憫笑しておたずねしてみたいとさえ思いました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "打立てられて敵の備の乱れた所を、煙の下より直ちに乗込んで、馬蹄に蹴散らすという、いかにも、東国の兵らしい荒々しき戦法である。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を組む上でのさまざまな細かな注文に答えられるよう備え、重箱の隅を突いては文句を垂れたがる因業親父を蹴散らすのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの理屈を蹴散らすだけの立派な理屈がこちらにもある。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、終りにあたり、千鶴子となお結婚を渋っている矢代の態度を、どういうものだか、蹴散らすように攻めていて、了解に苦しむというよりは、むしろ手探りようもない青春の消えさった手紙だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、昂奮を投げ交すような声でしばらく騒然となっていたが、やがて熊城が、蹴散らすようにして記者達を追い出してしまうと、再びいつものような三人だけの世界に戻った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そして漸く我に返つて、埃つぽい白けた温気を蹴散らすやうに勇ましく、ところが矢張り悄々として兎も角然し間違ひもなく跳ね起きはして、ふやけた寝床を片附けてゐたら、又してもあの高いうねりがひどい凄さで縹渺と荒れつのりつつ一際鋭く押寄せて来た。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川の渡しを越すと見えて馬の蹴散らす水音が甚五衛門の耳へも聞こえて来た。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな、鎗だの、楯だの、（とそこらに組み合わせて立ててある武器、馬具などを蹴散らす）今夜あ、こんな物あ眼触りだ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様は、若い血のすべてを、軍馬の蹴散らす砂漠の砂へ、投げ与えたはずではないのか。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けけ、蹴散らすぞっ……」　鏡のような、静かな顔に、蒼白い笑みをうかべた伊賀のあばれン坊、裃の肩を片ほうはずして、握り太の鞭を、群衆の頭上にふるう。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の安危、静かなること林のごときあいだにも機をねらって東西に奔馳しつつある同志の誓言、これらのことが守人の頭脳にひらめくと同時に、たった今までの思慕の感傷を、われから蹴散らすような足取りで、かれは川に沿うて歩き出した。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　藤吉の声に人心ついた二人、両手と両足を一時に使って光る土を蹴散らす。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳ゃない」　彼は静かな茶の間の空気を自分で蹴散らす人のように立ち上ると、すぐ玄関から表へ出た。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私めにお任せあれば、夜を幸い寺に忍びまいり、朝敵のうち手強い奴を打ちとってまいりまする所存、かくすればあとを蹴散らすはたやすきものにございます。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……苦もなくそういって蹴散らすことも出来た。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重の欺瞞に魅せられて憤恨を蹴散らすとすれば、彼は本当の道化者と何らの変りもないではないか。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ままよと乗り込み馬蹄の塵と雑兵らを蹴散らすが、もとよりそれらに用はなく、縛る軍律今はないと、一人脇手に乗り反らして駆け出したのは、逃げ足速い敵の大将を討ち漏らすものかという一心から。",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく露宿している被害民の枕頭を蹴散らすに至っては、これこそ国賊といわなければならない」　正造の声は、攻撃というより警醒のひびきで議場を被い、咳の声がもれるばかりであった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも大いなる巌が、うち当る波を踏まえ、四方より寄せ来る波を蹴散らすがごとく。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻想の花園を蹴散らすように、ガバと跳び起きて、ふたたび小柳生城の黒い屋形を見上げ、「卑怯といったな、恥を知れといったな。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語を話す国々の間で「詩」なる語が群衆を即座に蹴散らすこと消防ホース以上であるとアーノルド・ベネットが語った時、それは誇張とは到底言い難かったのだ。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "救いを求めて、彼の蜀軍を呼び、力を新たにして、魏を蹴散らすぶんには、荊州を奪りかえすことは十中九まで確信してよいかと思われますが」「まさにその一策しかない」　関羽は、矢倉へ上った。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ見ないならけちらすぞ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はては二匹で盛んにふざけちらす。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士のながいあいだの苦労が、今ここに実をむすんで、うまく外敵をけちらすか、それとも、外敵のため、博士も、他の人間とおなじように、こっぴどくやっつけられるか、二つのうちの一つが、今きまるところなのだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこがいけないんですか」「ひと月かそこら滞在するだけだというのに、あんなにネオンをつけちらすことが、いるかというんだ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……兄者の軍に迷ぐれまいぞ」　やがて、妙泉寺坂の上から敵を駈けちらす。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
