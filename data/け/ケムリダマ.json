          "literary": [
            {
              "text": "一人の子は恭しくバスケットから、狼煙玉を持ち出しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた、熊手や火煙玉を持った泊軍があらわれて、十重二十重にとりまき、いちめんな阿鼻叫喚を巻きおこした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、もっと驚いたのは、茶室の炉辺に、いつのまにか一個の狼煙玉がおいてあったことである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、事成らずと見たときは、遮二無二、もういちど茶室までのがれて、あの狼煙玉を炉のうちへ蹴こむつもりでした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
