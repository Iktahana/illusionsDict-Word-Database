[
  {
    "uuid": "3022a05e-d5ae-5452-be62-3ffa5e9b3375",
    "entry": "敬す",
    "reading": {
      "primary": "けいす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to respect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰も心で尊敬するわけではないが、非常にジャーナリスチックな交遊をしたりするから、何か仲間の足溜りの役をなす。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、僕は失敬するよ」佐竹は小声でそう呟き、金側の腕時計を余程ながいこと見つめて何か思案しているふうであったが、「日比谷へ新響を聞きに行くんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶々快活で、自分の仕事を尊敬することを知つてゐる者がゐると、ヘンな所でイヂメられたりする。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　四人のひとを尊敬する　四月廿二日の朝、私は、こんど出版する豫定の「愛と美について」といふ書き卸し短篇集の校正刷を、床の中で受け取つた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの四人を永久に尊敬する。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全然女性なるものを知らない理想主義風に尊敬するものもあれば、変態的の性格から女性にへりくだるものもある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊敬することによって自分が一人前にしてやった女を装飾することは職業に興味を持つ探偵に取って悪い道楽ではなかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（尊敬すべき詩人アルタに幸あれ、　スールダッタよ、あのうたこそはわたしのうたでひとしくおまへのうたである。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに深く愛する人でも、どんなに重く敬する人でも、一度心臓音の停止を聞くや、なお幾時間もたたないうちから、埋葬の協議にかかる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に芥川龍之介は、僕がかつて思つたよりも、ずつと遙かに性のちがつた、崇敬すべく愛慕すべき文學者だつた。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前を尊敬する全ての男はお前を貨物自動車にのったヴィクトリア女皇だと讃めたたえる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は彼の詩人的行動を尊敬する！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とし子は、※者の親爺や、その親爺を盲目的に尊敬する義母を、むきつけに、くさしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、自然と同窓生もこの人を仲間はずれにはしながらも内※は尊敬するようになって、甚だしい茶目吉一、二人のほかは、無言の同情を寄せるに吝ではなかった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯のように神仏を崇敬するのは維新前の世間の習慣で、ひとり私の家のみのことではなかったのだが、私の家は御祖母様の保守主義のために御祖父様時代の通りに厳然と遣って行った、其衝に私が当らせられたのでした。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尊敬すべき大家の謙遜な言葉は今の科学で何事でもわかるはずだと考えるような迷信者に対する箴言であると同時に、また私のいわゆる「化け物」の存在を許す認容の言葉であるかとも思う。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして科学上のピュリタニズムから見て最も尊敬すべき種類の学者である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の下等にして黒く暗憺なるを憂うるなかれ、桂正作はその主義と、その性情によって、すべてこれらの黒くして暗憺たるものをば化して純潔にして高貴、感嘆すべく畏敬すべきものとなしているのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は聞いているうちにもますます彼を尊敬する念を禁じえなかった。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の下等にして黒く暗澹なるを憂うるなかれ、桂正作はその主義と、その性情によって、すべてこれらの黒くして暗澹たるものをば化して純潔にして高貴、感嘆すべく畏敬すべきものとなしているのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は蓄音機をきらう音楽家のピュリタニズムを尊敬すると同時に蓄音機を愛好する素人を軽視する事はどうしてもできない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園は一人の勤勉な科学者であればそれで足りるのに、兄のように畏敬する星野からの依頼だとはいえ、格別の因縁もない一人の少女に英語を教えるということ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して相島は嘗て日記にフォックスの事を書いて「われは彼れを尊敬す。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして工合のわるいのをごまかすように、「ええと、我輩はこれで失敬する。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は此意味に於て彼を敬す。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円　埃ばかりじゃ、失敬するぞ、（と足を拭いたなりで座に入る）いや、その頭も頭じゃが、白髪はどうじゃ、白髪はよ？",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだかくのごとく畏敬すべき者ならんとは知らざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が友達になってくれとか、尊敬するとか言ったのはそれをきくためだったのだ、そう言えば、昨日彼がぼくに親切にしたり媚びる様な態度を見せたりしたのもこのことの予備行動ではなかろうか、そうぼくは思ったのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで奈良のだいぶつさまにさんけいするみんなの絵のようだと一郎はおもいました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで奈良のだいぶつさまにさんけいするみんなの絵のやうだと一郎はおもひました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
