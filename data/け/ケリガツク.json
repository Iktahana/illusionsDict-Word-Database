        "examples": {
          "standard": [
            {
              "text": "長引いていた裁判は、ついに判決が下り、一件「ケリが付く」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の友情にひびが入ったが、昨日の話し合いで、ようやく両者の間に「ケリが付く」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この件も、今日でケリがつくなら、心置きなく次のステップに進める。」と、彼は安堵の表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大騒ぎだけして一時ケリがつくと、あなた自身上べだけゴマ化し様子を見ていると対手もその間は知らん顔をしているなどというのは、正直に云えば双方で鼻息をうかがう卑屈な態度だと思います。",
              "citation": {
                "source": "「我らの誌上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の腕の者なら、槍を受けておいて斬込んだ時に、致命傷を与えてそれでケリがつくのだが、腕のちがいはそうも行かない。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫大な戦費を浪費して遊ぶ金に事欠いては無意味だといふ計算は行届いてゐるから、和談でケリがつくなら戦争などはやらぬがよい。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
