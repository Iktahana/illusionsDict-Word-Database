[
  {
    "uuid": "376d0924-fdbe-5410-ba47-f20e778b27d7",
    "entry": "決断",
    "reading": {
      "primary": "けつだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
