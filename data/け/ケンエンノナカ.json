        "examples": {
          "standard": [
            {
              "text": "彼ら二人は犬猿の仲で、顔を合わせるたびに口論になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの派閥とこの派閥は昔から犬猿の仲だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部長と課長は犬猿の仲だったが、あるプロジェクトで協力せざるを得なくなり、少しは歩み寄ったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "滑稽軽妙な先代重松は門人に始終落語を聴けと言っていたそうだし、同じく飄逸な至芸だったと聞く先代浪華軒〆友は八代目林家正蔵君とも盟友だった由であるが、他は多く犬猿の仲でないまでも、犬と猫ぐらいの不仲ではたしかにあった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに曲亭とは犬猿の仲であった。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアニヨメと珠緒さんは気持がシックリいくらしいが、秋子さんがアニヨメのころは事々に衝突、そのころから犬猿の仲であった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、新田足利の両家は、多年、人も知る犬猿の仲だ。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
