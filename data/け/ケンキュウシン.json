[
  {
    "uuid": "486bdabe-6a4b-5939-94f7-1039ad449f2a",
    "entry": "研究心",
    "reading": {
      "primary": "けんきゅうしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
