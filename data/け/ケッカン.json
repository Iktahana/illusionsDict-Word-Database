[
  {
    "uuid": "51112b7a-f916-5382-bade-2954a535cb3d",
    "entry": "欠陥",
    "reading": {
      "primary": "けっかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
