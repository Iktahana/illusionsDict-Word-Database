        "examples": {
          "standard": [
            {
              "text": "その法律は、個人の自由を侵害するとして憲法違反が指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「それは完全に憲法違反だ！」と、彼は強く主張した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最高裁は、その条例が憲法違反であるとの判決を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二〇〇三年一月一五日、連邦最高裁によってこの訴えは退けられたが、ステファン・ブレヤー判事とジョン・ポール・スティーブンズ判事は、二〇年延長を憲法違反とする反対意見を付した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "名乗りを脅迫するのは憲法違反だから、アッハッハ」　私はアタピン女史を怒らせておいて、逃げだした。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大政翼賛会は、憲法違反であると公言した。",
              "citation": {
                "source": "私の歩んだ道",
                "author": "蜷川新",
                "note": "青空文庫"
              }
            },
            {
              "text": "また国体護持を主張したり、天皇権力主義にもどることを主張したりすることは、憲法違反である。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
