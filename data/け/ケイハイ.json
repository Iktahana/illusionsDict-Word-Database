[
  {
    "uuid": "2d8bd714-6746-5672-af04-ba30fed658df",
    "entry": "軽輩",
    "reading": {
      "primary": "けいはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
