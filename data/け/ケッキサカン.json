        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "傍聴人は何れも血気盛んな、見るから頑丈な、腕つぷしの強さうな人のみであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、筑前志士の先輩に、越智彦四郎、武部小四郎、今村百八郎、宮崎｜車之助、武井忍助なぞいう血気盛んな諸豪傑が居た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んな利彦氏が渾身の気合いをかけて前進し、非常な勢いで身をかわして踏み止まろうとするが、止まれない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は情のある熱血漢、血気盛んといった具合で、どこから見ても僕と正反対だったが、どこか相通じるところがあった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、深谷も安岡も、それを口に出して訴えるのには血気盛んに過ぎた。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式呼ばわりして、過去の歴史を学ばず、聖賢の訓に従うことを形式に囚われるなどと云って忌み嫌うようなところは、英雄豪傑らしいところがあって、血気盛んな者には尤もらしく、痛快らしくも思われるが、結局は何の益も無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んな船頭が十人近くも曳々声を出して艫を操つても、それでもともすれば、舟は潮に流されるほどであつた。",
              "citation": {
                "source": "伊良湖岬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んな奴が懐中手をして濡手で粟の工風ばかりする老人連の真似をしたがる。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在の老教授を見ると、彼の人がかつてその配下の血気盛んなサムライたちからいかに恐れられて――畏敬されて――いたかをにわかに信ずることはできない。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分二十名位の客が急に泊まるのですから、宿では村の娘さんたちを召集して給仕させるのですが、血気盛んな若者揃いですから、村の娘も「おいゴハン」あちら、こちらから大声で呼ばれ、眼をまわすほどの忙しい目にあったものでした。",
              "citation": {
                "source": "明治懐顧",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時よく壮年の血気盛んな頃の思ひ出話が、伯父とお雪伯母との間に取り交された。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立去るうしろ姿を見ると老人、女、子供は勿論のこと血気盛んな……今で云うルンペン風の男も交っていた。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その安宿にいる人達というのは、血気盛んな若い男なんぞは、薬にしたくもいないで、みんなもうよぼよぼの、たよるところのない老人達ばかりでした。",
              "citation": {
                "source": "ある男の堕落",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "追って来るのは本職の刑事で半ばは二十台の血気盛んな屈強な男である。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（blood）血気盛んな若者。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ三蔵は免許の腕前、血気盛んの三十八歳、代稽古をする身分である。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は決して木石では無く寧ろ人一倍感情の烈しい血気盛んの若者だったので喜んでお君を隠匿った。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んな筈の三十歳あまりで、顔色は浅黒く、頭髪は硬く、眼は輝き、口許には冷笑を浮べ、肩がいかり、手がへんに大きな、そういう彼が憂欝そうに黙りこんでるところは、なにか乱暴な爆発が起るかも知れないと思わせるものがありました。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空監視員と云っても、完全な男子は出征して国内には居なかったので、四十過ぎの中老組か、二十歳以下の少年か、さもなければ、血気盛んなる妙齢の婦人達であった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからゴムの踵の摩滅具合から云ってこれは血気盛んな青年のものだと思うよ」「検事さん、待って下さい」と捜査課長は慌て気味に云った。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んな肉体の汚気が、約一万回排出される。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎手がいつでも首の骨を折る心配をしなければならないような馬が好きで、柔順でよく訓練された馬なぞは、血気盛んな若者には価値がないと考えていたのである。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、その男は血気盛んな青年だつた。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んの若者らしく筋骨なども逞しく、走って行く脚も軽々と、二人の男女を追って行く。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んなる小児の腹中に寄生する小虫を見る法なりとて、俗間に伝うるものを述ぶるに、小児の掌面に呪文三回墨書し、さらにその上を墨にて塗抹して文字をして不明ならしめ、これを握ること暫時にしてその手をひらき見れば、その爪甲より毛ようのごとき白繊維のもの続々出ずるなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は日暮里に本宅があるから一口に道灌山といい、後者は横浜に本拠を置くから野毛山と称え、親分御用の節はいつにても一命を、という誓紙を立てた血気盛んなる数千の身内を擁し、両々相譲らざる二大勢力。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は日暮里に本拠が在るから、一口に道灌山といい、後者は横浜に本拠をおくから野毛山と唱え、親分御用の節はいつにても一命を差上ぐべく、という誓紙をたてた血気盛んな数千の命しらずを擁し、両々相譲らざる二大勢力、これが皇帝誘拐事件を中心にして、風雲を孕んで相対抗する。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "某という血気盛んな親爺が急にいなくなり、大分しばらくたってから、ある日村の裏山から大きな声で「帰って来たぞ」と叫ぶ声がした。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ耳聡い者は、老いてなお血気盛んなウィップル船長が時々こんな独り言を呟くのを聞いた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで血気盛んなこととて、直ちに副島と二人で脱藩して大阪へ上陸した。",
              "citation": {
                "source": "青年の天下",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
