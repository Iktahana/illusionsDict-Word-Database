[
  {
    "uuid": "b5c2b29a-91fe-5351-874a-98bc9bbac3f1",
    "entry": "決勝",
    "reading": {
      "primary": "けっしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "decision of a contest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同時に決勝点へ着く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の敵手は決勝まぎわに腹痛を起こして惜敗したと伝えられている。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "決勝点なんか無論ない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出張撮影らしく、決勝点になっている長願寺の境内で、優勝旗をもってランニングシャツ姿で立っているのを、ひきまわした幕のうしろから、君枝の母親の初枝が背のびしてふと覗いている顔が、半分だけ偶然レンズのなかにはいっている。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平、決勝点へ入る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "清子、決勝点へ入る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出張撮影らしく、決勝点になっている寺の境内で、優勝旗を持って立っているのを、境内いっぱいにひきまわした幕のうしろから、君枝の母親が背伸びして覗いている顔が、偶然レンズにはいっている。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが我々の前へ来るまでにデズバラの脚色は鈍り、そこへ大佐の馬が仕掛けて抜き去り、ゆうに六馬身の差で決勝標に入る。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつどこで相手を抜いたか気付かなかつたが、Ｏ町の決勝点に入つた七郎の胸には、輝やかしい一等賞のメタルが、月の光のやうに光つてゐた。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、四軒の農場の主人たちは決勝点の所に一段高く桟敷をしつらえてそこから見物した。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが鞭とあおりで馬を責めながら最初から目星をつけていた先頭の馬に追いせまった時には決勝点が近かった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも決勝の鉄砲を打つ係りの教授が鉄砲を打ちそくなった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "決勝点は美禰子とよし子がすわっている真正面で、しかも鼻の先だから、二人を見つめていた三四郎の視線のうちにはぜひともこれらの壮漢がはいってくる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級戰の主力なるブルジョアとプロレタリヤの決勝によりてのみ解決されるものである。",
              "citation": {
                "source": "文藝運動と勞働運動",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級鬪爭の決勝戰はただ本隊の衝突によりてのみ決せられる。",
              "citation": {
                "source": "文藝運動と勞働運動",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬人歡呼の裡に決勝戰に入るマラソン競走ではなくて、雪と險路と窮乏と寒氣とのシベリヤ旅行のようなものである。",
              "citation": {
                "source": "文藝運動と勞働運動",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "決勝力をもたない、一種の補助運動、牽制運動と言つてもいい位だ。",
              "citation": {
                "source": "文藝運動と勞働運動",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて第四周目に及んだとき、さらに両名は二馬身ずつうしろの二人を抜いて、黒白両頭の名馬は、一進一退馬首を前後させながら、次第に第五周目の決勝点に迫りつつあったので、大坪流の古高勝名乗りをうけるか、八条流の黒住勝つか、場内の者等しく手に汗を握ったとき！",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また馬が前につなぎ直されると、もう、すつかり平坦な道を馬車は決勝点を越えた後の勇士のやうに、悠々として闊歩してゐた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒高跳決勝の時には陽は全く暮れ、明るく照明をうけた底を見下す観衆は西田と大江の名ばかり呼び続け、さて愈々二人が跳ぶ姿勢をとると水を打ったように静かになり、各国へ打つタイプライターの音と大空の上ではじけるオリンピアの焔の音ばかりパチパチとするだけだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、半ば頃まではケープルトンの黄色がその中の先頭を切っていたが、私達の前まで来た時はデスボロは力つきて出足鈍り、大佐の馬は突進してそれを抜き、決勝点に入った時は、優に六馬身の差があった。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番遠い太平洋を挟んで空軍による決戦の行なわれる時が、人類最後の一大決勝戦の時であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "数百年前、世界政策に乗り出して以来、スペイン、ポルトガル、オランダを破り、次いでナポレオンを中心とするフランスに打ち克って、一世紀の間、世界の覇者となっていた英国は、最後にドイツ民族との決勝戦を迎えたのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は第一次欧州大戦以後の国家連合の時代は、この次の最終戦争のための準決勝戦時代だと観察しているのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれが準決勝で優勝戦に残るかと言えば、私の想像では東亜と米州だろうと思います。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つが最後の決勝戦をやる運命にあるのではないでしょうか。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事的にも最も決勝戦争の困難なのは太平洋を挟んだ両集団であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事的見地から言っても、恐らくこの二つの集団が準決勝に残るのではないかと私は考えます。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろから日光がさすと、きらきらして無数の雪のけっしょうがみな光線をはねかえし、スペクトルというもののようになる。",
              "citation": {
                "source": "山の雪",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
