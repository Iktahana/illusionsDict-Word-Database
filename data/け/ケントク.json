    "definitions": [
      {
        "index": 1,
        "gloss": "emperor's virtue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
