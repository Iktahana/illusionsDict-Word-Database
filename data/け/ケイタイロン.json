        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＊　拙著『觀念形態論』一九八頁以下〔全集第三卷收緑〕參照。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "Vgl. Emil Brunner, Erlebnis, Erkenntnis und Glaube 1923, S. 105 ff.＊＊　歴史的意識に關しては拙著『觀念形態論』に於ける「歴史主義と歴史」〔全集第三卷收緑〕を見よ。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　Bernheim, Lehrbuch S. 37f.＊＊　拙著『觀念形態論』に於ける「科學の發展の制限とその飛躍」〔全集第三卷收録〕を參照せよ。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡單には拙稿「認識論の構造」（『觀念形態論』）〔全集第三卷收録〕を見よ。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して形態論者は、學習の成立には構造の安定、平衡、成全を必要とする。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して形態論者は現象學的に見て、構造の安定に留意し、安定せる結果に至つて滿足を感ずと考へて居るやうである。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味から云へば上村源之丞の操は方法論的にも形態論的にも文樂の操と全然同じ範疇に屬するものと斷定して差支へないのである。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲には意識形態論としての（まだ文化形態論までは行かない）、イデオロギー論の多くの課題が待っている。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が文化形態論としてのイデオロギー論の根本的な一般方針であった。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
