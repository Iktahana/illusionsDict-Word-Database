[
  {
    "uuid": "b364e230-9d90-5653-a4e8-167fc1823d1f",
    "entry": "研究",
    "reading": {
      "primary": "けんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "research",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自体芸術といふものは、それが研究の対象とされる限りに於ては如何にも科学的に闡明され得るものではあれ、制作される限りでは、生れるものであつて生むものではないのである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、いちいちその研究発表を、いま、ここで、せずともよい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ研究会でも起すか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともあなたの研究発表ですか？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神学」としての歴史的地理的な研究は、まだまだ日本は、外国に及ばないようであるが、キリスト精神への理解は、素早いのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした時代において、著者の如く専門の俳人でもなく、専門の研究家でもない一詩人が、この種の著書をあらわすということは、無用の好事的余技の如く思われるが、決してその然らざる必然の理由があるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村とちがって、芭蕉の研究は一般に進歩しており、その本質の哲学や詩精神やも、既にほぼ遺憾なく所論し尽されてる観がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後、彼の最初の発見者たる正岡子規、及びその門下生たる根岸派の俳人に継ぎ、殆んどすべての文壇者らが、こぞって皆蕪村の研究に関心した。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村研究の盛んなことは、芭蕉研究と共に、今日において一種の流行観をさえ呈している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら多くの人は、蕪村について真の研究を忘れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年九月『俳句研究』）",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年十二月『短歌研究』）",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ、アインシュタインの研究によってニュートンの力学が根底から打ちこわされた、というような話が世界じゅうで持てはやされている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の素人考えではこの方法論はかなり突きつめて研究さるべき問題のように思われます。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方法が鴫以外のいかなる鳥にまで応用出来るかということも、鳥類研究家には一つの新しい問題になりはしないかと思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事は子規という人とその作品を研究する際に考慮に加えてもいいことではないかと思う。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神學」としての歴史的地理的な研究は、まだまだ日本は、外國に及ばないやうであるが、キリスト精神への理解は、素早いのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから山の全裸体像として、線や、光や、影や、円味やを研究するのに、富士ぐらい秘密を許してくれる山はあるまい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど十九世紀に著しく勃興した探検事業は、科学的研究心と合体して、未知数に向い、無人境に向った結果、山岳研究ということが、欧洲より米国に、また日本に伝わって来て、諸々の文明国は、山岳会を有するに至った。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中山岳の雪は、研究の対象として最も興味のある題目である。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら山岳の雪は、ただその美観によって研究される価値あるばかりでなく、造山力を有する動作から言っても、雪それ自身の特立した状態から言っても、また生物を保護する恩恵から言っても、興味があるから、以下にこれを説く事にする。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、お互に、励まし合ひ、研究し合つたが、私にも、Ｎにも、カン所がつかめなかつた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度の何とか称する貴族で、デッキパッセンジャーとして、アメリカに哲学を研究に行くと云う、青年に貰った、ゴンドラの形と金色を持った、私の足に合わない靴。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦の場合などでは、それをどうして沈めるか、どうして穴を開けるかを、絶えず研究していることは、誰だって知ってることだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに永生きをして八十くらいになったら、その時にそろそろマルクス、エンゲルスの研究でも始めるだろうと皆でうわさをすることである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水で下車して研究所の仲間と一緒になり、新聞で真先に紹介された岸壁破壊の跡を見に行った。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地震のあとで鎌倉の被害を見て歩いたとき、光明寺の境内にある或る碑石が後向きに立っているのを変だと思って故田丸先生と「研究」していたら、居合わせた土地の老人が、それは一度倒れたのを人夫が引起して樹てるとき間違えて後向きにたてたのだと教えてくれた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室ばかりで仕事をしている学者達はめったに引っかかる危険のないようなこうした種類の係蹄が時々「天然」の研究者の行手に待伏せしているのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やっと、ふたつのどくろの持主をみつけて、暗号のけんきゅうをはじめたところなのだ。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
