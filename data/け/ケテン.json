    "definitions": [
      {
        "index": 1,
        "gloss": "turning evil into good through proselytization",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　小次郎再び化転して、「あんな事を云うよ、お婆さん。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間五十年｜化転の内を較ぶれば夢幻の如く也、一度生を稟け滅せぬ物のあるべきか……」　朗々として迫らない信長のうた声が、林のように静まりかえった陣営にひびき渡る。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間五十年、化転の内をくらぶれば、夢まぼろしのごとくなり――」　桶狭間の決戦にのぞみ信長の舞った敦盛の謡いが、本能寺を見ている矢代の口にも自然にのぼって来て、躊躇するものの轡すべてを彼は切り落そうとし、馬鞍を叩く手つきで窓枠の縁を打った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、神・精霊の考へは、常に変化転換して居る。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間五十年　化転のうちをくらぶれば　夢幻の如くなり　一度生を得て　滅せぬものゝあるべきか　信長終生熱愛の謡であり舞であった。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間五十年、化転の内をくらぶれば、夢幻のごとくなり、一度生を得て、滅せぬ者のあるべきぞ、こゝのところを自分で謡って舞うことだけがお好きのようです。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間五十年、化転の内を較ぶれば、夢幻の如くなりひとたび生をうけ、滅せぬもののあるべきか　世間並みのやり手は、芝居がかりで世間を欺くが、信長ときてはお能がかりだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間五十年、化転の内を較ぶれば……　道庵先生はこの時、異様な声を張り上げて、繰返し繰返しこの文句を唸り出しましたので、さてこそと集まるほどのものが、いよいよ眼と眼を見合わせました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、御当人は、買ってくれる人があろうがあるまいが、御当人の自己感激は、こうしていよいよ深み行くばかりで、もはや眼中に清洲の城址も無く、あたり近所の児童走卒も無く、古英雄信長もなく、今川義元もなく、ただ人生五十年の夢幻と、他生化転の宇宙実在とがあるばかり。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの世の中にも多い耽溺主義者だの、刹那主義的な人間も、信長の謡った「――人生五十年、化転の夢にくらぶれば」を、たった一つの真理と奉じて、一生懸命に、酒と女と刹那の享楽で、早死を心懸けている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも早速に相変化転するのが陣形の本質で、鶴翼でも蛇形でも鳥雲の陣でも、そのままに固執したりするのでは、死陣であって活陣ではない。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……人間五十年、化転のうちをくらぶれば」　信長は立った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……化転のうちを較ぶれば、夢まぼろしの如くなり、ひとたび、生をうけて、滅せぬもののあるべきか」　いつになく、彼の声は、朗々と高かった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "長門は、信長が舞うといえば、いつもの敦盛と心得ているので、人間五十年化転のうちを較ぶれば夢まぼろしの如くなりひと度、生をうけて滅せぬもののあるべきか　謡っている間に、長門は、信長の幼少の時のお姿から、自分が側近く仕えて来た長年のことなどが、胸のうちに、長い絵巻を繰るように思い出されて来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人間五十年　化転のうちをくらぶれば　ゆめ幻のごとくなり　ひとたび生を得て　滅せぬもののあるべきか「やい、待て」　犬千代は、謡いかけた藤吉郎の口を抑えて、「それはお汝が謡ではない筈だぞ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶狭間へ出陣の明け方、　――人間五十年、化転のうちをくらぶれば。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生五十ねん化転のうちをくらぶれば夢まぼろしの如くなり　酔えばうたう彼のおはこは、領民にまで知られている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと彼は、冷たい杯を手にして、人生五十年、化転のうちを……思いうかべていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人間五十年、化転ノウチヲ較ブレバ、夢幻ノ如クナリ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ」　「や、こりゃどうも」　「あら随分破けてんですねえ」　「え」　「縫いましょうか」　「いや、どうも済みません」　お静、糸と針を取りに立つ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何をねぼけてんだよ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いつまでねぼけてんだよ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼けてん」　娘は暗室のカーテンへ素早い視線を送っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば、即興詩人の君、アヌンチヤタの健康を祝して一杯を傾けてん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんぢやそれ掛けてんべ」商人は今度は眞鍮の皿へ卵を乘せて「こつちなんぞぢや、後幾らでも出來らあな」といひながらたどりを持つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんぢや此醤油掛けてんべな」おつぎは卯平の前に膳を据ゑて罎の醤油を菜漬へ掛けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんで、ラジオは〈ペニー・レーン〉ばっか、かけてんだよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一寸｜開けてんか。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「警視庁なんてところ、随分開けてんのネ」ダリアは、帆村をすっかり友達扱いにしていた。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな男のいうことマジメにきいて、何、ねぼけてんの。",
              "citation": {
                "source": "日月様",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
