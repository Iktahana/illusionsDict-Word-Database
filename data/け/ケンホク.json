    "definitions": [
      {
        "index": 1,
        "gloss": "northern part of a prefecture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
