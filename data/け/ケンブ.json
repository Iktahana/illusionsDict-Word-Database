  {
    "uuid": "3cca9d59-8954-5474-b1b7-42fc4bc2dc14",
    "entry": "肩部",
    "reading": {
      "primary": "けんぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shoulder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大統領は一弾を頭部に、二弾を肩部に受け、ただちにポオジョン病院に収容されたが、なにぶんにも七十四歳の高齢なので、生死を危まれている。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江の島をけんぶつして來たよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでかばんを、ひとまず、森の落ち葉のなかにかくして、町へけんぶつにでかけました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "お皿は下で　大きな口をあけて、けんぶつして　ゐました。",
              "citation": {
                "source": "お鍋とお皿とカーテン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町じゅう、たいへんなさわぎだというから、ぜひ、けんぶつにいかなくてはならぬ。",
              "citation": {
                "source": "鐘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみは　とだなのうえから　モペットちゃんを　たかみの　けんぶつ。",
              "citation": {
                "source": "モペットちゃんのものがたり",
                "author": "THE STORY OF MISS MOPPET",
                "note": "青空文庫"
              }
            },
            {
              "text": "造船所や船をけんぶつするのは、あしたの朝にすればいい。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家のかみ屋敷は上野池の端にあり、ちょっと出ればけんぶつする場所も少なくなかった。",
              "citation": {
                "source": "日本婦道記",
                "author": "おもかげ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロボットは、とうきょうタワーににげて、けんぶつ人にまじってしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふときがつくと、けんぶつ人の中を、へんなやつがあるいているのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十めんそうのロボットだ」　ふたりが、ロボットをおいかけだしたので、けんぶつの人たちも、ぞろぞろとついてきました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けんぶつ人でいっぱいで、なかなかみつかりません。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやしいやつが、エレベーターで上に上がっていった」　けんぶつ人は、びっくりしてしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かた手でてつぼうにつかまり、かた手をひらひらうごかして、下のけんぶつ人をばかにしています。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、じこくがはやいので、けんぶつの人はあまりいません。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
