        "examples": {
          "standard": [
            {
              "text": "お風呂では、香りの良い化粧石鹸を使うとリラックスできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お客様用に、高級な化粧石鹸を洗面台に置いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は固形石鹸といえば、ほとんどが化粧石鹸だった記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実際身綺麗な夫の姿は、そう云ふ人中に交つてゐると、帽子からも、背広からも、或は又赤皮の編上げからも、化粧石鹸の匂に似た、一種清新な雰囲気を放散させてゐるやうであつた。",
              "citation": {
                "source": "秋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父はひとり湯に入るとき薬用｜石鹸を使っていたが、春さんはそれをなにか上等な化粧石鹸のように思い込んで、その日ひそかに、その満面に面皰の吹き出ている顔にたっぷり塗り込んだというわけなのであった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
