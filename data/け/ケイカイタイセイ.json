        "examples": {
          "standard": [
            {
              "text": "災害に備えて、常に警戒態勢を維持することが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、年末年始のテロ対策として厳重な警戒態勢を敷いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国境付近では、常に軍が警戒態勢をとっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さしあたり、恐怖のあまり日常会話や目に見える記録からその話題を消し去ってはいても、大いなる種族は慎重な警戒態勢を維持し、威力のある武器を即応状態に保っていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーニ医師が楽しい会話に花を咲かせていた相手は著名な女流小説家だったが、瞬時に警戒態勢になった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "レスブリッジの話しを多少興味深く聞いていたが、警戒態勢になったのは、レスブリッジがもう一つ黄金薔薇を見つけたと言ったときだった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
