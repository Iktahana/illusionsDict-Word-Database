[
  {
    "uuid": "be967610-2439-5d69-9ae6-2cd5e5fcc5d1",
    "entry": "警ら",
    "reading": {
      "primary": "けいら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "patrol",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし巡警らは承知しない、たしかにこの家へ逃げ込んだに相違ないといって、家探しを始めかかったので、主人も困った。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡警らは家内を残らず捜索したが、どこにも人の姿が見あたらない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜百番地を警らしていた巡査が何か見た。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方だけいらっしゃい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又その女中が「けいらん五、」と或時言つた。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、きいちやん、けいらんツて玉子の事だね。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしつかえがないのなら話してね、私の所へなんかいつまでいてもいいことよ、いつまでもいらっしゃい、あなたがあきるまで――でも本当にどうして出てきたの」「いずれ話してよ、でも今夜は御免なさいね、ずいぶん長い話なんですもの」「そう、それじゃ今にゆっくり聞きましょう、あなたのいたいだけいらっしゃい。",
              "citation": {
                "source": "出奔",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無三十六童子、いけいら童子、うばきや童子、はらはら童子、らだら童子」と相和するものもありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なんにもしないで、生きてだけいらつしやることが、どうしておいやなの？",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那様にはその方面には、何んのお係りもございませんので」「遅いな、今夜は、どうしたんだろう」「いえもうおっつけいらっしゃいましょう。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……手短かに言えば、つまりその、私が人類の仇悪魔につけいられるまでには、一年とはかからなかったのです。",
              "citation": {
                "source": "女房ども",
                "author": "БАБЫ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初恋と終愛とが人間の死を飾る額ぶちのおさえであったら、かれの場合、この人こそ何にもいわないでただ愛してだけいられた平和を、かれに充分にあたえた立派な萩原の第三夫人であろう。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とアリスは、なるだけいらいらを飲みこむ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もう一度だけいらしって。",
              "citation": {
                "source": "葦は見ていた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さては、またけいらん巻を買いに行くんだな。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋で、世紀から、けいらんあんかけ一、こっちのうどん、よし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルペラはそんなことに手を貸さないが、誤報につけいらない理由はない。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇がみずから、その自由意思をもって、受けいられたのである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
