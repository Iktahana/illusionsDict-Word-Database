    "definitions": [
      {
        "index": 1,
        "gloss": "Tokyo and Chiba",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
