[
  {
    "uuid": "2e736dd2-8e54-5373-aa58-1d9ea9ec14d2",
    "entry": "境域",
    "reading": {
      "primary": "きょういき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
