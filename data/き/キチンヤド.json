    "definitions": [
      {
        "index": 1,
        "gloss": "cheap lodging house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若い頃、彼は貧乏旅行で各地の木賃宿を転々とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この路地の奥には、まだ木賃宿として営業している古い建物がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小説の主人公は、都会の片隅にある木賃宿で細々と暮らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最後には或る雪の凍つた朝木賃宿の窓の横木に首を縊つた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はかく労働している間、その宿所は木賃宿、夜は神田の夜学校に行って、もっぱら数学を学んでいたのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ汚ないばかりでなく、見るからして彼ははなはだやつれていた、思うに昼は街の塵に吹き立てられ、夜は木賃宿の隅に垢じみた夜具を被るのであろう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸つと、其の（思つた）が消えて、まざ／＼と恁うしてものを言交はせば、武藏野の丘の横穴めいた、山の手場末の寂びた町を、搜り／＼に稼いで歩行くのが、誘ひ合はせて、年を越す蚊のやうに、細い笛の音で、やがて木賃宿の行燈の中へ消えるのであらうと、合點して、坂上も稍もの言ひが穩かに成つたのである。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、夜が明け放れた時、お兼は新庄の山の頂を越えた、その時は、裾を紮げ、荷を担ぎ、蝙蝠傘をさして、木賃宿から出たらしい貧しげな旅の客。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて黒羽町に入込むと、なるほど、遊廓と背中合せに、木賃宿に毛の生えたような宿屋が一軒、簷先には△△屋と記してある。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ」と婦人の声、木賃宿の戸を開けて、内より出づる一人の美人、顔｜美麗しく姿優なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはいずこぞ鮫ヶ橋、白日闇の木賃宿にしかき姿あるは怪むべし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この木賃宿の所有主がよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなんぼ何でも木賃宿にいらっしゃるものを、姫様とはつかぬ語呂だぜ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」力に任して突飛ばせば、婆々へたばる、三吉｜遁る、出合頭に一人の美人、（木賃宿のあの人の）宵月の影｜鮮麗なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも御泊り木賃宿。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物売の、布子の円い背中なぞへ、同じ木賃宿のそこが歪みなりの角から、町幅を、一息、苗代形に幅の広くなった処があって、思いがけず甍の堆い屋形が一軒。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい女と若い紳士の、並んで立った姿が動いて、両方｜木賃宿の羽目板の方を見向いたのを、――無台が寂しくなったため、もう帰るのであろうと見れば、さにあらず。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜具を被って、仁王｜立、一斗｜樽の三ツ目入道、裸の小児と一所になって、さす手の扇、ひく手の手拭、揃って人も無げに踊出した頃は、俄雨を運ぶ機関車のごとき黒雲が、音もしないで、浮世の破めを切張の、木賃宿の数の行燈、薄暗いまで屋根を圧して、むくむくと、両国橋から本所の空を渡ったのである。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、お鎌はどうしました」「一旦は逃げましたが、五、六日の後に深川の木賃宿で挙げられました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、裏山で発見された死人は抱合心中だつたさうな、男が八十、女が四十、夫婦だか親子だか解らないさうだ、先月、小郡の木賃宿に泊つて、それから行方不明だつたさうである、とにかく八十の高齢にしてなほかつ縊死しなければならなかつた事情の深さを考へずにはゐられない、老の涙！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に着くと私は着物を売り払って労働者風になって四谷の木賃宿に泊った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は咳をしいしい四谷まで帰って木賃宿に寝た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザアザア降る雨の中を四ツ谷の木賃宿へ帰った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも云わずに、すっきりしたその人へ義理が有るから、手も附けないで突出すつもりで、一先ず木賃宿へ帰ろうとする処を、御用になりました。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板を書かえる隙もない、まだ出たてだという、新しさより、一人旅の木賃宿に、かよわい女が紙衾の可哀さが見えた。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木賃宿を泊り歩いているうちに周旋屋にひっ掛って、炭坑へ行ったところ、あらくれの抗夫達がこいつ女みてえな肌をしやがってと、半分は稚児苛めの気持と、半分は羨望から無理矢理背中に刺青をされた。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木賃宿へも平気で泊った。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いも揃うた昔に変る日焼｜面に鬚蓬々たる乞食姿で、哀れにもスゴスゴと、なつかしい京外れの木賃宿に着いたのが、ちょうど大文字山の中空に十四日月のほのめき初むる頃おいであった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原の花魁道中の前の日の事とて、洛中洛外が何とのう、大空に浮き上って行きそうな気はいが、二人の泊っている木賃宿のアンペラ敷の上までも漂うていた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしにモトの木賃宿に帰って来ると泣面に蜂という文句通りに、大惣が大熱を出いて、煎餅布団をハネ除けハネ除け苦しがる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
