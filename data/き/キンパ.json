[
  {
    "uuid": "82d954e1-9866-54a6-b0b4-14d658f98ed4",
    "entry": "金波",
    "reading": {
      "primary": "きんぱ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
