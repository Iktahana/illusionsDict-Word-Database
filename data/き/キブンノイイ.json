    "definitions": [
      {
        "index": 1,
        "gloss": "pleasant feeling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
