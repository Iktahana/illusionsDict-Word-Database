[
  {
    "uuid": "6a6fedd1-1ea1-54bc-8ed9-d10655cbaf66",
    "entry": "近辺",
    "reading": {
      "primary": "きんぺん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
