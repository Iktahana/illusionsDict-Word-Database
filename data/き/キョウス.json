[
  {
    "uuid": "ad3c2be6-ca0a-5176-af6e-7ef184bbb9fc",
    "entry": "供す",
    "reading": {
      "primary": "きょうす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-サ変-す",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to offer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "従つて、「面白い故に面白い」ことだけが芸術家に芸術の素材を提供する。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も「これは為になる、故に大切である」ことが生活家に生活の素材を供する如く。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味でいわゆる厄年というものが提供する環境や条件を考えてみたらどうだろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もし鯛が手に入ったら蒜と一しょにひしお酢にし即座の珍味に客に供する。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身の基体において既に「いき」の特徴をもった人間が、横縞に背景を提供するときに初めて、横縞が特に「いき」となるのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四畳半の小座しきの、縁の障子」は他の一切との縁を断って二元の超越的存在に「意気なしんねこ四畳半」を場所として提供する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "意味体験としての「いき」と、その概念的分析との間にかような乖離的関係が存するとすれば、「いき」の概念的分析は、意味体験としての「いき」の構造を外部より了得せしむる場合に、「いき」の存在の把握に適切なる位地と機会とを提供する以外の実際的価値をもち得ないであろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、「シーザーとカティリナとアルキビアデスとが顕著な典型を提供する」もので、ほとんど男性に限り適用される意味内容である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして後に不利な証拠物件を提供するためにダンサーの指環を靴磨きに贈らせ、靴磨きの金鎚をその部屋に遺却させる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は読者の心理学的機関に衝動を与え、その運転を導くような資料を提供するのであって、その作の価値はその資料の選択や、それを提供する順序や仕方によって規定される。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に云った第一の方法、すなわち心理過程の追究を読者に任せる方法でも、その読者を導いて普遍的な心理的経験を遂行させる事が必要であるが、その作に価値を与えるためにはその経験が単に普遍であるのみならず、それが読者にとってなんらかの意味で新しいものであり、また更に新しい問題を提供するものでなければならない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は茲で、アラヽギ諸同人に忠告を試みたい、我諸同人の歌は、概して形式を重じ過ぎた粉飾の過ぎた弊が多いやうであるから、石川君の歌などの、とんと形式に拘泥しない、粉飾の少しもないやうな歌風を見て、自己省察の料に供すべきである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことも一つの問題を提供するものであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　すみれ娘　日本の近代映画でも、ＰＣＬの提供するものの中には色々な点で有望な進歩の動向を示しているものがあるように思う。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝街道の朝　団九郎とおしま、後から武蔵がお供する。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女の夫の田村英介氏は才能あるにもかかわらず不幸にしてまだ無名の文士ではあったが、スマ子女史がつねに「彼氏浮気もの」と称しているだけになか／＼各方面に発展してスマ子女史に愉快な煩悶をときどき提供するのであった。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸入者の背後には、その商品を提供する哈爾賓のブルジョアが控えているばかりではなかった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術の巧拙は問ふ處でない、掲げて以て衆人の展覽に供すべき製作としては、いかに我慢強い自分も自分の方が佳いとは言へなかつた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術の巧拙は問う処でない、掲げて以て衆人の展覧に供すべき製作としては、いかに我慢強い自分も自分の方が佳いとは言えなかった。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この予期しなかった出来事は、見方によっては、東京市民一般に関するいろいろな根本問題を研究するために必要あるいは有益な資料を提供する一つの大がかりなエキスペリメントであったとも見られなくはない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理分析研究家の材料にこの夢を提供する。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来れば、きょうすぐ東京へ帰りたかった。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房がヒステリイみたいに口やかましく、君の働きのなさを痛罵するものだから、君も大きいこと言って、何か真顔で、きょうすぐお金がはいるあてがあるなんて、まっかな嘘ついて女房を喜ばせ、女房にうんと優しくされて家を出て、さて、なんにも、あてがない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨漏りというようなことを瞬間私は想像したのだが、言うまでもなく、天井には隙間はおろか汚点ひとつなく、第一、ここは二階で、うえにもう一つ三階があるのだし、それに、私は何という馬鹿だったろう、きょうすこしも雨の降らなかったことは、誰よりも、一日外出していた私が承知しなければならないはずだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっきょうするに、数年来、世の教育家なる者が、学問を尊び俗世界を賤しむこと、両様ともにはなはだしきにすぎ、高尚至極なる学問の型の中に無理に凡俗を包羅して、新奇の形を鋳冶せんとして、かえってその凡俗を容るることはできずして、大切なる教育を孤立せしめ、自から偏窟に陥りたるものといわざるをえず。",
              "citation": {
                "source": "慶応義塾学生諸氏に告ぐ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうすっぽかされては苦しいから。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりですな――ねえ、そうじゃありませんか――この種の事がらというものは、ひっきょうするにその……（いきなり大声で）ええっ面倒だ、あんたが気に入ったからって、それがわたしの罪ですか？",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、きょうすぐに、これから都へのぼるのか」「多少の支度もあるから、きょうというわけにはゆくまいが、いっこくも早く、菊亭右大臣にお会いして、なにかのことをうかがったうえ、密詔のご勅答を申しあげたいという若君のおことばだ」「なるほど。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
