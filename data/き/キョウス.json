  {
    "uuid": "b611aee0-5055-55a4-8986-aab2ecfb3d4b",
    "entry": "香子",
    "reading": {
      "primary": "きょうす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
