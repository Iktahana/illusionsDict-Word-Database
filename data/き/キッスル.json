    "definitions": [
      {
        "index": 1,
        "gloss": "to eat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議中に弁当を喫する参加者の姿がちらほら見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康維持のため、毎日バランスの取れた食事を喫するよう心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも、食事を喫する前に手を洗う習慣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの慘めな敗北を喫する狸は、その兎の少女を戀してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟は別として、人間の生活慾は、牛肉を快喫する動物性はあツても、人間の感情は、ただ一片の同胞の筋肉を見ても悚然とする。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの惨めな敗北を喫する狸は、その兎の少女を恋してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬまで僕一人で満喫する積りだ」　夕陽が隣の瓦屋根の角と後塀の上を掠つて庭に落ちる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君はその爽快味を満喫するため、大きく口をあけて、ハアーッハアーッと呼吸しながら、家まできてしまったのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛は、午前三時でも、四時でも、やはり、はね起き、而して必ず早すぎる朝食を喫するという。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自由なる牢獄にて大患に罹りし事とて、一時全快はなしたるものから、衰弱の度甚だしく、病気よりは疲労にて斃るることもやと心配せしに、これすら漸く回復して、遂には病前よりも一層の肥満を来し、その当時の写真を見ては、一驚を喫するほどなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道は東京からの、日帰り乃至は一泊の旅には最も平易であり新緑と海の香りを満喫するに充分であらう。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、恋愛の代りに、義務や服従を喫するのに、飽き果ててしまっていた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日もむろん前日にまさる炎暑でしたが、勤番は半日交替で午前中にひけるはずでしたから、伝六の怪しげなる腕まえによって調理された朝食を喫すると、あまりぞっとしない顔つきで、むっつりとしながら出仕いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚旅行も唐崎さん――ではない新妻みどりの稼ぎ貯めた財布のお陰で南伊豆まで遠出をし、温泉気分と夫婦生活とを満喫することができた。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏藪の筍がによき／＼のぞきはじめた、当分、筍のうまさを満喫することだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄太居のよさを満喫する、澄太君には大人の風格がある、私は友人として澄太君をめぐまれてゐることを感謝する、考へて見ると、私のやうなぐうたらに澄太君のやうな人物が配せられたといふ事実はまことに意義深遠なものがあると思ふ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平原のハイキングならまだしもだが、少くとも山岳の多い日本でのハイキングに或る程度山へ入らなければ意味を成さないのに、今年のやうにかうじめ／＼した秋霖が打続いたのでは、よほど運が好くなければハイキングの快味を満喫するといふ訳には行かない。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、明け方の五時から正午まで――十二時になるとお婆さんが二階の戸を叩打して男を追い出す――こうして、この空博奕に勝ったやつが、白熊テレサと彼女の over voluptuousness を専有し満喫するのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の女性が、結婚の科学をも十分わきまえて、ますます強く美しい肉体の歓びをも満喫する生活を持ってゆくとすれば、それは本当にうれしいと思う。",
              "citation": {
                "source": "結婚論の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ボタ山へ月見草咲きつゞき五月三十日　晴、行程五里、高津尾といふ山村、祝出屋（三〇・中）早く起きて別れる、そして川棚へ急ぐ、労れて途中で泊る、この宿はほんたうにしづかだ、山の宿の空気を満喫する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ椀盛などの味淡泊水の如く殆ど喫するに堪へざる所以なりと。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵其方向は王子附近で、王子の茶を買つて帰り、又帰途に白山の砂場で蕎麦を喫するを例とした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ田中が大村に案内されていないとしても、誰かに連れられてきっとこの界隈へ朝鮮色を満喫するために来ているに違いなかった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶わんに茶や飯を盛つて喫するといふことは人生の最大幸福である、といふ報捨の念があつた。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近くこれを譬うれば、かの煙草を喫する者を見よ。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜斤の価十銭の葉を喫するも、口に美ならざるに非ず。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子はづれに響く諸音の騒然たる中で、且つ飲み且つ喫する事は、予等の如き不慣れな者に取つて奇異な落ちつかぬ感じであるが、慣れて見れば個中に支那の燕楽の趣があるのであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶を喫するに法あり、茶の湯の道と云ふ。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁田岳とのコルに近づくと、深さ丈余もあるクレバスがリッジ上に形成されていて一驚を喫する。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茶を喫するという意味なのだ」老武士は口の中で呟いた。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンへの途中、マンチェスターもバーミンガムも空には夥しい阻塞氣球の城壁ができてゐて物物しかつたが、ロンドンに入ると更に夥しい氣球で、それだけでも戰爭氣分を滿喫するに十分だつた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り十歳位な小供でも東京辺の大人位食物を喫するね。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
