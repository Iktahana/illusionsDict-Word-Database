        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今回の失敗は、彼にとって大きな痛手を喫することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長引く不況で、多くの企業が厳しい状況を喫している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の病で、彼はキャリアの転機を喫した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
