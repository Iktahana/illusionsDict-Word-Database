    "definitions": [
      {
        "index": 1,
        "gloss": "whim",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "店先でふと目についた派手なスカーフを、彼女は気まぐれで買ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日は中華の気分、明日はイタリアンと、彼の食事はいつも気まぐれだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが急に動物園に行きたいと言い出したのは、また気まぐれだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の描く絵は、その時の気まぐれでタッチが大きく変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "健忘症の政治家や気まぐれな学界元老などの手に任せておくにはあまりに大切な仕事である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていたずらに「数」の気まぐれに翻弄された。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "製板所の構内だということはもくもくした新らしい鋸屑が敷かれ、鋸の音が気まぐれにそこを飛んでいたのでわかりました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この力を原動力に利用して各種の作業をすれば利益があるだろうという事はよく人の考える事だが、ただ一つ困る事は、風は至って気まぐれ者で、思う時に思うように吹いてくれぬので、始終きまった馬力を要する器械にはちょっと使いにくい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手客のほんの気まぐれに振り向けられた親しみに対して、ああまともに親身の情を返すのは、湊の持っているものが減ってしまうように感じた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の上海投機の気まぐれで、銀塊相場を有史以来の崩壊に導いた、その余波のためにこの輸出綿花事務所は不況のどん底にいた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう反抗も、その経験を繰返えすに従って、一部の兵卒の気まぐれなやり方では、あまりに効果が薄いことを克明に知るばかりだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの画家が時々もっと気まぐれを出していろいろな「試み」をやってくれる事を常に望んでいる。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか須田町で乗換えたときに気まぐれに葉巻を買って吸付けたばかりに電車を棄権して日本橋まで歩いてしまった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "張という男は、こんな気まぐれな男だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の帰途気まぐれに自分はＥで電車を降り、あらましの見当と思う方角へ歩いて見た。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対にまた世俗に有名ないわゆる大家がたまたま気まぐれに書き散らした途方もない寝言のようなものが、存外有名になって、新聞記者はもちろん、相当な学者までもそれがあたかも大傑作であり世界的大論文であるかのごとく信ずるような場合もあるのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの目も時々われわれをだますが、いつもだますと限らないで、時々は気まぐれにほんとうのものを見せてくれるので困る。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して物ずきな少数学者の気まぐれな研究に任すべき性質のものでなく、消防吏員や保険会社の統計係の手にゆだねてそれで安心していられるようなものでもなく、国家の一機関として統制された研究所の研究室において徹底的系統的に研究さるべきものではないかと思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今度のような事件はむしろあるいは落雷の災害などと比較されてもいいようなきわめて稀有な偶然のなすわざで、たまたまこの気まぐれな偶然のいたずらの犠牲になった生徒たちの不幸はもちろんであるが、その責任を負わされる先生も土地の人も誠に珍しい災難に会ったのだというふうに考えられないこともないわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこのような幼少なものには常識がないから、したがって気まぐれである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "製板所の構内だといふことはもくもくした新らしい鋸屑が敷かれ、鋸の音が気まぐれにそこを飛んでゐたのでわかりました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど今時分の夕立なんて、よっぽど気まぐれだ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝から小雨が降りそそぎ、その晴れ間にはおりおり生ま暖かな日かげも射してまことに気まぐれな空合い。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京女の気まぐれ者にはそれで済でゆくので、三日も四日も仕事を休む、どうかすると十日も休む、けれどサアとなれば人三倍も働くのが宅の磯｜様だと心得ている、だからサアとなれば困りや仕ないと信じている。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "異郷の空に語る者もない淋しさ佗しさから気まぐれに拵えた家庭に憂き雲が立って心が騒ぐのだろう。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんきに書店の棚を見てあるくうちに時々気まぐれに手を延ばして引っぱりだす書物が偶然にもその人にとって最も必要な本であるというようなことになるのではないか。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気まぐれだから送り狼に化けぬとも限らんよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって、生物の肉体に対する自然の気まぐれな浸蝕作用に対し、不損不滅の肉体を持ち度いと希う本能は持って居る筈だけれど、よほど原始人のままでこの本能慾が取り残されているのでなければ、特別にこういう慾を起すものではない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬翁はこれ等を、人手を借らずに並べ変えるのであったが、例の気まぐれから一日二日、大垣の町へ遊びに出かけて留守なので、書物は並べ放しにされていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飛び方は、気まぐれのようでもあり、舵がなくて飛びあえぬもののようでもある。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっ、とその手を出すほどの心になると、橋むこうの、屋根を、ひょいひょいと手踊り雀、電信柱に下向きの傾り燕、一羽気まぐれに浮いた鴎が、どこかの手飼いの鶯交りに、音を捕うる人心を、はッと同音に笑いでもする気勢。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつも気まぐれ者ですからね。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、おそろしく気まぐれでその上並々ならぬ空想癖をもっていたために、それが偶々こうした思いがけない調子外れの行為となって現われる迄の事であった。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
