        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "猫の気まぐれな行動に、飼い主は毎日振り回されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気まぐれな天気のせいで、ハイキングの計画はたびたび変更を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの作家は気まぐれで知られており、締め切りを守ったためしがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日のデザート、何にしようかな」「あなたの気まぐれに付き合うのは疲れるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
