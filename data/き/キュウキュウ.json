  {
    "uuid": "a8efa057-f5f5-5aa2-ac3a-1c5f3c789a60",
    "entry": "岌岌",
    "reading": {
      "primary": "きゅうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
