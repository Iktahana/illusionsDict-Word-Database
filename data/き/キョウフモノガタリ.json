        "examples": {
          "standard": [
            {
              "text": "キャンプファイヤーの周りで、ガイドは皆が飛び上がるほど恐ろしい恐怖物語を語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、幽霊やモンスターの話、特に恐怖物語を読むのが大好きだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのアンソロジーには、心理スリラーから超常現象まで、さまざまな恐怖物語が含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「聞いて！君に素晴らしい恐怖物語があるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それからまた、ひとしきり恐怖物語にみなさん夢中。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
