    "definitions": [
      {
        "index": 1,
        "gloss": "smoking (tobacco)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
