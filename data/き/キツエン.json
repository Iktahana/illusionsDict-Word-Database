        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公共の場所での喫煙は、周りの人に配慮しなくてはいけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康を考えて、そろそろ喫煙をやめようと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は喫煙の習慣がないので、タバコの煙が苦手だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近では、喫煙に関する規制が厳しくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はおなかがペコペコなのだが、喫煙室のソーファに沈んで煙草を吹かしてゐるより他はなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧進帳が終つて喫煙室に這入ると、「好いですね、好いですね、よくやりますね」と一人の爺々ィが云つてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが喫煙おまへのその、白い二本の脛が、　　夕暮、港の町の寒い夕暮、によきによきと、ペエヴの上を歩むのだ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は生涯喫煙はしなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃同年輩の中学生で喫煙するのはちっとも珍しくなかったし、それに父は非常な愛煙家であったから両親の許可を得るには何の困難もなかった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神棚の燈明をつけるために使う燧金には大きな木の板片が把手についているし、ほくちも多量にあるから点火しやすいが、喫煙用のは小さい鉄片の頭を指先で抓んで打ちつけ、その火花を石に添えたわずかな火口に点じようとするのだから六かしいのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンでも電車の内は禁煙であったが車掌台は喫煙者のために解放されていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく煙草をのまぬ人は喫煙者に同情がないということだけはたしかである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書室などで喫煙を禁じるのは、喫煙家にとっては読書を禁じられると同等の効果を生じる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も喫煙家の製造する煙草の煙はただ空中に散らばるだけで大概あまり役には立たないようであるが、あるいは空中高く昇って雨滴凝結の心核にはなるかもしれない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫煙家は考えようでは製煙機械のようなものである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから昼間は阿片喫煙者のように倦怠です」　とＫ君は言いました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの四句をどこかの科学研究所の喫煙室の壁にでも記銘しておいてふさわしいものであると思う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」と出してやる、そして自分も煙草を出して、甲乙共、のどかに喫煙いだした。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、未成年者喫煙の図を見られちゃった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の喫煙場で、隆と友人とが山の話をしていたが、ここにも病人があるらしく、若い女が流しの方で、しきりに氷をかいていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの一室で、立続けに電話をかけたり、紹介の文案を書いたり、訪問記者と折衝したりして、深い疲労と、極度な喫煙で、どろんとした顔付きになっている逸作は、強いて事もなげに言った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫煙家だつたら煙草を棄てて仕舞ふが宜い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯ういふ連中は、恰度、喫煙者がニコチン中毒に罹り、オピユムイーターが阿片中毒に罹るやうに、慢性の倫理中毒といふ奴に侵されてゐる。",
              "citation": {
                "source": "文藝中毒",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にあれほどの大酒も、喫煙もすっかりやめて、氏の遊蕩無頼な生活は、日夜｜祈祷の生活と激変してしまいました。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の喫煙量は急に増えて行った。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日四十本以上吸うのは、絶対のニコチン中毒だということだが、私の喫煙量は高等学校時代に、既にその限界を超えてしまったのだ。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかつて薬の効能書に「食間服用」とあるのを、食事の最中に服用するものだと早合点して、食事中に薬を飲んで笑われたことがあるが、しかしこの煙草に関しては私はつねに「食間喫煙」であった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月××日　消化不良と喫煙過多と、金にならぬ過労とで、全く死にそうだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は喫煙室に入り、サモア流に車座になって蹲んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧から、女王然たる老婆が喫煙を止めて、何か叱る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥から、女王然たる老婆が喫煙を止めて、何か叱る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
