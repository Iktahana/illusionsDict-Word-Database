        "examples": {
          "standard": [
            {
              "text": "「ご期待に沿うよう、チーム一丸となってプロジェクトの完遂に全力を尽くします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "残念ながら、今回の提案内容は弊社の予算枠内での期待に沿うものではありませんでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "納期を短縮してほしいという顧客の期待に沿うため、工場に増員を要請する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その名を科学的批評と呼ぶことは、案外人々のこの言葉に対する若干の期待に沿うているかも知れないのだ、と。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通アブサーディティー又はナンセンスを笑いと結び付けて考えるが、今の点から見れば却って、精密な期待に沿うことさえ笑いになると云うことが判る。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
