    "definitions": [
      {
        "index": 1,
        "gloss": "to be performed (on the stage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
