        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勧進帳の前が予定食事時間、三十分の休憩。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩室の土間の壁面にメンバーの名札がずらりと並んでいる。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の休憩室には色々な飾り物が所狭く陳列してあって、それに「花○喜○｜丈」と一々札がつけてある。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その靴磨きのルンペンの一人がすなわち休憩室の飾り物を貰った子供の御父さんである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度さう云ふ、をばさんの休憩の時であつた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事の休憩時間が少し長引き過ぎた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が元の休憩室に歸つた時、机の上には食事の用意が調つてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "管絃のプログラムが終ると、しばらくの休憩の後に舞楽が始まった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作業にかゝると休憩まで、彼女達と彼等は、用事上で喋ることも、雑談することも禁じられていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分間の休憩もなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タバコ（休憩時間のこと）には耳鳴りは一層ひどくなった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩の時間が来たとき私は離れた席にいる友達に目※せをして人びとの肩の間を屋外に出た。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩の時間を残しながら席に帰った私は、すいた会場のなかに残っている女の人の顔などをぼんやり見たりしながら、心がやっと少しずつ寛解して来たのを覚えていた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に一｜所、湖神が設けの休憩所――応接間とも思ふのを視た。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩時間に廊下へ出て腰かけて煙草でも吹かしていると、自然にのどかなあくびを催して来る、すると今までなんとなしにしゃちこばってぎこちないものに見えた全世界が急になごやかに快いものに感ぜられて来て、眼前を歩いている見知らぬ青年男女にもなんとない親しみを感じるようになるのがわれながら不思議なくらいである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば兵営の浴室と隣の休憩室との間におけるカメラの往復によって映出される三人の士官の罪のない仲のいいいさかいなどでも、話の筋にはたいした直接の関係がないようであるが、これがあるので、後にこの三人が敵の牢屋に入れられてからのクライマックスがちゃんと生きて来るように思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、鍵屋と申します御休憩所でございますが、よそと張合っておりますので。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度此時、休憩所では乘船の仕度も整つたと見へ、濱島の頻りに私を呼ぶ聲が聽えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかな水が滾々と泉み流れて、其邊の草木の色さへ一段と麗はしい、此處で一休憩と腰をおろしたのは、かれこれ午後の五｜時近く、不思議なる響は漸く近くなつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに馬車の休憩所ありて、馬に飲い、客に茶を売るを例とすれども、今日ばかりは素通りなるべし、と乗り合いは心々に想いぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩があり、やがてアトラクションの幕が上った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼾は公演場の休憩室の隅にあるソファから聴えていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "××港から船に乗り込む前の二時間ばかり、××町の東三〇〇米の地点で休憩するから面会に来てくれというＳの頼みをまつ迄もなく、私はＳを見送る喜びに燃えた。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校での休憩時間にも好んで女の子と遊び、少女のようにきゃしゃな体や色の白い小ぢんまり整った顔は女教師たちに可愛がられていたが、自分の身なりのみすぼらしさを恥じているようであった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦地へ出かける途中、上野駅に下車して、そこで多少の休憩の時間があるからそれを利用し、僕と一ぱい飲もうという算段にちがいないと僕は賢察していたのである。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて座談会の筈でありましたが、委員は、お疲れのようですから、少し休憩なさい、と私にすすめてくれましたが、私は、「いいえ、私のほうは大丈夫です。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分間、皆その場に坐ったままで休憩しました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだ具合いのよい時でも、自分は、さっぱり勉強せず、学校へ行っても授業時間に漫画などを書き、休憩時間にはそれをクラスの者たちに説明して聞かせて、笑わせてやりました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお弁当を二つも貰って食べ抹茶も一服よばれたのち、しばらくの休憩をとるため、座敷に張り廻らした紅白だんだらの幔幕を向うへ弾ね潜って出る。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京近郊或る勝景地の旧家である私の家の奥座敷はその日家来を大勢ものものしく率ゐた或る高貴の人の遊行の途次の休憩所でした。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
