        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清らかになまめかしい白足袋も一足落ちている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何の歌だか分らないが、二部の合唱で、靜かな穩かな清らかな感じのするものであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車のゴー／＼といふ單調な重々しい基音の上に、清らかに澄み切つた二つの音の流れがゆるやかな拍子で合つたり離れたり入り亂れて流れて行く。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖を下りて停車場の方へ行く道傍には清らかな小流が音を立てゝ流れて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかな斎の衣は、鶴の羽づくろいしながら泉を渡るに似て爽かにも厳かである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間はあんなにまでも美しく清らかに生きて行くことが出來るのだ。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室の床の上に美しい灰を撒き、清らかな藁を敷いて、その上に病人を寢かすことになつてゐます。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛は肩にたれて、まっ白な花をさした少女やそのほか、なんとなく気恥ずかしくってよくは見えませんでした、ただ一様に清らかで美しいと感じました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱漆で塗った地に黒漆でからすの絵を描いたその下に烏丸枇杷葉湯と書いた一対の細長い箱を振り分けに肩にかついで「ホンケー、カラスマル、ビワヨーオートー」と終わりの「ヨートー」を長く清らかに引いて、呼び歩いていたようにも思うし、また木陰などに荷をおろして往来の人に呼びかけていたようにも思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕に讃美歌の合唱が聞こえて、それがこうした山間の静寂な天地で聞くと一層美しく清らかなものに聞こえた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺はだんだん癒ってゆくぞ」　コロコロ、コロコロ、彼の小さな希望は深夜の空気を清らかに顫わせた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上を蟻が清らかに匍っていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小田原の町を放れ、函嶺の湯本近に一軒、茶店の娘、窶れ姿のいと美しきが、路傍の筧、前なる山凡そ三四百間遠き處に千歳久しき靈水を引いたりといふ、清らかなる樋の口に冷たき其の土を洗ふを見て、山の芋は鰻になる、此の牛蒡恁くて石清水に身を灌がば、あはれ白魚に化しやせんと、そゞろ胸に手を置きしが。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議や、唄った時の白痴の声はこの話をお聞きなさるお前様はもとよりじゃが、私も推量したとは月鼈雲泥、天地の相違、節廻し、あげさげ、呼吸の続くところから、第一その清らかな涼しい声という者は、到底この少年の咽喉から出たものではない。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "世には、清らかな白歯を玉と云ふ、真珠と云ふ、貝と言ふ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼は清らかに澄み、その面は明らかに晴れていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうときに、清らかに明るい喫茶店にはいって、暖かいストーブのそばのマーブルのテーブルを前に腰かけてすする熱いコーヒーは、そういう夢幻的の空想を発酵させるに適したものである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その老人のむすこにはその理由がどうしてもわからなかったのであったが、それから二三十年たってその老人もなくなって後に、そのむすこが自分の家庭をもつようになって、そうして生活もやや安定して来たころのある年の正月｜元旦の朝清らかな心持ちで起床した瞬間からなんとなく腹の立つような事がいろいろ目についた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女は、しんから、平気で、清らかな眼さえしていた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ああ神様…………私たち二人は、こんな苛責に会いながら、病気一つせずに、日に増し丸々と肥って、康強に、美しく長って行くのです、この島の清らかな風と、水と、豊穣な食物と、美しい、楽しい、花と鳥とに護られて…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなんの歌だかわからないが、二部の合唱で、静かな穏やかな清らかな感じのするものであった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車のゴーゴーという単調な重々しい基音の上に、清らかに澄みきった二つの音の流れがゆるやかな拍子で合ったり離れたり入り乱れて流れて行く。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖をおりて停車場のほうへ行く道ばたには清らかな小流れが音を立てて流れていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが朝の仕事に取りかかる際に、もう少し清らかな頭をもって、神聖であるべきその日の勤めに対する事ができはしまいか。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいにおいて春の花のほがらかさと、秋の月の清らかさとを正と負、陽と陰の両極として対立させたものであるに相違ない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地と空とが見交す瞳の情熱の豊さ、美しくも妬ましき自然――おお私にも心を迎えて呉れる清らかな胸が無いものか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、しかし――この清らかな繭のような餅を見るとき、捨て難きあのおん方――思い断ち難きわが心――。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難　――わたしは清らかな繭と見る、また峯を連ねた雪の山だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "待て、人の妻と逢曳を、と心付いて、首を低れると、再び真暗になった時、更に、しかし、身はまだ清らかであると、気を取直して改めて、青く燃ゆる服の飾を嬉しそうに見た。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　きよらかな声であると私は思った。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
