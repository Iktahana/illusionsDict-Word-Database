          "literary": [
            {
              "text": "キリスト教社会主義とでも、いへばいへよう。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "○政党キリスト教社会主義（極右）社会党大ドイツ党共産党○共産党と社会党との衝突はひどい。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点キリスト教社会主義や無政府主義もそうだろう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この自由主義はマルクシズムに取っては、無政府主義やキリスト教社会主義以上に、社会的運動としては微力なので、之は今の処、さし当り大した問題とはならない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
