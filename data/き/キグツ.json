    "definitions": [
      {
        "index": 1,
        "gloss": "wooden shoes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして私の足もとから私の歩みを引き離して、それでもつて町の向う側を、木靴でもつてのやうに鳴らしだした。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてＫさんと一緒に、質素な詰襟の服を著て、黒塗の木靴をはいた、五十位の年配の人が出て來た。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の木靴の音が床に緩く響いた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそこではびっこがなんの役にも立たないむしろ目ざわりなうるさい木靴の騒音発声器になっているだけである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百姓さんは、すぐさま、そばへやってきて、木靴で氷をくだいて、家のおかみさんのところへ持って帰りました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すずの手のついた、料理道具があるんでさ」こう言いながら、古い木靴を取り出して、カラスをそのまんなかに入れました。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのチャンチャン坊主の支那兵たちは、木綿の綿入の満洲服に、支那風の木靴を履き、赤い珊瑚玉のついた帽子を被り、辮髪の豚尾を背中に長くたらしていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王冠と、釣竿と、帽子と、木靴を残して一目散に逃失せてしまった。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は穿いていた木靴で氷を割り、子家鴨を連れて、妻のところに帰って来ました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "等々の総合的な推理からして、僕はこの靴を、一種の木靴――あの真夏の海水浴場で、熱い砂の上を婦人達が履いて歩く可愛い海水靴であると推定したんだ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとそこ等には誰も居ませんで、直ぐ前の横路地に、香潮の姿を見て逃げ出して行った果物屋の婆さんが、逃げかけに打っ棄って行った灰色の大きなマントと、黒い覆面の付いた茶色の頭巾と、毛皮の手袋と木靴とがありましたから、それを盗んで手早く身に着けて、すっかりお婆さんに化けてしまいました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "風車、木靴、にせダイヤ、おらんだ人形、銀細工、ゆだや人、運河。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫・木靴・ひまわり、麦の農村の平和と、ホテルの主人の昼寝とを一しょに妨げてしまう。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄鎚は鉄鎚で集まり、車輪は車輪であつまり、あちこちに調べ革と木靴の模様が散らばっていて、ちょうどお尻のところに聖書が一冊描いてありました。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、間もなく、彼の足音に代って石を打つ木靴の音が聞えて来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　反耶の木靴の音は暫く格子の前で廻っていた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして、木靴を履いた娘が踊ったのだ、――すると、この事件には一人の人間もいなくなってしまったのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が減つたので異つた路を登つて街へ引返したが、黒塗の大きな木靴を引ずつて敷石の上に音をさせ乍ら悠然と歩く肥つた老人が土地で一流の料理屋「アンリイ四世楼」を教へて呉れた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "折折木靴を穿いた田舎人が通る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪頭に縁の垂れた黒い帽を被て紅い毛糸のぶくぶくした襯衣に汚れた青黒い天鵞絨の洋袴を穿き、大きな木靴を引ずつて、又してもギタルを弾乍ら「聴きなさい、お前たち、南｜仏蘭西の田舎の麦刈唄を一つ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コスモはなんのかざりもない色のあせた黒い服をつけ、まんなかにすりきれたふさのついてる大黒帽をかぶり、木靴をはいていました。",
              "citation": {
                "source": "活人形",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今いったように、ベルナアルさんはもう一歩で白僧衣になるところだったので、白い僧衣を着、大きな木靴を穿き、手に祈祷書を持って丘の斜面や落葉松の林の中を眼を伏せて敬虔なようすで歩いていた。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまた多くの手と、多くの顔と、多くの素足と、多くの木靴とを染めた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから小さな中庭には、急いでかけつける木靴の音がつゞき、教場の戸口のところで「はい。",
              "citation": {
                "source": "村の学校（実話）",
                "author": "アルフオンズ・ドーデー　Alphonse Daudet",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の姿を見ると、彼女は軽い小刻みな足どりで、割れた木靴を引っかけ、脚の皮膚を白靴下のようにきゅっと穿いて、早速駆け寄って来る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の木靴をすれすれに掠め、その木のところをちょっと齧ってみ、あるいは大胆不敵にも、とうとうその上に登る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心して、途中で止らないようにしながら、植木屋の木靴の足跡のなかでは、いっとき道に迷ったのではないかと心配する。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は毛糸の上着をひっかけ、木靴をはいている。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が素足のままつっかけている木靴は、二本の平行した足あとをつける。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた、燻製の顔をした、モンペ姿の婦人がやつて来ると、ハンドバツクを下に置きぐつたりと膝を伸した。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
