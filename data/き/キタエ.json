        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「小さいときから、打ったり叩かれたりして踊りで鍛えられたお蔭だよ」　だが、彼女はその幼年時代の苦労を思い起して、暗澹とした顔つきになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たい、おまえは私に似て情熱家肌の純情屋さんなのに、よくも、そこを矯め堪えて、現実に生きる歩調に性情を鍛え直そうとした。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂を打込んだ真心が幾度か無惨に裏切られ、悩みに悩みを嘗めて鍛えられた心がいつわりやすい目的に目をくれなくなるのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動で鍛えた身体であったが、中年の頃赤痢にかかってから不断腸の工合が悪かった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味での俳句で鍛え上げた先生の文章が元来力強く美しい上に更に力強く美しくなったのも当然であろう。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃剣を鍛えそれを振り廻したりする魯鈍な大衆以外の人間によって戦争が決定せられ得る限り、それは何遍も繰りかえし起されるであろう。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の身体や脚はただ鎚でたたいて鍛え上げたばかりの鉄片を組合せて作ったきわめて簡単なもののように見える。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "デエコン煮えたかア――」と怒鳴る船乗の声は、永年波と風と、海の広さを相手として鍛えられたおかげで、立派に押えの利いた甲張りになっている。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するに、吾々の日常生活に於ける所作や発声は、その目的が何であるに拘らず、真剣に鍛えられて来るに従って、「能」のソレに近づいて来る。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧二　――わたくし達の腕は、戒律で鍛え上げて御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心を鍛える事ばかり尊しとして体を弱めてしまってはならぬ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには片切彫にしくものはない」　おかみさんを慰めたさもあって骨折るうちに知らず知らず徳永は明治の名匠加納夏雄以来の伎倆を鍛えたと言った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦畠の中へ引くりかえって、青天井で寝た処で、天窓が一つ重くなるようなんじゃあないよ、鍛えてあらあな。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象はその通だし、胆玉は大いし、体は鍛えてある、まあ、第一、その目つきが容易じゃあない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の痴話の傍杖より、今は、高き天、広き世を持つ、学士榊三吉も、むかし、一高で骨を鍛えた向陵の健児の意気は衰えず、「何をする、何をするんだ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の現状を報じ、芸術の傾向を語り、ちょっとした走り書きの旅行便りからも、かの女はむす子がこの稚純晩成質の母である自分を強くし、人生の如何なる現実にも傷まず生きられるよう、しっかりした性根と、抵抗力のある心の皮膚を鍛えしむるよう心懸けている本能的なものが感じられた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに話術を鍛えた近頃の下町の芸妓の話は、巧まずして面白かったが、自分の差当りの作品への焦慮からこんな話を喜んで聞いているほど、作家の心から遊離していいものかどうか、私の興味は臆しながら、牽き入れられて行った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、野良仕事一つ為た事が無いけれど、三日に一度の喧嘩に、鍛えに鍛えた骨節が強くて、相撲、力試し、何でも一人前やる。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心を見物衆の重石に置いて、呼吸を練り、気を鍛え、やがて、件の白蔵主。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じの方は、武生と言えば、ああ、水のきれいな処かと言われます――この水が鐘を鍛えるのに適するそうで、釜、鍋、庖丁、一切の名産――その昔は、聞えた刀鍛冶も住みました。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいしたものだよ」といって、古浴衣を上っ張りに着て、姉さま冠りに裾捲りをし、河岸ぶちに出て藁たわしでごし／＼洗っている姿にも、どこか鍛えられた藤間の躾けの線があり、見飽きない母でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどのように置き代えてもちゃんとして格式の見える身体の据りに躾けで鍛えられて来たわたしの趣味の嗜慾は礼拝歓喜する。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の肉体は相当鍛えられていたから四肢の活躍につれ、私の股や腕にギリシャの彫刻に見るような筋肉の房が現われた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "琵琶湖の浪で鍛え上げた腕節。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庖丁らしいものを鉄床の上に置いてそれを鉄槌で鍛えていた。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで大概の人は途中で思い切ってしまっただろうが、登りつめた人の腕や足は鉄のようにきたえられたに相違ない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本刀をきたえる気持ちで文を草している。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、いちばんかたいはがねで、いなずまをきたえさせました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "色できたえたこのキャッキャッだ」　京吉はそうふざけながら、しかし、表情だけはさすがに固く、パイを取って来ると、くそッと力を入れてその表を撫ぜた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」庄平「大丈夫です、いゝ身体ですよ」鶴三（微笑する）「なにしろ、十二の歳から四十五まで、船乗りをしてきたえて来た身体ですからね」庄平「それがまたどうして……？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
