  {
    "uuid": "7a1d1df0-4f7d-5e6b-909b-54e134ca60b7",
    "entry": "貴陽",
    "reading": {
      "primary": "きよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
