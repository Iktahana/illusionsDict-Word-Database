[
  {
    "uuid": "880788c4-0580-5803-b334-87d815b0bd60",
    "entry": "器用",
    "reading": {
      "primary": "きよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "skillful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さもなければ、無器用朴訥な愛嬌で助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はわるし、文章は下手、学問は無し、すべてに無器用、熊の手さながら、おまけに醜貌、たった一つの取り柄は、からだの丈夫なところだけであった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に著いて、すぐ女中さんたちに輕い冗談言へるやうな、器用な男ではないのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「………あゝなる程………成程、」　不器量であり、不器用である妻君の女優は、本当のことを言つたら三流四流といふ所でなければならなかつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をさせても器用であって、彼の作った紙鳶は風の弱い時でも実によく揚りそうして強風にも安定であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはどうも、不器用といふわけではないが、決してさういふわけではないが、鮒なんて水の中のものを捕へる事が出來ねえので、どうも、あいつはおいしいといふ事だけは知つてゐながら、それ以來三十何年間、いや、はははは、つい兄の口眞似をしちやつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と狸は、はしやいで、石油鑵ぐらゐの大きさの、れいのお辨當箱をまづ舟に積み込み、「お前は、しかし、ずいぶん器用な娘だねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかだか、三枚か四枚で、井伏さんの素描など、不器用な私には出來るわけがないのだ。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方を仰ぐと、赤沢岳が無器用な円頂閣のように、幅びろく突ッ立って、その花崗岩の赤く禿げた截断面が、銅の薬鑵のような色をして、冷めたく荒い空気に煤ぶっている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲消えて皹も亦拭ひ去らる、山色何の瑠璃ぞ、只だ赭丹赭黄なる熔岩の、奇醜大塊を、至つて無器用に束ねて嶄立せるのみ、その肩を怒らし胸を張れるを見て、淑美なる女性的崇高を知らず。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は、ういういしく不器用な形の獣の仔を見ると、何か心の喘ぎが止まるような気がした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その走り方は、不器用な中に鳥獣のような俊敏さがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の方が却って男の不器用を察して気ずつない思いを紛らすために、わきを向きながら小さな声で唄ったなど　　黥ける利目など　　黥ける利目　これは、男の顔を、ちらと見たとき、自然と思い浮べられた歌の文句だった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この大根、嫁かずであれ、――今に」そういうかと思うと、たちまち、男はまた、不器用にも俊敏に去った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は寝具だけは身分不相応のものを作っていて、羽根蒲団など、自分で鳥屋から羽根を買って来て器用に拵えていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作楽井は器用な男だったので、表具やちょっとした建具左官の仕事は出来る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無器用なお前樣が此子いぢくる譯にも行くまじ、お歸りに成るまで私が乳を上げませうと、有さまを見かねて、隣の妻の子を抱いて行くに、何分お頼み申ますと言ひながら、美尾の行衞に心を取られてお町が事はうはの空に成ぬ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを眼の高さに三十センチの処まで持って来て、さて器用な手つきをしてぱらぱらと数えて見せた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者がその方則を述べる字句の巧拙や運算の器用不器用は必ずしもその方則の価値と比例しないのと一般であろう。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時母に送った手紙に「あんなに不器用では実験家として成効しそうもない」と云ってこの政治家の余技を評している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の知っている狭い範囲だけでも蕪村、高陽のごとき人の傑作に対する時は、そこに幾多の不細工あるいは不恰好が優れた器用と手際との中に巧みに入り乱れ織り込まれて、ちょうど力強い名匠の音楽の演奏を聞くような感じがするのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に不器用な子供の描いたようなところがあると思うとまた非常に巧妙な鋭利なところがある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、彼の歩き方の不器用さは、緩和し、そして今度はさつさと歩いて行きました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓帷は引かれて、夏の午後のきびしい日ざしは、臆病な、怯やかされてゐるやうな器具類を一々檢査したり、龜裂の入つた鏡の中を不器用さうにうろつき※つてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして徳利を器用に持上げて酌をしてやる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しただ一人久保田さんが纎細緻｜密な作品を書く人でありながら球突ではひどく不器用なのを除けばそれぞれに球突の中にも作品の感じが現れてくるから面白い。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし豚は棒を持った男が近づいて来ると、それまでおとなしくしていたやつまでが、急に頭を無器用に振ってはねとびだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "断えず噛みながら脚で器用に団塊を廻して行くので、始めには多少いびつであったのが、ほとんど完全な球形になってしまって、もうどこにも毛などの痕跡は見えなくなってしまった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し我が儘なところのある彼の姉と触れ合っている態度に、少しも無理がなく、――それを器用にやっているのではなく、生地からの平和な生まれ付きでやっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よりよく生きようといふ心懸けだけが我等人間の願ひとして容れられる。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
