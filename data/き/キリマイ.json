    "definitions": [
      {
        "index": 1,
        "gloss": "rice (or an equivalent sum of money) given as salary to low-ranking samurai (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "井原は切米三人｜扶持十石を取っていた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲津で狼藉者を取り押さえて、五人扶持十五石の切米取りにせられた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤は奥納戸役を勤めた切米取りである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "野田は天草の家老野田｜美濃の倅で、切米取りに召し出された。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林は二人扶持十石の切米取りである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "切米取りの殉死者はわりに多人数であったが、中にも津崎五助の事蹟は、きわだって面白いから別に書くことにする。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五助は二人扶持六石の切米取りで、忠利の犬牽きである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "扶持切米召し放され、渡川限西へ流罪仰せ付けられる。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "実子あるものは実子を兵卒に召し抱え、二人扶持切米四石を下し置かれると云うのが二つ。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お切米、お扶持米、御役料の手形書替へをする。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "切米とは、扶持米を數囘に分けてか、又は金錢に取り替へて渡すことをいふので、手形の書替とは、切米券を、請取にしてもらふことで、請取手形が渡ると、受取人の名を紙に書いて割竹に挾み、大倉役所の藁苞に※込んでくるのである。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい一合二合の切米でなりとも、主取りさえできたら、きっと願いを出して、表向きそなたを引取るようにするから、それまでのところは、寂しかろうが、このまま御近所の世話になっていてもらいたい。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "御老女衆記（古事類苑官位部引）の大奥女中分限の条に、一御切米四石、一御合力金弐両、一壱人扶持、一薪参束、一湯之木弐束、一油半夜半分、一御菜銀拾弐両　　右御半下とある。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此外に御切米四石、二月・十一月両度に被下。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右者従古来掃除役人之名小法師と名付、今以知行御切米被下之。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御切米五拾俵被下置候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰ったというのは食の道のことだが、一年の先の分まで借りだしたうえに、一人がかすかすにやっていく雀の涙ほどの切米を、舅にまで分けるのだから、くりまわしのつけようがない。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬる茶を一ぱい飲んだだけで役所へ出たが、切米手形の発出をあずかる割場の下役が用人部屋へ遊びにきて、むだ話のついでに、こんなことをいった。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者火急のことで切米手形を抵當に僅か五十兩の金を借りると、期限前から催促だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "猿蟹合戰",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日か七日約束の日に遲れると、恐れながらと、その切米手形を持込んで龍の口へ訴へ出る野郎だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "猿蟹合戰",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分も知つて居るだらう、直參の切米手形は首から二番目の大事な品で、それを紛失しただけでも輕くて閉門、重くて追放だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "猿蟹合戰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の秤座は通四丁目の一角を占める大きな建物で、役人としては僅か切米十俵二人｜扶持の小身ですが、二戸前の土藏を後に背負つて、繁昌眼を驚かすばかり。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "秤座政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の秤座は通四丁目の一角を占める大きな建物で、役人としてはわずか切米十俵二人｜扶の小身ですが、二た戸前の土蔵を背後に背負って、繁昌眼を驚かすばかり。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "秤座政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときの扶持が御切米金十五両、御合力七両二分の他に、月々薪六貫四分、炭二俵八分、水油八合、糠二升八合、菜銀三十匁で、子供を三人使うことが出来た。",
              "citation": {
                "source": "柘榴",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府や三家の大上※に当る奥勤めの最上位で、切米も三十石、合力二十五両という扶持である。",
              "citation": {
                "source": "柘榴",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女鳥羽は、「奥向きの取締りを怠った」ということで、切米二十両十人扶持を付けて大条玄蕃へ預け。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日より駅売の弁当も食事時間外は無く（京都では七月二十何日とかゝら実施されたさうだが、東京でも今日から節米令が出て、時間を区切り、その時間外は一切米を出さず代用食のみ許すことゝなった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三｜合、はげしくわたりあうと、水色機が三機、ひゅーんとかなしげな悲鳴をあげて、きりきりまいながら、もえ落ちて来た。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度虎船長は、明日積荷を売るについて、その準備に、帳簿と書類の間にうずもれて、きりきりまいの最中だった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パックはきりきりまいして、仰向けに転んだり、横倒しになつたりした。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
