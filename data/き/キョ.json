[
  {
    "uuid": "06eb2508-a64f-53c0-b908-926e3f3186da",
    "entry": "距",
    "reading": {
      "primary": "きょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tubular nectary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "通路を距てて直ぐの向ひ側には、鉄道従業員の妻君みたいなのが、胸をはだけて赤坊に乳を飲ませてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして距離のへだてから、自然に交情が疏くなつてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもガードを一つ距てて、淀橋の向ふに二幸や三越のビルヂングが壘立し、空には青い廣告風船があがつて居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百米、二百米の短距離レエスでは、もう、この選手、全然見込みがない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの二つの、時間的にも空間的にも遠く距れた心像をつなぎ合せている何物かがあるだけはたしかでなければならない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷を距てた上野の動物園の仲間に比べるとここのは死刑囚であろう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右には未だ青き稲田を距てて白砂青松の中に白堊の高楼｜蜑の塩屋に交じり、その上に一抹の海青く汽船の往復する見ゆ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も複雑な分子と細胞内の微粒との距離ははなはだ近そうに見える。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその距離は全く吾人現在の知識で想像し得られないものである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今電車の窓から日曜の街の人通りをのどかに見下ろしている刻下の心持はただ自分が一通りの義務を果してしまった、この間中からの仕事が一段落をつげたと云うだけの単純な満足が心の底に動いているので、過去の憂苦も行末の心配も吉野紙を距てた絵ぐらいに思われて、ただ何となく寛ろいだ心持になっている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門も板塀も昔の方が今のより古くさびていたように思われ、それから門から玄関までの距離が昔はもっと遠かったような気がする。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通の発達につれて都会と田舎の距離は次第に短縮する。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、さうであるが、山岸の表現に就いての努力は、たつたいまのこの苦惱を、瞬時の距離に於いて切斷し、一まづ時間の流れのそとにピンセツトで、つまみ出し、その斷面圖をありありと擴大し、鮮明に着色して壁に貼りつけ、定着せしめることにある。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの山は眠ったことがないから、醒めたこともないというような、澄した顔つきをしている、私たちとの距離は、いよいよ遠くなった、その間を煙のように、眼先を霧が立って、右へ往きそうになったり、左へ思い出して、転がったりしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物が高くなるほど、富士が見えなくなり、交通が便利で、東京富士間の距離が短縮されるほど、市民の心から富士は切り取られて、さらしッ放しの無縁塔となってしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はサクラメントの大河に沿うて走る、川の底には、堅い凝灰岩などが露出しているが、シャスタを距ること、五十｜哩位のところから、熔岩が、両岸に段丘を作っている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の霧が、方々から烟のように這っているほど、快晴であるが、一合目辺をカッキリ境界線にして、頭上の富士山は、雲のためにまるで見えず、天上の空次第に低く垂れて、屋根の上を距ること僅に三尺。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは）　彼と、彼を愕かした少年との間には、言葉の異う二つの国民位の、距離があった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後に気を付けて見ると同年輩の友人の中の誰彼の額やこめかみにも、三尺以上｜距れていてもよく見えるほどの白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れに沿うて二條のトロの鐵軌が敷いてあつて、二三町距てた電車通の神社の脇に通じて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれだけの研究によって天の河を距るに従って星の密集の度が減ずる模様がよほどよく分って来たのである。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はまた写真電送機というものが成効に近づいて写真画図のごときものを一瞬間に遠距離に送る事さえ思いのままになろうという事である。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の暮にサント・ジュモンが始めて成効した時に飛んだ距離はわずかに二十五メートルであったが、この頃ファーマンやドラグランジュの飛行した距離は二万メートルに近く、すなわちわずか二年の間に飛行距離は八百倍になった訳である。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また磁石が電波を受けた瞬間にその磁力を変ずる事を利用したマルコニ式のマグネチック・デテクターと称するものもあって、これはごく遠距離の通信に限って用いられる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンとナウエンとの間十六マイルの距離に試みて成効したという。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信器のアンテナに電波が来れば急速な交番電流が起る、これを白熱灯デテクターおよび電流計あるいは電話の受話器に接続すれば、ごく微弱な電波でも感じるから遠距離の通信には都合のよいものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い水蒸気が、凱旋門からオベリスクの距離を実測よりやや遠く見せている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の右側、彼から五六十歩の距離に居る男女の密接に組んだ姿だ。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴と譬喩と、どうちがうか、それにさえきょとんとしている人がたまにはあるのだから、言うのに、ほんとに骨が折れる。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、あなたのお手紙の長さに感奮し、その返礼の気持もあり、こんな馬鹿正直の無警戒の手紙を差上げる事になりました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
