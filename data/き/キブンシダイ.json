    "definitions": [
      {
        "index": 1,
        "gloss": "according to (depending on) the mood of the moment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
