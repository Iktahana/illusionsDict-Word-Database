        "examples": {
          "standard": [
            {
              "text": "「今の大きな音、何だったの？」「聞いての通り、キッチンの皿が全部割れちゃったんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の結論は、先ほど課長が説明した聞いての通りの内容です。異論はありませんね？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「準備はもういいかな？」「聞いての通り、まだ外でバタバタしてる最中だよ。あと5分待って」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「新太郎、お静、気の毒だが、お前達も聞いての通りだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア、番所へ來い――三輪の兄哥、聞いての通りだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "麝香の匂ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア、番所へ来い――三輪の兄哥、聞いての通りだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新太郎、お靜、氣の毒だが、お前達も聞いての通りだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親方か、その方は」「そうです」「いま、聞いての通り、土地の顔役が、餅つき興行に、ここを借りたいと仰っしゃるのだ。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠房はさらに新九郎を見据えて、「聞いての通りな次第で、そちの身には危険が迫っている。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、次室には、佐々平左や、与左衛門も、姿をひそめて、佐吉の口上を聞いていたので、「聞いての通りじゃ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
