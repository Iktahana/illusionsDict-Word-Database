        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の生まれた年は乙巳で、知的な魅力があると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年は乙巳の年なので、新しいことに挑戦するのに良いと占いで見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その美術品が制作されたのは、明治時代の乙巳の年だそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国の歴史上重要な会議が、乙巳の年に開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は乙巳生まれなので、ヘビ年の運勢を毎年チェックしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "明治三十八乙巳年十月吉日鏡花　　　　　　　一「はい、貴客もしお熱いのを、お一つ召上りませぬか、何ぞお食りなされて下さりまし。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十八乙巳年十月吉日鏡花一「はい、貴客もしお熱いのを、お一つ召上りませぬか、何ぞお食りなされて下さりまし。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十八年（乙巳）　一九〇五○一月、明治座にてユーゴーの「エルナニ」五幕を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、乙巳、晴、将軍家鶴岳宮に御参、朝光御剣を役す、去る承元二年已来、御疱瘡の跡を憚らしめ給ふに依りて御出無し、今日始めて此儀有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日、乙巳、晴、筑後前司頼時、去夜京都より下向す、定家朝臣消息並びに和歌の文書等を進ず。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、乙巳、天霽、義盛、時兼以下の謀叛の輩の所領美作淡路等の国の守護職、横山庄以下の宗たるの所々、先づ以て之を収公し、勲功の賞に充てらる可しと云々、相州、大官令之を沙汰し申さる、次に侍別当の事、義盛の闕を以て相州に仰せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八日、乙巳、甚雨、午剋大風、鶴岳八幡宮の鳥居顛倒す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘化二年乙巳とすべきか、弘化三年丙午とすべきかに惑ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弘化二乙巳元旦偶成。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに拜殿の前の石燈籠には中央上部に「蛭子大神宮」とあり、その下に向つて右に「願主源之丞」「座中」「天明五乙巳十一月吉日」と並び、左に「村中」と刻んであるのを發見した。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "史記孝景本記に、「三年正月乙巳天火燔※陽東宮大殿城室」とあり、易林に「天火大起、飛鳥驚駭」とある如きである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「□□□天皇御世乙巳年六月十一日、近江天皇、林太郎□□ヲ殺シ、明日ヲ以テ其ノ父豊浦大臣子孫等皆之ヲ滅ス」　アッサリしたものです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから二年目が入鹿と蝦夷の殺された年であるが、それを法王帝説は、「□□□天皇御世乙巳年六月十日」　と書きだしているね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇極四年ならば、法王帝説は、先の条にある如く「飛鳥天皇御世乙巳年」と書く筈だね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、「□□□天皇御世乙巳年」は皇極天皇の飛鳥ではなく、甘梼岡だか林太郎だか他の何物だか知らないが、蝦夷天皇か入鹿天皇を示すどれかの三字があったのだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『幽林先生遺稿』に「天明｜乙巳ノ春張州ノ諸友ニ留別ス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔江亭春寂寂トシテ／山路樹重重タリ／酒ニ対ヒテ交ハリノ歓ビ薄ク／花ヲ看テ別レノ恨ミ濃シ／依遅トシテ故国ヲ辞シ／迢逓トシテ遥峰ニ向フ／京洛ノ旧朋友／恐ラクハ憔悴ノ容ニ驚カン〕天明五年乙巳には幽林は齢既に六十に達している。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十四　弘化二年｜乙巳の歳枕山は御徒町の新居に二十八歳の春を迎えた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "発程の日は詳でないがその集に「乙巳季夏」とあるから六月下旬であろう。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今茲乙巳余｜鄙作『詠物詩』ヲ再刊スルノ挙アリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『火後憶得詩』を見るに、湖山は去年乙巳の八月に麹町平川町に卜居し、この年丙午の三月に至って某処の谷町に移り更にまた俎橋に転居したのである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘化二年｜乙巳　　松陰兵を山田｜亦介に学ぶ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿蘭陀政府諸公閣下弘化二年｜乙巳六月朔日阿部伊勢守正弘印牧野備前守忠雅印青山下野守忠良印戸田山城守忠温印　如何に忠告書の親切にして、返書の冷淡無意義なるを見よ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
