        "examples": {
          "standard": [
            {
              "text": "市の主要な水道供給は、山間部にあるこの大きな給水池から来ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "技師たちは、給水池の水位を注意深く監視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水質保護のため、給水池周辺への立ち入りは制限されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この給水池は100年以上前からあるんですよ」とガイドは説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大きい給水池のまわりを矢島さんは静に歩いた。",
              "citation": {
                "source": "過渡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして給水池の所に来た時、何か罪の意識をでもふり落すように一二度頭を横に振った。",
              "citation": {
                "source": "過渡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
