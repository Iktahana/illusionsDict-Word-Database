    },
    "definitions": [
      {
        "index": 1,
        "gloss": "you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを第三者が批評して「貴殿広き世界を三百石の屋敷のうちに見らるゝ故なり。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が、Ｔ「拙者、強い方を　叩き斬る」　面喰って居る旗本を尻目に大吉尚も、Ｔ「貴殿が御強よう　厶ったら、今頃　貴殿の其の首は　まさか胴には……」　「着いちゃいまいテ」と大笑する。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍が、Ｔ「日下部先生お出で　と知って、よう出て　来ぬとは大吉も　案外情けない奴」　と言えば、　進藤が、Ｔ「と思って居られる　から、御貴殿は　未だ若い」　若いと言われて若侍訝しそう。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "易者が、Ｔ「貴殿を死ぬ程恋する女性が居る」　左膳が、Ｔ「一人で結構」　と言って、Ｔ「美人だろうなその女」　易者がクシャクシャと口の中でとなえ乍ら、Ｔ「絶世の佳人」　で左膳喜んだ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや皆まで申されるな」　「では」となりひらが、Ｔ「この連判状は貴殿に進呈致すその代り」　と言って、Ｔ「但馬屋源兵衛を早速放免して戴きたい」　「よろしゅう御座る」と左衛門、　「では」となりひら連判状を其処へ置く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「デハ貴殿が　宮本先生」　そうじゃ、と団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「早速貴殿の奥方様にお目に掛りましょう」　敬四郎が驚いて、　「いいや」Ｔ「身共の家内は身共が調べる」　右門が、　「では」Ｔ「拙者もお立合致します」　と言われては敬四郎も、　「勝手にさッしゃい」という他なし。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家殿、貴殿は一人の読者に千度読まれるのと、十万の読者に一度読まれるのと、いったい、いずれをお望みかな？",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿は我輩のやうに黒猫ではないから、まあ大した心配はあるまい。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主は、笠ながら会釈して、「貴殿は大高源吾どの？",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "流水濁らず、奔湍腐らず、御心境日々に新たなる事こそ、貴殿の如き芸術家志望の者には望ましく被存候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまりかねて野田武蔵、ぐいと百石衛門の方に向き直り、「それは貴殿の無学のせいだ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿のお屋敷の浅い泉水とくらべられては困ります。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿の御心底には一片の情愛なし、信義なし。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見られよ、金内殿は貴殿の毒舌に遭い、先刻より身をふるわし、血涙をしぼって泣いてござるわ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金内殿は、貴殿とは違って、うそなど言う仁ではござらぬ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃の金内殿の実直を、貴殿はよもや知らぬとは申されますまい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿にかかわったことではござらぬ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿にかかわった事ではござらぬ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿御所持の宝物、如何ようのものかは存ぜぬが、此男に呉れつかわされて、誓言通り此男に課状を負わさば、我等が企も」と言いかくるを、主人左京は遽ただしく眼と手とに一時に制止して、「卒爾にものを言わるる勿。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿の御存じ寄り通りになるものとのみ、それがしを御見積りは御無体でござる。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "手段は既に十分にととのい、敵将を追落し敵城を乗取ること、嚢の物を探るが如くになり居れど、ただ兵粮其他の支えの足らぬため、勝っても勝を保ち難く、奪っても復奪わるべきを慮り、それ故に老巧の方々、事を挙ぐるに挙げかね、現に貴殿も日夜此段に苦んで居らるるではござらぬか。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "損得利害明白なと、其の損得沙汰を心すずしい貴殿までが言わるるよナ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿やそれがし如きは損得に眼などが開いて居らぬ者。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其損得に掛けて武士道――忠義をごったにし、それはそれ、これはこれと、全く別の事を一ツにして、貴殿の思わくに従えとか。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ此の木沢左京が主家を思い敵を悪む心、貴殿に分寸もおくれ居ろうか、無念骨髄に徹して遺恨｜已み難ければこそ、此の企も人先きに起したれ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿一人が悪いではないが、エーイ、癪に触る一世の姿。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴殿をやった後で、心もとなくなって来たから、見に来たところじゃ」　平太郎と権八は刀を収めて並んで立った。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
