[
  {
    "uuid": "94532c28-4165-59ba-9d02-b895d15a7a2c",
    "entry": "危険",
    "reading": {
      "primary": "きけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
