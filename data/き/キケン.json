      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "danger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その危険な兆候が、五十｜歳を越えてからしばしば現われて来た。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に深く交際のない人には、一層発作が出易く危険なので、自然こちらから交際を避け、つとめて会わないようにして来たのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう、鳥にとってはおそらく生れて以来かつて経験した事のない異常な官能行使の要求に応じるに忙しくて、身に迫る危険を自覚し、そうして逃走の第一歩を踏出すだけの余裕もきっかけもないのであろう。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雪田もズッと裾の方へ行くと、雪の穹門から水が滾々と湧き出ていて、洞内に高山植物などが美しく咲いている、但し夏日うっかり奥まで深く這入ると、雪がくずれて圧倒する危険がないとも限らぬ。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「腐る」（不発）のがあると、危険だからであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫の子供ではあっても、その中へは入る事が許されなかったし、又、許されたとしても、そこがどんなに危険であるかは、子供の心にも浸み込んでいた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室ばかりで仕事をしている学者達はめったに引っかかる危険のないようなこうした種類の係蹄が時々「天然」の研究者の行手に待伏せしているのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばその人が従来続けて来た平静な生活から転じて、危険性を帯びたある工業に関係した当座に前述のような災難に会ったとしたらどうであろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア人と中央アジア並びにインド人と交渉のあったことは確かであり、後者とシナ人、シナ人と日本人とそれぞれの交通のあったことも間違いないとすれば、歌謡のごときものが全く相互沒交渉に別々に発達したと断定するのも少し危険なような気がするのである。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "根津を抜けて帰るつもりであったが頻繁に襲って来る余震で煉瓦壁の頽れかかったのがあらたに倒れたりするのを見て低湿地の街路は危険だと思ったから谷中三崎町から団子坂へ向かった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし裏庭へ出ていたら危険なわけであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然の設計による平衡を乱す前には、よほどよく考えてかからないと危険なものである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼日中、そんな危険な事が出来ますか。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の一生を小さい陥穽に嵌め込んでしまう危険と、何か不明の牽引力の為めに、危険と判り切ったものへ好んで身を挺して行く絶体絶命の気持ちとが、生れて始めての極度の緊張感を彼から抽き出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の中に濃硫酸をいれるのに、極めて徐々に少しずつ滴下していれば酸は徐々に自然に水中に混合して大して間違いは起らないが、いきなり多量に流し込むと非常な熱を発生して罎が破れたり、火傷したりする危険が発生する。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝た部屋が真暗で、電燈をつけようと思ったら電球が外ずしてあったそうで、そのときに友人は天井から垂れ下がったコードを目撃したであろうし、またソケットに露出した電極の電圧の危険を無意識に意識したのではないかと思われる。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話を友人のＡ君に話したら、Ａ君のいうのに、昔ローマを滅ぼしたのは風呂場である、あまり風呂場を鼓吹するのは危険ではないかと。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の危険を恐れれば地震国の日本などには住まわぬがよいというと一般なものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴を生んだ日本に、西鶴型の科学者の出現を望むのは必ずしも空頼めでないはずであるが、ただそういう型の学者は時にアカデミーの咎めを受けて成敗される危険がないとも限らない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども実際は科学者が科学の領域を踏み外す危険を防止するためには、時にこれらの反省的考察が却って必要なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際こういうような考えはある意味において甚だ危険である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味の危険を避けるために、どこまでも科学の立脚地たる経験的事実を見失わぬようにしなければならない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の科学の基礎方則を疑うのは危険であっても、社会主義が国家主義に危険であったり青年の思潮が老人に危険であるのとは趣を異にする。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的に一家が整わぬ所へ、やれ家庭小説じゃ、家庭料理じゃ、家庭科学じゃ、家庭の娯楽じゃと、騒ぎ立てることが、如何に覚束なきものなるか、予は危険を感ぜざるを得ないのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日においては、「神」の「み」は「ミ」の乙類に属し「上」の「み」は甲類に属して互いに混同せず、奈良朝またはそれ以前においては発音が違っておったのであろうと考えられますから、かような語源説は甚だ危険であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし安全も危険も実は相対的の言葉である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯の危険率も、危険地帯の安全率もゼロではない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後は何処にゆきけん、仮にも声の聞えずなりぬ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人がよみつる歌の事などさま／″＼胸に迫りて、ほと／＼涙もこぼれつべく、ゆかしさのいと堪へがたければ、閨の戸おして大空を打見あぐるに、月には横雲少しかゝりて、見わたす岡の若葉のかげ暗う、過ぎゆきけんかげも見えぬなん、いと口惜しうもゆかしうも唯身にしみて打ながめられき。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と帽子を取って目深に被り、戸外へ出づればかの男は、何方へ行きけん影も無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
