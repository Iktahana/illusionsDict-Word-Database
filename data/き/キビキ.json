[
  {
    "uuid": "d6b9d15d-6108-5649-96ce-98f1e73e9676",
    "entry": "忌引",
    "reading": {
      "primary": "きびき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
