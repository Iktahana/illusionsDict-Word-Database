    },
    "definitions": [
      {
        "index": 1,
        "gloss": "extremely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人情と義理と利害をＸＹＺの座標とする空間に描きだされた複雑極まりない曲面の集合の一つの切り口が見える。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この「法性」を知る前に、大生命中のいちいちの組立てにつき、その変幻極まりない複雑な相を、前に述べました因縁の法則に当てはめて相において学び取ろうとするのが、私たちの智の範囲に属する経験や知識です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に、紛雑極まりない現実の真直中に分け入り無私と慈悲を行い、和恭勤勉を保って行くという、積極的な現実浄化の仕事こそ、難事中の難事であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分に対して残虐極まりない自分の逞ましさの上に恃みを見出して来るときであります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に光を孕んだ豐麗極まりない藍紫色の大圓盤が、船の白塗の欄干の上になり下になりして、とてつもなく大きく高く膨れ上り、さて又ぐうんと低く沈んで行く。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に光を孕んだ豊麗極まりない藍紫色の大円盤が、船の白塗の欄干の上になり下になりして、とてつもなく大きく高く膨れ上り、さてまたぐうんと低く沈んで行く。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は、ありようが実に普通極まりないものを、真面目に取り合おうとはしない。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまででも君は問題の面白さに同意してくれるだろうが、調べてすぐ、最初の見当以上に異常極まりないと実感した。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に当つて画家はいふ「自然の美は極まりない。",
              "citation": {
                "source": "描かれた花",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、釣れぬと知りつつ、こんな冬ざれの寒風をおかしながら、わざわざ夜釣りにやって来たのは、タナゴ釣りの豪奢極まりない清興に心惹かれたからでした。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎はあの犬をけしかけて借金とりを悸したり、自分が小作人｜苛めに赴く時の供に使つてゐるさうだが、あいつを一番擲り殺して、ヤグラ岳で狼を退治した、野良を荒し、人畜を害して極まりない狼をやつつけたと吹聴したら、定めし俺達の奇智に人々は舌を巻くだらうが！",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の紳士が貴下にある極まりない重要事に関して意見を承るべく、参上致します。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "また今日の建築は危険極まりないことは周知の事実であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、野蛮極まりないブルジョア・地主的天皇制支配の機関の一つであることを絶対見逃してはならない。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも資本家地主の狡さ極まりないことには、こうして搾りつけるに便利なようにと、処女会だの御用雑誌だのをつかって、プロレタリア・農民の女の文化の程度を何処までも奴隷的な低さに止めて置こうとする。",
              "citation": {
                "source": "婦人と文学の話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八三年三月十四日――イエニーの死後三年目の早春に、人類の炬火のかかげ手カール・マルクスはメートランド・パークの家の書斎の肘掛椅子にかけて、六十五年の豊富極まりない一生を閉じた。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、自分の生活は俗にいう不徹底極まりない生活である。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーカサスの雄大極まりない山嶽を南へ縫ってウラジ・カウカアズから、スターリンの故郷チフリースまで、立派な自動車道が通っている。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくレオナルドの唇にはこの唇をかく時には、同じ微妙なそして同じ幽玄極まりない微笑をもらした事であらう。",
              "citation": {
                "source": "美術上の婦人",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなときでも東西に別れて二人が帰らねばならぬ事情というものは、やはりそれぞれにこれで胸中にあるのだなと矢代は思い、またそれが日本の風習である限り是非それだけは守らねば、どっちの父母からも許されぬもののあるのが、厳格極まりない日本だと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その卵白色とエナメル黒のダンダラの長い長い抛物線型に伸びた触角は、宇宙間に彷徨している超時間的、超空間的の無限の波動を、自由自在の敏感さで受容れるところの……そうして受入れつつユラリユラリと桐の葉蔭で旋回しているところの……変幻極まりない鋭敏な、小さい、生きた、アンテナそのものであった。",
              "citation": {
                "source": "髪切虫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの淫蕩極まりない私通史には、是非の論が喧囂と湧き起らずにはいなかった。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い散光の下で昨夜通りの書割の前で、法水はあの妖冶極まりない野獣――陶孔雀の犯罪顛末を語り始めたのであった。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し室内には、曽て何人も見なかったであろう所の、幻怪極まりない光景が展開されていた。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲脚の変幻極まりない時代の姿を、曙覧他界した慶応四年八月前後の北陸辺に関して抽出してみると、同月会津征討越後口総督府参謀西園寺公望が村松に入り、その翌日長岡藩の反将河井継之助が敗死、同年六月会津征討越後口総督嘉彰親王が征途につかれ、廿七日敦賀に御宿せられ、八月十二日には越後三条に進まれてゐる。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには日毎に朽ち果てて行く不治の病者が、なほ残された個我の生命力に引きずられて、陰惨極まりない生活を描いてゐる。",
              "citation": {
                "source": "月日",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、西洋近世のロヂカルなファルス的文章法といふものは、本質的には実に単純極まりないもので、「ＡはＡである」とか、「Ａは非Ａでない」と言つた類ひの最も単純な法則の上で、それを基調として、アヤなされてゐる。",
              "citation": {
                "source": "FARCE に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの組立ては、いちいちに様が変り、時を経るに従って事情を違えては行くものの、その様の変りよう、事情の違いようが複雑変幻きわまりない中に、およそ一貫した根本の性質があるというのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより事は急、壮烈きわまりない訴人のその覚悟を見ては、ちゅうちょしている場合でないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝入舟町｜甚七店　束巻師　源五兵衛　　　　謹上　墨痕あざやかに書かれてあったのは、右のような不思議きわまりない幾文字かでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            }
          ]
        }
