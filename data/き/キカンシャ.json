[
  {
    "uuid": "c94cfdd4-b678-5d06-ad3e-8ce6f5306a30",
    "entry": "機関車",
    "reading": {
      "primary": "きかんしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
