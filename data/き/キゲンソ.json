          "literary": [
            {
              "text": "君は少しふきげんそうな、口の重い、癇で背たけが伸び切らないといったような少年だった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の行楽に遊び疲れたらしい人の群れにまじってふきげんそうに顔をしかめた倉地は真向に坂の頂上を見つめながら近づいて来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三芳　やあ……（わざと不きげんそうな顔で）いらっしゃい。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもふきげんそうな顔つきをし、客を威嚇しようとでも思ってるかのようで、はいって来る人々に乱暴な言葉を浴びせ、料理を食わせるというよりむしろ喧嘩を売りつけようとしてるかのようだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
