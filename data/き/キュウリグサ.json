          "standard": [
            {
              "text": "道端に咲く小さな胡瓜草の花に、春の訪れを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の片隅で胡瓜草が群生し、可憐な青い花を咲かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、胡瓜草の葉をちぎると、確かにキュウリのような匂いがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はこのムラサキ科の者を絶対にタビラコと認めぬゆえに、新にこれに贋タビラコの新称を与えて置いたが、その後それにキュウリグサの名がある事を知った。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
