    "definitions": [
      {
        "index": 1,
        "gloss": "lying with one's head to the north (trad. position for dead bodies; taboo for sleeping)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その死骸を奥へ運んで、頸にからんでいる帯をといて、北枕に行儀よく横たえて、かれは泣いて拝んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の先生は自分が知つてからは何時でも北枕で居た。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は一番毒の少ないカナトウ鰒をば喰いましたが、だんだん免疫て来ますと虎鰒、北枕ナンチいうものを喰わんとフク喰うたような気持になりまっせん。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北枕なぞを喰うた後で、外へ出て太陽光に当ると、眼が眩うてフラフラと足が止まらぬ位シビレます。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北枕を喰うた奴も一町内に三人や五人は居るような事でトント自慢になりまっせんケニ、一番恐ろしいナメラという奴を喰うてみました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手当も出来ないで、ただ川のへりの長屋に、それでも日の目が拝めると、北枕に水の方へ黒髪を乱して倒れている、かかる者の夜更けて船頭の読経を聞くのは、どんなに悲しかろう、果敢なかろう、情なかろう、また嬉しかろう。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その八畳の座敷の片隅に、小さい娘の死骸が北枕に寝かされて、さすがに水と線香とが供えてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕７・26サンデー毎日　日本では寝るのに北枕を嫌ふ習慣がありますが、フランスの科学者のいふところによると、ぐつすり熟睡しようとするには、北枕で足を南に投げ出すに限るさうです。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団の上に這ひ上りて、今度は足を障子に向けて北枕に寐ぬ。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は『死人の北枕』というのを知っているかね。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁力線と並行の北枕というのが、理論上最も静かなる位置なんだからね。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちが北枕かも判らなかつたが、いまは、死者は、富岡に、壁ぎはへ枕をうつして貰つて、平べつたくなつてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林青年の手料理だが、新鮮無類の「北枕」……一名ナメラという一番スゴイ鰒の赤肝だ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一四　翌日、浪路の、北枕の亡骸の側に、法印を居残らせて、どこへか出て行った闇太郎、道具屋の小僧らしいのに、大きな箱のようなものを、大風呂敷で、背負わせて戻って来たが、ひろげて見ると、中から出たのは、丹塗りに、高蒔絵で波模様を現した、立派やかな、唐櫃だった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　手頃な屏風がないので、ただ都合の好い位置を択って、何の囲いもない所へ、そっと北枕に寝かした。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし共は、北枕といふことは決してしませんが、お二人とも、こつち枕でしてね、こつちが北です。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち名古屋河豚（小斎河豚）、目赤、虎河豚、黄金河豚、銀河豚、北枕、篭目河豚などが普通知られている。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らが、料理屋で食うのは虎河豚、名古屋河豚、世間では金河豚といっている黄金河豚であるが目赤と北枕、篭目は猛毒の持主で、食えば大概極楽行きである。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "北枕は名の示す通り、一度食ったならば北枕に寝かされるのを覚悟しなければならない、という危ない代物だ。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "北枕とも言い伝えられて来たところから、これは北でなければならないと言うものがある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日からの日本は、塩辛い水にかこまれ、北枕に寝た、細長いひとつの〈島〉にすぎない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、一膳飯と北枕とは一般に縁起が悪いといわれておる。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわけは、死んだ仏に差し上げる飯は盛り切りであるのと、死人を横臥さするときに北枕にするからである。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "型の如き屏風の中に、北枕で若旦那の死骸が横たへてありますが、線香をあげて膝行り寄つた平次は、たつた一目で、井戸の中で、三間以上の高さから、十貫目もある石を叩き付けられた死骸に相違ないと見てとりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "荒神箒",
                "note": "青空文庫"
              }
            },
            {
              "text": "中は六疊の一と間、檢屍の濟んだ死骸は、まだ棺にも納めず、煎餅布團の上へ北枕に寢かし、二枚折｜屏風を逆樣に、手習机を据ゑて駄線香をフンダンに燻し乍ら、松五郎はその前に神妙に膝小僧を揃へ、ポロポロと涙をこぼしては、お茶に紛らせた湯呑の冷酒を呷つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ入棺もせず、北枕に寢かして、逆さ屏風を廻した前に、弟子の良助と太吉がしきりに香を捻つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "城の繪圖面",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の真ん中、北枕に寝かした弥助の顔から、白い巾を取ってしばらく見詰めておりましたが、「旦那、この額の疵は、死んでから付いたものでございますね」「何？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中は六畳の一と間、検屍の済んだ死骸は、まだ棺にも納めず、煎餅蒲団の上へ北枕に寝かし、二枚折｜屏風を逆様に、手習机を据えて駄線香をフンダンに燻しながら、松五郎はその前に神妙に膝小僧を揃え、ポロポロと涙をこぼしては、お茶に紛らせた湯呑の冷酒を呷っております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
