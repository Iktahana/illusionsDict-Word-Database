        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがどうして、百姓どもは気が気じゃない。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴さん気が気じゃないよ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生懸命にあやしても、兎もすると泣き出そうとする赤ン坊を抱えて居ては気が気じゃない。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私だってそりゃ気が気じゃないんだけれどねエ……」　　　　　　　　三　主任の机はがら空きで、やって来ている連中も、執務姿にはなっているが或る者は廻転椅子をテーブルとは逆な方へ向けて新聞をひろげている。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーは遠慮なく低い方へ低い方へと滑って、木でも何でも見さかいなしだから乗ってる人間は気が気じゃない。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一年か二年、忘れていてくれるといいんだが、とにかく、いつ元の焼跡へ呼び戻されるかと思えば、全く気が気じゃないや」　幸いにもカスミ女史が、その夫君である考古学者カビ博士を紹介してくれたので、なんとかうまくやってもらえるかもしれない。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸の底へ、これがきこえるから、カメは気が気じゃない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはそばできいていても、気が気じゃない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ落とされるか、気が気じゃないよ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "左近は夢中にのびあがって倉三の耳に益々口を近づけて、手の障子をかたく張りまわして、「ナマズと出前持は八千円のことで酔えば酔うほど気が気じゃないぞ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしているあいだにもなにかはじまらないかと気が気じゃない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……正直に言えば、和泉屋の命ひとつを賭けたきわどい勝負で、さすがにおれも気が気じゃない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の時間は迫るし、俺は気が気じゃない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十二時までには、「清や、私、気が気じゃないよ。",
              "citation": {
                "source": "一年の計",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラス干しが眼の中で泳いでいるなんて、一見風流なようですが、当人としてはメクラになるかも知れないぞと、気が気じゃない。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客用の猫モツの代りにマグロの刺身だの肉鍋などを用意して、屋台にいても、女の通る姿を見かけるたびにドキリときて、気が気じゃない。",
              "citation": {
                "source": "出家物語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はもう昨今気が気じゃないんだ」「実は君……」「何だい？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気が気じゃないよ」「考えて見ると僕達の地位は社長の健康が土台になっている。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては車掌に知らせているんだな、こいつは愈々油断がならねえと気が気じゃないんだが、さて一件の物をどう始末したらいいのか、咄嗟の場合で日頃自慢の智慧も出ねえ。",
              "citation": {
                "source": "指環",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時開演の歌舞伎座へ行くのだから、気が気じゃない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっと、見物は帰りみちのこと、なにしろ役目を果さないうちは気が気じゃない……」　と燕作は、ふたたび笠のふちをおさえながら、一｜散に石段から石段をかけのぼっていくと、「こらッ」　といきなり合羽の襟をつかまれた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
