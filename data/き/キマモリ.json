    "definitions": [
      {
        "index": 1,
        "gloss": "fruits left on a tree during winter (supposedly causing more fruits to appear in the next season)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの風習で、木守りをすることで来年の豊作を願うんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冬の木枯らしが吹く中、一本だけ残された木守りの柿が寂しげに揺れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、木守りの風習が今も大切に受け継がれているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これと始めのうちに同居していたたくさんの花瓶はだんだんに入り代わって行くのに、これだけは木守りの渋柿のように残っていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最後の木守りの犬歯がとうとうひとりでふらふらと抜け出したときはさすがにさびしかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の中で、トウレの君のかたり草誠かはらで身を終へし愛人がいまはにのこしたる黄金のさかづきまもりつゝ　こんな事をうたって居た。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
