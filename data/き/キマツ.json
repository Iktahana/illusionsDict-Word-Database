    },
    "definitions": [
      {
        "index": 1,
        "gloss": "end of term",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（初中期の限界）後 Perikles（後期末）に至つて、民政主義は盛を極めた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一期末代添おうとしたに、松も苺も、もう見えぬ――　　――とまた唄う。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、学期末になると、体操の点が戊といふ最下等であつた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、學期末になると、體操の點が戍といふ最下等であつた。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇四にはじめておとずれた、そうした穏やかな空気と緊密な連帯は、慶一の期末試験の成績にまでは、いい影響をあたえてくれなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラの期末試験の現代国語は、四〇点だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷たい奴だな」「もう、明後日から期末だしね」　といって、頭に整髪料をふりかける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの廃屋の二階を、私が大切な瞑想の道場としている事を夢にも御存じない校長先生と、傴僂の老人の川村書記さんとは、いつも学期末の近付いた放課後になると、職員便所の横のカンナの葉蔭から、通行禁止の弓道場の板囲いの蔭伝いに仲よく連立って、コッソリと入って来られるのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "根室の港には、やがてまた押し迫って来る結氷期を前にして、漁期末の慌しさが訪れていた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が家を留守にしていたと云うのは、その頃県下の山間部に新しく開校された農学校へ、学務部からの指命を受けて学期末の一ヶ月を臨時の講師に出掛けていたのだった。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日しか四箇月が過ぎて、七月の末は一學期末の試驗。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日しか四箇月が過ぎて、七月の末は一学期末の試験。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆議制を経て、喧伝せられたものを採用するのが、文壇意識の出た前期末頃からの傾向で、其が一面、他派の非難を防ぐ楯にもなつた訣だ。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "見在書目録に二書の名の出て居る事は、平安朝初期末より前――即、公の鎖国以前――に、此等の書物の舶載せられて居た事を示して居るので、其が幾年前の事であつたかは明らかでない。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "です系統のものは、或は既に中世期末に起つて居た――勿論、その中世は室町期を中世末と見る考へ方であるが――との観察も凡誤りではない。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "学期末にどんな成績が発表されますやら……。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ数学にハあまり興味を持たないのか、さっぱり思はしくないので心配しましたが、此の度の中学入学受験予習のおかげで大分頭が鍛へられて少々難かしい問題もたやすく解かれる程度に進んだ様ですから、此の分ならば本学期末あたりから、もう大丈夫だとよろこんでゐます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "学期末の試験が済むと、各科目の担任教師は、一定の期日までに採点して報告しなければならなかった。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学期の途中には中間試験、学期末には、本試験がある。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口実測が正確であると仮定すれば、出生率の変動は、（脱漏を斟酌せず、そして各期末の人口をそれに先立つ五箇年間の平均出生と比較すれば、）一八〇一年は一対三四・八、一八一一年は一対三五・三、一八二一年は一対三六・五八となるであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから学期末まで、ウォードはハッチンソン暗号のフォトスタティックコピーと地元のカーウィン資料の収集にかかり切りだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "実のところ彼は学期末(*5)にあって解析学Ｄと上級一般心理学を落としており、まだ今なら失地を回復できるという一縷の想いで背水の陣を布いていたのだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルウッドはどうしてもそれを忘れることができず、そのため神経が切れてしまい、学期末までの間大学から離れることを強いられた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "(*5) アメリカでは秋に新学年が始まるので、学年末ではなく学期末です。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "学期末、五郎はとうとう落第した。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小室　期末には夜業に託けても宜しい。",
              "citation": {
                "source": "秀才養子鑑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先、学期末毎に苦情を言われては溜まらないから、その辺の理解をつけて置く必要があると思って、僕はその夕刻東金君を訪れた。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから学期末にかかると、「若様がた、学期はおわりが一番大切でございますぞ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学期末になまけてわるい成績をとるものは、それ、『百日｜薪を積み、一日にしてこれを焼く。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも期末試験が終わるまで待って」というようなやりとりがあり、期末試験の無事に終わった秋深いある雨の日、彼女の自宅の二階にある彼女の部屋で、若いふたりは裸になる。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
