[
  {
    "uuid": "15376683-8aa6-53dc-b559-3fb206e45cf0",
    "entry": "胸臆",
    "reading": {
      "primary": "きょうおく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
