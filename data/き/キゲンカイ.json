          "literary": [
            {
              "text": "私は、御機嫌買いである。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、叱られた供奴の、頭かきかき、なるほどねえ、考えれば考えるほど、こちとらの考え浅うござんした、えへっへっへ、と、なにちっとも考えてやしない、ただ主人への御機嫌買い。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに又ひょっくり、機嫌買いのお竜ちゃんも遊びにくるようになった。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふだんの無口な習慣から抜け出ようと努力しながら、これもまた機嫌買いらしい爺やを相手に世間話をし出した。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "面は綺麗だが、恐ろしい機嫌買いで、こちとらの手綱じゃ動きゃしません」「で、殺すとか言っているそうだな」「一時はカーッとしましたが、今じゃかえっていい塩梅だと思っていますよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんが御機嫌買いなら、却ってやり宜うございます」「御迷惑をかけます」「私も競争よ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リーズはごきげんかい」とお父さんは言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
