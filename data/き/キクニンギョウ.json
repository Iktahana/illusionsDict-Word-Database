    "definitions": [
      {
        "index": 1,
        "gloss": "doll clothed in chrysanthemum flowers and branches",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日のやうな日に見ると其の醜さが更に強められる、此んなものや菊人形などゝいふものに比べると例へば屠牛場の内部の光景の方がまだいくらか美しい位だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうのような日に見るとその醜さがさらに強められる、こんなものや菊人形などというものに比べるとたとえば屠牛場の内部の光景のほうがまだいくらか美しいくらいだと思う。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、わたくしの家は本郷の千駄木坂下町、どなたも御存じの菊人形で名高い団子坂の下で、小さな酒屋を開いていました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをば、菊細工、菊人形と、今しがた差出て名告りはしましたものの、……お話につけてもお恥かしい。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "階子段の下で、廊下を皈る、紫のコオトと、濃いお納戸にすれ違ったが、菊人形に、気も心も奪われて、言をかける隙もない。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂下では菊人形が二、三日前開業したばかりである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれで団子坂の菊人形が見たいから、連れていけなんて言うんだから」「連れていっておあげなさればいいのに。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川さんもいらっしゃい」「ええ行きましょう」「佐々木さんも」「菊人形は御免だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊人形を見るくらいなら活動写真を見に行きます」「菊人形はいいよ」と今度は広田先生が言いだした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日午後一時ごろから菊人形を見にまいりますから、広田先生の家までいらっしゃい。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊人形から出る声だ」と広田先生が評した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊人形で客を呼ぶ声が、おりおり二人のすわっている所まで聞こえる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤や菖蒲は単にその風趣を賞するだけであったが、躑躅には色々の人形細工がこしらえてあるので、秋の団子坂の菊人形と相対して、夏の大久保は女子供をひき寄せる力があった。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリソンさんは去年の九月、江戸の団子坂で菊人形を見物しているときに、女の巾着切りに逢いました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちでも繁昌している団子坂の菊人形、あれは江戸でも旧いものじゃあありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい江戸の菊細工は――などと、あなた方の前で物識りぶるわけではありませんが、文化九年の秋、巣鴨の染井の植木屋で菊人形を作り出したのが始まりで、それが大当りを取ったので、それを真似て方々で菊細工が出来ました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、このお話は文久元年の九月、ことしの団子坂は忠臣蔵の菊人形が大評判で繁昌しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の団子坂付近は、坂の両側にこそ町屋がならんでいましたが、裏通りは武家屋敷や寺や畑ばかりで、ふだんは田舎のように寂しい所でしたが、菊人形の繁昌する時節だけは江戸じゅうの人が押し掛けて来るので、たいへんな混雑でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、九月二十四日昼八ツ（午後二時）頃に、三人づれの外国人がこの菊人形を見物に来たんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十六日の朝、自分は子分の幸次郎を連れて、ともかくも団子坂へ出てゆくと、菊人形は相変らず繁昌していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし団子坂の菊人形を見物に行く明治時代の人達は、三十余年前にここで異人を殺してしまえと騒いだり、狐使いが殺されたりした事を夢にも知りますまい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊人形の噂を聞くたびに、わたくしはその昔のことが思い出されます」　古歌に「月やあらぬ、春やむかしの春ならぬ、わが身ひとつは本の身にして」とある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い熱がでて苦しむうちは、まだよいとして、全身に、すき間もなくふきでものがでて、それが膿をもって黄色に変じますと、まるであの菊人形のように……きくならば美しいですけれど、それがうみをもった黄色のできものでおおわれた有様を想像してごらんなさい。",
              "citation": {
                "source": "ジェンナー伝",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊人形宮本百合子-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）鏑木：入力者注　主に外字の説明や、傍点の位置の指定（例）やっちゃば通りまでできた。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃急な団子坂の左右に菊人形の小屋がかかった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬が足をすべらすほど傾斜のきつい、せまい団子坂の三分の一ばかり下って、人々の足もとがいくらか楽になったところの左側に一二軒、右側に三軒ばかり菊人形の店が出来た。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月下旬から十一月にかけて、団子坂の通りは菊人形で混雑し、菊見せんべいも、団子坂の菊人形につながった一つの東京名物なわけだった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊人形が国技館で開かれるようになってからは、見にゆく人の層も変ったらしいけれども、団子坂の菊人形と云われたことは、上野へ文展を見にゆく種類の人にも、そう縁の遠くない秋の行事の一つだったのではなかろうか。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
