    "definitions": [
      {
        "index": 1,
        "gloss": "decider",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五人全員が捕まったのだが、彼らに対する証拠が、決め手に欠けていた。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "署名のこの点はかなり含むところがある――事実上の決め手とも言える。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点が決め手になったやもしれぬ事件は何十件と挙げられる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その返事が決め手だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその分析力が挫かれ物語としても尻切れになりかねないものや、一方で全容が明らかならずその説明も友人の好む曇りない論理の決め手というより揣摩憶測にしか基づかないものもある。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「正直なところ、最後の決め手は大穴でした。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術というものはこの頃ではある一部でははっきりしておるようですが、芸術というものの研究に決め手が出来ていなかったお茶人たちは、彼の高橋箒庵などでも芸術とは皆目関係のないことに興味をもっておる。",
              "citation": {
                "source": "私の作陶体験は先人をかく観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この言葉が決め手となって、その場の一同どうにもみなざわざわ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "“創作性”があるかどうかの判断が決め手になると言えよう。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の奇妙なレンガ製古井戸が決め手だった――さっき話したような奴だ。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに決め手の要石となった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは事件の大きな決め手ともなるべきことであった。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがわかると、事件の決め手が付くのだが……」「まだあるわよ、オーゲ！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "張り込ませてから約二カ月ばかりの間に、その都度都度に寄せられ、この聞き込みを得た時分から、今度の犯罪に対する決め手として、嬢の頭の中で次第次第に※醸されてきたものである。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の決め手が違ったら、もうこれで探偵の看板は下してしまおう！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがムッソリーニはイタリア人で、イタリアを強くしたのであり、これこそが決め手だった。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "……細かなことは、その場でないと、決め手には出られませんな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの態度を、はっきりきめていただきたい。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで雑誌の最後的プランをきめてしまうのだとか言っていましたが、――どうでしょう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の秋祭はわが帰省中にとの両親の考えで少し繰り上げて八月某日にする事ときめてあったが、数日来のしけで御供物肴がないため三日延びた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやいや、さうきめてしまふのは、この善良の龜に對して氣の毒だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車屋のばあさんなどは「もうスッカリ御全快だそうで」と、ひとりできめてしまって、そっとふところから勘定書きを出して「どうもたいへんに、お早く御全快で」と言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親がきめてくれる、生涯ひとりの男を持って、何も迷わずに子供を儲けて、その子供の世話になって死んで行く」　ここまで聴くと、若い芸妓たちは、姐さんの話もいいがあとが人をくさらしていけないと評するのであった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば散歩に出るにしても、彼は最初からプランを立て、自分の好きな道筋や觀覽物やへ、文句なしに對手を引つぱつて行くにきめてる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩兵銃で射的をうつには、落ちついて、ゆっくりねらいをきめてから発射するのだが、猟にはそういう暇がなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突差にねらいをきめて、うたなければならない。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねらいをきめても、手さきが顫えて銃が思う通りにならなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って一概に秋を悲しいものときめてしまった昔の歌人などの気持が自分にはさっぱり呑みこめなかったのであった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも一度も行かないのは子供等に気の毒なような気がするので、日返り旅行という事を考えついてそれにきめていたのである。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不明瞭な点を残さず、悉くそれを赤ときめて、一掃してしまえば功績も一層｜水際立って司令部に認められる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
