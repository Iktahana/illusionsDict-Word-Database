    "definitions": [
      {
        "index": 1,
        "gloss": "operating system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このPCは古い基本ソフトを使っているから、最新のアプリが動かないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートウォッチを選ぶ際、どの基本ソフトが搭載されているかを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい基本ソフトのリリースに、多くのユーザーが期待を寄せている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、この基本ソフトって使いやすい？」 「うん、直感的でいいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現在のパーソナルコンピューターの多数派を占める、ＭＳ―ＤＯＳと呼ばれる基本ソフトを使ったマシンだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方マッキントッシュは、基本ソフトに使いこなしの仕掛けを組み込み、すべてのアプリケーションにこれを利用することを求めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどあの懐かしきＰＡＳＯＰＩＡがマシンの温度テスト用恒温槽で今もけなげに働いているのを発見したり、基本ソフトの開発部門にＮｅＸＴのキューブが転がっているのを見つけたりと青梅工場見学ツアーを存分に満喫しているうちに、またまた、次なる疑問がむくむくと湧いてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルとＩＢＭは先に、マルチメディア用の基本ソフトの共同開発にあたるとして、カレイダという会社を合弁で設立していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてブックマンにも、マイクロソフトの手になるマルチメディア・ビュアーと名付けられた基本ソフトが提供されることになった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "回路図を付けたうえで、ＲＯＭ★に記憶させておくモニターと呼ばれる基本ソフトのプログラムリストも公開するという方針には、品質管理の担当者から「公開した情報にもとづいてユーザーが何か手を加え、そこで問題が起きたらどう責任をとるのか」とクレームがついた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★複数のユーザーが、自分だけで独占しているような感覚でコンピューターを使える環境を目指した基本ソフトウエア。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして渡部和を中心に、ＩＴＯＳ（Interactive Tutorial Operating System）と名付けられたシステム１００用の新しい基本ソフトウエアの開発が始まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが開発チームは、一九七八（昭和五十三）年九月に発表したシステム１５０用の基本ソフトウエアとして、ＩＴＯＳのリリースにこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい機能を大幅に盛り込んだＩＴＯＳは、従来のシステム１００用の基本ソフトに比べ一〇倍ほどの規模に膨れ上がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで彼は、ベーシックとは性格の異なるオペレーティングシステム（ＯＳ）と呼ばれる基本ソフトをＩＭＳＡＩに載せるために、コンサルティングを依頼していたグレン・ユーイングを通じて開発元に連絡をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたマシンで、ベーシックの翻訳プログラムを自動的に立ち上げたり、どのキーが押されたかを判定して画面にその文字を表示するといった基本的な動作は、モニターと総称される小規模な基本ソフトがになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがユーザーは、こうした基本ソフトの存在をほとんど意識しなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが当初は高嶺の花だったフロッピーディスクをパーソナルコンピューターでも使おうとしはじめたころから、ユーザーは基本ソフトを意識しはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌出版社としてスタートしたアスキーは、このときを境にパーソナルコンピューターの基本ソフトの供給者という、もう一つの顔を備えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌出版から基本ソフトウエアの販売へという業態の拡張は、切り開くべき新しい世界の扉をつぎつぎとアスキーに開いていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇（昭和五十五）年の夏、ＩＢＭから基本ソフトウエア供給の打診があったとき、ビル・ゲイツにもポール・アレンにも、言語製品の供給に関しては何の懸念もなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳを成功させ、ＧＷベーシックに向けて流れを集めることができれば、マイクロソフトはパーソナルコンピューターの基本ソフトを独占的に押さえ、しかもプログラムの互換性を広く保証するという健全な役割を果たしうるはずだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＥＣのＰＣ―８００１は、日本市場のさまざまなマシンに基本ソフトを売り込んでいくきっかけとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌社を立ち上げたばかりの西が、ビル・ゲイツとの出会いをジャンピングボードとして基本ソフトの供給者へと脱皮を遂げたように、彼がマシン作りの主体へと再度の飛躍を試みるにあたっても、ある人物との出会いがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は、日本で『ＡＳＣＩＩ』という雑誌を出しており、マイクロソフトの副社長として、パーソナルコンピューターの基本ソフトウエアの開発と販売に取り組んでいると答えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターをどう進化させるか、その進路を決めるにあたってはマイクロソフトの基本ソフトの方向付けはきわめて大きな役割を果たした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもう一方で、パーソナルコンピューターの性格を決めてしまう基本ソフトウエアの開発作業には、未来に延びるレールを自分で敷いていくような喜びがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "基本ソフトウエアなどほとんど存在しない機械語のみの時代があり、言語がその役割の一部をにないはじめ、そしてＯＳが確立されようとしている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした流れに沿って基本ソフトウエアの規模が拡大するにつれ、開発作業もまたどんどん膨らみ、ハネウェルでは多くの要員が一つの仕事にかかわるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後のコンピューター事業の帰趨を決することになるＩＴＯＳの修正作業の責任者として、石井は基本ソフトウエア開発本部第三開発部長、古山良二を指名した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、渋面を浮かべて西和彦にベーシックの開発を拒否された経緯を語る浜田にとって、マシンの性格を決める基本ソフトウエアの持つ意味はなおいっそう重かった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその基本ソフトの上におびただしい労力と知恵がつぎ込まれ、たくさんのアプリケーションが書きためられていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六ビット機用基本ソフトの開発スケジュールを「明日中にもまとめてほしい」と古山に求めながら、浜田は最優先の緊急プロジェクトとして進めることになるこの開発計画に動員するスタッフを、脳裏に数えはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本家情報処理のＮ―10プロジェクト始動　一九八二（昭和五十七）年二月、基本ソフトウエアの開発スケジュールをたずさえて現われた古山良二の表情は、少しこわばっているように見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
