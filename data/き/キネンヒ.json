      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commemorative plaque (usu. on a stone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海岸沿いの崖の上には、かつてこの地を襲った大津波の教訓を刻んだ記念碑が置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寺の境内にひっそりと佇む記念碑には、この地を訪れた詩人の句が刻まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お父さん、この記念碑に書いてある文字、なんて読むの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ヘルマンの教室を出て右を見ると河向いにウィルヘルム一世記念碑のうしろの胸壁の裏側が見える。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "災害記念碑を立てて永久的警告を残してはどうかという説もあるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地方では明治二十九年の災害記念碑を建てたが、それが今では二つに折れて倒れたままになってころがっており、碑文などは全く読めないそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある地方では同様な碑を、山腹道路の傍で通行人の最もよく眼につく処に建てておいたが、その後新道が別に出来たために記念碑のある旧道は淋れてしまっているそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の岡の中腹に妙な記念碑のようなものがいくつも立っているのが、どういう意味だか分らない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "総持寺の厖大な建築や記念碑を見廻した時に私を襲った感じが、どういうものかこのケンプェルの挿絵の感じと非常によく似ていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の碑という高い記念碑がそびえているばかりです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ巽公園内にござ候記念碑の銅像を以て祭の中心といたし、ここを式場にあて候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも記念碑の正面にむかひあひたるが見え候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "サベリヨ記念碑を観た。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには美しい記念碑がいくつか立っています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頃は訪う人どころか、苔の下に土も枯れ、水も涸いていたんですが、近年他国の人たちが方々から尋ねて来て、世評が高いもんですから、記念碑が新しく建ちましてね、名所のようになりました。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでね、ここのお寺でも、新規に、初路さんの、やっぱり記念碑を建てる事になったんです。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念碑発起押っぽだての、帽子、靴、洋服、袴、髯の生えた、ご連中さ、そのつもりであったれど、寺の和尚様、承知さっしゃりましねえだ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあやあ、しっしっ、吹くやら、払いますやら、静として赤蜻蛉が動かねえとなると、はい、時代違いで、何の気もねえ若い徒も、さてこの働きに掛ってみれば、記念碑糸塚の因縁さ、よく聞いて知ってるもんだで。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが明治維新になって、神仏の分離のあった時、其の墓石を地中に埋めて、其の上に一｜宇の祠を建てて一木神社として祭ったが、昭和四年になって、後の山を開いて社を改築し、墓石も掘り出すとともに、傍に記念碑まで建立した。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の記念碑の表面は、伯爵田中光顕先生の筆で、「一木権兵衛君｜遺烈碑」とし、裏面には土佐の碩学寺石正路先生の選文がある。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私は其の時迄に、まだ、我が生の記念碑ともいうべき作品を書いていなかった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが記念碑として優れたものか、どうかは別として、私は、兎に角書けるだけのものを書きつくしたのではないか。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また階上の翁の部屋では天下のインチキ名士連が翁を取巻いて借銭の後始末、寄附、運動費、記念碑建立、社会事業、満蒙問題なぞ、あらゆる鹿爪らしい問題を提げて、厚顔無恥に翁へ持ちかける。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、死んでも銅像や記念碑、爵位勲等、生花、放鳥又は坊主の頭数、会葬者の人数、死亡広告の大きさやお墓の高さなぞに取り付いて行こうとするのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と記して傍に、寛政六年｜甲寅十二月　日とある石の記念碑である。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＣＯＭＰＵＴＥＲ』という雑誌の一九七七年三月号に載った「パーソナル・ダイナミック・メディア」という記念碑的な論文の最後に、彼がユタ大学に博士論文として提出した「ザ・リアクティブ・エンジン」や、所属していたゼロックス社パロアルト研究所の技術レポートとしてまとめた文献に関する記述がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、記念碑的なマシンやソフトウエアを動かしてもらって撮った映像が確かに映っているのが確認できると（レベルが低い！",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、「青空文庫からファイルをダウンロードして自分のディスクに収め読む利用者の方たちも、作者を賛える記念碑に石を積む人」であると添えた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者を賛える記念碑に石を積むという目的のためには、著作権法の規定でいけば、氏名表示権と同一性保持権は維持しなければなりません。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何かこの地球に Memento を置いて逝きたい、私がこの地球を愛した証拠を置いて逝きたい、私が同胞を愛した記念碑を置いて逝きたい。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生涯の、重大な記念碑を、骨折って造りに行くのだぞ、と繰返し繰返し、自分に教えた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社ノ額ハ、海軍少将大勲位依仁親王殿下ノ御染筆ニテ、高村光雲ノ作ナリ、社殿背後ノ丘上ニハ、竹田宮昌子内親王殿下ノ御染筆ニ係ハル妃ノ命ノ　さねさしさがむのをぬにもゆるひのほなかにたちてとひしきみはもノ御歌ヲ彫ミタル記念碑アリ。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
