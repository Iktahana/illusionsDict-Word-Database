[
  {
    "uuid": "c3f086d8-a1d1-5694-a173-59707a455384",
    "entry": "記念碑",
    "reading": {
      "primary": "きねんひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
