[
  {
    "uuid": "731a9b47-37d0-5879-a091-e9f9d1251f4a",
    "entry": "勤王家",
    "reading": {
      "primary": "きんのうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
