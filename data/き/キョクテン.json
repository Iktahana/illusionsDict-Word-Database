    "definitions": [
      {
        "index": 1,
        "gloss": "pole (north, south)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その偏倚は、今や極点に達してゐる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがある極点にまで達しようとするとき、突如ごおっという音が足下から起こる。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感情は喉を詰らせるようになって来、身体からは平衝の感じがだんだん失われて来、もしそんな状態が長く続けば、そのある極点から、自分の身体は奈落のようなもののなかへ落ちてゆくのではないかと思われる。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月、暑熱は極点に達した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋、友人の遭難を聞いて、私の畜犬に対する日ごろの憎悪は、その極点に達した。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねがね私の、こころよからず思い、また最近にいたっては憎悪の極点にまで達している、その当の畜犬に好かれるくらいならば、いっそ私は駱駝に慕われたいほどである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の不安は極点にまで達した。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今一歩進んでその伊奈子が腕に縒をかけた計画を、その終極点のギリギリのところで引っくり返したら伊奈子はどんな顔をするだろう。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性とは、所詮、ある窮極点に立てば、女性同士で抱きあって泣きたくなるものなのか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘の三郎の嘘の火焔はこのへんからその極点に達した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主観が自我を意味する限り、この問題の究極点は、結局して此処に達せねばならないだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大犯罪を遂行するものの如く、心中の不安、緊張は、極点にまで達した。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その「道の奥」の奥の極点の宿で一夜を明し、翌る日、やつぱりまだ船が出さうにも無いので、前日歩いて来た路をまた歩いて三厩まで来て、三厩で昼食をとり、それからバスでまつすぐに蟹田のＮ君の家へ帰つて来た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　恥ずかしさが極点に達すると勝治はいつも狂ったみたいに怒るのである。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲近世の傾向は吾人の知り得る所にあらず、然れども沙翁劇と称する一派及之と同性質の古劇の外は、漸く写実的精巧の極点にまで進まんとしつゝある由は、微に聞得たる事実なり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの落穴――それこそ地獄の典型であり、噂によれば彼らのあらゆる刑罰のなかの極点と考えられているものだ。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書は著者の自伝にあらず、著者は苦しめる基督信徒を代表し、身を不幸の極点に置き、基督教の原理を以て自ら慰さめんことを勉めたるなり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題なのは、さうした究極点に進んでゐる氏の仕事が一切を証明してゐるだけである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奔湍」の中に描かれた雉は、その羽を極点的に拡げてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "光瑤はこゝで驚ろくべき美しさを表現して、多くの人々に最大の嫉妬をされなければならないであらうし、また人間の為し得る美しさの究極点を示し得る人は光瑤氏のやうな人ををいてあるまいと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "また我々はさうした極点の美を示されることを待望してゐるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の絵は華美の極点を衝くほどの人間味が、ぐんぐん出て来る筈である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこの自己緊張の極点には往々にして恐ろしい自己疑惑が私を待ち設けている。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊張の極点にいるような今の葉子にはさほどと思われないようにもあったが、貞世が死ぬかなおるかして一息つく時が来たら、どうして肉体をささえる事ができようかと危ぶまないではいられない予感がきびしく葉子を襲う瞬間は幾度もあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の愛子に対する憎悪は極点に達した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問の進歩が極点に達した時なら知らず、何も彼も多くは疑問として存して唯の理窟の言現はし方を少し宛違へた位で総て研究に属してゐる今日では学者と無学者とは相去る事｜幾何も無い。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、父が車に乗って、その軸物の箱を肩に靠せながら、何処ともなく出て行く後姿を見た時、瑠璃子の心の中の妙な不安は極点に達していた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、原画が技巧の極点に達した人のものだから、うまくいかないね」　原口は首を曲げた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
