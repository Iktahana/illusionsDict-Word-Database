        "examples": {
          "standard": [
            {
              "text": "彼女は線が細くておとなしそうに見えるが、実は人一倍気が勝っていて、勝負事では決して引かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「負けてたまるか！」という気が勝っているうちは、どれほど点差が開いていても逆転の可能性は残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "技術的にはまだ未熟な新入社員だが、気が勝っている分、困難なプロジェクトにも物怖じせず飛び込んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "梅幸が、美しい態度で、聴きとつたといふ「切られお富」も、結局梅幸なればこそ呑みこめたが、尚、色気が過ぎ、律気が勝つた。",
              "citation": {
                "source": "芝居見の芝居知らず",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
