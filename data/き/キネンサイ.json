      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anniversary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今年の記念祭はOBもたくさん来るから、吹奏楽部の演奏にも一段と気合が入るね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "創立記念祭の目玉として、校庭に巨大なモザイクアートを展示する計画が進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、記念祭の模擬店で出す焼きそばの仕入れ、去年の1.5倍に増やしておこう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統ある男子校の記念祭は、近隣の女子校生たちも大勢訪れて異様な熱気に包まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我々が平穏に、健全で、猶久しく彼のために記念祭を行ふやうに、神は我々に恩恵を垂れ給へ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭の日、赤い褌をしめて裸体で踊っている寄宿生の群れを見て、軽蔑のあまり涙が落ちた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭の夜応援団の者に撲られたことを機縁として、五月二日、五月三日、五月四日と記念祭あけの三日間、同じ円山公園の桜の木の下で、次々と違った女生徒を接吻してやった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　その年の二月、高等学校の記念祭の頃、本郷の彼の下宿へ、伯父から葉書が来た。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭が近づいたので誰もそわそわして落ち着かず、新入生の歓迎コンパだと称して毎晩のように京極や円山公園へ出掛けて行くらしく、その自由さが豹一には羨しかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機も置かず、スリッパにはきかえてはいるような静かなその喫茶室が三高生達の記念祭の歌と乱舞で乱暴に騒がしかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和六年度記念祭万歳！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　やがて五月一日の記念祭の当日になった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭がすむと、生徒たちは興奮しながら町へあこがれ出て行く、その足を推戴式のため食い止めなければならない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の記念祭の折、私はロンドンへ来て、ラッセル・スクエアの宿泊所に滞在しました。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭の余興として各寮から余興を一つづゝやるので、その時自分達は南寮の余興として出演したのだ。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって男子は民族的宗教を記念祭的のものとし、女子は相変わらずこれを宗教的のものといたしました。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前にも申上げた通り、男子はその祖先崇拝の宗教を記念祭的のものとしてしまったのに、女子はあいかわらずこれを宗教的なものとして信じたためにいろいろの迷信が生じて来て、かえって政治の妨害となったために心配していったことでありましょう。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトの友の会では、去年の十月、革命記念祭に向って見学団派遣を計画し、農民代表として石川県の農民の山野芳松という小父さんが決定されるまでに運んだ。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイの誕生六十年記念祭にあたって、ソヴェト同盟・共産主義アカデミーで行われた討論は、ゴーリキイをもっとも重大な使命を果した文豪であるとした。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクシム・ゴーリキイが六十余歳の老齢をもって、去年の革命第十五周年記念祭の時党員となった事実は、私どもの記憶に新たな感銘として印されている。",
              "citation": {
                "source": "社会主義リアリズムの問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里コンミューンの記念祭の夜、ルイコフの名によるクラブへ行ったときも、クラブの入口にいくたりも主に青年がかたまって、来る者ごとに訊いていた。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばメーデーの時、革命記念祭のデモンストレーションの時には、各工場は自分の工場の音楽隊を先に立てて行進して来る。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故小山内薫氏が革命十年記念祭にモスクワへ来て、いろんな芝居見て、結局役者の上手なのはモスクワ芸術座しかないと云ったという噂をきいた。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、革命十周年記念祭のお客で日本から来ていた米川正夫、秋田雨雀をはじめ、自分も並んで、順ぐりに短い話をした。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二回国際革命作家大会がソヴェト革命第十三年記念祭を機会にハリコフで持たれようと云うのだ。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイ百年記念祭が一九二八年にモスクワの大劇場で行われたが、そのとき、外国からの客、ツワイグやケレルマンがそこに立って挨拶した演壇へ出て祝辞をよんだソヴェト作家代表はリベディンスキーでも、キルションでもなかった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲法記念祭、子供の日、母の日。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（都の西北、早稲田の森に……）　今はそこらの幼稚園の生徒でも、何かというとすぐ口癖のように歌い出す程あまねくひろまったこのなつかしい「われ等が母校」の歌が、はじめて「早稲田の森」から歌い出されたのは、明治四十年の秋、大学創立二十五年記念祭の折のことだった。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秋ビリンスキー村の革命記念祭デモンストレーションは、このクラブの前からはじまった。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月七日（水曜）細雨　革命記念祭　昼間、引越したばかりで、外に出る気せず。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、七月十四日は革命記念祭。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは始めて今日は東京市欧洲戦争講和記念祭の当日であることを思出した。",
              "citation": {
                "source": "花火",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしずめ記念祭でももよおしたいところだよ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
