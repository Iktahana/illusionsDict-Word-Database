[
  {
    "uuid": "0d3bdd4e-4d11-51fc-a3ad-7358ce8896ee",
    "entry": "記念祭",
    "reading": {
      "primary": "きねんさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
