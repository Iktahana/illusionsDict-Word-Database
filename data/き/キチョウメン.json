    "definitions": [
      {
        "index": 1,
        "gloss": "methodical",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は几帳面な性格で、デスクの上には常に文房具が整然と並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふぅ、さすが几帳面な君だ。資料のフォントサイズまで完璧に揃ってるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母は几帳面に日記をつけ続けており、古いノートが本棚にぎっしりと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "几帳面な職人の手によって、時計の複雑なパーツが一つずつ丁寧に組み立てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "社長に泣きつけば自分だけはまだ入れて呉れるかも知れないといふ位に考へてゐた彼女は、それにどう返事して好いか悪らずに、几帳面に坐つてさへゐれば好いことにしてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごつ／＼した、几帳面な藤井先生までが、野球フワンとなっていた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "律儀な、几帳面な男でもない。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木谷は、几帳面で、根気強い活溌な性質がとくをして、上等兵になっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はそのあひだに、几帳面らしく眞野と飛騨へ、お世話になりました、と言つてお辭儀をして、それから小菅へ眞面目な顏で尋ねた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの几帳面に見える園には不思議な現象だと人見の思うのはこのことだけだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敲き大工の息子ですから、几帳面に長く坐っていると立てなくなりますよ」　渡瀬さんはそういって、片眼をかがやかしながら、からからと笑って膝を崩した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敲き大工の息子ですから、几帳面に長く坐っていると立てなくなりますよ」　といって思いきり彼らしい調子を上げて笑い崩した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこうやって心からあやまるから」　そういって、彼は几帳面に坐りなおると、膝の上に両手をついて、頭をちょっと下げた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事にも几帳面で、怒らない時には柔順な敏夫は、私の父の塑像の前に行つて、「おぢいちやま御機嫌よう、おばあちやま御機嫌よう、ママ御機嫌よう」　一々頭を下げて誰にともなく云つてから、私の所に來て、「パパ御機嫌よう」と挨拶した。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼はいちいち几帳面に仇敵に、それ相応の復讐を遂げ、自分はわざと恋人の兄の刃にかかって死にます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷した水蜜桃の皮を、学者風に几帳面に剥き乍ら博士は云った。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスは、ときどき揺れて、呟き声や、笑い声を乗客に立てさせながら、停留場毎に几帳面に、客を乗り降りさせて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に几帳面に並べられている銀の食器や陶器皿や、折り畳んだナフキンは、いよいよ寒白く光って、催眠術者の使う疑念の道具の小鏡のように、かの女の瞳をしつこく追う。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな几帳面だなあ」規矩男は女性の問題はもう振り落したように独言を云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷した水蜜桃の皮を、学者風に几帳面に剥き乍ら博士は云つた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋に展覧会の開かれるグラン・パレーの入口は真黒く閉っていて、プチ・パレーの方に波蘭の工芸品展覧会の雪の山を描いたポスターが白い窓のように几帳面な間隔を置いて貼られてある。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の一ヶ所に張り出たボツクスの上の几帳面な薄端に聖者風の枯葦とそれに献花してゐるやうな海竿三輪。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校が休みでなくっても、それまでちょいちょい勝手に欠席していたのだし、二日つづきの休暇を利用するというのも下宿の家族の者たちへの手前、あまり怠惰な学生と見られても工合が悪いので、几帳面にそんな日を選んだというだけの話で、実際は、二日つづきの休暇も三日つづきの休暇も、問題でなかったのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの眼にだん／＼闇が慣れて来ますと道の両側に几帳面な間隔で電柱の並び立っているのや、青田のところ／″＼に蓮池のあるのや、おぼろに判って来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドは白くて几帳面な置き方と共に何となく子供らしい所作に感じさせられます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの眼にだん／＼闇が慣れて来ますと道の両側に几帳面な間隔で電柱の並んで立っているのや、青田のところ／″＼に蓮池のあるのや、おぼろに判って来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを几帳面に小さな船頭持ちの飯櫃に移し、それから茶碗によそって、鉢の中の魚の肉を豆ランプの灯影で透してみました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い大きな顔の男で、額に苦労皺が罫線のように何本も几帳面に刻まれています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを首尾しようとするなら、命を的の仕事と思って、まず商売は捨て、几帳面の素人に還りなさい」と。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "几帳面に道路に仕切られ、それに思い思いの住宅が構えられていた。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行の会計事務を済ますと几帳面に真直ぐに帰宅する彼女をワルトンは大抵午後四時半に待って居た。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲の何割かをきちんきちんと呉れるオイチョカブの北田を、順平は几帳面な男と思い、ふと女めいたなつかしさも覚えていた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが器械仕掛けでメトロノームのようにきちょうめんに鳴るのではちっとも涼しくはないであろう。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちょうめんにちゃんと曲がり角を曲がってあるくのと、その芝生の上を踏みにじって行くのとで、歩く距離にすれば三尺とはちがわない。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "wooden post that has been carved to have a rounded corner with grooves running along either side of it",
        "register": "standard",
