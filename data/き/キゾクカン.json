        "examples": {
          "standard": [
            {
              "text": "新しい部署に配属されてから、早くチームへの帰属感を得たいと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボランティア活動を通して、地域社会への強い帰属感を覚えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生たちが学校に帰属感を持つことは、学業成績にも良い影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リモートワークが増える中で、従業員の帰属感をどう維持するかが課題だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "我々のもののような社会では、普通、誰であろうと〈自国に対する極めて深い帰属感を持つほどの識者〉だ、という風には呼ばれない。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
