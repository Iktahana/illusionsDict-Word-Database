        "examples": {
          "standard": [
            {
              "text": "煮物の彩りに絹さやを添えると、ぐっと豪華になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絹さやは筋を取るのがちょっと面倒だけど、シャキシャキして美味しいよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お弁当に絹さやのおひたしを入れたら、彩りが良くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "畑の絹さやゑん豆をもぎつてきてサフアイヤ色の朝の食事に興じるでせう。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（でも私には買い出しなんぞよりもっと大切な勤めがあり、夫を喜ばせるための忙しい仕事が控えているので、なかなか錦へ行く暇などはなかったのだ）行きつけの八百屋の店で筍と蚕豆ときぬさやを少々買う。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
