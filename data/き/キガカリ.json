    "definitions": [
      {
        "index": 1,
        "gloss": "worry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」やっぱり、その事が先生にとっても、まず第一に気がかりになる様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ゆきが怪しいので、私は多少の気がかりで、大沢の小舎を立った、すぐ眼の前には、その大沢の難所なるものが控えている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは湊のことが、だんだん妙な気がかりになり、却って、そしらぬ顔をして黙っていることもある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の眠｜催す様なるこの水音を源叔父は聞くともなく聞きてさまざまの楽しきことのみ思いつづけ、悲しきこと、気がかりのこと、胸に浮かぶ時は櫓握る手に力入れて頭振りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅は、なお気がかりらしく、今度は恐る恐る、上目遣いに職長の方を見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私は恋愛の「愛」の字、「性的愛」の「愛」の字が、気がかりでならぬのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく故郷の富士が気がかりになる数日が続いた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下へ出るのは気がかりであったけれど、なおそれよりも恐ろしかったのは、その時まで自分が寝て居た蚊帳の内を窺って見ることで。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かれた学生は、いかにも気がかりらしく、そっと肩をすぼめて廊下まで出て、友達に読んで貰って、よろこんだり泣いたりするのでした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ふいと判事は気がかりなことを思ひ出した。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに貴僧、騒動の起居に、一番気がかりなのは洋燈ですから、宰八爺さんにそう云って、こうやって行燈に取替えました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうにも気がかりだ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、そこに、幽かでも障子の鳥影のように、かすめて通り過ぎる気がかりのものが感じられて、僕はいよいよ憂鬱になるばかりであった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、はっきり言いますけれど、この五円の切手がだいいちに気がかりなのです。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空腹を防ぐために子への折檻をひかえた黄村、子の名声よりも印税が気がかりでならぬ黄村、近所からは土台下に黄金の一ぱいつまった甕をかくしていると囁かれた黄村が、五百文の遺産をのこして大往生をした。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前から、気がかりになっていたのである。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、来て見ないうちは、気がかりなのだ。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは淡々とした味を持ちつゝ何となく気がかりの魅惑があつて、あとを引いた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい遺書のつもりで、こんな穢い子供もいましたという幼年及び少年時代の私の告白を、書き綴ったのであるが、その遺書が、逆に猛烈に気がかりになって、私の虚無に幽かな燭燈がともった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちのいま最も気がかりな事、最もうしろめいたいもの、それをいまの日本の「新文化」は、素通りして走りそうな気がしてならない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、気がかりだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこんどあたしが帰って来たという事を聞いて、急に、気がかりになって、何だかあたしを憎らしくなって来たのに違いないわ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう読むまいと思っても、それでも何か気がかりで、新聞などに島田の新刊書の広告などが出ていると、ついまた注文してしまって、そうして読んで、悶えるのです。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」気がかりということに就いて　気がかりということに、黒白の二種、たしかにあることを知る。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品の面白さよりも、その作家の態度が、まず気がかりになる。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がさめてから、やれ不思議な有難い夢よ、とひどく気がかりになっていたところにあなた、いきなお旦那が、お産のすむまで宿を貸せと台所口から御入来ですものねえ、夢は、やっぱり、正夢、これも、日頃のお不動信心のおかげでございましょうか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまけものほど、気がかりの当座の用事を一刻も早く片附けてしまいたがるものらしい。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は気がかりになったので尋ねた。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな風にしたら、彼等の絶望した心を引き立たせ、彼等の歪んだ意志を――事件の行きがかり上、ほんの一時的な假りの性格をとつてゐたところの、が現在は、殆どその使ひ方も知らぬ異樣な力として彼等自身のうちに持ち扱つてゐるところの、その意志を調節してやれるでせう？",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方面に関しては私ははなはだ不案内であるが上述の所説の行きがかり上少しばかり蛇足を加えることを許されたい。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
