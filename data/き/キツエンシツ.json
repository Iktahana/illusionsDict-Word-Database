        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新幹線には、一部車両に喫煙室が設けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議の休憩時間には、多くの人が喫煙室に向かう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ホテルの一階に、清潔で換気の良い喫煙室があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喫煙室の中は、いつもタバコの煙が充満している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はおなかがペコペコなのだが、喫煙室のソーファに沈んで煙草を吹かしてゐるより他はなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧進帳が終つて喫煙室に這入ると、「好いですね、好いですね、よくやりますね」と一人の爺々ィが云つてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの四句をどこかの科学研究所の喫煙室の壁にでも記銘しておいてふさわしいものであると思う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は喫煙室に入り、サモア流に車座になって蹲んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十六日　喫煙室で乗客の会議が開かれた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時ごろから喫煙室でＮ君ハース氏らと袂別の心持ちでシャンペンの杯をあげた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂、社交室、喫煙室の壮大はもちろん、劇場、教会堂、水泳プールから保安警察のようなものまで具備している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の客車は、例によって、一等室と一等喫煙室、二等室と二等喫煙室という四室に区劃られていた。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　シャーロック・ホームズは約束通り、一時頃に大佐の喫煙室にて我々と合流した。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "左へ折れたところに応接室か喫煙室かといふやうな部屋の窓の戸が少しあいてゐて人影が差してゐたが、そこを過ぎると玄関があつた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車でも喫煙室では選挙談が頻りに取り交されてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽作家の諧謔８・27サンデー毎日　滑稽作家マアク・トヱンが、いつだつたか英国通ひの汽船に乗り込んで、その喫煙室ですぱすぱやつてゐたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動の好きな彼女はシネマ・パレスへは大抵欠かさず行くので、彼も電車で一緒に行って見るのであったが、喫煙室へ入ると、いつもじろじろ青年たちに顔を見られ、時とすると彼女の名をささやく声も耳にしたりするので、彼は口も利かないようにしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて第一の映写が終つて、観客がどや／＼廊下や喫煙室へ出て来た。",
              "citation": {
                "source": "ある夜",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "花やピアノの飾られた部屋ででも話すことは「政治、鉄道、それから文学のことを少し、事務のことを沢山」男は男だけかたまって、しかも夕飯後は喫煙室へ行って話すようになって来ている。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中に四、五人の私服がはいりこんで、あちこちとうろうろしたり、僕が乗った二等の喫煙室に坐りこんだりしていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の出るまでキャビンの中に閉じ籠っているのも癪だし、僕はよほどの自信をもって、喫煙室とデッキの間をぶらぶらしていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一度は、私服らしい三、四人のもののほかは誰もはいっていなかった喫煙室に行って、彼等の横顔をながめながら煙草をふかしていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "植民地兵営の喫煙室みたいな前庭。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階へ上ると、おどり場に台と腰かけがおいてあって、喫煙室と書いたしるしが立てられている。",
              "citation": {
                "source": "図書館",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "テイラアは毎日喫煙室の隅に腰掛けて、ホテルの主人の和蘭人ミニィル・ヴァン・デル・ヴェルドを相手に、南阿弗利加の和蘭岬のことなどを、和蘭語まじりの英語で話し込んでいた。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫煙室にはお話の合う方もいらっしゃいますわ。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大佐に別れた保吉は喫煙室へ顔を出さずに、誰も人のいない教官室へ帰った。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫煙室では地所の売買が行われていた。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "合宿の頃から、ずうッと一人ぼっちだったぼくは、多勢の他テイムのなかに雑ると、余計さびしく、出帆してから二三日、練習以外の時間は、ただ甲板を散歩したり、船室で、啄木を読んだり、船室が、相部屋の松山さん、沢村さんに占領されているときは、喫煙室で、母へ手紙を書いたりしていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の晩、ぼくが、二等船室から喫煙室のほうに、階段を昇って行くと、上り口の右側の部屋から、溌剌としたピアノの音が、流れてきます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが、巨きな汽船だけに、まア、リフトの昇降時にかんじる、不愉快さといった程のものでしたが、やはり甲板に出てくる人の数は少なく、喫煙室で、麻雀でもするか、コリントゲエムでもやっている連中が多かったのです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで、暗い海を暫くみてから、寝に帰ろうと、喫煙室のなかを通り抜けていると、一隅で沢村、森、松山、東海さん達が、麻雀をやっていましたが、「おい、おい」と河村さんが、ぼくを呼びとめます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
