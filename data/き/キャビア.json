        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車付きの銀テーブルの上にキャビアの鑵が粉氷の山に包まれて居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛合わせ皿には、燻製の鮭、パン片に塗りつけたキャビア、鮒の串焼、黄いろい生雲丹、ラドッシュ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし腹がへったら、白いパンにキャビア……パンは白いにきまってる筈だが、その白いパンがなかなか手にはいらない悲しい時代だ。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャビアを分厚に塗りたくつたパン片が、三畳敷ほどもありさうな配膳台にぎつしり並べてあることもある。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャビアなどは、滅多に使わない。",
              "citation": {
                "source": "パーティ物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スープはポタージュ、犢の骨つき、キャビアのオルドヴル。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の食事、キャビアその他オルドヴル中々よろしい、冷コンソメ、次にトルネードにドライカレー付、レタスとトマト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "使用人たちは冷製の肉のスライスを、キャビアの壺を、スライスパンを、純物のバターを、本物のコーヒーを、そして酒を、ふんだんに運び込んだ。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
