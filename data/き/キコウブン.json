        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "根岸派では、饗庭篁村が先達で、八文字舎風の軽妙洒脱な紀行文を書き『東京朝日』の続きものとして明日を楽しませた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の人たちは、遅塚麗水、大町桂月、江見水蔭、田山花袋、久保天随、坪谷水哉などであるが、花袋が紀行文家と言われた時分は、自然派文学勃興以前のことで、文章に感傷癖はあったが、淡泊清新、ことに武蔵野あたりの原野や雑木林の寂しさを、淡彩的に点描するのに巧みであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野といえば、ただちに独歩の名作が連想されるが、花袋も紀行文家として「野の人」であった、武蔵野の人であった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然派勃興以後の花袋自身は、おそらく「こんなもの」と言うかもしれないが、私のすきな花袋は、やはり情緒綿々たる紀行文家の花袋である。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし直接に文通したのは、少しく金の入用があったので、白峰の紀行文を、花袋を通じて『太陽』に寄せたときが初めてであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋の周旋で『太陽』に載せられた白峰三山の紀行文は、意外の人の知己を得た。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後の豪家｜高頭仁兵衛氏が、山岳辞彙ともいうべき浩澣な原稿をかかえて、志賀先生を訪問せられたとき、横浜にいる人が、こんな紀行文を発表している、山を知っている人らしいから、訪問してみたらどうかと、注意されたそうだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文中で花袋の近作、紀行文集『草枕』の中の事実に合っていない個所を注意した。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま『文章世界』第二巻第十三号で、片上天弦、前田木城、水野葉舟、吉江孤雁ら合評の紀行文家月旦が出た。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一評者が「一時は紀行文は前人の未だ踏まない深山幽谷の奇景を、紹介するのを職とするような傾向であった、いや今でも、そういう好奇心で、紀行を書いている人もあるようだが、これはつまらぬことだろう」と言って、明らかに私に当たっている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり日本アルプス探検などは好奇心のなすわざで、その紀行文を書くのは、つまらぬことなんだそうだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の駁文は紀行文続論として『山水美論』（明治四十一年）に載せてある。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして躍起となって、ますます山に登り、その紀行文を発表した。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後『文章世界』で読者から紀行文家を投票させて、最高点を得た人に、彫塑かまたは油絵肖像を贈呈するということであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "原品の肖像画は、「紀行文豪」たる、あるいはたりし記念として、家蔵としている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋については、花袋全集の刊行されている今日、その文学的総収穫について、統一した見解が、定めて下されることであろうが、私は彼の紀行文について多く世に知られていない功績をあげたいと思う。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋の紀行文集の中では『南船北馬』（明治三十二年九月版）が最もすぐれている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従軍紀行文的なもの（遅塚麗水「首陽山一帯の風光」）及び、戦地から帰った者の話を聞いて書いたもの（江見水蔭「夏服士官」）は、まだやゝましだとしなければならぬ。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかと言えば、詩歌にはその言葉の連続によって生ずる一貫した企図の表現、平たく言えば筋書きがあって、その筋書きによって代表された一つのまとまった全体があり、そういう点では律動的でない戯曲や小説や紀行文や随筆やとも共通な要素をもっている。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "・陽がとゞけば草のなかにてほほづきの赤さ・つく／＼ぼうしもせつなくないてなきやんだ　　　改作追加・秋空の井戸がふかうなつた・雲が澄む水を汲むげんのしようこの花　九月五日秋晴、終日寝ころんで読む、牧水の紀行文集を読んでゐると一杯やりたくなる。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "国文に関した研究もの、国史、支那稗史から材料を採つた短篇小説、校釈、対論文、戯作、和歌、紀行文、随筆等、生涯の執筆は実に多岐に渉つてゐる。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月、そろそろ、牧水全集のうちの、紀行文を読みはじめていた。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か電気でも孕んだような工合で、今執筆中の「南洋だより」のような紀行文など、ゆっくり書いていられなくなる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私があの原稿を書く時、頭に浮べていた模範は、十八世紀風の紀行文、筆者の主観や情緒を抑えて、即物的な観察に終始した・ああいう行き方なのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は、前に学郎さんと一緒に甲州の方へ十日間ばかり旅行して、その時のことを学郎さんと二人で「甲斐の旅」という紀行文を作って、今村先生からほめられた事があった。",
              "citation": {
                "source": "骨を削りつつ歩む",
                "author": "――文壇苦行記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時の事を書いた紀行文を左に拔萃する。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀行文、随筆、短篇小説などにおける彼の数年間の文筆生活の後に、一八八一年の九月、スコットランドのブレーマーでの療養中に書き始められた。",
              "citation": {
                "source": "宝島",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、その紀行文の発端で、私が読んだところまでなのだが、「驢馬旅行」と題する本だから紳士は彼女を伴れて最後までこの旅を続けてゐるのだらう、その難苦は想像にあまりある。",
              "citation": {
                "source": "読書と生活",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "林芙美子氏の「牝鶏」（改造）は紀行文的な、そして随筆風な軽やかなものであるが、巧まざる心懐の淙々と流れるよどみのなさにこゝろよく惑き入れられるものがあつた。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀行文集として本書は私の第三冊目にあたる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
