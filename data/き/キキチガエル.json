        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは先ほど呼ばれた時のそれに比べると、聞き違えるほど美しい声だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の云うことを聞き違えることもなかったかわりに、人の口真似を巧みにこなすことは出来なかった。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二十年もあの方のお屋敷に奉公しておりながら、その御主人のお声を聞き違えるなんてことがございましょうか？",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "小督の琴は仲国の耳の底にはっきりと残っていて、いつどこで聞いても、聞き違えることのないほどの自信があった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん番たびではないが、人の云うことを聞き違える、という弱点に自分で気がついたのだろう、それからはもっぱら自分で饒舌るようになった、ということであった。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
