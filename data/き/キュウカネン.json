        "examples": {
          "standard": [
            {
              "text": "この道路工事には、調査開始から完成まで九箇年の歳月を要した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "九箇年にわたる義務教育の課程を修了し、彼は地元を離れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "徳川幕府の歴史において、その九箇年間は比較的平穏な時代だったとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十九箇年間に約八十もあった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三期は、第二期九箇年の後に、一箇年を置いて始められた。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は九箇年に関して表を与えているが、その中から次の例を引いている。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしこの計算の行われた期間はわずかに九箇年に過ぎないからである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
