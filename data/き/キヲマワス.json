          "literary": [
            {
              "text": "いつ妾が云ひ付けるなんて云つたのさ、何て男らしくもなく気を回す人なんだらう。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ないしょの用だからといって、すぐときさまのように気を回すやつがあるかッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実そうでない場合にまでも、何か自分のことを噂しているのではないかと、気を回すようになります。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし変に気を回すと、彼の鋭い直感にふれて、せっかくの寵を失うから、その方面には風馬牛にもしているのである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
