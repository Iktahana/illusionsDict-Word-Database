        "examples": {
          "standard": [
            {
              "text": "先生の教えを胸に、常に感謝の気持ちを記憶にとどめておきたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の最後の言葉を、私は生涯記憶にとどめるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトの失敗原因を教訓として記憶にとどめ、次に活かそう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "引つづいて読者はひどく精密であるが全く無味乾燥なユロ男爵家の系図の中を引きまわされるのであるが、普通の読者は、その数千字を終り迄辛棒して結局は、最初の行にあった四字「ユロ男爵」だけを全体との進行の関係で記憶にとどめるような結果になる。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は何千年もの昔から、考えや感情を人に伝え、自分自身の記憶にとどめるために紙の上の文字や記号、壁に描いた絵、声や楽器によってつづられるメロディーを利用してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
