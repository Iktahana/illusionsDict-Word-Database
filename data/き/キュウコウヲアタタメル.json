        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "同窓会で旧交を温め、学生時代の思い出話に花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "しばらく連絡を取っていなかった友人と、久しぶりに会って旧交を温めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転勤先で偶然昔の仕事仲間と再会し、夜通し旧交を温めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "定年退職を機に、各地に散らばった友人と旧交を温める旅に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "SNSを通じて、失われた旧交を温めることができたのは素晴らしいことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女が同期の卒業生は各自の家へ順番に寄合って旧交を温めることにしているので、彼女の家でも最近に小さな集りをして、以前格別御世話に成った学校の先生をも招いたと書いてよこした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "同人のうちでいちばん親しかったのは戸川秋骨君で、他に平田禿木君や、そのころ田舎から帰って来て、音楽学校へ入り直して、金釦の制服を着ていた島崎藤村君あたりとも、旧交を温めることになった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
