[
  {
    "uuid": "5fabb731-8f3c-5398-be75-18e5ab853b89",
    "entry": "危険性",
    "reading": {
      "primary": "きけんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
