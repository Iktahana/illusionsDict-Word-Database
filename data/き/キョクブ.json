[
  {
    "uuid": "96ba373a-1bfa-508e-b4a5-266a0126e177",
    "entry": "局部",
    "reading": {
      "primary": "きょくぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
