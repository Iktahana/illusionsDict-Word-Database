[
  {
    "uuid": "748d5ad1-ddd1-555a-ac2e-10a4520e7068",
    "entry": "経文",
    "reading": {
      "primary": "きょうもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scriptural text",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして経文を引用してある中に、海水の鹹苦な理由を説明する阿含経の文句が挙げてある。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時日朝上人というのは線香の光で経文を写したという話を観行院様から聞いて、大層眼の良い人だと浦山しく思いました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロオテはそれにむかって、なにやら経文を、ひくく読みあげていた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "須利耶さまは写しかけの経文に、掌を合せて立ちあがられ、それから童子さまを立たせて、紅革の帯を結んでやり表へ連れてお出になりました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法華経見宝塔品という経文の中に、多宝塔（この宝塔の中には如来全身有す）という塔が地中より涌き上って空中に止まり、その中に多宝如来と釈迦仏とが並んで座せられる場面が書いてあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この数分時の言の中に、小次郎法師は、生れて以来、聞いただけの、風と水と、鐘の音、楽、あらゆる人の声、虫の音、木の葉の囁きまで、稲妻のごとく胸の裡に繰返し、なおかつ覚えただけの経文を、颯と金字紺泥に瞳に描いて試みたが、それかと思うのは更に分らぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はッあ、」　と退って、僧に背を摺寄せながら、「経文を唱えて下せえ、入って来たわ、南無まいだ、なんまいだ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "袈裟のかげに隠れる、嘘の経文を読む、貰いの技巧を弄する、――応供の資格なくして供養を受ける苦脳には堪えきれなくなったのである。",
              "citation": {
                "source": "私を語る",
                "author": "――（消息に代えて）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又仏法から云っても是の如く慈悲の念のみの亢張するのが必ずしも可なるのでは無く、場合によっては是の如きは魔境に墜ちたものとして弾呵してある経文もあるが、保胤のは慈念や悲念が亢ぶって、それによって非違に趨るに至ったのでも何でもないから、本より非難すべくも無いのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い経文の言葉に、心は巧みなる画師の如し、とございます。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、盲目の垣覗きよりもそッと近い、机覗きで、読んでおいでなさった、書物などの、お話も伺って、何をなさる方じゃと言う事も存じておりますが、経文に書いてあることさえ、愚昧に饒舌ると間違います。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏滸がましき似非経文よな。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山の真相を言へば、一方に経文あり。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食歌もあれば、お経文もある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれとともに一心になって読経せよと云って、雨宝陀羅尼経という経文とお札をくれた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新三郎は良石和尚にあつく礼を云って帰って来たが、帰ってくると早速勇斎に手伝ってもらって、和尚の云ったようにお札をいたる処に貼り、海音如来のお守を胴巻に入れて首にかけ、蚊帳を釣って其の中で経文を読んでいた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新三郎は一心になって経文を唱えていたが、やがて駒下駄の音が垣根の傍でぴたりととまったので、恐るおそる蚊帳から出て雨戸の節穴から覗いてみた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幣帛を焚いて以て神に通じ、経文を誦して以て仏に諂う。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "智者大師説『金光明経文句』の釈捨身｜品の虎子頭上七点あるを見て生まれてすでに七日なるを知る事『山海経』に出づとあるが、予はかかる事『山海経』にあるを記えず。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶつぶつと、我とも分かず、口の裡で、何とも知らず、覚えただけの経文を呟き呟き、鶯谷から、上野の山中をって歩行いた果が、夜ふけに、清水の舞台に上った。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人は其の横に、机を控へて、行燈を傍に、背を細く、裳をすらりと、なよやかに薄い絹の掻巻を肩から羽織つて、両袖を下へ忘れた、双の手を包んだ友染で、清らかな頸から頬杖支いて、繰拡げたペイジを凝と読入つたのが、態度で経文を誦するとは思へぬけれども、神々しく、媚めかしく、然も婀娜めいて見えたのである。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして貴下が、仏像の前で、その言行録を誦する経文だといった、悉い話を聞きましょう。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「智心は孤児で十歳のときから当寺に養われて居りますが、生まれつきの鈍根で、経文なども能く覚えません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人跡稀れなる寒林に小院をかまえて、一心に経文｜読誦を怠らなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当山は勅願の寺院で、三門には勅額をかけ、七重の塔には宸翰金字の経文が蔵めてある。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔らかい白の綾に薄紫を重ねて、藍がかった直衣を、帯もゆるくおおように締めた姿で立ち「釈迦牟尼仏弟子」と名のって経文を暗誦みしている声もきわめて優雅に聞こえた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも本統の邪視のほかにインドでナザールというのがあって、悪念を以てせず、何の気もなく、もしくは賞讃して人や物を眺めても、眺められた者が害を受けるので、予これを視害と訳し置いたが、これは経文に因って見毒と極めるがよかろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも本統の邪視のほかに、インドでナザールというのがあって、悪念を以てせず、何の気もなく、もしくは賞讃して人や物を眺めても、眺められた者が害を受けるので、予これを視害と訳し置いたがこれは経文に拠って見毒と極めるが良かろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
