[
  {
    "uuid": "c69c336c-828c-52b5-a91d-e87986027371",
    "entry": "恐怖感",
    "reading": {
      "primary": "きょうふかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
