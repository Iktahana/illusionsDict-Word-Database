        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの美しい緑色は見えなくなって、※びたひわ茶色の金属光沢を見せたが、腹の美しい赤銅色はそのままに見られた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一メートルばかりの金属光沢をもった短いステッキを、防弾手袋をはめた片手に持っている。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面はぴかぴかに金属光沢を放っている。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顕微鏡の下で見ると、完全な球形をしていて、表面が金属光沢をもっていることが多い。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体長一｜米半、目方七十五｜瓩の大きい魚で、全身は青色に輝いた金属光沢を帯び、魚体は脂ぎってぴかぴか光っていた。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
