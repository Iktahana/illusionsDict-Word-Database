    },
    "definitions": [
      {
        "index": 1,
        "gloss": "order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "モーターの早い規律正しい廻転から起る音の中にはかなり純粋な楽音がいくつかある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この考えを更に押し拡め直接筋力と比較する事の出来ぬ種々の引力斥力を考えて森羅万象を整然たる規律の下に整理するのが物理学の主な仕事の一つである。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来傍には又岸に臨んで、果しなく組違えた材木が並べてあるが、二十三十ずつ、四ツ目｜形に、井筒形に、規律正しく、一定した距離を置いて、何処までも続いて居る、四ツ目の間を、井筒の彼方を、見え隠れに、ちらほら人が通るが、皆黙って歩行いて居るので。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがある日その神聖な規律を根底から破棄するような椿事の起こったのを偶然な機会で目撃することができた。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちはこの学校へいれられたが最後みんなおそろいの棒縞の制服を着せられて五か月たつまでは一回の外出も許されずに、厳重な舎監のいわゆるプロイセン的な規律のもとに教育を受けなければならないのである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらがどうも烏の軍隊の不規律なところです。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっはっは、どうだ、もっともそれはおれのように勢力｜不滅の法則や熱力学第二則がわかるとあんまりおかしくもないがね、どうだ、ぼくの軍隊は規律がいいだろう。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏十二の中に月と花が一つずつあってこの一楽章に複雑な美しさを与える一方ではまたあまりに放恣な運動をしないような規律を制定している。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "階子段を規律正しく静かに降りてくる足音がして、やがてドアが軽くたたかれた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往來傍には又岸に臨むで、果しなく組違へた材木が並べてあるが、二十三十づゝ、四ツ目形に、井筒形に、規律正しく、一定した距離を置いて、何處までも續いて居る、四ツ目の間を、井筒の彼方を、見え隱れに、ちらほら人が通るが、皆默つて歩行いて居るので。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、船に嚴然たる規律のある事は誰も知つて居る、たとへ霹靂天空に碎けやうとも、數萬の魔神が一｜時に海上に現出れやうとも、船員ならぬ者が船員の職權を侵して、之を船長に報告するなどは海上の法則から言つて、到底許す可からざる事である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "規律正しき軍艦の甲板、かゝる活劇の間でも决して其態度を亂す樣な事はない。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、此噂は早くも軍艦「日の出」の全體に傳つたが、誰れも其本分を忘れて「どれ、どんな男だ」などゝ、我等の側に飛んで來る樣な不規律な事は少しも無く。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ俺は法律を学んだ為に、秩序とか規律とか云ふものの精神を聊か知得した。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝらがどうも烏の軍隊の不規律なところです。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつはつは、どうだ、もつともそれはおれのやうに勢力不滅の法則や熱力学第二則がわかるとあんまりをかしくもないがね、どうだ、ぼくの軍隊は規律がいゝだらう。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御婦人、紳士方が、社会道徳の規律に因って、相当の御制裁を御満足にお加えを願う。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その混雑の間にも軍隊には一定の規律がある。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもここの町に奔走している人には、一定の規律がない、各個人の自由行動である。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが日本の兵士たちは、もっと勇敢で規律正しく、現実的な戦意に燃えていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっしりとして大地を蹈みつけ、歩調に力があり、数学的正確の規律を以て、真にリズミカルに堂々と行軍する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには女性的な弱い心や、神経質なものや、ぐにゃぐにゃしたメロディアスのものがなく、冷酷な理智的な頭脳によって、規律正しく組織的に分析された、概念のリズミカルな配列がある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし独逸人の好むものは、科学に於ける組織的、分析的、規律的、軍隊的であるところの、あのリズミカルでがっしりした形式にかかっているのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "錆びた朱いろの絨緞を敷きつめたところどころに、外国製らしい獣皮の剥製が置いてあり、石膏の女神像や銅像の武者像などが、規律よく並んでいる。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち酷寒酷暑に於ける從事、或は蟲害其の他に就ての繁雜なる手數、緻密なる觀察、時間的不規律な勞働に服するなどの種々の場合に、努力によらなければ、中途にして歇むの状態に立ち至ることもまゝある道理で、換言すれば好んで爲すと云つても、其の間に好まざる事情が生ずるのは人生に有り勝な事實である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勿論早瀬は、それがために、分けて規律の正しい、参謀本部の方は、この新聞が出ない先に辞職、免官に、なったです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校さんだって、そんなに素晴らしい生活内容などは、期待できないけれど、でも、毎日毎日、厳酷に無駄なく起居するその規律がうらやましい。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと見た所では何う規律があるのか分らない。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子分子の假説で宇宙の規律のやや整然と説明されさうになると、人々は驚いて新なる不可思議を求める。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、漸く人馬の足跡のはっきりついた、一つの細い山道を発見した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
