[
  {
    "uuid": "680c5c8d-a3e3-5fe6-890c-f0068db6c6f7",
    "entry": "規律",
    "reading": {
      "primary": "きりつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
