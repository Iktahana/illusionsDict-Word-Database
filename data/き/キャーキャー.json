        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アイドルが登場すると、観客から「キャーキャー」という歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遊園地のジェットコースターに乗った子供たちが、怖がって「キャーキャー」叫んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友達がサプライズで現れたので、思わず「キャーキャー」声を上げてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "高松宮が大阪で社会見学をした――と云ってもキャバレーやバーめぐりであるが、どたばたキャーキャーの記事。",
              "citation": {
                "source": "ジャーナリズムの航路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮、古村、咲、熱血キャーキャーワーワー。",
              "citation": {
                "source": "日記",
                "author": "一九四九年（昭和二十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度はっきりさせておきたいのだが、エリオット、私は通常より若干逸脱したものを見たからといって、キャーキャー叫ぶような腰抜けじゃない。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは野原へ泊りに行ってからでないと手紙かけませんでしょう、だって二階は若御夫婦の巣ですから、下にいるのだから、キャーキャーパタパタシュウシュウ（これはポンプの音よ）ですものね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは見たいけれども、キャーキャーワーワーで、気が安らかでないと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
