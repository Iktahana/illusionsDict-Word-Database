    "definitions": [
      {
        "index": 1,
        "gloss": "(very) unusual",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女のファッションセンスはいつも奇抜で、周りの注目を集める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そのデザイン、すごく奇抜だけど、なんだか惹かれる！」と、展示会で作品を見た人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "奇抜なアイデアこそ、新しいものを生み出す鍵になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "奇抜なので聞いてみると、成程もつともの次第であつた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「闇汁会」や「柚味噌会」の奇抜な記事などもなかなか面白いものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな奇抜な方法で雀や鴉を捕る話も面白かった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故｜日下部博士が昔ある学会で文明と地震との関係を論じたあの奇抜な所説を想い出させられた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の如き奇抜な働きをやっても当時窃にしたことで、人に話してほこりもせず、独無邪気ないたずら童子の頭に記臆された許りであった。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年三月二十九日『東京朝日新聞』）　　　　　　　　　七十　　　　　　料理に音楽　　　　　　近頃シカゴ市で電気応用諸器械の展覧会があったが、これに関する同地の新聞の記事中に次のような奇抜な意匠が述べてある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中倉先生は大の反対論者で、こういう奇抜な事を言った事がある。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃア僕ががっかりの総代というのか」と加藤男また奇抜なことをいう。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一見はなはだしく奇抜な対比のように聞こえるであろうが、しかし自分が以下に述べんとする諸点を正当に理解される読者にとってはこうした一見奇怪な見方が決して奇怪でないことを了解されるであろうと思われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、若い娘と若い男二人がその奇抜な新宅の設備にかかっている間に、年老った方の男一人は客車の屋根の片端に坐り込んで手風琴を鳴らしながら呑気そうな歌を唄う。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹斎だか何だったか徳川初期の草子にも外法あたまというはあり、「外法の下り坂」という奇抜な諺もあるが、福禄寿のような頭では下り坂は妙に早かろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この困難を切り抜けるために持ち出された一つの今から見て奇抜な考えは、この元子のおのおのはその直線的並行落下の途中で、ある不定な時、不定な場所において、おりおり、きわめて少しその経路を曲げるというのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "井水の温度に関する彼の説明は奇抜である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん奇抜な句が飛び出して愉快であったが、そのときの先生の句に「つまずくや富士を向こうに蕎麦の花」というのがあったことを思い出す。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬が結局窓の日蔽幕に巻き込まれてくるくる回る、そうなると奇抜ではあるがいっこうにおかしくない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその中に「解り易い」とか「面白い」とか「うまい」とか「奇抜だ」とか「眼新しい」とか言う分子が余計に含まれているからで、演者や、観衆、もしくは聴衆が余り芸術的に高潮せずとも、ストーリーの興味や、リズムの甘さ、舞台面の迫真性、もしくは装飾美等に十分に酔って行く事が出来るからである。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも非人小舎とは言うものの、その小径の左右に、何処かの火事の焼跡から拾って来たらしい大きな焼木杭が二本、洒落た門構えの恰好に立っているのが、その奥のガラクタ小舎とは不釣合いな奇抜なものに見える。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも現代を超越した呑仙士ばかりで、奇抜、痛快の形容を絶した逸話をノベツに提供して、筆者の神経衰弱を吹き飛ばしてくれる。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうとき、いかにも先生らしい凡想を飛び抜けた奇抜な句を連発して、そうして自分でもおかしがってくすくす笑われたこともあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅師もその一人として如何に稀有な奇抜な卓説を持ち帰られるかと人々は待ち構えていたものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入勝橋というを渡れば山勢、渓流いよいよ非凡奇抜、ケチ臭い滝が路の両側にあったが、名は悉く忘却｜仕った。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇抜な事は突飛な位奇抜とは思ふが、それがため却つて成程と首肯しがたくなる位なものである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奇抜さ加減にときどき逸作も、かの女自身すら驚嘆することがあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そんな調子です」「それから奇抜なのは、そういう恋愛を得た時、この男のインスピレーションは高められて、しっしと、引受けた店頭建築の意匠を捗らせて見事な仕事をするのですが、出来上った店頭装飾建築には、一々そのときの恋人の名前をつけるんです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかの女は突立ったままで「ははあ、規矩男も奇抜なことをするものだ」と単にこう思っただけだったが、直ぐそのあとから、しんしんと骨身に痛みを覚え出した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の人前でする一見奇抜相ないろいろな言動の中に実は何もかも、打算して振舞って居る分別がまざまざ見えすいて来た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には古雛を買ひ集めてみたり、時には筆矢立を漁り歩いたり、奇抜だつたのは昔の千両箱の蒐集であつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この趣向は飛抜けて奇抜だつたので、たちまち京阪の遊び仲間の評判になつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも僕の景気のいい時ならいいんだが、もう為方がないときばつかり騒ぐから、逃げて行く女に手当もやれずさ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにいきばつて居るが、一つ蹉躓が来れば利害の友はみんな背く。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
