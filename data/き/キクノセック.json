      {
        "index": 1,
        "gloss": "Chrysanthemum Festival (one of the five annual festivals; celebrated on the 9th day of the 9th lunar month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
