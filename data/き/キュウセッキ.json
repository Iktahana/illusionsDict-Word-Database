        "examples": {
          "standard": [
            {
              "text": "この遺跡からは、珍しい形の旧石器が多数出土したそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館に展示されている旧石器は、当時の人々の知恵を物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川辺で見つかったこの石の塊は、専門家によって旧石器と鑑定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らの研究テーマは、南米で発見された旧石器の用途解析だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はこの問題の概略、即ち旧石器時代、新石器時代、青銅時代、鉄時代と、ラボックが定限した欧洲の四つの時代に就て語り、次にステーンストラップがバルティック沿岸の貝墟でした仕事を話し、最後に大森の貝塚のことを話した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧石器時代から新石器時代への転換期に文明史における最大の１歩が起きた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居　旧石器時代の人たちは洞穴に避難所を求めた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
