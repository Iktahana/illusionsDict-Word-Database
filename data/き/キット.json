  {
    "uuid": "f35c96e7-e134-52ea-8552-e3f30e23582c",
    "entry": "キット",
    "reading": {
      "primary": "キット",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "九鬼は「クッキーなら貰わないでもこっちから上げるよ」といって笑ったが、何かしら胸にグキット感じた。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはクキがクッキーでグキットした話である。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの場合で、クキがクッキーでグキットしたとはいいやすいが、アマノがアマゴとアナゴを間違えたといおうとするとうまく口が廻らないで多少の努力を要する。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノ裏ニハキット墓地ガアリマス。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、外衣も裏衣も、雨や、風や、岩角に破られてしまって、二人ともホントのヤバン人のように裸体になってしまいましたが、それでも朝と晩には、キット二人で、あの神様の足※の崖に登って、聖書を読んで、お父様やお母様のためにお祈りをしました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘヘヘ……その学生さんの名前とお処はチャント控えておりますから、その中に××のお宅へお伺いしたらキットまだまだ面白い掘出し物があるに違いないと思ってこの二、三日ウズウズしているんですがね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし先生がソンナ事をなされますとあの本をどこから手に入れたという事が、警察でキット問題になりますよ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日になったら僕はまたキット死にたくなるんですよ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中のありとあらゆる夢よりも、僕の心に巣喰っている虚無の方がズット深くて強いんですからね……明日になったらキット醒めちゃうんですから……」「理屈を言ったって駄目よ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キット貴女の処に行くだろうと思ったのが図に当りましたね」「ホホホ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような御大家でも縁辺のお話となりますと、一度はキット私の存じ寄りを聞きに御出でになりまっするで、私が、あれなら大丈夫と請合いますると、それからお話が進みまするような事で……ヘエ……」　と自慢そうにモウ一度、鼻の頭をコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りにこの両三日のうちにはキット下手人を探り出いてお眼にかけまする私の所存……何卒……何卒御容赦を……」　松倉十内は、何か思い直したように切柄をかけた白鞘の脇差から手を離した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしておしまいにはキットあの鼓に心を惹かされるようになるから云うんだ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ね……その代りにキット逃して下さらなければ駄目ですよ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうお母様に見せていただいた活動のわるい王様でも、綺麗なお姉さまの顔でも、キットどこかにあってよ。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日になったら、あたしキット……アラ……お母さまチョット……あそこに……」　と云いさしてチエ子は又急に母親の手を引き止めた。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……マア……可哀相に……留守番役のおふくろが死んだもんじゃけん」「キット流れ渡りの坑夫のワルサじゃろ……」　その囁きを押しわけてこの家の若い妻君が帰って来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもたった一人で、あの茶店に居るので御座いますが、それでも村の寄り合いとか何とかいう御馳走ごとにはキット出てまいります。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの夫婦は碌な死にようはせぬから……信心をせぬような犬畜生にはキット天道様の罰が当る」　とか何とか蔭口を云う者が方々に出て来るようになったが、勿論それ位の事に驚くような牛九郎夫婦ではなかった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キット遣っつけるんだぞ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私があらん限りの智慧を絞って作り上げた伊奈子タタキ潰しの計画は、表面上どんなに完全に見えていても、どこかに空想らしい弱点や欠点が潜んでいることを、後で考え直して行くうちにキット発見するのであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナタハ、キットウマイ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも聡明なあなたはキット立派な判断力に依って物事の核心を掴んで帰って来ると信じて気を静めて居ます。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トテも丈夫な血管ですよ、貴方のは……貴方はキット長生き……」　私は後の説明が聞えなかった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キット取れるものをば毎年、取りに出るチウ事は、何ぼオンチでも面火が燃えるてや……のう……」　といううちに又野はモウ赤面しながら苦笑した。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キット仇を取って進ぜまするという手紙を添えて、大枚の金子を病身の兄御にことづけた……という事が又、もっぱらの大評判になりましたそうで……まことに早や、どこまで間違うて参りまするやら解からぬお話で御座いますが……」「ハハハ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃中学校に通ったらキット落第するであろう。",
              "citation": {
                "source": "私の好きな読みもの",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話が田中とか、山本とか、林、中村、又は長兵衛、芳夫、太郎、次郎、三郎といったようなアリフレた名前をヤタラに組合わせて並べて行くと、読者はキット途中で作中の人物を混線さしてしまう。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（別人とも聞いているが）この代議士君……頭山先生は人物が出来とるから禅学をやったらキット成功する……というので翁を掴まえ、禅学を説き立てた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎へ行けばキット運が開けると手筋に書いてある』　と云います。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
