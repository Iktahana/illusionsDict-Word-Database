        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "併し、何か「しなかつたこと」をすると屹度、何かしら一つ「ものを覺える」から妙である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな繪を見る度に、屹度自分も門から外へ出て描いて見たくなるのである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川君は此のやうな歌を作り作りして行つて最う少し年を取つて来たら、屹度かう云ふ風な歌許りでは満足の出来ない時が来る。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「いや、屹度そうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが気がついて見たら、顔も屹度青かったかも知れません。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が行かなかったら先生は屹度悲しく思われるに違いない。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手で金を出すてえと、屹度左の手は物を盗ねて居やあがる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりっと私を見据えて居るものがあると思って振り向くと、屹度イフヒムの大きな夢でも見て居る様な眼にぶつかったものである。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院に居る妹の處から來たのだらう、彼男は屹度妹に親切に違ひない。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは元氣よく起き上つて手袋を脱いで腰の雪を拂ひかけた途端、「貴樣はすべる時屹度人の居ない所ですべるぞ」と云ふ聲が心の奧でした。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺屹度停車場でとつちめて見せるから」　けれどもおんつぁんはたうとう勃凸をまいて東京に出て来てしまつたのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこに行つたら記念に屹度何かくすねて来る積りだつたが、何んだか気がさして、その気になれなかつたと云つてはゐたが、あいつのことだから何が何んだか分らないといふのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには屹度小さな小屋があって、誰でも五六銭を手にしてゆくと、二三人では喰い切れない程の林檎を、枝からもぎって籃に入れて持って来て喰べさせてくれた。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯をつける前には屹度硝子戸を引いて羽蟲の來るのを防ぐにも係らず、二匹の蛾が二本の白い線のやうになつて、くり／＼と電燈のまはりを飛び※つてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち屹度その人に逢う機会が出て来るのでございます。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――（屹度座り直し然し、息は切れ切れに）わたしは女に還りました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は奪われる前に屹度自分の体を奪う価値のないものにしてお目にかけますから。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜｜子の刻迄には屹度して差上げる筈の日課が、ゆうべからの騒ぎで暁方になって仕舞った。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ウルピノ山の聖人の仰つた樣に、昔から色々の口碑のある中で、船旅程時日を選ばねばならぬものはありません、凶日に旅立つた人は屹度災難に出逢ひますよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上、私は懇意の船乘さんに聞いて見ますと、今度の航海には、弦月丸に澤山の黄金と眞珠とが積入れてあります相な、黄金と眞珠とが波の荒い海上で集ると、屹度恐ろしい祟を致します。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『其眼が怪しい、海の上ではよく眩惑されます、貴下は屹度流星の飛ぶのでも見たのでせう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、魔の日魔の刻の因縁などは信ぜられぬが、老女が最後の一言、『弦月丸には、珍らしく澤山の黄金と眞珠とが搭載されて居ます、眞珠と黄金とが夥しく海上で集合と屹度恐る可き祟があります。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等は何時か、非常の幸福を得て、再び芙蓉の峯を望む事が出來ませう――イヤ確信します、今より三年の後は屹度其時です。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝行つた處は暗い道だの危ない橋だのが澤山あつて、大佐の叔父さんや此叔父さんのやうに、成長な人でなければ行けない處、日出雄さんの樣に小さい人が行くと、屹度泣きたくなる程恐い處なんだから、默つて行つたのだよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木大佐は痛く打悦び、『君に其决心があるなら屹度出來ます、鐵車の製造所は、我が秘密造船所内の何處かに設け、充分の材料は私の方から供給し、また君の助手としては、毎日午前午後に交代に、四｜名宛の水兵を遣はす事に致しませう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出雄少年は壯快なる聲を擧げて『叔父さん／＼、獅子なんかの方では、屹度私共を怪物だと思つて居るんでせうよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『イヤ、イヤ、稻妻は尋常一樣の犬でないから、屹度無事に海岸へは達したらうが、然し、吾等の災難は非常な事だから、大佐閣下でも容易には救ひ出す策がなくつて、考慮て居なさるのだらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの可憐なる日出雄少年は、今は我が敬愛する櫻木海軍大佐閣下と共に朝日島に元氣よく、今頃は屹度、例の可愛らしい樣子で、水兵共や、愛犬の稻妻なんかと、海岸の岩の上から、遙かに日本の空を眺めて、早く孤島を出發して、一日も速かに貴方等に再會したいと待望んで居る事でせう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時は、私は、屹度、軍艦「日の出」の艦尾の方、八｜吋速射砲の横たはる邊、若くば水面高き舷門のほとりに立つて――恭しく――右手に高く兜形の帽子を揚げて、今一度、諸君と共に大日本帝國萬歳！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番｜年長の娘は、直ぐに夫れを父伯爵の手から借りて見て、「まあ何んと云う綺麗な腕環でしょう、之れは屹度伯父様から、妾に贈って下さったのですよ」と云えば、二番目の娘は横合から覗込んで、「いいえ、伯父様と妾と大の仲好しですもの、妾に贈って下さったに相違はありません」と争う。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
