    "definitions": [
      {
        "index": 1,
        "gloss": "to feel under pressure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兎ァ気がせく、蟹ァ慌てるし、早く早くと客ァ詰めこむし。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、気がせくよ」「そんなに早急なのかい」「うん、この殺人芸術家はシンフォニーの第二楽章を不用意に開始した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうしたものか、気がせくのと、道が暗いので、よけいあわてて、どこかで道を間違えたものとみえて、いくら駆けても駆けても、里の方へは降りられません。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬るのはうまく行ったが、斬ったらあの手箱からと考えていたのが外れたから、彼処か此処かと探すが、こうなると気がせく。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がせく清少年は、谷兵曹長の腕をつかんで聞いた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を返すと、非常に気がせくらしく、受付の呼鈴にとびつくようにして釦を押した。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うと風流なようだが、泰軒は気がせく。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、いや、ただ気がせくのだ」　と弥生はできるだけ男のように大きくどっしりとかまえて、「そこでどうだ？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、紹介状もほしいな」　これではまづいと思ひながら、どうも気がせくのである。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅にはいい季節であるが、気がせくので、途中の風景も殆んど眼にとまらなかった。",
              "citation": {
                "source": "雨の山吹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "体がきかないのと気がせくのとで心理的にはずいぶん長く感じたが、実際はさほどでなく、もし植込みを突っ切って行けばちょうどガラス戸と鉢合わせをするわけだったと思う。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がせくのでその庭の垣根のそばだか土手のそばだかへ近づいて行った。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、さ、こうしているあいだも気がせく、あの屋敷はみんなで幾間あるかな？",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ニールスは、気がせくので、ここにも長くいるわけにはいきません。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がせくので、話は前後したり、脇へそれたりしたが、聞いている半次はすっかりまいったらしい。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくするうちに三十分余りも経過したので、壇上の正造も気がせくのか、あわただしく神戸造船所、釜石鉄山、小坂鉱山などの払下げの件に触れて政府の無方針を難詰した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに気がせくので、たまらなく悪筆＊だけれども、他人の手を煩わすよりは自分で書く方がすきである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それと、稲吉の生死もわからず、今夜は妙に気がせくから、これでお別れといたしますぜ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
