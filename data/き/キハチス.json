        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の日差しが降り注ぐ中、木蓮の花が次々と咲き、庭を涼しげに彩っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茶室の庭に咲く一輪の木蓮は、控えめながらも確かな存在感を放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登校中、通学路の垣根に咲く木蓮の薄紫色の花が、毎日の楽しみだったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この木蓮は、毎年お盆の時期に花を咲かせるから、亡くなった祖母を思い出すんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四月も末近く、紫木蓮の花弁の居住いが何となくだらしがなくなると同時にはじめ目立たなかった青葉の方が次第に威勢がよくなって来るとその隣の赤椿の朝々の落花の数が多くなり、蘇枋の花房の枝の先に若葉がちょぼちょぼと散点して見え出す。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると木蓮によく似た架空的な匂いまでわかるような気がするんです」「あなたはいつでもそうね。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝見ると、山吹の垣の後ろは桑畑で、中に木蓮が二、三株美しく咲いていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひとり世をば讚へし子が門に榮えよ、さかえよ花緋木蓮。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の町々から、やがて、木蓮が散るように、幾人となく女が舞込む。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀鞍の少年、玉駕の佳姫、ともに恍惚として陽の闌なる時、陽炎の帳靜なる裡に、木蓮の花一つ一つ皆乳房の如き戀を含む。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼のたよりのない土器色の月は、ぶらりと下つて、仏の頬を片々照らして、木蓮の花を手向けたやうな影が射した。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る墓標の傍には、大株の木蓮が白い律義な花を盛り上げていた。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時雨と霜」「雪の翅ばたき」「白木蓮花」あたりを見ていただけばわかる。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛飾での作が「白木蓮花」の諸章。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "門は東に面し、道路を距てて直ちに石塔と向ひ、隣は左に彫刻家朝倉文夫氏のアトリヱがあり、右には珠數工の板廂が門庭の木蓮の上に見えた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "門は東に面し、道路を距てて直ちに石塔と向ひ、隣は左に彫刻家朝倉文夫氏のアトリヱがあり、右には珠数工の板廂が門庭の木蓮の上に見えた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何の木とも名は判らないが、桜のような、椿のような、木蓮のような、牡丹のような、梅のような、躑躅のような、そうした花が一面に咲いていた。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蓮　白木蓮は花が咲いてしまってから葉が出る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫木蓮は若葉のにぎやかなイルミネーションの中からはでな花を咲かせる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫木蓮は若葉の賑かなイルミネーションの中から派手な花を咲かせる。",
              "citation": {
                "source": "木蓮",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正字通申集上、蓮の字の條に、白居易忠州木蓮詩序云、予遊臨、香亦酷似、花拆時有聲。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」すかし幌の裡から、白木蓮のような横顔なのです。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背景勝手に、紫の木蓮あるもよし。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとつてはあんなに稀重至極なオホムラサキが、見るとこの村のあちこちには恰で木蓮の花弁が風に飛び散る如く、さんさんと舞ひ乱れてゐた。",
              "citation": {
                "source": "その村を憶ひて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……竹籔の蔭の井戸傍に木蓮とコヾメ桜の老樹が枝を張り、野天風呂の火が、風呂番の娘の横顔を照してゐた。",
              "citation": {
                "source": "湖の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　竹藪の蔭の井戸端に木蓮とコヾメ桜の老樹が枝を張り、野天風呂の火が、風呂番の娘の横顔を照してゐた。",
              "citation": {
                "source": "るい",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蓮の大樹が、まだところどころに花を残していた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙彌がうたへる歌華籠に盛れる木蓮は香爐の灰の冷ゆるに脆く落ちて行春のながき愁を止めぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蓮に似てゐるがそれよりずつと小さく、木蓮の佛臭なく、色は白である。",
              "citation": {
                "source": "花二三",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蓮の樣にぶよ／＼した枝でなく、まんさくに似た細い枝の、しなやかで而も雪に耐ふる強みを持つて落葉しはてた枝のさきに白々と咲くのである。",
              "citation": {
                "source": "花二三",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "新声館へ曲がってゆく横町の角には、幾本かの幟が春風にゆるくなびいて、そこらの家の庭には木蓮や桜の花が白く咲いていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴ればれと高い空を見ながら木蓮の白い花が青と紫の中に浮いて居るのを見ながら、私の心は驚くばかりの美を感謝もし讚えても居る。",
              "citation": {
                "source": "繊細な美の観賞と云う事について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
