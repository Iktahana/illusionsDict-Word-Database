          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "配達中に荷物が落ちて、中の商品が傷ついて届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年使ってきた大切な家具が、引っ越しの際に大きく傷ついてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強風で屋根の瓦が剥がれ落ち、壁の一部が傷ついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
