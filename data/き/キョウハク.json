[
  {
    "uuid": "07b35aa9-f4ab-5546-9060-bbfa89a4ce89",
    "entry": "強迫",
    "reading": {
      "primary": "きょうはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
