      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "compulsion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、手を洗わずにはいられない強迫に駆られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "検査官は、不正行為がないか徹底的に強迫した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、人前で話すことへの強迫的な恐怖を抱えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "特に強迫観念が烈しかった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな馬鹿馬鹿しい詰らぬことが、僕には強迫的の絶対命令だった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年時代に、僕をひどく苦しめた病的感覚や強迫観念が、年と共に次第に程度を弱めて来た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では多人数の会へ出ても、不意に人の頭をなぐったり、毒づいたりしようとするところの、衝動的な強迫観念に悩まされることが稀れになった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな神経衰弱者の強迫観念や憂鬱感は桜にとって唯迷惑でありましょう。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、まだ私は、桜花に就いての憂鬱感や強迫観念を語りやめようとするのではありません。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時中原君は、強度の神經衰弱で弱つてることを告白し、不斷に強迫觀念で苦しんでることを訴へた。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり中原君の場合は、強迫觀念や被害妄想の苦痛を忘れようとして酒を飮み、却つて一層病症を惡くしたのだ。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年時代の私は、非常に神經質の人間であり、絶えず病的な幻想や強迫觀念に惱まされてゐた。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、妹も母も、支那兵の乱暴に対する強迫観念のようなものは、戦慄するほど強いが、中津の恐ろしさは、女達が、殆んど意識していないと思った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数言の強迫的な文句の後、かんぬきが、ガチッとはずされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我心に従えと強迫すれど、聞入れざるを憤り、日に日に手暴き折檻に、無慙や身内の皮は裂け、血に染みて、紫色に腫れたる痕も多かりけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　無理強迫　赤城家にては泰助が、日蔽に隠れし処へ、人形室の戸を開きて、得三、高田、老婆お録、三人の者｜入来りぬ、程好き処に座を占めて、お録は携え来りたる酒と肴を置排べ、大洋燈に取替えたれば、室内照りて真昼のごとし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかにそれは、一つの強迫觀念にちがひなかつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に強迫観念が烈しかつた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな馬鹿馬鹿しい詰らぬことが、僕には強迫的の絶対命令だつた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば町へ行かうとして家を出る時、逆に森へ行けといふ強迫命令が起つて来る。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では多人数の会へ出ても、不意に人の頭をなぐつたり、毒づいたりしようとするところの、衝動的な強迫観念に悩まされることが稀れになつた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかにそれは、一つの強迫観念にちがひなかつた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに君は未練がましくも追かけて来て、彼の女にその敬愛する夫を捨てて、憎悪し恐怖している君と、遁げ出すことを強迫したので、彼の女は、不幸極まるものになってしまったのだ。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、女からものをもらうのは、いやだから、はじめからお土産の強迫などもしなかったし、また、みんなと同じおもちゃの懐中鏡一枚の恩恵に浴したところで、つまらない事だと思っていたし、マア坊が僕たちの部屋へやって来て、かっぽれに鏡を手渡し、「かっぽれさんは、この女優を知ってる？",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏を嫌がる強迫観念の強烈なのに囚われたものだけが生命に別状を起すのである。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "滔々たる世上の人、実は大なり小なり厭貧的強迫観念に囚われて苦しんでいるのでは有るまいか。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "稀有な事例に属する病的苦悩を抱いて居る者を、医家も世人も強迫観念に囚われて居るというが、達者の眼から看たら大抵の人は貧即不幸福の強迫観念所有者で、それは慥に病的であるのでは有るまいか。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは貧乏がその人を殺したと云わんよりは、貧乏即不幸福の強迫観念がその人を殺したと云った方が正しかろう。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその根本には甘味偏重の幼稚なる感じの如き財利偏重、貧乏大嫌いの幼稚なる考が強迫観念の如く附纏うている。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "木部はあらんかぎりの手段を用いて、なだめたり、すかしたり、強迫までしてみたが、すべては全く無益だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはくれないとるりとの二つ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうはくたぶれたぞ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きょうはくたびれちゃって、おじさまを喜ばせるだけの体力が、あたいに、なくなっているのよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "obsession",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、そのアイデアへの強迫にとらわれ、仕事に集中できなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "過去の失敗が、彼の心に強迫のように残り続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "芸術家は、完璧な作品を求める強迫観念に似た探求を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
