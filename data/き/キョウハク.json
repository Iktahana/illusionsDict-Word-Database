        "examples": {
          "standard": [
            {
              "text": "この楽曲は、強拍と弱拍のリズムが特徴的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "音楽理論では、拍子記号によって強拍の位置が決まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ダンスの振り付けは、音楽の強拍に合わせて作られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「私の読みかたとはずいぶん違うということくらいなら、いまの私にもよくわかるのよ」「真似すればいいのです」「教えて」　強拍やひとつにつながる部分、そしてブレスなどを鉛筆で印しながら、彼はおなじ話をもう一度読んだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはくれないとるりとの二つ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうはくたぶれたぞ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きょうはくたびれちゃって、おじさまを喜ばせるだけの体力が、あたいに、なくなっているのよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはくたびれて、かえって、お湯をあびつつ、ふと、あなたが肩の上の勲章に何気ない風で手拭をかけたりなすったときの手つきを、何とも云えない鮮やかさで思い出しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはくたびれて何となくほーとして居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあ、遠慮なくいうてくれ」　と、官兵衛もきょうはくだけた調子ではなしかけた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
