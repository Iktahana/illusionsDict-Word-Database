        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今度の旅行の切符代は、往復で1万円くらいだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画の切符代が値上がりして、少し残念だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生割引が適用され、切符代が安くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日の切符代、いくらだった？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」と丁寧に門をおとづれて、切符代を返してくれた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符代なんて、てんで集まらないし……僕は、すっかり憂鬱になりますな。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "借用証一金五千何法也右正に借用候也　月　日　　　　　大杉　栄　　菅領事殿　そしてその翌日、うちから、三等の切符代とすれすれぐらいの金が来た。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十二・五カペイキ　　切符代二十カペイキ　　　　　電車賃往復十カペイキ　　　　　　プログラム　芝居は七時半から始って十一時すぎ終る。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、或るものはまるきり無代でないにしろ、二十七カペイキの切符代で、こんな面白い、そしてためになる芝居が観られる。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリーゲルが行って、七円も八円も切符代のする帝劇かどっかの舞台で古典的なバレーの型を演じることと、二百万の失業者をふくむ日本のプロレタリアートとの間に、どんなつながりがあるであろうか。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田から御成門までの切符代が無かつたのか、惜しまれたのかして、曾ては、その間を歩いて、夜中の一時半頃に我善坊へ歸つて來たこともある女だが、一緒になつてからは、こんなに遲くまで留守にしたことはない――と、かう思ひながら、渠は額を枕の切れに當てて、油あせを拭きつけた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしトラスト（二〇）は不思議なほど繁盛する、値段が途方もなく安いから――天国へ行く切符代の御祈祷も、立派な公民の免許状も。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人前の切符代だけもらったよ」と新ちゃんがいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十銭、吉野口駅より高野口駅迄切符代。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車と汽船の切符代と雑費を差し引いて、まだ十四円程ある。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車と汽船の切符代と雑費を差し引いて、まだ十四円ほどある。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符代が惜しかつたら、自分の席から、舞台へ、「切符代を返せ」と怒鳴ればいいでせう。",
              "citation": {
                "source": "新劇の観客諸君へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十四日　月　おくれかけていそいでメイエルホリドへ出かけたら、今日はどっかのザブコム〔工場委員会〕の総見だというので切符代をかえされた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い座席が何段にも重なって、一等席は倫敦一流の劇場以上の切符代を取ってるくらいだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符代の集金やら、それに芝居の批評会にも出なきゃならなかったので。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金は、この間の研究所の公演の切符代。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっしょに来るべきはずでつい乗り後れた東洋城の電報を汽車中で受け取って、その意のごとくに御殿場で一時間ほど待ち合せていた間に、余は不用になった一枚の切符代を割り戻して貰うために、駅長室へ這入って行った。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンまでの切符代金を借りようとしていた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親が威張って馬車賃を支払い、一等車に乗れと念を押したが切符代は立て替えなかった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
