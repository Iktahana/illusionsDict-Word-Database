        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あぶなく耳にひびを切らすとこだった。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守になると、橋手前には腕白盛の滝太一人、行儀をしつけるものもなし、居まわりが居まわりなんで、鼻緒を切らすと跣足で駆歩行く、袖が切れれば素裸で躍出る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶなく耳にひゞを切らすとこだつた。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し話を途切らすと、君は、ぴくりとして眼を覚ますのだから、弱った」　それで葛岡は一夜まんじりともせず、何かかにか咽喉から声を出していたと言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫を叱って……いや、とくと理解を加えて思い切らするまでじゃ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷へかえってあの菓子頂戴しながら、菊めにお茶なぞひとねじりねじ切らすかのう。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に白髪小僧は、ヒョロヒョロに疲れて、息をぜいぜい切らすようになった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは道具を切らすまでの手続き。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも漬物を切らすので、あの日には茄子と胡瓜を沢山に漬けて置けと云ったのだ。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいつちよよ、なぜに声をば途切らすぞ、初秋の夜の蚊帳は錫箔の如く冷たきを……すいつちよよ、すいつちよよ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとマネージャーがしびれを切らすのか、私の希望する通りにかえてくれるのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　長田は、丁度居たが、二階に上って行くと、平常は大抵｜此方から何か知ら、初め口を利くのが、その時は、長田に似ず、何か自分で気の済まぬことでも、私に仕向けたのを笑いで間切らすように、些と顔に愛嬌をして、「今日も少し使者の来るのが遅かったら、好かったんだが、……明日でも自分で社に行くと可い。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一郎と三郎との泣き声が、交々母の言葉を途切らす）一郎や、後生だから、母さんの云ふことを聴いておくれ……。",
              "citation": {
                "source": "灯ともし頃",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もしわたしが話を途切らすと、彼女も口を噤んでしまう。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はどうかしてこの鉄扇の由来を聞いて見たいと思ったが、まさか、打ちつけに質問する訳には行かず、と云って話を途切らすのも礼に欠けると思って「だいぶ人が出ましたろう」と極めて尋常な問をかけた。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とまで言ひかけて、執念深いやうな亭主のある女のところまで訪ねてきた自分を、厚面しく、いくらか赤い顏をするやうな氣もちになつて、語尾を切らすやうに言つた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに不思議なことには、咳をするたびにぜいぜい苦しそうに息を切らすことだった。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "三芳　そりゃ君、時によって内でも切らすことがあるんで、そりゃ君、こうしていっしょに生活していりゃ、それくらいお互いに助けたり助けられたりするのは当然で、それくらい、君――つまり連帯性というのはそこんとこさ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはわたしの堪忍袋の緒を切らすのだ！",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人たちが歌をうたう時に、お前は息を切らすようになるんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと今日の死刑囚で、すり切らすだけの時日が私にはなかったあの藁たばの上に今晩寝るはずの、その男のことにちがいない。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "若ければ諦めをつけているが、もう中年へ差しかゝっているのに先が全く閊えていると思うから痺れを切らす。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ旦那が痺れを切らすんじゃないかと心配ですな。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い顔で息を切らすも、一瞬たりとも爵位と威厳を失うことは無かった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "十内が着物に綻びを切らすと、さっそく針と糸を借りうけて、それを縫うことまでしていた。",
              "citation": {
                "source": "日本名婦伝",
                "author": "小野寺十内の妻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういった信長の気持には、この男に、つめ腹を切らすような失態をさせたくないとする――思いやりがあったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "切るといっても、治郎左衛門は、切らすわけに参らぬ」「でも。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸陣、しびれを切らすほど、毎日が無事だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この勝家に、腹切らす奴よ）　と、玄蕃允にたいして罵った自分のことばも、陣夢｜寂たる裡に、独り沸らせていると、その憤怒も、やがては誰へも向けようもなく、自業自得と、自己に思い返してみるしかない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりきらきらする河原には私の搜すやうな畫題はなかつたので、河と此れに並行した丘との間の畑地を當もなく東へ歩いて行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
