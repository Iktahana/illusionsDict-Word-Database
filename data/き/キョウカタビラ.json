    "definitions": [
      {
        "index": 1,
        "gloss": "white kimono in which dead person is dressed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マダム・ハヤミの奴、大理石の経帷子きこんで昨夜｜晩く神戸へ行ったぞ、おい、君。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にもなきゃ経帷子を縫って遣ら。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が死んだら、姉さん、経帷子も何にも要らない、お嬢さんに頂いた、この半襟を掛けさしておくれよ、頼んだよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽ばかり秋の蝉、蜩の身の経帷子、いろいろの虫の死骸ながら巣を引※って来たらしい。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "経帷子にでも着換えるのか、そんな用意はねえすべい。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷に包まれた物というのは、白い新しい経帷子であった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の親戚あるいは知人の家に不幸があって、かれは経帷子を持参する途中であったかも知れない。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠して置くべきことでもないので、お峰はかの老婆と経帷子の一条を夫にささやくと、亭主の由兵衛も眉をよせた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "経帷子が嫁入り衣裳に化けたのだ。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい老婆に経帷子を残されたのは、こういうめでたいことの前兆であったのかと、お峰もお妻も今更のように不思議に思ったが、いずれにしても意外の幸運に見舞われて、近江屋の一家は時ならぬ春が来たように賑わった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "経帷子の老婆のすがたが目先に浮かんだからである。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「横浜から帰るときに、あのお婆さんが経帷子を置いて行ったのも、所詮こうなる因縁でしょう。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「去年あの経帷子を流したのは海辺のどこらあたりか、お前はおぼえているだろう。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがかの経帷子であるらしく思われたからである。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、人々に奇異の感を懐かせたのは、これもいつの間にか拵えてあったと見えて、かれは新しい経帷子を膝の下に敷いていたので、その鮮血が白い衣を真っ紅に染めていた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来小柄な伯父の、経帷子を着て横たわった姿は、ちょうど、子供のようであった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この妖僧へ着せようが為めか、経帷子のような雪が、レニングラード（その頃ペトログラード）の大都会に降っていた。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女連は、別の部屋の方で、経帷子や頭陀袋のようなものを縫うのに急がしかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺にも入れずに死骸許りを捨てるとなると、棺の窮屈という事は無くなるから其処は非常にいい様であるが、併し寐巻の上に経帷子位を着て山上の吹き曝しに棄てられては自分の様な皮膚の弱い者は、すぐに風を引いてしまうからいけない。",
              "citation": {
                "source": "死後",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするのだ」「叱」　と老人は眼で叱り、「経帷子がお通りになる。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ血染めの経帷子がな。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲を冠り鎧を着、薙刀を小脇に掻い込んでいるその風采には不思議はないが、鎧の上に羽織っている血紅色の経帷子が日光を受けて燦然と輝き四辺にあたかも虹のような陸離たる光彩を描き出したのは――庄三郎にとっては驚異であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお血染めの経帷子だな？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、婦人らの手で経帷子が忙しく縫われ始めた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕も紙製のが棺にあって、檜の白木が造花や経帷子の中から強く匂って来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日間の病苦におもやせてはいたが信のかおにはどこか稚らしい可愛い俤が残って、大人の死の様に怖い、いやな隈はすこしもなく、蝋燭を灯して湯灌し経帷子をきせると死んだ子の様にはなく、またしてもこの小さい魂の飛び去った遺骸を悼たんだのであった。",
              "citation": {
                "source": "梟啼く",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、死骸の上へ最後の愛撫をしていたが、経帷子に包まれた腕に触れたとき、「あっ！",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「得心なりやこそ、経帷子六字の幡。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は女がみんなして宵子の経帷子を縫った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
