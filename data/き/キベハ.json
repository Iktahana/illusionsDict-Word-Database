        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "滋賀県にある錦織寺は、真宗木辺派の本山として、静謐な空気が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わが家は代々、木辺派の教えを大切に守ってきたんだ」と、法事の際におじが語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "木辺派独自の声明の節回しを聴くと、なんだか心が洗われるような気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の資料を紐解きながら、真宗木辺派がどのように発展してきたのかを調査する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "言し来ずとも（巻十四）きべは、村の外囲ひの柵塁の類である。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "きべは地名説はわるい。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
