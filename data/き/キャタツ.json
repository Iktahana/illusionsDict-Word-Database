        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "町角の街頭画家は脚立をしまいかけていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所は椰子林の中を切り拓いて建てた、草葺きのバンガロー風のもので、柱は脚立のように高く、床へは階段で上った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子の二三脚立てられてあるのを見た。",
              "citation": {
                "source": "モウタアの輪",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、城持ち大名と一騎打ちになりそうだからな、遺言があるなら、今のうちに国もとへ早飛脚立てておかねえと、笠の台が飛んでからじゃまにあわねえぜ」　がてんがいけば天気快晴。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮時に脚立を担いだ点灯夫が、蝙蝠のやうに駆け廻つて灯を入れてゆく門々の瓦斯灯がもはや細々として今にも消えかゝりさうな時刻であつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一礼して去った給仕は、やがて、しゃれた脚立氷容器に三鞭酒の壜を冷し込んで運んで来た。",
              "citation": {
                "source": "三鞭酒",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯊釣りは彼岸を待っての垂綸で、東京湾の鱚釣りは脚立に限る。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い脚立をかついで駈てきた点燈屋さんも、立止ってにこついて眺めている。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は下足番として、浅黄の染抜の法被の上に白い前垂をかけて、入口の隅に小さな脚立に腰掛けて客を待つて居た。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが後で脚立をひっくりかえした。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に雑巾バケツや脚立が出しっぱなしになっているという粗末なビルディングだ。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海面へ脚立を立てて釣る。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱚は脚立釣りといふのをやる。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "海中の浅瀬に脚立を立てて、その上に一人宛乗つて黎明の潮の中を釣る。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "御居間の戸を開けるのはどうかと思いましたので、一応庭に脚立梯子を立てまして、硝子窓越しに覗いてみました。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって旦那様が首のうしろを真赤にして死んでいらっしゃるんですからなあ、いや、そのときわしは身体が慄えだして、脚立の上から地面へとび下りたものでございますよ」「それからどうした」「そこでわしと小林さんは、家へ入ってお手伝いのお末さんも呼び、どうしようかと相談しました。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘田医師は、脚立の上にあがって、毒劇薬の壜をセッセと下していて、それは余りに遠方に居たから、私の洋服を引張ったのは帆村の外には無い。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山すみれが脚立から下りて、二本の綱を引張って、赤見沢博士の傍へ来た。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあ、博士は、いつもこの梯子をつかっているのだな」　脚立のような形をしたその西洋梯子を、新田先生は、秘密室へかつぎこんだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鱚脚立釣佐藤垢石　青鱚釣は例年八十八夜即ち五月上旬には釣れはじまる。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣場へつくと船が適当の場所を選定して脚立を立てて呉れるからそれに乗換えて釣りはじめるのであるが、潮通しのよろしい場所でないとよく釣れない。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣れると例の長いビクを脚立から海へたれ下げるが釣れない内はビクを下してはいけない。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱心にやって見て釣れない場合は竿をあげて合図をすると船頭は舟を漕いで来て別の場所へ脚立を移して呉れるのである。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚立の上から潮下に向って錘を遠く打込み海底で錘をこづき加減に竿先を動かしているとゴツンと当りがある。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、おれののぞいている鼻のさきにはひとりの黒服をきた男が、女の奇妙なありさまをじいっとみつめているらしく、二本の足が脚立のようにつったったまま微動だにしない。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼のまえの脚立のようにつったっている男はだれだろう。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまもその本郷の朝の景色が記憶に残っているが、まだ当時は電灯がなく、ガス灯の時代で、脚立をもった人夫が点灯して回る時代であった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚立をたてて、その上へ板を一枚のせて、肉売りがいる。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自転車の横には短い脚立がしっかりとくくりつけてある。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒衣の男は、脚立を片づけて、ちょっと黙祷すると、みんなをあとにのこして去った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
