  {
    "uuid": "2a65f8da-8d9d-56e7-8836-eeb15f31aa74",
    "entry": "競合",
    "reading": {
      "primary": "きょうごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
