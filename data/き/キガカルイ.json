        "examples": {
          "standard": [
            {
              "text": "ずっと喉に刺さった棘のようだった懸案事項がようやく解決し、今は驚くほど気が軽い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、これで休暇に入れるぞ！」最後のメールを送信した彼は、気が軽そうにデスクを片付け始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "借金を完済した日の帰り道、いつもの見慣れた景色が違って見えるほど、足取りが気が軽かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつも無口な肇は、「私は今日どうしたんだかほんとうに気が軽いんです、　いくらでも話せそうなんです、　ほんとうに好い天気なんですもの。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人達は四里の峠路を而も夜になるのを承知で、隣村へでも行くように気が軽いのは羨しい、などと話しながら温い食事を始める。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやあ、気が軽いだか重いだか――へえ、唄あ唄ってら。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この臭気が軽い船暈で余程強められたのだから、航海はたしかに有難からぬものになった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い病気が軽い原因で起きたときには、カルマと病体の体液の関係を調べる必要がある。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし病名を自ら知らなければそれだけ病気が軽いといういわれはない。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに主人の為てしまった事を受けとったほうが、どんなにか、気が軽いか知れぬ』　沁々と、彼は、彼独りの心のうちで、そう思う。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて公卿殿の立場は気が軽いと申すのじゃ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
