    "definitions": [
      {
        "index": 1,
        "gloss": "one's dominant arm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
