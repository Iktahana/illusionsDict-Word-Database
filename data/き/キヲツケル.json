    "definitions": [
      {
        "index": 1,
        "gloss": "to be careful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は往来で医者の看板に気をつける自分を見出すようになった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も、気をつけるがね。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも元気をつけるにゃアこれに限るッて事よ！",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が飛びこんでから急ににぎおうて来て、いつしか文公に気をつける者もなくなった。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のように、身体で庇って、とんだ怪我でもしちゃ不可ん、気をつけるんだよ、きつと、可か、分ったかね。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色気をつけるためと言った通り、全体の劇の進行と何の関係もない浅薄なラヴシーンであった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島は出て行く時の、帯の模様の寸法にまで気をつけるのだったが、帰る時それがずれているか否かはちょっと見分けもつきかねるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、背中の女の子に気をつけるんだよ」　そこで、ゲルダは、大きな指なし手袋をはめた手を、山賊の娘のほうへのばして、「さようなら！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけるんだね」「きのうは、ここには、お日さまが照っていたのに」と、小鳥が言いました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのひとは不良少女だから、気をつけるように、ときまって言うのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者諸君も気をつけるがよい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労を知らぬわがままな処女の、へどが出るやうな気障つたらしい姿態に対して、ああ青春は純真だ、なんて言つて垂涎してゐる男たちは、気をつけるがよい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は自分に勇気をつけるように、進んでむす子の腕を組みかけながらいった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭の取りあつかいには気をつけるのですよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにぶん、おまえらは盗人になったばかりだから、へまをしないように気をつけるんだぞ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人ごみの中では、人のふところや袂に気をつけるものだ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだのクラス会の時に、君は出なかったようだが、これからは出なければいかんね、そのクラス会の時にも、藤野先生が、幹事の僕に向って、留学生との交際には気をつけるように、とおっしゃった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者も、お気をつけるがよい。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、そんな絵がはいっていると、その財布を落さないように、しじゅう気をつけるようになるし、すべての注意力をお財布に集中させて置くようにとの、つつましく厳粛な心から、あの絵を一枚入れて置くのだ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前様串戯ごとではあんめえが、何でも仕事するには元気に限るだで、景気をつけるだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒爾に見ていると判りませんが、こまかく気をつけると、湖心から風上へ揺り戻る浪のはためきで渚の結氷は二寸三寸ずつ壊れて欠けて、湖心へ向け散って行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人事を尽して天命を待つという諦めとは違った――吾々は今不幸だ、だから元気をつける為めに大饗宴を開こうという積極的な行動となって現われました。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある街の辻に古くから立つてゐる円筒状の黒い広告塔に、折々、西洋奇術の貼札が紅いへらへら踊の怪しい景気をつけるほかには、よし今のやうに、アセチリン瓦斯を点け、新たに電気燈をひいて見たところで、格別、これはという変化も凡ての沈滞から美しい手品を見せるやうに容易く蘇らせる事は不可能であらう。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "由平はそこで元気をつけるために酒を喫んだ。",
              "citation": {
                "source": "阿芳の怨霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこれで帰るから、あとを気をつけるがいいぜ。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまは勿論、わたしたちも随分気をつけることにしよう。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船首で、とんぼ返りをして景気をつける男。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中風で寝ている父親に代って柳吉が切り廻している商売というのが、理髪店向きの石鹸、クリーム、チック、ポマード、美顔水、ふけとりなどの卸問屋であると聞いて、散髪屋へ顔を剃りに行っても、其店で使っている化粧品のマークに気をつけるようになった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち專制主義の時代から、フランス革命、明治維新等を經て自由主義の時代となり、人類社會はそこに飛躍的發展をとげたのであるが、その自由には限度あり、増加する人口にたいし、土地や資源がこれに伴わない場合、多くの人に眞の自由を與えるため若干のさばきをつける、所謂「統制」を與える必要を生じた。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきはぎとあきをつけるのも、聯想を避けたのであらう。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
