    "definitions": [
      {
        "index": 1,
        "gloss": "never mind!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と申せば、庭先の柿の広葉が映るせいで、それで蒼白く見えるんだから、気にするな、とおっしゃるが、お身体も弱そうゆえに、老寄夫婦で一層のこと気にかかる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "森谷さまの財産といったら、こりゃあまた大したもんだ」「おりゃあ、財産なんかどうだっていいんだ」「お嬢さんにしてみりゃあ、そりゃあ正勝さんのことを気にするなあもっともな話だよ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて、妙に思いあがった、先輩ぶった言い方をしましたが、なに、竹さんなんかの事は気にするな、というだけの事なんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如、越後が、「人の事なんか気にするな！",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にするな」　テーブルの下にかがみこんで、高志は紙袋をひっぱりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、まあ、不始末と言えば不始末だが、お前のようにそう気にするなんてことが俺なぞから見れば可笑しい。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それほど君が気にするなら、種明しをしてもよいが、実は、意外なところに策源地があるらしい。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは自家の位地を占むることに於て毫末も仮借せざるなり、彼れは議論に負けたとか勝つたとか言ふことを頗る気にするなり。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坪　　（淋しく笑ひ）さう気にするなよ。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "様子の悪いのを気にするな。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "出しゃばるな、偉ぶるな、名を売るな、人気者になるな、世間を気にするな、いつも隠れて善いことをせよ！",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙午のごとき、人を殺すほどの迷信に対してさえ、かような優柔不断な態度を取る人々は、他のやや軽い迷信に対しては、もちろんすこぶる寛大で、人が気にするなら、せぬ方がよかろうとか、人が勧めるなら、やって見るもよかろうというて、許して置くゆえ、馬鹿げた迷信がいつまでも盛んに行なわれる。",
              "citation": {
                "source": "改善は頭から",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢさんは気が違つてゐるんですつて――だから何を言つても本気にするなつていふのよ。",
              "citation": {
                "source": "世帯休業",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまた一人の坑夫が、「そんなに嚊の事ばかり気にするなよ。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、何時かも云つたらう、ひとの女房のことばかり気にするなつて……」　鬼頭は、そこで、露骨に苦い顔をしてみせ、「ぢや、僕は少し急ぐから……」　と云つて、タクシイを拾つた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気にするなってことよ、こっちで本当の下手人を挙げりゃいいんだろう」「それだよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蜘蛛の巣",
                "note": "青空文庫"
              }
            },
            {
              "text": "登は去ってゆく津川を見送りながら、「気にするな」と半太夫に云った。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気にするなって、――」と半太夫は振返って云った、「出てゆく保本はいいだろうが、おれはあいつといっしょに」「ああ」と登は立ちながら手を振った、「そういきまかないでくれ、あいつはここにいやあしないよ、そのことは話したじゃないか」　半太夫はにぎった拳をひらき、それをまたぎゅっとにぎり緊めた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のことは何も気にするな。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ツーロン監獄と全く関係ないこともないだろ」「誰が男爵に教えたんですか」「気にするな、キミはムショ帰りだろ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "地形などは気にするな。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「休んでるのに、昇給してくれた礼をいいますとね、なに、もうけてるんだから気にするなって――」「よかったわね」　元子が顔をさしよせていうと、ひろみが尻馬にのって、「今日は、まだいいことがあったのよ。",
              "citation": {
                "source": "日めくり",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんなことを気にするな。",
              "citation": {
                "source": "葦は見ていた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おわきさんのお目付よ」おりうは安宅に酌をしながら云った、「みていてごらんなさい、こんどは自分でやって来るから」「ちまらないことを気にするな、おわきはとちも三十だっちいうじゃないか」　おりうはふきだして「お上手だわ」と云った。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しまったな」と隼人は計りながら独り言を云った、「鋸と斧を持って来るんだったな、そうすればここで支柱が作れたんだ」　岡村が云った、「そうなにからなにまで、独りで思いつくものじゃありませんよ」「気にするな」と隼人が云った、「ただの独り言だ」　岡村七郎兵衛は肩をゆりあげた。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっこ部屋だって」と男がきいた、「名はなんていうんだ」「気にするな」「名めえをきいてるんだ」「気にするなよ」と栄二は云った、「おらあ海を見に来ただけなんだ」　男は口をつぐみ、黙って栄二を見あげていた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいい、気にするな、と幹太郎は云った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎兵衛が言葉を切ると、兵部は「気にするな」と云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことを気にするな」と男は云った、「おまえさんの知りたいのは、その男におまえさんを斬れと命じた人間だろう。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年二十年巴里に子を置き違い画かきにするなぞいう野心の親とは私は違う。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
