    "definitions": [
      {
        "index": 1,
        "gloss": "temper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頻繁なる対人圏にあつて、各人が各人で朗らかであり得ぬ程度に比例して人々は互の「顔色を覗ふ」こと盛となる、即ち相対的となる、即ち創作的気心より遠ざかるわけである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "気心の合った親友なら別であるが、そうでもない来客と話をすると、すぐに疲労が起ってきて、坐って居るのさえ苦しくなる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん困るのは、気心の解らない未知の人の訪問である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」は恋の束縛に超越した自由なる浮気心でなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れゃ、あいつの気心をようくのみこんどる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気心の合った主従としか見えまい。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵っておいたって仕様がないし、そうかといってウッカリ気心の知れないところに持って行ってお勧めする訳にも行きませんからね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ですけど……まだ妾の気心がおわかりにならないんですからね。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気心でかヤコフ・イリイッチの声がふと淋しくなったと思ったので、振向いて見ると彼は正面を向いて居た。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな気心を知り合った人間同志の間柄でも、互いの性質が違い、年齢が違い、教養が違い、その時々の気分や頭の調子に変化のある以上、そう一つことを二人の人が全く同じように了解し合うということは不可能であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当に世に認められる仕事をするには、何か自分の得意とするもの、あるいは自分に振り当てられた仕事に就いて、塹壕戦のつもりで、自分の身形や他人からの悪口を気にせず、また躍り上る浮気心や他人のお世辞にのぼせ上らずに、埃だらけ泥まみれになって努力し続けなければ駄目でしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「気心は知ったり、遠慮は無しで、そこへ行くようになってから、余り月日を置かないで、顔だけも見るのは、やっと一昨年の夏からだと思う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）……で、いずれ、杯のやりとりのうちに、その職人の、気心が分ったんでしょう。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし、気心の知れた丑の時参詣でさえ、牛の背を跨ぎ、毒蛇の顎を潜らなければならないと云うんです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　照子は聞くより怒気心頭を衝きて面を赤め、「騙局です、失敬な。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて座敷で介抱して、ようよう正気づくと、仁右衛門は四辺を※し、あまたたび口籠りながら、相済みましねえ、お客様、御出家、宰八｜此方にはなおの事、四十年来の知己が、余り気心を知らんようで、面目もない次第じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムは死際に、浜龍にはどうせ好い相手があって、家を出るだろうから、銀子は年も行かないから無理かも知らないけど、気心がよく解っているから、マダムの後釜になって、商売を受け継ぐようにと、そんな意味のことも洩らしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃、あなたの気心を一ばんよく知つてゐたのは私ぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気心の合つた親友なら別であるが、さうでもない来客と話をすると、すぐに疲労が起つてきて、坐つて居るのさへ苦しくなる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「河岸の事務室を開けて、貸室に致しましたのも窮余の策で、実は、この娘に結婚させようという若い店員がございますのですが、どうも、その男の気心がよく見定まりません。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘想いの老父は、まことに良縁と思い、気心の判らぬ海へ行った若い店員との婚約は解消して是非その男に娘を嫁入らせると意気込んだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "予かつて数これを試みしに、山本氏の「清風」は茶の至美なる者にあらずと雖、神味｜頓に加はりて、霊気心胸に沁むものあるを覚ゆ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "細川忠興も立派な一将であるが、歌人を以て聞えた幽斎の後で、人物の誠実温厚は余り有るけれど、不知案内の土地へ移って、気心の知り兼ねる政宗を向うへ廻して取組もうというには如何であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、明日の糧にも気心を配る女房の顔を見れば、釜貞も人間、只暗澹として首を俯する他はなかつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年連添って、気心も、羽織も、帯も打解けたものにだってちょっとあるまい。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏深き鳴滝山のひぐらしは水の音よりすずしかりけり秋風に肌すずしく午睡して聞きごころよきひぐらしのこゑひぐらしのうつくしよしと鳴くなへに野に来て見れば千草花咲くかへりこぬあたら月日をいたづらに過すは我と山のひぐらし虫三首。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の面長な天人が、琵琶をかかえている姿をみると、「行く春やおもたき琵琶の抱きごころ」という蕪村の句を思い出す。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "できごころではなく計画的なもので、帳簿の操作も極めて巧みにやってある。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感心といっても、意外な感を持ったにすぎないが、弥兵衛はひそかに、（主君も、妙な女性に、興味をおもちになるものだ……）　と、秀吉のすきごころに、思わず微苦笑をおぼえたものだろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙村の少女、温泉の湯女、物売りの女など、かえって、都人のすきごころを疼かせたことでもあろう。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
