  {
    "uuid": "1751b33a-2832-52f9-aba7-67f453f6b406",
    "entry": "キロ",
    "reading": {
      "primary": "キロ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接頭辞"
      ],
