        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議の前に、資料をきちんと読み込んでおいてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも時間にきちんと現れるので、信頼されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風邪をひかないように、夜はきちんと暖かくして寝なさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "黒の蝶ネクタイを固くきちんと結んだままで、女給たちにはついに一指も触れなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは学生服をきちんと着て、そのうえに、ぶくぶくした黄色いレンコオトを羽織っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂家の玄関に於いて颯っと羽織を着換え、紺足袋をすらりと脱ぎ捨て白足袋をきちんと履いて水際立ったお使者振りを示そうという魂胆であったが、これは完全に失敗した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美男子といふものは、顏が小さくきちんとまとまつてゐるものである。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも家の中はきちんとしているし、よごれ物一つ溜めてないね」「そりゃそうさ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり生活は苦しそうだったが、服装はきちんとしていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗字は違っているがね」　入って来たのは洋服の服装をきちんとした壮年の紳士であった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして巣の中をきちんとかたづけ、きれいにからだ中のはねや毛をそろえて、また巣から飛び出しました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして教室中はしばらく机の蓋をあけたりしめたり本を重ねたりする音がいっぱいでしたがまもなくみんなはきちんと立って礼をすると教室を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると鳥捕りは、もうそこでとって来た鷺を、きちんとそろへて、一つづつ重ね直してゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りには黒い洋服をきちんと着たせいの高い青年が一ぱいに風に吹かれてゐるけやきの木のやうな姿勢で、男の子の手をしっかりひいて立ってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はすなほにそこへ座って、きちんと両手を組み合せました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、黄いろなゴムの長靴をはいて、脚をきちんとそろえて、まっすぐに立って云いました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは大へんまじめな顔で、きちんと立って水を見ていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛石の上に両あしを揃えてきちんと立って四人つづいて待っているのは面白い。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、とうとう、すべては再びきちんとなつたかのやうでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私の部屋を訪れた人は御存じの事だらうがとにかくそれはいつも實にきちんと整頓してゐる。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑近な事を言へば、きちんと書齋の机に向つて正座しなければ書けぬ人もあるし、疊や寢床の上に腹這ひになつても書ける人もあるし、時には混み合つた動搖する汽車の中などで平然と筆を動かす事の出來る人もあるといふ風だ。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして両あしをきちんと集めて少しかゞむやうにしてしばらくじっとしてゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ブランダと呼ばれた子はすばやくきちんとなって答えました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、も一度きちんと空がみがかれて、星座がめぐることなどはまあ夢だ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして教室中はしばらく机の蓋をあけたりしめたり本を重ねたりする音がいっぱいでしたがまもなくみんなはきちんと立って礼をすると教室を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると鳥捕りは、もうそこでとって来た鷺を、きちんとそろえて、一つずつ重ね直しているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りには黒い洋服をきちんと着たせいの高い青年が一ぱいに風に吹かれているけやきの木のような姿勢で、男の子の手をしっかりひいて立っていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はすなおにそこへ座って、きちんと両手を組み合せました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は二人とも、きっとお宮に帰って、きちんと座り、空の星めぐりの歌に合せて、一晩｜銀笛を吹くのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人はお宮にのぼり、向き合ってきちんと座り銀笛をとりあげました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は二人ともきっとお宮に帰ってきちんと座ってそらの星めぐりの歌に合せて一晩銀笛を吹くのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
