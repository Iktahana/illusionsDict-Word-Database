        "examples": {
          "standard": [
            {
              "text": "彼女は自分の部屋をいつもきちんと片付けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "提出するレポートは、きちんと清書してからにしましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あら、食器がきちんと並べてあるわね。」母が感心したように言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
