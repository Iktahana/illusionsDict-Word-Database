[
  {
    "uuid": "eef909d3-c0ee-55b0-b712-67b2cffd80f4",
    "entry": "キャメル",
    "reading": {
      "primary": "キャメル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "camel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たわむれに呟いて、たばこ屋に立ち寄り、キャメルという高価の外国煙草を二個も買い、不良少年のふりをして、こっそり吸っては、あわててもみ消す。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バットやチェリーやエアシップは月並みだと思ったが、しかし、ゲルベゾルテやキャメルやコスモスは高すぎた。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「キャメル……」「ごめんなさい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子に、子爵は新子とさし向いに坐ると、キャメルに火をつけながら、「貴女がさっき愛人とおっしゃったのは、愛人か許婚かのつもりで、おっしゃったのですか……そんな深い意味じゃないんでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "準之助は、キャメルの灰を、無意識に、畳の上に落しながら、「もっと、ほかのことがあったんでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『さあ――まずフラミンゴかキャメルフォウドでしょうな。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメルフォウドかフラミンゴさ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラミンゴか、さもなけりゃキャメルフォウドよ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを私が不幸にも小耳にはさんでいたので、今回にかぎり大事をとって独特の馬名判断法を廃し、その素晴しい人気の二匹の馬をふたりのあいだに分けて、私はフラミンゴをとり、彼女はキャメルフォウドへ、各二｜磅ずつ賭けた――ところが！",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色の小さい箱のなかに、四本入りのキャメルの煙草や、ちり紙、乾パン、粉末スープ、豚と馬鈴薯の罐詰なぞが、きちんとはいつてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「広島の大竹港へ着いて、桟橋で、キャメルの袋が落ちてましたが、あの色つてものは綺麗だと思ひましたな。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は変るが Ten-in-one にはキャメル、チェスターフィールド、ラッキー・ストライク等の煙草が入っている。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が「お母ちゃん、バナナ貰ったよ」と走って行く後を見送りながら、兵隊はキャメルを僕にくれ、自分も一本咥えて、まず僕のにライターで火をつけてから、話を始めた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしラッキーストライクに大鹿が加入して、三番にピースの国府一塁手、四番にキャメルの桃山外野手がとれたら、攻守ともに百万ドル。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメル軍の猛打者桃山外野手の住居である。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽そうな、キャメルのスプリングを着た、二十二三のほっそりとした女のひとが、五十雄君のベッドに浅く掛け、顔にハンカチをあて、思いだしたように、しゃくりあげている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、キャメルが好き、ラッキイ・ストライクでなくっちゃいけないっていうような、タバコ好きでも、まっ暗なところで、一本吸わして、それが何という煙草か、ハッキリ判ることは、めったにないものである。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメルとラッキイストライクの罐を貰って帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
