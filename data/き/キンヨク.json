[
  {
    "uuid": "a95584b5-31e9-54a2-b06c-73bedb9c3a87",
    "entry": "禁欲",
    "reading": {
      "primary": "きんよく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
