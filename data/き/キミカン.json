        "examples": {
          "standard": [
            {
              "text": "珍しい黄蜜柑をいただいたので、ジャムを作ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市場で鮮やかな黄蜜柑を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "黄蜜柑の爽やかな酸味が、暑い日にぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この黄蜜柑は、皮が薄くて剥きやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして私は子の親になっていて夕食食す子らのどの子かにほふなりすでにみかんをもぎはじめたり湯に入ると帯解く吾子のふところの青きみかんの落ちてころがる　こうした歌を詠んだりした。",
              "citation": {
                "source": "かき・みかん・かに",
                "author": "中島哀浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
