[
  {
    "uuid": "e50d7482-b495-5fdd-a8ef-e013d71e5e87",
    "entry": "覬覦",
    "reading": {
      "primary": "きゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
