    },
    "definitions": [
      {
        "index": 1,
        "gloss": "covetousness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ幸いに芸術の在るありて感覚と情緒とにより、彼の風韻を覬覦し得る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋は古来、精神界においては、西洋と較べものにならぬほど深く見事に完成せられていて、西洋の最もすぐれた哲学者たちが時たま、それをわずかに覬覦しては仰天しているという事も聞いているが、西洋はそんな精神界の貧困を、科学によって補強しようとした。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王｜覬覦の情無き能わざりしと雖も、道衍の扇を鼓して火を煽るにあらざれば、燕王｜未だ必ずしも毒烟猛々、蕩々、糾々、昂々として、屈す可からず、撓む可からず、消す可からず、抑う可からざる者、燕王に遇うに当って、※然として破裂し、爆然として迸発せるものというべき耶、非耶。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然無くても古より今に至るまで、関東諸国の民、あすこにも此所にも将門の霊を祀つて、隠然として其の所謂天位の覬覦者たる不届者に同情し、之を愛敬してゐることを事実に示してゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで夙に覬覦の心を懐いてゐたといふことは、面白さうではあるが、正統記に返還して宜いのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の虐げ、五十川女史の術数、近親の圧迫、社会の環視、女に対する男の覬覦、女の苟合などという葉子の敵を木村の一身におっかぶせて、それに女の心が企み出す残虐な仕打ちのあらん限りをそそぎかけようとするのであった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザビエル、ガゴー、フロエー、オルガンチノこれら切支丹の伴天連共、教法に藉口し耳目を眩し、人心を誘い邪法を用い、日本の国を覬覦している。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにそれがこの考証によりて、彼がうぶからの臣籍の者ではなかった事が明らかにせられた以上、彼が畏れ多くも天位を覬覦し奉った事についても、そこに幾分の理由が認められ、それが必ずしも彼が仏教徒であったが為ではないとの言い開きも立つ訳だというにあった。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "道鏡の天位を覬覦するに至った事が、阿曾麻呂の奏言によって始まったことは勅撰の国史の明記するところである。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし当時誠心国を憂うる人々は、道鏡のあまりに悪虐なるを見るに見兼ねてこれを排除せんと企て、道鏡が皇胤たるの間隙に乗じて、これを誑かして天位覬覦の念を起さしめ、それによって彼を排斥せんと試みたものであったと解する。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外には平群真鳥が天位覬覦者として数えられるが、これも孝元天皇の皇胤として、ただの臣籍の例には引き難い。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その演奏にはいろいろと疑義を持たれるが、パデレフスキーより技巧的には遙かにうまいと思われる若きピアニストが五人や七人はあるにしても、まだパデレフスキーの王座を覬覦するものは一人もあり得ない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "王位の覬覦を怖れて血縁者を除いたという如きも他の一例である。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "西銀座の「きゆぺる」の二階で会つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸の大きいお辨當箱の中を覗いて、ぎよつとしたけれども、やはり何も言はず、肩をきゆつとすくめて、またもや柴刈りに取かかる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」掌中の雀の嘴をこじあけて、小さい菜の花びらほどの舌をきゆつとむしり取つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢいつと茫然黄昏の中に立つて、なんだか父親の映像が気になりだすと一歩二歩歩みだすばかりです深夜の思ひこれは泡立つカルシウムの乾きゆく急速な――頑ぜない女の児の泣声だ、鞄屋の女房の夕の鼻汁だ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからしてみれば、一夜の間は心を静め澄さねばならない女神の斎の莚にかかる動きゆらめくものが傍におることは親とはいえ娘の神の為めにならないことは判り切った話だ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは心たしかに侠気ある若者なりしがゆえのみならず、べつに深きゆえあり、げに君にも聞かしたきはそのころの源が声にぞありける。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、于に向っては、すぐもとの通りにひきゆがんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菅は、西洋ふうに肩をきゆつとすくめて、すぐ部屋へ引き返し、眠つてゐる飛騨をゆり起した。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアのわきの壁に、兩腕をうしろへまはしてよりかかり、めくれあがつた上唇をことさらにきゆつと尖らせて言ふのであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてきゆうくつな上着の肩を氣にしながら、それでもわざと胸を張り、大きく手を振つて町を通つて行きました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風当りの強きゆゑか、何れも丸裸体になつて、黄色に染つた葉の僅少ばかりが枝にしがみ着いて居るばかり、それすら見て居る内にバラ／＼と散つて居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　手もしびれたか、きゆつと軋む……水口を開けると、茶の間も、框も、だゞつ廣く大きな穴を四角に並べて陰氣である。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　手もしびれたか、きゆつと軌む……水口を開けると、茶の間も、框も、だゝつ広く、大きな穴を四角に並べて陰気である。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の砕けて落散りたるが、見る／＼水になりて流れて、けぶり立ちて、地の濡色も乾きゆくを、怨めしげに瞻りぬ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜は西洋臭し、三崎は品が落着かず、界隈は間に合わせの俄仕入れ、しけものが多うござりますので、どうしても目量のある、ずッしりしたお堅いものは、昔からの藤沢に限りますので、おねだんも安し、徳用向きゆえ、御大家の買物はまた別で、」　と姥は糸を操るような話しぶり。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸の大きいお弁当箱の中を覗いて、ぎよつとしたけれども、やはり何も言はず、肩をきゆつとすくめて、またもや柴刈りに取かかる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女よそのごむのごとき乳房をもてあまりに強くわが胸を壓するなかれまた魚のごときゆびさきもてあまりに狡猾にわが背中をばくすぐるなかれ女よああそのかぐはしき吐息もてあまりにちかくわが顏をみつむるなかれ女よそのたはむれをやめよいつもかくするゆゑに女よ　汝はかなし。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
