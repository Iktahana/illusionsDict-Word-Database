    },
    "definitions": [
      {
        "index": 1,
        "gloss": "worn out of shape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "着崩れた二子織の胸は、血を包んで、羽二重よりも滑である。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "包ましやかな姿ながら、身を揉む姿の着崩れして、袖を離れて畳に長い、襦袢の袖は媚かしい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが羽織もぬがないで、着物がしどけない姿に着崩れてゐる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着崩れがしたと見え、褄が捻れて足くびが白く出た。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪が乱れ、衣裳が着崩れ、ちりをかぶっているところを見ると、まるで永旅でもしたようだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でもみつ口のお爺イさんが、さっき妾を丁寧に、駕籠へかき乗せてくだすった時から、妾は正気に返ったようだ」　髪一筋乱れていず、衣裳一つ着崩れていない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり着崩れた振り袖姿！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう三十二三にはなっているのだろう、着崩れた着物の下から、何か仇めいた匂いがして窶れた河合武雄と云ってもみたい女だった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に螢をあしらった、京染の単衣が着崩れてい、島田髷さえ崩れている。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤味の勝った友禅の振り袖、着崩れてかえって艶かしく、鬢などもほつれて頬へも額へも、幾筋か毛がかかっていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れた若衆髷、着崩れた男装、それが美貌と映り栄えて、歌舞伎の色若衆さながらの、艶冶たる姿態を形成っている。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田の髷が崩れ傾り、細い白い頸にかかってい、友禅模様の派手な衣裳が、紫地の博多の帯ともども、着崩れて痛々しい。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の裡くねくねと体を蠢めかして居た妻も、軈ては気力尽きてぐったり動かなくなったのを見済まして、私は悠然と落ちた帽子を拾い着崩れた着物の襟を合わせ、是でいいんだ、ふん、是でいいんだ、と呟き乍ら、一歩一歩念を押す気持で石段を下り、来懸る円タクを留めようと至極呑気な気持で待って居りました。",
              "citation": {
                "source": "陳情書",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物は派手な長襦袢のまゝ、少しの着崩れも無いのは、まだ寢なかつた證據で、何うかしたら下手人は、お蘭の前褄位を、直して行つたのかもわかりません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ／＼」　筵を取つて見ると、紛れもなくそれは、吾妻屋の手代の佐太郎で、その精力的な身體や、ちよいと好い男に變りはなく、濡れ鼠になつて着崩れてゐても、澁い好みの袷などは、水死人には勿體ないやうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒藥酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ／＼」　筵を取って見ると、紛れもなくそれは、吾妻屋の手代の佐太郎で、その精力的な身体や、ちょいと良い男に変りは無く、濡れ鼠になって着崩れて居ても、渋い好みの袷などは、水死人には勿体ないようです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は二十七八にみえる、めくら縞の長半纏にひらぐけをしめているが、着崩れで胸も足も裸同様であり、元結が切れてさんばら髪になった頭から、顔の半面、胸まで血に染まっていた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "揉みあっているうちに着崩れたものか、縞目もわからないような古｜布子の前がはだけ、平べったい胸や、晒し木綿を巻いた腹があらわになっていた。",
              "citation": {
                "source": "霜柱",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで喧嘩でもしていたような、かつて見たことのない着崩れた恰好で、栄二はなにごとかと眼をみはった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり酔っているようで、眼の中まで赤く、髪の根もゆるんでいるし、着物も前さがりに着崩れていて、よろよろしながらはいって来るとき、下っている裾を踏んであぶなく転びそうになった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸腰で、着物の衿ははだかり、袴も裾がひきずるほど着崩れている。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれも手早く、着崩れを直そうと、浴衣の上前をぐいぐいとひっぱったが、ひっぱりすぎて脇縫が前に回った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼女は、百姓の腕に泣きくずれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさまのような不義者は、一刻もおくことはできん、さっさと出て往ってくれ」「何と申します、いつ私が不義をいたしました」「しらばくれてもだめだ、きさまは彼の按摩と不義をしているのだ」「あんまりな、そりゃ、あんまりでござります」　お岩は泣きくずれた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは唐の郭元振が、夜、旅をしていると、燈火の華やかな家があるので、泊めてもらおうと思って往くと、十七八の娘が一人泣きくずれている。",
              "citation": {
                "source": "怪譚小説の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで話は数十行にわたって大きくずれてしまうのだが、それにしても自動車レースなんぞに登場してくるハイレグにハイヒールという女性は、時と場所を選ぶという感覚をどこにうっちゃってしまっているのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい一旦はこのままに済んでも、その行末が危ぶまれるので、彼女は途方に暮れたように泣きくずれてしまった。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて彼女をおびやかしていた悪夢がいよいよ現実となったのを知った時に、お時は正体もなく泣きくずれた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は自分の目からも英雄的に見えるこの決心に感激してまた新しく泣きくずれた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "額縁をつけない下絵というようなものは、重ねて巻いた端が、巻きくずれて、小口をしだらなくあらわした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
