  {
    "uuid": "db79fdb5-575e-5f3d-ab32-c3c8968107ae",
    "entry": "気炎",
    "reading": {
      "primary": "きえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high spirits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ねえ、そうじゃアないか満谷の大将」と中倉先生の気炎少しくあがる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「連中が気炎を吐いてこちらを追っていると想定するに足る理由がある。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな調子に前夜は空気炎をはいておおいに来客をへこませ、すこぶる元気よく寝についた僕も、けさは思いがけない「またへんですよ」の一言に血液のあたたかみもにわかに消えたような心地になってしまった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと歩きな」　名人の気炎、当たるべからずです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、同僚の士官たちは、｜Ｍ大尉をかこんで、「おいＭ、明日はしっかりやってくれ、日本人の名声をあげるには絶好の機会だ、どうか祖国のために万丈の気炎をはいてくれ！",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて｜Ｍ大尉は第一等の栄冠を得て、予定通りわが日本のために万丈の気炎をはきました。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畑なんて野郎は、最近、宮中にだいぶモヤモヤした空気があるようだが、新型爆弾のことを心配しているのなら、おれが出かけて行ってあくまでも頑張らせるなんてバカな気炎をあげているそうじゃないか」「そうなんですよ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの集まりはむしろ若い連中が気炎をあげる会のようになっていたのである。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを漱石は心得ており、気炎をあげる連中は自分で気づかずにいたのだと思う。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仲間を相手に雑談するうち、つい気炎をあげてしまったのだ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の気炎の中に彼らの姿がゆききするのを見るのが彼の喜びだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ミーちゃんたら、大気炎だね」と言って、細君が台所から出て来た。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "此夜はしかも雪になりて、すこしあけおきたる戸口よりもふりこむ風にあかしもきえんとするゆゑ、戸をさし炉のはたにありて戸棚の七兵衛にいふやう、蒲団はしきおきたり、そこにありて眠り玉ふな。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "松は彼のゆくまえに来て、もうだいぶ飲んだのだろう、もつれるような舌で頻りにきえんをあげていた。",
              "citation": {
                "source": "嘘アつかねえ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇った、なま暖たかいような晩だったが、信吉は「やなぎ屋」の台板へ凭れかかって、いい気持そうに酔っている松のきえんを、なんの感動もなく、聞いていた。",
              "citation": {
                "source": "嘘アつかねえ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐はわずかに遅刻しただけであるが、座はもう賑やかになり、奥山大学はもう酔って、高い声でなにかきえんをあげていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐が酔いつぶれるまで、奥山大学はきえんをあげつづけた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
