          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は気の弱いところがあって、頼み事をされると断りきれずに全部引き受けてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔から気の弱い性格だったが、部活動を通じて少しずつ自分に自信をつけていったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "気の弱い自分を変えたくて、あえて厳しい環境に身を置くことを決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに気の弱いことばかり言っていないで、一度は自分の意見をはっきり通してみなよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ひと一人、くらい境遇に落ち込んだ場合、その肉親のうちの気の弱い者か、または、その友人のうちの口下手の者が、その責任を押しつけられ、犯しもせぬ罪を世人に謝し、なんとなく肩身のせまい思いをしているものである。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、内地に於いて、彼と交際を続けていた者は、私と、それから二、三の学友だけで、いずれも大隅君から、彼の理解者として選ばれたこの世で最も気の弱い男たちであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気の弱さは、気の弱い人が人を気にしない間、善良をだけつくるのだが、人を気にしだすや、それは彼自身の生活を失はせる、いとも困つた役をしはじめる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどに無邪気な可憐な恋でありながら、なお親に怖じ兄弟に憚り、他人の前にて涙も拭き得なかったのは如何に気の弱い同志であったろう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民や、そんな気の弱いことを思ってはいけない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが都会人の気の弱いものが、一たん飜ると思い切った偽悪者になることも、小初はよく下町で見受けている例である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱いものにはむしろ凄愴いようにも思われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな気の弱いことを云わないでさ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠はあの通りの病身ですし、わたくしもこの通り気の弱い方ですから、大師匠の眼を忍んで唯まあ打ち解けて話をするぐらいのことで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼婆で名高い浅茅ヶ原に近いだけに、鬼娘の噂がそれからそれへと仰々しく伝えられて、残暑の強いこの頃でも、気の弱い娘子供は日が暮れると門涼みに出るのを恐れるようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、勤勉な工人の一人だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、それを見ている、気の弱い少年工は、自分が刺されるような気がして、顔をそむけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王はかくれてしまいたげな、気の弱い表情をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の紅殻色の壁に天狗の面が暴戻な赤鼻を街上に突き出したところは、たしかに気の弱い文学少年を圧迫するものであった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥釣りに来るおおぜいの中でも勇敢なのは堂々と先頭に立ってやって来るが、気の弱いのは先頭の背後に隠れるようにして袋をさし出すのもある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと笠井さんは、たいへんおどおどした、気の弱い男なのである。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分では、気の弱い淋しがりの不憫の子のつもりでいたのですが、いま考えてみると、やはり、わがままの高慢な子であったようでございます。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理不尽に引っ括って痛め吟味にでも掛ければ、直ぐにも冤罪を引受けそうな気の弱い連中ばっかりじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はしばらく杉の杜の陰で休んでいたが、気の弱いかれは、かくまでに零落れてその懐かしい故郷に帰って来ても、なお大声をあげて自分の帰って来たのを言いふらすことができない、大手を振って自分の生まれた土地を歩くことができない、直ちに兄の家、すなわち自分の生まれた家に行くことができない。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが昔気質の祖母の気に入りません、ややともすると母に向いまして、『お前があんまり優しくするから修蔵までが気の弱い児になってしまう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに気の弱い私ですから、よしんば危いことと気がつきましたところで、とてもあの場合、武とお幸を振りきって逃げて帰るというような思いきった所作は私にはできないのでございました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「気の弱いことをいうもんじゃあない、私はこれから加州へ行って、少し心｜当があるんだし、あそこへは先へ行って待合わせている者がある。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はごく気の弱い一信者ですから。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱いシグナレスはまるでもう消えてしまうか飛んでしまうかしたいと思いました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病な、気の弱い、箸にも棒にもかゝらぬやくざものだ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お蔦　何だねえ、気の弱い。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い罪人は一回の拷問で問い落されるのが多い、大抵の強い者でも先ず五、六回が行き止りであるのに、吉五郎は已に八回までも堪え通したのであるから、牢内では立派な男として褒められた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂越中平の平野はここに尽きて、岩を噛む神通川の激流を右に視ながら、爪先上りに嶮しい山路を辿って行くと、眉を圧する飛騨の山々は、宛がら行手を遮るように峭り立って、気の弱い旅人を脅かすように見えるであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鋭い眼でじろりと睨まれて、気の弱いお清は思わず立縮んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
