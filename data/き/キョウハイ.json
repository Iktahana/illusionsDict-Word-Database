[
  {
    "uuid": "55cbeeba-2f1f-5f8a-8b5d-53675d7ba140",
    "entry": "狂悖",
    "reading": {
      "primary": "きょうはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
