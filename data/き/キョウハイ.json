    },
    "definitions": [
      {
        "index": 1,
        "gloss": "immoral and thoughtless behaviour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は怏々として楽しまず、狂悖の性は愈々抑え難くなった。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂悖暴戻、余りに其家門の栄達を図るに急にして彼等が荘園を奪つて毫も意とせざりし、より大胆なるシーザーとしての入道相国を見たり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、平氏は独り彼等の反抗を招きたるに止らず、今や入道相国の政策の成功は、彼が満幅の得意となり、彼が満幅の得意は彼が空前の栄華となり、彼が空前の栄華は、時人をして「入る日をも招き返さむず勢」と、驚歎せしめたる彼が不臣の狂悖となれり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其狂悖の日に募るに比例して、天下は益風地震悪疫亦相次いで起り、庶民堵に安ぜず、大旱地を枯らして、甸服の外、空しく赤土ありて青苗将に尽きなむとす。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "方今聖度汪洋、爾が狂悖を恕す。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、何やら深刻な顔をして、うろうろして、突然となりの女の局員に、きょうはいいお天気だ、なんて曇っている日なのに、大声で言って、相手がおどろくと、ぎょろりと睨んでやって、立ち上って便所へ行ったり、まるで阿呆みたいになっていたのでしょう。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金平は、よんべから腹がいとうてのォ、ねておるのだで、きょうはいっしょに遊べんぜェ。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいい塩梅に船もそう混まないで、引潮の岸の河底が干潟になり、それに映って日暮れ近い穏かな初冬の陽が静かに褪めかけている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、きょうはいい天気だった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、古手屋の遠助が、きょうは大根屁だとか、きょうはいも屁だとか、きょうは、えんどう豆屁だとか、正確にかぎわけて、手がら顔にいうのである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく大学に在りし日に、余が品行の方正なるを激賞したる相沢が、きょうはいかなる面もちして出迎うらん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊は半紙廿枚綴りで、七冊百四十枚、それに御家流で丹念に細かく書かれているのであるから、全部を読了するにはなかなかの努力を要すると、わたしも始めから覚悟して、きょうはいつもよりも早く電燈のスイッチをひねって、小さい食卓の上でその第一冊から読みはじめた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいいお天気ですが、風が強いです。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "采女という邪魔外道をなんとか片付けてしまわなければ、姫と山名との縁談がなめらかに進行しないのは判り切っているので、彼はこの間からいろいろに肝胆を砕いた末にきょうはいよいよ二人の秘密を師冬の前に暴露したのであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村はまあといって倉地に椅子を与えて、きょうはいつものすげない態度に似ず、折り入っていろいろと葉子の身の上を頼んだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいつもより早かったのね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "椽側へ出て、低い廂の外にある空を仰ぐと、きょうはいい天気だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が、小さな声で、「ちと、ダーターファブラをやらないか」と言うと、「きょうはいけない」と答えたが、すぐ横を向いて、隣の男と話を始めた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なればこそ、しめたとばかり――」「うるさいね」「いいえ、きょうはいうんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいったいなんの日だと思っているんですかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいろいろの御款待、なにかと御苦労でござった」　若い公家は左少弁兼輔であった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに、きょうはいい、お天気だなあ」と、先生も感心したように空を見上げて云いました。",
              "citation": {
                "source": "誕生日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいよいよ半鐘の詮議に取りかかろうと思っていたが、午前は客が来たので出る事ができなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもきょうはいいわ、五時に日比谷で原に会うの」「ハハア」桃子は抑揚をつけてそう云いながら大きく顎をひいて芝居がかりの合点をすると、手にもっていたベレーを振って、シラノ・ド・ベルジュラックが舞台でやるような挨拶をした。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞の前垂をかけて小さい丸髷に結ったセキが、ああなアんだ、そこけ、と近づいて来るのを猛之介はこちらに立って見据えていたが、セキは又どういうものかきょうはいつものように顔の見えたところから大声でがなって来ず、すっかり猛之介のそばへよるまで黙っていて、しかも四辺を憚る気配で囁いた。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モデルはきょうはいつもよりは一層むっつりしているらしかった。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀「きょうはいりませんヨ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいいお天気であったので、三角岳登山を試みたのであったが、途中で雷に出あい、洞穴の中にとびこんで雷鳴のやむのを待った。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはいろいろと考えさせられました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だか可笑しそうね」「うん、ことしは腹ぺこ正月で、きのうまでパンが止ったろう、ゆうべはクライマックスで、二時間しか眠れなかったよ」「二三分熱を出してるが、もうきょうはいい、パンがきょうから入るから」足袋もはかないで出ている、扉の蝶番のところから見えた本をとってかえる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
