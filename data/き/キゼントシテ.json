[
  {
    "uuid": "6bec7c96-bd46-58b1-9d2e-d4ec716826b3",
    "entry": "毅然として",
    "reading": {
      "primary": "きぜんとして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
