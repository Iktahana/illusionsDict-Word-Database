    },
    "definitions": [
      {
        "index": 1,
        "gloss": "feeling uneasy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "集中豪雨で近所の川の水位が警戒レベルに達したと聞き、住民たちは夜も気が気でない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんなに大きな物音がしたけど、上の階の人は大丈夫かしら」彼女は気が気でない表情で天井を見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分が重大な計算ミスをしたかもしれないと気づいてから、上司の確認が終わるまで気が気でなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "製作物を出した生徒は気が気でない、皆なそわそわして展覧室を出たり入ったりしている。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仔細を知らぬ番人夫婦は、余りお早いではありませんか、せめてモウ五六日、せめて殿様がお出になるまで、と詞を尽して抑留めたが、私はモウ気が気でない、無理に振切って逃げて帰った。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は気が気でない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "根気よく寸断なく進んで川幅を拡めて行く生命の流れの響きを聞くものは、気が気でないものだ。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が気でないのは、時が後れて驚破と言ったら、赤い実を吸え、と言ったは心細い――一時半時を争うんだ。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と房はきよと／＼して気が気でない。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄ちゃん、早う……」　行かないと見失うわよと、カラ子はそんな京吉に、気が気でない声をあげた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の身辺で不名誉なことが起きるかと思うと、気が気でないってね。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや気が気でない乳母が、緊張に耐えられず、一切の胸のうちをぶちまけたのです。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お話の不思議さ、気が気でないで急立ちますよ、貴辺は余り落着いておいでなさる。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん高い牛だから、気が気でないという。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に為吉は血気ざかりの若い者で、自分の女房と思っているおさんが行方不明になったので、気が気でない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども縛った子にひいひい泣かれると、母は気が気でない。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかというと、彼は前の日の夕方にも一度その家を見に来たというのですから、ことによると、その時に兇行を演じて、明くる日になってから、気が気でないので、兇行の現場を偵察に来たのではないかとも疑えるのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――母はとう／＼云った、お前に会う迄は居ても立ってもいられなかったが、こうして会ってみると、こんなことをしている時にお前が捕かまるんじゃないかと思って、気が気でない、それでモウそろ／＼帰ろうと云うのだった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島さんはもう気が気でないらしい、僕を途中に置き去りにして、夏の虫のようにかがり火の影をしたって駈け出した。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中ですから、その電報を遅くうけ取って、気が気でないわたくしは慌てて東京へ帰ることにしました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは気が気でないぞ、と考えると、背筋が急に冷くなって、身体がガタガタと細く震えだした。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸掘機械なりとなんなりと、要ると思うものはすぐ集めてきて、早くこのとおりの穴を掘ってくれたまえ」　蟹寺博士は気が気でないという風に、消防隊を激励した。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために先方からどんな苦情をうけるかと思うと、彼は気が気でないのだと包み隠さずにいって、この寒中に額にびっしょりとかいた汗を手巾で拭った。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の面の白い浮標の、今沈むかと気が気でない時も斯うであらう。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してお定は、以後先、怎して那※滑かな言葉を習つたもんだらうと、心細くなつて、お吉の顔が自分等の方に向くと、また何か問はれる事と気が気でない。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叱つても矢張気が気でない。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは先刻から気が気でないのだ。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は気が気でない……　藻掻いていると、確か女が来てから一週間目だったかと思う、朝からのビショビショ降りが昼過ても未だ止まない事があった。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が気でないのでな。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も気が気でないので寐ても居られぬから弥次馬でついて往た。",
              "citation": {
                "source": "病",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が気でないような心持もした。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
