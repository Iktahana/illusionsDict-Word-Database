    "definitions": [
      {
        "index": 1,
        "gloss": "van (of a movement)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
