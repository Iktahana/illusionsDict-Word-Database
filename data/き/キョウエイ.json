  {
    "uuid": "d8332ff2-aa12-5da3-a87e-7e115d5f527a",
    "entry": "競映",
    "reading": {
      "primary": "きょうえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "competitive showing of films",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ヴェネツィア国際映画祭では、世界中から集まった力作が金獅子賞を懸けて競映された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの映画、コンペ部門で競映された時から話題になってたよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元の映画サークルが主催するインディーズ映画の競映会が、市民ホールで開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「名金」「マスターキー」「拳骨」「ハートの３」「護る影」等、等、連続探偵大活劇が競映され、例の「天国と地獄」の音楽が、必らず追駈のとき演奏された。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはね、ひと頃の競映時代で、東亜キネマとか、松竹日活だとかで、さんざん競映でやったもんですよ。",
              "citation": {
                "source": "小説のタネ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
