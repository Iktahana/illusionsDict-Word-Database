[
  {
    "uuid": "fa89c236-15e8-52e6-bf6f-245bf54f5f67",
    "entry": "競泳",
    "reading": {
      "primary": "きょうえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "competitive swimming",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は競泳の日本代表選考会に向けて、毎日一万メートル近くを泳ぎ込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっ、始まった！ 競泳の400メートル個人メドレー、手に汗握る展開だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏休みのテレビは、競泳種目の予選と決勝のハイライトで埋め尽くされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あー、やっぱり競泳選手の肩幅ってすごいな。迫力が違うよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "競泳の選手ででもあるらしく、いずれも、鮮やかな泳ぎぶりであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平泳ぎ、背泳ぎ、両抜手、片抜手、競泳、立ち泳ぎ――等を悉く試みた。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しさうな息使ひをして、眼を閉ぢて、猛烈な競泳を試みた。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志が口を手で押さえ、いかにもおかしそうに、慶一の紺の競泳パンツを指さした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プウルを村川と二人、平泳の競泳をしながら、日本へ帰ったらうんと遊ぼうや、とつまらない約束をし、プウルから上がり、脱衣場に戻って行ったら、まんまと五｜弗入りの財布を盗まれていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "プウルを村川と二人、平泳の競泳をしながら、日本へ帰ったらうんと遊ぼうや、とつまらない約束をし、プウルから上がり、脱衣場に戻って行ったら、まんまと五弗入りの財布を盗まれていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由型競泳にクロールで千六百｜米（一哩）だけ全速で泳いでも世界記録で二十分以上、大学の一流選手でも二十二三分で泳いでゐる始末だ。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、あの冷い南氷洋で競泳する覚悟ができているかね」「わしは、競泳には、自信がねえです。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の日米競泳でも、古橋は勝負強さを見せてくれた。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の日本の国際レベルの選手は高石一人だが、彼は競泳界を引退するまで、一度もワイズミュラーに勝つことができなかった。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の日米競泳で古橋のだした新記録なるものはターザン氏の記録には遠く及ばないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "この最初の国際競泳は、なんとか玉川という遥か郊外で行われ、終点で電車を降りて、多摩川ぞいの畑の中をトボトボ歩いて遊園地の五十米プールに辿りつく。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今度の日米競泳は面白かった。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャルは濠州人で、日米競泳の点数に関係しない番外の人物だ。",
              "citation": {
                "source": "日本の水を濁らすな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と古橋との対戦は日本のファンのみでなく全世界の水泳ファンの期待であったし彼が日米競泳に番外として来日したのも古橋と競技したいためであった。",
              "citation": {
                "source": "日本の水を濁らすな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本は日米競泳の勝敗にこだわって、全世界の期待を、明朗な話題を、裏切ったね。",
              "citation": {
                "source": "日本の水を濁らすな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に古橋がアメリカへ来て、日米競泳に勝ち、同時に世界記録をつくった。",
              "citation": {
                "source": "ものは考えよう",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すさまじい競泳になる。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、二百メートルほど沖に岩があってね、あの岩までひとつ競泳をしようじゃないか、とだからぼくはいった。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アザラシが島にいないときは、大きな声で、「ほうい、ほい、ほい、アザラシやあい」　と、海にむかってさけぶと、この声をききつけて、沖の方から、海面を走る魚形水雷のように、白波を起して、われこそ一着と競泳しながら、何頭も島に帰ってくる。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを水に投げ込むと亀の子が競泳を始め、何度も何度もパクンパクンやってはそれを遠くに投げ、それが水びたしになるか、池の辺をなす石垣へ押しつけられるかに至って、すぐさま破壊されて食い尽されるその光景は、実に珍無類である（図689）。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「助けてやろう、助けてやろう」　一同口々に叫んで、着物をかなぐり捨てて、競泳の様に、次々と、ドボンドボン飛込んだ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショート・パンツの下には、彼は競泳用の黒いショーツをはいていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十メートル八コースの、本格的な競泳プールだった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで全責任を負って競泳するのは、祐一の性格に合っていなかった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパー・マーケットの二階にスポーツ用品の店をみつけ、そこで競泳用のショーツを買った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "競泳用と言っていいほどに余計なデザインのされていないその水着は、白くきれいな肌をした大柄な美人である三枝子に、哲也の言うとおりよく似合っていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
