[
  {
    "uuid": "0648244c-1292-56da-9192-bdb674e21cb6",
    "entry": "旧約",
    "reading": {
      "primary": "きゅうやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
