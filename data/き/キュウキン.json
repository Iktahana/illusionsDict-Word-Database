[
  {
    "uuid": "7688611e-3a06-50ea-a1db-6eb0ef1786f9",
    "entry": "球菌",
    "reading": {
      "primary": "きゅうきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "coccus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葡萄状球菌、連鎖状球菌に因る諸疾患にも卓效を奏するといふことだつたので、私は、それを、はじめて二錠服用したときから、既に恢復の一歩を踏み出したやうな爽快を覺えました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達は、あのフィラリヤって言う寄生虫のために淋巴管が閉塞がれて、淋巴の欝積を来した場合だとか、或は又、一寸した傷口から連鎖状球菌の浸入に依って、浮腫性の病後に続発的に現れる象皮病――って奴を知ってるかい？",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウサギに肺炎球菌（）型特異的な多糖類によって抗体を沈殿させて(38)、同位体濃度を測定した。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "（球形の）球菌、（棒のような）杆菌、（コルクせん抜き様と言うか波型の）らせん菌、である。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "球菌は２つ、４つ、房、または連鎖状、をしている。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "産褥熱その他の連鎖状球菌による致死的な感染も間もなく過去の病気と考えられるようになるであろう。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんライオンが牧師を食べるのは親切な老紳士がチキンパイを食べたりブドウ状球菌が老紳士の首に腫れ物を作るのと同じように残酷さを感ずることはないであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "広義に言うとライオンは牧師に寄生するのは老紳士がチキンパイに寄生しブドウ状球菌が老紳士に寄生するのと同じである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "腸チフスや赤痢の細菌、コレラのらせん菌、外科感染を起こす連鎖球菌と葡萄状球菌、その他の微生物は宿主の外で長く生きることも短いこともある。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶血性連鎖状球菌は今日と同じように恐ろしいものであった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は腸チフスまたは亜急性連鎖状球菌症に罹ったのであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は２日後に死亡し足指の爪が食い込んだことによる悪性の連鎖状球菌によって死亡したことは間違いないであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気が何であるか判らないが全身性の連鎖球菌感染または一種の猩紅熱であり二次的に連鎖球菌肺炎を伴うものではないかと考えられる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気は重症の天然痘か猩紅熱と全身の連鎖球菌感染の合併症のようなものであった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
