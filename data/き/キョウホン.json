[
  {
    "uuid": "f7324b21-5f39-5318-88f1-de4d0296594c",
    "entry": "教本",
    "reading": {
      "primary": "きょうほん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
