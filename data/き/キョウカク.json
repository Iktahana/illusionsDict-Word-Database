[
  {
    "uuid": "344aafad-fb97-54e1-8617-5252e50747ab",
    "entry": "胸郭",
    "reading": {
      "primary": "きょうかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出刃の切っ先に切られていく骨の一つも、筋の一つも、肉の間に網のごとく走っている白い奇怪な線条も、白く浮き上っている脂肪も、びろびろと胸郭いっぱいに気味悪く広がっている肺も、左肺の下から覗いている真っ赤な桃の実のごとき心の臓も、ターヘルアナトミアの絵図と、一分一点の違いもなかった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまここに天使のお告げの神聖な鐘の音が高らかに鳴り出でて、荒れた町の上をやわらかになでてゆくならば、どんな美しい共鳴を人々の胸郭内に起こすであろう……。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モグラは蝙蝠と同じく逞ましい胸郭をもっている」と彼は手文庫を閉めながらつづけた、「骨骼と筋肉が驚くほど発達しているし、口には異常な武器を備えている。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃帝は左の胸郭のまんなかを射ちぬかれ、枯葉のようにゆらめいて前へ倒れた。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ胸郭が急にうつろになって、そこを秋風が吹くような気がする。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにも病気などなさそうに、胸郭の広い厚い胸であった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉の厚い、逞しい胸郭が大きくふくらみ、手足の筋肉に発条のような力の溢れてくるのがうかがえる。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸郭は肋間筋の収縮によって拡大すると彼は言った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯はハサミの一種で、胃はビン、腸や腺は篩、血管は管の単なる系、胸郭は１組のフイゴを入れた箱、に過ぎなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこのような方法すなわち「打診」法によって胸郭内の臓器が正常かまたは病的に変化しているかを確かめることができる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはヒトの胸を叩く方法であってこれによって起きる音の独自の性質によって胸郭内の状態についての知見が得られる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸郭の異常音はすべての場合に重篤な危険を示す徴候であると主張する。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全な題は長たらしい「新考案、胸壁を叩いて胸郭内部に隠れた病気の病徴をみつけるための」であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長六尺、大理石のような胸郭、青銅のような腕、洞穴から出るような呼吸、巨人のような胴体、小鳥のような頭蓋。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
