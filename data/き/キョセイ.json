[
  {
    "uuid": "c22979f1-c343-5ad7-a29a-36cf9242cee4",
    "entry": "去勢",
    "reading": {
      "primary": "きょせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
