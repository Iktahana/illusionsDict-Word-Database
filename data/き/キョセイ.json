        "examples": {
          "standard": [
            {
              "text": "彼の死は、文学界における真の巨星の陥落として悼まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の功績は、ファッション業界の歴史に燦然と輝く巨星だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その科学者は、後続の研究の道を切り開いた巨星だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
