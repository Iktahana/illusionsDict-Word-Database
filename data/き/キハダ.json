[
  {
    "uuid": "10a5b6d6-c5bc-57fb-b928-4a8d13b0487c",
    "entry": "黄肌",
    "reading": {
      "primary": "きはだ",
      "alternatives": [
        "きわだ",
        "キハダ",
        "キワダ"
      ],
