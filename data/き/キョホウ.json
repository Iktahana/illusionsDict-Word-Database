[
  {
    "uuid": "8890f63e-7cb4-53b6-83bf-d178d76f962c",
    "entry": "巨峰",
    "reading": {
      "primary": "きょほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
