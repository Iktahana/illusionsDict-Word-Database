[
  {
    "uuid": "b2c21454-7171-5335-bb43-8d2f7beca512",
    "entry": "起居",
    "reading": {
      "primary": "ききょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
