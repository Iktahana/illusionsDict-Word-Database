    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bark (of tree)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の木の皮が剥がれているのは、病気なのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは木の皮を使って、小さな船を作って遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "樹齢数百年の大木の木の皮は、ごつごつとしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漢方薬の中には、木の皮を乾燥させたものが使われることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "其製造というは、小刀で黐の木の皮を脱がし、それを自分の口でかみ摧いては水に洗うのである。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドでは饑饉の時灰や土を木の皮に交ぜて間に合わせる事がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから鉄砲打ちが何か云ったら、『なんだ、柏の木の皮もまぜておいた癖に、一俵二｜両だなんて、あんまり無法なことを云うな。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから鉄砲打ちが何か云ったら、『なんだ、柏の木の皮もまぜておいた癖に、一俵二両だなんて、あんまり無法なことを云うな。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の皮を煮てかせ糸を染めることまで自分でやるのを道楽にしていたようである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の皮を石でたたきつぶすと、いいにおいがしたので、おとなたちが、昼ねをしている昼さがりなど、三人で、まるできつつきのように、木のみきをコツコツとたたいていたりしました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云ひながら、栗の木の皮を一切れポタッと落して行きました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠惰屋なぞになられて堪るものか、學校へ行くのが慊なら櫻の木の皮を剥すが可いか、サア如何だ此大たわけめ！",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父は眞赤になつて怒つた、店にあるだけの櫻の木の皮を剥せ（な脱カ）ければ承知しないと力味で見たが、さて一向に效果がない。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋は三間に四間を出でず、屋根も周囲の壁も大木の皮を幅広く剥ぎて組合したもので、板を用ゐしは床のみ、床には莚を敷き、出入の口はこれ又樹皮を組みて戸となしたるが一枚｜被はれてあるばかりこれ開墾者の巣なり家なり、いな城廓なり。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あんまりいろいろなことを、あこがれて考えるものですから、木の皮が、ひどく痛みはじめました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の皮が痛むというのは、わたしたち人間にとって頭がずきずきするのと同じことです。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の皮を石で叩きつぶすと、いい匂がしたので、大人たちが、ひるねをしてゐるひるさがりなど、三人で、まるで啄木鳥のやうに、木の幹をコツコツと叩いてゐたりしました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニ・アシユ・ランゲ・グル（をを、汝立木人よ）キサラハ・ランゲ・シヌブル・カムイ（をを、汝木の皮の尊き鬼神よ）オー・トイヤン・クツタリ（汝地上に拡張せる者よ）総て善し、吾は拝せり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニ・アシユ・ランゲ・グル（をを汝立木人よ）キサラハ・ランゲ・シヌブル・カムイ（をを汝木の皮の尊き鬼神よ）オー・トイヤン・クツタリ（汝地上に拡張せる者よ）総て善し、吾は拝せり。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを振り切って山を下りまして、紅山桜や、桂の叢林を分けながら、屏風を切り立ったような石狩本流の崖の上まで来ますと、生木の皮で作った丈夫な綱をブラ下げまして、下の石原に降り立って、岩の間の淀みに迷う鱒や小魚を、掬い上げ掬い上げしておりました。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでひと晩じゅうかかって、みんなしてよくしなうかわやなぎの木の皮と、強いあしとで網を織りました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィンランド、ノルウェーなどには、今も地方に吹いたら飛ぶような木の皮で作った紙製の礼拝堂あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは木の皮をもって衣服を織り、草の実をもって五色に染めたが、その衣服の裁ち方には尾の形が残っていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけてから、智通が表へ出てみると、かれがゆうべ倒れたらしい所に一片の木の皮が落ちていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢はすでに枯れかかって、その根のくぼみに新しく欠けたらしい所があるので、試みにかの木の皮をあててみると、あたかも貼り付けたように合った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の子が此度は木の皮で編んだ袋のやうなものに入れた儘自分に出してくれた。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一人は木の皮で編んだ帽を被つて、足には木履を穿いてゐる。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その路に処々大木の皮摩損するものあり。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が、一身を賭して、僕のために保留してくれた近藤家の保護を、俺はこちらから御免を蒙ったのだ」といっているような青木の皮肉な顔を、雄吉はまざまざと想像することができた。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪に降られ雨風に打たれて、木の皮や草の根を食べながら行く苦しさはたとえようもありません。",
              "citation": {
                "source": "虫の生命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先ず白い木の皮で冠を造って、赤い木の実で染めて、王様に冠せてやった。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして巨大な材木の皮が、ひとりでにグングンむかれたり、また幹がひとりでに輪切られたり、板のように扁平に削られたり、そうかと思うと粗造ではあるが、盆や椀や筒などの形が、つくり出されるのを見ることが出来よう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして枝をきりおとされ、太いみきのかわをはがれ、まるはだかの、ほそっこいものにされて、とうとう、木だかなんだかわけのわからないものになると、この若いもみの木は、それをみてこわがってふるえました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみの木は、あいかわらず、ふかいためいきのかわりに、パチ、パチいいながら、森のなかの、夏のまひるのことや、星がかがやいている、冬の夜半のことをおもっていました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
