[
  {
    "uuid": "7a15f93c-c01a-5e16-bb38-04beadc372ea",
    "entry": "木の皮",
    "reading": {
      "primary": "きのかわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
