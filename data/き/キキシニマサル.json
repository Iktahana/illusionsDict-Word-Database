        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "われ、かく思ひて其の夜すがら三坂峠を越え行くに、九十九折なる山道は、聞きしに勝る難所なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅津只圓という者は聞きしに勝る立派な人物である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長の弟勘十郎信行の折目正しい肩衣袴で慇懃に礼拝したのとひき比べて人々は、なる程信長公は聞きしに勝る大馬鹿者だと嘲り合った。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川町の唄女のお梶どのといえば、いかに美しい若女形でも、足元にも及ぶまいと、かねがね人々の噂には聞いていたが、始めて見れば聞きしに勝るそなたの美しさじゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "バロツシユその答にや憤りけん傍人に囁いて云ひけるは、「このユウゴオ氏も聞きしに勝る狂人なり」と。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはここへくる途中、青山の久保本まで大廻りして、あらかじめ女主人と下足番の爺やとから、発病前後のことを聞きただしてきたのだが、師匠の一家はいま聞きしに勝る惨憺たる体落だった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン塔は誇るべきだよ、ニューヨークに勝る、うん」　スリム氏が年代物に対して、聞きしに勝るアメリカ人の畏敬の念を込めた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお世辞でもあるまいが、婆は、西門慶が女にかけての凄腕を、聞きしに勝るものだったと、舌を巻いて驚嘆する。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて、異様な姿で押し歩くとは聞いていたが――　今、見れば、聞きしに勝るものだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聞きしに勝る太守」　光秀も、そう見た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――会って来たが、なるほど、聞きしに勝る人品だ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「孫策の人となりは、かねて聞いていたが、聞きしに勝る英武の質だ。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、ききしにまさるお口達者でござりまするな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをあざけり顔で、冷ややかな笑みを見せながら、つづいておどり出るように姿を見せたものは、ききしにまさる醜男の、西方結び相撲秀の浦です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "林田という男は成程ききしにまさる探偵だよ」　しかし藤枝はさつきの草笛の一件からまだ私に対して気を悪くしていると見え何も云わなかつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎本は彼等の陳情を、両眼を湿ませながら懇にきいていたが、「私は谷子爵や津田仙、高橋秀臣の諸君からも実情を聴いていたし、また先日は津田君とともに被害地を視察して、ききしにまさる惨状に驚いて帰った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷は、過日みずから踏査してききしにまさる惨状をはじめて知り、断腸の思いをしたといった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "ききしにまさる天才であるよ。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがのピカ一先生も呆れた様子で、「はてさて、ききしにまさる豪傑だ。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
