        "examples": {
          "standard": [
            {
              "text": "水道管の破裂があった地域に、給水車が派遣された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お祭りの間、給水車が各所に配置され、飲み水を提供した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建設現場では、コンクリート混合用の水を供給するために給水車に頼っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「給水車があって本当に助かったよ、何時間も水が出なかったんだから！」と住民は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "自分で水を取りに行った方がよいと考える人々は、給水車など待っていられない。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
