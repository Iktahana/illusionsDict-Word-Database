        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鶴雄だけではない、――いや鶴雄などはまだ良い方で、たいていの学生は新円生活に困っていて、内職に露店の古本屋を出したり、駅でキャンディーを売ったりする学生が多かったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでも召し上がれ」　食事が済んでから葉子は米国から持って来たキャンディーを二人の前に置いて、自分は煙草を吸った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一が顔をあげると、ピンクのキャンディーストライプのエプロンをかけた店の女の子が、カウンターのなかで笑っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうがパンとキャンディだけしかつくれないじゃないの。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "またチョコレートその他のキャンディも入っている。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有毒な砂糖菓子とその検出法　飴玉、果物入り飴、その他の種類の砂糖菓子、とくに下級のキャンディはしばしば公道で子供たちを誘惑して売られていて大きく悪用されている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の種類のキャンディは時には銅の調合物により有毒になっている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この系列のキャンディには銅で汚染された痕跡を見つけ出されるであろう。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐切りであけたものは論外であるが、日本では大いに尊重している共蓋のキャンディの容器でも、コーヒーの罐でも、しまっておく家庭の方が珍しい。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりよく似ているので、ジュポンさんと思いました」　忙しそうに歩いて行くと、トラックのそばで、クリスマス・パァティの紙の袋帽そっくりなのをかぶった若い兵隊が、“Candy” I call sugar “Candy”……キャンディよ、まったく砂糖だね。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンディの仲だよ、なんてのんきな歌をうたっている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い目を光らせ、骨張った鉤爪で一度は人間だったものを掴み、子供がキャンディスティックを齧るようにその頭部にしゃぶりついていた。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに少女にとっては食事と食事のあいだにキャンディーを食べることである。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車に赤い旗を立てて、「エー、アンパンに食パン」「牛乳にサイダー」「アイスクリームにキャンディー」　と、さながら映画館の一回の終わりのようだ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はチョコレェトのキャンディをくちや／＼噛んだり（どうも失禮なことを）煙草をふかしたり代る／″＼やり乍ら、一方｜華やかな通りを近くの劇場へと驅る馬車の群を眺めてゐると、その時、美しい二頭の英吉利産の馬をつけた華奢な箱馬車がやつて來ました。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンディなんて、それは歯でかむものの名です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国のピクニックや、キャンディ・パーティ〔若い男女が集まって、砂糖菓子等をつくる会合〕その他の集会や、素人芝居や、橇や、ボートや、雪すべりや、その他の同様な集りを思い浮べると、この点に関する社交的のやり方は、娘達にとってさえも、我国の方がずっといいような気がする。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちのひとりが、集まった町の子供たちにキャンディを配った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女に関する最初の記憶は、キャンディの袋に印刷してあったサンシャインという言葉の意味を、僕に説明してくれたことだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのキャンディは、干し葡萄のひと粒ひと粒を、ミルク・チョコレートでくるんだものだった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンディや菓子パン、クッキー、そして自動車のための小さな部品、日用のこまごました雑貨の奇妙にかたよった一部分、釣りの道具などがケースの内部に入っているが、ならべ方は雑然としていて、たいていのものは色あせ、ほこりをかぶっている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスキャンディーを売っている店があった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスキャンディー、と染め抜いた旗が出ていて、プラスティックで作った見本が何本か、窓の奥にならんでいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は代金を払い、店の女性はアイスキャンディーを彼に手渡した。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスキャンディーを一本持って、彼は歩きはじめた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲也はアイスキャンディーを食べた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく彼はアイスキャンディーを食べ終った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスキャンディーの棒を、彼はその箱のなかに落とした。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「隣りの町でアイスキャンディーを食べて、それから東京へいってきた」「なにしに？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンディスのレーベルから発売されたはじめてのレコード『サーフィン』は、一九六一年の後半に五万枚ちかく売れた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
