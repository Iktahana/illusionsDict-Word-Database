        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あいつの行動、ちょっとキ印だよな。」と彼はこっそり言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな無茶な計画、まるでキ印の沙汰だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「何これ、キ印なデザイン！」と彼女は笑いながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕はこわごわ起きあがってその跡に付いてたんやけど、何やら様子が不思議やったんで、軍曹に目を離さんでおったんやが、これはいよいよキ印になっとるんや思た、自分のキ印には気がつかんで――『軍曹どの危の御座ります』僕が云うたら、『なアに、くそ！",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世の中にゃ、変わったキ印もあるもんじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、その心狂えるっていうやつが、殺された子どものそばにいるっていうんですがね」「キの字か」「そうそう、そのキの字なんだ、キ印なんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも、ご先祖代代日本橋のほうでね、手広くかつおぶし問屋をやっていたんだそうなが、なんのたたりか、代代キ印の絶えねえ脳病もちの血統があるというんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おげんはあの牢獄も同様な場所に身を置くということよりも、狂人の多勢居るところへ行って本物のキ印を見ることを恐れた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月廿三日　雨后晴、泥中行乞、呼子町、松浦屋（三〇・中）波の音と雨の音と、そして同宿のキ印老人の声で眼覚める、昨夜はアル注入のおかげで、ぐつすり寝たので、身心共に爽やかだ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の鍋とり屋さんとまた同宿、徳須恵では女が安い話を聞かされた、一枚も出せば飲んで食つて、そして抱いて寝られるといふ、あなかしこ／＼、それにつけても昨夜のキ印老人は罪のない事をいつた、彼は三十八万円の貯金があるといふ、その利子で遊ぶといふ、わはゝゝゝゝ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも一寸キ印じゃないんですか」「いや、そうですか、全く御関係はないのですか」「無論ですよ、何か彼と共犯関係でもあるという御疑いなら御免｜蒙りたいものですな」　これは勿論、半分冗談のつもりだったが、共犯関係という、或る犯罪を前提にした言葉は彼の為に聊か不用意だったとすぐ感じた。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやり方の乱暴なこと……もしかしたら今朝ほど私に食事を持って来て、非道い目に会わされた看護婦が、三人の中に交っていて、復讐を取っているのではないかと思われる位であったが、なおよく気を付けてみると、それが、毎日毎日キ印を扱い慣れている扱いぶりのようにも思えるので、私はスッカリ悲観させられてしまった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともキ印がダンビラふりまわして威勢よく乗りこんできた当座はいくら利巧者が相手にならなくとも、相当の被害はまぬがれない。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が暴行されたり、男の子が頭のハチを割られ片腕をヘシ折られキンタマを蹴りつぶされるようなことが相当ヒンピンと起ることはキ印相手のことでどうにも仕方がないが、それにしてもキ印相手にまともに戦争して殺されぶッこわされるのに比べれば被害は何万億分の一の軽さだか知れやしない。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国の文化水準や豊かな生活がシッカリした土台や支柱で支えられていさえすれば、結局キ印が居候になり家来になって隅ッこへひッこむことに相場がきまっているのである。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻めこんでくるキ印がみんな自然に居候になって隅ッこへひっこむような文明文化の生活を確立するに限るのである。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争はキ印かバカがするものにきまっているのだ。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどのバカやキ印は考えられない気になるからだ。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "キ印の娘ヤス子（当年十八歳）を一室に監禁し、食事を与えずチョウチャクして死に至らしめたという事件である。",
              "citation": {
                "source": "山の神殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さら気がつくことはなかんべ」「なぜ」「この温泉へ家族づれで来る客のうち一人はキ印さね。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大昔からキ印の温泉さ。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝にうたれているのがみんなキ印さ。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オ、キ印だ」「まだ若えのに可哀想に――」　そういって何べんすれ違う人たちに嗤われ、後ろ指さされたことだろう、でもてんでそんなこといまの小圓太の耳には入らなかったのだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初逢つた時から俺は、あの眼は氣違ひの眼ぢやないし、言ふことも拵へ事のやうな氣がしたよ」「へエ、あつしなどは本當のキ印とばかり思ひ込んで居ましたが」「それが彌太郎の利口なところだらう、――ところで、後に殘つたお信はまだ子供だ、お町は賢こい娘で、藤六の邪魔になつて仕樣がない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青錢と鍵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは日蔭町の質屋の息子で評判のキ印です。",
              "citation": {
                "source": "朝起の人達",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは彼は狂人だと言ったが、一向キ印らしくもない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも一種のキ印には相違ないが、そのキ印は、キチガイのキではなく、キケン人物のキでもなく、最も愛すべき意味の畸人のキであることを、感ぜずにはおられませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところキ印に近い奇人のようではありますが、稀れに見る奇特な老人でもある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は多少キじるしだとの評がホールの仲間にあるけれども、おそらくホールの御連中にキ的傾向を持っていないかたはあるまいと思われる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
