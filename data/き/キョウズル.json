    "definitions": [
      {
        "index": 1,
        "gloss": "to amuse oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "犬に吠えられるのは怖かったが、これはまた非常に可笑しく思ったから今以て思い出して独り興ずる折もある位で、本宅を捜したらまだ其大巾着がどこかにあるだろうと思います。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等がどのやうな物語にうち興ずるかの一例として、ここへ數行を※入しよう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "破毛布を纏ったり、頬被で顔を隠したり、中には汚れた洋服を着たのなどがあった、四五人と道連になって、笑いさざめき興ずる体で、高岡を指して峠を下りたとのことである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子も所在がないので、たまには客につれられ、汚い桝のなかで行火に蒲団をかけ、煎餅や菓子を食べながら、冬の半夜を過ごすこともあったが、舞台の道化にげらげら笑い興ずる観衆の中にあって、銀子はふと他国ものの寂しさに襲われたりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだ昼前だのに、――時々牛の鳴くのが入交って――時に笑い興ずるような人声も、動かない、静かに風に伝わるのであった。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "働く人の賣聲を、打興ずるは失禮だが、旅人の耳には唄である。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛｜鼓をうちならし乱舞に興ずる陣所もあり。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵から、夫人の前で、かしこまって、子供達とも笑い興ずることも出来ずに、ご飯をたべるのかと、新子が考えている矢先に、先刻の女中が上って来て、またひどく気の毒らしく、「奥さまが、お食事は家族だけでなさりたいとのことで、今晩から貴女は別に差しあげることになりました。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "心なき高津の何をか興ずる。",
              "citation": {
                "source": "誓之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりでザボンを切ってしばらく笑い興ずる。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その笑ひ興ずるを見て、われは更に又笑ひ興ぜざるを得ざりき。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『杖頭の錢』といふことは、支那にありたるが、『杖中の酒』は、他に其例を聞かずと、一同の喜び興ずるを見て、裸男大得意也。",
              "citation": {
                "source": "粕壁夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "検疫官は絵島丸が残して行った白沫の中で、腰をふらつかせながら、笑い興ずる群集にまで幾度も頭を下げた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "図は四条の河原の涼みであって、仲居と舞子に囲繞かれつつ歓楽に興ずる一団を中心として幾多の遠近の涼み台の群れを模糊として描き、京の夏の夜の夢のような歓楽の軟かい気分を全幅に漲らしておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西八條の御宴より歸り途なる侍の一群二群、舞の評など樂げに誰憚らず罵り合ひて、果は高笑ひして打ち興ずるを、件の侍は折々耳｜側て、時に冷やかに打笑む樣、仔細ありげなり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、古ぼけた顔に墓場のやうなそつけなさを表はした老婆たちが、若い、喜々として笑ひ興ずる、元気溌剌たる人々のあひだに揉まれてゐる有様を一瞥したなら、更に奇妙で一層合点のゆかぬ思ひが心の奥底に湧きたつたであらう。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はこんな風な物凄い陰気な話を誰れ憚らず大きな声で笑ひ興ずる様に物語つた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜など看護婦達を呼び集めて、彼等の或者も交つてかるたを取つて興ずることもあつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の酔人は「離騒」を読んで興ずると云ふが、「離騒」にあらずとも詩篇は概ね酔後の好侶伴である。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            },
            {
              "text": "人皆その眷属の如くないがしろに呼ばれながら、猶この神と笑ひ興ずることを喜びぬ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がひそひそと語らいながら、私の顔を見ては何事か笑い興ずるような時など、私は胸を刳って嬲り殺しにされるような思いがした。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気の好い日は、老博士も、死人のような生残者たちも、僕から釣道具を借りて、釣りに興ずるのだった。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学生みたいな子供っぽいところもあり、ひどく厳格な怖いところもあり、声高く笑い興ずることもあり、真正直な理屈を主張することもあり、どうも形態の知れないひとのようで、親しみにくかった。",
              "citation": {
                "source": "窓にさす影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常に於て、私は、音楽のことを語るよりも遊び興ずることが好きであつた。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語とても、本来はそうで、八ッつぁん熊さんが粋がっているのも、当時の新流行で、今日の青年がジャズに興ずる如く、当時の青年の生活がそこに実存していたにすぎないのである。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は日々時代の茶番に打興ずる事を勉むると共に、また時としては心ひそかに整頓せる過去の生活を空想せざるを得ざりき。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座辺の飲食店を徘徊する無頼漢や不良の文士などから脅迫される虞もあり、また君江が酔客を相手に笑い興ずるのを目の前に見ているのも不愉快である。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "篇中の主人公迷犬を書斎につれ来りて打興ずるあたり最面白し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
