        "examples": {
          "standard": [
            {
              "text": "前方の車が急ハンドルを切ったので、私も慌ててブレーキを踏んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "凍結した路面で急ハンドルは危険だから、ゆっくり運転しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運転中に猫が飛び出してきて、思わず急ハンドルを切ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも急ハンドルや急ブレーキが多いので、同乗していて少し怖い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ぼくのカワサキをひっかけそうになり、急ハンドルで避け、ホーンを何度も鳴らし、なぜか加速して走り去った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
