    "definitions": [
      {
        "index": 1,
        "gloss": "looking slender in clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの蒲団かて手織やが、まだそんねに着やせんのやぞ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "着やせといって裸かにしてみると肥っているのが女はよく、近頃の女は一緒に寝ても味がなかろう。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ」「びくっとして、硬く構えたわよ」「当然です」　姿が良く動きの滑らかな恵子は、半袖のシャツにスカート一枚のいまでも、着やせして見える。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着やせして見えるその体は、しかしじつはたいへんに肉感的な体であることを、これまでに何度も彼女に会って、川島は知っていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着やせして、すっごく美人で、こりゃ何者じゃ、と娘の私だって思うからね」　帆奈美を相手に喋りながら、里里葉は背後の壁に寄せて大きなクッションを積み重ねた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中西啓子は身長百六十五センチ、着やせして見える魅力的な美人であったということで、「しかし、しきりに気になるのは、消えたその独身ＯＬが、妙齢の美人であるという事実だ」と、その二ページの記事は結んでいた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に嬶が出来たり餓鬼が出来たり何かしてマゴマゴしている中にコンナに頭が禿げちゃっちゃあモウ取返しが付きやせん。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、投銭、お手の内は頂きやせん、材あかしの本を売るのでげす、お求め下さいやし。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」七　おじい傍から引取って、「ええ、旦那、つい串戯に、一番驚かしてくれようと、おう、姉や、とそれ、雲助声を出しやしたが、棲折笠に竹の杖、小袖の上へ浴衣を着て、緋の褌にもつれながら、花道を出るのと違って、方なし、おどかしが利きやせん。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "野邊の若樹の葉がくれ、根白葦の笛吹きて、みぎはの羊を呼ばふ子等も、なが音夕に聞きては、靜かなる世もみだれて、そことしもなく歎きやせめ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたなんだつて四十幾日つてものは、芳も私も帶を解きやせんでしたからねえ、かはりばんこに炬燵にひつくりかへつてて……いやいや一方ならぬ心配をしやした。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの所じゃ、老人夫婦で泥鰌一匹捕ることやてできやせん。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の方はどないにする氣でゐるんぢやろ、さつぱり見當もつきやせんが。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢたばたして見たところであきやせん。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな惡うは思はれたくない、けどいい目はしたいといふ連中ばつかしぢやけに、あきやせん。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへみんながすんでも、駒平さん一人放つときやせんのだから、ゆつくりお採りなさんせ、と云うても、その時はうんうん云つとるが、いよいよとなるとやつぱりあかん。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな學で人間は動きやせん。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けど、どれもこれもあきやせん。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしには今度の事件がどんなものやら、新聞を讀んだかててんで見當もつきやせん。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうなりや一方にしてやつて一方にしてやらんといふわけには行かんが、村長がさうしたことに一々かかづらうてゐるわけには行きやせん。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、お腹には代へられやせん、二十弗の方を戴きやせう。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた三本だけ庭木をないものと思つていたゞきやせう。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その時は、お前もそのままにはして置きやせん、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことまで僕も氣が付きやせん、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢやあ手附にこの五留札を一枚あづけときやせう！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋へは向きやせん――」「東小路中納言向きだのう」　町へ近づいたので、屋並が多くなってきた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "異草は枯れゆく秋の初霜に痩せさらぼへる犬蓼の花咲くままに萎れざりせばなかなかに見あきやせまし朝顔の花秋風にこころほどけて藤袴ほころびにけり著る人なしに秋風三首。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それつつうが、みんな赤痢の性質をわきまへて居るからなんで、なんでも赤痢は命にかゝはる病ではねえやつで、病人がしきりに糞をまり度がつちやあ便所へ行きやせう、ところが出てえには出てえだが、さて出ねえのが此の病のきまりでごわすから、何度通つても同じだ。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客「エヽ是は宜うがす、ナニ一｜両だとえ大層安いね、お貰ひ申て置きやせう、小僧さんまた木挽町の方へでもお使に来たらお寄んなせえ、私は歌舞伎座附の茶屋で武田屋の兼吉てえもんです、何日でもちよいと私をお喚びなさりやア好い穴を見附けて一｜幕位見せて上げらア、何うも大きに有難うがした。",
              "citation": {
                "source": "世辞屋",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駄目、駄目、ワクチンどころか、まだ培養できやせん」「困ったな。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
