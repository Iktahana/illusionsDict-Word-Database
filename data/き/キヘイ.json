[
  {
    "uuid": "bf00dc0b-7ab4-5ffa-85df-81f59e9b987b",
    "entry": "騎兵",
    "reading": {
      "primary": "きへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
