    "definitions": [
      {
        "index": 1,
        "gloss": "cavalry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幹部候補生を勤め上げて、騎兵少尉になつてからのことだ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一早稻田高等學院教授陸軍騎兵中尉Ｋ・Ｋ君逝けり。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎兵聯隊や上肢の運動や、下級官吏の赤靴のことや、山沿ひの道を乗手もなく行く自転車のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原は今は練兵場や粟の畑や苗圃などになってそれでも騎兵の馬が光ったり、白いシャツの人が働いたり、汽車で通ってもなかなか奇麗ですけれども、前はまだまだ立派でした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、騎兵だ、騎兵だ。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下流のまっ青な水の上に、朝日橋がくっきり黒く一｜列浮び、そのらんかんの間を白い上着を着た騎兵たちがぞろっと並んで行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　騎兵はだんだん橋を渡り、最后の一人がぽろっと光って、それからみんな見えなくなりました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、私がパリで散髪をしていると理髪師が私に向ってデ・ジャポネー（日本人）は騎兵は要らぬそうですねといった。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば第一区には「敵騎兵国境に進入」第二区には「重甲兵来る」と云った風な、最も普通に起り得べき色々な場合を予想してそれに関する通信文を記入しておく。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、その弟クリストフ（提出せられし死亡證書によれば墺太利帝國ハイステル騎兵聯隊ピロヴァノ男爵部隊の旗手として戰死せり）萬一生還せる場合は、その相續の無效たるべき證文を作成せしめられたり。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある朝、一人の騎兵があらはれた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから第二の、第四の、第十の騎兵があらはれた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、その背後には、千騎あまり――騎兵の一隊が見え出した。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎兵旗は、窓の棧の十字をしたところに凭せかけられて、斜めに立つてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルセーユの夜の酔泥れた女騎兵士官の寝床、売春婦の体温が軍服に滲みでて、私が彼女が卒倒しない程度で号令をかけるのだが、たちまちアダが軍帽の下にクレオンで愛情を描くと、卵色の口を開いて作り声を出すと、ねえ、つきあえよ、Ｙ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも妾を女騎兵中尉だなんて思わないでください。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼等に貴族の末路を象徴するブカレスト生れの軽騎兵の肖像と、人間の過去のミイラと、女の踵を提供した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼等に貴族の末路を象徴するブカレスト生れ軽騎兵の肖像と、人間の過去のミイラと、女の踵を提供した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの勇敢なコシャック騎兵までが逃げてきまひた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は、前後、左右を騎兵によって守られていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街を、剽悍な蒙古騎兵の一隊が南へ、砂煙を立てながら、風のように飛んで行く。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたは騎兵が実弾射撃に来るさうぢゃないか。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぃつさ騎兵だんすぢゃぃ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふん、あいつはあの首に鬱金を巻きつけた旭川の兵隊上りだな、騎兵だから射的はまづい、それだから大丈夫｜外れ弾丸は来ない、といふのは変な理窟だ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち行列の前駆に騎兵が来ました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいろいろ広告の山車がたくさん来て、最後にまた騎兵が警護していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　ベンガルの槍騎兵　変わった熱帯の背景とおおぜいの騎兵を使った大がかりな映画である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「だれしもいっていますように、さきへいってこまらないように、したいものでございます。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門流のむだ石捨て石は、十手さき二十手さきへいって生きてくるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
