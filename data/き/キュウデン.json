  {
    "uuid": "d2c7683c-6f0b-5eff-b010-3d849be6ef11",
    "entry": "宮殿",
    "reading": {
      "primary": "きゅうでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "palace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白人の子供も黒人の子供も、すべての人間の子供は、本來フアンタスチツクな夢の宮殿に住んでゐるのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邸宅はもとノリッチ僧正（Bishops of Norwich）の宮殿であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悲歌」の天使にとつては、過ぎし世の塔とか、宮殿とかは、ずつと昔から既に見えなくなつてゐるが故に、「實存」してゐるのです、そしていま我々の世界に立つてゐる塔とか橋などは、我々にとつてこそ實體のごとく存續してゐるけれども、天使にとつては既に見えざるものとなつてゐるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者よ、かくの如きは湖の宮殿に至る階の一｜段に過ぎない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "光を移してこちらの岸を見ると、こちらの右の方には大きな宮殿｜様の建物があって、玉樹と地を劃して、欄中には奇石もあれば立派な園花もあり、人の愛観を待つさまざまの美しい禽などもいる。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑の焔はリボンのようで、黄色い焔は宮殿のようであった。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宮殿の屋根には美しい網がかかる。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は戦争に勝つ毎に、宮殿の壁や廊下を数万の敵兵の新しい虐殺屍体で飾りその中で敵国の妃や王女を初め、数千の女性の悲鳴を聞いて楽しんだ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣と家来共は馬を降りて洞穴の中へ入って行きますと、やがて一つの見事な宮殿に来ました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宮殿のお庭に一人の気高い姿をした女と一人の美しい青年が話をしておりました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、近ごろにアインシュタインが突然第二の扉を蹴開いてそこに玲瓏たる幾何学的宇宙の宮殿を発見した。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マラーは彼が宮殿と呼ぶ襤褸籠のような借家の浴室で、湯にひたりながら書きものをしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實驗室――彼れの庵室とも、城郭とも、宮殿とも昨日まで思つて、この六年間｜立籠つてゐた實驗室を彼れはいま／＼しげに見まはした。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルュクサンブルグ宮殿には若きルイ十六世とその妻マリー・アントワネットが住んでいた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　錦葉の蓑を着て、其の階、其の柱を攀ぢて、山々、谷々の、姫は、上※は、美しき鳥と成つて、月宮殿に遊ぶであらう。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河間王が宮殿も、河陰の亂逆に遇うて寺院となりぬ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの眼は、ルーブル宮殿の中のあちこちの部屋の中へ入りこんでいきました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は宮殿の部屋や広間の中に押し入って行きました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに天文学の発達が、月を疱瘡面の醜男にし、天女の住む月宮殿の連想を、荒涼たる没詩情のものに化したことなども、僕等の時代の詩人が、月への思慕を失つたことの一理由であるかも知れない。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のわきに柵があって、その崖の下の緑樹の梢を越してトロカデロ宮殿の渋い円味のある壁のはずれを掠めて規則正しくセーヌへ向けてゆるやかな勾配を作っている花壇の庭が晴々しく眺められた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の緑の宮殿の柱が砕けているのです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とくりかえしながら、宮殿のほうへかえってゆきました。",
              "citation": {
                "source": "王さまと靴屋",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "光を移して此方の岸を見ると、此方の右の方には大きな宮殿様の建物があつて、玉樹と地を劃して、欄中には奇石もあれば立派な園花もあり、人の愛観を待つさま／″＼の美しい禽なども居る。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分は、天なる（仰いで礼拝す）月宮殿に貢のものにござりました。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま海の底へお引取りになって、現に、姉上の宮殿に、今も十七で、紅の珊瑚の中に、結綿の花を咲かせているのではないか。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海底の琅※の宮殿に、宝蔵の珠玉金銀が、虹に透いて見えるのに、更科の秋の月、錦を染めた木曾の山々は劣りはしない。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私の愛する、この宮殿にある貴女が、そんな故郷を思うて、歎いては不可ん。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女　いいえ、この宮殿、この宝玉、この指環、この酒、この栄華、私は故郷へなぞ帰りたくはないのです。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童だい、あかんべい、とやった処が、でしゅ……覗いた瞳の美しさ、その麗さは、月宮殿の池ほどござり、睫が柳の小波に、岸を縫って、靡くでしゅが。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月一日の朝まだき、神々の御父ジュピタア様の宮殿へおまいりの途中で逢った三人目の男のひとを私の生涯の夫ときめよう。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
