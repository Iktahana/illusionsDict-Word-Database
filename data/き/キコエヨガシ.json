[
  {
    "uuid": "5dec8312-216e-5f86-bbab-22ab365be78c",
    "entry": "聞こえよがし",
    "reading": {
      "primary": "きこえよがし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
