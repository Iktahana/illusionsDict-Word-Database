  {
    "uuid": "2eb55dee-d927-5614-9bdd-e5589a48265c",
    "entry": "貴宅",
    "reading": {
      "primary": "きたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
