    },
    "definitions": [
      {
        "index": 1,
        "gloss": "your house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの石川さんなら」「では、私が今石川さんを貴宅につれて来ましょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "石川光明氏と心安くなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子さんが、若し貴宅を訪れましたらこのことゝ、そして、実家の思惑について依頼された守りに関しては、飽くまでも信用のある家庭教師が頑張るであらうから――とお伝へ下さい。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「清和之時候と申内、稍薄暑も催候処、貴宅御揃愈御多祥被成御坐候条、拝賀之至。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何時でしたか、雨の降る中を貴宅からの帰りに、此の田圃で、若い娘さんの簑笠で、肥車を押して来るのに逢ひましたが、其の簑の濡れた姿が如何にも可かつた。",
              "citation": {
                "source": "大野人",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三六）23　書物六題一　書物の私的擅有　かつて、多少私が知っているある富豪が有っている本を一部見たいと思って、貴下の文庫の之々の本を見せて頂きたいと思うが、貴宅に参上して簡単に閲読させては呉れまいかと申し出た。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がもし一個の林檎に如何にも惚れ惚れとしたら、それを描きたくなるであらう。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、手紙が書きたくなるたびに、沢山書くことがあるやうな気持なのですが、さて書き出してみると、何もないのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思へば、甲州のことは、書きたくない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、この一文を書きたくなつた今晩君が傍にゐて呉れたら僕は大変沢山なことが喋舌れた。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は孤独で居れば居るほど、夜毎に宴会の夢を見るようになり、日毎に群集の中を歩きたくなる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく同じような事を二度は書きたくないから、前に書かなかったと思うことだけを記すことにする。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻掻きたくても体は一寸も動かぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこの狸は、何の罪とがも無く、山でのんびり遊んでゐたのを、爺さんに捕へられ、さうして狸汁にされるといふ絶望的な運命に到達し、それでも何とかして一條の血路を切りひらきたく、もがき苦しみ、窮餘の策として婆さんを欺き、九死に一生を得たのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「書きたくないんですよ。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書きたくないのです。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は役人に縛られたときとった蕈を持たせられて町を歩きたくないと考えました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしだってわからないわ、どこへもいきたくないわね。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで調べていよいよある温泉に行くとなると、今度はその温泉の案内に明るい人の話が聞きたくなるのである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンベリーの「新兵」の絵を見ていれば可笑しいよりは泣きたくなる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川君は、驚きたくないと云つてる。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は敢て驚きたいとも思はないが、強て驚きたくないと猶更勉めたくはない。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川君は驚きたくないと云つたが、驚かない寧ろ驚けない人であつたらしい。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子の風を見て僕も俄に悲しくなって泣きたくなった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、その意味を説明する前に、私はこの一文の読者に、氏が嘗て批評に就いて有島生馬氏に与へた反駁文と、同じく嘗て書かれた氏の感想「芸術その他」とを想ひ起し、また氏が何故に自己の直接体験を取材化しないかを一寸考へてみて戴きたく思ふ。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし此頃に成って見ると矢張仕事ばかりじゃア、有る時や無い時が有って結極が左程の事もないようだし、それに家にばかりいるとツイ妹や弟の世話が余計焼きたくなって思わず其方に時間を取られるし……ですから矢張半日ずつ、局に出ることに仕ようかとも思って居たところなんですよ。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類に民事上の訴訟問題でも起りかかった場合に、われわれはある具体的の法律上の知識の概要を得ておきたくなる。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞きたくなければ聞流している事も音楽ならばそれほど困難ではない。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津は、この家のあっさりとして、華やかな、日本娘の着物や、四国｜訛のある日本語や、若々しい鶏の胸肉のように軟らかい、ふるいつきたくなる娘の肉体を、視覚で享楽しながら、一家の不安に同感し、心配げな顔をしたり、また、特別、力になってやるようなことを云ったりした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでも、醤油屋へ行きたくなくなって、彼は、十時頃まで日向ぼっこをしていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
