[
  {
    "uuid": "e95d9a5f-f56d-540e-99e0-a7037cbe60cf",
    "entry": "帰宅",
    "reading": {
      "primary": "きたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
