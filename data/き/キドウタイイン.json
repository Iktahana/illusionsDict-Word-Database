        "examples": {
          "standard": [
            {
              "text": "真夏の猛天下でも重い装備を身につけた機動隊員たちが、黙々とマラソン大会の沿道警備にあたっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お兄ちゃん、将来は機動隊員になって災害現場で人を助けたいって、毎日懸垂の練習をしてるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヘルメットの隙間から、若い機動隊員が鋭い眼光で周囲の不審な動きに目を光らせているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "立ち入り禁止区域の境界に立っていた機動隊員が、迷子になって泣き出した子供に優しく声をかけて保護した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "地上で待機していた機動隊員約八〇〇人はこの動きを規制。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
