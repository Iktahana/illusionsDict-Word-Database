[
  {
    "uuid": "55b014cd-af28-5fa7-a1b6-1d1fb936bb41",
    "entry": "虚礼",
    "reading": {
      "primary": "きょれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
