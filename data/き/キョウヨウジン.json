[
  {
    "uuid": "7d071df2-1b3c-58f9-bf6a-2aaa8255546c",
    "entry": "教養人",
    "reading": {
      "primary": "きょうようじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
