    "definitions": [
      {
        "index": 1,
        "gloss": "to become mentally exhausted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "何度も同じ説明を繰り返したが理解してもらえず、すっかり気骨が折れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "連日の徹夜作業と度重なるトラブルで、さすがに私の気骨も折れる寸前だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複雑な人間関係の調整に奔走し、彼の気骨はすっかり折れてしまったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この困難な状況に直面しても、気骨が折れることなく最後までやり遂げたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "結婚した当時、博士は笑談に、お前は硝子出だから、扱ふに気骨が折れると云つた事があるさうだ。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は何の未練気もなく斯んなことを喋舌つて、「それにしても君は俺達も、左う思つてゐるんだが、珍らしく淡白な男で、却つて、何をして貰ふにも一番気骨が折れるなんて彼女は面倒がつてゐたよ。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売屋じゃ、なかなか気骨が折れるだろうね。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "李剛　（低声に）人気者は気骨が折れると諦めるさ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銀烟管などは失ふまいと思ふと気骨が折れる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの行商は気骨が折れる、一軒一軒で口上だからと、捨吉は不機嫌だった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなものかしら、でも、あんな所へ始終いってる男の方たちは、気骨が折れると思うわ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなひと相手では、あなたも気骨が折れることでしょう。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし奥さんの方でもずいぶん気骨が折れるでしょう。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿女中が花見にでも行くようにこう云うものを研ぎ出しの提げ重の抽出しへ入れて、飲み物から摘まみ物までわざわざ京都から運んで来るのでは、茶屋に取っても有り難くない客であろうが、お久もずいぶん気骨が折れるに違いあるまい。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
