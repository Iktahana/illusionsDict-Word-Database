    "definitions": [
      {
        "index": 1,
        "gloss": "disposition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてその気質としては、動物よりも植物を、夏よりも冬を愛し、――『鋼青』を『苹果』を、午前のみそれを愛したのです。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かそれは、現実的な理想家気質――とでもいふやうなものではないのか。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の『貞淑』とは、良人に奴婢としての善き奉仕をすることではなくして、良人の気質や性格をよく理解し、努めて良人に同化して一心同体となることの奉仕である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くから母に死なれ、父は頑固一徹の学者気質で、世俗のことには、とんと、うとく、私がいなくなれば、一家の切りまわしが、まるで駄目になることが、わかっていましたので、私も、それまでにいくらも話があったのでございますが、家を捨ててまで、よそへお嫁に行く気が起らなかったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私――私の気質は、理性的ではない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか前に他の論文で書いたことだが、芥川龍之介の悲劇は、彼が自ら「詩人」たることをイデーしながら、結局気質的に詩人たり得なかつたことの宿命にあつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというに、俳句の一般的特色として考えられる、あの枯淡とか、寂びとか、風流とかいう心境が、僕には甚だ遠いものであり、趣味的にも気質的にも、容易に馴染めなかったからである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があらゆる俳句を理解し得ず、俳句を本質的に毛嫌いしながら、一人例外として蕪村を好み、彼の俳句だけを愛読したという事実は、思うにおそらく、蕪村の情操における特異なものが、僕の趣味性や気質における特殊な情操と密に符合し、理解の感流するものがあったためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は関西の人であり、元来が南国人であるけれども、好んでまた南国の明るい風物を歌ったのは、彼自身が気質的にも南国人であったことを実証している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉自身が、気質的に北国人であったからだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り蕪村がこの点で独歩であり、多くの秀れた句を書いているのは、彼の気質が若々しく、枯淡や洒脱を本領とする一般俳人の中にあって、範疇を逸する青春性を持っていたのと、かつ卑俗に堕さない精神のロマネスクとを品性に支持していたためである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉における木曾義仲の崇拝や、戦国時代への特殊な歴史的懐古趣味を、一方蕪村の平安朝懐古趣味と比較する時、両者の異なる詩人的気質が、おのずから分明して来るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんその事情の第一番は、僕の孤独癖や独居癖やにもとづいて居り、全く先天的気質の問題だが、他にそれを余儀なくさせるところの、環境的な事情も大いにあったのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は少年時代に黒岩涙香やコナン・ドイルの探偵小説を愛読し、やや長じて後は、主としてポオとドストイェフスキイを愛読したが、つまり僕の遺伝的な天性気質が、こうした作家たちの変質性に類似を見付けた為なのだろう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独癖ということは、一般的には東洋人の気質であるかも知れないのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは騎士気質から出たものとして、武士道から出た「意気地」と差別しがたい類似をもっている｛１０｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『武道伝来記』に列挙された仇討物語のどれを見ても、マテリアリストの眼から見た武士｜気質の不合理と矛盾の忌憚なき描写と見られないものはない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは永年お民さんをかわいがって御いでですから、お民さんの気質は解って居りましょう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助、暗然と涙声で、Ｔ「仲蔵は、　我子とは思わぬ」　と云って、Ｔ「雪枝　そなたもあれを、　兄とは考えるでないぞ」　と云われて、雪枝が涙ぐんで承知して見せると、　老人も泌々、Ｔ「わしは、あれの　素晴らしい評判を、　聞くだけで、　もう満足……」　武家気質の老人が淋しい満足です。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しあわせなことに汽車がブルガリア領に入れば商人は伊太利人の武士気質に禍いされなくて思うままに我意を通すことができるのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの作者は、その戯作者気質と、幇間気質を曝露している。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、広く行き渡ったにもかゝわらず、いまだ文学的批判の対象として取り上げられなかったらしいのは、従来の文学批評家の文人気質によるというよりは、愛国的熱情があまって真実を追求しようとする意力の欠如が、文学としての価値を低めているがためだろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、会えばいつも以前のままの学友気質で、無遠慮な口をきき合うのです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "気質も京人のようにはなし。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方には最愛の姫様があって、容貌も気質もすぐれて美しいお方であったが、その美しい姫様は明けて十七という今年の春、疱瘡神に呪われて菩提所の石の下へ送られてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長も、士官も、武士｜気質を持っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことも、気質の明るい彼には心の鬱したこの頃でも割合平気なのであった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ぎしりと床にきしつた自分の靴音を感じると、足はそのまますくんでしまつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、」とばかりで、お妙は俯向いて、瞬きしつつ、流眄をするのであった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々の道連れたる青年は、まばたきしつつこちらを見る。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
