        "examples": {
          "standard": [
            {
              "text": "融資の相談に行ったが、窓口の担当者に木で鼻をくくったような態度で断られてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "忙しいのはわかるが、あんな木で鼻をくくるような返事をされると、こちらまで気分が悪くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女に勇気を出して告白したものの、木で鼻をくくったような一言で一蹴されてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君、そんな木で鼻をくくるような言い方をしては、取引先の心象を悪くするぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――管理所を尋ねて、早速起し直すように頼みましたが、木で鼻をくくると言うのはその時の応対でした。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御返事は、これだけです」　と、木で鼻をくくるような挨拶だった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
