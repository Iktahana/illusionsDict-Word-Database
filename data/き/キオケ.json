        "examples": {
          "standard": [
            {
              "text": "昔ながらの製法で作られた味噌は、大きな木桶で熟成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銭湯には、檜の香りがする木桶が置いてあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人が丁寧に作った木桶は、とても長持ちする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本酒造りには欠かせない木桶の文化を守りたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は其一ヶの木桶の外に何物をも有する勿りき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が五尺の痩躯は陋なき木桶の中にあり乍ら、然も彼の心は飄悠として宇宙に高遊せり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "水溜めの木桶にも、使い残りの水がごくわずかしか残っていなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物は石油缶が一、二本、太い荒縄が数十メートル、浅底の木桶が数個、コルクがバケツに数杯。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは世の亂るゝ瑞相とか聞きおけるもしるく、日を經つゝ世の中うき立ちて、人の心も治らず、民のうれへつひにむなしからざりければ、おなじ年の冬、猶この京に歸り給ひにき。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一三）小児、夜なきの呪術　小児、夜なきするときは、当人の臍の下へ「田」の字を書きおけばやむという。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ずいぶん波の音が聞えるでしょ」とそのときおけいが云った、「こんなふうに波の音が聞えるようになるともうすっかり秋で、夜が更けると寒くなるんですのよ」　栄三郎は眩しそうな顔つきで、おけいの着せかける羽折に袖をとおしながら、その波の音を聞いた。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこ、かしこの山にも急いで砦を築きおけやい」　数日にわたって、雪なお深い山村、渓谷、高地などを歩き巡りながら、秀吉は、杖にしていた竹のさきで、折々、要地を指しては、こう指図して歩いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
