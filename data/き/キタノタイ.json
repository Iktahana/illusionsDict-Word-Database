    "definitions": [
      {
        "index": 1,
        "gloss": "northern side house (to the rear of a main residence; often home to one's wife)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平安時代の寝殿造りでは、主人の住む中心的な建物に対し、北の対に北の方が住んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は北の対に住む妻を訪ねて、静かに夜を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「北の対の様子はどうだ？北の方は機嫌を損ねていないか。」と主は側近に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "文学作品の中では、北の対が女性たちの生活空間として描かれることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "北の対の下の目だたない所に立って案内を申し入れると音楽の声はやんでしまって、若い何人もの女の衣摺れらしい音が聞こえた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の対をばことに広く立てて、かりにも源氏が愛人と見て、将来のことまでも約束してある人たちのすべてをそこへ集めて住ませようという考えをもっていた源氏は、そこを幾つにも仕切って作らせた点で北の対は最もおもしろい建物になった。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、例の血痕が北の対（離れ座敷）の車宿（車を入れておく建物）にこぼれているのが分った。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の対と云えば、官邸に使われている女中達の宿である。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは北の対屋の東の庭であった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下仕えの女が顔を知っていて、北の対に使われている女の子だといって、撫子を受け取った。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
