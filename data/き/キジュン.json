[
  {
    "uuid": "af33a64f-9207-5359-8e41-9123d6dfcdca",
    "entry": "帰順",
    "reading": {
      "primary": "きじゅん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
