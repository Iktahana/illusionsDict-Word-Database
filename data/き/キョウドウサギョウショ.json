        "examples": {
          "standard": [
            {
              "text": "彼はリハビリテーションの後、地域の共同作業所で新たな仕事を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その共同作業所は、障がいのある人々に職業訓練を提供し、社会復帰を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域支援の取り組みを理解するために、私たちは地元の共同作業所を訪問した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ここでは、皆が自分のペースで、やりがいのある仕事をしているんだ。」と職員は説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "八代の共同作業所へ着いたのは五時過ぎだつた、そして意外にも樹明君が後を追うて来た、小郡から自転車で二時間半で飛んだのである。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
