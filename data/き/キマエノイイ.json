        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの人は気前のいい性格で、困っている人がいればすぐに手を差し伸べる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気前のいい叔父は、会うたびに私たちにお菓子を山ほど持たせてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの福引の景品は、地元の気前のいい商店街が提供してくれたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「仙台の面目」とでもいうようなものに、こだわりすぎて、それで初対面の挨拶が固苦しく、尊大にさえ見えるのであるが、こっちのほうから遠慮なく突込んで行くと、急にはにかんで、なかなか親切な、気前のいいとこを見せてくれる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何だかここいらに伯父の巣窟がありそうに思えたので、その印度人に握手する振りをして十円札を一枚握らせると、印度人は私の気前のいいのに驚いたらしい。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「あなたは詩人なんですから、気前のいいとこを発揮して、あなたの札をムッシュー・ヴォルデマールに譲って上げるべきだわ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか気前のいい妓や。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも隣り近所に気前のいい所を見せようとしていたのがやっと、今日実現された訳なのである。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持で気前のいい地主だろうか、それとも奉職ちゅうにたんまりと財産を拵えたような、親切気のある人間ではなかろうか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は東京の目白のある田舎道で夜の八時過ぎだった、急にフラフラとやって来て暗い草叢の中へ倒れた、その時は或る気前のいい車屋さんに助けられたものだった、その時の話は以前｜広津氏が何かへ書いたことがあるからそれは省略するとして、今一つは奈良公園での出来事だった。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらでも、だれにでも、己の身体を切り売りする――僕は気前のいい売笑婦だった。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ほんとに気前のいい娘だった」「ところが多四郎めに瞞された。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは気前のいい鳥だわ、わたしに赤い靴をくれたりして。",
              "citation": {
                "source": "杜松の樹",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人はたしかに気前のいい老紳士だ。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お前は気前のいい、鷹揚な女だからな。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはたしかに世界じゅうでいちばん幸福な、いちばん気前のいい大金持ちであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、まあ、なんて気前のいい旦那でしょう！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "持つべきものは、気前のいい兄貴さ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう、この気前のいいこと」　この発言に誰も反論しなかったが、こんなにウェイクフィールド叔母の気前がいいのは何か裏があるなと皆思った。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそろしく気前のいい女だな。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、管営、差撥、書記、牢番にいたるまでが、「いい新入りだ、気前のいいやつだ」　と、宋江にたいしては、みな愛相がよかった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきまえのいい子だけれど、それでもあの子が自分のうれしさや元気でわれしらず身じろぎする刹那も、なかなかの若武者ぶりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
