[
  {
    "uuid": "f2dfa73e-9098-5f4d-b2a1-e9648941e49c",
    "entry": "希望",
    "reading": {
      "primary": "きぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
