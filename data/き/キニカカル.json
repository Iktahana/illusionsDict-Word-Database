    "definitions": [
      {
        "index": 1,
        "gloss": "to weigh on one's mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、こんな事は云えた義理ではないんだが、僕の留守の者たちの事も気にかかる。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで家中の人が皆集って、それをどうしようかと相談しましたが、可哀相なような気持もするけれど、見ずに置くのも気にかかる、とにかく開いて見るがよいと、あれの父が言い出しまして、皆の居る中であけました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は母のことも気にかかるので、もうお昼だという時分に戸村の家を辞した。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大吉振り返る事もせずに、Ｔ「昨日の女の事　気にかかる」　と言い残して其の儘スーと去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな状態がいつまでもつづけばきっと病気にかかるだろう。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にかかるのは、師団長にどういう報告書を出すか、その事の方が大事であった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすれば先生と弟子とが同じ病気にかかる確率は、全く縁のない二人がそうなるより大きいかもしれない。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも気にかかるから仕方ない。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にかかるものは一つも御座いません。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "不孝の子であるように言われてみると甚どくそれが気にかかる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にかかるというには種々の意味が含んでいるので、世間｜体もあるし、教員という第一の資格も欠けているようだし、即ち何となく心に安んじないのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にかかるというには種々の意味が含んでいるので、世間体もあるし、教員という第一の資格も欠けているようだし、即ち何となく心に安んじないのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳氏はしきりに向うの異教徒席や異派席とプログラムとを比較しながらよほど気にかかる模様でした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申せば、庭先の柿の広葉が映るせいで、それで蒼白く見えるんだから、気にするな、とおっしゃるが、お身体も弱そうゆえに、老寄夫婦で一層のこと気にかかる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気にかかるか、それともキチガイになるか、自殺するかして……というような薄暗い予感に襲われ初めたのはこの頃からの事であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には天国よりも、地獄のほうが気にかかる。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはまだ、地獄の方角ばかりが、気にかかる。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何か気にかかる。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、かぜ一つひいてさえ気にかかる。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "似ていないか、似ていないか、気にかかる。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう帰ったと見える、やっぱり気にかかる物があると、浮ばれないと見える」「そうでございますとも」　二人は泣き声になって話しながら家に入った。",
              "citation": {
                "source": "餅を喫う",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても凶作地帯の事私気にかかるわ。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三年四月　　かるい背広をかるい背広を身につけて、今宵またゆく都川、恋か、ねたみか、吊橋の瓦斯の薄黄が気にかかる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それが何分にも気にかかるので、父は根よく探して歩いたが、どうしてもそれらしいものを見いだせないばかりか、よほど注意していたにもかかわらず、父はさらに第三の穴に転げ落ちたのである。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処に蔵ひしかと気にかかるかな。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来自分の鼻の恰好というものは存外に気にかかるものでありまして、一度鏡で見ておきますとどうかした時によく思い出すものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　新子に愛人があったかどうかは、前川にとって、かなり気にかかることだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女は用捨なく娘と阿難を一体にして毛綱で捲きにかかる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から又外へ出てヴァイトリンガ河岸への径を開きにかかる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの金時が鯉を抱いたように生捕りにして上覧に入れようと、かれは水中に身をかわして、かの魚を横抱きにかかると、敵も身を斜めにして跳ねのけた。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
