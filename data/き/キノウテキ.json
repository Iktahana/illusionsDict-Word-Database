[
  {
    "uuid": "d5c503b7-dacc-512a-9378-2ca790653f1a",
    "entry": "帰納的",
    "reading": {
      "primary": "きのうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
