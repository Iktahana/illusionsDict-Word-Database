    "definitions": [
      {
        "index": 1,
        "gloss": "to brace one's core (e.g. when carrying something heavy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが独自のウインドウ環境を持たないＴＯＷＮＳは新しい提案と気張るには、あまりに痩せていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気張るぞ」と今一人の船頭が言って、左の臂をつと伸べて、一度拳を開いて見せ、ついで示指を竪てて見せた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつかりしろ、しつかり……」　画家は強ひて自分を叱りつけてみるが、いつも駄目で、気張れば気張るほど自分の身体が小さくなるやうに思へた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "う――んと気張ると、お前の胃みたいにごぼごぼお臍が鳴るのや。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し奮発して気張る事さえ覚えれば、当っても外れても、今よりはまだ痛快に生きて行かれるのに、今日までついぞそこに心を用いる事をしなかったのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのために気張るのかというと、そこまでは考えないで、なんだか知らぬで気張って書こうという了簡が起こるのであります。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "改まっては、無意識に気張る。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やめろ、やめろ兵さん」と呼んでみたが、兵さんは決心したらしく、ウンと気張ると、膝の上まで持ち上げた。",
              "citation": {
                "source": "あまり者",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常生活のいろいろの出来事に勇ましく堪えるように鍛えられている者は、軍人となるのに特に気張る必要は少しもないのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうですか」と云って、純一が五円札を一枚出すのを見て、背後に立っていた瀬戸が、「馬鹿にきばるな」と冷かした。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
