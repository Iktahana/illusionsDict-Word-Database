          "literary": [
            {
              "text": "閣下のお手許に置いて置けば、日本銀行へ供託して置くより安全です、ハヽヽヽ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "閣下のお手許に置いて置けば、日本銀行へ供託して置くより安全です。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから或弁護士は供託金を費消していた。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には奈良博物館に供託してある以外の舞樂面がまだ相當に所藏されてあつた。",
              "citation": {
                "source": "奈良二題",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
