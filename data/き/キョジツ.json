[
  {
    "uuid": "3bdb090f-d08c-5b8e-ad7c-85882f276b59",
    "entry": "虚実",
    "reading": {
      "primary": "きょじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
