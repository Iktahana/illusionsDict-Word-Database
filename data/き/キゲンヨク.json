    "definitions": [
      {
        "index": 1,
        "gloss": "cheerfully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなら皆さん御機嫌よくも云った積りなれどやゝ夢心地なればたしかならず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その鬼どもは、いま機嫌よく醉つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に議論にもならないから、われわれ友人の間ではただ機嫌よく笑ってすむのである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの下宿屋で、室に備え付けの洗面鉢を過ってこわしたある日本人が、主婦に対して色々詫言を云うのを、主婦の方では極めて機嫌よく「いや何でもありません、ビッテ、シェーン」を繰返していた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手にからかって、梟に泣かれたんでは、全く気の毒でしたし、第一折角あんなに機嫌よく、私にはなしかけたものを、ひやかしてやめさせてしまふなんて、あんまり私も心持ちがよくありませんでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、返して来よう」と一郎さんが機嫌よく云いますとたえ子さんも、「それがいいわねえ」とはっきり申しました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不治の癌だと宣告されてから却って長い病床の母親は急に機嫌よくなった。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山脈の雪も光の中で機嫌よく空へ笑っています。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "機嫌よくお盃を受けろというのだ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの父も最初の晩に招かれまして、主人も満足、客も満足、みんながお目出たいを繰り返して、機嫌よく帰って来ました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして帰りには又どこかで落ち合って、何かしら機嫌よく語り合いながら帰って来るのであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その鬼どもは、いま機嫌よく酔つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥をかかせてやつたので怒つて居るといふ噂の若い儒者まで機嫌よく挨拶に来た。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットさえ、機嫌よく私たちに、なついてくれたら、このエルシノア王城の人心も治り、王も意を強うして外国との交渉に専心出来ますのに。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父、和田左衛門尉義盛さまは、その頃、上総国伊北庄に御滞在でございましたさうで、鎌倉に兵起るの風聞に接しとるものも取りあへず鎌倉に駈けつけてみたら、御子息お二人捕へられてゐるので仰天して、ただちに御ところへ参り、拝謁のほどを願ひいれましたところ、御機嫌よくお許しに相成りすぐに御対面なさいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薄暗がりに頷いたように見て取った、女房は何となく心が晴れて機嫌よく、「じゃ、そうしましょう／＼。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠井氏は、僕の郷里の先輩で、僕の死んだ兄とは大学で同級生だったらしく、その関係もあり、笠井氏と僕とは、単に作家と編輯者の附合い以上に親しくしていて、僕の雑誌でも笠井氏の原稿をもらうのは、もっぱら僕の係りで、また笠井氏も、僕の原稿依頼なら、割に機嫌よく聞いてくれたものでした。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てるも追々お嫁さんになれるとしごろになったのだから、ただ行儀見習いだけのつもりで、ひとつ立派なお屋敷に奉公してみる気はないか、と老母にすすめられ、親の言う事には素直なてるは、ほんとうに、毎日こうしてうちで遊んでいるよりは、と機嫌よく承知した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ご機嫌よくこうやってござらっしゃる処を見ると、間違えごともなかったの、何も、別条はなかっただね。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、かの女はその姿でいつの間にか三枚四十五錢の寫眞を取つて來て、なか／＼機嫌よく、「よう寫つただろ」と、自慢さうに義雄に見せた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」気のいい母は、かの女の思わく通り、割合機嫌よく、圭子の書籍代を、その内から出してくれながら、「ほんとうに、あの子は金喰い虫だね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吉田は、機嫌よくそんなことを話して聞かせたりした。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して僕はごく機嫌よく、この怨みは忘れないぞと言ってやった。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと通りの挨拶が済んで、老人は機嫌よく話し出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒のあいだに彼はうまく二人を扱ったので、冠蔵もしまいには機嫌よく笑い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつを縛って獄屋につなげ」　李は素直に引っ立てられて去ると、士真の顔色はまたやわらいで、今まで通りに機嫌よく笑いながら酒宴を終った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女たちは玉の杯で酒をすすめると、機嫌よく笑い興じながらかれは数｜斗の酒を飲んだ。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚さん、その後の具合は……」　重次郎は機嫌よく微笑んでいたが、その顔には、何処となく憔悴した影が流れていた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春のはやり風も無事に逃れた」と、母は機嫌よく笑っていた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同変ることもないか」　五郎三郎は機嫌よくみんなに挨拶して、腰から白扇を取り出してはらはらと使った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
