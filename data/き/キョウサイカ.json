          "literary": [
            {
              "text": "家事また顧みず内事複雑、この頃恐妻家の名を博す。",
              "citation": {
                "source": "吉川さんの声と眼",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は恐妻家、女天下というが、昔は「からすの昆布巻」（かかあまかれだ）「ずいぶん歩いたがまだよほど遠方なのかね」「なーに、台屋のお鉢だ」（じき底、すぐ底）　吉原の料理屋からとる飯櫃は上げ底になっていた。",
              "citation": {
                "source": "昔の言葉と悪口",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "家事また顧みず、内事複雑、この頃、恐妻家の名をはくす。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐妻家にあらずとも、へツついを買ふ女房を待つ男などは、われながらいゝ圖ではない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
