        "examples": {
          "standard": [
            {
              "text": "事故現場の周囲には黄色いテープで規制線が張られ、野次馬が遠巻きに眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここから先は規制線内ですので、立ち入らないでください！」と警官が叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "爆破予告のあったビル周辺には二重の規制線が敷かれ、物々しい雰囲気に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
