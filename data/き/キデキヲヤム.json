          "standard": [
            {
              "text": "「まだ結果も出ていないのに、そんなに一人で気で気を病んでいたら体が持たないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は些細な失敗をいつまでも引きずり、自分自身で気で気を病んで塞ぎ込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母親は、一人暮らしを始めた息子のことが心配でたまらず、毎日気で気を病んでいる様子だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "取り越し苦労だと分かっていても、どうしても気で気を病んでしまうのが彼の性分だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
