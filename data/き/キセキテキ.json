    },
    "definitions": [
      {
        "index": 1,
        "gloss": "miraculous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おっ、奇跡的に雨が止んだぞ。今のうちに荷物を積み込んじゃおう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "絶望的だと思われていた逆転劇が、終了間際の奇跡的なシュートで現実のものとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "崖から転落したにもかかわらず、彼は奇跡的な生還を遂げ、周囲を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "偶然立ち寄った古本屋で、長年探し続けていた絶版本を奇跡的に見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼があの怪事件を解決するのに用いたあの簡単な帰納的推理は、私以外には総監にさえも説明されたことがなかったので、あの事件がほとんど奇跡的なものと見られたり、デュパンの分析の才能が直覚の名声を得たりしたことはもとより驚くにあたらない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、例の品物がパリのすぐ付近のどんな茂みのなかででも、ある日曜日から次の日曜日までより長いあいだ、発見されないでいるなどということは、まるで奇跡的と見なすべきだ、ということを僕がくりかえしても、それは冷静な観察家には誰にでもまったくわかりきったことを言っているにすぎんのだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ当時の私は極端に勉強が出来なくて、国語の成績など五段階評価で一でしたから、教室でほめられるなどと言うことは奇跡的な事件でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻つてゐる火のやうな春が、これまでの季節に横たはつてゐたのであるが、男はじつと腰に両手を支へて、如何にも沈勇な歩調で、悠つくりと貞操な英雄のやうに通りすぎてきたことが奇跡的にも思はれた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラス全体は、まったく地上に取り残されていて、ただ青木だけが、杉本教授と同じ空間まで昇っていったような奇跡的な感銘を、雄吉たちに与えずにはいなかった。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、あの人にどんなに美しい性格があったとしても、サハラ砂漠のまん中にダイヤモンドが落ちていると同じで、奇跡的な幸運でそのそばを通りあわせた人にだけしか、それはわかりっこはなかったのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクは古いほど、よく走るもんだてえことを……」　車のお蔭で、僕は奇跡的に役所の門に着くことができた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し方向を転じて島の内へ来ると、長堀川の板屋橋に俗に住友の浜といって、市の今は中央であって、なおかつ昼間でも投身する者があるというくらい閑寂な場所が奇跡的に残っているのです。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一人で十一か国語を話し、しかもあんまりチップを期待しない奇跡的案内者組合。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "100429急追せられたるも、奇跡的幸運により、　暗号文は本日完全に獏鸚せり。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、安らかにすることによって、奇跡的に、病気がなおるよう、神に念じたのであります。",
              "citation": {
                "source": "雲と子守歌",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ゆえかというに信濃の人々は「竹内式部先生は、奇跡的に三宅島からのがれ出て、天龍河畔に隠せいして、みずから天龍道人と称して、晩年を平和に送った」と、今日も固く信じており、証拠もある点まで挙げているのであるから。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風宗匠は筆談以外には、話ができないということを、おれはすぐに忘れて……これではまるでひとりごとだ、あはははは」　そのお駕籠には、柳生藩のお茶師、百と何歳になるかわからない奇跡的な藩宝、一風宗匠がゆられているのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、こけ猿の壺の真偽鑑定役に、はるばる伊賀の柳生の庄から引っぱり出されてきた奇跡的老齢者、あのお茶師の一風宗匠、この二人をはじめ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、痩せたブスのフィッチ嬢を見ると、カーターが見るのと同じ奇跡的な美貌がちらと見え始める。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろから見ると、三日ほど前に、曲者に髪を切られたばかりの頭は、辛くも撫でつけた毛が、後ろへフラフラと乱れて、浅ましい限りですが、襟首の美しさ、肩のあたりの素直さ、すべて色調の高雅なのと、線の交錯の品の良さで、その女を反って美しく見せるのは、まことに奇跡的でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "保存状態は奇跡的で、明らかに石灰岩の作用によるもの。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇跡的に空襲を免れ、地震や津波の被害にも逢っていないという点においては、駅前から一キロ以上つづく商店街も同様で、戦前からの、明治や大正時代の建築が、さらに古いものだと蔵などの江戸時代からの建造物が今もなお形を留めている。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬学において彼は阿片チンキの硬膏を導入して奇跡的な治療をしたことで有名であった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇跡的に治癒させるものと、医学を通して治癒させるもの、である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これは磁力の奇跡的な力によってそのバルサムが移植され、他の人の血液で性質を保つことによる」と。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇跡的に、彼女はいくつかの打撲と擦過傷を受けただけで、たいした怪我はなかった。",
              "citation": {
                "source": "あるドライブ",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には詩のように思われる気取った平板な文体で書かれてる、ある無趣味な論説や無味な奇跡的物語――あるいは、母親が愚かにも彼女の手へ渡してくれる、日曜新聞の着色｜插絵付きの犯罪談など、そんなものを読むこともめったになかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "長老の奇跡的な力は、アリョーシャも絶対に信じて疑わなかった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして絶えずあなたを愛し、ひそかにあなたを導かれた神の奇跡的な力を、自己の上にはっきりと認められるのじゃ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇跡的な治療を行なった聖者もあったし、その伝記によれば、聖母の訪れを受けたような人々もあった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇跡的にもそれは、割に近く、足下の急斜面に茂る偃松さして舞い落ちる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて水浴で、高温、微温、冷温の前または後に、奇跡的医薬品が処方された。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
