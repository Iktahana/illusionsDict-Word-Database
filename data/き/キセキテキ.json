[
  {
    "uuid": "54efe4e8-ff4c-5acf-9203-902bc0d0a6cb",
    "entry": "奇跡的",
    "reading": {
      "primary": "きせきてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
