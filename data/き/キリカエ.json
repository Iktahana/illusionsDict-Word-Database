[
  {
    "uuid": "3acf7646-2544-5348-8d36-ddd8ccb41de6",
    "entry": "切り替え",
    "reading": {
      "primary": "きりかえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
