        "examples": {
          "standard": [
            {
              "text": "この寄生生物は、宿主の脳を操って自分に都合の良い行動をとらせるという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熱帯地方には、人間に重篤な疾患をもたらす恐ろしい寄生生物が潜んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "顕微鏡でのぞくと、水滴の中で蠢く未知の寄生生物の姿がはっきりと見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この概念は多くのばあい粗雑に取り扱われ個々の病気は人間を支配している寄生生物のように考える傾向が医師たちにあった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんどの寄生生物は独立していた（寄生していない）先祖が現存するにせよ化石として存在するにせよその足跡を明確に辿ることができる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
