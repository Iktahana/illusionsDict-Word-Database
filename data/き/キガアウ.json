    "definitions": [
      {
        "index": 1,
        "gloss": "to get along (with someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初めて会ったのに、まるで昔からの友人のように彼とは気が合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "趣味も考え方も似ていて、彼女とは本当に気が合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職場の人とは仕事仲間としてうまくやっているけれど、特別に気が合う人はいないな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの二人、すごく気が合うみたいだね」「うん、見てて気持ちいいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ何となしに気が合うて、死生を共にしようというだけでそこに生命知らずの連中が、黙って集まり合うたというだけで、そこに燃え熾っている火のような精神は文句にも云えず、筆にも書けない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ気が合うといっても何だか茫漠としたもので男ならその調子で一杯やろうというかも知れぬ。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も前に繰り返したように単に気が合うというのみでは到底真の友とはいえぬ、謂わば水面の低いローレベルのヴァルチューである。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから度々いってる通り互に気が合うというようなそんな低い程度の友ではなく直に天父の意志を了解するものが欲しいのだ。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊太郎は兄の容一郎とは気が合うというものか、彼から泊りがけに来ることもあり、容一郎が俊太郎の家へ泊りがけに行くこともあった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢来の叔父の方が好きだとか気が合うとか申しちゃよく出かけます。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、後には、しっくり気が合うようになった。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍曹どのと自分とは、前から、双生児のように、なんでも気が合うのですから、そういう場合に、二人の頭の中に、別々に出てくる幽霊が同じ姿をしていても、かくべつふしぎでないわけですなあ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴょんぴょんじいさんとは　気が合うみたいで、　ふたりとも　いじわるカワウソや　きつねめさんが　きらいなのだとか。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いにひどく気が合うのである。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "ねずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分と気が合うという意味では叔父よりもずっと縁が遠かった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はいろいろのことで、不思議にしっくりと気が合うのでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝介　よっぽど気が合うんだねえ、あの人と。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど乃公は忠公と一番気が合うんだ。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだからこの奥さんとは気が合うと思った。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うはあの大身代、こっちは店こそ持っていますが、いわば職人で、釣合わない事この上なしですが、妙に主人のとは気が合うものか、やれ来いそれ来いと言っちゃ、三日にあげず呼出されて、時々は世帯の方まで面倒を見て下さいます」　お夏は少し得意そうでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お民の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、だんだん気が合うにつれ、自分が生活の用意としてその学校にいることもかくさなかった。",
              "citation": {
                "source": "今朝の雪",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にいえば、おくめは、あまり長女と気が合う方でなかった。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君たちは気が合うのかい？",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼女はクリストフと気が合うようにできていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女はクリストフと気が合うに相違なかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が合うというものか知らん、偶然の会話が、二人を結んで行くようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんや、あて、よう知りまへんのやけど、牢屋のなかで、友達になった人がいやはりましてな、その人も、若松の方とかで、えろう気が合うたらしゅうて、娑婆に出たら、玉井はんにも、ぜひ紹介して、兄弟分になって貰うんや、いうてはりましたわ」「なんという方ですの？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宅さまの方は存じませんけれど」「似たり寄ったりですわ、宅だって」「それでこんな気が合うんでございましょうかね」「仕合せのことに、この人、少し足りないなんて思ったことは一遍もありませんけれど」「それが目っけものでございますよ」　と女房同志は忌憚なく見積りを交換している。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "範頼と彼とはよく気が合う。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『――お側用人の柳沢出羽守と、吉良上野介とは、そんなに、曰くのある仲かの』『気が合うというものだろう。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆娑羅な半面もよく気が合うし、わけて武将間の内輪さぐりにも、市井の雑訴を知るうえにも、得やすからざる人物、最良な顧問役と、彼は見ている。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物と舞台と、あんなにいきがあうんですもの――独特ねえ……何て独特なんでしょう！",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
