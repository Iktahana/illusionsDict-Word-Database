    "definitions": [
      {
        "index": 1,
        "gloss": "100% buckwheat soba",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
