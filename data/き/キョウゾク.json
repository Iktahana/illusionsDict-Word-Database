    },
    "definitions": [
      {
        "index": 1,
        "gloss": "violent robber",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村は、度重なる凶賊（きょうぞく）の襲撃に怯えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "盗賊団の中でも、特に残忍な凶賊（きょうぞく）たちは恐れられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、こんな静かな町に凶賊（きょうぞく）が現れるなんて！」と住民は驚愕した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "見ると、浪花表の凶賊と誇称されている八つ化け仙次も、江戸まえの捕物名人むっつり右門の目にかかってはまことにたわいもないので、その小手先に歴然たる大きなすきがあったものでしたから、右門のとっさに抜き取ったるは奥義の手裏剣！",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "指紋の結果は、離れの一閑張からは左手の指紋ばかりしかあらわれなかったに反し、母屋の金庫に残っていた指紋には左右両手のものがあったので、母屋を襲った凶賊は、右手のない男ではないことだけはわかったが、府庁の鑑識課に保存されている指紋のうちには、それと同一のものは見つからないのだった。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも義経が秀衡に頼ったことは、鎌倉に奥州討伐の良い口実を与えたもので、頼朝奏請してしばしば院庁下文を申し下し、秀衡は凶賊義経を扶持して反逆を起したものとして、これを征伐せんことを希望したが、朝廷では単に義経を搦め進ずべき旨を下知し給うのみで、奥州討伐のことはどうしてもお許しがない。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天孫降臨に先ち、天降り、大蛇を誅戮し、国土を修理し、航海の法を教え、医療の途をはじめし、素盞嗚尊とその子孫との功労の大なるは、云うまでも無く、凶賊東西に起って、国民の人文に大なる障礎を与えんとせし時に、年少の身を以て、東西を平定せし、日本武尊の功績も亦た、永世不朽なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天智天皇の御代に異国の凶賊の蜂起したことが「日本書紀」に見えている。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道々の配置も充分、庵を繞る備えは、二重三重の防ぎで、容易のことでは、凶賊黒旋風も近づけそうはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "心待ちに待って居る蕎麦も、容易にありつけそうになく、そうかと言って、予告した凶賊黒旋風もやって来そうはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "【第二回】一　池の端妙月庵を襲って、千両の祠堂金を奪い取った、凶賊｜黒旋風の手際は、平次の想像を飛び越えて、不可能を可能にしたように見えました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　十二月七日、凶賊黒旋風が、金沢町の質屋、淡路屋佐兵衛の襲撃を予告した日です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十七、八と言っても、小柄で萎びて、厄過に見えるような不景気な男で、商売はうまいかも知れませんが、凶賊黒旋風の前には、まことに頼りない存在です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "凶賊黒旋風の跳梁は、妙月庵から淡路屋と、銭形平次を相手に、益々積極的にノシかかって来るのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "波岡采女甲府勤番仰せつけられ、暮の雑用として、公儀から金子二千両を預かり、それを馬に乗せて、明日は早朝出発という前の晩を、凶賊黒旋風に狙われたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は凶賊バラバスの子と国王ヘロデの子とをあわせ呼ぶに少しも躊躇しなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　槍騎兵は凶賊カルトゥーシュが誠直だと言ってほめられたような満足の渋面をした。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう洞穴から凶賊ラスネールが現われて来る。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディオゲネスが凶賊カルトゥーシュに変じたとしたらそれにもふさわしいような、銅製の古い龕燈が一つ、暖炉の上に置いてあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはやはり昔プーライエやカルトゥーシュなどの凶賊が使っていた古典的な賢明な隠語であった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこうなっては、いかな凶賊も抵抗のしようがありません。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われこそはその自動車をつかまえて、凶賊逮捕の名誉をになわんものと、交番という交番の警官が、目をさらのようにし、手ぐすね引いて待ちかまえたことは申すまでもありません。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "手をやいていた希代の凶賊が、なんと思いがけなくつかまったことでしょう。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁をあげての、凶賊逮捕の喜びも、ぬか喜びに終わってしまいました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけの凶賊を、探偵がとらえようともしないで逃がしてやるのが、どんなひどい侮辱だか、きみには想像もできないくらいだよ。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜査課長さん、あらためて、凶賊二十面相を、ひきわたします。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの凶賊ももはや運のつきです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの十秒か二十秒のあいだでしたが、さすがの凶賊も、自分の成功によったようになって、ついピストルを持つ手もとがおるすになってしまいました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京全都を、いや日本全国をあれほどさわがした凶賊二十面相も、ついに悪運のつきるときがきたのです。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "凶賊と少年探偵のたたかいは、いよいよ、これからなのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの身には、宗門役人の眼、怖ろしい凶賊の眼、野心の眼が光っています」「じゃヨハン、私はいつまでもここに居てかまわないの」「石室の奥に居れば、山屋敷の役人でも、気のつく気づかいはありません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
