[
  {
    "uuid": "f5f91184-7191-5c19-b593-b53af3e5db92",
    "entry": "凶賊",
    "reading": {
      "primary": "きょうぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
