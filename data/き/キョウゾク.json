        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地域では、古くから伝わる郷俗（きょうぞく）を大切に守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭りの準備は、地域の人々が協力して、様々な郷俗（きょうぞく）に則って行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "都市部から来た私には、その村の独特な郷俗（きょうぞく）は少し奇妙に思えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "（登安陽城楼）異俗非郷俗、新年改故年。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
