[
  {
    "uuid": "99f8b59a-47e5-5446-9610-c5525ad76d9f",
    "entry": "休演",
    "reading": {
      "primary": "きゅうえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suspending performance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、貴女に休演されることは、この際何よりの打撃なんですからね。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで妾は、小屋の前へ廻って中を覗いてみたが、生憎一座は休演していることが分った。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の不意の訪問も、この佗しい休演中の座長の老人を反って悦ばせたらしい。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人の無断休演があって、七回も高座へ穴があいてしまった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "客もありがたいもので、あくる晩、席の表へ、「金馬急病につき休演」　と、張り紙を出したのを見て、「金馬、また釣りか」といったという。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、Ｒ劇團は毎日午前十一時から夜の九時ごろまで一日約三囘ずつ同じシバイやショウをくりかえして休演日というのは無く、そして全部の出し物を十日目十日目に變えて行かなければならぬため、いつでも、次ぎの出し物のケイコは、前の十日の最後の二三日の午前中と、シバイがはねた後で半徹夜でやる。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷町から木挽町へゆくと、山村座は休演ちゅうであった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、じっさいにも、暑いから客足がおちるので、よほどの条件でもないかぎり、休演するのが例であった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前が休演している劇場だから、道は広く、人通りも稀である。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新婚」三益休演、藤田房子代役、綺麗だし、三益よりサラッとしてゝよかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十六日（火曜）　トビゝのため、三本の狂言中二本休演。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三益病気休演、やめると定ったらすぐ休むでは仕方ない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺篤、声が出ない、ひどいので休演。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は「活動ロッパ」だけ休演しようかなどゝ弱気になって来る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「幡随院」をつとめ、「雛妓」をつとめて、「活動のロッパ」のみ休演、サトウロクローに僕の役、石田がサトウの役又代りにて相つとめ、僕は宿へ帰ったものである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今井氏も来診、杉寛なども来り、休むことをすゝめるので、夜の部休演と定めた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の酷暑も松竹座に出演し、九月は公園劇場だったので休演、川口・東氏の手で東海道を、徳川夢声と共に旅行し、ムザンなる目にあひ、十月は再び「笑の王国」金龍館公演に加はり、十・十一・十二月と大入りを続けて、打ち通した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十日（土曜）　今日第一回を休演、川口・東と鏑木とで日本劇場へ、マーカス・ショオを見に行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十五日（火曜）　座へ早目に出る、と、渡辺病気休演とある。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は山野一郎休演、しょうがないので今日は両方渡辺がやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三益愛子続けて休演、京都から手紙をよこし、十日には帰ると言って来た、よく意見してやらう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳山と三益の万才は徳山休演、ビクターの灰田が代って気の毒みたい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "能勢妙子、胃痙れんで休演、代役「出征」を花井、「弥次喜多」のお園を藤田にやらせる、二人ともよかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つ爆笑がほしい感じはするが先づ以て成功、はま子休演などこたへない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、今日の夕刊に休演お詫び広告を、コロムビアと共同で出してゐるが、これもよかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶴八」は、三益休演と定ってるので気が抜ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
