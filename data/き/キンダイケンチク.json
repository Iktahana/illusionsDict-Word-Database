        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もとより洋風もとりいれてない、近代建築でないのは知れてゐるが、待合といふものの發展しない時代ではあり、賢實な市民の住宅で、しかも京阪風をも取り入れた、江戸といふサツパリしたところもある良い家が多かつた。",
              "citation": {
                "source": "家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツがこれを建設した当時、土民の乞いによって残されたという旧衙門と天后宮とだけが、旧支那式建設であって、他は悉く近代建築である。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは」　四百ページもあるその本には、各種類の近代建築物がのっていた。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機の美しさ、すべての機械の美しさ、機能美の近代建築もまたそうである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その公衆便所は高千穂町全体のうちでどの建物よりも近代建築といってよいぐらい。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世紀的なクレムリンの不便な建物の中から、落成したらソヴェト政府が移るべき近代建築が着手されはじめていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ハソレヲ取リ壊シテ近代建築ニ作リ直し、ソコニ今度ハワレ／＼ノ隠居所ヲ作リタイ考デアルガ、ソレニハ今日マデ婆サンガ反対シテイタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
