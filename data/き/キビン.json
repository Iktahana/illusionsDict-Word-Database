        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "偖、機敏な男とは生活の処理のよくつく男といふことゝいつて差支へありません。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人はヴァニティの方に傾く即ち堕落する方は楽なのでこの男は長い間機敏を続けてゐました。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今は魂のことの方が先になつたのだから、以前の機敏は右にか左にかともかく変化をうけた筈です。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして流行歌曲の作家が、機敏にこの大衆の向ふ所を捉へたのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現はお坊つちやんじみてゐても、その機敏でよく氣のつくことは人一倍です。",
              "citation": {
                "source": "ふつくりとした人柄",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百人が僅かかい……」　こいつほど、人の懐中を見抜くことに機敏な奴はなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリよりも機敏だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "制帽の庇の下にものすごく潜める眼光は、機敏と、鋭利と厳酷とを混じたる、異様の光に輝けり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時予の後にあって※網を何時か手にしていた少年は機敏に突とその魚を撈った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていったいとんびは大へん機敏なやつで勿論その染屋だって全くのそろばん勘定からはじめましたにちがひありません。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌自身の家は下町の洋服業組合の副頭取をしていて、家中が事務所のように開放され、忙しく機敏な人たちが、次々と来て笑い声や冗談を絶さなかった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叫んだのは、懷かしや、櫻木海軍大佐の聲、同時に、今一人乘組んで居つた馴染の顏の水兵が、機敏に碇綱を投げると、それが巧く鐵檻車の一端に止つたので、『それツ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて機敏に、極めて愼重なれ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪野は小さい時分から、米の大問屋へ奉公にやられ、機敏に立ち働き、主人の信用を得ていたが、主人が亡くなり妻の代になってから、店を一手に切りまわしていたところから、今までの信用を逆に利用し、盛んに空取引の手を拡めて、幾年かの間に大きな穴をあけ、さしも大身代の主家を破産の悲運に陥れたものであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして耳をそば立て、起き上り、緊張した目付をして、用心深く、機敏に襲撃の姿勢をとつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老父のそこまでの話の持って来方には、衰えてはいるようでも、下町の旧舗の商人の駆け引きに慣れた婉曲な粘りと、相手の気の弱い部分につけ込む機敏さがしたたかに感じられた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌自身の家は下町の洋服業組合の副｜頭取をしてゐて、家中が事務所のやうに開放され、忙しく機敏な人たちが、次々と来て笑ひ声や冗談を絶さなかつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "グスタフソンは相變らずすべての點に機敏で拔目がなかつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、自分に紹介を求めるのは、英吉に反対した廉もあり、主税は面当をされるように擽たく思ったばかりか、少からず敵の機敏に、不意打を食ったのである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前にどんな非常な事が起つても、健康な時と同じやうな機敏と勇氣とを以てそれに處するだけの準備があつた。",
              "citation": {
                "source": "病室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に機敏なる新聞も、唯敍上の事實と、及び彼等被檢擧者の平生に就いて多少の報道を爲す外に爲方が無かつた。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "無口で鈍重な逸作が、対社会的な画作に傑出して居るのは、その部分が機敏に働く職能の現れだからである。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてある時は画業に対しある時はかの女に対してその逸作の非常に精鋭な部分が機敏に働いているのである。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の妄想までを傍で逸作の機敏な部分が、咀嚼していて呉れる。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他それに似たような機敏な振舞いをして小金を溜めた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女たちも、実に機敏で手馴れたものである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "商才に長けてなかなか機敏な人であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは二ひきともきびんだからだいじょうぶだよ。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の上にはみかんの皮やビールのあきびんなどが浮いたり沈んだりして音楽に調子を合わせていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供らはよくこれらの小さな虫をつかまえて白粉のあきびんへ入れたりした。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
