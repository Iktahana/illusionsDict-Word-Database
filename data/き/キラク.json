[
  {
    "uuid": "c2404856-e2da-555b-a342-5b5fe157e1a1",
    "entry": "気楽",
    "reading": {
      "primary": "きらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "carefree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車が浅草の雑沓のなかにまぎれこみ、私たちもただの人の気楽さをようやく感じて来たころ、馬場はまじめに呟いた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした環境に育った僕は、家で来客と話すよりも、こっちから先方へ訪ねて行き、出先で話すことを気楽にして居る。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵隊も呑気でいいなあ」と竹村君が云うと「あなた方も気楽でしょう」といってにやにやした。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の席の人々が何となく緊張しているに反して中央の席の人々は、まるで別の国の人のように気楽そうに見えた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、非常な天災などの場合にそんな気楽な胸算用などをやる余裕があるものではないといわれるかもしれない。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵があんまりのんきで、その描き方があんまり気楽なので、思わず二人で笑ってしまった事があるが、同じ油絵をかくのでも、人によってこんなにもちがうものかと思った。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に恐ろしく綿密で面倒臭そうで、描いている人は存外気楽で、面白くてたまらぬような絵があるとすれば、それは横井弘三氏のである。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルノアルなどは、ちょっと見ると気楽に描いているようだが、また恐ろしく神経を使っているようにも思われるのだが、横井氏のはそれともちがう。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なんだかひどく気楽な心持になつて、或る柱の背後へ歩み寄つた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと云って、もう少し気楽なところでは、卓布や食器がひどく薄汚かったり、妙に騒々しかったり、それよりも第一料理が重苦しくて、自分の胃には拠なく負担が過ぎるのである。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気楽なたちの人はそのうちで自分に都合のいい気持のいいのだけを自由に振動させ、都合のわるいのはそっとダンプしておく。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不幸なことには、気楽に他人と世間話など、どうしてもできないたちなので、もし今から、この老爺に何かと話を仕掛けられたら、どうしようと恐ろしく、いよいよこれは、とんでもないことになったと、少しも早くここを逃げ出したくなって来た。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "作文のお時間にも、私は気楽に書いて、普通のお点をもらっていました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には野暮な、書生流の着物が、何だか気楽である。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏神様の御蔭なりゃあこそこげに気楽な一生が送れますので、福の神様が舞込んで来かかりますと、どうぞ他所様へ他所様へとお断り申上げますような事で、貧乏神から兄貴とも親分とも頼まれる心安さ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "他所様のお余りで明日の生命に事を欠かぬ気楽さ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "六平太先生のお能を見ていると花園の中を行くような……又は名画の連続を見るような有難い……トテモ気楽な気持になる。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ今は気楽である。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ気楽だ、自由だ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年の十二月末つ方、年は迫れども童はいつも気楽なる風の子、十三歳を頭に、九ツまでくらいが七八人、砂山の麓に集まりて何事をか評議まちまち、立てるもあり、砂に肱を埋めて頬杖つけるもあり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそから毎晩のようにこの置座に集まり来る者二、三人はあり、その一人は八幡宮神主の忰一人は吉次とて油の小売り小まめにかせぎ親もなく女房もない気楽者その他にもちょいちょい顔を出す者あれどまずこの二人を常連と見て可なるべし。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヘイ、親もなければ妻子もない、気楽な孤独者でございます、ヘッヘヘヘヘヘ」「イヤ気楽でもあるまい、日に焼け雨に打たれ、住むところも定まらず国々を流れゆくなぞはあまり気楽でもなかろうじゃアないか。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "月々郷里から学資を貰って金の心配もなし、この上気楽な境遇はなかった筈であるが、若い心には気楽無事だけでは物足りなかった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしたちのなかにいるほうがきらくだよ。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで、しづかで、きらくで。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば沖つ浪きらく気ままに遊ぶやうに。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の場合は、ふわふわと宙に浮いていて、いかにもきらくそうに見えたが、あれはもちろんトリック撮影である。",
              "citation": {
                "source": "高度八十マイル",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿に向ってカメラマンはすでにカメラを向けている）記者　どうか、きらくにお話し下さい。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様は涙をこぼして「ああ　ああ　もうじきらくになるけんの」といって背中をさすった。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
