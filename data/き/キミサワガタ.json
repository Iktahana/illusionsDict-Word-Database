        "examples": {
          "standard": [
            {
              "text": "幕末に建造された君沢形の船は、日本の造船技術の進歩を物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "文献によると、君沢形は従来の和船とは一線を画す洋式の帆船だったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "港には、当時としては最先端の君沢形が何隻も停泊していたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "展示されている君沢形の精密な模型に、当時の面影を見ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
