[
  {
    "uuid": "1c5e9676-af4c-50d4-b7c2-5659030b89f3",
    "entry": "気息奄々",
    "reading": {
      "primary": "きそくえんえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "形容詞-たる",
