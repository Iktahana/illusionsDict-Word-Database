        "examples": {
          "standard": [
            {
              "text": "「返事が来ないからって、そんなに肝を煎るなよ。そのうち連絡があるさ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締め切りが迫っているのに一向に筆が進まず、一人で肝を煎っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ああ、もう！ 準備が全然間に合わない！」彼女はパニックで肝を煎っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部下のミスをどうカバーすべきか、上司は胃を痛めながら肝を煎っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
