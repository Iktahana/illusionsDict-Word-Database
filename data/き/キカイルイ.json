[
  {
    "uuid": "6e92a3b7-ec89-53ef-8632-ce9f8d2eef68",
    "entry": "機械類",
    "reading": {
      "primary": "きかいるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
