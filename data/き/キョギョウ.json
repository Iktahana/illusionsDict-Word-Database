        "examples": {
          "standard": [
            {
              "text": "情報も技術もないまま新規事業に参入するのは、まさに虚業と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は一攫千金を狙って、常に儲け話という名の虚業に手を出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの怪しい投資話、絶対虚業だよ。関わらない方がいい。」とベテラン投資家が忠告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結果的に大損をしたが、当時はそれが虚業だと気づかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "おのれのみが志を遂げんために利を逐うて狂奔する虚業家、或いは政治家、おのれの心のみを倦まざらしめんためにホテルへ踊りに行く貴族富豪、それらを見て父の心には勃然として怒りの情が動きはしまいか。",
              "citation": {
                "source": "蝸牛の角",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
