        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、新しい職場でも周りの人々に対して非常に協力的でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この調査は、対象者の皆さんの協力的な姿勢があってこそ成り立ちました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが協力的であれば、家庭での家事分担もスムーズに進むでしょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと協力的な態度で接してくれると嬉しいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "＊この原稿を盗み見て以来、我が家のゴリラはビデオの予約録画に関してさっぱり非協力的となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三期　各新聞社は確実な営利事業である経済的利益を守るために、第一期の活溌な民主化への協力的態度をすてて意識的に保守勢力に追随し後退した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性が人格者として社会的権能を所有する事は、よりよい叡智に依って、異性との協力的結果の価値を高める為でございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んな騒ぎだったか、そして又、協力的に、実は競争的に手を着けて、いま完全に警察に鼻を明かされた憲兵隊や軍部が、如何に口惜しがったか、想像が付こう。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七五年の夏が終わり、カムラットがパートナーの非協力的な態度に頭を抱えていた時期、当のウォズニアックの関心はマイクロコンピューターを使った新しいシステムの側にすっかり移ってしまっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★本書の主要な登場人物である浜田俊三氏は、とりわけ取材を始めた当初においてはきわめて非協力的だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主的文学の分野には、昨年末から批評と創作の協力的前進の問題が起っており、勤労者の文学サークルの間にはリアリズムのみなおしの問題も起っている。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評と創作の協力的向上の問題についての評論「両輪」を新日本文学〔三〕月号に書いた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本は協力的産物である。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学生のころは浅草がひどかったが、震災後、親分連が自粛して、浅草の浄化運動というようなものを自発的に、又、警察と協力的にやりだしたので、私が東京の盛り場をノンダクレてまわる頃には、浅草は安全な飲み場の一つであった。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような子どもたちのしつけの苦しみや、教育のことについての悩みを、先生方に相談したり、学校全体で話しあったり、研究したりすることはないかとたずねると、Ｋ子はさびしく学校のなかの先生方の孤立していて協力的でないことなどを語ったのだった。",
              "citation": {
                "source": "石をしょわずに",
                "author": "――わかい女教師の自殺",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠者はついに集って協力的修行に移った。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ては友人の協力的好意の賜物であった。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "民藝品は個人の所産ではなく、多くの人の協力的所産だということに大きな意義があるのです。",
              "citation": {
                "source": "民藝の性質",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし貴方は非協力的ですねえ、ハンプトン大佐」精神病医は文句を言った。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん、とても協力的だし、申し分ありません。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田家の方からは、井口兵助、大野九郎左衛門の二名が、附添って来たが、なお竹中家からも家臣伊東半右衛門を侍け、協力的にこの一子を珠の如く磨いていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥九郎は自分の役儀上、この近村から軍糧の徴発に当っていたが、とかく庄屋や百姓たちのあいだに、不正や非協力的言動が絶えないので、堀尾茂助に行ってもらって、庄屋どもを大いに叱ってもらうつもりで――と、実状を説明した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
