        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅先の駅で、十数年も会っていなかった旧友と期せずして再会した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、期せずして意見が一致したね。それなら話が早い。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "趣味で始めたSNSの投稿が、期せずして海外で大きな反響を呼ぶことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "停電のおかげで、家族全員がリビングに集まり、期せずして団らんの時間が持てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "期せずしてみんなが空を振り仰ぐ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりに浸々と押し寄せて来る、知識的な空気に対して、この点では両親は期せずして一致して社会への競争的なものは持っていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事をうかうか考えている自分を発見すると同時にまた、現在この眼前の食堂の中に期せずして笑い上戸おこり上戸泣き上戸｜三幅対そろった会合があったのだという滑稽なる事実に気がついたのであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかる時に期せずして、朝の人は日の出を望むであろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し、期せずして、一つ宙返りをして車夫の頭を乘越したのである。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ半を口に啣へて、うつむいて見せた圖は、永洗の口繪の艷冶の態を眞似て、大に非なるものであつたが、これは期せずして年方の插繪の清楚であつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田さんは、旅籠のあんまに、加賀の金澤では天狗の話を聞くし、奧州飯野川の町で呼んだのは、期せずして、同氏が研究さるゝ、おかみん、いたこの亭主であつた。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ無理に留めないけれども……」　このとき両箇の眼は期せずして合えり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才は何物にも束縛されず、自由に大膽に彼の情緒を歌ひ、しかもそれが期せずして美しき音樂の調律となるであらう。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ただいま期せずして座の一隅より、切望懇願のうめき声が発せられたようでもあり、まあ致しかた無い、御伝授しましょう。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "期せずして三人同時に、おのずから溜息が出た。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち期せずして來るところのものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢い可い加減にでも返事をすれば、すなわち期せずして遊蕩の顧問になる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の空気は期せずして和やかになり、私たち三人、なんだか互に親しさを感じ合った。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "期せずして同じ樣な笑聲が皆の口から出た。",
              "citation": {
                "source": "女郎買の歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "富豪自身は期せずして良民の呼吸の為めにふんだんな酸素を分配して居るのである。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、そうだ、この船での第二夜、一等の食堂で、期せずして私たちの間に童謡音楽会が開かれた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――――――　城代も両奉行もいちを「変な小娘だ」と感じて、その感じには物でも憑いているのではないかという迷信さえ加わったので、孝女に対する同情は薄かったが、当時の行政司法の、元始的な機関が自然に活動して、いちの願意は期せずして貫徹した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて我々は期せずして第二の経験――宗教的欲求の時代に移った。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "期せずして真面目な、堅苦しい会合となった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひたすらに相手の行衛を心探しにしていた銀之丞、千六の二人は期せずして祇園の茶屋で顔を合わせた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば藩内の不平士族が一時に武器を執って集まって来ましょう」　席上諸先輩の注視が期せずして奈良原少年に集まった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "期せずして二人とも一直線に山を登り始めたが、その山が又、案外｜嶮岨な絶壁だらけの山で、道なぞは無論無い。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶喜といひ、西郷といひ、わが国体といふ点にいたつて、その両極端の立場にも拘はらず、期せずして一致したわけである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚朋友がその不思議を聞き伝えて、祭祀の時のような服装をしてきたが、期せずして二三百人の者があつまった。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し期せずして其人に逢はゞ、我友の怒を霽す便にもならんとおもひき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "血書　われは眠ることを期せずして、身を藁蓆の上に僵しゝに、前の日よりの恐ろしき經歴は魘夢の如く我心を劫し來りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼夫人の期せずして我等と物言ひしは、或は他日我等に利あらんも知るべからず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や少女は期せずして我前に來り、我に眼を開かんことを請へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日となりて又期せずしてハツバス・ダアダアの侯爵家を訪ふに會ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
