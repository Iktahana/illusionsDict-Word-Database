[
  {
    "uuid": "91e673cc-7f33-5ef8-8ee8-0c785c08655b",
    "entry": "嫌いがある",
    "reading": {
      "primary": "きらいがある",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
