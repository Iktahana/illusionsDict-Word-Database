        "index": 1,
        "gloss": "Gui Qu Lai Ci (Come Away Home, classic Chinese poem by Tao Yuanming, 405 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
