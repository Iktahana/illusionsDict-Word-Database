    "definitions": [
      {
        "index": 1,
        "gloss": "collaborator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シンクレア夫人は気前よく二部屋を自由に使わせてくれているし、僕の友人かつ協力者とくれば絶対に歓迎してくれるから、安心していい。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "現れ始めた協力者から、何度か同じような質問を受けて、「作業方針に関して決められることは決めて、マニュアルにしておくしかない」と感じ始めていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうときには絶対に協力者が必要だ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "協力者として水戸を誘ってよかったのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッドパージで全国の学生がたたかっていた十月　一万九百人の戦争協力者が解除された。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は果して協力者を求めることが出來るか？",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "協力者を求めはじめたのだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるひは協力者たり得たかも知れなかつた者も、ある事情から、その頃は急速度にわしに背を向けて離れて行つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんのこと、通りにいた人は皆、協力者だ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというと、労働において女は男の協力者であり、又家庭生活の中でも第一、小学校から男と女のする仕事が別れるということはない。",
              "citation": {
                "source": "ソヴェトに於ける「恋愛の自由」に就て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の文化の特性というものが、強調され、農村の文化を創るものは農民である、という農本主義的の考え方は、現代においては農民自身の幸福のために、欠くべからざる協力者である都会の労働者と、進歩的な知識階級人とを文化的にはもっともおくれた農民から切り離すための役割しか演じていない。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いっさいの社会的諸制度※　そして両極たる征服階級と被征服階級との中間にある諸階級の人々は、原始時代のかの知識者と同じく、あるいは意識的にあるいは無意識的に、これらの組識的暴力と瞞着との協力者となり補助者となっている。",
              "citation": {
                "source": "征服の事実",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "年とったひとのためには、ただ若い華やぎとうつる青春の生活の基礎に健全なこういう種類の友だち、仲間、協力者としての異性の関係が成長していることを周囲にわからせようとしている。",
              "citation": {
                "source": "明日をつくる力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の中には釈放された有力な戦争協力者たちが暗躍していて、この一年間に人民に対する抑圧とアジアの解放を妨げる仕事がある時はこっそりと、ある時は公然と法律をふりかざして行われてきています。",
              "citation": {
                "source": "新しいアジアのために",
                "author": "――アジア婦人大会によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、大局ではマイナスの作用をしつつ、目前ともかくプラスである協力者をもたず、或は良人と自身との画境をはっきり弁えて自力の成熟をしようと心がけている若い少数の婦人画家たちは、現在の常識ではどっちを向いても損であり苦しいということになる。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人参政権の活動家たちは、精神総動員を初めあらゆる戦時総動員に狩り出されて、戦債の買込遊説だの、貯金の勧誘だの、全く軍事協力者として動員されてしまったのであった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろくほど戦争協力者がまぎれ込んでいる。",
              "citation": {
                "source": "春遠し",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナップは文化活動の分野において、出来るだけ広く、多くの同志、協力者を包括する意図です。",
              "citation": {
                "source": "文戦脱退はなぜすぐナップに加入出来るのか？",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時中日本の作家の大部分は侵略戦争の協力者であったし、民主的な作家は強圧されていた生活からぬけたばかりで、いわゆる「浄らかな手」で書かれた新しい歴史の展開にふさわしい文学作品が求めにくかった。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは、一九四六年中は戦争に対する協力者としての活動の経験から執筆をひかえていたどっさりの作家が、公然と活動をはじめたことです。",
              "citation": {
                "source": "一九四七・八年の文壇",
                "author": "――文学における昨年と今年――",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川達三、林房雄氏その他の戦争協力者が民主化の低迷に乗じての活動は本年中どう動くかということは、これこそ実に数百万の小説を読む人々が自分たちの運命についてどこまで自分の主人になりうるかという問題と関連しています。",
              "citation": {
                "source": "一九四七・八年の文壇",
                "author": "――文学における昨年と今年――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア作家が狭い「私」的環境に止められて、僅かな感情冒険だの偏奇の誇張などにエネルギーをついやしている時、少くとも現在民主的作家は、政治的活動の分野を解放されているし、経営内の文化活動に直接ふれることができるし、労働者・農民の闘いに観察者であるばかりでなく、協力者となり得ます。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての専門家は、単に、大衆の文化欲求の接待役として役立つばかりでなく、その新しい成長のための協力者であり、ある場合は表現者、形成者である必要があります。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというと、労働において女は男の協力者であり、また家庭生活の中でも第一小学校から男と女のする仕事が別れるということがない。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかして真面目に戦争をきらう人民から、そういう協力者をきりはなしたい。",
              "citation": {
                "source": "便乗の図絵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また篠原組親分の実質的協力者は塩野前司法大臣であったこともしられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時中戦争協力者であった清瀬一郎弁護士が日本側弁護人首席として登場したことに日本の民主的市民は驚いたのであった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公民館が協力者として連絡をもつべきものとされている三〇ばかりの文化事業団体のほとんどすべてが戦犯的な団体であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
