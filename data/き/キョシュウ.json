[
  {
    "uuid": "0f197be6-a294-54c2-92a4-e50600e8e937",
    "entry": "去就",
    "reading": {
      "primary": "きょしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
