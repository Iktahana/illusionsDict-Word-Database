[
  {
    "uuid": "1af026b6-e8f3-5a62-a616-341a3e5fb103",
    "entry": "吉祥天",
    "reading": {
      "primary": "きっしょうてん",
      "alternatives": [
        "きちじょうてん"
      ],
      "is_heteronym": false
    },
    "grammar": {
