      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Sri-mahadevi (consort of Vaishravana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "吉祥天は、その富と幸運の象徴として多くの信仰を集めてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寺院の壁画には、優美な姿の吉祥天が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい店の開店祝いに、吉祥天の縁起物を贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ、西の方遥に、山城国、浄瑠璃寺、吉祥天のお写真に似させ給う。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱の盤　吉祥天女、御功徳でござる。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉祥天女を恋人にしようと思うと、それでは仏法くさくなって困るということになるだろうからしかたがない」　中将がこう言ったので皆笑った。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吉祥天女を思ひがけんとすれば、怯気づきて、くすしからんこそ佗しかりぬべけれ。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは梵天、帝釈、弁天、吉祥天等。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋篠寺の伎芸天女や、薬師寺の吉祥天といつたやうな結構な美術品は幾度となく見は見たが、いつといふ事なし、それ丈では何だか物足りなくなつて、旅籠の夜の徒然に、ある時三味線を弾く妓を聘んでみた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓は薬師寺の吉祥天のやうに手の指を六本も持つてはゐなかつたが、それでも学者の心の臓を掴むには十分であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの人差指８・13サンデー毎日　大和薬師寺の境内から発見されて、国宝の一つとなつてゐる吉祥天女の絵像は、今では日本の美術史の上で、なくてはならない代表作となつてゐるが、あの天女の指は、不思議なことに右左とも六本づつある。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野博物館にある吉祥天女の像、出雲大社の奇稲田姫の像などの貌容に見ても知られる。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも頬がぼっと赭く、円顔で、吉祥天のような胸のふくらみ、瑞瑞しい新鮮な足首だ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、吉祥天女にしてもこんな糞はする筈がない。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さやうな男でございますから、吉祥天を描く時は、卑しい傀儡の顔を写しましたり、不動明王を描く時は、無頼の放免の姿を像りましたり、いろ／＼の勿体ない真似を致しましたが、それでも当人を詰りますと「良秀の描いた神仏が、その良秀に冥罰を当てられるとは、異な事を聞くものぢや」と空嘯いてゐるではございませんか。",
              "citation": {
                "source": "地獄変",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さやうな男でございますから、吉祥天を描く時は、卑しい傀儡の顏を寫しましたり、不動明王を描く時は、無頼の放免の姿を像りましたり、いろ／＼の勿體ない眞似を致しましたが、それでも當人を詰りますと「良秀の描いた神佛がその良秀に冥罰を當てられるとは、異な事を聞くものぢや」と空嘯いてゐるではございませんか。",
              "citation": {
                "source": "地獄變",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拙者、今夜は、いかなる幸運か――吉祥天女が天下ったような気がして、とんと、気もそぞろになり申すよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは吉祥天女像、第三は葛飾の輪廻寺の――」「まあ、後でゆっくり読んで、案を練るがいい。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二十分後に、貫一は琥珀寺の秘仏である吉祥天女像を、荒ごもに巻いて背中に背負い、寺を出た、その寺では、坊主たちが気がついて騒ぎだしたが、貫一がピストルをポケットから出すと一同は温和しくなり、貫一のいうことを聞いて一同は便所の中に本当の雪隠詰めとなった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫一はその後で、便所の戸を釘づけにし、そして悠々と吉祥天女像を荷造して背負って寺を立ち出たのであった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眉引」は眉墨を以て眉を画くことで、薬師寺所蔵の吉祥天女、或は正倉院御蔵の樹下美人などの眉の如き最も具体的な例である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "八木で電車を降りるとき、五尺五寸ぐらいもあって肉づき美しく、浄ルリ寺の吉祥天女そっくりの白いウリザネ顔のお嬢さんを見た。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば吉祥天女様のようで」「いやいやそうではありますまい」　いよいよ金兵衛は面白くなった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、揶揄的になろうとする、そういう心持ちを苦心しておさえて、ますます加工的に真面目顔をしたが、「吉祥天女様というような、仏くさいお方ではありますまい。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着ている衣裳は粗末ながらそれに何んの累もされず玲瓏と澄み切ったその容貌は、愛と威厳と美との女神、吉祥天女さながらである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　三月堂の壇上に置かれた諸像のうちでは、塑像の日光・月光菩薩像、吉祥天像などが彫刻として特にすぐれている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同時に吉祥天女が天女二十人をひきいて現われる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにこの像は正倉院の樹下美人図や薬師寺の吉祥天女画像などの方に近い。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天平末にできた吉祥天女の画像も同じような柔らかい姿勢で立っている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから何にしましょう、西大寺の十二天、さよう、一幅でいいとなるとまず水天ですかな、まあそうでしょうな、それから、薬師寺の吉祥天、さよう、あれも代表的のものですからな、それから信貴山縁起、ようがす、それから、それだけですか、なにおよろしければいくらでも出しますよ。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九西大寺の十二天――薬師寺吉祥天女――インドの吉祥天女――天平の吉祥天女――信貴山縁起　西大寺十二天のうちの水天は、初めて見たときの印象がよかったので、この日もかなり楽しみにしていたが、いよいよ壁にかけられてみると、剥落や補筆が目について静かに引き入れられて行く気持ちになれなかった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
