        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恭賀新年の郵便を送る先は、主に地方の親戚知人で、府下でもよほど辺鄙な不便な所に住んでいない限りは、郵便で回礼の義理を済ませるということはなかった。",
              "citation": {
                "source": "年賀郵便",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追日向暑、倍起居御安和可被成御座奉恭賀候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊家愈御安祥御迎被成候覧奉恭賀候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥御揃御安祥被成御坐候覧、奉恭賀候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恭賀新年庄司利喜太郎と心を協せ山々の書類を隠し、偽証、喜平を無実の罪に陥いれたる神戸氏の御健康をお祈りいたします。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは除夜で、〔｜Cafe' Atlantis〕 のなかに入り、真夜中に、恭賀新年の杯を高く挙げて、午前三時ごろ其処を出た。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一便毎に配達受けし、「恭賀新年」の葉書は、机上に溜りて数十百枚になりぬ。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春の節に御座候ところ、御渾家御｜揃い遊ばされ、ますます御機嫌よく渡らせられ、恭賀たてまつり候。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭賀新年の語を聞く毎に堪へざる寂寞を感じ候と云ふ書出しで、年の進み改まる毎に明治の生活は淺薄俗惡になつて行く。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ホトトギス』は漸次御発展の由これまた恭賀。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭賀新年という端書だけを出した。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は十二、三になる末の子に、同じく恭賀新年という曲りくねった字を書かして、その子の名前で健三に賀状の返しをした。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭賀新年とかいて、傍らに乍恐縮かの猫へも宜しく御伝声奉願上候とある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさえ近年はずっと減じて普通の恭賀新年になってしまった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは三本槍を、片ッ端から、登っては降りして、数日前に来たことのある御幣岳の一角と行き合った、嘉門次すら、この三本槍を縦走したのは、この年になるまで、きょうが始めてだと言っていた、岩石の連嶺は、ここで槍ヶ岳から、蒲田谷を包み、焼岳を回ぐって、びったりと素の位置で、繋ぎ合われた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸くあきらめがついて帰ってしまった　先生の許へ往くようになってからこんな事はきょうが始めてである十三日の午後から急に訪問を思い立って出掛けた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この町から一里ばかり離れたところの村に神様があって、きょうがちょうどお祭りの筈です。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして朝、眼が覚めて、わかれたのが現実の世界の出来事で、逢ったのが夢の世界の出来事、そうしてまた別れたのがやはり夢の世界の出来事、もうどっちでも同じことのような気持ちで、床の中でぼんやりしていたら、かねて、きょうが約束の締切日ということになっていた或る雑誌の原稿を取りに、若い編輯者がやって来た。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうが休みだと知っていたら、ゆうべだって、もっと楽しかったであろうに。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦の上では、きょうが立秋というのであるが、三日ほど降りつづいて晴れた後は、さらにカンカン天気が毎日つづいて、日向へ出たらば焦げてしまいそうな暑さである。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、頭山先生が、この新青年に、きょうが日まで顔を出さないのが間違っている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどきょうがおたん生日で、このとおりさかんなお祝をしているしだいでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋七が彼に逢うのはきょうが初めてであるが、これまでにも叔母の使で時々にここへ来たことがあるらしいとの事であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて廓の颶風がここへ舞い込んで来て、それからいろいろの渦を巻き起すことはありありと眼に見えているので、お時は毎朝の空を眺めて、きょうが其の破滅の悪日ではないかと、いつも怖ろしい予覚におびやかされていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし武家奉公というものは面倒なもので、親のかたきを探しに出るからといって、きょうが今日すぐに暇をくれるわけのものじゃあねえ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眇目の唐人――それを見るも聞くも小坂部はきょうが初めてであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて一つのスケッチができあがって、軽い満足のため息とともに、働かし続けていた手をとめて、片手にスケッチ帳を取り上げて目の前に据えた時、君は軽い疲労――軽いと言っても、君が船の中で働く時の半日分の労働の結果よりは軽くない――を感じながら、きょうが仕事のよい収穫であれかしと祈った。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちには天長節も何もあったもんじゃない」　そういわれてみると葉子はきょうが天長節なのを思い出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし日本に帰ってからこの家にお客様をお上げするのはきょうが始めてですのよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、きょうが外出日であるのを幸いにお見舞いします。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
