    "definitions": [
      {
        "index": 1,
        "gloss": "fresh in one's mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
