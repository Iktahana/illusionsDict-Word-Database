        "examples": {
          "standard": [
            {
              "text": "レントゲン写真で確認したところ、股関節の臼蓋の形状にわずかな異常が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は模型を使いながら、股関節の臼蓋と大腿骨頭の関係について詳しく説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "臼蓋の軟骨がすり減ってくると、歩くたびに股関節に痛みが走ることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが水疱瘡を治すには、おきゅうがいいということであったのだが、現人神たる玉体におきゅうをすえるということは許されないという異議が出たために、ついに譲位をなさって、おきゅうの治療を受けられた。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            }
          ]
        }
