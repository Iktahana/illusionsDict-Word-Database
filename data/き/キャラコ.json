        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大隊長とその附近にいた将校達は、丘の上に立ちながら、カーキ色の軍服を着け、同じ色の軍帽をかむった兵士の一団と、垢に黒くなった百姓服を着け、縁のない頭巾をかむった男や、薄いキャラコの平常着を纏った女や、短衣をつけた子供、無帽の老人の群れが、村に蠢き、右往左往しているのを眺めていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾斜面に倒れた縁なし帽や、ジャケツのあとから、また、ほかの汚れた短衣やキャラコの室内服の女や子供達が煙の下からつづいて息せき現れてきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼は、煙の中を逃げ出して来る短衣やキャラコも、子供や親があることを考えた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有平糖の洋傘もいまは普通の赤と白とのキャラコです。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとで陽がまたふっと消え、風が吹き、キャラコの洋傘はさびしくゆれます。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンツも純白のキャラコである。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "服は廉物の白に花模様のキャラコの更紗で、何れも韃靼風のものかと思われた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして下に掛けられたキャラコの白い布を引っ張って、生え際の所までかけた。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、キャラコの布ごしに、すべてが淡紅色にはてなく見えた。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はついと立って、鞄の中から、キャラコのシャツとズボン下を出して、それを素肌へ着けて、その上から紺の兵児帯を締めた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルの單衣に涼しさうな生絹の兵子帶、紺キャラコの夏足袋から、細い柾目の下駄まで、去年の信吾とは大分違つてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売　帳簿を立て並べた長い台に向って、土間に、白キャラコの覆いのよごれた粗末な腰かけが三四脚おいてある。",
              "citation": {
                "source": "日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ私ここでただ喋くっているからね」　志野は、白キャラコの前かけを丸めてむこうに放ぽり出し、机の前に坐った。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏地にはキャラコを選んだが、これまた地質のよい丈夫なもので、ペトローヴィッチの言葉によれば、絹布よりも上等で、外見もずっと立派な、艶もいい品であった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹の着物の場合はキャラコをはきますが木綿が一番はき心地がよくて好きです。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉は白キャラコの被いのついた薄い坐蒲団の上に制服のまんまあぐらをかいた。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又端巾は言い合せたように細かい花や楽器を散らした舶来のキャラコばかりだった。",
              "citation": {
                "source": "点鬼簿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "○白キャラコのカーテン。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に土人の酋長への贈物や交易品としては、羅紗、キャラコ、真鍮の針金、首飾りの硝子玉など。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あなた、洋服だの、キャラコだの、砂糖だのといふものは、まだ殿様の先例がないから、殿様の手口にかゝる御仁のタネはつきないけれど、紙に限つて、これはもう、きかない手口ときまつてるんだがな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "月曜日せんたくをなさいましたが、しぼらずにのりをつけたり、もも色キャラコを青くしたり、おかしくてころげるほど笑いました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気はいいが、もう萎びてしまった彼らの女房たちは、ひだのついた帽子をかぶり、胴の長いガウンを着て、手製の下衣をつけ、鋏や、針さしやら、派手なキャラコの袋を外側にたらしていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が生れた土地の風習でも御座いませうが、絹の着物がほしいと思へば、蠶を飼ひ家庭で繭から絲にし、紡いで織りましたし、足袋にしても今の樣に眞白なキャラコなどはある筈も御座いません。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どちらにしても、お医者さんに診てもらうより他はないじゃないか」　翌日、とく子は配給のキャラコを取り出し、尺を計って、裁断している。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間までは黄八丈の綿入れに艶々とした糸織の羽織を着て、ちょいと出るにもキャラコの足袋に表附きの駒下駄を穿いて居たものが、まあ何と云う浅ましい変りようをしたのだろう。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャラコ」のキャラは、白檀、沈香、伽羅の、あのキャラではない。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラ子はキャラコ、金巾のキャラコのことである。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "剛子がキャラコの下着をきているのを従姉妹たちに発見され、それ以来、剛子はキャラ子さんと呼ばれるようになった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、社交室の満座のなかで、槇子がキャラコの由来を披露したので、みなが腹をかかえて笑い、思いつきのいいのに感服した。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
