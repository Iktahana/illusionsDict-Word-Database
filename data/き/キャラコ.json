    "definitions": [
      {
        "index": 1,
        "gloss": "calico (cloth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
