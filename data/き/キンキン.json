    "definitions": [
      {
        "index": 1,
        "gloss": "shrill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "柳の花がきんきんと光って飛んだ。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私は全体何をたずねてこんな気圏の上の方、きんきん痛む空気の中をあるいているのか。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして諒安はそらいっぱいにきんきん光って漂う琥珀の分子のようなものを見ました。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘はすっかり緑でほたるかずらの花が子供の青い瞳のよう、小岩井の野原には牧草や燕麦がきんきん光っておりました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは、きんきんした声でさけびながら、火ばしで、アヒルの子をぶとうとしました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はからっと晴れていて、百舌鳥の声がきんきん、ひびいていました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんもお母ちゃんも居たはる」　そして、きんきんした声で、「――わて、もう親なし子やあれへんなア。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄の一徳か、動作も敏捷で、声も必要以上にきんきんと高く、だから客たちは、ほう綺麗だなと思っても、うっかり冗談を言いかける隙がなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝はいきなり、きんきんした声をあげて、「〆さん、あんたアンドロメダ星座いうのん知ったはる？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮がちに低めていたが、それでもきんきんとよく通る声だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、きんきんした声で、「わて、もう親なし子やあれへんなア。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄の一徳か、動作も敏捷で、声も必要以上にきんきんと高く、だから客たちは冗談を言いかける隙がなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝はきんきんと、「〆さん、あんたアンドロメダ星座いうのん知ったはる？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、きんきんした顔で、「ああ、びっくりした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありもしないことを泣き訴訟すると承知しないよ」　きんきんとかん高にがなりながら、三つ輪のお絹が横からのさばり出て折檻しようとしたのを、「うるせえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いピアノがきんきん鳴り始めると、子供達は一斉に「われらはすこやかに、いざ育とう」という歌を、屋根でも飛んでしまいそうな元気な勢で張り上げた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "日輪草そらへのぼつてゆけ、心のひまはり草よ、きんきんと鈴をふりならす階段をのぼつて、おほぞらの、あをいあをいなかへはひつてゆけ、わたしの命は、そこに芽をふくだらう。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩野の叔父は意志の強そうな、やや金窪眼の老人とはいえ、声には張りが籠ってきんきんとよく響き、何より実行力の溢れたその確実そうな風貌には、世の荒波を押し渡って来てなお衰えぬ厚みがあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの奇妙な塔上に閉じこめられることはまぬがれることができるのだが、しかし、きんきん一時間ぐらいの間に鉄筋コンクリートの階段が移動したとはなんと不思議千万ではないか。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「左門先生らがおとしたのかもしれないさ」「いや、かいでみたまえ、たばこのにおいが、まだ新しくのこっている、きんきん一、二日前か、あるいは一、二時間前にここにおとしたものだ」　はたして、ゴルドンの推察があたっているとすれば、海蛇らの魔手はすでに、洞の目前にまで伸ばされているのだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや港までは、きんきん五十キロを出ない航程です」「ではこの島は、大洋中の孤島ではないのですか」「島の西方は大洋であるが、東南北は大洋ではありません。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして静かな夜となれば小い花子が面白いお伽噺を読む側で月はきんきん黄金の色虫はりんりん鈴の声。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと伺いますが」　と大寺警部のきんきん声がした。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナウンサー田村君の声が、いつになくきんきんとするどく響く。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この附近の風光を見てゐると、安来節のあのゆつくりとした、水と田舎とのまざり合つた調子が、やはり何となく感じられるのだ、　安来節も、東京あたりで耳にするのは一種浅草調ともいふべきものになつて、たゞきんきんするだけであるが、ほんたうはずつとおほらかで、のんびりした、ゆつくりした調子のものである。",
              "citation": {
                "source": "出雲鉄と安来節",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）幽暗の底の縞目よわが　小児の趾にこの歩行は心地よし逃げ後れつつ逆しまに氷りし魚のうす青いきんきんとした刺は痛し！",
              "citation": {
                "source": "わがひとに与ふる哀歌",
                "author": "伊東静雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イーヌィチはお茶にむせて咳き入り、首を絞められたようなきんきんした笑いで、総身を顫わせはじめた。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
