        "examples": {
          "standard": [
            {
              "text": "道路の中央部には雨水を外側に流すためのキャンバーがつけられており、わずかに盛り上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サーキット仕様にカスタムするなら、フロントのキャンバー角を調整して旋回性能を上げたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このスキー板はキャンバーが強めだから、硬い雪面でもエッジのグリップがしっかりきくね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "タイヤの偏摩耗を防ぐために、車検のタイミングでキャンバーの数値を適正に直してもらう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "キャンバーウェル州パラダイス通り十七番地と書けば、ザリが明朝受け取る」　ヴィラがあて先をしっかり明確に書き、多少恥じて渡した。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
