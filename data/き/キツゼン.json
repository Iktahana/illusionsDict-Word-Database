    },
    "definitions": [
      {
        "index": 1,
        "gloss": "towering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山頂には、屹然とそびえる岩があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦火を免れた古城が、今もなお屹然と建っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の前に、警備員が屹然と立ちはだかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "学生の隣に竦みたりし厄介者の盲翁は、この時屹然と立ちて、諸肌寛げつつ、「取舵だい※」と叫ぶと見えしが、早くも舳の方へ転行き、疲れたる船子の握れる艪を奪いて、金輪際より生えたるごとくに突立ちたり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭あるもの腰を拔かして、ぺた／＼と成つて※目して之を見れば、頭なき將軍の胴、屹然として馬上にあり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引かえて主人は萎え汚れて黒ばめる衣裳を、流石に寒げに着てこそは居ないが、身の痩の知らるる怒り肩は稜々として、巌骨霜を帯びて屹然として聳ゆるが如く、凜として居丈高に坐った風情は、容易に傍近く寄り難いありさまである。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽浮剽逸なる戯作者流を圧倒して、屹然思想界に聳立したる彼の偉功の如きは、文学史家の大に注目すべきところなるべし。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の霧の中から浮び上る丘々や、その上に屹然として聳える古城郭から、遥か聖ジャイルス教会の鐘楼へかけての崎嶇たるシルウェットが、ありありと眼の前に浮かんで来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四大の峻烈な意志に逆らって、雲と水と丘との間に屹然と独り目覚めてあることは！",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔生は眼前がくらみ耳がつぶれるように思ったが、屹然と立ってすこしも動かなかった。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の木立に圍まれたる中に、屹然として立つ。",
              "citation": {
                "source": "中野あるき",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちこれ觸手ある大都會、屹然として、平野田園の盡くるところに立つ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あながち人丸、赤人の余唾を舐るでもなく、もとより貫之、定家の糟粕をしゃぶるでもなく自己の本領｜屹然として山岳と高きを争い日月と光を競うところ実に畏るべく尊むべく覚えず膝を屈するの思い有之候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七砲台の跡に建てられたる銅像、日本が数箇の強国を打ち倒し第十四回平和会議の紀念として建てられたる万国平和の肖像は屹然として天に聳え、日々月々出入する幾多の船舶の上に慈愛の露を灑ぎ居れり。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、輪太郎の怪塔は有りや無しやと仰いで見れば、あったぞ、あったぞ、夜目にも屹然と聳える見覚えある高塔――窓についた灯も、この前見たとおりだった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その草山から不圖東南の空を眺めやると、重なり合ふてゐる山々の奧に、際やかな眞白い連峯が屹然として、群を拔いて立つてゐるのを見つけた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ち人丸・赤人の余唾を舐るでもなく、固より貫之・定家の糟粕をしやぶるでもなく、自己の本領｜屹然として山岳と高きを争ひ日月と光を競ふ処、実に畏るべく尊むべく、覚えず膝を屈するの思ひ有之候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ち人丸赤人の餘唾を舐るでも無く固より貫之定家の糟粕をしやぶるでも無く自己の本量屹然として山嶽と高きを爭ひ日月と光を競ふ處實に畏るべく尊むべく覺えず膝を屈するの思ひ有之候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかの大火に寺院はおろかあたりの家居まで扨も焼けたりや焼けたり、千歳の松も限りあればや昔の縁｜乍ち消えうせて木も枝もやけこがれさも物うげに立てるあはひに本堂のみ屹然として聊かも傷はざるは浪花堀江の御難をも逃れ給ひし御仏の力、末世の今に至るまで変らぬためしぞかしこしや。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤松陰撰の墓誌に、「君既寡、子皆幼、而持操屹然、凡事皆遵奉遺命、夙夜勤苦、教育二孤、終致其成立」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "這入ろうと思って片足高い処に踏み掛けたが、丁度出入口の処に絆纏を着た若い男が腕組をして立っていて、屹然として動かない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけでございますわ」　アルトヴェル氏は倒れている男をじっと覗きこんでいたが、やがて冷静に立ちかえったらしく、屹然した語調で問いかけた。",
              "citation": {
                "source": "犬舎",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンは屹然肚をきめた。",
              "citation": {
                "source": "父",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "目指す槍ヶ岳の尖峰は、屹然と中空に聳え、鋸歯状に輪廓を刻んで、左手穂高岳へ連り、右手はゆるやかに延びて、双六、鷲羽、野口五郎、烏帽子、蓮華、などの諸岳となり、大気澄む日には、遙かに白馬岳をも遠望される。",
              "citation": {
                "source": "霊気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方はその際の発見者ですし、何より、この館ではリシュリュウ（ルイ十三世朝の僧正宰相）と申してよろしいのですから」そうして、扉の方へ二、三歩歩んだ所で立ち止り、屹然と法水を振り向いて云った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷の断涯が無数の滝を垂らし、屹然とそびえている。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、考えれば考える程、却って僕は、その逆説的な解釈の方に、惹かれて行ってならないのですよ」「承わりましょう――一体何を仰言りたいのです」　盤得尼は屹然と額を上げた。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の信念こそ吾々が確守すべき武器であり、之あるによって始めて吾々は暴力の前に屹然として亭立しうるのである。",
              "citation": {
                "source": "二・二六事件に就て",
                "author": "河合栄治郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳の立木の上に、天主堂の尖塔、屹然と雲端を摩せるを見る。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "反を打った中折れの茶の廂の下から、深き眉を動かしながら、見上げる頭の上には、微茫なる春の空の、底までも藍を漂わして、吹けば揺くかと怪しまるるほど柔らかき中に屹然として、どうする気かと云わぬばかりに叡山が聳えている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し捨松は棒か杭のように、人波に押されても押されても、それに屹然と反抗しながら、何時迄も同じ場所に、立っていた。",
              "citation": {
                "source": "人間製造",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、幾星霜、風雨にうたれたヘクザ館は、古色蒼然として、荒れ果ててはいるが、幸いにして火にも焼かれず、水にもおかされず、いまもって淡路島の中央山岳地帯に、屹然としてそびえている。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "由布院がきつぜんと聳え立ち、朝月が近くかゝつてゐる、よいな。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "standing out without the influence of others",
        "register": "standard",
