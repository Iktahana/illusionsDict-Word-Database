        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は周囲の反対にも屈せず、自分の信念を屹然と貫いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんな困難にも、その女性は屹然とした態度で立ち向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "議論の中で、彼だけが屹然たる態度で反対意見を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
