    "definitions": [
      {
        "index": 1,
        "gloss": "gift of money (contained in an envelope)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
