[
  {
    "uuid": "3d1a11ec-58fe-5d85-9830-fbe57485fc3e",
    "entry": "気の毒",
    "reading": {
      "primary": "きのどく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
