      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pitiful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "交通事故で怪我をした彼を見ると、本当に気の毒で胸が痛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎日遅くまで残業している彼の姿は、見ていて気の毒になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの人、仕事が見つからないんだって。」「へえ、それは気の毒だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貧しい生活を送る子供たちのニュースを見て、気の毒に思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の病で夢を諦めざるを得なかった彼女の境遇が、気の毒でならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それがなんだか気の毒で、私は何も云ひ出せなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは益々気の毒に思ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒にみえた奴が、忽ち自分の不得手なことを始めたからだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて再び、ＡはＢを気の毒がりさへし始めるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒がられては、Ｂとしては冠履転倒も甚だしいものだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめにはイヤな奴だと思つてゐたが、だんだん見てゐると気の毒になつた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は次第に気の毒さうにしはじめ、そのうち少し私を「脳不足」だといふ意味の目配せを主人やお主婦さんと交すやうになつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし朝顔に気の毒しました』と叱言を言われた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち不勉強の学生たちを気の毒に思い、彼の知識の全部を公開する事は慎しみ、わずかに十分の三、あるいは四、五、六くらいのところまで開陳して、あとの大部分の知識は胸中深く蔵して在るつもりでいたのだろうけれども、それでも、どうも、周囲の学生たちは閉口した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の視線が妻君に放たれた時に妻君がピクリと怖ぢけたので、まあ黙過しようかとも思つたが、少し赤坊の母親に気の毒な気がして来てゐた時なので云つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が気の毒であつた、福岡の客つて奴が癪に障つた、彼は自分の自信する詩が鼻にかゝつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に乞食が一人しゃがんで頻りに叩頭いていたが誰れも慈善家でないと見えて鐚一文も奉捨にならなかったのは気の毒であった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田寅彦さんと云う方は御座らぬかとわめくボーイの濁声うるさければ黙って居けるがあまりに呼び立つる故オイ何んだと起き上がれば貴方ですかと怪訝顔なるも気の毒なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒にもあり可笑しくもあれば終にそのままに止みぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし宅へ帰って考えるとそれが非常に気の毒になって矢も楯もたまらなくなる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの事を考えると、何よりも年老いた父に気の毒だ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細民街のぼろアパアト、黄塵白日、子らの喧噪、バケツの水もたちまちぬるむ炎熱、そのアパアトに、気の毒なヘロインが、堪えがたい焦躁に、身も世もあらず、もだえ、のたうちまわっているのである。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で待っていたお客に対して運転手が一々丁寧に、どうも気の毒だが御覧の通り一杯だからと云って、本当に気の毒そうに詫言を云っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃお気の毒なことでございました。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自分のその当時の欲求に照して、彼は一部分の対象でしかないのが、彼に対して憐れに気の毒であった。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも使い過ぎたり思い違いで云い過ぎたりしたと分れば「気の毒しました。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラはみんながそんなことを云ふときは気の毒さうにしてゐるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラは気の毒さうに、だまって少しわらって、怒らないだらうかといふやうにジョバンニの方を見てゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもぼくは、このひとをばかにしながら、この人のお菓子をたべてゐるのは、大へん気の毒だ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはなんだかわけもわからずににはかにとなりの鳥捕りが気の毒でたまらなくなりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはそのひとにほんたうに気の毒でそしてすまないやうな気がする。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラが気の毒さうに窓から顔を引っ込めて地図を見てゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらも何だか気の毒なような、おかしながらんとした気持ちになった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラはみんながそんなことを言うときはきのどくそうにしているよ」「カムパネルラのお父さんとうちのお父さんとは、ちょうどおまえたちのように小さいときからのお友達だったそうだよ」「ああだからお父さんはぼくをつれてカムパネルラのうちへもつれて行ったよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "unpardonable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼が部下の功績を自分のものにしたという話は、実に気の毒な行いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "無抵抗な相手を攻撃するなど、人間として気の毒な行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あんないたずらをするなんて、本当に気の毒なやつだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "約束を何度も破る彼の態度は、友人として気の毒だと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自分の利益のために他人を陥れるなんて、気の毒な考え方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
