  {
    "uuid": "b8153f23-ad6b-5e2c-91e1-3f78eeb12773",
    "entry": "貴輪",
    "reading": {
      "primary": "きりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "era at the end of 1970s dominated by grand champion Wajima and ozeki Takanohana",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なみなす丘はぼうぼうと、　　　　　青きりんごの色に暮れ、大学生のタピングは、　　　　　　　口笛軽く吹きにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは縁故と言えば大縁故さ、縁故でないと言えば、いっこう縁故でもなんでもないぜ、が、しかしさ、こんなことにはてめえのような変ちきりんはあんまりいろいろ手を出さない方が結局てめえのためだろうぜ」「なんだと。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱な風景猫のやうに憂鬱な景色であるさびしい風船はまつすぐに昇つてゆきりんねるを着た人物がちらちらと居るではないか。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんは、あんな妙ちきりんな顔をしていて、それでもご自身では少しは美男子だと思っているのかしら。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は野菊に嫁菜、草もみぢ、秋のきりんさう。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黒んぼの奴、すっかりお調子に乗って、いよいよ出でていよいよ妙ちきりんな姿態をする。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その時、すぐにも貴女に会えたら、こんな妙ちきりんな三角関係なんか、出来なかったんですよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなして屋敷に入って、その妙ちきりんな盗人が果たして何も持ち出さなかったのか、確かめるというのは。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつもの自分ならそれを変だと感じもしようが妙ちきりんな状態にある僕はそんな事は格別気にも掛けないで矢張りのらりくらりと絶えず落着かず、少し本を読んだかと思ふとすぐ煙草を眩ひする程吹かす、画を描くかと思ふと鉄亜鈴をいぢる、その内に眠る、すぐ醒める、殆んど狂噪の状態であつた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、いつもしていたように、こどもたちはお菓子や焼きりんごをたくさんいただくことができませんでした。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまあ、あの中の一｜羽は何て妙ちきりんな顔をしてるんだろう。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれもあの妙ちきりんな白封の手紙を見たときゃ、ちっとぞっとしたが、あれこそは九郎兵衛が世間の口にけち九といわれているとんだ大ネタさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だつて變ちきりんと思ふわ、さうして宗三郎兄さんがはひつて來ると、ぴつたりとやめてしまふんだもの、何とか思ふに違ないわ、そりや誰だつて……』　お芳は涙をこぼして母に喰つてかゝつた。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時から私の変ちきりんの籠はあまり見えないようになった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の紳士かと思ふと、どうも変ちきりんな家へ這入てますからね」と門野はすぐあとを付けた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "両博士も変ちきりんな身振をやって歩いている。",
              "citation": {
                "source": "月世界跋渉記",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おう」　と、駕屋が、振向いて、後棒へ「妙ちきりんなものが、現れましたぜ」　その声に、綱手が、駕から覗くと、遠くの曲り角へ、槍を持って白布で頭を包んだらしい侍が、急ぎ足に降って来た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんに――」　深雪も、笑ったとき「人間の運というものは、不思議、奇手烈、妙ちきりん、庄公、びっくりするな」　足音は、南玉一人でなかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの前へ来た一人の芸者が、あんた、なんぞ、唄ひなはれ、と三味線を抱へたから、おれは唄はない、貴様唄つて見ろと云つたら、金や太鼓でねえ、迷子の迷子の三太郎と、どんどこ、どんのちやんちきりん。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩いて廻つて逢はれるものならば、わたしなんぞも、金や太鼓でどんどこ、どんのちやんちきりんと叩いて廻つて逢ひたい人がある、と二た息にうたつて、おゝしんどと云つた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の紳士かと思うと、どうも変ちきりんな家へ這入てますからね」と門野はすぐあとを付けた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの前へ来た一人の芸者が、あんた、なんぞ、唄いなはれ、と三味線を抱えたから、おれは唄わない、貴様唄ってみろと云ったら、金や太鼓でねえ、迷子の迷子の三太郎と、どんどこ、どんのちゃんちきりん。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩いて廻って逢われるものならば、わたしなんぞも、金や太鼓でどんどこ、どんのちゃんちきりんと叩いて廻って逢いたい人がある、と二た息にうたって、おおしんどと云った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは連中心得たもので、さてこそここに木菟の先生といふ妙ちきりんな相棒を並べておく。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "みょうちきりんなタコのばけものみたいな動物が、うじゃうじゃかたまっているその中から、いきなり英語でもって自分の名が呼ばれたものだから、きもをつぶすのもどうりであった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの妙ちきりんないやな味のする薬をのむ不愉快を考えてみただけでも、あれは人間のすることじゃありませんね。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし交ざってしまえば、二十四時間後にはどんな変ちきりんな身体になるか分ったものではない。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでに手がけた事件とちがって、全く妙ちきりんな事件である。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからもっと先へいくと、重力が減りすぎて、妙ちきりんなことが起るだろうよ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
