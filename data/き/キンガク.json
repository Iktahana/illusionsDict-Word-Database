[
  {
    "uuid": "7f58778b-d213-54b0-8e75-aa591fab3149",
    "entry": "金額",
    "reading": {
      "primary": "きんがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
