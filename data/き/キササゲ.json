    "definitions": [
      {
        "index": 1,
        "gloss": "yellow catalpa (Catalpa ovata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
