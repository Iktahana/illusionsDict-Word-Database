        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供はおいしいと云うのが、きまり悪いので、ただ、にいっと笑って、母の顔を見上げた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義直はきまり悪い思ひもせずに女に近寄らうと考へることが出来た。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらへお移りになりました時も、存じないものでお世話をいたしませんでした」　と忠実なふうに言うのを聞いていて、真実のことを知っている者はきまり悪い気がするほどであった。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその眼付きが気になったが、前にも言った通り芥川に顔を会わすのが、きまり悪いので、その当時用事はたいてい人を通じて、済ませていた。",
              "citation": {
                "source": "芥川の事ども",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、も少し飲め、歌は出来んでもいいよ」　私はきまり悪いながらも、よく解ると思った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に見られると、きまり悪いと思つて、まはり道をして、夕方になつて家へかへつて見ますと、「時男さんは、もう行つたかえ。",
              "citation": {
                "source": "時男さんのこと",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまり悪いような微笑みの影さえあった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハ、きまり悪いなあ。",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しきまり悪いのをかくすために、かえって馴々しすぎる表情）三平　やあ！",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で（わたしはあえてこのいまわしい真実を書く）、長いすの上に俯伏して、やくざな革のクッションにぐっと顔を突っ込んでいたわたしは、今さら頭を上げて、リーザの顔をまともに見るのがきまり悪いということを、われともなしに少しずつ遠廻りしながら、とはいえ抑え難い力をもって、感じ始めたのである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジューンだなんて、きまり悪いわ」　笑顔で、三津子は言っていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗っていると、きまり悪いよ」　ぼくが借りてきたこのビューイック・センチュリーに関しては、父親はなにも言わなかった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のように空がまっ青で陽ざしが強く、風がさわやかな日に、公園にむかって歩いていると、公園につくまではなんだかとてもきまり悪いことをしているような気になる。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、裸になると、自分でもきまり悪いほどに、女の体なのよ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまり悪いとか、恥ずかしいとか、早く帰りたいとか、そんなことばかり思うの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまりわるいのかしらと思って、私は自分からロゼエの名などあげて、あなたは？",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい大きい大人の男が、髪を長くして肩のところ迄下げているというのは、何と珍しく、少し怖しく、それを見てびっくりする友達たちに愧しくきまりわるいような思いのすることだったろう。",
              "citation": {
                "source": "本棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまりわるいけれど事実だから仕方がない、もつともそれだけ vital force が残つてるのだらう！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかきまりわるい変な気が致します。",
              "citation": {
                "source": "一つの愛情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――体がわるいということについてｍ、きまりわるいような、悪いような子供らしい微妙な顔をした。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前のときもそうだったが、ｍを見た瞬間何だかきまりわるいような珍しいような、すこし違ったような感じがする。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そないにいわれるときまりわるいよってに、やめとほしわ」「なんとかおっしゃるわ。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そないにいわれると、きまりわるいよってに、やめとほしわ」「なんとか、おっしゃるわ。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言つてわたしが田舎にゐて文壇のことを思慕するのではない、これまで余りしばしば意識しすぎて孤独と偏屈だつたことに気づき、そしてさういふ考へには自分乍ら賛成できないものがある、きまりわるい感じさへするとさう考へたからであつた。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそのこと、きまりわるいけれども兄にこの恋愛のことを訴えて、兄から父を説得してもらう手を考えてみないでもなかったが、兄でも父の頑固さには歯が立つまいとおもうより外にはなかったのである。",
              "citation": {
                "source": "私の青年時代",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　わきできいていて、伸子はきまりわるい心持がした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかの金銭のことや時計のことを告げているとき、伸子はきまりわるい思いだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くたびれが出て、大変長い間眠ったような気分で目がさめたひろ子は、いくらかきまりわるい表情で、前や横で、人々が弁当をひろげはじめているのを見た。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎は、何かきまりわるいような気がして、いそいで正面を見た。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、お供えは俄然生色を帯びて、まるで生きもののように表情的になって、うれしいようなきまりわるいような様子をして、お盆の上にのって居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
