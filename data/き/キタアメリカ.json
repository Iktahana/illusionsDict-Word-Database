        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人はこの夏の休暇にはサウザンプトン港から新造の米船に乗りニューヨークに上陸してはるばる北アメリカを横断する計劃が良人と約束してある。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アングロサクソン民族がオーストラリアを従え、南アメリカに権力を得て、南北アメリカを支配するようになったのも彼の遺蹟といわなければなりませぬ。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでヨーロッパの諸港から北アメリカの太平洋海岸へ来る船も、その海岸からニューヨークへいくのにも、わざ／＼南アメリカの南端をまはらないですむやうになつたので、けつきよく約四千マイルだけ航路がはぶけることになつたのです。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーリング海峡を距てて北アメリカのアラスカに対しているそうだ。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカのが五、アジアのが一三、オーストラリア及びポリネシアが九、南北アメリカのが三七である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "合衆国を中心とし、南北アメリカを一体にしようとしつつあります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カナダをはじめ南北アメリカの英国の領土は、合衆国の力に対して絶対に保持できません。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "北アメリカのインディアン中にも類似の言葉があるということである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "――北アメリカの大西洋岸にある港。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "――北アメリカのフロリダ半島の西海岸にある島。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　在野諸政黨に對する共産黨の地位　既成の勞働諸黨派に對する共産黨の關係、從つてイギリスのチャーチスト、および北アメリカの農民改革黨などに對する關係は、第二章の説述で自然に明瞭となつてゐる。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も強猛なのは、西北アメリカ、アラスカから、ロッキー山脈を通じてメキシコに至るその辺に散布する Grizzly Bear（半白熊）。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このたびの異国船、国名相尋ね候ところ、北アメリカと申すところ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "北アメリカには黄花を開くハスがあります。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に中生代の蜥蜴類の旺盛を極めて居た勢は殆ど想像も及ばぬ程で、近頃発掘せられた化石のみに就いて見ても北アメリカから出たアトラントサウルスといふ蜥蜴などは体の長さが十六間もあつて、今日の最大の鯨よりも更に大きい。",
              "citation": {
                "source": "人類の将来",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北アメリカにおいて、黒人がいかにきらわれるか、南アフリカにおいて支那人がいかに虐待せられるかを見れば、異なった人種の相接触するところではいかに互いに相排斥し合うものなるかが明瞭に知れる。",
              "citation": {
                "source": "人類の生存競争",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから南アメリカ、それから北アメリカ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも一八三一年の十二月二十七日にイギリスを出帆して、南北アメリカをめぐり、更にオーストラリヤ方面に向い、その間に五年の日子を費して、一八三六年の十月二日に漸く帰って来ました。",
              "citation": {
                "source": "チャールズ・ダーウィン",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魚は、ミシシッピイ河の沼沢地に棲んでいて、北アメリカ最大の淡水魚とされている。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその説明というのが、いちばん上等なところで、せいぜい「ごらん、北アメリカ洲で、いちばん大きい淡水魚だよ」というくらいである。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際大阪で製造し、また輸出した商品は、東洋のマーケットに限らず、遠く南北アメリカまでも廣がり、歐洲は申すに及ばず、南洋、印度、ペルシア、支那、滿洲、シベリアまで普及し、地球全體を股にかけて蔓をのばし、豪勢なものである。",
              "citation": {
                "source": "大阪といふところ",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのグウスというおばあさんはいまから二百年ばかり前に、その当時英国の植民地であった北アメリカにうまれたかたでした。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿を一番沢山産する国は、インド、エジプト、ブラジル及び、北アメリカ合衆国とである。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ド・ロマよりは少し前に、北アメリカ合衆国では、フランクリンが雷の本質について、同じやうな研究をした。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、こんどは北アメリカが来る。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台はたっぷりしていて、北アメリカインディアンの心に奢侈の念を起こさせるようなありきたりの洗面装置があり、歯ブラシよりも大型の雨傘が楽らく掛かりそうな、役にも立たない褐色の木の棚が吊ってあった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "気候がより厳しく、土地がより瘠せている、北アメリカのある地方では、荒廃は更にいっそう甚しい。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "南アメリカであろうが北アメリカであろうが、そのいずれの地方においても、その数が減少した結果非常に豊かに生活するようになったインディアン民族があるという話は、聞かない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、あとからきたアメリカ兵に横取りされてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳ／Ｖの波に乗る資格をもっているのは、少なくとも当面はＰＣ市場で激しいたたき合いを演じてきたアメリカとＮＩＥＳの企業だろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
