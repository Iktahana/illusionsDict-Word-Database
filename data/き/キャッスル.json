[
  {
    "uuid": "b47b5ecd-401a-5680-a0e0-0a5be6153230",
    "entry": "キャッスル",
    "reading": {
      "primary": "キャッスル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
