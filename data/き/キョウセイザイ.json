        "examples": {
          "standard": [
            {
              "text": "「最近疲れが取れないんだよね。」「それなら、強精剤でも試してみたらどう？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_": "彼は夜の営みに自信を持つため、ドラッグストアで強精剤を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市販されている強精剤の中には、効果が疑わしいものも少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が冗談で「これ、秘密の強精剤だよ」と言って、怪しげなドリンクを差し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師に相談せず安易に強精剤を使用するのは、体にとって危険な場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕には、あれは強精剤みたいなものなんだ」「それじゃ、いっそ、ホルモン注射がいいでしょう」「ばかにしちゃいけません。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、強精剤だとばかり思っていたのでしょうか。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県地方の人々は、姫｜柚子などよりも大きい源五郎虫を、強精剤として貪り食うというから、ザザ虫や川百足など、姿の小さいものは恐るるに足るまいと思うが、理屈は抜きにして、ちょっと手が出ないのだ。",
              "citation": {
                "source": "ザザ虫の佃煮",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお米の袋を携えて、それこそある種の強精剤の注射でも受けた人の如く、元気旺盛、足取りも軽く配給所へ赴いたのであるが、とかく浮世はままならぬところ、そこには思いがけぬ不幸が待ち伏せしていて私を打ちのめしたのである。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
