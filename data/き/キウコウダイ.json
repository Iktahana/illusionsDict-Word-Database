        "examples": {
          "standard": [
            {
              "text": "創業者が掲げた気宇広大なビジョンが、何十年経った今でもこの会社の根幹を支えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へぇ、彼って意外と気宇広大なんだね。もっと数字に細かい神経質なタイプかと思ってたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんな失敗をしても笑って『次があるさ』と言ってくれる恩師の気宇広大さに、何度も救われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さすがに、Ｎ君の気宇広大の蛮声には、度胆を抜かれたものらしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
