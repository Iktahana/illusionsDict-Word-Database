          "literary": [
            {
              "text": "寒くなってからも蚊がいて、気の詰まるような処であった。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人文楽　一字一画を楷書でいくいわゆる本格の落語家には、気の詰まるほど陰性の芸風の人が多い。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "無駄なせんさくに、気の詰まるような事をしている八五郎ではありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋の上の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでそんな人物の前では気の詰まるといふ心持がないからである。",
              "citation": {
                "source": "死",
                "author": "アルチバシェッフ・ミハイル・ペトローヴィチ　Artsybashev Mikhail Petrovich",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ会社へ入って競争するのは気の詰まる話だと思ったが、今更後へは引けない。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
