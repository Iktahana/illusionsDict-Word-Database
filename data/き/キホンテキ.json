    "definitions": [
      {
        "index": 1,
        "gloss": "fundamental",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の考え方は、私とは基本的な部分で食い違っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトは、基本的な計画段階で多くの課題が浮上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人間の基本的な欲求は、食欲や睡眠欲などいくつかある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「これって基本的な知識で解ける？」 「うん、ちゃんと基礎を学んでいれば大丈夫だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それ故、ｋａｓなどは音の単位としては究極的な最も基本的なものであるけれども少くとも我が国語においては、これらの単位から成立ったア・タ・マなどの類を言語の外形を形づくる基本的の音単位と認めてよいと思う。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは時の代わりに或る何かのエネルギーあるいは「作用」のごとき量を基本的のものとしてこれを空間と対立させる事によって、新しき力学的系統を立て直す事は不可能であろうか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、基本的人権というのは、……」　と、誰かが言いかけると、「え？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、いますぐ、映画なんかのほうへ行こうと思わず、五六年、いや、七八年でも、どこか一流のいい劇団へかよって、基本的な技術を、みっちり仕込んでもらうんだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、五、六年は基本的な勉強をしなければいけないと思いますし、――」「それはそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学雑誌の編集部から求められていたのは、基本的な知識や新しい発見、我々が捕らわれている常識とは食い違う科学的な視点などを、わかりやすく、かみ砕いて表現することでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パワーブックで読むという想定で、電子本の基本的なあり方を決めて行くにあたって、彼らは先ず、これまでの紙の本の体裁を徹底的に真似ることを目標に置きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "基本的に向上心というものが欠けていて、いつまでたってもさっぱり詳しくはならない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も基本的で、それゆえ長く使い続けられるだろうテキスト版と、ウェッブブラウザーですぐに読めるＨＴＭＬ版も、作品毎に用意する。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、最も基本的であるがゆえに、どんな環境でも、先々長く操作できる確実性がある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば非営利目的でのみ使用可、とか複製再配布は基本的にダメ、とか。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内の一つをあげて、目的達成の唯一の手段であるかのように語る１は、著作権制度の基本的な姿勢から、意図的に目をそらしている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権保護期間の延長は、憲法が「侵すことのできない永久の権利として、現在及び将来の国民に」与えると約束している、基本的人権を制約しかねない。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターを使うとき、仕事の中身にかかわらずいつでもついて回る基本的な動作を受け持つソフトウエアは、特に一まとめにされてオペレーティング・システム（ＯＳ）と呼ばれている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通は新規まきなおしのＴＯＷＮＳで、画像と音の魅力を売り物に、基本的には独力でこの目的を果たそうとした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもおっさんのにらめっこがとても面白いとは思えないという基本的欠陥に加えて、この企画には決定的な弱点がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたごく基本的なルールがほんの少しだけ存在し、それがすべてのアプリケーションを支配している。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のパーソナルコンピューターは、基本的に人間が机の上で行なう作業を支援する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準に向かって風の吹くコンピューターの世界には、共通の財産とするのがよほど健全な基本的技術が育ってくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳが考えるための道具作りの研究成果をなにも取り入れておらず、一方マッキントッシュを大将としたＧＵＩ派が過去四十年来の成果を味方に付けているのだから、そりゃ勝負にならんというのがオレの基本的な認識だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるからしてＴＲＯＮのような挑戦には基本的に賛同するところ大であるし、次善の試みとして互換勢力の台頭にはまずもって拍手を送る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "見出し文字や広告コピーの類をのぞけば、私たちのまわりにある印刷物の本文は、基本的には、すべて桝形組版によって印刷するきまりになっている。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この船室全体の構造と、彼らが一様に抱かされる共通な基本的な感じとは、倦怠に虫ばまれ切った囚人が、やはり、ボンヤリ高い窓をみつめて、そのなれ切った倦怠と無感覚とを、鈍く感じてるのとよく似ていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法の折紙とは、一つの基本的な折方から出発して、様々の形に三十七種まで麒麟やら、扇やら、機関車などに変化するもので、彼は獄中で差入れの塵紙を根気よく折り返して考案したのだ、発売したら子供達が喜びさうなものであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉遊亀氏の人気の基本的な線は、決して最近の現象ばかりをもつてそれを論じられない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとリアリズムの守り手として、旧来の絵画上の諸秩序の打ちこはし手として吉原の創造性を発揮してもらひたいし、若い後進のためにリアリズムの基本的方向を示してやるべきだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼殊に戦争とか事変とかいふ精神的ショックの後に来る国民精神の変化といふものは、ある決定的な姿をとつて現はれることは明らかで、それは国民の国内的な基本的な生活の変化としての必然的な姿である。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "從テ基本的租税以外各種ノ惡税ハ悉ク廢止スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラ、ちょっと、そこのＣＤを紹介してくれ」「えー、基本的には、六〇年代中期のものです。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
