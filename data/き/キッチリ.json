    "definitions": [
      {
        "index": 1,
        "gloss": "exactly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「予算の10万円をきっちり使い切って、最高の卒業旅行をプロデュースしてみせるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「会議の開始時刻は13時きっちりだから、1分でも遅れないように注意してね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「料理の隠し味として、お酢を小さじ一杯きっちり量って入れるのがコツなんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、あそこの看板まであと100メートルきっちりだよ。ラストスパートだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いいえ、お逢いしたことは無いのでございますが、私が、その五、六日まえ、妹の箪笥をそっと整理して、その折に、ひとつの引き出しの奥底に、一束の手紙が、緑のリボンできっちり結ばれて隠されて在るのを発見いたし、いけないことでしょうけれども、リボンをほどいて、見てしまったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九字二十四行、つまり、きっちり四百五十六字の文章を一つ書いてみろというのである。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっちり四百五十六字の文章なんて、そんな気のきいた事が出来る男じゃないんだ。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上歯と下歯がきっちり合い、引緊って見える口の線が、滑かになり、仏蘭西髭の片端が目についてあがる――父親は鮨を握り乍らちょっと眼を挙げる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっちり障子を閉める音がした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツに畳んできっちり重ねてあった蓆がばらばらにされていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたと困惑、濡れ鼠のすがたのまま、思い設けぬこの恥辱のために満身かっかっとほてって、蚊のなくが如き声して、いま所持のお金きっちり三十銭、私の不注意でございました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "襦袢の襟を、あくまでも固くきっちり合せて、それこそ、われとわが襟でもって首をくくって死ぬつもり、とでもいったようなところだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三枚にきっちり入れるために、何度も書き直す。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸はダブルの、金ボタンを七つずつ、きっちり並べて附けました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛はいろいろと研究したあげく、こぶしの中に親指をかくしてほかの四本の指の第一関節の背をきっちりすきまなく並べてみた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このきっちり並んだ第一関節の背で自分の膝頭をとんとついてみると、こぶしは少しも痛くなくてそのかわりに膝頭のほうがあっと飛びあがるほど痛かった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごはんをたべてから必ずそれをきっちり半分もどして、それでもって糊をこしらえるという噂さえあった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっちり二枚になった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きた時から、よごれの無い、縞目のあざやかな着物を着て、きっちり角帯をしめている。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "受けた恩は、かならず、きっちりとそれだけ返す。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃酒を好む者、いかにその精神、吝嗇卑小になりつつあるか、一升の配給酒の瓶に十五等分の目盛を附し、毎日、きっちり一目盛ずつ飲み、たまに度を過して二目盛飲んだ時には、すなわち一目盛分の水を埋合せ、瓶を横ざまに抱えて震動を与え、酒と水、両者の化合｜醗酵を企てるなど、まことに失笑を禁じ得ない。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "成熟した女学生がふたり、傘がなくて停車場から出られず困惑の様子で、それでもくつくつ笑いながら、一坪ほどの待合室の片隅できっちり品よく抱き合っていた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その堂がもう出来て、切組みも済ましたで、持込んで寸法をきっちり合わす段が、はい、ここはこの通り足場が悪いと、山門｜内まで運ぶについて、今日さ、この運び手間だよ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし疲れて、体がほっと熱ばんで来ていながら袴の裾の処がうすら冷たくずっと下の靴できっちり包んでいる足の先は緊密に温い。",
              "citation": {
                "source": "兄妹",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、左側の中央部に、互に蒲団をきっちりと引きつけて、そうして、近々と向き合って寝ていた一組の若い夫妻の、その妻君の方が、ふっと眼を開けて、驚いたようにくるりと背を向けてしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、まるで、じぶんの寸法を取ってこしらえたように、きっちり合いました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "半時間も早く出頭するのは癪だとふと思ったから、門からひきかえして近所の五銭喫茶店へはいって、演芸画報を見たり、新聞の就職案内欄を写したりして時間を潰し、きっちり午前九時に、受付へ出頭して葉書を見せると、可愛い少女の給仕に二階の粗末な応接間へ連れて行かれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時きっちりに出社すると、帳簿の整理をやらされた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はきっちり払っておりましたから、あとはご存じの通りです。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでわかるのは、ある若い女性が身なりはきっちりしているのに、別々の靴をしかも釦を半分しか留めずに自宅からやってきたということだから、急いでお越しにと言っても大した演繹でもない。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっちり申し上げます。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも私が明日死んでも、ありえることではありますが、この世での務めが、そう、きっちり果たされたと知った上で死ぬのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人物の性格通り、名宛もきっちり、筆跡もぐらつかずくっくりしていて、あたかも書斎で書かれたかのようだった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして食事が終るとあとを片づけて、すぐ勢よく廊下を歩き、自分の部屋に入り襖をきっちり閉めてしまふ。",
              "citation": {
                "source": "嫂",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "closely",
