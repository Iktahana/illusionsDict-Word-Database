          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「冬の冷たい風が入ってこないように、窓の鍵をきっちり閉めておいて。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このパズル、最後の一片が隙間なくきっちりハマった時の快感はたまらないね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「保存容器の蓋をきっちり閉めないと、中身が湿気て台無しになっちゃうよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「スーツケースに荷物をきっちり詰め込んだから、もうこれ以上は何も入らないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "properly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
