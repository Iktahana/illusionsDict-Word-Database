[
  {
    "uuid": "82fde140-8aaf-523a-bcca-e8a6cbd6a288",
    "entry": "黄身",
    "reading": {
      "primary": "きみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "egg yolk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その激しいときは吹きあげる砂ほこりで空は麦粉色になり、太陽は卵の黄身をその中へ落したやうである。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今戸橋、東詰の空の霞の中へ、玉子の黄身をこめたような朝日が、これから燃えようとして、まだ、くぐもっている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い味噌汁と、塩昆布に麦飯を女中と差し向いで食べると、あとは卵を破って黄身をぐっと飲んでおく。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母さんは鶏卵の黄身をまん中にして白身を四角や三角に焼くのが上手だ、駿河台へニコライ堂が建つとき連れてってくれたのもこの伯母さんだ。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い味噌汁と、塩昆布に麦飯を女中と差し向ひで食べると、あとは卵を破つて黄身をぐつと飲んでおく。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Y※lk（ヨーゥク）【名】（卵の）黄身、蛋黄。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏卵にたとえていえばちょうど黄身も白身もまだ判然と分かれておらぬ程度である。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが月日を経るに従い、黄身は黄身、白身は白身と分かれ、さらに進んでは頭もでき、手も足もそなわり、一つの雛に化するように、きわめて幼少の折から自然的に各分業的の萠あるものである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉢に盛った鶏卵が少し気になるが、彼女には、卵の黄身だけをぬき出してすする癖があるので、その癖を大目に見てもよかろう。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵の黄身をやたらにすするのは、彼女の唯一の悪趣味だ。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○上等製の林檎フライは前文の品をブランデーと砂糖に一時間漬けおき、玉子の黄身と米利堅粉とを牛乳にて溶きかつねりて固くし、白身を泡立たせてそれへ交ぜるなり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "また玉子の黄身の湯煮たるを裏漉しにしてかけるもよし。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの半熟というのは白身ばかり半分固まって黄身は少しも煮えておらん。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白身も黄身も共に半熟にならなければ真誠の半熟といわれんが昔しから温泉で湯煮るとその半熟が出来る事は人が知っていた。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い火へ湯を掛けて玉子を入れるのですがその湯の中へ指先をちょいと入れられる位の温度にして三十分から四十分間位湯煮ると白身も黄身もちょうど良い半熟になりますよ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○黄身の成分は百分中蛋白質一割六分、脂肪三割余、鉱物質一分三厘、水分五割二分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の中川は側にありける鶏卵を執りて小皿の上へ割って落し「小山君、よく見給え、玉子を皿の上へ割ってみて黄身がこの通り中高に盛上っていて白身も二段か三段に高くなっているのは新しい証拠だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮の光ったのを割ると黄身も白身もダラリとして横に拡がる。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでよく見給え、黄身の上に鳥の眼位な円い小さな線があるだろう。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に黄身の眼というがこれは玉子の胎盤だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眼が黄身の真中にあって眼の近所に何にもありますまい。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは眼の処へ透明ったドロドロのようなものが附着いていてそれが黄身の白い紐と連結してあります。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな玉子でもこの通りに黄身の両端から白い筋が出ていましょう。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは黄身を両方の皮へ繋いで釣っている紐でカラザというものです。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この紐で両方の皮へ釣っているから黄身がいつでも真中にいるのです。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川君、玉子の黄身に色の白いのと赤いのがあるがこれはどういう訳だね」中川「それは食物と飼養法と種類とで違う。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋鶏は黄身の色が白い、西洋人は黄身の白いのを好む。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに哀しく、きのふきみのくちびる吸ひてきずつけ、かへれば琥珀の石もて魚をかこひ、かの風景をして水盤に泳がしむるの日、遠望の魚鳥ゆゑなきに消え、塔をきづくの額は研がれて、はや秋は晶玉の死を窓にかけたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
