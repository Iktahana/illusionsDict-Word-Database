        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は誰にでも優しくて、本当に気がいい人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困っている人がいると、すぐに手を差し伸べる、気がいいおばあちゃん。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は気がいいので、周りにはいつも人が集まってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの店主、気がいいからついつい長居しちゃうんだよね」「わかるー！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実際文壇に出ることが容易になつた此の頃は、さういつた文学青年も少くないことで、一知半解の故に却て元気がいいといつた風の元気が、本当の元気と間違へられる風景は、毎日のやうに見受けられることである）。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月頃から、一度子供連れで熱海へでも行ってみようと云っていたが、日曜というと天気が悪かったり、天気がいいと思うときっと何かしら差障りがあって、とうとう四月二十日の今日の日曜までこのささやかな欲望を果たす機会がなかった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めった、今度は去年あたりよりゃあいつらの景気がいいと思ったら、独逸が新しい武器を提供しとるそうじゃありませんか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん人気がいいそうであります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このごろはお前も景気がいいと見えて、なかなか貯金にも精が出るのう。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは仲間の石どもだけでしたがあんまりベゴ石が気がいいのでだんだんみんな馬鹿にし出しました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気がいいと油絵のスケッチに出たりしていたようである。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろバナナのほうは景気がいいが、書物のほうはさびしい。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はばかに景気がいいじゃないか」　といったのは人見だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間の僻地の割には景気がいいらしい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「景気がいいぢやないか。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、温泉といった方が景気がいいからですわ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がいいと云えば云えないこともないが、それだからと云って、僕の生活までが、そんな被害を甘んじてうけ入れていられるものではない。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、あんたから送って来た戦地のスナップショット、どれもこれも、とてもお天気がいいね。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若い者は、なんて元気がいいんだろう！",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主の金作が朝早くから山芋掘りに行った留守に、あんまりお天気がいいので、女房のお米は家を閉め切って、子守女のお千代に当歳の女の児を負わせた三人連れで、村から一里ばかりあるＨ町の八幡宮に参詣した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんも、陽気がいいときですから、ときどき出雲崎まで出掛けておいで下さい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの説に依ると、昔から、天長節は必ずこんなに天気がいい事にきまっているのだそうである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "景気がいいのだそうですね。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたの、今日は痴に景気がいいじゃないの、何か掘りだし物でもあったのかい」「あったとも」風呂敷の結目を解いて包を背からおろして、「おい、みろ」　金五郎は包の中から三つの古い桐の箱を執りだした。",
              "citation": {
                "source": "偶人物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたは、天気がいいね。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ若い牛は元気がいいので、ひと晩のうちに十里くらいは歩くでしょうから。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は初酉だそうですが、天気がいいせいか頗る繁昌しているので、混雑のなかを揉まれながら境内と境外を一巡して、電車通りの往来まで出て来ると、ここも露天で賑わっている。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に商売であるから、取分けて景気がいい。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは景気がいいので、友蔵も幸吉もどこへか飲みに出かけて、お常ひとり留守番をしている。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、今度の興行は外れるだろうと言っていたんですが、案外に景気がいいようです。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんでもな、天気がいいがら、少し稼いで来んべで。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは根気がいいし、工夫力もあるし、狡猾でもあるし、職務上主として必要なように見える知識には十分によく通じてもいる。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森辺魔道の事　明和三年｜弥生なかば――これは首尾の松の霜、浅間の残暑、新堀の五月雨などとは事かわって、至極陽気がいい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっくりと柔く、尻の落ちつきがいい。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
