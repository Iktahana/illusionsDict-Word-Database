[
  {
    "uuid": "b6a349f4-300f-5166-abc3-ec3017ae0e91",
    "entry": "客用",
    "reading": {
      "primary": "きゃくよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
