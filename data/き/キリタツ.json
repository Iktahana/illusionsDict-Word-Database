    "definitions": [
      {
        "index": 1,
        "gloss": "to rise perpendicularly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つひに鹿は、屏風のやうに切り立つた崖のすそをまはつて、向かふへ姿をかくしてしまひました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側には切り立つ岩壁、もう片側にはまっすぐに落ちる崖、そこへ宿敵が追いついた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "その切り立つた岩山を抱く樣にして、大きく眞白く、手に取る樣な眞近な空にわが富士山は聳え立つてゐるのであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の無い村　怒田村は、切り立つた櫟林の屏風の山で囲まれた崖下の部落であつた。",
              "citation": {
                "source": "その村を憶ひて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩岸は切り立つた樣な斷崖で、その斷崖には意外なほど多くの樹木が生えてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下す坂下には大きな谷が流れ、その對岸に同じ樣に切り立つた崖の中ほどには家の數十戸か二十戸か一握りにしたほどの村が見えてゐた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り立つた斷崖の眞中どころに鎹の樣にして架つてゐる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何か遥かなものばかりを眺めてゐるかのやうにいつも眼をうつとりとさせてゐるためか、白く切り立つた鼻筋の嶺の左右に据つてゐる眼は春霞に煙つてゐる湖のやうなひろさを感じさせた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に遠淺な砂濱があれば、こゝには切り立つたやうな岩壁がある。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "稜を鋭く何箇所か空に目がけて切り立つて、孔雀石と翡翠の明暗を隈つた半島が此方の海岸に詰め寄せるかのやうに鮮かに浮出してゐる。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側には住宅風の小さな二階家が立ちならび、正面は幅のひろい切り立つやうな石の段々でした。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前には、真っ黒な山が切り立つようにそびえて、はるか上の断崖のふちに、雑木林にかこまれた一軒家の灯が、何事か語り顔にチラチラしている。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンプはより高い麓の丘が急に切り立つ点から八キロメートルあまり離れた所に設営した。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り立つように嶮しい断崖です。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り立つ階段を前にして、素直にロープウェイに頼ることにし、海への見晴らしのきく山上へと至る。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "山は中腹からいきなり垂直に切り立つ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一思にこんなやくざ女を蹴とばしてしまはうといきりたつこともあつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女は自分の云つてることがちつとも先方へ通らないもどかしさと、一年も前の古い後藤の名を云ひだされた邪慳さとで、無暗に心がいきりたつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は、あの笑つたのか怒つたのか解らない不思議な剣幕でいきりたつだらう。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくふくと　なほしめやかに香気をふくんで霧のやうにいきりたつあなたの　ゆびのなぐさみのために、この　月の沼によどむやうな　わたしのほのじろい頸をしめくくつてください。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥つちよのめかしやは赫つといきりたつたが、しかし荷馬車はその時もうよほど遠く距たつてゐたので、女房はその腹癒に罪もない継娘や、のそのそ歩いてゐる亭主に当り散らした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "モコウ」　富士男はいきりたつモコウをおさえた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある屋根裏に棲んでゐたといふのであるが、東京には欧羅巴の安宿なみの屋根裏なんぞ見当らないといきりたつ性質のよろしくない読者のためには、ＢＯＮ！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗北するや口惜しがること夥しく、今のは怪我敗けだ、ほんとは俺の方が強いのだといきりたつし、勝てば忽ち気を良くして、あんたは下手だと大威張りである。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三雲画伯は喧嘩の当人と同じぐらゐいきりたつて、分けて這入つて、おい、かういふ際に喧嘩するとは何事だ、荒々しく息を吐いて叱りとばしてゐる。",
              "citation": {
                "source": "真珠",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と頭を振ったり何かしていきりたつので、笑ってすんでしまいはしたけれ共、あんなじゃあきっと銀行でも毛虫あつかいにされて居るのだろうと思うと、旦那様、お父さんと一角尊がって居る家の者達が気の毒な様にもなったりした。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」人々は一斉にいきりたつて怒鳴つた。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い谷底から、きりたつた岩塊が冬空へ走りこむ。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはるがいうには、自分が勝手で洗濯していたところへ作衛がやって来て、どうしても俺のところへ帰って来いといきりたつ。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝てば忽ち気を良くし、いや、あなたはちよろいと納まるし、負ければ大いにいきりたつて、負け惜しみを並べ立てること騒々しい。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
