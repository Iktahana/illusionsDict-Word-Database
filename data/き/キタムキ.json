[
  {
    "uuid": "0c0bdbaf-ecc0-5c19-9e22-bf782d523cbe",
    "entry": "北向き",
    "reading": {
      "primary": "きたむき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
