        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眼をウッスリと半分開いて、気持よさそうに口をアングリしていやがる」「気色の悪い。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆論をしても負けさうになればいつでも向ふを向いて仕舞ふぬらくらした気色の悪い敵であつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、よろしく……」　と気色の悪い微笑を浮べてゐた。",
              "citation": {
                "source": "老猾抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "気色の悪い……」　これだけ聞きますと、私はソッと切戸から離れました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様が御気色の悪い日には旦那様は密と御部屋へ行って、恐々御傍へ寄りながら、「綾さん、どっか悪いのかい。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は一日｜気色の悪い日で、店から来た束髪の女ともあまり口を利かなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "気色の悪い話ですが、よくそれで眼を覚まさせられますので……とうとうたまらなくなって、夜中に起き上って、御苦労様に義足をはめ込んで、そこいらと思う処へ湯タンポを入れたりしてやると、綺麗に治ってしまいましてね。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不相変雲のかぶさった、気色の悪い天気だった。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふふふふ」と彼はただ気色の悪い笑い方をしていたが、不意にじろりと尾田を見ると、いきなりぴしゃりと硝子戸を閉めて駈けだしてしまった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸から股のあたりへかけて、汗がぬるぬるしてい、気色の悪いこと一とおりではなかったが、起き上がることができなかった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気色の悪い爺く玉だ！",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻痺、と簡単に言つてしまへばそれまでのものであるが、生きた肉体の一部が枯木のやうに感覚を失ひ、だんだん腐つて行く恐しさは、考へれば考へる程奇妙な、気色の悪い無気味さである。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々寝苦しさうな呻き声や、つまつた鼻穴で気色の悪い音をたててゐるのや、今にも断れさうな急はしない呼吸などが聞えるだけで、ひつそりとした病室らしい静けさである。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この野郎、全く気色の悪い奴だ。",
              "citation": {
                "source": "青い焔",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして疲れはてては咽喉や胸腹に刃物を当てる発作的な恐怖に戦きながら、夜明けごろから気色の悪い次ぎの睡りに落ちこんだ。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば肉体を腐せてゆく悪疾の気色の悪い映像であつた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざ／＼私でも本郷座まで立見に行つたから知つてゐますが、随分この「波」といふ芝居はベタ／＼した気色の悪い芝居でした。",
              "citation": {
                "source": "井上正夫におくる手紙",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝っぱらから人の家へ上がり込んだりしやがって、気色の悪い。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "綾吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "このラサという所ほど気色の悪い腹の立つ所はない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなの前でで、気色の悪い、みんなの前でで」　それには重吉もいねも二の句が継げず、黙ってカヤノの泣きじゃくる背中を見ていた。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実枝が重吉の看病に呼び戻された時にクニ子にその話をすると、クニ子はむっとして、「あた気色の悪い、カヤノ姉さん、ようそんな婿さんのとこにいるわ」と、クニ子らしい憤慨のしかたをした。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ることまで気がねさせるなんて、気色の悪い女ね。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「気色の悪い魔じゃ」「変なひとねえ」　笑っていたお京の切れ長の眼が、複雑な思いをこめた秋波になる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、こげな気色の悪い選挙は二度といやですばい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "心細そうな、断末魔のうめきのような、ひどく気色の悪い吠え声だった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
