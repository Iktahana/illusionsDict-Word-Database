        "examples": {
          "standard": [
            {
              "text": "その美術館では、ピカソやブラックなど著名なキュビストの作品が一堂に会していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のアート作品は、キュビストの影響を強く受けた、多角的な視点から描かれた人物像が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キュビストの画家たちは、現実を分解し、再構築することで、新たな表現を切り開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "浅井は口笛を吹きながら、キュビストのピザパイの外周から、中央の回廊と部屋をつなぐドアの方向に、ひとりでずんずんと入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
