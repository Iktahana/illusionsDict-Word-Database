        "examples": {
          "standard": [
            {
              "text": "「受付は本館ではなく、渡り廊下を通って隣の北館の方になりますのでご注意ください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "北館の3階にある資料室は、あまり人が来ないので集中して勉強するには穴場だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大規模な改修工事のため、来月から北館の全フロアが立ち入り禁止になるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、北館の入り口に傘忘れてきちゃった」「今から取りに行くの？もう閉まってるかもよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "モコウが倹約に倹約をかさねてたくわえたかも、しちめんちょうの肉、塩づけのさかな、サクラ号から持ってきたかんづめ類も、今後どれだけのあいだつづくか、はかることができない。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり身が、心が、ぽってりと肥えて太ってきたかんじでした。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、鉄でできたかんおけのようなものの中に、とじこめられていることがわかりました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
