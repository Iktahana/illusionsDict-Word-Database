[
  {
    "uuid": "9f5d56a0-31cf-52ca-b582-5c27f97b660d",
    "entry": "禁則",
    "reading": {
      "primary": "きんそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prohibition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "現行の英語バージョンにも漢字かな混じり文が流し込めるとはいえ、こうした日本語の禁則には、当然対応していない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁則処理に関連して、あちらを立てればこちらが立たずとなり、整然とした組みを作りにくいこと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがマニュアルを読むことに遺伝子レベルで禁則をかけられたこのスカートを履いたゴリラでも、マッキントッシュのアプリケーションは複数種類を日常的に自力でどうやら使いこなしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戒律が煩瑣で過酷で禁則が細々しているのも、つまりは身心不二の故に、身を如法（教えのとおり）にするには心を如法にし、身を不如法にする時は心を如法にすることができないからである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由を尊重する民主主義の世界には成可く禁則の少い事が望ましい。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し其為には禁則が無くても問題を起さない様な立派な国民になる事が先決問題である。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく禁則はしない方が望ましいと仰有るのはその通り。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ上ってしてはいけないということは（それはこのビルデングの開館した初めに、チャンとこの便所のドアに張りつけてあった禁則であった。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の話はその謎めいた結婚について極めて個性的な光を与えるもので、そんな打ち明け話をする気になったのも、つらい禁則を緩めるべき時がきたということなのだろう。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
