[
  {
    "uuid": "a6fb66f2-eaf7-5aaa-a0f0-2aab0df2dcf1",
    "entry": "給与",
    "reading": {
      "primary": "きゅうよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
