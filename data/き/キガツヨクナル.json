        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そう思うと、俺は何んだか急に気が強くなるのを感じた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、大体大丈夫だがね、しかしどうかした拍子で電気が強くなると、心臓をやられることもあるだろうね。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "不当に気が強くなる。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "癩病一家へ御降臨あそばしたからッて、牛肉屋の娘がにわかに気が強くなるのは考え物だな」「あなたの何が天才なのさ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きよると見せかけて笑いおるぞ」　大勢集まれば、気が強くなるに決まっている。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎はそれでいくらか気が強くなる。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "息はあらく、呼気が強くなる。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
