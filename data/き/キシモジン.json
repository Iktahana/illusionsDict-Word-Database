[
  {
    "uuid": "2d195e79-c341-5029-a5f0-2d9e381f93af",
    "entry": "鬼子母神",
    "reading": {
      "primary": "きしもじん",
      "alternatives": [
        "きしぼじん"
      ],
      "is_heteronym": false
    },
    "grammar": {
