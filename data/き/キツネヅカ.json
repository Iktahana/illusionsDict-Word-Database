        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "兵士たちは敵の猛攻を避けるため、急いで地面に狐塚を掘って身を隠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画の戦闘シーンでは、主人公が爆撃の中、たった一つの狐塚に身を潜める緊迫した場面があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "訓練中、新兵は厳しい寒さの中、自ら掘った狐塚で一夜を明かすことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……遣手部屋の蚯蚓を思えば、什※か、狐塚の女郎花。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて北軍の総大将勝家は、今市の北狐塚に陣して居たのであるが、盛政の敗軍伝わるや、陣中動揺して、何時の間にか密かに落ちゆく軍勢多く、僅か二千足らずになった。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、蛇塚、猫塚、狐塚よ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐塚あたりで午飯だらう。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひよつとするとお蕗婆さんは狐塚に来てゐるかも知んねえよ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狐塚の茶屋には柚太の情婦がゐた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚太にとつては狐塚までの径は全く苦もないところを、こんな脚弱と伴れ立つて余程退屈さうだつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜巻山、雉子ヶ淵、怒田、ヤグラ沢、狐塚、吹雪川、そして漸くにして鬼柳の森を見出す次第だが、私はもうそんな名前をかぞへるだけで地面が波にでも見えるかのやうな眩惑を覚えた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐塚まで辛へて貰はう。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼涙沼や狐塚の界隈であればこそあんな山駕籠も不思議とされぬが、自動車や機関車が文明の煙りを挙げて往き交ふてゐる繁華な駅路へ向つて、ほい／＼／＼！",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この分ぢや日のあるうちに狐塚までが、やつとだらう。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狐塚が近づいたら泣き声だけは辛棒しておくれ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯「狐塚事件」という小説を、もう十日も机上に置いて書いているが、まだ半分しか書けない。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この県の地名になっている塚で関東と共通するのは狐塚・オサル塚・山伏塚も念仏塚も全国にあるけれども、関東が本場といってよい。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高時川の部落が焼けておるのでございましょう」「その彼方の煙は」「新堂かと思われまする」「もそっと、右の方へ寄って、なお旺んな煙の見ゆるのは、どの辺か」「今市の町と、狐塚辺に当るかと存じられますが」「柴田め。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、北国街道を流れ下って、狐塚まで進み、東野山方面にある有力なる敵――堀秀政の兵五千――をひきつけて動かさぬために、敢えて、旌旗堂々たる進出を誇示した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦捷の飛札を添えて、中川瀬兵衛の首級は、直ちに狐塚の柴田勝家の本営へ送られた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お案じあるなと、お伝え申せ」　狐塚までは、迂回路をとると四、五里もあるが、直線に行くと一里余しかない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘲うても嘲いきれぬ」　このとき、さきに狐塚の柴田勝家の本陣へ、戦捷報告にやった使いが、勝家の旨を帯びて帰って来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今、帰陣いたしました」「御本陣狐塚の方面には、敵のうごきはないか」「別条もない由にござりました。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとは、ちと御満足が早過ぎる」「いや、岩崎山のことは、それがしがお暇申す頃には、早や狐塚にも伝わっておりました」「では、再度、早馬には及ばぬな」「そのことだけならば――」「いずれ明朝と相成れば、さらに賤ヶ｜嶽も、わが手のものじゃ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先刻、狐塚へも伝えておいたが」　と、余事には耳もかさぬ顔をした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狐塚の御本陣より、国府尉右衛門殿、御軍令を承って、ただ今、これへお越しになられます」　この度の使いは、単なる面談や、勝家の意思の取次でなく、正式なる軍令を伝達する者として来たのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣所は狐塚の一寺にあったが、そこの廻廊を、黙々と、めぐり歩いては、山門の方を見て、「まだか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ、ここは玄蕃にまかせ、修理叔父は、狐塚にお控えあって、一両日は、御見物が然るびょう思われる）　と揶揄して、てんで受けつけもせず、その間にも、観音坂や蜂ヶ峰方面の新地点へ、積極的に小部隊を増派している様子でした――と弥惣はつつみなく語るのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "（柴田勝家の本軍一万二千もまた時を同じゅうして、全面的にうごき出て、狐塚を中心に、北国街道に沿い、東野山方面へ当てて、布陣｜凡ならず見えて候う）　時、ちょうど秀吉は、呂久川べりへ出て、増水の勢量を視て帰って来たところだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "位　ここで、視野をかえて、狐塚方面のうごきを視る。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、勝家としては、冒険ではあるが、一奇手なりと、玄蕃允にゆるしたほんの“序戦の取”が、思惑と相違して、忽ち、味方全軍の致命を招来し、敵の大挙を見たときはもはや、狐塚主力の機動も、彼の総帥力も、それを現わすすべもないものと化していたのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――躁ぐな、狼狽するな、と抑えるつもりでいう彼自身の声からして、狐塚本陣の、騒然たる狂躁のひとつだったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自身、狐塚附近を巡り、陣々の物頭たちへ、口ずから呶鳴った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
