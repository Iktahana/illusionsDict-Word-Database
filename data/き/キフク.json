        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とある谷を下つた處で、曲りくねつた道路と、其の道傍に榛の木が三四本眞黄に染まつたのを主題にして、稍複雜な地形に起伏する色々の畑地を畫布の中へ取り入れた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二日　曇　朝大学へ行って破損の状況を見廻ってから、本郷通りを湯島五丁目辺まで行くと、綺麗に焼払われた湯島台の起伏した地形が一目に見え上野の森が思いもかけない近くに見えた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風に作者は主人公の女に對する氣持の起伏の消息や、陰影に富んだ然も純な性格を、語るより以上に感ぜしめてある。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘は起伏して、ずっと彼方の山にまで連なっていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気候の次に重要なものは土地の起伏水陸の交錯による地形的地理的要素である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面は、波のような丘陵の起伏と、そのさきの太平洋に面した荒海がある。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の下なる七つ森のその三つなり、　　白々として起伏するもの。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がすっかり白い雲でふさがり太陽も大きな銀の盤のやうにくもって光ってゐたのです）がなだらかに起伏しそのところどころに茶いろの栗や柏の木が三本四本づつちらばってゐるだけじつにしぃんとして何ともいへないさびしいのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家はこの方角だ」　自分は友人と肩を並べて、起伏した丘や、その間に頭を出している赤い屋根や、眼に立ってもくもくして来た緑の群落のパノラマに向き合っていた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "起伏あたかも大波のごとく打続きて、いつ坦ならむとも見えざりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またその身に蘿また檜榲生い」というのは熔岩流の表面の峨々たる起伏の形容とも見られなくはない。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合には反響によって昼間はもちろんまっ暗な時でも地面の起伏を知りまた手近な山腹斜面の方向を知る必要がありそうに思われる。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオリンの音の、起伏するのを受けて、山彦の答えるように、かすかな、セロのような音が響いて来る。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが「地図の言葉」で読めばただ一目で土地の高低起伏、斜面の緩急等が明白な心像となって出現するのみならず、大小道路の連絡、山の木立ちの模様、耕地の分布や種類の概念までも得られる。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや日没ちかく、残光を浴びて山の峯々が幽かに明るく、線の起伏も、こだわらずゆったり流れて、人生的にやさしく、富士山の、人も無げなる秀抜と較べて、相まさること数倍である、と笠井さんは考えた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一本の木も草もない、荒涼たる硬炭焼滓だらけの起伏と、煙墨だらけの煉瓦や、石塊や、廃材等々々が作る、陰惨な投影の大集団であった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大洋のうねりのように高低起伏している。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある谷を下った所で、曲がりくねった道路と、その道ばたに榛の木が三四本まっ黄に染まったのを主題にして、やや複雑な地形に起伏するいろいろの畑地を画布の中へ取り入れた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて眼界｜頓に開けた所へ出れば、重畳せる群山波浪のごとく起伏して、下瞰すれば鬼怒の清流真っ白く、新しき褌のごとく山裾を迂ぐっている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の日盛りの空はぼうとして、起伏する駿州の丘陵が薄い霞の中から、初夏の姿をあらはして居る。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の日盛りの空はぼうとして、起伏する駿州の丘陵が霞の中から、初夏の姿をあらはして居る。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しき美人は満面に笑みを含みて、起伏常ならざる席に安んずるを、隣たる老人は感に堪えて、「おまえさんどうもお強い。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイ私の背後の鼻の先に、いつの間に立ち現われたものか、何ともいえない奇妙な恰好をした海藻の森が、涯てしもない砂丘の起伏を背景にして迫り近付いている。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯流山は氷のかけらが溶けかけているような形で、峯には三つのなだらかな起伏があり西端は流れたようにゆるやかな傾斜をなしていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "起伏表裏がありながら、また最後に認め合うものを持つ二人の交際は、縄のように絡み合い段々その結ぼれを深めた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪のように起伏する灯の粒々やネオンの瞬きは、いま揺り覚まされた眼のように新鮮で活気を帯びている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その起伏のさまは、伊香保の湯宿の高い裏欄干から上つ毛野、下つ毛野に蟠る連山の頂上を眺め渡すようだった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはろばろと眺め渡して行く起伏の末になると、枯蓮の枯葉は少くなり、ただ撓み曲った茎だけが、水上の形さながらに水面に落す影もろとも、いろいろに歪みを見せたＯの字の姿を池に並べ重ねている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その片隅の薄あかり、背にうけて天鵝絨の赤きふくらみうちかつぎ、にほふともなく在るとなく、蹲み居れば。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樵夫の娘爪先を爐にあたたむる雪の朝、いきふく聲を洩れ聞きて、情郎こそ呼べと駈けいでて、あはれや軒に立ちくらし、凍えて泣きし談あり。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
