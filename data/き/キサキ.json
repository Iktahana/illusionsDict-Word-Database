        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを歓び楽しむことで、わしは人后に落ちはせん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない天の川のずうっと川下に青や橙やもうあらゆる光でちりばめられ〔〕た十字架がまるで一本の木といふ風に川の中から立ってかゞやきその上には青じろい雲がまるい環になって后光のやうにかかってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした放課后みなさんとうちへ遊びに来てくださいね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは数週前いきなり掲示場にはりつけられた〔〕われらはわれらの信ぜざることをなさず　といった風の宣言めいたものの〔〕十幾人かの聯名のその最后に記された富沢であった。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、向うの農夫室のうしろの雪の高みの上に立てられた高い柱の上の小さな鐘が、前后にゆれ出し音はカランカランカランカランとうつくしく雪を渡って来ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　午后零時五十分　午の食事が済んでから、みんなは農夫室の火を囲んでしばらくやすんでいました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　騎兵はだんだん橋を渡り、最后の一人がぽろっと光って、それからみんな見えなくなりました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日農場実習　午前八時半より正午まで　　除草、追肥　　　第一、七組　　蕪菁播種　　　　第三、四組　　甘藍中耕　　　　第五、六組　　養蚕実習　　　　第二組（午后イギリス海岸に於て第三｜紀偶蹄類の足跡標本を採収すべきにより希望者は参加すべし。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは午后から鵞口瘡疫の事に就て。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后の乳搾る頃になりてますます鳴く。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか支那の軍閥の退屈な野戦が西大后の運河に押し流されてしまう日のあることを妾は知るのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉食獣則ち、獅子、虎、豹の類、最后にこれらのものを食べる人間則ち主義者自身ももし需要があれば絶対に食はれることを避けてはいけないといふ規則である〔。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」異人は“Ha, ha, ha-a-a-a”と最后を顫音でわらった。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔老いては冬の孔雀守る〕老いては冬の孔雀守る、　　　　蒲の脛巾とかはごろも、園の広場の午后二時は、　　　　湯｜管のむせびたゞほのか。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后はみんなでテニスコートを直したりした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后はうちのひば垣をはさんだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明后日までにすっかり決まるのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后一時に約束の通り各班が猿ヶ石川の岸にあるきれいな安山集塊岩の露出のところに集った。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、昨日の午后に校長が、おいでになっただけでした。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日農場実習　午前八時半より正午まで　　除草、追肥　　　第一、七組　　蕪菁播種　　　　第三、四組　　甘藍中耕　　　　第五、六組　　養蚕実習　　　　第二組　（午后イギリス海岸に於て第三紀｜偶蹄類の足跡標本を採収すべきにより希望者は参加すべし。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野宿第一夜四月二十日の午后四時｜頃、例の楢ノ木大学士が「ふん、此の川筋があやしいぞ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、午后零時五十分　午の食事が済んでから、みんなは農夫室の火を囲んでしばらくやすんで居ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野宿第一夜四月二十日の午后四時｜頃、例の楢ノ木大学士が「ふん、この川筋があやしいぞ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへんやさしい王子であったのが、まだ年のわかいうちに病気でなくなられたので、王様と皇后がたいそう悲しまれて青銅の上に金の延べ板をかぶせてその立像を造り記念のために町の目ぬきの所にそれをお立てになったのでした。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーの母、澳太利の名皇后、マリア・テレザは心配した。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで工芸学校の先生は、町の紫紺染研究会の人達と相談して、九月六日の午后六時から、内丸西洋軒で山男の招待会をすることにきめました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎と五年生の耕一とは、丁度｜午后二時に授業がすみましたので、いつものように教室の掃除をして、それから二人｜一緒に学校の門を出ましたが、その時二人の頭の中は、昨日の変な子供で一杯になっていました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のみたのは今も云いました通り、午后の授業です。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今丁度ひるのやすみでございますが、午后の課業をご案内いたします。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、こんな暮し方をしてゐて、さきさきどうなるかと思ふと不安ぢやなくつて？",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
