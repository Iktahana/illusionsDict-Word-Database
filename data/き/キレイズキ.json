    "definitions": [
      {
        "index": 1,
        "gloss": "love of cleanliness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
