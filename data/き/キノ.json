              }
            },
            {
              "text": "「ソウダ、コノ　キノドクナ　ヒトビトヲ　タスケテ　ヤラネバ　ナラナイ」　ヲトコハ　アチラ　コチラノ　ムラニ　ノコツテ　ヰル　ヒトビトヲ　ヒトトコロニ　アツメマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミズノ　ナカニハ　イツピキノ　サカナガ　シヅンデ　ヲリマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンノキノ　シタデ　オカアサンノ　タヌキガ　コドモノ　タヌキニ　バケル　コトヲ　ヲシヘテ　ヰマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　ハンノキノ　シタニ　コロガツテ　ヰマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムラヒハ　ゲタノ　ヲヲ　キツテ　コマツテ　ヰル　トコロデシタノデ、「ヤ　コレハ　ウマイワイ、ココニ　ゲタガ　オチテ　ヰル」ト　イツテ、コドモダヌキノ　バケタ　ゲタヲ　ハキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "キノ　カゲカラ　コノ　ヤウスヲ　ウカガツテ　ヰタ　オカアサンダヌキハ　タイヘンナ　コトニ　ナツタト、メヲ　マンマルクシテ　オドロキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカアサンタヌキハ　シンパイシテ、キノ　カゲヲ　カクレテ　サムラヒノ　アトヲ　ツイテ　イクノデス。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムラヒハ　ゲタヲ　カツテ、コドモタヌキノ　バケタ　ゲタヲ　オモテニ　ダシテ　ヤリ、オアシヲ　ヒトツ　ヤツテ、「ヤ、ゴクラウダツタノウ」ト　イヒマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コドモダヌキハ　オアシヲ　モラツタノデ　サツキノ　クルシサモ　ワスレテ、ヨロコビ　イサンデ　カヘツテ　イキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツピキノ　シロイ　テフテフガ　フウセンダマノ　トコロヘ　マイニチ　トンデ　キテ、イチンチヂユウ　アソンデ　イクノデシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルサメノ露ノヤドリヲ吹ク風ニコボレテ匂フヤマブキノ花　天真爛漫とでも申しませうか。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノッソリ出テ来テ、蠅タタキノ如ク、バタットヤッテ、ウムヲ言ワサヌ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半島の西部の金木地方も、山菜はなかなか豊富であるが、この蟹田地方も、ワラビ、ゼンマイ、ウド、タケノコ、フキ、アザミ、キノコの類が、町のすぐ近くの山麓から実に容易にとれるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
