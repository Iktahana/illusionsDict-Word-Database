    "definitions": [
      {
        "index": 1,
        "gloss": "keno (casino game)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ラスベガスのラウンジで、軽食を楽しみながらキノの抽選結果をのんびり待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「キノって、日本の宝くじやビンゴに近い感覚で遊べるカジノゲームなんだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カジノの片隅に設置されたキノのカウンターには、鉛筆を手にした年配の常連客が集まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "○オクツタ」ユイノウタノム」ケツコンシキノシタクセヨ」アスペキンタツ」オオスミチユウタロウ　同時に電報｜為替で百円送られて来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "点取虫だといわれて、初めてはっと気が付くと、豹一はもう首席という綽名に芸もなくやに下って居られなくなり、自分が余り勉強もせずに首席になれたことを思いこませようとして、試験の前日には必ず新世界の第一朝日劇場に出掛けてマキノ映画を見、試験の日にそのプログラムの紙をもって来て見せるのだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ起った今度の事件なので、草川巡査は最初からチョット一つタタキノメされたような感じで、一種異様な興奮――緊張味を感じているのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウグヒスハ　ヘイノ　ウヘヤ、ツバキノ　エダニ　トマツテ、「ケキヨ、ヨ　ケキヨ、ヨ」ト　ナキマシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　マタ　サツキノ　フトイ　コヱデ、「ワタシハ　ウマデス、チツトモ　オソロシイ　モノヂヤ　アリマセン」ト　イヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレハ　ホントニ　イツピキノ　テフテフデ　アリマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゴカキ新美南吉　ツキヨノ　マツナミキノ　ミチデ　一リノ　サムライガ、ウシロカラ　ハシツテ　キタ　カラノ　カゴニ　ノセテ　モラヒマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト、ウシロノ　ハウガ　イヒマスト、マヘノ　ハウガ、「モウ　スコシ　サキノ　ガケノ　上カラ　タニ川ヘ　ホリコンデ　ヤラウ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト、カゴカキノ　一リガ　ツエヲ　フリナガラ、「オーイ、ダンナア。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルト　サムライ新美南吉　五ニンノ　サムライガ　タビヲ　シテ　アル　ヒ　ヤマミチヲ　トホリカヽルト、木ノ　下ニ　一ピキノ　サルガ　ヰマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビヨウキノ　サルヲ　キツテモ　シカタナイト　イフノデ、五人ノ　サムライハ、ソノ　サルヲ　ツレテ　ユキマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダ　サツキノ　コワイ　カホデス。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテ、コノ　オハナシハ、マダ　ソノ　タケノコガ　ヂビタノ　ナカニ　ヰタ　トキノ　コトデス。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　テフテフハ、キノハノ　アヒダヲ　クグツテ　ソラ　タカク　トンデ　イキマシタ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンデンムシノ　カナシミ新美南吉　イツピキノ　デンデンムシガ　アリマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヘノ　ナカニハ　フタリノ　トシヨリガ　ヰテ　チヨウド　ヒトツノ　パンヲ　フタツニ　キラウト　シテ　ヰル　トコロデシタガ、ハラノ　スイタ　ヲトコヲ　キノドクニ　オモツテ　パンヲ　ミツツニ　キリ、ソノ　ヒトキレヲ　ヲトコニ　メグンデ　ヤリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲトコハ　コノ　ヒトビトガ　キノドクニ　ナリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソウダ、コノ　キノドクナ　ヒトビトヲ　タスケテ　ヤラネバ　ナラナイ」　ヲトコハ　アチラ　コチラノ　ムラニ　ノコツテ　ヰル　ヒトビトヲ　ヒトトコロニ　アツメマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミズノ　ナカニハ　イツピキノ　サカナガ　シヅンデ　ヲリマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンノキノ　シタデ　オカアサンノ　タヌキガ　コドモノ　タヌキニ　バケル　コトヲ　ヲシヘテ　ヰマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　ハンノキノ　シタニ　コロガツテ　ヰマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムラヒハ　ゲタノ　ヲヲ　キツテ　コマツテ　ヰル　トコロデシタノデ、「ヤ　コレハ　ウマイワイ、ココニ　ゲタガ　オチテ　ヰル」ト　イツテ、コドモダヌキノ　バケタ　ゲタヲ　ハキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "キノ　カゲカラ　コノ　ヤウスヲ　ウカガツテ　ヰタ　オカアサンダヌキハ　タイヘンナ　コトニ　ナツタト、メヲ　マンマルクシテ　オドロキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカアサンタヌキハ　シンパイシテ、キノ　カゲヲ　カクレテ　サムラヒノ　アトヲ　ツイテ　イクノデス。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムラヒハ　ゲタヲ　カツテ、コドモタヌキノ　バケタ　ゲタヲ　オモテニ　ダシテ　ヤリ、オアシヲ　ヒトツ　ヤツテ、「ヤ、ゴクラウダツタノウ」ト　イヒマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コドモダヌキハ　オアシヲ　モラツタノデ　サツキノ　クルシサモ　ワスレテ、ヨロコビ　イサンデ　カヘツテ　イキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツピキノ　シロイ　テフテフガ　フウセンダマノ　トコロヘ　マイニチ　トンデ　キテ、イチンチヂユウ　アソンデ　イクノデシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルサメノ露ノヤドリヲ吹ク風ニコボレテ匂フヤマブキノ花　天真爛漫とでも申しませうか。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノッソリ出テ来テ、蠅タタキノ如ク、バタットヤッテ、ウムヲ言ワサヌ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半島の西部の金木地方も、山菜はなかなか豊富であるが、この蟹田地方も、ワラビ、ゼンマイ、ウド、タケノコ、フキ、アザミ、キノコの類が、町のすぐ近くの山麓から実に容易にとれるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
