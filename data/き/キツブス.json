    "definitions": [
      {
        "index": 1,
        "gloss": "to wear out (clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
