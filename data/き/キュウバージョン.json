        "examples": {
          "standard": [
            {
              "text": "新しいアプリにアップデートしたら、前のバージョンにはなかった機能が増えてて驚いたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このゲーム、旧バージョンの方が好きだったな。なんか操作感が違ってて。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "取引先から、旧バージョンでは対応できないと言われたので、急いでシステムを更新しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会社のデータベースは、セキュリティのために必ず最新バージョンに保つようにしているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一方でＭＳ―ＤＯＳがバージョンアップを繰り返す中で、日本市場のユーザーの多くはアプリケーションの陰に隠れた旧バージョンを、その存在すら意識せずに使い続けていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
