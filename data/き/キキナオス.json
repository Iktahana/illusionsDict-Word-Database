    "definitions": [
      {
        "index": 1,
        "gloss": "to listen again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と聞き直すように小頸をかしげて私のほうを見て、当惑そうに幽かに笑いました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と聞き直すように、私の顔を見つめます。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と聞き直すと、彼女はけろりとして、「ああ忘れちゃった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "与次郎が野々宮君を知ろうとは思いがけなかったから、念のため理科大学の野々宮さんかと聞き直すと、うんという答を得た。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "与次郎が野々宮君を知らうとは思ひがけなかつたから、念の為め理科大学の野々宮さんかと聞き直すと、うんと云ふ答を得た。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ」と甲野さんは聞き直す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御前あすこへ行く気があるのかい」「宗近へですか」と聞き直す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「驚いたかい」と今度は兄が聞き直す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君はどこへ」とまた聞き直す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「欽吾にかい」と母が聞き直す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこで、もう一度聞き直す。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と聞き直すと、とにかくこの辺らしいという。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩三　　わかつてることを聞き直すな。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "内の松がとうとうやられました」「どうしたんです」と聞き直すと、　煤煙のために庭の松の木が枯れたということであった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞き直す主人はよほど愚だと思っていると、主人は何にも分らずに吾輩の頭を叮嚀に撫でている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き直すまでもない、それは竜之助として、甲州の月見寺以来熟しきった、お喋り坊主の音声に相違ありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から婦人の間には「見直し聞直し」といって、悪いとされることをも善く見直し、醜聞として伝わってくることをも聞き直すようにする―というように、すべてに愛の母心が強調されている。",
              "citation": {
                "source": "女性史研究の立場から",
                "author": "高群逸枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしも一度聞き直すのは、彼の自尊心が許さなかった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵は、相手のことばを、耳を洗って聞き直すように、しばらくだまっていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イントロダクションのところをもういちどききなおすと、ワラは、高志と慶一のほうにむきなおった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学問に関しなかばモーロクしかけた師よりもはるかに熱心な弟子にむかって質問の内容をききなおすのである。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃききなおすから、堪忍してくれ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
