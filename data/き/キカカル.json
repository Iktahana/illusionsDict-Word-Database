[
  {
    "uuid": "71d178d2-ef9d-58ce-8ec1-a93a80ce8196",
    "entry": "来掛かる",
    "reading": {
      "primary": "きかかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to happen to come",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ふと昔馴染みの店に立ち寄ると、ちょうど恩師が店に来掛かるところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あら、いいところに！ちょうど今、あなたの噂をしていたところへ来掛かるなんて」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事件の現場を偶然通り掛かった、いや来掛かった者の証言によれば、犯人は西へ逃げたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こんな事を、幾分かの注意を払って見た為めに、歩調が少し緩くなって、家の真ん前に来掛かるまでに、数秒時間の余裕を生じた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎がそこへ来掛かると、本箱が崩れ墜ちた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は来掛かる人に彼問を試みて、怖るべき面貌を見せたのであるが、柏軒は近視で其面貌を見なかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "音をたてると私の心が揺れる、目が薄明るい地平線を逐ふ……黒々と山がのぞきかかるばつかりだ――失はれたものはかへつて来ない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "音も立てずに、黒い蛇腹が前にのめり出しで、そしてそのうしろから火炎の昇騰してゐる、高い塀が、音もなしに傾きかかる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、なほも蜂の體につつ突きかかると、すぐ嘴が松葉に噛みついた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前景のなかへ、右手からも杉山が傾きかかる。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "界隈の男女達は潮のようにこの十字路へどよめきかかる。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同、どやどやと行きかかる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通りぬけて行きかかると、その子供の群れは一度にばらばらと駈けよって来て、地に映っているおせきの黒い影を踏もうとした。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和尚の居間はどこだね」「こっちですよ」　友吉は先に立って行きかかると、半七もふた足三足ゆき掛けたが、また小戻りして松吉にささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "お邸の裏手から、山へ這入るところに柿の樹と、桑の畑があったが、梅雨があけてから小作人の一人が山へ行きかかると、そこの一番大きい柿の樹の根方から、赤ん坊の足が一本洗い出されて、蟻と蠅が一パイにたかっているのを発見したので真青になって飛んで帰った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土橋を渡って、西仲通りに歩るきかかるとちらほら町には灯が入って来た。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（靴をはきかかる）三男　　あ、次郎ちゃんは、ぼくの靴をはいてる。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、靡きかかる煙の中に、夫人の顔がちらちらと動いて、何となく、誘われて膝も揺ら揺ら。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前垂の下で手を揉みながら、手代が立って、五足ばかり行きかかると、（多一、多一、）と呼んだ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に負傷したる敵兵三人、――あるものは白き布にて右の腕を吊したり――日に焼けたる絶望の顔をよせてそこはかとなきかかる日の郷愁に悩むがごとく珍かにうち眺めたる……足もとの黄色なる花湿りたる土の香のさみしさに※りつつうち凋る。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあたりの潮が吹きかかる岩の間から、澤山のみそばへ並に岩れんげが生えてゐるのを二三株摘み取り、僕はそれを瀧と一軒家と自分の馬に瀧の水を飮ましたとのなつかしい記念にした。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫の目のあきかかるころになってから、時々棚の上からおろして畳の上をはい回らせた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また血はそこに働く人々の白いシャツにも飛沫きかかる……、豚はそこにころりっと倒れて屍となる。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしと幸次郎と善八、この三人が宿屋を出て、六所明神の社をさして行きかかると、今も申す通り、随身門までは右も左も松杉の大きい森、その森を横に見ながら辿って行くと、幸次郎がだしぬけにあっと云う。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが次第に舞い下がって、大樹の上にひらめきかかると、何物かが木の葉のようにばらばらと降って来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田は又行きかかるを、柳は又ひき留める。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（弥三郎は向うへ行きかかる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二人は行きかかる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　行きかかる小坂部の袂にまた取り付いて、師直は悲しそうな声をあげた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほてった彼の顔から耳にかけて埃を含んだ風が息気のつまるほどふきかかるのを彼れは快く思った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤットそれを直してまた行きかかると、「オイオイ手を振ってはイカン」とまた叱りつけられる。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五柔かきかかる日の光のなかに、いまひとたび、あはれ、いまひとたび、ほのかにも洩らしたまひね、われを戀ふと。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかうどの友よ、美くしきかかる日の夕暮に、さは疎くたれこめてのみ、なにごとをか思ひわづらひたまふ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
