          "standard": [
            {
              "text": "大規模なデモ行進に備え、機動警察の防護車両が主要な交差点の各所に配置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわ、あそこに停まっている黒塗りの大型バン、機動警察の特殊車両じゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際会議の会場周辺では、機動警察による24時間体制の厳重な警備が敷かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末の繁華街の治安を維持するため、機動警察によるパトロールが深夜まで強化される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "機動警察隊　怪人を乗せてきた自動車は、もとの町角で、じっと待っていました。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが機動警察って言うんだよ。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
