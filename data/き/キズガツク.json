[
  {
    "uuid": "fc9d0425-28ac-55a1-b1f5-64b4031b3190",
    "entry": "傷がつく",
    "reading": {
      "primary": "きずがつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
