          "literary": [
            {
              "text": "」　ホームズはほくそ笑み、長くきめ細やかな手をこすり合わせた。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "かならず、かれの小説と、混同すべからず、かれのあの、きめこまやかなる文章と。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　　　精神永遠無窮な水精は、　　きめこまやかな水｜分割て。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、時間は充実して、それ故きめこまやかに重く平らにすぎていて何といい心持でしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
