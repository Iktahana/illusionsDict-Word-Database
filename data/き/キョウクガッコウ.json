        "examples": {
          "standard": [
            {
              "text": "うちの子は、カトリック系の教区学校に通わせることにしました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この辺りには、評判の良い教区学校がいくつかあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教区学校の文化祭には、地域の人々もたくさん訪れて賑わっていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統ある教区学校で、子供たちが豊かな人間性を育んでくれることを願っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一九一七年までその教師は近所の村の教区学校の教師をしていた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう仕事がすむと教区学校以来二十年の経験をかさねた小学校教師として、コンムーナの文化向上を終身の職務としてやっている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
