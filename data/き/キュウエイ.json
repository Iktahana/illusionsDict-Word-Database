        "examples": {
          "standard": [
            {
              "text": "古びた文庫本の余白には、かつての持ち主が自作したと思われる美しい旧詠が鉛筆で書き残されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の遺品である革表紙の日記帳をめくると、若かりし頃に異郷で詠んだ旧詠がいくつも綴られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文芸誌の特集記事で、万葉集に収められた名もなき民の旧詠を現代的な視点から再解釈する試みを読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "故あつて俳句の吟詠を廃した今日の私に最早句と云へばみな旧詠のおもひで許りしかないやうに、私の東京の街々に関する談叢も亦みな過去のこと以外にはなくなつてしまつた。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
