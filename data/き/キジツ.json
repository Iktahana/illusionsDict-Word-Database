      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fixed date",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし方数十里の地域に起るべき大地震の期日を数年範囲の間に限定して予知し得るだけの科学的根拠が得られるか否かについては私は根本的の疑いを懐いているものである。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "税金を期日までに納めんような者が、お前、息子を中学校へやるとは以ての外じゃ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つにはまだ年が行かない一人子の初旅であったせいもあろうが、また一つには、わが家があまりに近くてどうでも帰ろうと思えばいつでも帰られるという可能性があるのに、そうかと云って予定の期日以前に帰るのはきまりが悪いという「煩悶」があったためらしい。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ此秘密造船所を出づる前に、一言聽きたきは、海底戰鬪艇の竣成の期日と、此艇の如何に命名されるかとの點である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今吾等は、重大の使命を帶びながら、何時大陸へ着くといふ目的も無く、此儘に空中に漂蕩して居つて、其間に空しく豫定の期日を經※してしまつた事ならば、後悔臍を噛むとも及ぶまい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も、目下の急丈けを、かの軍艦に助けられて、何處でもよい、最近の大陸地方に送り屆けて貰つたならば、其後は必死に奔走して、如何にかして、豫定の期日までに約束の凖備を整へて、櫻木大佐等が待てる橄欖島に到着する事の出來ぬでもあるまい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件の公判期日が極つた頃であつた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳子は知らず／＼二十日ばかりの間に、間を置いて七八夜も牧瀬の庭に遊びに行つたが、もう婚約の良人の家へ帰る期日も近づいたので、いよ／＼今夜もう一晩ぐらゐの交際だと思つて、茨の垣の門内に入つた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごしているうちに試験の期日は切迫して来る。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそうした衣服であるから期日も急ぐので、裁縫師は他の仕立物を後廻しにして裁縫にとりかかったが、期日が翌日の朝になっているので、その夜は一時近くまで仕事をして、やっと縫いあげたところで客があった。",
              "citation": {
                "source": "娘の生霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "期日は、明後日正午まで。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり切れないこの気持でいるのにわたしはちょうど向島の三囲稲荷に献額する現代江戸派の俳諧の揮毫を頼まれて、これを書き上げるのに式日まで四五日の期日を剰しているだけだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お君は、「あわれ逢瀬の首尾あらば、それを二人が最期日と、名残りの文のいいかわし、毎夜毎夜の死覚悟、魂抜けてとぼとぼうかうか身をこがす……」　と、「紙治」のサワリなどをうたった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの頃までにはかならず出來するか、あらかじめ期日をさだめてお詫を申せ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　その期日は申上げられませぬ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けて文禄元年正月、太閤秀吉は海陸の諸隊に命じて出発の期日並びに順序を定めた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "期日の五十日を過ぎても明使が来ないので、行長等怪んで居る処へ、計略を含められた惟敬が来って、媾和使の来る近きに在りと告げた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて期日の二十五日も、その翌日も雨なので、攻撃を延期して居る中、二十七日の昼頃、突然鍋島の一隊が命を待たずして攻撃に移った旨を、本営に告げる者があった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の終りになると、芳郎と喜美代との間に結婚話が持ちあがって、その約束が出来たところで、芳郎が神経痛のようになったので、その期日が延びることになった。",
              "citation": {
                "source": "赤い花",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして期日を定めて、その期日ももう三日の後に迫った。",
              "citation": {
                "source": "赤い花",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）僕ちよつと憂鬱をおぼえ、そして、こんなに酩酊してゐるんだが、期日も間に合はぬだらうと思ひ、皆な皆な、ちよつと彼方へ行つておくれ、俺は今！",
              "citation": {
                "source": "秋が深い頃だ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お君は、　――あはれ逢瀬の首尾あらば、それを二人が最期日と、名残りの文のいひかはし、毎夜毎夜の死覚悟、魂抜けてとぼとぼうかうか身をこがす……。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四千部、夕方までに発送を済まさねば、発行期日に間に合わぬというので、社長、妻君、園井、園井の妻君、豹一の五人掛りだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "肚の底から面白がっている訳でもなく、聴いている私もまた期日の迫った原稿を気にしながらでは、老訓導の長話がむしろ迷惑であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで期日を打ち合わして胡は帰って往った。",
              "citation": {
                "source": "胡氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また僕は、その返済期日が過ぎてゐるので、滞京中に何ほどでも始末して、彼の気焔を逃れたく念じて、いろ／＼と厚顔になつて、友達などにも謀つてゐるのであるが、未だ、それが得られないのである。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの貼り紙を自分で書いてピンで貼ったが、そのときじつに淋しい気がした。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいように計らってくれ、こう申しつけましただけで、そのときじつは、その貸方のあて名先を、手前は見なかったのでございます。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、そのときじつは、ぼくは外の春雨以上に、しとゞに醉つてゐたのである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
