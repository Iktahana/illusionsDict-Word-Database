    },
    "definitions": [
      {
        "index": 1,
        "gloss": "changing clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「スポーツバッグの中に、ジムで使う予定の着替えを丸ごと入れ忘れてきちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふぅ、やっと家に帰れた。とりあえず楽な着替えを持って、熱い風呂に入ってくるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「子供の着替えって、なんでこんなにすぐ泥だらけになっちゃうんだろうね。洗濯が追いつかないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "風呂から出て奥の間へ行くと一同の着替えがそろえてある。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは皆して参ってくるがよかろう……いや着物など着替えんでよいじゃないか」　女達は、もう鼻啜りをしながら、それじゃアとて立ちあがる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の幾枚目かの衣裳を着替えて化粧室からあらわれてくる踊子は、その小脇にかかえた口紅棒の汚点のついたハンド・バッグを離さない。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がさめると枕もとにはゆうべの女たちが行儀よく控えていて、さらにお蝶に着物を着替えさせてくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雨のふる晩に、着替えの一枚も持たずに、どこへ飛び出したのでしょう。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会の開催中彼は駿河台に宿を取っていたが、この土地の宿坊にも着替えや書類や尺八などもおいてあり、そこから議会へ通うこともあれば、銀子を馴染の幇間とともに旅館へ呼び寄せることもあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって、銀子は風呂に入り、土地の習慣なりに、家へ着替えに行くと、主人夫婦もちょうど奥で晩酌を始めたところで、顔を直している銀子に声をかけた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の間に着替えたのか、姉は肩のピンと糊でつっ張った紫と白との疎い棒縞の衣裳を着ていた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと衣物を着替えて来るから待っていらっしゃいよ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはそれをぼんやり眺めて亡父の思い出に耽りながら、どうやら外出着の着物に着替えました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "興醒めた気持になって今井田は服に着替えて出勤の支度をし始めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイの答えによると彼女は今しがたカジノからホテルへ乗馬服と着替えに帰って来て、鞭を持って出て行った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山の明子の家に着くと、明子も急いで和服の盛装に着替えて銀座行きのバスに乗った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安子が学校から帰って、長い袂の年頃の娘のような着物に着替え、襟首まで白粉をつけて踊りの稽古に通う時には、もう隣りの氷店には五六人の若い男がとぐろを巻いて、ジロリと視線が腰へ来た。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親の浴衣を借りて着替えると、蝶子の肚はきまった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、行かないとわるいから、ちょっと顔出しして来るわ」　そして、先に寝んで頂戴と、次の間にはいって、イヴニングを和服に着替えながら、多鶴子はそんな風に言ったことを、若い新聞記者にはちょっと済まなく思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この室は女の衣装を着替える所になっていたので、四面にずらりと衣桁を並ベ、衣紋竹を掛けつらねて、派手なやら、地味なやらいろんな着物が、虫干しの時のように並んでいる。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、着物を着替えてくるわ」　紀久子はそう言って、正勝の顔を自分の顔の上から除けた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「着物を着替えてくるって」「だって！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着替えながら自分の時計に目をやった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "着替えが済むやホームズが戻ってきて、少年が馬の準備をしてくれていると告げた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "今週の月曜、一日を終え、阿片窟の上で着替えをしていて、ふと窓の外を見ると、恐ろしいことに、なんと、僕の妻が通りにいて、こちらに目を注いでいるじゃありませんか。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、もう恐ろしくて寝台にも戻れず、そこで着替えて、夜明けが来ると家を抜け出し、お向かいのクラウン・インという旅館で二輪馬車を頼みまして、レザヘッド駅へ駆けつけ、それからこうして今朝、こちらへお助けをお願いに参ったのでございます。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "着替えたあとで行く。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであわてて着替えて、女中を呼んで厩舎まで行ってみた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――客もなかったし、――めったに出かけなかったし、――たくさんの着替えの衣装もいらなかった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよは気が引けるわけもないけれども、今日はまた何といわれるのかと思うと胸がどきまぎして朝飯につく気にもならない、手水をつかい着物を着替えて、そのままお千代が蚕籠を洗ってる所へ行こうとすると、「おとよ」と呼ぶのは母であった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は外に待っていて、半七だけが小屋へはいると、小柳は楽屋で着物を着替えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をとめてよく見ると、半開きの白ばらの花のかげ――肥料をやりたての根本の赤土の上に生れたばかりの小さいひきがえるがよちよちしている。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきがえるが這出して来るのもこの大きな単調を破るに十分である。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
