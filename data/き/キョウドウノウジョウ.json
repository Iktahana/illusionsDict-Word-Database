        "examples": {
          "standard": [
            {
              "text": "その村では、土地を共有し、農作業を一緒に行う共同農場が運営されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "共同農場での収穫物は、組合員全体で平等に分配されることになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政府は、食糧増産のため、全国に共同農場を設立する計画を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「昔は共同農場で、みんなで汗水流して働いたもんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "共同農場でも同じ様で、大きなものになると、収穫時にはキャンプ生活をやるのだが、その一つのキャンプが「クラブ」になる。",
              "citation": {
                "source": "ソヴェトの「労働者クラブ」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーロホフの『開かれた処女地』には、共同農場に於ける小家畜（禽）共有の失敗が詳しく描写されている。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
