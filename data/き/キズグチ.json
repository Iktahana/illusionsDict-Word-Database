        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "包帯を取り替える際、赤く腫れ上がった生々しい傷口を見て思わず顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、傷口から砂が入ってる……。まずは水で綺麗に洗い流さないと大変だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強い消毒液が傷口に触れた瞬間、彼は痛みのあまり小さく悲鳴を上げて身悶えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医師は顕微鏡を覗きながら、傷口の奥深くに入り込んだガラスの破片を丁寧に取り除いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "剥製の獣じゃあるめえし、傷口に、ただの綿だけ押し込んどいて、それで傷が癒りゃ、医者なんぞ食い上げだ！",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷口のような月は沈んだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傷口からふき出す血でお前の臆病も流れ出てしまう。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少女の未完成と無垢とが彼女の墓の戸を開いたままにさせてをり、そのためその少女は死んでゐても、一方では生の半分をいきいきと保ち、もう一方では他の大きな傷口をひらいてゐる半分の方へ開いてゐるといつた、一種の能力をもつてゐるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間にはその開いた傷口にピンセツトと鋏とがす早く入り交るだらう。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背に、小指のさき程の傷口があるだけであった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗島は、老人の傷口から溢れた血が、汚れた阿片臭い着物にしみて、頭から水をあびせられたように、着物がべと／＼になって裾にしたゝり落ちるのを見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷した同年兵たちの傷口は、彼が見るたびによくなっていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、まだぬくい血が傷口から流れ出ている者があった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷口が痛そうな振りもせず、とっておきの壁の青い別室に坐りこんでいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火酒は、戸棚の隅に残っていた、呉は、それを傷口に流しかけた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュンセ童子が大烏の胸の傷口に口をあてました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　チュンセ童子が黙って傷口から六｜遍ほど毒のある血を吸ってはき出しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早く流れでその傷口をお洗いなさい。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして奇麗に傷口を洗ってやって、その上、傷口へ二三度｜香しい息を吹きかけてやって云いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は泉の水をすくって、傷口にかけて奇麗に洗いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば月を断ち切る雲が、女の目を切る剃刀を呼び出したり、男の手のひらの傷口から出て来る蟻の群れが、女の腋毛にオーバーラップしたりする。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の幹がその特殊な皮はだをこれ見よがしに葉漏りの日の光にさらして、その古い傷口からは酒のような樹液がじんわりと浸み出ていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林に這入つて木の幹を見上げると傷口といふ傷口からは樹液がねつとりと溢れ出て、そのまはりには早くも殼をぬけ出たばかりの小さな蟲達が黒々と集つてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞ましい雄獅子が自分と妻の致命的な傷口を嘗め労わりつつ呻く、絶体絶命の呻きです。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると倒れた方のまっ二つになったからだがバタッと又一つになって、見る見る傷口がすっかりくっつき、ゲラゲラゲラッと笑って起きあがりました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭をほんのすこし下げてお辞儀をして、「まだ傷口がよくくっつきませんから、粗末なおじぎでごめんなさい。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでも今のうちに、この海に向いたほうへボーリングを入れて傷口をこさえて、ガスを抜くか熔岩を出させるかしなければならない。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子の体はもうすっかり傷口を繃帯して、綺麗に拭き浄められてあった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、たいした事じゃないがね、たまには、高円寺のほうへも遊びに来てくれっていう御伝言さ」　忘れかけると、怪鳥が羽ばたいてやって来て、記憶の傷口をその嘴で突き破ります。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘆きや悲しみさえも小唄にして、心の傷口を洗って呉れる。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は膝頭に突きささっている鉛の弾を簡単にピンセットで撮み出して、小さい傷口を消毒し繃帯した。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、そのようにおおらかな、まるで桃太郎のように玲瓏なキリストのからだの、その腹部に、その振り挙げた手の甲に、足に、まっくろい大きい傷口が、ありありと、むざんに描かれて在る。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
