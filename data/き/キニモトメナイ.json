[
  {
    "uuid": "b7c9c00b-23fc-59b2-9d8c-3d5c0ff8bbdd",
    "entry": "気にも留めない",
    "reading": {
      "primary": "きにもとめない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
