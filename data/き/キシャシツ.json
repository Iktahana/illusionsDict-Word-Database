        "examples": {
          "standard": [
            {
              "text": "発表が終わると、記者は皆、慌ただしく記者室へ戻っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "締め切り間際の記者室は、電話のベルやキーボードの音で騒がしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、記者室で原稿を書き上げ、送信ボタンを押した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの芸能スキャンダルの日は、記者室も寝る間がなかったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへ倉島竹二郎がやつてきて、オイ、記者室の方で升田と原田がやつてるが、あつちぢや、塚田よしの結論だぜ。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつは、面白い」　と、豊田三郎が記者室へ走つて行つた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も記者室へ行つて、原田八段から説明をきいたが、必ずしも塚田がいゝといふ結論ではない。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁の新聞記者室などでも、平素から人交わりをして呉れぬのだから、このくらいの屈辱には馴れ切っている筈の古市加十でも、満座の中でこれほどまでに晴れがましい恥辱を受けてはさすがにもはやいたたまれない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は智恵子の心の動きを見たかったのだよ」　花房一郎は斯う言って記者室を出て行きました。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
