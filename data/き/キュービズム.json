        "examples": {
          "standard": [
            {
              "text": "ピカソやブラックが提唱したキュービズムは、近代絵画に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "美術館で、様々な角度から対象を描いたキュービズムの作品を鑑賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この画家の作品は、幾何学的な形状と複数の視点を組み合わせたキュービズムの手法が特徴的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それで絵画におけるキュービズムやフュチュリズムの運命が、おそらくはこの種の映画の行く末を見せてくれるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術界におけるキュービズムやフツリズムが直接五官の印象を離れた概念の表現を試みているのとかなり類したところがないでもない。",
              "citation": {
                "source": "科学者と芸術家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「新感覚派」が『文芸戦線』の文学的傾向とは全く対蹠的なキュービズムやダダイズム、構成派の影響を強く受けて、それを独自なよりどころとしようとしたことも充分うなずける。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、或人のように、眼の眩めくキュービズムにも。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解釈」から絵を描けば、一方において唯美主義やデカダンスが生れ、一方においてキュービズム、アブストラクト、シュールその他が生れる。",
              "citation": {
                "source": "ゴッホについて",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
