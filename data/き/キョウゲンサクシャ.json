    },
    "definitions": [
      {
        "index": 1,
        "gloss": "house playwright (of kabuki)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが江戸じゅうの噂になったので、狂言作者の名人南北がそれを清玄桜姫のことに仕組んで、吉田家の息女桜姫が千住の女郎になるという筋で大変当てたそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後は多く振るわざりしが、江戸末期における著名の狂言作者の一人にて、黙阿弥らの先輩なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、狂言作者二代目河竹新七向島の梅屋敷に初代新七の石碑を建立し、荵塚という。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸末期には黙阿弥と対抗する著名の狂言作者にて、「佐倉宗吾」「切られ与三郎」「うわばみお由」など、その代表作と称せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙阿弥の高弟にて大阪における著名の狂言作者なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言作者として南北以後の大家と称せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一年（戊戌）　一八九八○一月三日、狂言作者久保田彦作死す、五十三歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "河竹能進の子にて、明治三年以来大阪に赴き、遂に京阪随一の狂言作者となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙阿弥翁もそれに勢いを得て、つづいて「小幡小平次」をかき、「忍ぶの惣太」を書き、ここに初めて狂言作者としての位地を確立したのであるという。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうわけで、お岩稲荷の縁起は、徹頭徹尾おめでたいことであるにも拘らず、講釈師や狂言作者がそれを敷衍して勝手な怪談に作り出し、世間が又それに雷同したのである。",
              "citation": {
                "source": "四谷怪談異説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説界には最早二三世紀とも言ふべき程の変遷あり、批評界も能く変じ能く動きたるに、劇詩のみは依然として狂言作者の手に残り、如何ともすべき様なし。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯貴人が往々文芸の士を羅致して、声威を張り儀容を飾る具となすように、藤次郎は俳諧師、狂歌師、狂言作者、書家、彫工、画工と交って、その多数を待つことほとんど幇間と択ぶことが無かった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言作者には河竹新七、次で瀬川｜如皐がある。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠に当日叱られたということが、かれらに取ってはおあつらえ向きの材料で、お紋の母はそれから趣向をうみ出して、一個の狂言作者となりすましたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから芝居とすれば、座長が後藤新平で、市会議員中の或る一派が狂言作者でなければならぬが、同じ後藤系の人物を抜きさしするのに、何でこんな芝居を打たなければならぬのであろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三幕目の常磐津は座の都合で長唄に変更することになったのは我々もかねて承知していたが、狂言作者の一人は脚本を持って来て「これをどうぞ長唄にすぐ書き直してください」と、皮肉らしく云った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代には小説作者と狂言作者とのあいだに一種の不文律があって、非常に大当たりを取った小説は格別、普通は小説を劇化しない事になっていた。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今晩も狂言作者で名高い河竹其水（黙阿弥の俳名）さん、戯作で売り出しの鈍亭魯文先生なぞがお見えになって居ります。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際その当時の戯作者や狂言作者が寄席の高坐から種々の材料を摂取していたのは、争いがたき事実であった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その葬式の当時、兄の団十郎はわたしの父にむかって、「弟は早く役者をやめさせて、もっとたくさんに本をよませて、狂言作者にすれば好かったのでした。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵本の特色は、狂言の名題や役割以外に、狂言作者や、チョボの浄瑠璃を語る太夫や、長唄の一座や、それらの連名を記入してあることで、普通の番附には狂言作者の名などを記さないのが例である。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵本を見れば、その終りに狂言作者として、鶴屋南北その他の連名が記入されているから、ここに初めて「四谷怪談」はその立作者たる鶴屋南北の作であることが見出だされるのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "詮議の結果、それは狂言作者の一人で『歌舞伎新報』の編集者たる久保田彦作の仕業に相違ないと決められて、久保田氏がその抗議の矢おもてに立つ事になった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内状には必ず堀越秀という本名を記し、最初の二、三回は本人の直筆であったが、その後は狂言作者の竹柴瓢三の代筆になったということである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで、父はわたしに何の職業をあたえるという定見もなく、わたしもただぼんやりと生長してゆく間に、あたかも演劇改良などが叫ばれる時代が到来したので、わたしも狂言作者になってみようかと父に相談すると、それも好かろうと父はすぐに承認してくれた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座の絵本に、狂言作者竹柴なにがし並木何某とある中で、榎本君ひとりが榎本虎彦と本名を名乗っているのが、その時代としては珍らしく見られた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれらはいずれも原作そのままを上演されたのではなく、みな在来の狂言作者の改竄を経たのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ばかりではない、狂言作者のうちで、かの三代目｜瀬川如皐や三代目｜桜田治助のごときも明治以後は一向に振わなくなった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて座附の狂言作者の竹柴なにがしが二階から降りて来た。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
