        "examples": {
          "standard": [
            {
              "text": "戦時中、多くの人々が労働力として炭鉱や工場へ強制連行された悲劇を忘れてはならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警察は容疑を否認し続ける男を、パトカーへ強制連行していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いきなり腕を掴まれて強制連行されるなんて、まるで映画のワンシーンみたいだった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デモ隊の一部が暴徒化し、首謀者と見られる男たちが次々と強制連行された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "山に強制連行されたそうです。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
