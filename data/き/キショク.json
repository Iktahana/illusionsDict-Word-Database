[
  {
    "uuid": "d80de1ce-1a5d-5660-af43-57c794f4bb94",
    "entry": "喜色",
    "reading": {
      "primary": "きしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
