[
  {
    "uuid": "258ebff3-63a0-5409-abf8-61c738d7afcb",
    "entry": "虚心坦懐",
    "reading": {
      "primary": "きょしんたんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
