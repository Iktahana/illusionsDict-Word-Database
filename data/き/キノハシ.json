[
  {
    "uuid": "809fd0ed-f24f-520a-b390-63b90adbc5e5",
    "entry": "木の端",
    "reading": {
      "primary": "きのはし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
