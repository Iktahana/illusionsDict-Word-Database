    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fragment of wood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "工作の授業の後、床に散らばった木の端を拾い集めてゴミ箱に捨てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焚き火の火を絶やさないよう、手近にあった木の端を少しずつ投げ入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大工さんがノミで削り出した木の端からは、清々しい檜の香りが漂ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分はあんな木の端のような男のために、そして下らない喧嘩のためこのように気が上釣ってしまうのが腹立たしかった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ立去りぎわに名残惜しくてや、両手もて輪をつくり、抱くように胸のあたりまで火の上にかざしつ、眼しばだたきてありしが、いざとばかり腰うちのばし、二足三足ゆかんとして立ちかえれり、燃えのこりたる木の端々を掻集めて火に加えつ、勢いよく燃え上がるを見て心地よげにうち笑みぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし御覧の通り、木の端同然のものでありますので、別に名告りますほどの苗字とてもありませぬ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の加減のよいときは、わたくしを木の端か竹の端かのようにあしらいながら、病気が重って来ますとどういうものかまた周章てわたくしを重んじて来まして、「神様からの預りものを、今まで粗末にして勿体ない／＼」　と言って、ときには震える手を合せて、わたくしを拝むような真似をすることがあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして親子の座席にしている材木の端に腰をかけた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり僕は、――盗んだ豚を殺してからではとても一人では持てないから、生かしたままで線路まで連れて来て、さてそこで上手に汽車に轢かせる様にするためには、単に縄を枕木の端の止木の釘と反対側に立っている里程標との間へ渡して、その真ン中へ豚を縛った位では到底三遍も四遍も成功する事は出来まい。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの農夫が木の端くれで刻んだか、紙きれで折つたかといつたやうな、いはゆる農民芸術の味があるのはこの花です。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく其材木の端に腰掛けて、昔の事を懷うて見ようかとも思つたが、イヤ待て恁な晝日中に、宛然人生の横町と謂つた樣な此處を彷徨いて何か明處で考へられぬ事を考へて居るのではないかと、通りがかりの巡査に怪まれでもしては、一代の不覺と思ひ返へして止めた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく其材木の端に腰掛けて、昔の事を懐ふて見やうかとも思つたが、イヤ待て恁な昼日中に、宛然人生の横町と謂つた様な此処を彷徨いて何か明処で考へられぬ事を考へて居るのではないかと、通りがかりの巡査に怪まれでもしては、一代の不覚と思ひ返して止めた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧句人句集「木の端集」を読み直して、君の熱意と巧妙とにうたれた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌詠む人の方便とのみ思ひ居し戀に惱みしと言ふさへあるに、木の端とのみ嘲りし世捨人が現在我子の願ならんとは、左衞門｜如何でか驚かざるを得べき。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方より暇乞ふ迄もなし、人の數にも入らぬ木の端は、勿論親でもなく、子でもなし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧口時頼が發心せしと、誰れ言ふとなく大奧に傳はりて、さなきだに口善惡なき女房共、寄ると觸ると瀧口が噂に、横笛轟く胸を抑へて蔭ながら樣子を聞けば、情なき戀路に世を果敢なみての業と言ひ囃すに、人の手前も打ち忘れ、覺えず『そは誠か』と力を入れて尋ぬれば、女房共、『罪造りの横笛殿、可惜勇士を木の端とせし』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "途方に暮れて立つてゐると、Ｓ君が漸く流木の端へ両手をかけて爬ひ上つて来た。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ人の云うところの soyu（醤油）や食える木の端（鰹節）を米とともにいさぎよく――海峡の彼方へ置いて来た。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそあれが何であるかを確めたいと思つて、私は欄干の側まで出て、伸べ首をしてゐたが、見れば見るほど、あんな木の端のやうなものを、どうしてあゝ大事にするのかと、それが分らなくなつた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、推摩居士にはそれが何処にあるかと云うと、現に義足を見れば判る通りで、腓骨の中央で切断されている擂木の端にはなく、却って、膝蓋骨の下の腓骨の最上部にある。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と留吉は、切らずともよい、可成り大事な枝を、自棄で、つい切って了い、「ほいほい、木の端くれか、……と、うっかり木の端くれを切ったが、こいつ親方に叱られそうだぞ。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と、いうようなことはお預けとしておいて、木の端くれだなんて云わずに、どうですい、この留吉へも、……」　お力は返事もしないで、木間を隙して、離座敷の方を眺めた。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは到底人に好かれる性でないとあきらめて居たから、他人から木の端の様に取り扱はれるのは何とも思はない、却つて此清の様にちやほやしてくれるのを不審に考へた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは到底人に好かれる性でないとあきらめていたから、他人から木の端のように取り扱われるのは何とも思わない、かえってこの清のようにちやほやしてくれるのを不審に考えた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "成範が返歌を考へて居る処へ、重盛が上つて来たので、急いで立ち退きしなに、燈楼のかきあげの木の端で、や文字を消して、ぞの字を書きつけて、御簾の中に、さし込んで退出した（十訓抄）と言ふのが、其である。",
              "citation": {
                "source": "鸚鵡小町",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からの強風にかてて加えて、火勢の呼び起すつむじ風もすさまじいことで、御泉水あたりの巨樹大木も一様にさながら箒を振るように鳴りざわめき、その中を燃えさかったままの棟木の端や生木の大枝が、雨あられと落ちかかって参ります。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からの強風にかてて加へて、火勢の呼び起すつむじ風もすさまじいことで、御泉水あたりの巨樹大木も一様にさながら箒を振るやうに鳴りざわめき、その中を燃えさかつたままの棟木の端や生木の大枝が、雨あられと落ちかかつて参ります。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理の実験室などでも、不用なものはどんどん棄てて、いつも砥ぎすました鎌のような気持で仕事を進めて行く人もあるし、随分くだらぬ木の端や真鍮板の片のようなものまで溜め込んで、玩具箱をひっくり返したような中で研究をしている人もある。",
              "citation": {
                "source": "米粒の中の仏様",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其を木の端か何ぞのように、一月も寝ていればいいなんて何事だろう。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを私が教えると、伊勢屋の旦那は釣竿を片手に、材木の端っこまで乗出して水の中を眺めました」「…………」「泳ぎの自慢な旦那でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまめかしい緋縮緬の胴抜きの部屋着は、その襟から抜け出した白い頸筋をひとしお白く見せて、ゆるく結んだ水色のしごきのはしは、崩れかかった膝の上にしどけなく流れていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、たしかにこの中に、猫みたいなものがはいっているぞ」「そこで、ふろしきの中をのぞいてごらん」　青二は、ふろしきのはしをすこしあけて、六さんに中をのぞかせた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、もし一度彼女をごろうじ遊ばしましたらお二方とて此の私が、こうまで慕うのが無理はないと、屹度御解り下さいます」「ほんにそなたをそれ程に迷わせた、乙女を拙者達も見たいもの、のう、露月どの」「わしも絵かきのはしくれじゃ。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
