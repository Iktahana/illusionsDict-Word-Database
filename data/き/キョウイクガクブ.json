        "examples": {
          "standard": [
            {
              "text": "彼は将来、先生になりたいという夢を抱き、教育学部への進学を決めたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その大学の教育学部は、特に心理学や発達学に強いことで知られているそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教育学部で学ぶことで、学校教育のシステムや歴史について深く理解できたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学のオープンキャンパスで、教育学部の先生や学生の話を聞いてきたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "現役の受験となった一九七四（昭和四十九）年、美大には軒並みふられたものの、静岡大学教育学部の美術専攻に受かりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖怪学講義第一類　　総論第二類　　理学部門第三類　　医学部門第四類　　純正哲学部門第五類　　心理学部門第六類　　宗教学部門第七類　　教育学部門第八類　　雑部門　これ実に講義の順序なり。",
              "citation": {
                "source": "妖怪学講義",
                "author": "緒言",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とおなじ大学の教育学部の三年生だ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
