    "definitions": [
      {
        "index": 1,
        "gloss": "Empire Day (February 11th; national holiday held from 1872 to 1948)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "』大佐は滿面に笑を堪へつゝ『無論躊躇する必要はない、我が海底戰鬪艇も、今日から十｜日目の紀元節の當日には、試運轉式を行ひ、其後一週間以内には、總ての凖備を終つて、本島を出發する豫定だから、紀念塔の建立も其以前に終らねば――。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十一回　空中の救ひ何者にか愕いた樣子――誰かの半身が現はれて――八日前の晩――三百反の白絹――お祝の拳骨――稻妻と少年と武村兵曹　指を屈して見ると、當日は吾等が海岸の家を去つてから、丁度九日目で、兼て海底戰鬪艇の試運轉式の日と定められたる紀元節の前日である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十二回　海の禍孤島の紀元節――海軍大佐の盛裝――海岸の夜會――少年の劍舞――人間の幸福を嫉む惡魔の手――海底の地滑り――電光艇の夜間信號　二｜月十一｜日、待に待つたる紀元節の當日とはなつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて夫よりは、紀元節の祝賀と、此大なる成功の祝とで沸くが如き騷ぎ、夜になると、兼て設けられたる海岸の陣屋で大祝賀會が始まつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "華族の御孃さんから惚れられたなんて妙なのが出て來るでせう　今日は紀元節でいゝ天氣です、一昨日は雪でね。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上　　　　　　　　二月十一日紀元節朝金　　　　　三重吉樣　　　　　　　　　　三三八　明治三十九年四月十一日　午後十一時―十二時　本郷區駒込千駄木町五十七番地より廣島市江波村築島内鈴木三重吉へ　御手紙も小説も屆いて只今兩方とも拜見千鳥は傑作である。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年たち、紀元節の大赦で二日早く刑を終えると読み上げられた時、泣いて喜んだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の紀元節の夜にいよいよ婚礼ということに相談が進んで、溝口矢田の両家ではその準備もおおかた整った一月二十九日の夜の出来事である。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年経ち、紀元節の大赦で二日早く刑を終えると読み上げられた時、泣いて喜んだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "対局の終つたのは、七日目の紀元節であつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年紀元節号「日本及日本人｣に、山内嵒氏いはく、雲南の大理府はこの草の原産地で、外国人はじめてこの花を広東で見た時、何の花ぞと問ふと大理牙（ダリヤです）と答へたるをそのまゝ花の名としたのだと。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　紀元節に学校の式を休んで、翌日もまた学校を休んだ。",
              "citation": {
                "source": "焚いてしまふ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時迄も百姓ばジッとさせて、何時迄も勤勉に仕事ばさせて置くためには、新聞でこい、雑誌でこい、紀元節でこい、徴兵検査でこい、青年訓練所でこい、機動演習でこい、学校でこい、みんなその目当てのためにドンドン使ってしまうんだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元節の日には校門には日章旗が立てられ、講堂からはオルガンが聞こえた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば紀元節、神武天皇祭等時日一定せる者は論を俟たず、氷店を夏とし焼芋を冬とするも可なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雪、紀元節、建国祭。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧の正月元日、そして紀元節、建国祭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元節、建国祭、今日から国民総動員第二強調週間。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元節、新らしい世紀を意識し把握し体得せよ、殆んど徹夜だつた、句稿整理。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学生たちは、千家尊宜が軍国的建国記念日としての伝統をもっている日本の紀元節を国祭日として主張するとき拍手を送った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林さん、金田さんに一日二日手伝って貰い、紀元節の日、半月前には、予想もしなかった引越しを行った。",
              "citation": {
                "source": "又、家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）・冬の山からおりてくるまんまるい月・枯枝をまるい月がのぼる・月へいつまでも口笛ふいてゐる・月のよさ、したしく言葉をかはしてゆく・月のあかるさが木の根　二月十一日　紀元節、そして建国祭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日は紀元節で、見窄らしい新開街の家々にも國旗が飜つて見えた。",
              "citation": {
                "source": "足相撲",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十六年の紀元節の日譯者",
              "citation": {
                "source": "はじめに",
                "author": "「青い鳥」訳者序",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、――そうそう、あの日は紀元節だっけ。",
              "citation": {
                "source": "妙な話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
