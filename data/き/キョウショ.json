[
  {
    "uuid": "e701a81e-6161-50ce-8f42-f4d71139434c",
    "entry": "教書",
    "reading": {
      "primary": "きょうしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
