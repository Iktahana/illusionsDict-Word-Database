        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古代ギリシャの壁画で、詩人がキタラを抱えて吟唱している場面を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キタラは当時の貴族たちの間では欠かせない、格調高い楽器だったらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の展示で見かけたキタラのレプリカは、想像していたよりもずっと大きかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "スルト　ダンダン　センサウノ　アル　トコロニ　チカヅイテ　キタラシク、トキドキ　トホクノ　ハウカラ　カスカニ　タイハウノ　トドロキガ　キコエテ　キマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スナマンヂウガ　デキタラ　パカ、パカピヨン、ピヨン、パカ、パカオウマニ　ツンデマチヘ　ウリニ　ユキマセウ。",
              "citation": {
                "source": "スナマンヂウ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フタリハ　ナニヲキタライイカ、イロイロト　ソウダンシテヰルウチニ、ダンダント　ネムクナツテ　キマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フタリハ　ナニヲキタライイカ、イロイロト　サウダンシテヰルウチニ、アマリ　ポカポカト　アタタカイモノデスカラ　ダンダント　ネムクナツテキマシタ。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "問　然ラバ、清三ガオキタラドウスル積リダッタカ。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　ハジメハ、道子ヲ殺シタ後清三ガオキタラ、罪ヲスッカリ自白シテ自殺シヨウト思ッテ居タノデスガ、然シ清三ノ態度如何ニ依ッテハ之ヲ殺スツモリデシタ。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（キタラの伴奏にて歌ふ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "キタラは二つになった。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たえず美しいヒアキントスと遊ぶために、神託をも弓をもキタラをも忘れてしまったこいがたきである。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神がアメノサギリの神の女のトホツマチネの神と結婚して生んだ子は、トホツヤマザキタラシの神です。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上ヤシマジヌミの神からトホツヤマザキタラシの神までを十七代の神と申します。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
