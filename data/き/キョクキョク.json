        "examples": {
          "standard": [
            {
              "text": "昔ながらの石畳の道は`曲々`としており、迷路のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "山道は`曲々`としていて歩きにくかったが、頂上からの景色は最高だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あそこの川沿いの道、`曲々`としているから運転には気をつけてね。」と地元民は注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生という`曲々`とした道を、彼は着実に歩んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "結果はまたも想像の力で曲々の波瀾を起す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰り返して言ふと、天子がみこともちでいらせられる事の外に、宮廷の職員として、中臣・斎部が後世まで其俤を残したことは、既に述べたが、その外に更に、部曲々々に就いて、さうした意味のみこともちたる宰領を奉じてゐたと言ふことが出来る。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が松島湾の曲々を限りなく照していました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でんぶ」「でんぶ」「でんぶ」「でんぶ」　曲々浦汀から起る波（？",
              "citation": {
