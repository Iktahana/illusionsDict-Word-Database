    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heavy-hearted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「明日の朝一で部長に謝罪に行かなければならないと思うと、今から気が重いよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "連休明けの月曜日、満員電車に揺られながら、彼は気が重そうに窓の外を眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はぁ、またあのややこしい案件の打ち合わせか……」受話器を置いた彼の肩は、どこか気が重そうに落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "成績表を親に見せる瞬間は、学生時代においてもっとも気が重い時間の一つだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、どうにも、気が重い。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お湯をじゃぶじゃぶ掻きまわして、子供の振りをしてみても、なんとなく気が重い。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にふれるものがみんな燃えちまふわわあ　みんなすごい熱だ○あの病気はつまりペチャ　クシャうむ、それでペチャ　ペチャそれだから　ペチャクシャどうも大ぶ病気が重いのぢや○あれつ？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が重いのか、口の利き方も鈍かった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気が重い上に大きい衝動を受けたのであったからこの人はいたましいほどにも苦しんだ。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しっとりした都会で、住んだら、住みよいところで、離れにくいそうやが――」　母子がそんな話をしているときに、モルガンの父の病気が重いという、知らせが来た。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪がよくないので、喉が痛むやら鼻汁がつまるやらして気が重い。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の病気が重いとは知りつつも死を予期しなかった私達は胸をドキドキさせてかけつけた。",
              "citation": {
                "source": "梟啼く",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑枝は、胸のせまってくるのを感じた、余程病気が重いに違いない。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し病気が重いと思うと直ぐに早桶を買って来る。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気が重いと云ふことを誰から聞いたのか、それまで一度も家へは足を入れたことのない幾が見舞にやつて来た時には、卯女子だけが居合せた。",
              "citation": {
                "source": "鳥羽家の子供",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし――あたしねえ――何だか悲しいんですの――何だか、妙に気が重いんですの――」　しかし、そう云ってしまうと彼女は何だか怖ろしい気がしたので、周章ててこう附け加えた。",
              "citation": {
                "source": "初雪",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは気が重くなって、羊歯の路を帰って来たけれど、気が重いといっても、どうしたのか、心がすっかり落着いて、すずしい平和の露でいっぱいになったような気もして来た。",
              "citation": {
                "source": "漁師",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ病気が重いと云うだけじゃなかったんだ、その時はもう死にかけていたんだよ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご迷惑でしょうけど、ぜひ聞いていただかなくてはならないの」「今夜は変なものばかり見てしまって気が重い。",
              "citation": {
                "source": "雪間",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっとりするほど気が重い。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は晴れても、山城守は、気が重いのだった。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が重い――無理もない。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ねえ、とど助さん、どうしよう、このお客さんは、豊島ガ岡までいらっしゃりたいとおっしゃるんだが……」　とど助は、仏頂面で、「わしは満腹で気が重い。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でもねえ、モデルの仕事、気が重いのよ」「それは、昨日も聞いたけどさ、あんたが考えているより、もっといい仕事がありそうな気がする。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく説明することは気が重いが、結局はこの少壮有望の学徒はまだ独身のうちに病死したのである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、母さんの病気が重いのに、帰ってしまうのはよくないことだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした役所を代表する義務をとくに気が重いものと感じるのは、むしろいい役人なんですわ。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごらんのとおりたいへん病気が重いのですから、どんな用件もお話しはできません」　看護婦は叔父の言葉をおそらくはただ億劫がって繰返したにすぎなかったのであろうが、ともかくそれは第三者から見てさえ嘲笑しているもののようにとられ、叔父はもちろん、ちくりとやられた者のように飛び上がった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "山人たちはまた大量の荷に気が重い。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はあっさりした口ぶりで、おとうさまが子福者だから、自分たちもその筋をひいているのだろうが、このとしで五人もの子持になるのは気が重い、もうこの辺でおしまいにしたいと思う、などと云った。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどいわ、ひどいわおっ母さん」駕籠をいそがせて帰る途中、おしのは声に出して呟いた、「お父つぁんの病気が重いと知っていながら、そんな人と平気で箱根へゆくなんて」　おしのは自分の手をひらいて、眼に近づけて見た。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の眼蓋にトビゝして、これが痛むので気が重い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから又一回「水戸黄門」をやるのかと思ふと気が重い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖然とした友松の顔つきがおもい出され、彼女はなんとなくおかしくてならなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
