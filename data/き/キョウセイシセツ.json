        "examples": {
          "standard": [
            {
              "text": "非行少年が社会復帰できるよう、矯正施設で様々なプログラムが提供されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は過去の過ちを償うため、矯正施設で数年間を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地元の矯正施設が、一般市民向けの施設見学ツアーを開催すると聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのニュースに出てた子、矯正施設に入ったんだって。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "矯正施設では、教育や職業訓練を通じて、若者たちの更生を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
