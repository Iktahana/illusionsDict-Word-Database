        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "国際労働機関（ILO）は、過酷な環境での強制労働を根絶するための勧告を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな安い給料で長時間拘束するなんて、実質的な強制労働じゃないか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "独裁政権下の収容所では、政治犯たちが道路建設などの強制労働に従事させられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私たちが使っている製品の原材料が、強制労働によって生産されていないか確認すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "新聞記者は私達を取り囲んで一日に黒パンを幾ポンド支給されるかとか、強制労働は苦痛だらうとか、常識的な質問をし私はこれに常識的な答をするだらう。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソビヱットの苦痛は黒パンの量や、強制労働や、隊の規律にあるのではない。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "集団農場から箇別農場へ、強制労働から自由契約労働へ転向した。",
              "citation": {
                "source": "反動ジャーナリズムのチェーン・ストア",
                "author": "――森鶴子君に答える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日でさえ、このような状態であるのに、一度、戦争が拡大して「国家総動員」が公然とやられ始めると、労働者は、兵隊の賃銀と同額（つまり一日十五銭）で銃剣にかこまれた強制労働をやらされるのだ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に強制労働を強いるのはナホトカからあッちの方の捕虜だけの話さ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる邦人というのは、いまから十年前、すなわち、昭和五年の夏、勘察加のパランスクで密漁中、監視砲艦のために撃沈され、スタノヴォイの苔原地帯に流刑され、河流工事の強制労働に従事させられていた、第二神風丸（舶籍、小樽市）の乗組員、漁場監督・篁栄二郎、一等運転士・清水岩吉以下六名であった。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤクーツク州の「第二十七｜流刑地」で水路工事の強制労働に従っている流刑囚の一群である。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラ　　科料は強制労働の賃金によつて、支弁することがゆるされてゐる。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロク　　強制労働をさせる妻があつたら、この村もおしまひだ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは笑いの強制労働である。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは笑いの強制労働であり、語弊さえ厭わないなら「売笑」と呼んで差支えないくらいだ。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルウ及びチリイにおいては、土人の強制労働は、地面の耕作ではなく地下の穴掘へと、致命的な転化をさせられた。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ筆法で、五日週間という「アメリカでさえやっていない方法」を採用するソヴェト政府は、世界のキリスト教徒の習慣に挑戦するものであるし、強制労働が全住民に拡大されることであると非難していた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのひとたちは『五日週間』についてさえ強制労働が全住民へ拡大したってかいたんです、わたしはパリでそれを読んだわ」　オリガは非常に考えぶかく、自分のひとことひとことに責任をとっているようにつぶやいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな暴虐も――拷問、人質の利用、強制労働、大量国外退去、裁判抜きの収監、捏造、暗殺、市民への爆撃、なんでもござれだ――「わが方」がやってのけた場合は人道的な色彩に塗り替えられてしまうのだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
