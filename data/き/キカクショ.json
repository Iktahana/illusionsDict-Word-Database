        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この企画書、もっと具体的な収支シミュレーションを盛り込まないと、役員会で即却下されるぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "徹夜で書き上げた企画書を提出した帰り道、朝日が眩しくて少しだけ達成感に浸った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これを見てくれ」と手渡された企画書には、手書きのラフ案がびっしりと書き込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼンの直前に企画書の誤字を見つけてしまい、慌てて修正を依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『オヤジ一人で出版社を作る』という仮のタイトルをでっち上げ、この本の企画書を書いて相談を持ちかけると、アスキーの渡辺俊雄さんからは一つ注文がつきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津田さんたちのサイバーブックセンターがスタートした直後にまとめた企画書には、エキスパンドブックをインターネットで売るという項目も加えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの中でも特にＣＧに入れ込んでいたハッカーに企画書をまとめさせ、後藤や池田たちとの打ち合わせを繰り返した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
