[
  {
    "uuid": "a4c1241f-249c-5c37-8967-e4be1dcd3902",
    "entry": "居住",
    "reading": {
      "primary": "きょじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "residence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい土地での居住手続きを終えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は長年、この高級住宅街に居住している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "外国人の居住に関する法律が改正された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域は、静かで緑豊かな居住環境として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "況んや日本に居住することなく、日本の文学を全く読まず、日本に就いて知る所の殆んどない一般の欧米人が、宮森氏の訳を通じて、芭蕉等の俳句が解り得る道理はない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し行くと路地の角の塀に掛けた居住者姓名札の中に「寒川陽光」とあるのが突然眼についた。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャスタへ行くには、私たちの居住地、桑港から、オレゴンへと北向する南太平洋鉄道の便を借りるのである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、六｜月の下旬にまたＴ市の居住地に歸營した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は営外に居住し得、妻帯し得るのに対して、下士以下兵卒は兵営に居住しなければならないし、妻を持ち得ない生活条件から、そういう結果になっていた簡単な事実が、独歩には気がつかなかったものらしい。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑な地形はまた居住者の集落の分布やその相互間の交通網の発達に特別な影響を及ぼさないではおかないのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月も末近く、紫木蓮の花弁の居住いが何となくだらしがなくなると同時にはじめ目立たなかった青葉の方が次第に威勢がよくなって来るとその隣の赤椿の朝々の落花の数が多くなり、蘇枋の花房の枝の先に若葉がちょぼちょぼと散点して見え出す。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い、広い、渾沌たる支那内地に居住する外国人の多くは、この硬派か軟派かを本当の仕事としていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はあわただしく蹶ね起きて、急に居住まいを繕いながら、「はい」と答うる歯の音も合わず、そのまま土に頭を埋めぬ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクス・ベーアはサンフランシスコ居住のユダヤ系の肉屋だそうである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が入ると娘は急に起とうとしてまた居住いを直して顔を横に向けました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくのことで唾を呑みこんで、居住まいをなおしながら下を向いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややしばらく思案しているらしかった小母さんは、きゅうに居住まいをなおして園の方にまともに顔を向けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その要領は人類の居住すべき世界の土地は一定である、又その食料品は等差級数的に増加するだけである、然るに人口は等比級数的に多くなる。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女は居住まひを直して男の真向になつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女は居住まひを直して男の眞向になつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "と得右衛門居住い直して挨拶すれば、女房も鬢のほつれ毛掻き上げつつ静まりて控えたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月になると旱つづきで、さなきだに水に乏しいここら一帯の居住者は、水を憂いずにはいられなくなった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘は蓮葉な声で笑いかけたのを周章てて呑み込むと、居住いを直しながら、低声で私に注意した。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "お眼にかけましょう」「エッ見せて下さいますか」と私は思わず釣り込まれて居住居を直した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るのはいつも五時か六時頃です」「じゃ御免下さい」と一礼して羽織を脱いだ、妻木君も居住居を直した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は自分の思ひを自然に映して、それぞれの景色の中に居住してゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずるずるべったりに伯母の望む如く、鼈四郎は、東京居住の人間となり逸子を妻と呼ぶことにしてしまった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところは、あたし敵わないと思うわ」　かの女は言葉通り尊敬の意を態度にも現わし、居住いを直すようにしていった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化に於いて、はたまた産業に於いて然り、かしこくも明治大帝の教育に関する大御心はまことに神速に奥州の津々浦々にまで浸透して、奥州人特有の聞きぐるしき鼻音の減退と標準語の進出とを促し、嘗ての原始的状態に沈淪した蒙昧な蛮族の居住地に教化の御光を与へ、而して、いまや見よ云々。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お納戸の絹セルに、ざっくり、山繭縮緬の縞の羽織を引掛けて、帯の弛い、無造作な居住居は、直ぐに立膝にもなり兼ねないよう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃生活派と呼ばれ、一様に三十歳を越して、奥様、子供、すでに一家のあるじ、そうして地味の小説を書いて、おとなしく一日一日を味いつつ生きて居る一群の作家があって、その謂わば、生活派の作家のうちの二、三人が、地平の家のまわりに居住していた。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れてアパートの居住者がそれぞれの勤先から帰って来る頃、佐伯は床を這いだして街へ出て行くのだが、町へ出るにはどうしてもその道を通らねばならないと思うと、業苦を背負ったように憂欝になってしまう。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
