    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの樂しみは、お天氣のよい日、腰に一瓢をさげて、劍山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減、たきぎ拾ひに疲れると、岩上に大あぐらをかき、えへん！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中になって大学士は「うう寒い」と云いながらばたりとはね起きて見たらもうたきぎが燃え尽きてただのおきだけになっていた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士はいそいでたきぎを入れる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は少うし森から、たきぎを運んでくれ」オツベルは房のついた赤い帽子をかぶり、両手をかくしにつっ込んで、次の日象にそう言った。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ぼくたきぎを持って来よう。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひるすぎの半日に、象は九百把たきぎを運び、眼を細くしてよろこんだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの楽しみは、お天気のよい日、腰に一瓢をさげて、剣山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくじやうぎんぎよのめよりをんなのへそをめがけてふきいづるふんすゐひとこそしらねてんにしてひかるはなさきぎんぎよのめあかきこつぷををどらしめ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、森でひろいあつめたたきぎをひとたば、せなかにのせていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――インド人のやもめは、火葬のたきぎのつまれた上に、ながい赤いマントをまとって立っています。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の焔は、火あぶりのたきぎのなかで、もえつきるものでしょうか。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は南水のきぎょ、西竹林の三けいちょうと名乗りて入り来り、三怪揃うて僧に飛び掛かるを、少しも動ぜず経を読んで引導を渡すと化物消え失せる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんさくだの、かしわの葉、あかしで、いぬしで、いぼた、白い花の咲くがまずみ、うつぎ、赤い花の咲くはこねうつぎ、模様のようなやまにしきぎ、そんな名前を一つ一つていねいにおしえて下さいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こごんで竹の皮包みをまるめだしたが、そのときぎくッとくりはまたぎくンとつきあげて来た。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の手伝いを云いつけられていやなかおをした働きぎらいの千世子は八時頃になって、「お先きへ――私気分が悪いからもう寝ますわ、あしたは学校に多分行きましょう」　こんな事を云ってじきにねてしまった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきて森へ行って、たきぎをひろってくるのだよ。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妃は火あぶりのたきぎを積み上げた上につれだされたとき、六枚の肌着を、しっかりとそのうでにかけていました。",
              "citation": {
                "source": "六羽の白鳥",
                "author": "グリム兄弟　Bruder Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妃がたかい台の上に立って、いよいよたきぎに火がつこうというとき、お妃は、そっと四方に目を注ぎました。",
              "citation": {
                "source": "六羽の白鳥",
                "author": "グリム兄弟　Bruder Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は煮たきをするたきぎや、野菜がわりにつかう草葉をさがしてきたり、おなべを火にかけたりしました。",
              "citation": {
                "source": "十二人兄弟",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "たきぎをしょったり、石を運んだり、また、荷物をかつがしたり、いろいろのことを頼みました。",
              "citation": {
                "source": "牛女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も、万は役場から帰ると、すぐ山へたきぎを取りに出かけました。",
              "citation": {
                "source": "万の死",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチ、カチと、時をきぎむ音がしています。",
              "citation": {
                "source": "緑色の時計",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、柱にかかる時計のきぎむ音を聞くうちに、いつのまにか、ねむってしまいました。",
              "citation": {
                "source": "夢のような昼と晩",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、兄は口こごとをしながら、前のあき地につんであったたきぎを一｜本ずつとりあげて、長いのをのこぎりでひき、太いのはなたでわって、てごろにできあがったのから、なわでくくりはじめました。",
              "citation": {
                "source": "ペスときょうだい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
