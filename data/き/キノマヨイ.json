        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「まさか、結婚しようと思ったなんて、あれはきっと気の迷いだったんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一時の気の迷いで、彼は仕事を辞めて海外へ旅立ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの派手な服を買ったのは、どう考えても私の気の迷いだったとしか思えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな馬鹿なことを考えているなんて、お前は気の迷いがあるんじゃないか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "気の迷いじゃなかったかねえ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、気の迷いじゃありません。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷いにもせよ、確にそう見えた、と多津吉は言うのである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷いかしら、それとも揺椅子でぬくもりながらついウトウトとしてしまって夢をみたのかしら――酒と阿片とでいい加減狂いかけている俺の頭だもの、その位の気の迷いや夢がないとも云えない――が、併しそんな風に簡単に思いなしてしまうには、どうもすべてがあんまりまざまざとし過ぎている。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、どうして気の迷いや夢とは思われん……むしろ幽霊を信じた方がもっと間違いがなさ相だ……おやおや、俺はひょっとしたら本当に気が狂いかけているのかも知れないぞ！",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜水夫やめよう思たんは、あれは気の迷いやった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは※の気の迷いだ」と言うと、渠は信じがたげな眼で、一同を見返し、さて、それから、なぜ自分はこうみんなと違うんだろうといったふうな悲しげな表情に沈むのである。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜水夫やめよう思たんは、あれは気の迷いや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、だんだんに――ほとんど眼につかないほどにゆっくりと、そして、長いあいだ私の理性はそれを気の迷いだとして否定しようとあせっていたのだが――それが、とうとう、まったくきっぱりした輪郭となった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷いかも知れないと打消しながらもわたくしは妙にそれが気にかかってならないので、いつまでも夢のような心持でそこに突っ立っていました。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三太郎君の幻想が決して三太郎君一人の気の迷いではない。",
              "citation": {
                "source": "卵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あの頭に繃帯して、こっちを覗いていた男は、川上の顔のように思ったが、気の迷いだったろうか）　まさか川上機関大尉が、あのような労働者アパートの男女の中にまじっているとは、ちょっと考えられない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も馬鹿な――大方、気の迷いだらずが――昨日は恐ろしいものが俺の方へ責めて来るぢゃないかよ。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すると今しがただれか呼んだと思ったのは、気の迷いであったか。",
              "citation": {
                "source": "殺生石",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛といっても、けし粒ぐらいの奴から、大きいのは直径五、六寸あるのがある、笑談じゃない、それは気の迷いだろうと笑う人があるかも知れないが、事実あるのだからいたし方がない。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すぐにそれが、気の迷いでもあったかのように、ふたたび泡立ちはじめた河面のなかに隠れてしまったのである。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私の気の迷いか、あるいはあの画が世の中にあるには、あまり美し過ぎるからか、どちらが原因だかわかりません。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かを呼びたい、ような気もしたが、自分の気の迷いで、人を呼ぶのも恥かしかったから、心切りを持ち直して、燭台を見ると、前よりも薄暗いようであった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "びくびくしてるから、気の迷いだ。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷いだったかしら、と私はアパートの裏口へ引返した。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが名を呼ぶは何者ぞ、気の迷いであろうかと、学士は耳を欹てた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "話を聞いてから夢をみるのなら兎に角、聞かない前に事実そっくりの夢をみたのだし、その幻がまざまざと見えたのだから、気の迷いとばかりはいえなかった。",
              "citation": {
                "source": "都会の幽気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前、気の迷いじゃないか」　武平はきいた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、気の迷いで、見たように思ったのでしょうか」「いや、気の迷いなんてことはないよ。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷いにしては余り何度もだから、試みに母を二階に連れてきた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが寝ぼけてるって、ただの夢だって、……気の迷いだって。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、気の迷いさ」と、セルゲイは片づけた。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもさ、気の迷いなら迷いでいいけど、なぜそれが、今までついぞなかったんだろうね、ねえ、セリョージャ？",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
