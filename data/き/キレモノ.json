[
  {
    "uuid": "8df9cba3-d731-5802-9a3a-a43b8485625f",
    "entry": "切れ物",
    "reading": {
      "primary": "きれもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "edged tool",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おまけに大工だというから、なにか切れ物でも持っているかも知れねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や切れ物を振り回したり、傷を負わした事があるものか。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、御両所、切れ物にお気をつけ召されい――とね、はっはっは、俺の玄内はどんなもんでえ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "切れ物は鋭き石の刄物なるべく、針は骨にて作りたるものなるべし。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "振向いて、眼と眼が、かち合ったら、その途端、お杉が選ぶ行動は分っているし、老婆とはいえ、切れ物と死に物狂いで来る以上、こちらが怪我をしない程度のあしらいは酬いなければならない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっ腰のない主持ちのおさむらいなんぞにゃあ、どうせ喧嘩はできまい」　そこらの角丸太、金づち、切れ物などを、手当り次第に持つと、あわや一かたまりの旋風になって、あとを追いかけようとした。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "切れ物を持ち合って、殺しっこをしているこの戦場の人間は、みんな頭がヘンなのにきまってるわ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "南町奉行所を一人で背負って立っているといってもいいほどのきれものだが、驕慢で気むずかしくて、ちょっと手におえない男である。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "ねずみ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
