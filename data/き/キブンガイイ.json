    "definitions": [
      {
        "index": 1,
        "gloss": "feel good (pleasant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
