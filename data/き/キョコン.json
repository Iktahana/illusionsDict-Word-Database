        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大地はいつの間にか透けて、地中で白玉の数本の根枝に纒められて、地上のものを、また支へてゐる巨根がカツーン映画の影像のやうに明かに覗かれる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、江戸を騒がす総ての巨根が薩摩に存することをよく知っております。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、南条も宇津木も、それはまだ末で、例の巨根はそこから蔓を張っている薩州屋敷にある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
