        "examples": {
          "standard": [
            {
              "text": "苦労の末、ついに九重の天にも昇る気持ちで優勝トロフィーを掲げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の歌声は、まるで九重の天から響いてくるかのように美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その崇高な教えは、九重の天にまで届くと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "九重の天から見守られているような、清らかな場所だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人この裏に立ちて寥々冥々たる四望の間に、争か那の世間あり、社会あり、都あり、町あることを想得べき、九重の天、八際の地、始めて混沌の境を出でたりといへども、万物｜未だ尽く化生せず、風は試に吹き、星は新に輝ける一大荒原の、何等の旨意も、秩序も、趣味も無くて、唯濫に※く横はれるに過ぎざる哉。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            }
          ]
        }
