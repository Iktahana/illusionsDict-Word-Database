    "definitions": [
      {
        "index": 1,
        "gloss": "joint sponsorship (of an event)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
