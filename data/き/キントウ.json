[
  {
    "uuid": "e81b2123-baef-51ff-9109-1f6aa042757a",
    "entry": "均等",
    "reading": {
      "primary": "きんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
