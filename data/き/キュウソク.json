    "definitions": [
      {
        "index": 1,
        "gloss": "rest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから少し休息し、書斎に入って仕事をする。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェは読書を「休息」だと云ったが、今の僕にとって、交際はたしかに一つの「休息」である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言つて疲労を休める為に、休息してゐるといふわけでもない。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと休息といふ事にしようぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨染の衣を着た坊さんが、網代笠を片手に杖ついて、富士に向って休息しているとすれば、問わずして富士見｜西行なることを知る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも大野原の上を、自由に飛翔しようとする大鳥が羽翼を収めて、暫く休息している姿勢を、富士は取っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が決めたか知らない食道法律が、この時までフランス人の胃腑に休息を命じている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人休息して居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）翌る朝――　＝（Ｆ・Ｉ）お光の茶店　進藤甚助と昨日の若侍とが休息して居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの品々は、一時、深沢洋行の倉庫の中で休息した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一日には頂上までの五分の一だけ登って引返し、第二日目は休息、第三日は五分の二までで引返し、第四日休息、アンド・ソー・オン。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の若いお蝶はただおびえているばかりで捗々しい返事もできないのを、女はなおいろいろ慰めて、まずしばらく休息するがいいと云って、茶や菓子を持って来てくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも食事が済むと、また少し休息するがよかろうと云って、このあいだの女はしずかにその席を起った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの座敷へ戻ると、お蝶はまた一刻ばかりの休息をあたえられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にゆうべの祈祷の休息のあいだに、彼はお姫様をとらえて猥らなことを云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　遠足に疲れた生徒が、泉のほとりに群がって休息しているように、兵士が、全くだれてしまった態度で、雪の上に群がっていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちは、ぐたぐたに、二日半の休息を得た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人が、地獄か、極楽かで、その金を出して、自分の休息場を買うのである！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平時には、商工業の機械工場で、不断の労働の規則に取り囲まれ、道具の奴隷となり、ペンの奴隷となり、才能の奴隷となり、又は、何か他の物の奴隷となって、朝から晩まで休息することもなく日々の労役に曳きずられる君よ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町も磯も今は休息のなかにある。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく休息的な愉しさが彼をとらへたのであらう。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の疲れた眼球には、しみじみとした、この世のものでない休息が伝わって来る。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親牛は長いこと、夕方まで休息していた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御意、」と一同川岸に休息する。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れてだろう、脚を伸ばして休息せらるるようにしてあげろ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲の好い友達でしたから折々遊びにもゆきましたが、これが読本を家で読んで来ては、学校の休息時間に細川や私なぞに九紋龍史進、豹子頭林冲などという談しを仕て聞かせたのでした。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯をすませて少し休息すると、わずかばかりの紙幣を財布に入れて出かける。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術がすんだら看護婦が葡萄酒を一杯もって来て飲まされ、二三十分｜椅子にもたれたまま休息することを命ぜられた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで二十九にちのよるは寄せ手もせめあぐんできゅうそくいたしまして、あくる九月ついたちにまたせめてまいりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりしまへおあがりなされて一と夜｜参籠あそばされ、あくる日｜佐和やまへおわたりになりまして、いちにちふつか御きゅうそくなされましてから御ほっそくあそばし、どうちゅうつゝがなく清洲のおしろへ御あんちゃくになりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
