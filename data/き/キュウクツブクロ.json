        "examples": {
          "standard": [
            {
              "text": "昔の武士は、窮屈袋を身につけていたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "卒業式で、大学生の多くが窮屈袋姿で参加していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弓道の稽古では、動きやすい窮屈袋を着用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代劇で見る窮屈袋は、現代のものと形が違う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「變な音がしたやうだ、――來い、八」「あつしが行つても構ひませんか」「その窮屈袋と紋附をかなぐり捨てるんだ」　言ひ捨てて平次は飛出しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「変な音がしたようだ、――来い、八」「あっしが行っても構いませんか」「その窮屈袋と紋付をかなぐり捨てるんだ」　言い捨てて平次は飛出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
