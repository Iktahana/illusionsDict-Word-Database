          "literary": [
            {
              "text": "また、たとい、きつねやむじなにばかされないにしても、よっている人間というものは、ばかされている人間とあまりちがわないというわけです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "那須野の原というのは十｜里四｜方もある広い広い原で、むかしはその間に一｜軒の家も無く、遠くの方に山がうっすり見えるばかりで、見渡す限り草がぼうぼうと生い茂って、きつねやしかがその中で寂しく鳴いているだけでした。",
              "citation": {
                "source": "殺生石",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "外のきつねや烏共は皆平伏しました。",
              "citation": {
                "source": "おどり子の出世",
                "author": "槇村浩",
                "note": "青空文庫"
              }
            }
          ]
        }
