    "definitions": [
      {
        "index": 1,
        "gloss": "day on which a museum, library, etc. is closed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "せっかく美術館まで来たのに、今日は休館日だった。ちゃんと調べてくればよかったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市立図書館は毎週火曜日が休館日なので、本を借りに行く際は曜日を確認してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴールデンウィーク期間中も、一部の施設は休館日があるので注意が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
