        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "甲子の年に生まれた人は、 diligent だと言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父は甲子園球場ができたのと同じ甲子の生まれだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次の甲子の年は、孫が成人する節目の年になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の創立記念日は、ちょうど甲子の年だったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえば甲子の日曜日は一年に一つあることとないこととあるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲子を一とし乙丑を二とすれば甲戌は十一であり丙子は十三になる、少しめんどうなだけに、それだけの長所はあるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、甲子、晴、金吾将軍の若君、定暁僧都の室に於て落餝し給ふ、法名公暁。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、甲子、天晴、二所に御進発、相州、武州等供奉し給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、甲子、快霽、将軍家、花を覧んが為、三浦の横須賀に御出。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日、甲子、陰、寅刻大地震。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元治元年甲子、十八歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、以前に近藤勇の為めに、倒された転向勤王派たる、伊東｜甲子太郎の残党なる鈴木三樹三郎、篠原｜泰之進、加納｜就雄などが、薩摩の伏見屋敷に庇護されていた。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "修一が現在交際してゐる北井伊都子は浜甲子園の邸宅に母と二人住み、係累もなく、その代り父の遺産は三十万を超えてゐるのだと、修一はかつて楢雄に話したことがあつたのだ。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜甲子園の北井の使ひだといふので、寿枝はさつと青ざめた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政元年より毎年二月と九月に長崎奉行兎狩に託して人数押えを行うた由（『甲子夜話』六四）、いずれそれが済んだ後で一盃飲んだのでしょう。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "開幕早々気を失った巨人が、甲子園球場で虎印気付薬をかがされて目を覚ました時期だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甲子夜話」には、慶長十二年の朝鮮の使にまじっていた徳川家の旧臣を、筧又蔵だとしてある。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏村は長谷川浩三や吉田甲子太郎と「基調」、鈴木は浜野英二や故近衛直麿と「象徴」などを始めた。",
              "citation": {
                "source": "交遊記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に入つて初めて口を利いたのは故柏村次郎であり、次にクラス会が大久保の方で開かれた時浅原六朗と知り、間もなく岡田三郎、吉田甲子太郎、下村千秋などに出会つた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれが間違って居るかしら、『甲子夜話』に壱岐に※鼠なしとある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといその境｜雑るもかくのごとし（『甲子夜話』続篇八〇）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲子夜話』八七に、文政九年六月二十五日、小石川三石坂に蛇多く集まり、重累りて桶のごとし、往来人多く留まり見る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第１図　『甲子夜話』蛇塚　エストニアの俚談にいわく、ある若者奇術を好み、鳥語を解したが、一層進んで夜中の秘密を明らめんと方士に切願した。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の『和漢三才図会』や『北越奇談』『甲子夜話』などにも蛇蛸に化る話あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "里伝にこの島に名馬草を産し、牝馬これを食えば必ず名馬を産めど、絶壁間に生える故馬これを求めて往々墜ちて死すと（『甲子夜話』続編五七）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本邦でも秀吉の馬塚（『摂陽群談』九）、吉宗の馬像（『甲子夜話』五一）、その他例多く、馬頭観音として祀ったのも少なからぬ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし『甲子夜話』続十七に、舅の所へ聟見舞に来り、近頃｜疎濶の由をいいかれこれの話に及ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に猴智慧というは『甲子夜話』続二一に、四国の猴は余国よりは小さくして舞伎を教えて能く習う、因って捕え他国へも出して利を得るとぞ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年二月、『太陽』二七ノ二）３『甲子夜話』続一七にいわく、ある老人耳聞えず、常に子孫に小言をいう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲子夜話』続一三に、ある人曰く、大槻玄沢が語りしは、奥州栗原郡三の戸畑村の中に鶏坂というあり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲子夜話』一七に家豕の闘戦を記して、畜中の沈勇なるものというべきかと評す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲子夜話』五一に、吉宗将軍小金原に狩りして、自ら十文目の鉄砲で五月白と名づけた古猪の頭を搏ち、猪一廻りした処を衆人折り重なって仕留めた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲子夜話』続篇八〇に、松浦天祥侯程ヶ谷の途の茶店にて野猪の小なるを屠るを見る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『書紀』に小碓命少女の装いで川上｜梟師を誅したと出で、婦女男装して復仇したり、役者が女装して密通したりなど往々聞くが（『拾遺｜御伽婢子』三の三、『甲子夜話』続二一）、多くはその場だけで事済み、外国のような大騒ぎ社会を害毒するの甚だしきに至らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
