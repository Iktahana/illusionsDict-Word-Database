    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heavy-hearted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠方に引っ越す友を見送る日、胸が気重になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要なプレゼンの前はいつも気重な気持ちになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が病気と聞いて、最近はずっと気重な日々を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気重な荷物を背負うように、彼はずっと思いつめていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眠られぬままにいろいろな事を考えた中にも、Ｎ先生が病気重態という報知を受けて見舞いに行った時の事を思い出した。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事のあとでりんごか何か食っていたようであったが、とにかく三人のムードが、食前とはすっかり一変して、なんとなく気重く落ち着いた、眠ったいような雰囲気がその食卓の上にただよっているように感ぜられた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに想い候え、十蔵とは奸なる妻のために片目を失いし十蔵なり、妻なく子なく兄弟なく言葉少なく気重く心怪しき十蔵なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがなおなおかの女の態度を真剣に沈み入り気重にさせるようになって来た。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日輪の走せ廻る気重き虚空鞭うつて、羽掻の音の声高き一鳥遂に飛びも来ず、たまたま見たり、蟒蛇の夢も熱きか円寝して、とぐろの綱を動せば、鱗の光まばゆきを。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島はどうしても直り合うことの出来なくなったような、その時の厭な心持を想出しながら、涼気の立って来た忙しい夕暮の町を帰って来たが、気重いような心持がして、店へ入って行くのが憚られた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　どちらか皮肉を云い出せば、髄まで刺し通して共倒れになるまでやり合う習慣がまたしても出かかったが、もう久慈には刺される痛さも感じない、午後の気重い退屈さがのしかかっていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　多額の金銭の支給を受けて視察を命ぜられ、何一つ新しい発見もせず明日帰ろうという機械技師の苦衷は、自分の想像外の気重さだろうと久慈は思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜だけは本物のピエールというアルマンと競争しなければならぬだけに、気骨の折れること一通りではないと思い、少し歩くと一度も練習したことのない舞台を踏むような気重さである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人がテーブルを包み座をそれぞれに定めたとき、暫く妙に白んだ気重い沈黙がつづいたが、久慈は見事にそれも突き崩した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、矢代は、今のような気重さは、そう長くつづくものとは思えなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て来るときは、気重く充実した気持ちで坂を下ったのも、帰りはもう一度少年のころの駄駄を繰り返すような気軽さで家へも這入れた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京でもすでに海外版の写真で活動を始めていた塩野は、明日からの京都の旧蹟を撮ることに、今から愉しみぶかい興奮を示して絶えず活溌に話したが、矢代だけは明日の別れもあり、また皆のものを京都へひき出したこの度びの責任の回避も覚えて、とかく沈みがちに気重くなるのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "気重い沈黙が続いた後に、彼女は言い出した。",
              "citation": {
                "source": "程よい人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんなのよりもっともっと気重いのである。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "気重さは、漠然たる怖れに変る。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は度胸をすえてはいたものの、柿沼が一度も来なかったこと、或るいは来なかったらしいことが、却って私には気重いものとなって感ぜられました。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "□北から使で、スエ子が病気重くカンゴフをよんだから来い、と云う口上。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、いや、ごていねいなことで」　坐につくとすぐ固苦しい挨拶をはじめた房一に向つて、その気重い調子を払ひのけでもするやうに、老医師の正文は口早やに云つた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か白らけた出来事があつて与里と総江は気重い無言を固執してゐたものとみえ、空々しい薄暗がりが其処ら一杯にはびこつてをり、与里の寝顔は激しい空虚に殆んど間抜けなものに見えた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と池内は何かしら胸を押えられる気重な気分を三枝の持つ雰囲気から受けた。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲黒く気重く、身｜蒸され心｜塞がれ、迷想｜頻に蝟集し来る、これ奇なり、怪なり、然れども人間遂にこれを免かること難し。",
              "citation": {
                "source": "「油地獄」を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "重房は宿に帰ると、気重な心を振り起して女房たちにいった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもあなたが、お気重さうに見えるゆゑ。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、いま自分が遠く日本をはなれて来ていて、モスク※の生活感情そのもののなかで、故国からの手紙をよむ気持を思いあわせると、泰造ばかりでなく、すべての外国暮しをしているものが、その外国生活の雰囲気のなかにうけとる故国からのたよりを、一種独特の安心と同じ程度の気重さで感じるのがわかるようだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋にかえって夫とさし向いになると、気重さが彼女に迫ってきた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此宿はこゞゐの森にもあらぬを、この夜頃たえせず声の聞ゆるが上に、ひるさへかく」と打出したれば、友は得ときがたきおもゝちして、「何をかのたまふ」とたゞに言ふ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ新しくて青き光失せぬ建仁寺籬折りまはしたる小さき坪の中に咲き出でたる、あるはまたよろづ黒みわたりたる古き大寺の書院の椽近く※ひこぼるゝなど、云ひがたき佳きおもむきあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土踏むことを知りたるものの心ひくべきおもむきは有たざらむ歟。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄線蓮　てつせんは、詩にも歌にも遺れられて、物のもやうにのみ用ゐらるゝものなるが、詩歌に採らるべきおもむき無きものにはあらじ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
