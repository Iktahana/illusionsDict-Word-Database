[
  {
    "uuid": "2d932cc1-6797-5cd8-bf38-db29c4da3854",
    "entry": "気重",
    "reading": {
      "primary": "きおも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
