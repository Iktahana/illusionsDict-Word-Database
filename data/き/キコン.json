[
  {
    "uuid": "dc38559f-cccd-55c8-a669-60c5eaacb73d",
    "entry": "既婚",
    "reading": {
      "primary": "きこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
