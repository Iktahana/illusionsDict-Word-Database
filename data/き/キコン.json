    },
    "definitions": [
      {
        "index": 1,
        "gloss": "married",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十四　おはぐろ　自分たちの子供の時分には既婚の婦人はみんな鉄漿で歯を染めていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子は、それに遺憾の気持ちが多かったため、かなり沢山招かれた花嫁の友人の皆が既婚者であり、自分一人が独身であったということさえ、あまり気にならなかった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また多くの既婚者等が、いかにこの点で嘆いてゐるかを見よ。",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（口だけでは、やれ古いのなんのって言うけれども、決して人生の先輩、老人、既婚の人たちを軽蔑なんかしていない。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "リメイは既婚者ギラ・コシサン一人だけを選んだ。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお既婚者のストレーカは厩舎から二〇〇ヤードほど離れたささやかな母屋住まいだ。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木君の場合はまだ独身ですから、貴女の戯れの犠牲になるものは一人で済むのですが、僕のような既婚者の場合は被害者が複数ですからね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木君の場合はまだ独身ですから、貴女の戯れの犠牲になるものは一人で済むのですが、僕のやうな既婚者の場合は被害者が複数ですからね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "既婚女性はその赤子を抱え上げ、未婚女性は宝石箱に手を伸ばす。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば彼女たちが昔の既婚婦人に扮する場合、演出者の注意をまたずして、眉を落し歯を染めて出るのは時代劇の常識であるべきはずだが、実際にはこれらの問題で手を焼かせなかった女優は極めて稀である。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを引き延ばすと、既婚の一対は、双方ともに、流俗に所謂不義の念に冒されて、過去から生じた不幸を、始終｜嘗めなければならない事になつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に平岡に嫁いだ三千代に対して、こんな関係が起り得るならば、此上自分に既婚者の資格を与へたからと云つて、同様の関係が続かない訳には行かない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにこの当然さ自然さのために、今日総ての未婚と既婚の真面目な女性たちが、言い尽せない複雑広範な問題を日々の中に感じている。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チャールス・ラムは『エリヤのエッセイズ』で、「既婚者の言動についての或る独身者の嘆き」というものを説いている。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそこで既婚者が独身者に向って加える凡ゆる非礼を分析し、最後の最も不埓なものとして、女房達が亭主をその親友と絶交させる方針を一貫して採用する、という原則を結論しているのである。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂った不幸な姉を護って独身に終った彼は併し、ここで自分を嘆いているのではなくて既婚者を嘆いているのだということを、読者は忘れてはならぬ。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼は親が放蕩息子を嘆き、教師が劣等生を嘆くように、既婚者を嘆くのである。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその独身者としての特権を充分長期に亘って有効に行使して私達既婚者を苦しめて来た。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し結婚指輪は唯一つを既婚婦人にのみ許す。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから歯みがき一つ買うにも、まず政府へ願書を差し立て、何が故に歯磨きに興味を感ずるか、年齢は幾つか、既婚か未婚か既婚ならば妻もしくは夫の人物・性行・嗜好の一般、家族は何人か――各写真一葉添附のこと――共産党政府に異心なきことの証明。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、予備兵役の兵士たちは――突然の召集に応じなければならなかった既婚者たちであるが、生計の手段のない妻や幼子たちと突然に別れなければならなくなったので――その出征留守家族を援護するための特別の募金運動が街頭で行われている。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく四人目の席へ姿を現わしたのは――既婚の婦人とも老嬢ともつかず、そうかといって親戚の女とも家政婦とも、乃至はただの居候とも、確かなことはちょっと言えないが、――ともかく頭巾帽は被らないで、斑ら模様の肩掛をした、年の頃三十前後の婦人であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "未婚の男女の恋愛には、既婚者のように徹するような思慮があるだろうか。",
              "citation": {
                "source": "恋愛の微醺",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――勿論茲に云うのは、既婚の中流婦人の大多数、僅かな例外を除いた全部を指すのである。",
              "citation": {
                "source": "都会に於ける中流婦人の生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（※）　支那では既婚の男子が既婚の女子と姦通する時は、（彼等は）死刑に處せられる。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に女と云ふのは未婚者であつて、婦と云ふのは既婚者です。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も婦と云ふのは既婚者であります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社では既婚者を大体歓迎しないもんで、しづ子は旧姓のまま通していたのであった。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はせきこんで「ウン一体どこぢや」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
