    "definitions": [
      {
        "index": 1,
        "gloss": "pure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は生粋の江戸っ子で、祭りになると血が騒ぐらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この日本酒は、生粋の米だけで作られた伝統の味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は生粋の職人気質で、妥協を許さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ともかくもその瞬間に自分が子供の時分に夢みていた生粋の西洋というものが忽然と眼前に現われて忽然と消えてしまったのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮と化物とは箱根より東に住まぬことを「生粋」の江戸児は誇りとした。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "智能の世界においての貴族である彼は社会の一員としては生粋のデモクラットである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても主婦の容貌があまり日本人によく似ているから、母親もオランダ人かと念のためにＢ君に聞いてみたが、やはりまぎれもない生粋のオランダ人だという事であった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七　男の世界　生粋のアメリカ映画である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもわれわれ生粋の日本人のほんとうに要求する音映画はまだどこにもない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けぬ気の生粋の江戸ッ子としての先生を、この時目前に見ることができたような気がするのであった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は、ほとんど生粋の都会人の如き浅墓な社交振りを示して、「その弟さんは、しかし、あなたに似て頭がいいのでしょう？",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、生粋の津軽人のそれである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生粋の津軽人といふものは、ふだんは、決して粗野な野蛮人ではない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は、丈長掛けて、銀の平打の後ざし、それ者も生粋と見える服装には似ない、お邸好みの、鬢水もたらたらと漆のように艶やかな高島田で、強くそれが目に着いたので、くすんだお召縮緬も、なぜか紫の俤立つ。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うで歌っていたので、生粋のしょめ節の唄と思いちがえたでしょうが、こうした例はいくらもあるでしょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「や、生粋の樺太｜葡萄です。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の若者の言葉、生粋の長崎弁にて理解し難かりけれど、わが聞取り得たる処は、おほむね右の通りなりき。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は洒々落々の博多児の生粋、仁輪加精神の権化であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕頭に集まる者は湊屋の生前の親友であった魚市場と青物市場の連中ばかりで、一人残らず無学文盲の親方連中であったが、それでも真情だけは並外れている博多ッ子の生粋が顔を揃えていた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのｒの喉音や語尾の自然な音韻が紛れもないドイツの生粋の気分を旅客の耳に吹き込むものであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、しなやかな乙女の影が小麦畑を軽やかに歩いていったり、あるいは生粋の西部っ子として親のムスタングを悠々と乗りこなしていたり、という光景を見ることになったからだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べでは船員のうち、あやつともうふたりの仲間だけが生粋のアメリカ生まれ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "生粋の船乗りにとっては、そのぞんざいに拵えてある板細工などを攀じ登るのは、わけもないことだった。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう稼業には上方者が多いなかで、どっちも生粋の江戸っ子でしたから、自然おたがいの気が合って、兄弟も同様に仲がよかったんですが、それが妙なことから仇同士のような不仲になってしまって、一つ楽屋にいても碌々に口も利かないほどになったんです」　二人が不仲になった原因はこうであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処までも謹恪で細心な、そのくせ商売人らしい打算に疎い父の性格が、あまりに痛々しく生粋の商人の前にさらけ出されようとするのが剣呑にも気の毒にも思われた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ生粋の人ってどんななんでしょうね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生粋の江戸ツ子で、見るも精悍な美男子です。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "生粋のアメリカ人だ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父兼松は生粋の江戸ッ児で、身長こそは小さいが、火事なぞに掛けては、それはハシッコイ人物、……我子を両手に抱いたうれしさに勇気も百倍し、それから人波を押し割って元の道に引ッ返し、大神宮際の床店の所まで父は私の楯となって引き退いたのでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "新納武蔵守は薩摩武士の生粋で例の戯談好きな太閤様の歌にある、ちんちろりんのやうな長い鬚を生やした男だつたが、矢張り薩摩者に有りうちの、ちんちろりんのやうに雌を可愛がるので聞えた男だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "手数をかけりゃ、啖呵にもきっすいの江戸油をかけなきゃならねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "外遊時代に書いた「支那街の記」「西遊日誌抄」などをみると、荷風はしきりにボードレェルなどをひいて自傷の状をかなでているのであるが、荷風の本質は決して徹底したデカダンでないし、きっすいの意味でのロマンティストでもないことが感じられる。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナターシャはきっすいのソヴェト娘として育ち、生きている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
