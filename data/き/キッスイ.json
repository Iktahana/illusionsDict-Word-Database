        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "船が喫水を深くすると、港への入港が難しくなることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喫水線を目安に、船の積載量を調整する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この船舶は喫水が浅いため、航行できる海域が限られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その為船は船足重く喫水深く見えるのであった。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス船の大檣は、喫水線上二百十七尺の高さに及ぶものがある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々への航海中に、貝殻の厚い層が喫水部に付着して、速力の半ばを減じていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその掃除のために喫水部の釘が損じていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "手数をかけりゃ、啖呵にもきっすいの江戸油をかけなきゃならねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "外遊時代に書いた「支那街の記」「西遊日誌抄」などをみると、荷風はしきりにボードレェルなどをひいて自傷の状をかなでているのであるが、荷風の本質は決して徹底したデカダンでないし、きっすいの意味でのロマンティストでもないことが感じられる。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナターシャはきっすいのソヴェト娘として育ち、生きている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
