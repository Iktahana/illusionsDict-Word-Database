    "definitions": [
      {
        "index": 1,
        "gloss": "aloes wood (Taxus cuspidata var. nana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
