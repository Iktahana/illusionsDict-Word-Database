        "examples": {
          "standard": [
            {
              "text": "英単語を覚えるのに、語呂合わせの記憶法が意外と効果的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の年号を覚えるために、独自の記憶法を編み出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの人は、円周率を何百桁も暗記しているらしい。どんな記憶法を使っているんだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "従って非常に骨を折ったものであるが、規則立っての勉強も、特殊な記憶法も執ったわけではない。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の記憶法のやうなものであります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云ふ記憶法でありますが、是れなどを猶研究したならば、教へる方法は今日よりも一層完全に出來得るかと思ふのであります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
