[
  {
    "uuid": "d2a6a8e5-a7d5-5217-93c4-1d697b0a88e9",
    "entry": "局長",
    "reading": {
      "primary": "きょくちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
