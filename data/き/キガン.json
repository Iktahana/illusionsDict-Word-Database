  {
    "uuid": "ffc375a9-8e79-5fd5-90bc-2d73241f2307",
    "entry": "危岩",
    "reading": {
      "primary": "きがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "steep, towering rock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "崖の崩れた生ま生ましい痕が現はになり渓流の中にも危岩が聳え立つて奔流を苛立たせてゐる処もある。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の崩れた生ま生ましい痕が現わになり渓流の中にも危岩が聳え立って奔流を苛立たせている処もある。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或云、大月ノ分界ニ山上ニ登ルコト六町許ニシテ、危岩峨々トシテ峙立セル所アリ、之ヲ砕ケバ菊紋アリ、此処菊花山ナリトモ云、何レガ正説ナルヤ分明ナラズ、大月、駒橋元一村ナレバ、山モ連峰ニテ分界ナシ、然レバ都テ此南山ヲ菊花山ト云シナルベシ。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰頭を仰ぐと危岩が転げ落ちそうで、思わず首がすくむ、足下は何十丈だかしれぬ深谷、ちょっとでも踏みそこなうものなら、身も魂もこの世のものとは思われぬ。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より危岩錯立、登攀困難を極む。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
