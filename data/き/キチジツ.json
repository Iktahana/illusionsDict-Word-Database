        "examples": {
          "standard": [
            {
              "text": "手紙の結びに「令和六年三月吉日」とだけ書かれており、正確な日付は不明だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "招待状の日付が「吉日」となっているのは、主催者の配慮だろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い書状を読んだら、日付の欄に「某月吉日」とあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
