[
  {
    "uuid": "61bc6fb2-8d8b-5c89-996d-e2807d5bd8a6",
    "entry": "気宇",
    "reading": {
      "primary": "きう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "breadth of mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "気宇が大きく、しかも無限の抒情味に溢れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠り勝ちな家庭の女性の気宇を闊くしよう。",
              "citation": {
                "source": "女性と庭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲酒は感激を呼び、気宇も高大になる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も本州の北端の宿へ来て、気宇が広大になつたのか、仰天するほどのおそろしい蛮声を張り上げた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、Ｎ君の気宇広大の蛮声には、度胆を抜かれたものらしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "版図の大を誇る鼻の一団は、智勇豪邁、気宇万軍を圧する鼻に従ってこれに殉じました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気宇｜凜然として山河を凌銷し、万象｜瑩然として清爽際涯を知らずと書物には書いてあります。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者のレーニン的世界観の統一、政治的鍛練によって、自らそなわって来た独特の簡明さ、迫真力、革命的気宇の大さが、作品の深い光沢となってかがやき出そうとしている。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この「地区の人々」という小説は同志小林が初めてボルシェヴィク作家らしい著実さ、人絹的艷のぬけた真の気宇の堂々さで主題の中に腰を据え書きはじめたことを印象させ、その点で感動を与える作品であった。",
              "citation": {
                "source": "同志小林の業績の評価によせて",
                "author": "――四月の二三の作品――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いうのは、気宇のすぐれた女ばかりをいうのではない、眉も、顔だちも、はれやかに、背丈などもすぐれて伸々として、若竹のように青やかに、すくすくと、かがみ女の型をぬけて、むしろ反身の立派な恰好であった。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、登山の興味は、やれ気宇を豁大するとか、塵気を一掃するとか、いろいろ理屈を並べるものの、その実、誰もが恐がって果し得ない冒険を遂行する好奇心が主題であった。",
              "citation": {
                "source": "登山は冒険なり",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して小原の剛健｜沈毅な気宇、ふたりの対照はたまらなく美しい。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私は先生の政治的気宇を云々しようとはせぬが、しかし先生の熾烈敦厚な済民の志と、その実際施政の才能とには服せざるを得ない。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならず大母病気にあり、諸妹幼弱｜不解事、自ら縁を破り柱を割いて炊ぐ、云々」ところで父の左衛門太郎は馬術剣術の達人で気宇人を呑む豪傑ではあったが平常賭け事や喧嘩を好んで一向家事を治めなかったので一家の会計は少い麟太郎が所理わなければならなかった。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、山岳に対するこの親愛の情は、人々の気宇を高邁にし、同時に団結を強固にする、云々。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "気宇が大きく、又忍耐に富み、戦が不利でも驚かない。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、彼の棲む博多の町に、宗室、宗湛、宗九などといふ朱印船貿易の気宇遠大な豪商がゐて茶の湯の友であつたからで、茶の湯を通じて豪商達と結ぶことが必要だつたせゐもある。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをくらふ時、人おのづからにして気宇闊大、時に愛嬌こぼるるがごとし。",
              "citation": {
                "source": "生活のうるほひ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "気宇の壮、さういふものへの同感はなほ漠然と残つてゐても、戦乱に倦み疲れてゐた。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには彼の棲む博多の町に、宗室、宗湛、宗九などといふ朱印船貿易の気宇遠大な豪商がゐて茶の湯の友であつたからで、茶の湯を通じて豪商達と結ぶことが必要だつたせゐもある。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人百姓に至つては、大明遠征の気宇の壮、さういふものへの同感は極めて僅少で、一身一家の安穏を望む心が主であるから、不平は自ら太閤の天下久しからず、謀反が起つてくつがへる、お寺の鐘が鳴らなくなつたから謀反の起る前兆だなどゝ取沙汰してゐる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本国民の、本来、与へられたもの以上を与へ、命ぜられることをそれ以上になさんとする、かの闊達恬淡な気宇は、教育こそがこれを尊重すべきであると思ふがどうであらう。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それは飽くまでも、自分の至誠と情熱とを土台とし、信念にまで高められる「志」となつて、はじめて輝かしい希望の色を帯び、雄大な気宇を生むのです。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、真の新しい青年の典型は、ゆかしく凜々しい日本的典型の上に、若さのもつ健康と職分の嗜みとを加へ、日本青年としての雄大な気宇を自然に備へながら、男子は男子らしく剛毅に、女子は女子らしく柔軟に、それぞれ清純な風格をもつて人をして畏れ懐かしめるものでありたい。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐るべき力量は十分ありながら、父の持っていたような天空海闊の気宇に欠ける。",
              "citation": {
                "source": "書について",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨蹟の上に一番鮮明に表現されるものは、至純、横着、気宇の大なる者、小なる者、気取家、虚勢、虚飾、雅趣ある者、なき者、下等人物、上品なる者、熱ある者、なき者、学者、無学者、信力ある者、なき者、強き個性、弱き個性など、大体表われるものである。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "気宇大きければ、自ずから字の懐ろが大きい。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年の黒楽茶碗は、最初、黒瀬戸茶碗にヒントを得て、軽便焼黒茶碗として造られたものであるとの伝説がある如く、ちょっと見て黒楽茶碗に見ゆるが、しかと、作行を見る時、長次郎ものんこうもその気宇に於て到底及ぶものではない。",
              "citation": {
                "source": "志野焼の価値",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "気宇の広濶希望の雄大、任侠的の精神など、日本海賊史のその中でも、三役格といわなければならない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）南洋の風物人情の克明描写（２）新鮮で力強くてドッシリしていて、充分｜玄人的のその文章（３）必しも古く無いそのトリック（４）持ち重もりのするような荘重な作風（５）気宇広濶な国際的の味、等々々、堂々たるもので、二十枚三十枚の作などに、浮身をやつしている作家などには、真似さえ出来ない立派な作でした。",
              "citation": {
                "source": "印象に残った新作家",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
