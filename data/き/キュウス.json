[
  {
    "uuid": "ba646c9e-1876-5163-b9ed-43d38a6fc4f5",
    "entry": "急須",
    "reading": {
      "primary": "きゅうす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "small teapot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "椅子の横の台の上には薬びんと急須と茶わんとが当時のままに置いてあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間には轆轤台と陶土、出来上った急須や茶碗も五つ六つ並んでいる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯茶を無暗に飮む習慣が有つたなら、急須や茶碗を抛り出して仕舞ふが好い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と急須子をあける。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川は吭が乾くので、急須に一ぱい湯をさして、茶は出ても出なくても好いと思って、直ぐに茶碗に注いで、一口にぐっと呑んだ。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう云つて、千代子も失望して、急須に湯をつぎかけた鐵瓶を持つたままこちらの顏を見た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "竈の前に心配相な顏をして茶を沸して居たお袋はたぎつた湯を急須にさして上り框へ持つて來た。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は醤油の浸みた菜漬を旨さうに噛んでやがて冷えた鐵瓶から急須へ注いで其鐵瓶を炬燵の火へ懸けた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁が特に愛していた、蝦蟇出という朱泥の急須がある。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "径二寸もあろうかと思われる、小さい急須の代赭色の膚に Pemphigus という水泡のような、大小種々の疣が出来ている。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蝦蟇出の急須に絹糸の切屑のように細かくよじれた、暗緑色の宇治茶を入れて、それに冷ました湯を注いで、暫く待っていて、茶碗に滴らす。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯茶を無暗に飲む習慣があったなら急須や茶碗を抛り出して仕舞うがよい。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時尋ねると、「昨日は突然差押えを喰って茶呑茶碗まで押えられてしまった、」と眉山は一生忠実に仕えた老婢に向って、「オイ阿婆、何処かで急須と茶碗を借りて来な、」と平気なもんだった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おくみは急須を持つてあちらへ立つた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶盆の上の急須に無心に湯をつぎながら、さらさらと茶漬をしまつて、間もなく細君はひとりゐの淋しさに、早くから戸じまりをして床に就いた。",
              "citation": {
                "source": "女",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は古い茶箪笥から茶のはいった罐と急須とを取った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "出からしになつた急須の茶滓を茶碗の一つに空けて、机の下から小さい葉鉄の茶壺を取出したが、その手付がいかにも懶さ相で、私の様な気の早い者が見ると、もどかしくなる位｜緩々してゐる。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がらしになつた急須の茶滓を茶碗の一つに空けて、机の下から小さい鐵葉の茶壺を取出したが、その手付がいかにも懶さ相で、私の樣な氣の早い者が見ると、もどかしくなる位｜緩々してゐる。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蓮月尼は、和歌を以て有名なれども俳諧にも亦堪能にして納涼み過ぎて恥かしく成る糺川戸口にて傘の雨きる寒さ哉　などあり、また尼は、修業の傍ら陶工に耽り、その句に百ばかり急須造りて年の暮　ともあるが如く、今も蓮月焼と称する一種の古朴なる陶型は存せり。",
              "citation": {
                "source": "極夜の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何でも噂によると、高田は一つ一万円もする贋の急須を大事に蔵ひ込むでゐたさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――贋の急須が買ひ度さに、贋の女の気に入りたさに、男といふものは、せつせと飛んだり跳ねたりする。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "急須となりて茶人が長き夜のつれづれを慰むるにもあらねば、徳利となりて林間に紅葉を焚くの風流も知らず。",
              "citation": {
                "source": "土達磨を毀つ辞",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度ばかりも湯をつぐうちに、急須の中の※葉がすつかりその持味を失つてゐることは、茶好きなもののよく經驗するところである。",
              "citation": {
                "source": "短夜の頃",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時婆さんが漸く急須に茶を注れて持つて出た。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分用の小さい中古の急須と茶のみ茶わんとをひと重ねにして、それを手のひらで上から包むようなもちかたでもって、台所へ出て来た。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔風に南側が二間の高窓になっていた、そのかまちの上に急須と茶わんをのせて、七輪の方へ来てやかんをとり、自分ののむ茶をいれた。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は日本女を見ると珍しそうに目で笑い、だが何にも余計なことをいわず、頼まれただけの湯呑と急須とをゆっくり棚からとってくれた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶・急須・砂糖・コップ・匙。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康な村のニキートや技師マイコフがする通り、患者達も朝は自分の茶を急須につまんで、病院からくれる湯をついで、それがすきなら受皿にあけてゆっくりのむ。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小串へ行つて、買物をする、財布を調べて、考へ考へ、あれこれと買つた、茶碗、大根おろし、急須、そして大根三本、茶一袋、――合計金四十三銭也、帰途、お腹が空いたので、三ツ角の茶店で柏餅を食べる、五つで五銭。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
