[
  {
    "uuid": "426906a7-09cc-5d69-81df-47b6512ccc60",
    "entry": "教材",
    "reading": {
      "primary": "きょうざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
