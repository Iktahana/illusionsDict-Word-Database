[
  {
    "uuid": "07293a82-1c1d-5ea4-a36c-79801a1534c8",
    "entry": "許容",
    "reading": {
      "primary": "きょよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "permission",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術家にとつて世界は、即ち彼の世界意識は、善いものでも悪いものでも、其の他如何なるモディフィケーションをも許容出来るものではない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才者常に空威張りし、予言者嘆息するはまことに許容すべきのみ。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "反応を要求しない親切ならば受けてもそれほど恐ろしくないが、田舎の人の質樸さと正直さはそのような投げやりな事は許容しない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "交際よ、汝陰鬱なる汚濁の許容よ、更めてわれを目覚ますことなかれ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "可能性を許容するまでは科学的であるが、それだけでは科学者とは云われない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる精密科学においても吾人は偶然と名づくるものを許容す。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自然現象に偶然を許容すれば吾人の当面の問題は公算的単義性なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "予報者と被予報者との意志の疎通せざる手近き原因は、予報の指定する範囲と被予報者の利害範囲の大きさの相違と、その公算的不整合を許容する程度の差異に帰すべしと思わる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮説を許容するか、しないかで結果には非常な差を生じる。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のわがままを許容して、そのやうな冒險を敢へてしてくれた竹村書房主に、あらためて禮を言ひたい。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこの考えがいくらか穏当である事を許容するとすれば、そこからいろいろな、消極的ではあるが、だいじな事がらが想定される。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたとえば両国語の適当な語彙から比較に不適当な分子、たとえば本質的でないと思わるる接頭語、接尾語などを整理し（もちろんこれにはある仮定を要するが、それが tentative method として許容される事は、いわゆる精密科学においても同様である。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に比較の標準を少し下げて、メタセシスを許容すると、Ｐの展開式のｉ項に※が乗ぜられる事になるが（ただし子音が皆異なるとして）、これでは少なくもｎがあまり小さくない限り、明らかに最後の結果の桁数に変化は起こらない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「運動」あるいは速度加速度にともかくも確実なる物理的現象、可測的現象としての存在を許容して、時間のほうをむしろ従属的のものと考えているかのように見える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその「部分」に有限な大きさを考えるとすれば、無限の種類を生ずるためには結局無限大の大きさのものの生ずる事を許容しなければならないことになるのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように純粋に物質的な現象、すなわち地震のような現象と、生物的、かつ人為的要素の錯雑した漁獲といったようなものとの間の相関を取り扱うことが科学的に許容されるかどうかという問題については、往々物理学者の側でもまた生理学者の側でも疑問をさしはさむ人が存するようである。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見る器械」、「聞く器械」としての優劣の存在を許容するのもやむを得まい。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう見方を進めて行くと、結局、いわゆる創作とは、つじつまを合わせるために多少の欺瞞を許容したこしらえものの事であり、随筆とは筆者の真実、少なくも主観的真実を記録したものであるというふうにも見られる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、もしも、こういう場面の発声ニュース映画の撮影映画が許容されるとしたら、どうであろう。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら神さまが寛大だからといって、これだけは御許容なさるまい。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プライドが、虫が、どうしてもそれを許容できない場合がある。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は、喧嘩を好まず、否、好まぬどころではない、往来で野獣の組打ちを放置し許容しているなどは、文明国の恥辱と信じているので、かの耳を聾せんばかりのけんけんごうごう、きゃんきゃんの犬の野蛮のわめき声には、殺してもなおあき足らない憤怒と憎悪を感じているのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし以上の考察はこれら因子中の最も重要なるものに関したもので、これからの結論がだいたいにおいて事実とあまりに懸隔したものではないという事も許容されるだろうと信じる。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは過去の封建制度によってこれが強調されたということは許容しても、人力のいかんともし難い天然環境の影響は将来においてもおそらく永久に継続するであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように、自分の明日の仕事に少しも差支えのないことで客人達を喜ばせ、客人達もその利己主義を許容し、主人夫妻をして明日のために充分眠らしめ、そこで自分も安心して自分達の愉快を尽すというところに、本当の利己主義の妙味があると思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスト教信者諸氏、処を換えて次の如き命題を諸氏は許容するか、仏教国に生れてクリスト教を信ずる所以はどうしてもクリスト教が深遠だからであると。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体こんな残酷な運命の悪戯を、果してわれわれはそのまま許容してしまっても差閊えないものであろうかと、私は嘆き、悲しみ、憤りました。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが子供たちの純潔なロマンチスムは、かかる父の俗惡性を許容しない。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此処には、もちろんいかなる例外をも許容しない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
