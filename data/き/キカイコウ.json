[
  {
    "uuid": "987cb6b3-d6d2-5e94-b3a3-75cea5422092",
    "entry": "機械工",
    "reading": {
      "primary": "きかいこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
