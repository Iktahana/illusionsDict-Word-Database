[
  {
    "uuid": "7d67a42a-1f16-5441-9605-3a081dbee50e",
    "entry": "気の利いた",
    "reading": {
      "primary": "きのきいた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
