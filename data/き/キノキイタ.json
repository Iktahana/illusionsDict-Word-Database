    "definitions": [
      {
        "index": 1,
        "gloss": "sensible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女はいつも気の利いた一言で、場の雰囲気を和ませてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気の利いたプレゼントを選んでくれたので、とても嬉しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まあ、気の利いたこと言ってくれるじゃない、ありがとう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が気の利いた提案をしてくれたおかげで、会議がスムーズに進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "気の利いたタキシーがすぐ側へ乗りつけて来て無言で扉をあける。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山寄りの道を行く方が山の岳神を探すに便利は多いようなものの、それ等の山は多く未開の山で、ちょっと人に訊いただけでも、山の主は、百足であるとか、猿であるとか、鷲であるとか、気の利いた山の神ではなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱で渇いた口に薫りの高い振出しをのませ、腹のへったものの前に気の利いた膳をすえ、仕事に疲れたものに一夕の軽妙なレビューを見せてこそ利き目はあるであろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして恐る可き殺人事件が突如として映つたり、素敵に気の利いた探偵が走つたりする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か気の利いた花を見立てて買って来てくれないか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽せ札を作り出せるような気の利いた、男ではなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉はもう三十以上で、見るからに気の利いた、威勢の好い男であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってせっかく釣って帰っても、今｜小父さんの言った通りにネ、昨日は、こんな鮒なんか不味くて仕様がない、も少し気の利いた魚でも釣って来いって叱られたのだもの。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが、そりゃ私どもはじめ世間で感心する事で、当の対手は何の女ッ子の生命なんざ、幾つ貰ったって髢屋にも売れやしねえ、そんな手間で気の利いた香の物でも拵えろと、こういった工合でなくッちゃ色男は勤まりませんよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅毒患者が療養すべき土地にして、わざわざ東京から見物がてら避暑なぞという気の利いた所ではない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも震災前までは四間半の間口を張つて、少しは気の利いた西洋料理屋を遣つてゐたんですが、震災で何も彼も型無しになつて仕舞つたので、半分を隣のパン屋に貸して……。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿なしにしては気の利いた寝床だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「香をたく代りに、煙草をたいてるのね」　と、冴子はちょっと気の利いたことを言った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、気の利いた言葉を言っているだけにすぎないのかも知れない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "）して、余も何かスバラしいのを考えたのですが、どうも気の利いたのは全部昔の奴が使ってしまった後なので、今更もう発見し得ないのか、と散々考えて居た所、東京は京橋、中橋広小路、千疋屋の隣の自動車屋の向いにある骨董屋の屋号が何と「壺中居」というのであったのであります。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮にも人の座敷へ呼ばれて来て、気の利いたふうな真似をするもんじゃないわよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "所へある気の利いた男が出て来て、煤煙の全部を出版しやうとすればこそ災を招く恐れがあるので、そのうちの安全な部分｜丈を切り離して小冊子に纏たらどんなものだらうといふ新案を提出した。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう少し気の利いたものになりたいんですが、事情が許しそうもないのです」「張合のないことおっしゃるのね。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうことは多少気の利いたこともいうが、機械人間が物言うように発声の構造が云っているのだ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝の姿は見えねど、滝壺の裾の流れの一筋として白絹の帯上げの結び目は、水沫の如く奔騰して、そのみなかみの※々の音を忍ばせ、そこに大小三つほどの水玉模様が撥ねて、物憎さを感ぜしむるほど気の利いた図案である。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもっと気の利いた面白い女へ移る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）公子　（卓子に腰を掛く）たいそう気の利いた書物ですね。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "結城の藍微塵の一枚着、唐桟柄の袷羽織、茶｜献上博多の帯をぐいと緊め、白柔皮の緒の雪駄穿で、髪をすっきりと刈った、気の利いた若いもの、風俗は一目で知れる……俳優部屋の男衆で、初阪ものには不似合な伝法。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれもお前に貰って、見たが、版がわるい上に、紙も子供の手習いにも使えぬ粗末なもので、むろん黒の一色刷り、浪花節の寄席の広告でも、もう少し気の利いたのを使うと思われるような代物だった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草について気の利いた名文句を考えている余裕などなかった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "長身の、まだ若いが、職掌柄だけに凛として気の利いた顔貌と風采の持主だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだ新しい小説や脚本は出ていぬし、抒情詩では子規の俳句や、鉄幹の歌の生れぬ先であったから、誰でも唐紙に摺った花月新誌や白紙に摺った桂林一枝のような雑誌を読んで、槐南、夢香なんぞの香奩体の詩を最も気の利いた物だと思う位の事であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあ　この磨きのきいた林檎の一顆から買つて頂きたいのでございます。",
              "citation": {
                "source": "果物屋の広告文",
                "author": "仲村渠",
                "note": "青空文庫"
              }
            },
            {
              "text": "女らしくきのきいた（機智のある）ものの云いかたの中に批評も反駁も主張もふくませる、という調子で、アメリカの所謂上流文化人の社交性の文字化されたような味があります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
