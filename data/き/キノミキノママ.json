        "examples": {
          "standard": [
            {
              "text": "火事の時は、着の身着のままでなんとか外に逃げ出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は突然の出張にもかかわらず、着の身着のままで空港へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "津波から逃れるため、多くの住民が着の身着のままで高台に避難した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい街に引っ越したものの、着の身着のままなので、まずは生活用品を揃えなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この頃はさツぱり加集はやつて來ませんから、宿を變へる必要はないと思ひますが、ふだんの着がへまで質に入れて、着の身着のままですから、わたしが入れた質物を出してしまひました。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸から、田舎へのがれてくる時分に、みんないろいろなものを捨てて、着の身着のままで逃げなければなりませんでした。",
              "citation": {
                "source": "さかずきの輪廻",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け跡に立った光明翁、「原因は放火ですが火の回りが早く、とうとう着の身着のまま、陶器も全部駄目です。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
