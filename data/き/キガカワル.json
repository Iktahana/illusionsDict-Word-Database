          "literary": [
            {
              "text": "人間て、気が変わるからな」「だって、ビートルズだよ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも女と心中する約束をして置きながら、女の死んだのを見て急に気が変わるなんて、あんまり薄情じゃありませんか。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "変梃な蝶をなくしたことぐらいで、気が変わるとは解せないよ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると不思議なことに、それから二三日中の間に必ず天気が変わる。",
              "citation": {
                "source": "音の世界に生きる",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すずめは、いよいよ天気が変わると思いました。",
              "citation": {
                "source": "春になる前夜",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、俺の知らない、天気が変わる前兆だろうか。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
