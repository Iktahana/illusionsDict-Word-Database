    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lodging",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "舎監になつたが、夜になると時々寄宿生の誰かが便所へ行く音がするきり何にも聞こえないと此の間の手紙には書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は寄宿舍で勉強してゐる學生のやうである。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならんで光って何かの寄宿舍の窓のやうだ。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこのみちばたの青いいろの寄宿舎はゆっくりして爽かでよかったが。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、物理学教科書にある方則と寄宿舎の規則との区別を自覚している生徒がどれだけあるか疑わしい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯島に就て　寄宿舍の受付には外國からの映畫雜誌が飯島宛に澤山來る。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯島は中谷と私とが三高の寄宿舍で同室だつたことがある。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "此某町から我村落まで七｜里、若し車道をゆけば十三｜里の大迂廻になるので我々は中學校の寄宿舍から村落に歸る時、決して車に乘らず、夏と冬の定期休業毎に必ず、此七｜里の途を草鞋がけで歩いたものである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七｜里の途はたゞ山ばかり、坂あり、谷あり、溪流あり、淵あり、瀧あり、村落あり、兒童あり、林あり、森あり、寄宿舍の門を朝早く出て日の暮に家に着くまでの間、自分は此等の形、色、光、趣きを如何いふ風に畫いたら、自分の心を夢のやうに鎖ざして居る謎を解くことが出來るかと、それのみに心を奪られて歩いた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この某町から我村落まで七里、もし車道をゆけば十三里の大迂廻になるので我々は中学校の寄宿舎から村落に帰る時、決して車に乗らず、夏と冬の定期休業ごとに必ず、この七里の途を草鞋がけで歩いたものである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七里の途はただ山ばかり、坂あり、谷あり、渓流あり、淵あり、滝あり、村落あり、児童あり、林あり、森あり、寄宿舎の門を朝早く出て日の暮に家に着くまでの間、自分はこれらの形、色、光、趣きを如何いう風に画いたら、自分の心を夢のように鎖ざしている謎を解くことが出来るかと、それのみに心を奪られて歩いた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の支那兵は、女学生の寄宿している宿へ入り、彼等の飢えた性欲を十分に満足させた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが、二棟の寄宿舎に閉じこめられてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎の方で涙ぐんで淋しげに黙っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二棟の寄宿舎は、険悪なけしきに満ちた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マッチ工場の寄宿舎から、工人を他の一棟へ追いやって、そこの高粱稈のアンペラに毛布を拡げ、背嚢か、携帯天幕の巻いたやつを枕にして、横たわった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、マッチを箱に詰めるところや、職工の寄宿舎には、婦人もいるんだから、用事のないのに、そこへむやみに出入りしてはいけない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七　軍隊は、工場の寄宿舎の一と棟に泊まっただけだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎は狭くなった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のざらざらした、屋根がひくい、息づまる寄宿舎で、彼等は思い／＼の考えにふけった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のない、支那風の暗い寄宿舎には、男ばかりのくさい息がこもった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは、一度兵士達が見つけて以来、勤務について、寄宿舎にいなくなった留守を見はからって敢行された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人の大蒜や葱の匂いと、兵士の汗と革具の匂いが交錯して、寄宿舎の厚い重たい壁についているようだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い寄宿舎で、彼等は、それを読んだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まもなく、寄宿舎と工場内に大騒動が起った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫びながら、寄宿舎から逃げるように駆け出してしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実際居留民の保護だけなら、何故、こんな不便な、きたないマッチ工場の南京虫がうようよしている寄宿舎に入れて置くかね？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の奥の方では寄宿の窓のガラスも光る。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ここは何かの寄宿舎か。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが次の朝になって、やっと太陽が登った頃、寄宿舎の生徒が三人、げたげた笑って小屋へ来た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
