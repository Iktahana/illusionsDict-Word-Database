[
  {
    "uuid": "edb68ff9-a279-503b-b21f-12e0e2f91476",
    "entry": "興味をそそる",
    "reading": {
      "primary": "きょうみをそそる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
