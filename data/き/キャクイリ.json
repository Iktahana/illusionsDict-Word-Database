        "examples": {
          "standard": [
            {
              "text": "平日の昼公演にしては、かなりの客入りで立ち見も出ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "悪天候の影響で、今夜のライブは客入りが芳しくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幕が上がる直前、舞台袖からそっと客入りを確認して深く息を吐いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "店に羊頭を掛けてその肉を売らんというものあり、客入りてこれを需むればこれに狗肉を与う、知らざる者は見て羊肉となし、しかして恠しまず、世間政論を業とする者これに類すること多し。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は座敷へ戻つて再び酒宴がひらかれたが、俄に乱酔が始まつて、主客入りみだれて全員たゞゴチャ／＼ともつれてゐる。",
              "citation": {
                "source": "朴水の婚礼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
