          "literary": [
            {
              "text": "過去の文学はもはやそれなりで今日の救命袋とはなり得ない。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、中学から高等学校、高等学校から大学と幾つかの学校を通り抜けることは僅かに貧困を脱出するたった一つの救命袋だった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、中学から高等学校、高等学校から大学と幾つかの学校を通り抜けることは僅かに貧困を脱出するたつた一つの救命袋だつた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて救命袋に食糧品をくくりつけて、投げてやれ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　フーラー博士が、救命袋を投げたのは、この時である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "清君は、つかれた体を動かして、やっと救命袋にすがりついた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しい、さみしい闇の中で、清君は救命袋にすがりついたまま、いずくともなく流されてゆくのであった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
