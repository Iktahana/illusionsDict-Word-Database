          "standard": [],
          "literary": [
            {
              "text": "○保険の金はそっくり井上金太郎氏にお渡しする事。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍馬の水をやる、ニイ小輩　五色旗を持つ　空、戦火、黒煙が夕立雲の様　荒れ果てた土の上の烏三羽手紙（井上金太郎　宛）　十六日の朝になってもまだいつ上陸するのか分りません。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（井上金太郎　宛）　揚子江岸に上陸して南京入城に至る迄の一ヶ月間はまことに、はや、タイヘンなもンでした。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の諸兄によろしく（七月二十三日）（井上金太郎　宛）　腹くだりで入院なぞと真とに不甲斐ない話のようですが僕としては、身体の続く限りやるだけの事はやった後でブッ倒れたのですから（入院の時軍医さんの前で文字通りヘタヘタと倒れました）俯仰天地に恥じません。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜間金太郎氏の演出なぞは素人眼にはスゴミが横溢しているようであるが、よく見ているとそのスゴ味は金春一流の意識的な気合い（アテ気と言っては過ぎる）から生まれたものであることが次第次第にわかって来る。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、金時、足柄山、えらいぞ金太郎。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太郎と云ふ芸者がひよつとこ踊でよく喝采を博した。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "能樂師、松本金太郎叔父てきは、湯どうふはもとより、何うした豆府も大のすきで、從つて家中が皆嗜んだ。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は金太郎の人形と飾り馬との二箱を風呂敷につつんで抱えていた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき私のからだは無事であったが、抱えていた五月人形の箱は無論投げ出されて、金太郎も飾り馬もメチャメチャに毀れた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）のは阿母一人で、昔物語に聞く山姥と金太郎とを其のままに、山※や猿や鹿や蝙蝠を友としつつ、此に二十余年を送り来った重太郎自身に取っては、人間の身分や階級などは、何の値も無いものであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで金太郎は、二時間といふ僅かな時間をもてあましてしまふ。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふことが時々あるのだが、人間は果してこんな時仕合せなのか不仕合せなのか、と金太郎は考へたがそれも解らない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで金太郎は、一つ自轉車で町にでも出て來ようと思つて母に何か用事はないか訊ねると生憎ないさうである。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太郎はさて、家の前で身｜輕にひよいと自轉車にまたがつた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして金太郎は、更めて自分が專門學校生｜徒である誇りにうつとりする。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "專門教育を受ける人間は現代日本では六十人に一人の割合であると、以前に誰からか聞かされたことのあるのを思ひ出しながら、金太郎は坂を下り始めた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはいけないと金太郎は思つた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩足をもう一度ペタルにのせて速度を制御しようとしたが、ペタルの囘轉は速さを増すばかりで金太郎の足を寄せつけない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大事に到らず濟むことは確かだ、と金太郎は、速度を増してゆく自轉車の上で、幾何の問題を解くときのやうに冷｜靜に推理した。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで金太郎は體を固く小さくして、道の白い流れの上へ、飛びこむやうな具合に轉んでいつた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで金太郎は、二三米先へ歩いていつて自轉車を起すと、またそれにまたがつて、今度はペタルから足を離さぬ樣に注意し、適當に速さを加減しながら坂の下へおりていつた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太郎が帽子をとつてお辭儀をすると、山下先生は眼を絲のやうに細くして、春｜休みは何日までか訊ねた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太郎は路傍の道しるべの石に片足をかけて、自轉車に跨つたまゝ憩みながら、今｜晩たつといふ返事をした。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今別れた愛想のよい山下先生が、金太郎の入學を喜んでくれた時、この町で一番｜偉くなつてゐるのは××大學の教｜授をしてゐられる林信助さん、その次に偉くなるのは君だとみんなが云つているから、しつかり勉強したまへ、と言つた言葉を憶ひ出し、惡い氣持はしなかつたのである。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの事だから、ホームまではいるのはよせといつて、すみ子を出口のところに立たせておき、金太郎はブリツヂを渡つた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が出るとき金太郎は、出口の方の妹に手をふりながらも彼女の左右や背後を見た。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが……例へばすみ子を可｜愛がると同時に金太郎にも愛を感じてゐるといつた風のすみ子の上｜級生か何かゞ、こつそり金太郎を見送つてゐはしないかと思つたのである。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、發車間｜際に慌てゝのつたらしい、鞄を持つた、營利會社の外交風の男が二人、金太郎のうしろの、も一つうしろのボツクスに腰を卸して何か話し出した。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
