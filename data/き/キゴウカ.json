        "examples": {
          "standard": [
            {
              "text": "複雑な感情を、あえて短い詩の形式に記号化して表現してみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この暗号化アルゴリズム、データを記号化する工程でかなり負荷がかかるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文化人類学では、儀式的な行為がどのように社会的な意味を記号化しているかを分析する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デザイナーは、ブランドの理念をロゴという形に記号化することに心血を注いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば重さがいくらという普通の言葉による普通の文章は、物理学的には、人工的にそして数的に定義された重量という記号化された言葉を枢軸として、定式で叙述したり或いは普通の文章で叙述したりする。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
