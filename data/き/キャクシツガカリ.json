        "examples": {
          "standard": [
            {
              "text": "旅館に到着すると、ベテランの客室係の方が手際よくお茶を淹れて部屋の案内をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すみません、枕をもう一つ追加できますか？」と通りかかった客室係に声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "客室係として長年勤めている叔母は、宿泊客の顔と名前を一晩で覚える特技を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ホテルのジェイムズ・ライダー客室係長の証言では、事件当日、ホーナ容疑者をモーカー伯爵夫人の化粧室まで連れて行ったという。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵夫人が普段から宝石を保管している箱だとは知らなかったものの、客室係長はすぐ通報、容疑者は同日晩に逮捕された。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル・コズモポリタンの客室係長。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、やつとのこと、郵船Ｋ丸の客室係を勤めさせていただくことにきまりました。",
              "citation": {
                "source": "緑の星",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
