  {
    "uuid": "3c72fb21-2233-5538-ba4d-ddc666f18472",
    "entry": "機関士",
    "reading": {
      "primary": "きかんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "engineer (on a train, ship, aircraft, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ａ操縦士はハンドルに、Ｔ機関士はエンジンにそれぞれ全神経を集めていた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士ははっとして眼をあげた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ」　Ｔ機関士は思わず叫んだ。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（よかった）　Ｔ機関士はほっとした。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "発動機の整備と云う重大な任務をもっているＴ機関士は、出発の時には何人よりもさきに機上の人となるので、したがって何んな客が幾人乗るか、そんな事にはすこしも注意しなかった。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士は鉛筆を執ってメモに何か書いていたが、やがてそれを前にいるＡ操縦士に渡した。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士はまたメモに鉛筆を走らした。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（客席には一人しか見えないが、おかしいなあ）　Ｔ機関士は不思議に思って後を見た。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（やっぱり一人だ）　Ｔ機関士がそう思った時、Ａ操縦士の右手が動いて、前の防風ガラスに指が往った。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にＴ機関士は背すじに水をかけられたように思った。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士はあわてて鉛筆をとると、何かに追われるようにしてメモの上に走らした。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ」　Ｔ機関士の云ったように、たしかに後の客席に痩せぎすな一人の紳士がいるのであった。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、Ｔ機関士に手真似で、「往ってみよ」　と云うようにした。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士はうす鬼魅が悪かったが、それでも勇気を出して客室の方へ進んで往った。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（へんだぞ）　Ｔ機関士はドアの後から椅子の下をきょろきょろと見まわしたが、今までいたはずの客の姿はどこにも見えなかった。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて蒼白い顔をして座席へ帰って来たＴ機関士は、夢中で三本の気弁桿を握った。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士は無言のままその指針を見つめていた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の脱走者機関士舵をあげろ　同志ワフラメヱフ君はなんといふ眼をするのだそんな眼差しを何処に隠してゐたのだ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士可哀さうな、ワフラメヱフよ、君はいま、歩いてゐるんぢやないんだよ、君は金属の鳥に乗つてゐるんだよ、しつかりしてくれよ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士君はまるで駄々つ子だよ、一台の飛行機に二つの闘争が乗つてゐるんだよ、君が私を愛してゐる友情と、私が君を愛してゐる友情と、どつちが熱烈だらうか。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士新しい世界を古い自由の物指しではからうとする者は、ソビヱットでは総べて苦しいのだ、これらの毛のぬけた犬や鼠はソビヱットの袋の中にゐる。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士私はソビヱットを愛してゐる、そのためにこそ――。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士力尽きた鳥よ、聴け、発動機の音を――、お前の咽喉は異様に鳴つてきた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士君の心の中の浚渫船、古い泥の掻ひ出しの仕事を停めた、瞬間、君には寂寥がきた、時代は青年のものだ――とレーニンは言つた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士そうだ死の平穏が――。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、汽車の機関士の烈しい罵声が、狼狽した運転手の耳朶を打った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな声ではいえないが、連盟脱退後の日本艦隊はどこまで強いのか、底力の程度がわからないてえことだぜ」　機関士官は、だいぶん恐日病にかかっているらしい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の艦隊をして、各個撃破の挙に出でしめないのが、そもそも英ソ軍事同盟の一等大きな狙所なのだ」「ふーむ、うまいことを考えたなあ」　機関士官は、嬉しそうに、はじめてにやりと笑った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、とても勝利を信ずることができない」　機関士官は、また蒼くなった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、汽車の機関士の烈しい罵声が、狼狽した運転手の耳朶を打つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
