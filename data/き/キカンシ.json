    "definitions": [
      {
        "index": 1,
        "gloss": "bronchus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「違う」「気管支カタルでは？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎や浸潤や気管支カタルだったら、必ず私の力でなおしてあげる。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄石は気管支の苦痛を、長火鉢によりかかって耐えているようだったが彼の心の中は、麻のように乱れていた。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冬笹村のふと冒された風邪が、長く気管支に残った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少は快くなつた筈の胃のアトニイは相変らずで、食べものが不自由なので、後戻りした形だつたが、気管支もひどく悪くなつてゐた。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はそれを小さい時にわずらった気管支のせいにしていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "保子から、やれ胃腸が悪いの、やれ気管支が悪いの、やれどこが悪いのと、手紙のたびにいろいろなことを言って来るが、要するにいよいよ肺に来たのじゃないかと思う。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者はよく肺の初期をつかまえて、胃腸だの気管支だのと言うものだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "都をば泥海となしわが子等に気管支炎を送る秋雨　今日の東京も滅茶滅茶にこはれてしまつたが、明治末年の雨の日の東京の道路と来たらお話にもなにもあつたものではなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中の冷気にさわってか、お上さんは感冒にかかり、気管支から肺尖をいため、高熱が続いた。",
              "citation": {
                "source": "オランウータン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬はインフルエンザとなり、喘息となり、気管支炎となり、肺炎となりて、親と子と八人を責め苛む。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病名慢性気管支加答児。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの二年ばかし以来のことだが、彼は持病の気管支と貧乏から、最も恐れている冬が来ると、しばしばこの亡霊に襲われたと言うのだ。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "気管支肺炎から肋膜までわるくし、高熱を出した。",
              "citation": {
                "source": "早春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○風邪急に気管支まで侵入したと見え、しきり、末期の息のような音を出す。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人が大腸カタルや気管支カタルで死んだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "気管支が悪いと医者に注意されもしたし、雨の日など寝て過したりした。",
              "citation": {
                "source": "鳥羽家の子供",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷口博士にみてもらひましたら、慢性の気管支加答児とかいふ病気で御座いますって……。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしは日本の気候が合わなくて、よく気管支炎をやりましたが、今でもそんなことがございますのでしょうか？",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "気管支加答児の方は殆んどよくなったと医者から告げられていた。",
              "citation": {
                "source": "愚かな一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "転地してから二ヶ月、最近感冒から気管支に加答児を起した危険な二週間、その間のことを考えた。",
              "citation": {
                "source": "愚かな一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で気管支加答児と肺炎とを併発した。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ僕の気管支と同じ程度のものさ。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが変にこじれて、気管支加答児となり、高い熱が出た。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気は気管支加答児だけで、それも大したことはないそうだった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、真面目な調子で――気管支炎なの、病気は……。",
              "citation": {
                "source": "モノロオグ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の話では、筋向うの、嬰児も、気管支で、今日中は持つまいと云う事だ。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこんな時に一寸風邪をひいて、嚔をすると、血粒が気管支から出るので、自分にも気味が悪かつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると気管支炎とある。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "気管支炎と云えば肺病の下地である。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
