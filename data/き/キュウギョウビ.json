        "examples": {
          "standard": [
            {
              "text": "すみません、当店は毎週水曜日が休業日となっております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴールデンウィーク期間中は、多くの企業が休業日を設けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急な休業日のお知らせで、お客様にはご迷惑をおかけいたしますが、ご理解のほどよろしくお願いいたします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来月は工事のため、数日間が休業日になる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日は一日で休業日だからほかの使用人は一人も居ない。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "水分のない蒸気のためにあらゆる行李は乾燥して飽くことない午後の海水浴場附近にある休業日の潮湯は芭蕉扇の様に悲哀に分裂する円形音楽と休止符、オオ踊れよ、日曜日のビイナスよ、しはがれ声のまゝ歌へよ日曜日のビイナスよ。",
              "citation": {
                "source": "LE URINE",
                "author": "李箱",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
