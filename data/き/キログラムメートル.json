        "examples": {
          "standard": [
            {
              "text": "100キログラムメートルの仕事をするには、どれくらいの力を加えれば良いのだろうか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このクレーンは、最大1000キログラムメートルの負荷を持ち上げることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "仮想仕事の原理を学ぶ際、微小な変位に対する仕事量（キログラムメートル）の計算が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この結果に拠れば、広い室で演説する場合ならば、一時間につき一四四ないし二八八キログラムメートルの仕事をする。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
