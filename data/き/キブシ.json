        "examples": {
          "standard": [
            {
              "text": "春の訪れを告げるように、庭の木五倍子の黄色い花が咲き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山道を歩いていると、木五倍子の独特な花の形に目を奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "木五倍子の実を子供の頃に遊んだ記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "生け花に木五倍子の枝を使うと、とても趣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ジュル・ラフォルグお月樣のなげきぶし星の聲　膝の上、　天道樣の膝の上、踊るは、をどるは、　膝の上、　天道樣の膝の上、星の踊のひとをどり。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪のよるひるも、起きぶして、いかばかり彩鳥の音の恋ひしき。",
              "citation": {
                "source": "あやどり",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            }
          ]
        }
