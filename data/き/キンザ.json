    "definitions": [
      {
        "index": 1,
        "gloss": "Edo-period gold mint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
