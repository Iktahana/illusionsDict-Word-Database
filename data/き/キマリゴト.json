        "examples": {
          "standard": [
            {
              "text": "この地域では、お盆には家族で集まって墓参りするのが決まり事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の飲み会では、上司のグラスが空になったらすぐに注ぐのが暗黙の決まり事になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大会での服装は、事前に指定されたものが決まり事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部活の練習が終わったら、全員でグラウンドのゴミ拾いをするのが決まり事です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "でも、でたらめなじかんにくるなら、いつ心をおめかししていいんだか、わからない……きまりごとがいるんだよ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きまりごとって、なに？",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、おいらをねらうかりうどにも、きまりごとがある。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
