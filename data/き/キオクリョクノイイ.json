        "examples": {
          "standard": [
            {
              "text": "記憶力のいい彼は、一度聞いた話を忘れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラスに記憶力のいい子がいて、いつも感心させられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は記憶力のいい人だから、細かい部分まで覚えているだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "記憶力のいい人は、試験勉強にあまり苦労しない傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "平尾は出っ歯で、近眼で、みんなの中で一ばん不景気な顔をしているが、おそろしく記憶力のいい勉強家で、三年の頃からめきめきと成績をあげ、四年以来一度も首席を人にゆずったことがないというので有名になっている。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
