    "definitions": [
      {
        "index": 1,
        "gloss": "road (or railway) cut through hilly terrain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近頃の新しい畫學生の間に重寶がられるセザンヌ式の切通し道の赤土の崖もあれば、そのさきには又舊派向きの牛飼小屋もあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "據なく車掌臺に立つて外を見て居ると、或る切通しの崖の上に建てた立派な家の庇が無殘に暴風に毀されて其儘になつて居るのが目についた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし或は家の方が先に建つて居たので切通しの方が後に出來たかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灌木や竹藪の根が生なました赤土から切口を覗かせている例の切通し坂だった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から夏休みにの、お邸中が浜の別荘へ来てじゃに就いて、その先生様も見えられたが、この川添の小橋の際のの、蘆の中へ立てさっしゃる事になって、今日はや奥さまがの、この切通しの崖を越えて、二つ目の浜の石屋が方へ行かれたげじゃ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎がちらちらと白く飛んで、浜の二階家のまわり縁を、行きかいする女も見え、簾を上げる団扇も見え、坂道の切通しを、俥が並んで飛ぶのさえ、手に取るように見えたもの。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……切通しは堰を切つて俥の瀧を流した。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お蔦　切通しを帰るんだわね、おもいを切って通すんでなく、身体を裂いて分れるような。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、市川｜女寅が本郷の春木座へ稽古に通う途中、湯島切通しの坂へ差しかかりし時、俄かに眩暈を感じて人力車を降り、路ばたの西洋小間物屋へ転げ込みしに、店の人々は大家の夫人と見誤まりしという。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "切通しをのぼると、かそかな春の夜風にのって、ひゅうひゃらりゃりゃと笛の音が聞えて来ました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "切通し坂の上に来たとき、一人の子が、もう一人の子の耳に口を寄せて何かささやきました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でげすがな、これから切通しの坂を一ツお下りになりゃ、五両と十両は飛ぶんでげしょう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにつけ、またそれよ、壱岐殿坂で鼠の印を結んでより、雪の中を傘なしで、池の端まで、などと云うにつけても、天保銭を車に積んで切通しを飛んだ、思案入道殿の方が柄が大きい。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丘の、後ろが切通しになり、蒲田から大井へ通ずる貨物線が敷かれた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "持主は湯島切通しの質屋で、そこの隠居がついこの間まで住んでいたのが亡くなったので、婆あさんは本店へ引き取られたと云うのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お負に小綺麗な所で店賃の安い所へ越したいから、世話をしてくれろと云うので、切通しの質屋の隠居のいた跡へ、面倒を見て越させて遣った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は湯島切通しから、岩崎邸の裏手へ出る横町で、曲りくねった奥にある。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち南から切通しを経る道と、北から無縁坂を経る道とで、この二条は岩崎邸の内に中心を有した圏を画いている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで利害を比較すれば、只｜振かな切通しを避けて、寂しい無縁坂を取ると云うことに帰着する。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷たい夜露を踏んで、ひとりの男が湯島の切通しをぬけて、本郷の大通りへ出て、かの加州の屋敷の門前にさしかかった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて朝夷の切通しに近いという頃に、むこうから同じく牛を牽いた男が来るのに出逢った。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この引込線は全線に亙って深い切通しの底を走っているのだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何人かが切通しの縁に立っていない限りは列車の姿の眼に留まるはずがないからだと。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "切通しを通るまえに、湯島……その鳥居をと思ったが、縁日のほかの神詣、初夜すぎてはいかがと聞く。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日は本所の五百羅漢へゆくつもりで、本郷通りを真すぐに切通し、寄席の求肥の、めがねへ出ました。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戻つて切通しの坂へかゝつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊濁点付きの二倍の踊り字は「／″＼」-------------------------------------------------------　久野の家を出た三人は、三丁目から切通しの方へ、ブラ／＼歩いていた。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青いなかの切通しへ三人の車が静かにかかって行く。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はその二百二十日の雨の中を、また切通し越に町の方へ下った。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
