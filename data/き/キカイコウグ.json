        "examples": {
          "standard": [
            {
              "text": "作業員は、機械の調整に必要な機械工具を棚から取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "定期的なメンテナンスには、専用の機械工具が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの機械工具を使うと、作業時間が大幅に短縮できるらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "食糧、衣料、燃料、機械工具などいっぱいつまっている。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
