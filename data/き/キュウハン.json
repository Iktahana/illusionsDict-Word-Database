      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "steep slope",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひどい急坂を上る機関車のような、重苦しい骨の折れる時間が経った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が急いで急坂を上るのは、私の身心から発散する墓場の雰囲気が恐ろしかつたのだと、私は考へた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "急坂を登り切らうとする所、村の部落外れに、荒ら屋がある。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の小市街の横町は水平であるが、本通りは急坂で、それが極めて不規則な階段のメロデイーの二重奏を奏してゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急坂を這ふやうにしてよぢ登り、一時間ほどにして三ツ峠頂上に達する。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急坂に添つた石垣の上の芝土手（築地と歌には言つたが、日本風のそれではなく、洋風の芝の土手である。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今此急坂の頂に立ちて願望せんか、前と左右との峯巒之を限らざるの間は、遠きもの、近き里悉く指呼の間にありて點々たり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に至りて鐵面子を待つ馬は、急坂突兀たるを以て注意して下る故に遲々として進まず、久うして至る。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武ちゃんが、足を出して転がしたあ」「大きな子が、何もしないのに、殴ったあ」「本が失くなッたあ」「遅くなっちゃッたあ」　などと言って、急坂を泣き下って帰って来るのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「探しといで」　と言うと、ランドセルを置いたまま、また小川沿いに急坂を上って行った。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄んどころなくわたしは跣足になつてものゝ一丁あまりもあらうといふ急坂を芋畑の上から下まで糸を引いたまゝ一散に駈け降りるのであつた。",
              "citation": {
                "source": "山峡の凧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴を鳴らして急坂を滑る橇に打ち乗つて、ブレイキを握りながら風を切つて、口笛を吹きます。",
              "citation": {
                "source": "祝福された星の歌",
                "author": "An episode from the forest",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびか清溪をわたり、危巖をつたひ、終に急坂を上りはつれば、山上に通ずる路あり、海岸に下る路もあり。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "急坂を下りに下りて、やれ安心と思ふ折しも、路を失ひて澤に行當れり。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十九折の急坂を登つて行くと、路に山茶花の花が散つてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処より逆落しの様な急坂を降れば海の口村、路もよくなり、もう中村君も歩いてゐた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十九折になつたその急坂を小走りに走り降ると、坂の根にも同じ樣な村があり、普通の百姓家と違はない小學校なども建つてゐた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹路といふ急坂を登り切つた頃から日は漸く暮れかけた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹路の急坂にかゝつた時であつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう言ひ捨つると、彼の挨拶を聞き流して私はとつとと掌を立てた樣な急坂を湯元温泉の方へ驅け降り始めた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十九折になったその急坂を小走りに走り降ると、坂の根にも同じ様な村があり、普通の百姓家と違わない小学校なども建っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹路という急坂を登り切った頃から日は漸く暮れかけた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹路の急坂にかかった時であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "では御機嫌よう、左様なら」　そう云い捨つると、彼の挨拶を聞き流して私はとっとと掌を立てた様な急坂を湯元温泉の方へ馳け降り始めた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八九町も急坂を登ると焼岳と相向うて立つ高台があった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里あまりの急坂を下りて来た我等は其処で釣橋を渡って大野川を越え、直ぐ左手に梓川の思いの外の大きな奔流が岩を越え岸を噛んでいるのに相対したのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "周章てて急坂を駈下りて転がるように停車場に飛込みざま切符を買った処へ、終列車が地響き打って突進して来た。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう引き返さう／＼と投げ出しながらも、わずかに畜生の追撃によつてこゝまで達したのであるが、もう絶体絶命でうか／＼すればＺの脚の先で蹴り飛ばされるより他はない急坂なのだから、私はもう夢中になつて枯草の茎に獅噛みつき、此処を先途と吐息のピストンを凄まじく必死のピツチに没頭するのであつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この坂はアシクラ断崖の北端にあたって、霧ヶ峰登山中第一の急坂であるが、（此の断崖は霧ヶ峰溶岩流冷却の際、板状節理をなしたもので、建築用具の平石と称して、盛に採掘せられる。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
