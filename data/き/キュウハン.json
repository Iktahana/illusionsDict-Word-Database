  {
    "uuid": "6f5138f2-0b4a-567c-bf5e-e035e4372c82",
    "entry": "旧版",
    "reading": {
      "primary": "きゅうはん",
      "alternatives": [
        "きゅうばん"
      ],
      "is_heteronym": false
    },
    "grammar": {
