[
  {
    "uuid": "19a551ef-3cbe-5a0c-b336-1cc91bc6395b",
    "entry": "急坂",
    "reading": {
      "primary": "きゅうはん",
      "alternatives": [
        "きゅうざか"
      ],
      "is_heteronym": false
    },
    "grammar": {
