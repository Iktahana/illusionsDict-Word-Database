[
  {
    "uuid": "7834ca22-1e24-506d-8dff-33b7107e5aec",
    "entry": "旧弊",
    "reading": {
      "primary": "きゅうへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
