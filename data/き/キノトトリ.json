        "gloss": "Wood Rooster (22nd term of the sexagenary cycle, e.g. 1945, 2005, 2065)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
