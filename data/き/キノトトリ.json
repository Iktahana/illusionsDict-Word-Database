        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は乙酉の年に生まれ、生まれつき華やかな雰囲気を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先代の社長は乙酉生まれで、酉年らしく朝早くから仕事をする人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方の伝統的な祭りは、乙酉の年に盛大に行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は乙酉生まれなので、来年は還暦を迎えることになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史書によると、その戦乱は乙酉の年に終結したそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十八年（乙酉）　一八八五○久松座の再築落成して、千歳座と改称し、一月四日より七日まで開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日、乙酉、将軍家以下二所より御帰著。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日、乙酉、京極侍従三位、二条中将雅経朝臣に付し、和歌文書等を将軍家に献ず、御入興の外他無しと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、乙酉、晴、六波羅の飛脚到著して申して云ふ、和田左衛門尉義盛、大学助義清等の余類洛陽に住し、故金吾将軍家の御息を以て大将軍と為し、叛逆を巧むの由、其聞有るに依りて、去る十三日、前大膳大夫の在京の家人等、件の旅亭を襲ふの処、禅師忽ち自殺す、伴党又逃亡すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿四日、乙酉、白雪山に満ち地に積る。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（乙酉六月上浣）（昭和二十年七・八月）",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八年乙酉、三十九歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某が相果て候今日は、万治元｜戊戌年十二月二日に候えば、さる正保二｜乙酉十二月二日に御逝去遊ばされ候松向寺殿の十三回忌に相当致しおり候事に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政八年「乙酉元日」は立春後十四日であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百六十八　此年乙酉の八月十三日上野不忍池の上なる静宜亭に催された例会の席上の作と、中秋の作との中間に、※斎詩集は「送森島敦卿還福山」の七絶一首を載せてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで八年乙酉中秋前後に、蘭軒は将に福山に還らむとする樸忠がために詩を賦したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二首共に遺稿乙酉の詩中には見えない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛巳より算すれば此年乙酉は第五年、西遊の次年壬午より算すれば第四年である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年乙酉　平八郎三十三歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を詰れば則ち曰、「甲申乙酉に（明の亡びたる〔二字欠〕の末年なり。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "正保二｜乙酉年五月十九日、熊本で死んだ。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝の記録には、神護景雲元年八月乙酉、參河國に慶雲が現れたので、西宮寢殿に、僧六百人を招いて齋を設けた。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳩のやうな彼女たちの多くは乙酉三月九日の夜の戦火に焼かれ、いのちを落したものもあるだらう。",
              "citation": {
                "source": "浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、国芳の戯画にも月下浴衣がけの兎が影勝団子の屋台の前に立つところ、頭上一杯に飛びまくつてゐる蝙蝠の姿、大そう江戸前に涼しかつたことを忘れないが、この錦絵は青春貧困のころ夙に流寓に失つてしまつてゐて、乙酉の戦災以前すでに／＼私の手許にはなかつた。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙酉、天皇皇后及び草壁皇子尊、大津皇子、高市皇子、河島皇子、忍壁皇子、芝基皇子に詔して曰く、朕れ今日｜汝等と倶に庭に盟ひて、千歳の後に事無からむと欲す。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
