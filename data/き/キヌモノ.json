[
  {
    "uuid": "311bd7dd-f19b-5389-9457-ed5d08d78efd",
    "entry": "絹物",
    "reading": {
      "primary": "きぬもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
