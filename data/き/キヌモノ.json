    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silk goods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「最近は洗える素材も増えたけど、やっぱり絹物の肌触りは格別ね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "湿気でカビさせないよう、晴天の続いた午後に箪笥から全ての絹物を出して虫干しをする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外からの賓客への贈り物として、日本の伝統的な染めを施した絹物のスカーフを用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "少年の姿は絹物の美々しいものになった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分の正月の記憶で身に沁みた寒さに関するものは、着馴れぬ絹物の妙につめたい手ざわりと、穿きなれぬまちの高い袴に釣上げられた裾の冷え心地であった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹物とてはモリムラと秩父が二三枚あるきりだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絹物はすぐに破れてしまう。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋のものには判読しがたい変った書体で、それは父譲り、裁縫は、絹物は上手といえなかったが、之は母親譲り、月謝一円の界隈の娘たち相手には、どうなりこうなり間に合い、勿論近所の仕立物も引きうけた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　枕頭の行燈の影で、ええ、その婦が、二階廻しの手にも投遣らないで、寝巻に着換えました私の結城木綿か何か、ごつごつしたのを、絹物のように優しく扱って、袖畳にしていたのでございます。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の者には判読しがたい変った書体で、それは父親譲り、裁縫は、絹物、久留米物など上手とはいえなかったが、これは母親譲り、月謝五十銭の界隈の娘たち相手にはどうなりこうなり間に合い、むろん近所の仕立物も引き受けた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは顔の沢々した※な女で、黒っぽい色の衣服を着ていたが、絹物の光のあるものであった。",
              "citation": {
                "source": "花の咲く比",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのお袋が自慢の年中絹物を着ているものの住所とは思えなかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の者には判読しがたい変った書体で、それは父親譲り、裁縫は絹物、久留米物など上手とはいえなかったが、これは母親譲り、月謝五十銭の界隈の娘たち相手にはどうにか間に合い、むろん近所の仕立物も引き受けた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "休日に外出する時なんぞは、そっと絹物を着て白足袋を穿いたり何かする。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくはお佐代さんはめったに絹物などは着なかったのだろう。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに男にとつて嬉しかつたのは娘さんの着物がすべすべとした絹物であつたことゝ、まだ肩揚げが羽織についてゐたといふことであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の働きが出来るまでは、絹物は一切身につけてはならない――常々さう云つてゐた母である。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はこんな心持ちになって、先ほどの手紙の包みをかかえて立ち上がりながら、うつむいて手ざわりのいい絹物をなで回している叔母を見おろした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「イエ、機織の大きな店があつて、其處に……あの人は近頃やつと絹物が織れるやうになつたのだつたが……妾に時々習ひに來よりましたが……」　談話は切れ／″＼の上の空である。",
              "citation": {
                "source": "姉妹",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は金時計を帯にさげたり、絹物ずくめでえらい勢いであったいうとった。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹物を着て汗をかいたのは好い氣持ではない。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインのある街に絹物を商う店があった。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの画家の製作品が海外に売れる金額の量は、日本全部の絹物の輸出額よりもはるかに大きい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの絹物商の娘で Luisa Ruszt という二十二になる女が、同市 Josefvaros 区の警察へ奇態なことを言って訴え出た。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで飯の給仕に来たり、昼寐の床を取りに来たりした女中とはまるで違って、着物も絹物を着ている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通、服地とか袖口とか裾よけとかになるレース地は、絹物、ジョーゼット、木綿、人絹などいろいろあって、機械にかける前、十ヤールに縫合せる。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考えでは、村で養蚕ができるなら、百姓はその糸を紡いで仕事着にも絹物の着物を着て行けばいい。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先日も座談会で山脇敏子さんが話されたように、いまの絹物にはのりの多い地へゴム印を押したような模様が多いのです。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいったい木綿主義ですが、絹物でも白地を買って自分で色や模様を工夫して染めに出すのが好きです。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷えると夜中に小便が出たくなってやり切れないんです」　切れた裾が襤褸になって下っている絹物の縞袷を着た与太者らしい目のギロリと大きい男が、そういって小腰をかがめ、看守の返事を待たずさっさと布団を出している。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きて顔を洗う金盥の置き方から、夜寝る時の寝衣の袖の通し方まで、無意識な定型を繰返している吾人の眼は、如何に或る意味で憐れな融通のきかきぬものであるかという事を知るための、一つの面白い、しかも極めて簡単な実験は、頭を倒にして股間から見馴れた平凡な景色を覗いて見る事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、若い女人の肉体の美しさと、四季それぞれの食物の味に言い及んだとき、彼の言葉はいつまで経っても尽きぬもののように思われた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出してみると、彼女の訪問はホームズにとってきわめて歓迎できぬものであった。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
