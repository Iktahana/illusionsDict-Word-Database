        "examples": {
          "standard": [
            {
              "text": "季節の変わり目は、衣替えの切り替え時でもあり、気分も新たになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "システムメンテナンスの切り替え時には、一時的にサービスが利用できなくなります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、次のプロジェクトへの本格的な切り替え時ですね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
