    "definitions": [
      {
        "index": 1,
        "gloss": "reception hall (in a temple or palace)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冬の日は釣瓶おとしというより、梢の熟柿を礫に打って、もう暮れて、客殿の広い畳が皆暗い。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "北辰妙見菩薩を拝んで、客殿へ退く間であったが。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どうぞ此方へ」　住職は小腰を屈めながら客殿の方へ隻手をさした。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客殿は本堂の前を右の方へ折れ曲ったその横手の処にあった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監物が前に粗末な客殿の竹の簀子を敷いた縁側へ往った。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新築して外孫の内親王方の裳着に用いて、美しく装飾された客殿があった。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "左甚五郎の作と稱する門を入れば、客殿宏壯にして、青苔地に滿つ。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "客殿の後ろに方丈あり。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "神野寺の客殿にて演説す。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろき客殿に賽者の充滿せること、寄席の如し。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮と薫は何かとお話をし合っていたが、夕方に宮は御所へおいでになろうとして、車の仕度がなされ、前駆などが多く集まって来たりしたために、客殿を立って西の対の夫人の所へ薫はまわって行った。",
              "citation": {
                "source": "源氏物語",
                "author": "早蕨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たいそうなふうをして何しにおいでになったのかと言いたい」　などとお言いになり、宮は不機嫌になっておいでになったが、客殿のほうへ行って御面会になった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此図面には、大抵所謂寝殿造りの「泉殿」が能舞台の役目をして居まして、客殿――寝殿の変化――から見ることが出来る様になつて居るのです。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、客殿と桟敷との考へが一つになつて、後世の見所といふものは発達して来たことが察せられます。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして此かん座は、謂はゞ舞台の芸を観る、客殿の位置であります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、これは」というわけで、招ぜられて客殿へ通ると、つい話が面白くなりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、この大寺の客殿の間にひとり寝かされてみると、今晩こそ、全く異なった世界へ持ち来たされたような気持にならざるを得ません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお松は、田山白雲をと思って、庫裡から客殿の方をたずねてみましたけれども、今日は早帰りをしたと覚しくて、杖も、下駄も見えません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "法然は客殿に待っていて「さあこれへ」といわれる。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "西方浄土からお詣りが遅いから、急いでおいでがあるように阿弥陀仏からのお使いでございます」　そこで成家が喜んでその僧を客殿へ招き入れ、丁寧にもてなし様々の引出物を与えることにした。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等がひねもす物語をした客殿の牀は青緑であつたと書いてある。",
              "citation": {
                "source": "乾あんず",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王が泊つた客殿の部屋は美しい香気が、東洋風な西洋風な、世界中の最も美しい香りを集めた香料が女王自身の息のやうに残つてゐて王を悲しませたことであらう。",
              "citation": {
                "source": "乾あんず",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺は精舎とも、清浄地とも言わるるところから思いついて、明治二年のころよりぽつぽつ万福寺の裏山を庭に取り入れ、そこに石を運んだり、躑躅を植えたりして、本堂や客殿からのながめをよくしたのもまた和尚だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは方丈から客殿へ続く回り縁になっていて、さらに本堂の裏手、位牌堂までも続いて行っている。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "客殿と位牌堂との間には渡れる橋もある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫より福禅寺客殿に至ル。",
              "citation": {
                "source": "坂本龍馬手記",
                "author": "イロハ丸航海日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "客殿、本殿、脇本殿、離亭、厩舎、望楼台、そういう建物が厳しく、あるいは高くあるいは低く、木立の上に聳え木立の中に沈み、月光に光ったり陰影に暗まされたりして、宏大な地域を占領している。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その返辞を待とうともせず、廊から客殿へ駈け上がり、二｜間ばかり馳せ通り、ここぞと思われる一間をあけた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて側なる障子一枚を、無造作に足で踏み破り、六間の客殿へ躍り出た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城廓と云うのが物々しければ砦と云っても差しつかえないが、まことに堂々たる構えであって、母屋、客殿、武具蔵など、幾棟かに分かれて建て連らなっている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
