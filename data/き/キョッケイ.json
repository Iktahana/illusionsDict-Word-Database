[
  {
    "uuid": "0fe81ae7-5ffd-5858-91ca-ce34ddbc0daf",
    "entry": "極刑",
    "reading": {
      "primary": "きょっけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
