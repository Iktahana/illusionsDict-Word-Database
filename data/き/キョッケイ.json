    },
    "definitions": [
      {
        "index": 1,
        "gloss": "capital punishment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
