  {
    "uuid": "b21081ea-da13-51e9-92b9-d3d4c9f88afd",
    "entry": "金糸",
    "reading": {
      "primary": "きんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gold thread",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一しきり襲い来る雨の足に座敷からさす灯が映えて、庭は金糸の光に満つる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にはまた金糸の繍ある派手なる帛を拡げあり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "台の上には緋の天鵞絨に金糸の繍ある立派なる帛を投げ掛けあり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀井戸の金糸堀のあたりから木下川辺へかけて、水田と立木と茅屋とが趣をなしているぐあいは武蔵野の一領分である。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "摩登伽尼の手には金糸、阿難の手には銀糸の端切れがまだ遺って居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も色合と模様は人々の好に因る、金糸にて縫ひたるもあり、縮緬、綾子、絽、等を用ふ。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きざっぽく、どうしても子供の鎧、金糸銀糸。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる賤しき油売の姿にわが身を扮つしてあれば、貴き言葉も疑はるるなれ――（伊留満喜三郎俄に油売の服装を脱ぎて緑の地に金糸の縁飾をとりたる邪宗門僧侶の職服にかはる。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真綿をスイと繰ったほどに判然と見えるのに、薄紅の蝶、浅葱の蝶、青白い蝶、黄色な蝶、金糸銀糸や消え際の草葉螟蛉、金亀虫、蠅の、蒼蠅、赤蠅。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮の河岸のあかしや、二本の海岸のあかしや、その葉のゆめの金糸雀のごとくに散るころを、またしてもくちずさむ、下品なる港街の小唄。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピアの金糸蛇の長い尾のように、何故在ったか。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金糸でややこしい刺繍の紋章を綾取った緋色の帷帳がユラユラと動いたと思うとサッと左右に開いた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人魚のひいさまは、絹に金糸の晴れの衣裳で、花よめのながいすそをささげてもちました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人は鼠地へ金糸銀糸で刺繍つた牡丹の花である。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹の花のうらを返して見ると金糸銀糸は亂れて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其心の亂れは刺繍の金糸銀糸が亂れて居る如く只美しくあるべき筈の亂れである。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには太夫の名が金糸で二重文字に繍つてある。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "Operaglass で ballet を踊る女の股の間を覗いて、羅に織り込んである金糸の光るのを見て、失望する紳士の事を思えば、罪のない話である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹青に手をひかれて奥の部屋へ行くと、その部屋は暗く、卓上の銀燭は青烟を吐き、垂幕の金糸銀糸は鈍く光って、寝台には赤い小さな机が置かれ、その上に美酒｜佳肴がならべられて、数刻前から客を待ち顔である。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、赤煉瓦造りの火床の棚には、緑地のビロードに金糸のオベリスクを縫ひとつた覆ひをつけたオルゴール・ボツクスが載つて居り、音譜箱には五六種の唱歌の巻譜が残つてゐた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の源氏名の八橋にちなんだのであろう、金糸で杜若を縫いつめた紫繻子のふち取りの紅い胴抜きを着て、紫の緞子に緋縮緬の裏を付けた細紐を胸高に結んでいた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金糸で大きい鰕を刺繍にした縹色繻子の厚い裲襠は、痩せてすらりとした彼女の身体にうつりがよかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫の裾模様の小袖に金糸の刺繍が見える。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服ひとつとっても、金糸のエンブレムがついた紺のブレザー、レジメンタル・タイ、グレイのスラックス、というフォーマルなもの、そして、ふだん学校や寮で着る、衿なし上着にオープンシャツの校服、という二種類があり、いろいろ行事のある入寮入学前後は指示が複雑で、新入生を悩ませた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひたいのところに、金糸や、赤、青、白の糸で刺繍がしてある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半分には、円周の内側に沿って、大きく「ＫＷＴＳ」とあり、中心の金色の小さな円の左側には “Side A” 右側には “45 RPM” 下には、まず “TAKASHI” とあり、その下に “You Baby” と金糸で縫いとってある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見てごらん、名前が繍ってあるずら』『ええ、あるわ』　私は金糸の撚糸の垂房に触りながら、滝に鯉の繍とりの中に、信太郎と浮き出している字を見つけました。",
              "citation": {
                "source": "虫干し",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから冬から春への推移だって、鳥屋の前で金糸鳥の和毛にそそぐ日の光を二三秒立留って眺めて面白いと思っただけであった。",
              "citation": {
                "source": "風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "お政は鼠微塵の糸織の一ツ小袖に黒の唐繻子の丸帯、襦袢の半襟も黒｜縮緬に金糸でパラリと縫の入ッた奴か何かで、まず気の利いた服飾。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勢は黄八丈の一ツ小袖に藍鼠金入繻珍の丸帯、勿論下にはお定りの緋縮緬の等身襦袢、此奴も金糸で縫の入ッた水浅黄縮緬の半襟をかけた奴で、帯上はアレハ時色縮緬、統括めて云えばまず上品なこしらえ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
