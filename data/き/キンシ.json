[
  {
    "uuid": "f34fa19f-1555-562d-8bdf-3cf85ee56fd7",
    "entry": "禁止",
    "reading": {
      "primary": "きんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prohibition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特にまた「忘れちやいやよ」に至つては、最近それが発売禁止になつたほど、一層もつと極端に、この時代的陰鬱の梅毒的エロチシズムを表現して居る。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日服用したら、あと服用を禁止せよ、三日乃至五日間休止して、それからさらに二錠づつの服用を開始せよ、と效能書に書かれて在りましたので、私は、少しも、ききめの無いままに、その藥の服用を、やめなければならなくなりました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の下に婆さんの骨が散らばつてゐたなんて段に到ると、まさに陰慘の極度であつて、所謂兒童讀物としては、遺憾ながら發賣禁止の憂目に遭はざるを得ないところであらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあ、發賣禁止も避けられるし、大いによろしい事であらうが、しかし、たつたそれだけの惡戲に對する懲罰としてはどうも、兎の仕打は、執拗すぎる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の地主たちも、彼に倣って立入禁止を断行した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら米国でもこの天象を禁止し排斥する事は出来ないので、その予報の手がかりを研究しているのである。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達でやる筈になつてゐた試演會は校長の禁止で、公演の前日に迄もなつてゐて、それを思ひ切らなければならない破目になつたのである。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旱魃を免れた県には、米穀県外移出禁止というような城壁が築かれてはいるが、表門は閉っていても、裏のくゞり戸があいているので、四斗俵ならぬ三斗五升いりの袋ならその門を通過させてもらえるのだと笑っていた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の小作料の引上げや、立入禁止、又も差押えがある。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮銀行がやっていた、暗黒相場のルーブル売買が禁止されたのが明らかになった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「そうだ、もっと早くから、ルーブル紙幣の暗黒売買を禁止しとかなけゃならなかったのだ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その輸入は禁止されていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その吸飲も禁止されていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いくら禁止しても、その法令は行われなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄養不良と、日光不足（朝四時から夜七時まで作業）にもってきて、世界各国で禁止されている、最も有毒な黄燐を使うため、健康な肉体も、極めて短時日の間に、毒素に侵されてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薬、悪い、大いに毒ある、悪い、こいつは、……この黄燐マッチは、有毒だし、すぐ火事を起すから、どこの国でも禁止しているんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川、天保の改革に幕府から厳しい奢侈禁止令が出て女の髪飾りにもいわゆる金銀玳瑁はご法度であった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃になっては、昭和五年に世界各国は金禁止に伴って関税障壁を競い出した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によると禁止をしなければなるまい。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、盆踊りは野蛮の遺風だとかなんとかいって、一も二もなく先祖伝来の盆踊りを禁止し、他に楽み少なき農民の娯楽を奪い去るとは、当世の役人や警官はよくよく冷酷な根性になったものかな。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙法の掲載禁止命令は茲に威力を発揮して、秋山亨一、真野すゞ子、神谷太郎吉、古山貞雄等の拘留審問の事実を、一ヶ月余も社会へは洩さなかつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府の方針として、かたき討を公然禁止したわけではないが、決して奨励してはいなかった。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを禁止されたのはやはり十八、九年の頃であろう。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどに怖るべきものであるならば、どこの親たちも子どもの遊びを堅く禁止しそうなものであるが、それほどにはやかましく言わなかったのをみると、その伝説や迷信も一般的ではなかったらしい。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少しで上演禁止を申し出るところであった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると医者は、この頃婦人雑誌で石油が肺病に効くと騒いだり、又、石油を主剤にした肺病薬が発売されたりしたので、内務省衛生医局で実験をしてみたところ、結局石油に結核菌を殺す力は無く、むしろ人体に有害であると分り、その肺病薬は発売禁止になった、最近の新聞にその事が出ていたのを君は知らないのか、と言った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が朝第一番に唄う、こゝは地獄の三丁目、行きはよい／＼帰りは怖い、という彼女の愛唱の唄は軽部によってその卑俗性の故に禁止された。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の留守中に返事書くだろうと思うと外出もせず、勿論お君の外出も禁止した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことが知れて、彼は権右衛門から出入を禁止された。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、出入禁止をされた彼は屡々末弟の三亀雄に資本の融通をたのんだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
