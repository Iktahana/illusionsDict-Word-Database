        "examples": {
          "standard": [
            {
              "text": "風の音が激しすぎて、船長の指示を「全速前進」ではなく「停止」だと危うく聞き違うところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イチ」と「ハチ」は電話口だと聞き違うことが多いので、必ず一文字ずつ確認するようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相手の意図を完全に聞き違うと、せっかくの商談も台無しになってしまうので細心の注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は極度の緊張から、試験官の「始めてください」という合図を「止めてください」と聞き違うミスをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "亭主｜予て予の気短きを知れば、給仕人が聞き違うた体に言い做し、皿を引き将て去らんとするを気の毒がり、浜口氏が自分引き取りて食べ試みると奇妙に旨いとて、予に半分くれた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
