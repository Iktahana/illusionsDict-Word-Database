[
  {
    "uuid": "487de0cb-84d2-5480-ac51-67629a7a3173",
    "entry": "競技",
    "reading": {
      "primary": "きょうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
