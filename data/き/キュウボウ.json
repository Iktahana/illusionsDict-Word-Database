        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はその生存した時代において、ほとんど全く認められず、空しく窮乏の中に死んでしまった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは多分、蕪村自身が窮乏しており、終年裏町の侘住いをしていたためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬近き日に袷をきて非有の窮乏は酢えはてたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れの持たざるものは一切なり我れの持たざるものは一切なりいかんぞ窮乏を忍ばざらんや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた大学財政の窮乏を救うためにカーネギーを説いたり、タイムス紙を通して世間に訴えたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、ひどく窮乏してゐた書生時代から、彼はさういふやり方で生活して居た。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢餓と窮乏に惱まされてた當時の詩人犀星が、その鳩笛を鳴らしてる樣子は、實際また寂しく悲しさうであつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田端に住むやうになつてからも、彼はやはり窮乏して居た。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の窮乏時代には、一錢の蝋燭を一圓の價値に使つた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の青年たちは、鍬や鎌を捨て、窮乏と過労の底にある家に、老人と、幼い弟や妹を残して、兵営の中へ這入って行かなければならない。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　蒋介石の第二次の北伐と、窮乏した山東兵の乱暴と狼藉が、毎日、巷の空気をかき乱した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人達の窮乏は次第に度を加えて来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争には、残虐や、獣的行為や、窮乏苦悩が伴うものであるが、それでも、有害で反動的な悪制度を撤廃するのに役立った戦争が歴史上にはあった。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "善事をした訳でも悪事をしたわけでも無くて、貴家に生れると窮乏の家に生れるとで其の赤坊の運命は大なる差があります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年間、その間には、往年の呑気な帝国大学生の身の上にも、困苦窮乏の月日ばかりが続きました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメのまた下のダメという、謂わば「ほんもの」のダメという事になりまして、私は詩壇に於いて失脚し、また、それまでの言語に絶した窮乏生活の悪戦苦闘にも疲れ果て、ついに秋風と共に単身都落ちというだらし無い運命に立ちいたったのでございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽きも飽かれもしない妻と子とを残して、何んといつても住心地のいゝ日本から、どんな窮乏と危険とが待ち受けてゐるかも知れないいづこかに、盲者のやうに自分を投げ出して行かうとする。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に当って、この窮乏に堪え、かつこれを打開するものは、ただ人々の仏教信仰によっての安心立命と、慈悲の円融なる救済力とに待つのが適切と思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私の窮乏｜困蹶が始まり、多数の同志は悉く脣を反らし、完膚なきまでに中傷しました。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私の窮乏｜困蹶が始まり、多數の同志は悉く脣を反らし、完膚なきまでに中傷しました。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦のお正月だといふのに、百姓は田を耕やしたり、畑を打つたり、洗濯をしたり、大根を刻んだりしてゐる、こゝにも農村窮乏の色が見えるといへるだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな季節のながいあひだぼくの生活は落魄してひどく窮乏になつてしまつた家具は一隅に投げ倒され冬の　埃の　薄命の日ざしのなかで蠅はぶむぶむと窓に飛んでる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまたその時以来、僕は物質の窮乏などというものが、精神の牢獄から解放された自由の日には、殆んど何の苦にもならないものだということも、自分の生活経験によって味得した。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな季節のながいあひだぼくの生活は落魄してひどく窮乏になつてしまつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神神の生活　ひどく窮乏に惱まされ、乞食のやうな生涯を終つた男が、熱心に或る神を信仰し、最後迄も疑はず、その全能を信じて居た。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し定基は何彼と尋ねると、いずれ五位六位ほどの妻であろうか、夫の長い病の末か、或は何様いうかの事情の果にいたく窮乏して、如何ともし難くなって、吾が随一の宝の鏡を犠牲にして売って急を凌ごうということらしい。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "去りながら外面に窮乏を粧ひ、嚢中却て温なる連中には、頭から此一藝を演じて、其家の女房娘等が色を變ずるにあらざれば、決して止むることなし。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈善病院の資金窮乏の訴え。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
