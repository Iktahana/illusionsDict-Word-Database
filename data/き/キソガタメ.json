        "examples": {
          "standard": [
            {
              "text": "新しいプロジェクトを始める前に、まずは基礎固めから始めよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "語学学習では、文法の基礎固めが上達の鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地震に備えて、家の基礎固めをしっかり行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はこの数年間、来るべき大会に向けて基礎固めに励んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "朝倉先生に師事しつつ、塾生の立場から塾風樹立の基礎固めに努力し、しかもしばしば田沼という大人格者に接して親しく言葉をかわしている自分を想像すると、胸がおどるようだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから九月中にダルメイダが豊後へ往復した機会に平戸のダミヤンを博多に移し、博多のフェルナンデスを横瀬浦へ連れ帰らせて、横瀬浦の教会の基礎固めに力を集中している。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
