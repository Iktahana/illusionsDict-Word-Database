[
  {
    "uuid": "e26bef35-8f11-52a3-b70c-a0e0f54396bc",
    "entry": "木の香",
    "reading": {
      "primary": "きのか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
