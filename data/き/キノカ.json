    },
    "definitions": [
      {
        "index": 1,
        "gloss": "smell of new wood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新築の家に入ると、木の香りがして心が落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森林公園を散歩していると、爽やかな木の香りがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このテーブルはヒノキ製で、木の香りが部屋中に広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "木の香りがするお風呂は、一日の疲れを癒してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "朝は早く起き、榊をあげて柏子を打ち、木の香の匂ふ縁側に、日向ぼつこでもしてみるとしたらどうであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "描いて居るすぐ傍には新しい木の香のする材木が積んであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋燈も珍しいが、座敷もまだ塗立ての生壁で、木の香は高し、高縁の前は、すぐに樫、槻の大木大樹鬱然として、樹の根を繞つて、山清水が潺々と音を寂に流れる。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽木の香があたりに立ち籠めている。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいているすぐそばには新しい木の香のする材木が積んであった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした寺がいくつも並んだ寺町を通る時、ぱっと暗闇に強い木の香がひらめいた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の座敷は香木の香がみちみちてムッとする程あたたかかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると岸打つ波の音も、濱に寄つた貝の色も、默して居る磯の巖の顏も、死せるが如き藻鹽木の香も、皆盡く歡喜の美酒に醉ひ、吉慶の頌歌を唱へて、愉々快々の空氣に嘯くやうな相を現はすのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少しゆくと空地があったから行こうと松次郎が言うので、ついて行って見るとそこには木の香も新しい立派な家が立っていたりした。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立つ灰にも、留南木の香が芬と薫る。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の草や木の香いを嗅ぎ分けながらだよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暑かったが、校舎の内部はまだ生々しい木の香がぷんぷんと匂って、何か虔ましい旅愁をさえ味わせられた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その上手の、まだ木の香のなまなましいバラックの、戸は引いて、窓も閉めたのが、その中では何か盛んに喧騒していた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの末木の香は「世の中の憂きを身に積む柴舟やたかぬ先よりこがれ行らん」と申す歌の心にて、柴舟と銘し、御珍蔵なされ候由に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの末木の香は、「世の中の憂きを身に積む柴舟やたかぬ先よりこがれ行らん」と申す歌の心にて、柴舟と銘し、御珍蔵なされ候由に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "生肌の木の香くゆれる函館よ、いともなつかし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中に案内されて奥へ来てみると、小田原ほど立派ではないが木の香がプンプンしている二尺の一間床に、小田原と同じ蝦夷菊が投入にしてある。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つたといふくらゐ、総｜檜木作りの木の香も新しい立派な場所であつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つたといふくらゐ、総檜木作りの木の香も新しい立派な場所であつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い草木の香にむせながら、胸をおどらせながらこんな虫をねらって歩いた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも城山の奥の茂みに蒸された朽ち木の香を思い出す事ができるのである。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして絶えず新らしい木の香や、土の匂が彼にさわやかな清い心を与えているのであった。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕暖の空氣の中には草木の香みち／＼て、美しき甲蟲あまた我等の身邊に飛びめぐれり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのむかしは御用木として日本堤に多く栽えられて、山谷がよいの若い男を忌がらせたという漆の木の香いがここにも微かに残って、そこらには漆のまばらな森があった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木口は余り上等とも思わなかったが、左に右く木の香のする明るい新築だった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の傍らには、節を荒けずりした新らしい木の香のする電柱が、間隔を置いて、何本も転がさっていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、裏畑の中の材木小屋に入つて、積み重ねた角材に凭れ乍ら、雨に濕つた新しい木の香を嗅いで、小一時間許りも密々語つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の大半を占めてゐる焼跡には、仮屋建ての鑿の音が急がしく響き合つて、まだ何処となく物の燻る臭気の残つてゐる空気に新らしい木の香が流れてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、裏畑の中の材木小屋に入つて、積み重ねた角材に凭れ乍ら、雨に湿つた新しい木の香を嗅いで、小一時間許りも密々語つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の大半を占めてゐる燒跡には、假屋建ての鑿の音が急がしく響き合つて、まだ何處となく物の燻る臭氣の殘つてゐる空氣に新らしい木の香が流れてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
