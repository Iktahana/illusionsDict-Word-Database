        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公的な場面では、標準語が共通語として用いられることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "方言も豊かで魅力的だが、全国民が理解する共通語があるのは安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "テレビやラジオで流れる言葉が、自然と皆の共通語になっていくんだろうね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
