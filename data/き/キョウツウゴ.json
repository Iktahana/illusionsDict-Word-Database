        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地域では、スペイン語が共通語として広く使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "異なる文化を持つ人々が交流する上で、共通語の存在は大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「みんなが理解できる共通語で話しましょう」と会議の冒頭でアナウンスがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "民主戦線ではその広さと、そこに包括される社会活動の部面が多様であるにかかわらず、他の一面ではこれまで社会各層がもたなかった互いの共通語をもつようになってきている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで50個の諸國共通語が決定せられたのである。",
              "citation": {
                "source": "ベーシック英語",
                "author": "高田力",
                "note": "青空文庫"
              }
            },
            {
              "text": "共通語と今ではいう様だが、これはもっとふやさなければならない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄人は共通語をよく会得せねばなりません。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに世界の各国が自国の言葉を棄てて共通語のエスペラントを選ぶとしたら、世界は果して幸福でしょうか。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "在来の支配者クラカは都に移されて言語風習を仕込まれるが、人民に対してもまた都言葉が共通語として教え込まれるのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "standard language (language variety understood throughout a country)",
        "register": "standard",
        "nuance": null,
