      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわっ、包丁で指切っちゃった……。結構深い傷かも。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新車にこすり傷を見つけてしまい、朝からひどく落ち込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼に言われた無神経な一言が、今も心の傷となって残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「大丈夫？ 転んだ拍子に膝に傷ができちゃってるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷品萩原朔太郎ほつねんなれば魚にとへしんじつなれば耶蘇にとへ",
              "citation": {
                "source": "感傷品",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月蝕皆既萩原朔太郎みなそこに魚の哀傷、われに涙のいちじるく、きみはきみとて、ましろき乳房をぬらさむとする。",
              "citation": {
                "source": "月蝕皆既",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は、新聞記事を読んでの私の記臆でありまして、詳しいことは何も存じませんが、又私はこれから、此の記事に出て来る実際人物のことを云はうとは思つてゐませんが、この記事を種に、私が想像出来るだけのことを記して、以て我邦感傷主義を一寸論じてみたいのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにもつれ易い感傷の綱の海を漕ぎゆくためには、否応なきストイシスムを身に付けて、胸襟打開いて事に当る平明さを、諦らめる覚悟が要ります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来自然を友とすることが多かつた我が国人は、感傷の綱の海を漕ぎゆくには余りに清廉であり、されば比較的清廉でなかつた人が用に与つて来たかも知れませぬ。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ或る時は僅かな経済学的知識を持出してその裏付けとなし、或る時は自分の感傷にまかせてダダを捏ねるのである。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで御当人は益々元気で、『此の世が渡りにくいなぞとはみなこれ感傷の徒のこと』だなぞとも云ふ。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃此の国の詩壇は傷ましくも荒みきつて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには少年に特有なあの美しい感傷と、生娘のやうな純潔の気高さがあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはむやみと生硬の漢語や、俗悪で不自然な言葉のアクセントや、中学生じみた幼稚な興奮や、およそさうした類の低能な感傷的表情を、むやみと鼓張した態度で一本調子に並べたてられて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いが既に来り、死の近づいて来たことを知った彼は、すべての自然を感傷的に眺めることから、万象に対して愛以上の深いものを注いだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこれらの話をきいてる中に、私は涙ぐましく感傷的になつてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私と語るために、故意に話の主題を合せて、その心にもない人生的感傷論をするのだと邪推した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらそれは、悲痛な、傷ましい不斷の戰による英雄だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前だれが――どんな彼の親友が――この傷ましい英雄を彼に見たか？",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はニイチェの英雄であり、藝術至上主義の傷ましい殉教者だ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、三鷹の家は爆弾でこわされたが、家の者は誰も傷を負わなかった。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへＣやＤやＥやＦやＧやＨやそのほかたくさんの人物がつぎつぎに出て来て、手を変え品を変え、さまざまにＢを中傷する。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして馬場のひとりごととは千里万里もかけはなれた、つまらぬ感傷にとりつかれていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京だなあ」というたったそれだけの言葉の感傷に。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――中傷さ」「それじゃ言うが、そのしどろもどろは僕の特質だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても、これは維新の志士、傷療養の土地の感じである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し感傷的な、あまい事なども書かれてありますから。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "過失傷害致死とかいふ罪名でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "過失傷害致死とかいう罪名でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その声にともかくも好感を懐いた人達の或者は、感傷的な道徳家となり、他の或者は批評主義派になつてしまつた。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今日私は過去五年間の暗中模索、傷ましき躁宴の後に、聊か芸術の泉なるものが依て以て存する所以に想ひ到つた。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　歩かざる人にある芸術は、竟に一呼吸中の物、及びその延長であり、延長――即ち感傷の根本形式である。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いまするどく鋭刃を合せ、手はしろがねとなり、われの額きずつき、劍術は青らみつひにらじうむとなる。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
