[
  {
    "uuid": "e9dc5cf9-4c94-510b-bf13-36bbd4f78d60",
    "entry": "傷",
    "reading": {
      "primary": "きず",
      "alternatives": [
        "キズ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
