    "definitions": [
      {
        "index": 1,
        "gloss": "winding coast (beach)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
