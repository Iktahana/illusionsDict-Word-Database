    "definitions": [
      {
        "index": 1,
        "gloss": "Hedera rhombea (species of ivy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
