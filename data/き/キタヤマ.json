    "definitions": [
      {
        "index": 1,
        "gloss": "northern mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "京都の北山エリアには、洗練されたカフェやブティックが並び、落ち着いた大人の雰囲気が漂う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の北山から吹き下ろす「北山時雨」が、京の街に本格的な冬の訪れを告げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、今週末は天気が良そうだし、北山の植物園までドライブに行こうか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "北山の法経堂に現れる怪火の話とか、荒倉山の狸が三つ目入道に化けたのを武士が退治した話とか、「しばてん」（木の葉天狗）と相撲を取る話。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この匂いを嗅ぐと、少年時代に遊び歩いた郷里の北山の夏の日の記憶が、一度に爆発的に甦って来るのを感じる。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山さんといふ詩人は、雪の夜路を私と二人で歩いて、北山さんはその夜、特に新しい軍靴をはいて私に歡迎の心意氣のほどを見せてくれたのですが、新しい軍靴は雪に滑つて、北山さんは、何度も何度もころびました。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山さんは、一升瓶を持參してゐたので、私は、北山さんのころぶ度に、ひやりとしました。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人、五六人という群れになって北山おろしの木枯らしに吹かれながら軒並みをたずねて玄関をおとずれ、口々にわざと妙な作り声をして「カイツットーセ」という言葉を繰り返す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分ほッついたで、夕飯の腹も、ちょうど北山とやらじゃわい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、色氣どころか、ほんたうに北山だ。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうさ、生は東だが、身上は北山さね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わツといつて駈け拔けて、後をも見ずに五六町、彌次さん、北八、と顏を見合はせ、互に無事を祝し合ひ、まあ、ともかくも橋を越さう、腹も丁度北山だ、筑波おろしも寒うなつたと、急足になつて來る。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男――北山正雄は大阪のある銀行の下級行員であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、大阪の中之島公園で拾った娘に、北山は恋心めいた情熱を感じた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び立つ思いとはこのことだと北山は日曜日が来ると、朝のうちにもう京都へついた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと思った途端、北山の手は伸びていた……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時のことを、北山はなまなましく想い出して、溜息とも叫びともつかぬ、得体の知れぬ声をうめきながら、ぶるんと首を振っていると、電車が来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山はそわそわと、しかし、何か心を残しながら、その電車に乗った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、北山もカラ子もそれぞれ河原町通りの舗道を、窓ごしにキョロキョロ見ていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラ子はふと兄ちゃんとこのまま別れてしまって、もう二度と会えないのではないかという予感にさびしく揺れたが、眼はピカピカ光り、北山をにらんでいた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山は未練たらしく、いつまでも河原町通りの方へ、視線を泳がせていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに自分が掏られたことへの腹いせでもあり、魔がさしたともいえるが、しかし、その闇の娘を買う金という目的がなかったら、実直で小心な北山には、ひとを掏るなどという大それたことは出来なかったはずだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いていることが怖くなり、北山は祇園荘へ飛び込んだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘が昨夜、仏壇お春たちと一緒に検挙されたとは、むろん北山は知らなかったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらいらと待っていると、いきなり、「おれはこんな所でボヤボヤしていてもいいのやろか」　という焦躁が、蛇のように頭をもたげて、北山の右の手首へからみついた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山はソワソワとセントルイスを飛び出し、京都駅行きの電車に乗ったのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅前の広場を横切る北山の足は速かった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は彼等の傍を通り抜けながら、ふと優越的な気持が同情に先立つらしく、さげすみの眼をちらと投げて行ったが、北山の眼はそんな旅行者が羨ましい眼付だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　北山は半泣きの顔に弱々しい微笑をうかべて、何か言いかけようとしたが、その時駅員が前方からやって来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山ははっとして顔をそむけると、固い歩き方で通路を抜け、省線のプラットの方へ階段を降りて行った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
