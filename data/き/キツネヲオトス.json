    "definitions": [
      {
        "index": 1,
        "gloss": "to exorcise a fox spirit (from a person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "取り憑かれたように暴れる男を鎮めるため、高名な祈祷師に頼んで狐を落としてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狐を落とす儀式が終わると、彼女は憑き物が取れたように穏やかな表情に戻った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな非科学的な！狐を落とすなんて言わずに、早く病院へ連れて行きなさい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "村の古い言い伝えによれば、冷たい滝に打たれることが狐を落とす一番の近道だという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どこから聞いたものか、私が狐を落とすと言う者があったので、かの人はこの苦痛を除くためには、多くの手段を尽くしても全く無効であった。",
              "citation": {
                "source": "妖怪談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、十年来のことでもあれば、ただちに快復するということは難いが、幸い私の所に狐を落とす道具がある。",
              "citation": {
                "source": "妖怪談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
