        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "切り立ての鋏穴は円形から直角の扇形を取りのけた格好をしている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、切り立ての鋏穴の縁辺は截然として角立っているが、揉んで拡がった穴の周囲は毛端立ってぼやけあるいは捲くれて、多少の手垢や脂汗に汚れている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹三郎の家はすゞが帰ると、切り立ての生花をいけたように、清新になった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "城の後ろは切り立てたような懸崖で深く見おろす直下には真黒なキイファアの森が、青ずんだ空気の底に黙り込んでいた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月並能の後、一人頭二三十銭宛切り立てて舞台で御馳走を喰うのが習慣になっていたが、御馳走といっても、味飯に清汁、煮〆程度の極めて質素なものであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿崎隊は新手を入れかえ入れかえ無二無三につき進み切り立てたため、さしもの典厩隊も苦戦となり隊伍次第に乱れるにいたった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が数ヶ月の後に、実に興味深く読んだ、君のこの事件に対する絵を見るような記録には、その岩壁は、切り立てたようであったと記されてあったが、しかしあれは必ずしも、文字通りには正しくはなかったのだ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、白い切り立ての紗で特別仕立の上つ張のやうなものを拵へ、それを着込んでにこにこもので王献之の許へ着て往つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "手下の鬼どもは、しばらくの間はてんでんに鉄棒をふるって、打ちかかってきましたが、六｜人の武士に片端から切り立てられて、みんな殺されてしまいました。",
              "citation": {
                "source": "大江山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒っぽい小浜縮緬の振袖をキリキリと着込んで、金と銀の色紙と短冊の模様を刺繍した緋羅紗の帯を乳の上からボンノクボの処へコックリと背負い上げて、切り立てのフェルト草履の爪先を七三に揃えている恰好は尋常の好みでない。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――次郎は、こういう勢いに促されて、いつか二人の侍と三頭の犬とに追われながら、小路を南へ少しずつ切り立てられて来たのである。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがやがて小路のまん中まで、切り立てられて来たかと思うと、相手は、大きな声を出して、彼が持っていた鉾の柄を、みごとに半ばから、切り折った。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、バラバラと人の影が、四方八方へ別れたが、切り立てられた一ツ橋勢が、逃げて走って行く影であった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女の一団の、鋭い太刀風に切り立てられ、二、三間後へ退いた。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは紛れもない五年以前に川口町の天水桶の蔭から、ヌッと姿を現わして勾坂甚内を呼び止めたあげく、その甚内に切り立てられ危く命を取られようとした匕口を持った若者であった。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右近丸のために切り立てられ、逃げて来た猪右衛門の足音である。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖垣に辛夷を添わせて、松苔を葉蘭の影に畳む上に、切り立ての手拭が春風に揺らつくような所に住んで見たい。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも切り立ての脊廣に赤靴をはいて、ゲイトルもかけてゐなければ洋傘も持つてゐなかつた。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言葉に出して叫んだが、その間も織江を仕止めようと、踏み込み踏み込み切り立てる。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい紺の腹掛、紺股引、下ろし立てのはだし足袋、切り立ての手拭を顋の下でチョッキリ結びの若い衆が、爺をせびった小使の三円五円腹掛に捻込んで、四尺もある手製の杉の撥を担いで、勇んで府中に出かける。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら有段者が初心者を相手に、稽古をつけるそれの如く、主水が撃とう切ろう突こうと、心組む心を未前に察し、その先その先その先と出て、追い立て切り立て突き立て進んだ。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……では行こう」　この混乱の人渦の中を、阿修羅のように荒れ廻っているのは、澄江を奪われお妻を見失い、猪之松の乾児達に取り巻かれ、切り立てられている陣十郎であった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直のところ、この私こそ右門殿のために切り立てられ、危かったのでござります。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野太刀を抜いた山窩の群、人殺しには慣れている、敏捷に飛び廻って切り立てる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗三郎は切り立てられ、呼吸も逼り、筋も釣り、眼の前がチラチラ踊るようになった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人を捕えているその間に、他の一人に切り立てられ、その上肝腎のトヤ駕籠でも、破壊されたら大変である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」真っ先の一人が声を掛けたが、さっき宗三郎に切り立てられ、あやうく逃げた伊集院で、新手をひきいて現われたのである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足拵え厳重、裸、手拭、頬被り、切り立ての白木綿の下帯腹巻、その上に三尺をグイと締めてそれにゴボー差しにした鉄拵え一本刀。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛脛が大變で――その上切り立ての犢鼻褌をして威張つてゐましたよ」　八五郎の説明は途方もないものでしたが、この冒涜行爲も、相手が確かに男とわかつて、平次の神經を痛める程の事件でもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒藥酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬くうちに三人とも切り立てられ、土間へ逃げる）三蔵　　（急に奮い起ち、磯目の鎌を斬り倒し、ぐったりうずくまる。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
