  {
    "uuid": "c46847f9-c962-557a-a93a-c760fd51c094",
    "entry": "競ふ",
    "reading": {
      "primary": "きおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-四段-ハ行-古典",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to compete",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "驕奢を石崇と相競ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末俗　工を競ふ　繁縟の体、千秋の精意　誰と与に論ぜん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "険を冒し奇を競ふ世の中には、利益と名誉とを修むるの途甚だ多し、而して尤も利益あり、尤も成功ありと見ゆるものは人を害し人を傷ふ的の物品の製造なり。",
              "citation": {
                "source": "主のつとめ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃くして席は遊藝を競ふところとなり、ポツジヨは得意の舟歌（バルカルオラ）を歌へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ト此の奇異なる珍客を迎ふるか、不可思議の獲ものに競ふか、静なる池の面に、眠れる魚の如く縦横に横はつた、樹の枝々の影は、尾鰭を跳ねて、幾千ともなく、一時に皆｜揺動いた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲競ふた花は美しさと、その貴い香水のにほひとを合せて、春の女神への捧げ物として居りました。",
              "citation": {
                "source": "駒鳥の胸",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出ぶれをして置けば、迎への馬車がＫ駅迄は仕立てられてゐたのに――と思ひながら、秋草の咲き競ふてゐる河原堤を溯つた。",
              "citation": {
                "source": "ピエル・フオン訪問記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に如此くなれば、怪は愈よ怪に、或は夢中に見たりし踪の猶着々活現し来りて、飽くまで我を脅さざれば休まざらんと為るにあらずや、と彼は胸安からずも足に信せて、かの巌の頭上に聳ゆる辺に到れば、谿急に激折して、水これが為に鼓怒し、咆哮し、噴薄｜激盪して、奔馬の乱れ競ふが如し。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "千山奇を爭ひ、萬壑怪を競ふ。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子の家には、母親と姉妹との夫々の雛が三組もあつて、その家の隆盛時代を物語るかのやうに最も豪儀な姉妹の雛段が存分な綺羅を競ふてゐた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ行かむ、月おぼろなる夜は、われらが胸に翳せる白百合の香りこそ光らむ、そはまた百千の妖魔をくらます白金の剣ともなりて月光と共に競ふらむ……。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋果熟すれば即ち落つ、落つるは偶然にして偶然にあらず、春日光暖かにして、百花｜妍を競ふ、之も亦偶然にあらず、自然は意味なきに似て大なる意味を有せり、一国民の消長窮通を言ふ時に於て、吾人は深く此理を感ぜずんばあらず。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけど僕も、ほんの少しゝか眠つてゐないんでね……」　滝本も、村井と競ふて徹夜することが多かつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ当日となつて、吾家の凧などは到底この仲間には入らなかつたが、主だつた持主は夫々工夫を凝らした上句の新奇を競ふのであつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この両家は毎年糸の長さを競ふてゐた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ彼等は互に競ふのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ち人丸・赤人の余唾を舐るでもなく、固より貫之・定家の糟粕をしやぶるでもなく、自己の本領｜屹然として山岳と高きを争ひ日月と光を競ふ処、実に畏るべく尊むべく、覚えず膝を屈するの思ひ有之候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ち人丸赤人の餘唾を舐るでも無く固より貫之定家の糟粕をしやぶるでも無く自己の本量屹然として山嶽と高きを爭ひ日月と光を競ふ處實に畏るべく尊むべく覺えず膝を屈するの思ひ有之候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "午は少壮者が健啖を競ふので、特に多く準備した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは、誰と成績を競ふこともなく、伊藤も、ばア様も、川島舎監長も、下駄屋の亭主もゐなかつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "論旨は昆吾と鋭を争ひ、文辞は卞王と光を競ふ。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の清朝に入つてから染付もいろ／＼の變化を見せ、徒らに精巧を競ふ觀あるまで脱線したが、清初のものにはなか／＼いゝものがある。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には星が一杯で、黒い河水に映る両岸の灯と色を競ふやうであつた。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には星が一杯で、黒い河水に映る兩岸の灯と色を競ふやうであつた。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初死ぬ程辮髮を嫌つた漢人は、流石に康煕の末頃までは――Careri の『世界一週記』にも明記せるが如く（31）――頗る辮髮を喜ばなかつたが、雍正・乾隆・嘉慶と年を經る儘に、次第に辮髮に慣れて來て、果ては髮の編み樣、頭の剃り樣に、追々流行を競ふ有樣となつた。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "斷髮洋裝で舞踏場に出入し、西洋人に身を任せる事を競ふ女と共に、新興國の産物である。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴頭に「ばさら」を競ふのは、時こそ違へ、狼藉無頼の徒の異風を衒ふ点に於いては一つである。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたげの場処で、即興に頓才を競ふ心持ちを持つた人々が、四顧の風景の優れた小屋に居て、謡ひ上げる歌は、段々其景を叙することに濃かに働いて来る。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が法楽の歌で、平安の都も末になるほど、神祇歌・釈教歌の流行に連れて、益々盛んになり、数も多さを競ふやうになつて行く。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は華厳の滝壺に下りんとて長塚も我もいさみきおう。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
