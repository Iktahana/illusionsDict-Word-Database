[
  {
    "uuid": "913a9912-6705-52a8-a6f4-5511558edc63",
    "entry": "気息",
    "reading": {
      "primary": "きそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "breathing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深い眠りにつき、彼の気息は静かに続いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "息を潜めて敵の気息を探った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「…ふぅ、やっと終わった…」彼は荒い気息を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "窮屈さと蒸された人の気息とで苦しくなった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の皮膚は、薄黒く、また黄色ッぽく、白血球は、薬のために抵抗力を失って、まるで棺桶に半脚突ッこんだ病人のように気息｜奄々としていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなくある日縁側で倒れて気息の絶え絶えになっているのを発見して水やまたたびを飲ませたら一時は回復した。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しでも早く海の中につかりたいので三人は気息を切って急いだのです。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "力が無くなりそうになると仰向に水の上に臥て暫らく気息をつきました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せわしく深く気息をついて、体はつかれ切ったようにゆるんでへたへたになっていました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼の申しようも御座んせん」　すぐそばで気息せき切ってしみじみといわれるお婆様の声を私は聞きました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで安らかに単調に秒を刻んでいた歯車は、きゅうに気息苦しそうにきしみ始めていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうその男は先生が一生懸命に介抱してやったにもかかわらず、だんだん気息が細って死んでしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はほとんど衝動的にその場にうずくまって、胸をかがめて、膝頭に押しつけるようにして、なるべく軽く咳をせこうと勉めたが、胸の中から破裂するようにつきあげてくる力には容易に勝てないで、二三十度も続けさまに重い気息をはげしく吐きださねばならなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「背中をさすってくれ」　清逸はきれぎれな気息の中からそういった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は思いきって芯を下げてからホヤの口に気息をふきこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬さんの気息はいつものように酒くさかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいさんはほっと小さく気息をついた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつ私はその人に見られていたんだろう」と思うと、怖ろしさと無気味さに気息がとまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの不意に思わず気息を引くと、迸る様に鋭く動悸が心臓を衝くのを感じた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意の驚きに気息を引いた子供が懸命になつて火のつくやうに「マヽ……マヽ……パヽ……もうしません……もうしないよう……」と泣き出した時には、彼はもう寝室の唐戸を足で蹴明けて廊下に出てゐた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは子供の育て方を何んだと思つてるんだ」　気息がはずんで二の句がつげない。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまやかしてゐればそれですむんぢやないんだ――」　彼は又気息をついた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んだか搾りつけられるやうに胸がせまつて来ると、止めても／＼気息がはずんで、火のやうに熱い涙が二粒三粒ほてり切つた頬を軽くくすぐるやうにたら／＼と流れ下つたと思ふと、たまらなくなつて無我夢中にわつと泣き伏した。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔父さん、今、今」　と気息をはずまして居る。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴吉の店にかけこんで来た姉は前後も乱れた話振りで、気息をせき／＼是れだけの事を鶴吉に話した。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末は苦しみに背中を大波のやうに動かしながら、はつ／＼と熱い気息を吐いて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十　赤城様――得三様　普門品、大悲の誓願を祈念して、下枝は気息｜奄々と、無何有の里に入りつつも、刀尋段々壊と唱うる時、得三は白刃を取直し、電光｜胸前に閃き来りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠等が炎熱を冒して、流汗面に被り、気息｜奄々として労役せる頃、高楼の窓半ば開きて、へいげん帷を掲げて白皙の面を露し、微笑を含みて見物せり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は我が背後で微に物の動く気息を聞いたので、何心なく顧ると、驚くべし彼のお杉｜婆は手に磨ぎ澄したる小刀を振翳して、あわや彼を突かんとしているのであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十一）　この時、背後の方から不意に物の気息が聞えて、何者か忍び寄るようにも思われたので、市郎は手早く蝋燭を把って起上ると、余りに慌てたので、彼は父の死骸に蹉いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には雪を踏む跫音ががさがさと聞えて、雨戸の外へ何者か窺い寄るような気息を感じた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は猶能く其顔を見届けようと、朧の雪明を便宜に凝と見詰めている時、忽ち我が背後に方って物の気息を聴いたので、忠一は驚いて屹と顧ると、物の音は又｜止んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中は長い廊下、真闇の中で何やら摺違つたやうな物の気息がする、之と同時に何とは無しに後へ引戻されるやうな心地がした。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
