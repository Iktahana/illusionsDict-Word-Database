    "definitions": [
      {
        "index": 1,
        "gloss": "to notice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「自分の知人Ａ、Ｂ、Ｃの三人が同じ市の同じ町に住まっている事を、年賀状をより分けてみて始めて気がつく。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうあたりまえのことにひょいと気がつくと何とも知れない涙が眼の奥から浸潤み出るのだ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭吉氏の芸術に接した人は、そのありとあらゆる線が、無気味にも悉く「性慾の嘆き」を語つて居る事に気がつくであらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日お前を訪ねて此処へ来るそうだ」　「だから今夜の中にたってしまえば、まさか吉兵衛の奴も、気がつくめえと思うンだ」（ＷＩＰＥ）Ｓ＝奥座敷（前のシーンと同じ）　石松、大分飲んだ後の感じです。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フト武蔵の居ないのに気がつく。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくとその路を自分は今夜三回も通っていた。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、僕は気がつくのであった。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護長の苦々しげな笑いに気がつく余裕さえ上等兵には無いようだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ気がつくや、私も声を優しゅうして、「本を読んでいるのだよ。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだほうが幸福だよ……」　私に気がつくや、「ね、先生。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じようにわれわれはまた俳句というものの中に流れている俳句的精神といったようなものの源泉を、その詩型の底にもぐり込んで追究して行くと、その水脈のようなものは意外に広く遠い所に根を引いているのに気がつくであろう。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桐の花咲くころ」はこれまでの風景に比べて黄赤色が減じて白と黒とに分化している事に気がつく。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ女は好い面の皮で、さぞ怨んでいるだろうよ」「二人が心中だという確かな証拠があるんでしょうか」「女の書置が見付かったから間違いもあるめえ」　云いかけてふと気がつくと、お登久の涼しい眼には涙がいっぱいに溜っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、源作は、小川に気がつくと答えた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうやって毎夜おそく湯へ下りてゆくのがたび重なるとともに、私は自分の恐怖があるきまった形を持っているのに気がつくようになった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい俺は今夜あの男をどうするつもりだったんだろう」　生島は崖路の闇のなかに不知不識自分の眼の待っていたものがその青年の姿であったことに気がつくと、ふと醒めた自分に立ち返った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はだんだん呼吸が切迫して来る自分に気がつく。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりしていて、それが他所の子の泣声だと気がつくまで、死んだ妹の声の気持がしていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと綿で包んだような音がかすかにしている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと、白い猫が一匹、よその家の軒下をわたって行った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと男滝の方はどうどうと地響打たせて。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめては狩衣か、相成るべくは、緋縅の鎧……と気がつくと、暑中伺ひに到来の染浴衣に、羽織も着ず、貝の口も横つちよに駕籠すれして、もの欲しさうに白足袋を穿いた奴が、道中つかひ古しの蟹目のゆるんだ扇子では峠下の木戸へ踞んで、秋田口の観光客を――入らはい、と口上を言ひさうで、照覧あれは事をかしい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲が最も科学的と思う事が乙には工業的に思われたり、乙が最も科学的と考えることが甲には最も非科学的な遊戯と思われたりするという意外な事実に気がつくであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って私の冷静なるべき客観的紹介の態度は、往々にしてはなはだしく取り乱され、私の筆端は強い主観的のにおいを発散していることに気がつく。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばＡかＢかのほかには何物も有り得ないという仮定のもとに或る人間の問題を取り扱っている際に、ある物質界の現象を学ぶことによって忽然として、他にＣの可能性の存在を忘却していたということに気がつくことがしばしば有りうるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには妙なゆらゆらした光った線や薄暗い線が不規則な模様のようになって、それがゆるやかに動いているのに気がつくでしょう。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと、曲は終っている。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとはまた別のことであるが昇降機の二つ三つ並んでいる前に立って、扉の上にあるダイアルに示された各機の時々刻々の位置の分布を注意して見ていると一つの顕著な事実に気がつく。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生とは何かなどという問題は、世界をすっかり見た上でなければうっかり持ち出せない問題だということは、こんな映画を見ても気がつくであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語の筋はむしろ簡単であるが、途中に插入されたいろいろのエピソードで「映画的内容」がかなり豊富にされているのに気がつく。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
