    },
    "definitions": [
      {
        "index": 1,
        "gloss": "former capital region (i.e. Kyoto and its environs)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし仮りに「来る六、七月の頃、東京地方に破壊的地震あるべし」との予報が科学的になし得られたりと仮定せよ。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち東京地図を懐中にして、本所深川の知らない町や、浅草、麻布、赤坂などの隠れた裏町を探して歩く。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其一人は法學士となつて今は東京地方裁判所の判事をして居ます。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の飛行機が日光へ向った同じ午前に、一方では、波多野中尉が一名の兵卒をつれて、同じく冒険的に生命をとして大阪に飛行し、はじめて東京地方の惨状の報告と、救護その他軍事上の重要命令を第四師団にわたし、九時間二十分で往復して来ました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康恢復と同時に、自らの働きをもって生活するの必要に迫られ、中央局通信事務員、河口鉄工場職工、東京地方裁判｜所雇、その他二三を転々として、東京市水道拡張課の土木監督となり、震災と同時に失職。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央気象台へ電話を掛けて、昨晩の東京地方の気象を問い合せて下さい」　喬介の命ずるままに六階へ降りた私は、其処の電話室で任務を済ますと、結果をノートへ記入して再び屋上へ帰って来た。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて――」　喬介は、先程私の渡したノートに眼を遣り、「午前零時から二時半までに、東京地方を通過している753粍の低気圧と西南の強風は、バルーンを垂直上昇線から東北方へ押し出します。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京地検局から伊尾検事以下も急行したが、最初の死体はネクタイか手拭で絞殺したものと見られ、ネズミが食い散らしてあり、後に発見された死体もトビが喰い散らした形跡があって人相その他は全然判らないが、いずれも両足を開いている……』「――ちょっと！",
              "citation": {
                "source": "探偵会話　下駄を探せ",
                "author": "――芝公園　女の殺人事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに近頃、東京地方では、地震が頻発しているが、これもその前徴の一つである」「気温が高いということは、氷河期とは、ぜんぜん反対の現象のように思いますが、いかがですか。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "物心がついてからずつと東京に住んだ私にとつては、一片の東京地圖は、實に有機的な私の人文科學史です。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京から遠い温泉の旅籠で、偶然東京地圖など披いて見る事がある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅くも来月の十日頃までには、一同京地を引き払うことになるであろう。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に云うとこわいもの見たさのような気もあって○○○さんと一緒に東京地方裁判所へ出かけました。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京地図を畳んだり拡げたりして、今日見て歩くところを目算立てしていた鶴二は、気がいらいらしてきたように懐中時計を見ては、しきりに待ち遠しがっていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "（たとえば「コップ」東京地方協議会署名にかかる同志小林労農葬のビラ。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、かつて『平民新聞』に記載したクロポトキン翁の「青年に訴う」というのが政府の忌諱にふれたので、先月の末に東京地方裁判所で、秩序壊乱の廉とかによって軽禁錮一カ月半の宣告を下されたのであります。",
              "citation": {
                "source": "お別れ",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さる十月二十七日に石川検事が東京地検の三階の会議室で、検察事務官に対する刑事訴訟法の講義において次の如き三鷹事件に対する検事の方針がのべられている」とその内容を明かにした点である。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上昭和十年一月唯物論研究会事務長　戸坂潤東京地方裁判所検事局検事宛",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京地図などが持ち出されるのは、大抵従弟で、戦争を実地に経験して来たような客のある晩であった。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことから、どれ、東京地図あるかい、という調子で地図が出され、その地図を開いてテーブルの上にひろげ、両膝をついて先ずのり出して来るのは九歳の太郎であった。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妻よねむれ」にしろ「私の東京地図」にしろ、「播州平野」「風知草」ことごとく、その種のモティーヴに立ち、作品の本質も戦争による人民生活の破壊、治安維持法が行って来た非人間的な抑圧への抗議であった。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐多稲子は「私の東京地図」をもって新しい出発に踏みだした。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の東京地図」と「女作者」「虚偽」「泡沫の記録」などをよみあわせたとき、二十年前に「キャラメル工場から」を書き、プロレタリア文学の歴史に一定の業績をのこしているこの作家が、複雑な良心の波にゆすられながら、民主主義の婦人作家として自身に課している努力を理解することができる。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが事件の十五日夜アリバイがはっきりしているために「やや焦燥の色濃い東京地検堀検事正、馬場次席検事は」「教唆罪もあり得る」と語っている（七月十九日『東京新聞』）。",
              "citation": {
                "source": "犯人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分というものに与えられた人間的可能を伸ばしひろげようとする熱心に燃え、女の消極を克服することに精魂を傾けて来た彼女は、連続した「私の東京地図」を第四回発表している。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の東京地図」で、作者は、今日の日本の社会と今日の自身の生活と、このかつてのたたかいの跡である地域の思い出とを、明日へのどういう能動の方向で結び合わせようとしているのだろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小祝の一家」が雑誌『文芸』に発表されて程なく、一九三三年十二月二十六日宮本顕治は東京地方委員会のキャップをしていたスパイに売られて検挙された。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京地は勿論、府藩県に於て厳重探索を遂げ、且平常無油断取締方｜屹度可相立旨被仰出候事。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤枝真太郎とは、五年ほど前まで、鬼検事という名で、帝都の悪漢達に恐れられ憎まれていた、もとの藤枝東京地方裁判所検事の後身である。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ八月には、セン・マリ、セン・ルイの大祝日があるので、これを当てこんで何千本というえぞぎく、フクシア、きょうちくとうなどを温室や温床にはいりきらないほどしこんでおいた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
