        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この十種の覆面者のどれが１２３４５６７８９０のどれであるかを、これから推理でもつて探偵しようといふわけである。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十種の覆面者のどれが１２３４５６７８９０のどれであるかを、これから推理でもって探偵しようというわけである。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙船を管理する人工知能コンピューターＨＡＬ９０００は〈精神〉に異常をきたし、船長に回路モジュールをつぎつぎと引き抜かれ〈死〉に追いやられる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ４の縦長のディスプレイを採用していたアルトに対し、ブルーのあざやかな画面を横長（一〇二四×八〇〇ドット）にとったスターは、大きなデータの高速処理に適したビットスライス方式★のマイクロコンピューター、２９０１を採用して高度なグラフィックスの処理要求に応えようとしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社は一九七九（昭和五十四）年、テキサスインスツルメンツ製の一六ビットマイクロコンピューター、ＴＭＳ―９９００を使ったディスプレイ、フロッピーディスクドライブ一体型のＰＨＣ―３１００で市場に参入した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤ社からライセンスを受けてセカンドソースとして製造していた四ビットスライスのμＣＯＭ―２９００を担当した後藤は、このタイプのプロセッサーを使えば、コストは高くなるものの、アルトの子供をすぐに作れることを意識していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "８０だの９０だのと数字が変って行く度に、声に波がついた。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "１２３４５６７８９０・１２３４５６７８９・０１２３４５６７８・９０１２３４５６７・８９０１２３４５６・７８９０１２３４５・６７８９０１２３４・５６７８９０１２３・４５６７８９０１２・３４５６７８９０１・２３４５６７８９０・１２３４５６７８９０診断　０：１２６・１０・１９３１以上　責任医師　李箱",
              "citation": {
                "source": "診断　０：１",
                "author": "李箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "１９０１年　クリスマス　つるぎと　カツラが　まだ　あって、　コートの　すそが　長くて、　花がらの　ひらひらの　ついていた　むかし、　男の人も　ひだや　ふさの　ついた　きらびやかな　きぬの　チョッキを　きていた　むかしのこと、　グロスターに　ふくやさんが　おりました。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」１８９０　イースターの時節に１　しろウサギ　むかしむかし　アリスという　おんなのこが　いてね、　とっても　へんてこな　ゆめを　みたんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらが地上９階、地下３階、延べ床面積９００万平方メートルの敷地にゆったりと配置してある、西日本最大級と謳われていた。",
              "citation": {
                "source": "グローバルタワーにて",
                "author": "福永信",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十九日（木）推定脳細胞総数　１４９億３９００万個　一番ヶ瀬隼人は窓から差し込むうすくやわらかい日の光で目を覚し、毛布の中で陽子に思いを馳せながら二回マスターベーションに耽った後ようやくベッドから抜け出してシャワーを浴び、それが済むとオーブンにサンドイッチを入れてタイマーを５にセットした。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月三十日（金）推定脳細胞総数　１４９億３８９０万個　四谷からラッシュ時の中央線特別快速に乗り、終点の東京で丸ノ内の方へ降りる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "死去したのは９０歳のときであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "賛成の方は、署名をそえて、平和のための宣言委員会、３２３７ベンダ・ストリート、ロサンゼルス、カリフォルニア、９００２８に送ってください」　パン・アメリカン航空も、軍事輸送で莫大な利益をあげている事実を理由に、ボイコットの対象にあげられている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
