        "examples": {
          "standard": [
            {
              "text": "市場の反応は気乗り薄で、新製品の予約数は予想を大きく下回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "買収の提案を持ちかけたが、相手企業の役員会は気乗り薄な態度を崩さなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲が盛り上がる中で、彼一人だけが気乗り薄な表情で窓の外を眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "再開発計画の説明会が開かれたが、住民たちの反応は終始気乗り薄なものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "駒子は母と姉が殆ど気乗り薄にこの邸へ同行してきたことを知らなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが第一に肝心の内政会議に出席した閣僚自身が気乗り薄だというから如何にお手軽でも実行されないかも知れない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」と、相かわらず仲達は気乗り薄な顔つきである。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
