[
  {
    "uuid": "db7b8281-6a9c-552a-9726-9cacd93ad742",
    "entry": "起算",
    "reading": {
      "primary": "きさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
