        "examples": {
          "standard": [
            {
              "text": "テレビ放送をキネスコープで記録する時代があったと、古い資料で読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのモノクロドラマは、キネスコープでしか残っていない貴重な映像らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いテレビ番組のアーカイブには、キネスコープで保存された映像が多数ある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夕刻雨止みて一同にて手製の食事を終りブラッデイ氏邸へキネスコープの見物に赴く。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻雨止みて一同にて手製の食事を賑々しく終へたる後、ブラツデイ氏宅へキネスコープの見物に赴く。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
