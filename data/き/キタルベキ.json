[
  {
    "uuid": "e72fe853-cbe4-5e67-9328-803bfd6cd68a",
    "entry": "来るべき",
    "reading": {
      "primary": "きたるべき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
