[
  {
    "uuid": "ee8d86a6-f01a-523c-8caf-8624d550fc26",
    "entry": "凶報",
    "reading": {
      "primary": "きょうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
